{"tag":"section","attrib":{"id":"idb8f035ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349"},"text":null,"children":[{"tag":"num","attrib":{"value":"8349"},"text":"§ 8349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset relating to certain benefits under the Social Security Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f035bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f035bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this subchapter, if an individual under section 8402(b)(2) is entitled, or would on proper application be entitled, to old-age insurance benefits under title II of the Social Security Act, the annuity otherwise payable to such individual shall be reduced under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A reduction under this subsection commences beginning with the first month for which the individual both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f035be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to an annuity under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled, or would on proper application be entitled, to old-age insurance benefits under title II of the Social Security Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f035c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f035c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to clause (ii) and subparagraphs (B) and (C), the amount of a reduction under this subsection shall be equal to the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8f035c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the old-age insurance benefit which would be payable to the individual for the month referred to in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f035c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the old-age insurance benefit which would be so payable, excluding all wages derived from Federal service of the individual, and assuming the individual were fully insured (as defined by section 214(a) of the Social Security Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f035c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the amount of a benefit referred to in subclause (I) or (II) of clause (i) shall be determined without regard to subsections (b) through (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of section 203 of the Social Security Act, and without regard to the requirement that an application for such benefit be filed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A reduction under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f035c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not exceed an amount equal to the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8f035c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the old-age insurance benefit to which the individual is entitled (or would on proper application be entitled) for the month referred to in paragraph (2), determined without regard to subsections (b) through (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of section 203 of the Social Security Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f035c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fraction, as determined under section 8421(b)(3) with respect to the individual, except that the reference to “service” in subparagraph (A) of such section shall be considered to mean Federal service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f035ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not cause the annuity payment for an individual to be reduced below zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An amount computed under subclause (I) or (II) of subparagraph (A)(i), or under subparagraph (B)(i)(I), for purposes of determining the amount of a reduction under this subsection shall be adjusted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8340"},"text":"section 8340 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A reduction under this subsection applies with respect to the annuity otherwise payable to such individual under this subchapter (other than under section 8337) for the month involved—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f035cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on service of such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to section 8345(j), if otherwise applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operation of the preceding paragraphs of this subsection shall not be considered for purposes of applying the provisions of the second sentence of section 215(a)(7)(B)(i) or the provisions of section 215(d)(5)(ii) of the Social Security Act in determining any amount under subclause (I) or (II) of paragraph (3)(A)(i) or paragraph (3)(B)(i)(I) for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f035d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f035d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f035d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a disability annuity to which an individual described in section 8402(b)(2) is entitled under this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a survivor annuity to which a person is entitled under this subchapter based on the service of an individual described in section 8402(b)(2),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to reduction under this subsection if that individual or person is also entitled (or would on proper application also be entitled) to any similar benefits under title II of the Social Security Act based on the wages and self-employment income of such individual described in section 8402(b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f035d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), reductions under this subsection shall be made in a manner consistent with the manner in which reductions under subsection (a) are computed and otherwise made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reductions under this subsection shall be discontinued if, or for so long as, entitlement to the similar benefits under title II of the Social Security Act (as referred to in paragraph (1)) is terminated (or, in the case of an individual who has not made proper application therefor, would be terminated).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of applying section 224 of the Social Security Act to the disability insurance benefit used to compute the reduction under this subsection, the amount of the CSRS annuity considered shall be the amount of the CSRS annuity before application of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall prescribe regulations to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f035d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “Federal service” means service which is employment for the purposes of title II of the Social Security Act and chapter 21 of the Internal Revenue Code of 1986 by reason of the amendments made by section 101 of the Social Security Amendments of 1983.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f035da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In administering subsections (a) through (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f035db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the terms “an individual under section 8402(b)(2)” and “an individual described in section 8402(b)(2)” shall each be considered to include any individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f035dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is subject to this subchapter as a result of any provision of law described in section 8347(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f035dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose employment (as described in section 8347(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")) is also employment for purposes of title II of the Social Security Act and chapter 21 of the Internal Revenue Code of 1986; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8349/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal service”, as applied with respect to any individual to whom this section applies as a result of paragraph (1), means any employment referred to in paragraph (1)(B) performed after ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f035df-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tII/s201/b/1"},"text":"Pub. L. 99–335, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/589"},"text":"100 Stat. 589","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s108/b/2"},"text":"Pub. L. 100–238, title I, § 108(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1748"},"text":"101 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8f035e0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8f035e1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8f035e2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II of the Social Security Act is classified generally to subchapter II (§ 401 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. Sections 203, 214, 215, and 224 of the Social Security Act are classified to sections 403, 414, 415, and 424a, respectively, of Title 42. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Chapter 21 of the Internal Revenue Code of 1986, referred to in subsecs. (c) and (d)(1)(B), is classified to chapter 21 (§ 3101 et seq.) of Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101 of the Social Security Amendments of 1983 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/21"},"text":"Pub. L. 98–21","children":[],"tail":"], referred to in subsec. (c), amended "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3121"},"text":"section 3121 of Title 26","children":[],"tail":" and sections 409 and 410 of Title 42, The Public Health and Welfare, and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3121"},"text":"section 3121 of Title 26","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"section 410 of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8f035e3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8f035e4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/s108/b/3"},"text":"section 108(b)(3) of Pub. L. 100–238","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334"},"text":"section 8334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8f035e5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8f035e6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8f035e7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Offsets To Prevent Full Double Coverage for Employees of Park Police and Secret Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to offsets for prevention of full double coverage for employees of Park Police and Secret Service, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s103/e"},"text":"section 103(e) of Pub. L. 100–238","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334"},"text":"section 8334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
