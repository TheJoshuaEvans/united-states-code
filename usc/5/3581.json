{"tag":"section","attrib":{"id":"idb823223b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3581"},"text":null,"children":[{"tag":"num","attrib":{"value":"3581"},"text":"§ 3581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb823223c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3581/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb823223d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3581/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823223e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3581/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823223f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3581/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employing authority in the legislative branch;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232240-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3581/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an employee in or under an agency;","children":[],"tai