dren":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656"},"text":"Pub. L. 91–656","children":[],"tail":" substituted “duty at remote worksites” for “duty on California offshore islands or at Nevada Test Site” in section catchline and assignment to duty “at a site so remote from the nearest established communities or suitable places of residence as to require an appreciable degree of expense, hardship, and inconvenience, beyond that normally encountered in metropolitan commuting, on the part of the employee in commuting to and from his residence and such worksite” for assignment to duty “on one of the California offshore islands or at the United States Atomic Energy Commission Nevada Test Site, including the Nuclear Rocket Development Station”, inserted reference to employee “of an Executive department or an independent establishment” and provision for designation by regulation of sites to which the rates apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb88e66b8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88e66b9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1971 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/656/s6/b"},"text":"Pub. L. 91–656, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1954"},"text":"84 Stat. 1954","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/656/s6/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":", United States Code, and the amendment made by subsection (a) of this section [amending this section], and until the effective date of regulations prescribed by the President under such amendment—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowances may be paid to employees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5942"},"text":"section 5942 of title 5","children":[],"tail":", United States Code, and the regulations prescribed by the President under such section, as in effect immediately prior to the effective date of this section ["},{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such regulations may be amended or revoked in accordance with such section 5942 as in effect immediately prior to the effective date of this section [","children":[{"tag":"date","attrib":{"date":"1971-01-08"},"text":"Jan. 8, 1971","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88e66ba-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Increase in Allowance Based on Duty at Remote Worksites","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1116"},"text":"Pub. L. 117–81, div. A, title XI, § 1116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1955"},"text":"135 Stat. 1955","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dA/tXI/s1116"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment and Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-03-31"},"text":"March 31, 2022","children":[],"tail":", the Director of the Office of Personnel Management shall complete an assessment of the remote site pay allowance under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5942"},"text":"section 5942 of title 5","children":[],"tail":", United States Code, and propose a new rate of such allowance, adjusted for inflation, and submit such assessment and rate to the President and to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the first day of the first pay period beginning after the date the Director submits the assessment and rate under subsection (a), such rate shall, notwithstanding subsection (a) of such section 5942, be the rate of such allowance.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb88e66bb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb88e66bc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section to prescribe regulations establishing rates at which an allowance based on duty (except temporary duty) at remote worksites will be paid and defining and designating sites, areas, and groups of positions to which rates apply delegated to Office of Personnel Management, see section 8(3) of Ex. Ord. No. 11609, ","children":[{"tag":"date","attrib":{"date":"1971-07-22"},"text":"July 22, 1971","children":[],"tail":", 36 F.R. 13747, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
