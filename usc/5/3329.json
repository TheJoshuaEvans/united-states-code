{"tag":"section","attrib":{"id":"idb8125984-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329"},"text":null,"children":[{"tag":"num","attrib":{"value":"3329"},"text":"§ 3329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments of military reserve technicians to positions in the competitive service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8125985-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “military reserve technician” has the meaning given the term “military technician (dual status)” by section 8401(30).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8125986-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall take such steps as may be necessary to ensure that, except as provided in subsection (d), any military reserve technician who is involuntarily separated from technician service, after completing at least 15 years of such service and 20 years of service creditable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of title 10","children":[],"tail":", by reason of ceasing to satisfy the condition described in section 8401(30)(B) "},{"tag":"ref","attrib":{"idref":"fn002057"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall, if appropriate written application is submitted within 1 year after the date of separation, be provided placement consideration in a position described in subsection (c) through a priority placement program of the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8125987-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8125988-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The position for which placement consideration shall be provided to a former military technician under subsection (b) shall be a position—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8125989-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in either the competitive service or the excepted service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb812598a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb812598b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the person is qualified to serve, taking into consideration whether the employee in that position is required to be a member of a reserve component of the armed forces as a condition of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb812598c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent practicable, the position shall also be in a pay grade or other pay classification sufficient to ensure that the rate of basic pay of the former military technician, upon appointment to the position, is not less than the rate of basic pay last received by the former military technician for technician service before separation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812598d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section shall not apply in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb812598e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an involuntary separation for cause on charges of misconduct or delinquency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb812598f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a technician who, as of the date of application under this section, is eligible for immediate (including for disability) or early retirement under subchapter III of chapter 83 or under chapter 84.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8125990-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3329/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall, in consultation with the Director of the Office of Personnel Management, prescribe such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8125991-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tV/s544/a"},"text":"Pub. L. 102–484, div. A, title V, § 544(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2415"},"text":"106 Stat. 2415","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1037/a"},"text":"Pub. L. 104–106, div. A, title X, § 1037(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/431"},"text":"110 Stat. 431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tXI/s1103"},"text":"Pub. L. 105–85, div. A, title XI, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1923"},"text":"111 Stat. 1923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(f)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–293.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8125992-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8125993-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8125994-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401/30"},"text":"Section 8401(30) of this title","children":[],"tail":", referred to in subsecs. (a) and (b), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s522/c/2"},"text":"Pub. L. 106–65, div. A, title V, § 522(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/597"},"text":"113 Stat. 597","children":[],"tail":", and, as so amended, no longer contains a subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb8125995-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 3329 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3330"},"text":"section 3330 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8125996-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(f)(1)(A)], substituted “the term ‘military technician (dual status)’ ” for “such term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1087(f)(1)(B)], substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12732"},"text":"section 12732 of title 10","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1332"},"text":"section 1332 of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" struck out “a position described in subsection (c) not later than 6 months after the date of the application” after “program of the Department of Defense”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1037/a/1"},"text":"Pub. L. 104–106, § 1037(a)(1)","children":[],"tail":", substituted “be provided placement consideration in a position described in subsection (c) through a priority placement program of the Department of Defense” for “be offered”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1037/a/2"},"text":"Pub. L. 104–106, § 1037(a)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which read as follows: “The position to be offered shall be a position—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) in the competitive service;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) within the Department of Defense;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) for which the individual is qualified; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) the rate of basic pay for which is not less than the rate last received for technician service before separation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
