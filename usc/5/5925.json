{"tag":"section","attrib":{"id":"idb88bf64f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5925"},"text":null,"children":[{"tag":"num","attrib":{"value":"5925"},"text":"§ 5925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post differentials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb88bf650-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A post differential may be granted on the basis of conditions of environment which differ substantially from conditions of environment in the continental United States and warrant additional pay as a recruitment and retention incentive. A post differential may be granted to an employee officially stationed in the United States who is on extended detail in a foreign area. A post differential under this subsection may not exceed 35 percent of the rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb88bf651-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee granted a differential under subsection (a) of this section may be granted an additional differential for an assignment to a post determined to have especially adverse conditions of environment which warrant additional pay as a recruitment and retention incentive for the filling of positions at that post. An additional differential for any employee under this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88bf652-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5925/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be paid for each assignment to a post determined to have such conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88bf653-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5925/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be paid periodically or in a lump sum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88bf654-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5925/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed 15 percent of the rate of basic pay of that employee for the period served under that assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb88bf655-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/512"},"text":"80 Stat. 512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2309"},"text":"Pub. L. 96–465, title II, § 2309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2165"},"text":"94 Stat. 2165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s591/a"},"text":"Pub. L. 108–199, div. D, title V, § 591(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/207"},"text":"118 Stat. 207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/140/s4/b"},"text":"Pub. L. 109–140, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-22"},"text":"Dec. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2651"},"text":"119 Stat. 2651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb88bf656-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb88bf657-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb88bf658-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s3038"},"text":"5 U.S.C. 3038","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/707/s231"},"text":"Pub. L. 86–707, § 231","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/795"},"text":"74 Stat. 795","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the last sentence, the words “Additional compensation paid as” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb88bf659-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb88bf65a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/140"},"text":"Pub. L. 109–140","children":[],"tail":" struck out “25 percent of the rate of basic pay or, in the case of an employee of the United States Agency for International Development,” after “may not exceed” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Pub. L. 108–199","children":[],"tail":" inserted “or, in the case of an employee of the United States Agency for International Development, 35 percent of the rate of basic pay” after “25 percent of the rate of basic pay”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" designated existing provisions as subsec. (a), inserted “under this subsection” before “may not exceed”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb88e665b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88e665c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s591/c"},"text":"Pub. L. 108–199, div. D, title V, § 591(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/207"},"text":"118 Stat. 207","children":[],"tail":", which provided that except for employees of the United States Agency for International Development stationed in Iraq and Afghanistan, the amendments made by subsections (a) and (b), amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5928"},"text":"section 5928 of this title","children":[],"tail":", would not take effect until the same authority was enacted for employees of the Department of State, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/140/s4/a"},"text":"Pub. L. 109–140, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-22"},"text":"Dec. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2651"},"text":"119 Stat. 2651","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88e665d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88e665e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Criteria","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/140/s4/d"},"text":"Pub. L. 109–140, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-22"},"text":"Dec. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2651"},"text":"119 Stat. 2651","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/140/s4/d"},"text":"“The Secretary of State shall inform the Committee on International Relations [now Committee on Foreign Affairs] of the House of Representatives and the Committee on Foreign Relations of the Senate of the criteria to be used in determinations of appropriate adjustments in post differentials under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5925/a"},"text":"section 5925(a) of title 5","children":[],"tail":", United States Code, as amended by subsection (b), and danger pay allowances under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5928"},"text":"section 5928 of title 5","children":[],"tail":", United States Code, as amended by subsection (c).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88e665f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Extension of Foreign Post Differentials to Certain Federal Employees Who Served in Connection With Operation Desert Storm","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1093"},"text":"Pub. L. 102–190, div. A, title X, § 1093","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1487"},"text":"105 Stat. 1487","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tX/s1093"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Requirement That Employee Be Detailed to A Post for an ‘Extended’ Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who performed service of a type described in subsection (b) shall, upon appropriate written application, be granted the total amount to which such individual would have been entitled for such service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5925/a"},"text":"section 5925(a) of title 5","children":[],"tail":", United States Code, disregarding any eligibility requirement relating to the minimum period of time for which an individual must serve at, or be detailed to, a post."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of Service Involved","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies with respect to any period of service if, or to the extent that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it was performed as an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with Operation Desert Storm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the Persian Gulf conflict;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a post within the area designated by the President, in Executive Order 12744 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s112"},"text":"26 U.S.C. 112","children":[],"tail":" note], as a ‘combat zone’ for purposes of section 112 of the Internal Revenue Code of 1986 ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s112"},"text":"26 U.S.C. 112","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while a differential under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5925/a"},"text":"section 5925(a) of title 5","children":[],"tail":", United States Code, was authorized with respect to such post; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no differential under such section 5925(a) was granted to such employee for such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may prescribe any regulations necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘employee’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5921/3"},"text":"section 5921(3) of title 5","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Operation Desert Storm’ has the meaning given such term by section 3(1) of the Persian Gulf Conflict Supplemental Authorization and Personnel Benefits Act of 1991 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25"},"text":"Pub. L. 102–25","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"10 U.S.C. 101","children":[],"tail":" note); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Persian Gulf conflict’ means the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-08-02"},"text":"August 2, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1991-06-02"},"text":"June 2, 1991","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
