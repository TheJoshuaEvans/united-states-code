{"tag":"section","attrib":{"id":"idb8827fcc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5709"},"text":null,"children":[{"tag":"num","attrib":{"value":"5709"},"text":"§ 5709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air evacuation patients: furnished subsistence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, and under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5707"},"text":"section 5707 of this title","children":[],"tail":", an employee and his dependents may be furnished subsistence without charge while being evacuated as a patient by military aircraft of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8827fcd-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/481/s1/1"},"text":"Pub. L. 91–481, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-21"},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1081"},"text":"84 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
