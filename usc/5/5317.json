te":"1994-12-12"},"text":"Dec. 12, 1994","children":[],"tail":", 59 F.R. 64551; Ex. Ord. No. 13063, "},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"Sept. 30, 1997","children":[],"tail":", 62 F.R. 51757, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5317"},"text":"Section 5317 of Title 5","children":[],"tail":" of the United States Code it is hereby ordered as follows:"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb852bd3e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1–1. ","children":[{"tag":"inline","attrib":{},"text":"Executive Schedule Positions","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"1–101. The following positions are placed in level IV of the Executive Schedule:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) Counselor to the Secretary, Department of the Treasury.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Deputy Under Secretary for International Labor Affairs, Department of Labor.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) Administrator, Alcohol, Drug Abuse and Mental Health Administration, Department of Health and Human Services.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) Executive Secretary of the National Security Council.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e) Administrator, Office of Juvenile Justice and Delinquency Prevention, Department of Justice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(f) Comptroller of the Department of Defense [now Under Secretary of Defense (Comptroller)].","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(g) Assistant Secretary of the Air Force (1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(h) Director, Office for Victims of Crime, Department of Justice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) Director, Bureau of Justice Assistance, Department of Justice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(j) Director of the National Institutes of Health.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(k) Members, Chemical Safety and Hazard Investigation Board (5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(k)[(l)] Commissioner on Aging [now Assistant Secretary for Aging], Department of Health and Human Services[.]","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1–102. The following positions are placed in level V of the Executive Schedule:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) Deputy Assistant Secretary of Defense for Reserve Affairs, Department of Defense.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Executive Assistant and Counselor to the Secretary of Labor, Department of Labor.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) Deputy Under Secretary for Education, Department of Education.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) Deputy Under Secretary for Education, Department of Education.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e) Commissioner, Administration for Native Americans[.]","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb852bd3f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1–2. ","children":[{"tag":"inline","attrib":{},"text":"General Provisions","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"1–201. Nothing in this Order shall be deemed to terminate or otherwise affect the appointment, or to require the reappointment, of any occupant of any position listed in Section 1–1 of this Order who was the occupant of that position immediately prior to the issuance of this Order.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1–202. Executive Order No. 12076, as amended, is hereby revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
