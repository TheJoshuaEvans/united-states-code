{"tag":"section","attrib":{"id":"idb89f0923-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364"},"text":null,"children":[{"tag":"num","attrib":{"value":"6364"},"text":"§ 6364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Leave Bank Boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89f0924-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f0925-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency that establishes a leave bank shall establish a Leave Bank Board consisting of 3 members, at least one of whom shall represent a labor organization or employee group, to administer the leave bank under the provisions of this subchapter, in consultation with the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f0926-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may establish more than 1 Leave Bank Board based upon the administrative units within the agency. No more than 1 board may be established for each leave bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f0927-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each such Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f0928-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and approve applications to the leave bank under section 6367;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f0929-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor each case of a leave recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f092a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the amount of leave in the leave bank and the number of applications for use of leave from the bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f092b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6364/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an adequate amount of leave in the leave bank to the greatest extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f092c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2839"},"text":"102 Stat. 2839","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
