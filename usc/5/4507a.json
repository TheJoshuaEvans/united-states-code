{"tag":"section","attrib":{"id":"idb82f08f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4507a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4507a"},"text":"§ 4507a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awarding of ranks to other senior career employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82f08f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4507a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section, the term “senior career employee” means an individual appointed to a position classified above GS–15 and paid under section 5376 who is not serving—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f08f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4507a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a time-limited appointment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f08fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4507a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a position that is excepted from the competitive service because of its confidential or policy-making character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f08fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4507a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency employing senior career employees shall submit annually to the Office of Personnel Management recommendations of senior career employees in the agency to be awarded the rank of Meritorious Senior Professional or Distinguished Senior Professional, which may be awarded by the President for sustained accomplishment or sustained extraordinary accomplishment, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f08fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4507a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recommendations shall be made, reviewed, and awarded under the same terms and conditions (to the extent determined by the Office of Personnel Management) that apply to rank awards for members of the Senior Executive Service under section 4507.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f08fd-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/67/tVI/s641/a"},"text":"Pub. L. 107–67, title VI, § 641(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/554"},"text":"115 Stat. 554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82f08fe-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82f08ff-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb82f0900-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–15, referred to in subsec. (a), is contained in the General Schedule, which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82f0901-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82f0902-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective for awards granted in 2003, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/67/s641/d"},"text":"section 641(d) of Pub. L. 107–67","children":[],"tail":", set out as an Effective Date of 2001 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4506"},"text":"section 4506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
