{"tag":"section","attrib":{"id":"idb8873b49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5733"},"text":null,"children":[{"tag":"num","attrib":{"value":"5733"},"text":"§ 5733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expeditious travel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The travel of an employee shall be by the most expeditious means of transportation practicable and shall be commensurate with the nature and purpose of the duties of the employee requiring such travel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8873b4a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s222/c/1"},"text":"Pub. L. 90–206, title II, § 222(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/641"},"text":"81 Stat. 641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b4b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873b4c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8873b4d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective thirty days after ","children":[{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s220/a/4"},"text":"section 220(a)(4) of Pub. L. 90–206","children