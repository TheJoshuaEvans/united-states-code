{"tag":"section","attrib":{"id":"idb7e04c8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014"},"text":null,"children":[{"tag":"num","attrib":{"value":"1014"},"text":"§ 1014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to National Academy of Sciences and National Academy of Public Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7e04c90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency may not use any advice or recommendation provided by the National Academy of Sciences or National Academy of Public Administration that was developed by use of a committee created by that academy under an agreement with an agency, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e04c91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee was not subject to any actual management or control by an agency or an officer of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a committee created after ","children":[{"tag":"date","attrib":{"date":"1997-12-17"},"text":"December 17, 1997","children":[],"tail":", the membership of the committee was appointed in accordance with the requirements described in subsection (b)(1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in developing the advice or recommendation, the academy complied with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e04c94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(2) through (6), in the case of any advice or recommendation provided by the National Academy of Sciences; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e04c95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(2) and (5), in the case of any advice or recommendation provided by the National Academy of Public Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e04c96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements referred to in subsection (a) are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e04c97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public notice regarding appointees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Academy shall determine and provide public notice of the names and brief biographies of individuals that the Academy appoints or intends to appoint to serve on the committee. The Academy shall determine and provide a reasonable opportunity for the public to comment on appointments before they are made or, if the Academy determines prior comment is not practicable, in the period immediately following the appointments. The Academy shall require that any individual the Academy appoints (or intends to appoint) to serve on the committee inform the Academy of the individual’s conflicts of interest that are relevant to the functions to be performed. The Academy shall make its best efforts to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e04c98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no individual appointed to serve on the committee has a conflict of interest that is relevant to the functions to be performed, unless such conflict is promptly and publicly disclosed and the Academy determines that the conflict is unavoidable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e04c99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee membership is fairly balanced as determined by the Academy to be appropriate for the functions to be performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e04c9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final report of the Academy will be the result of the Academy’s independent judgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public notice of committee meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Academy shall determine and provide public notice of committee meetings that will be open to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data-gathering meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Academy shall ensure that meetings of the committee to gather data from individuals who are not officials, agents, or employees of the Academy are open to the public, unless the Academy determines that a meeting would disclose matters described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of this title","children":[],"tail":". The Academy shall make available to the public, at reasonable charge if appropriate, written materials presented to the committee by individuals who are not officials, agents, or employees of the Academy, unless the Academy determines that making material available would disclose matters described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Academy shall make available to the public as soon as practicable, at reasonable charge if appropriate, a brief summary of any committee meeting that is not a data-gathering meeting, unless the Academy determines that the summary would disclose matters described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of this title","children":[],"tail":". The summary shall identify the committee members present, the topics discussed, materials made available to the committee, and other matters the Academy determines should be included."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Academy shall make available to the public its final report, at reasonable charge if appropriate, unless the Academy determines that the report would disclose matters described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of this title","children":[],"tail":". If the Academy determines that the report would disclose matters described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of this title","children":[],"tail":", the Academy shall make public an abbreviated version of the report that does not disclose those matters."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reviewers of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After publication of the final report, the Academy shall make publicly available the names of the principal reviewers who reviewed the report in draft form and who are not officials, agents, or employees of the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e04ca0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may issue regulations implementing this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e04ca1-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4205"},"text":"136 Stat. 4205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e04ca2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7e04ca3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7e04ca4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1014","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (FACA § 15)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/463/s15"},"text":"Pub. L. 92–463, § 15","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/105/153/s2/b"},"text":"Pub. L. 105–153, § 2(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 17, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/2689"},"text":"111 Stat. 2689","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the date “","children":[{"tag":"date","attrib":{"date":"1997-12-17"},"text":"December 17, 1997","children":[],"tail":"” is substituted for “the date of the enactment of the Federal Advisory Committee Act Amendments of 1997” for clarity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
