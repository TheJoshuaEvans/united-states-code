{"tag":"section","attrib":{"id":"idb863869f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5505"},"text":null,"children":[{"tag":"num","attrib":{"value":"5505"},"text":"§ 5505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monthly pay periods; computation of pay","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The pay period for an individual in the service of the United States whose pay is monthly or annual covers one calendar month, and the following rules for division of time and computation of pay for services performed govern:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86386a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A month’s pay is one-twelfth of a year’s pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86386a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A day’s pay is one-thirtieth of a month’s pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86386a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 31st day of a calendar month is ignored in computing pay, except that one day’s pay is forfeited for one day’s unauthorized absence on the 31st day of a calendar month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86386a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each day of the month elapsing before entering the service, one day’s pay is deducted from the first month’s pay of the individual.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This section does not apply to an employee whose pay is computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5504/b"},"text":"section 5504(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86386a4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/476"},"text":"80 Stat. 476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86386a5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86386a6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86386a7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s84"},"text":"5 U.S.C. 84","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1906-06-30/ch3914/s6"},"text":"June 30, 1906, ch. 3914, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/763"},"text":"34 Stat. 763","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-06-30/ch212/s604/c"},"text":"June 30, 1945, ch. 212, § 604(c)","children":[],"tail":" (2d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/59/303"},"text":"59 Stat. 303","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sta