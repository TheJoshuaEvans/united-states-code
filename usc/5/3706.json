{"tag":"section","attrib":{"id":"idb8256c4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706"},"text":null,"children":[{"tag":"num","attrib":{"value":"3706"},"text":"§ 3706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8256c4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Personnel Management shall, not later than April 30 and October 31 of each year, prepare and submit to the Committee on Government Reform of the House of Representatives and the Committee on Governmental Affairs of the Senate a semiannual report summarizing the operation of this chapter during the immediately preceding 6-month period ending on March 31 and September 30, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256c4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report shall include, with respect to the 6-month period to which such report relates—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8256c4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals assigned to, and the total number of individuals assigned from, each agency during such period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a brief description of each assignment included under paragraph (1), including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8256c4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the assigned individual, as well as the private sector organization and the agency (including the specific bureau or other agency component) to or from which such individual was assigned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the respective positions to and from which the individual was assigned, including the duties and responsibilities and the pay grade or level associated with each; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration and objectives of the individual’s assignment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Office considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256c53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A copy of each report submitted under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8256c54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be published in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made publicly available on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256c56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Office, agencies shall furnish such information and reports as the Office may require in order to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8256c57-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/tII/s209/c/1"},"text":"Pub. L. 107–347, title II, § 209(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2929"},"text":"116 Stat. 2929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8256c58-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8256c59-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb8256c5a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8256c5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
