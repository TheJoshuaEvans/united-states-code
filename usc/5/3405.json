{"tag":"section","attrib":{"id":"idb820b048-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3405"},"text":null,"children":[{"tag":"num","attrib":{"value":"3405"},"text":"§ 3405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb820b049-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, on the date of enactment of this chapter, there is in effect with respect to positions within an agency a collective-bargaining agreement which establishes the number of hours of employment a week, then this chapter shall not apply to those positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb820b04a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter shall not require part-time career employment in positions the rate of basic pay for which is fixed at a rate equal to or greater than the minimum rate payable under section 5376.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb820b04b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1057"},"text":"92 Stat. 1057","children":[],"tail":", § 3395; renumbered § 3405 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", (2)(C), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","child