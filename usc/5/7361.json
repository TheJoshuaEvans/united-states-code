{"tag":"section","attrib":{"id":"idb8b48c9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7361"},"text":null,"children":[{"tag":"num","attrib":{"value":"7361"},"text":"§ 7361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b48c9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall be responsible for developing, in cooperation with the President, with the Secretary of Health and Human Services (acting through the National Institute on Drug Abuse), and with other agencies, and in accordance with applicable provisions of this subchapter, appropriate prevention, treatment, and rehabilitation programs and services for drug abuse among employees. Such agencies are encouraged to extend, to the extent feasible, such programs and services to the families of employees and to employees who have family members who are drug abusers. Such programs and services shall make optimal use of existing governmental facilities, services, and skills.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 527 ","children":[{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–3"},"text":"42 U.S.C. 290ee–3","children":[],"tail":"), relating to confidentiality of records, and any regulations prescribed thereunder, shall apply with respect to records maintained for the purpose of carrying out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7361/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency shall, with respect to any programs or services provided by such agency, submit such written reports as the Office may require in connection with any report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7363"},"text":"section 7363 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48ca0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7361/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “agency” means an Executive agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b48ca1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tVI/s6002/a/1"},"text":"Pub. L. 99–570, title VI, § 6002(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-157"},"text":"100 Stat. 3207–157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b48ca2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b48ca3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8b48ca4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 527 of the Public Health Service Act, referred to in subsec. (b) and formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290ee–3"},"text":"section 290ee–3 of Title 42","children":[],"tail":", The Public Health and Welfare, was renumbered section 548 of that Act by "},{"tag":"ref","attrib":{"href":"/us/pl/100/77/tVI/s611/2"},"text":"Pub. L. 100–77, title VI, § 611(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/516"},"text":"101 Stat. 516","children":[],"tail":" and then omitted in the general revision of Part D of Subchapter III–A of Chapter 6A of Title 42 by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s131"},"text":"Pub. L. 102–321, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/366"},"text":"106 Stat. 366","children":[],"tail":". Provisions relating to the confidentiality of patient records are now classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290dd–2"},"text":"section 290dd–2 of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b48ca5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b48ca6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Educational Program for Federal Employees Relating to Drug and Alcohol Abuse","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tVI/s6003"},"text":"Pub. L. 99–570, title VI, § 6003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-159"},"text":"100 Stat. 3207–159","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/570/tVI/s6003"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management shall, in consultation with the Secretary of Health and Human Services, establish a Government-wide education program, using seminars and such other methods as the Director considers appropriate, to carry out the purposes prescribed in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under this section shall be designed to provide information to Federal Government employees with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the short-term and long-term health hazards associated with alcohol abuse and drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the symptoms of alcohol abuse and drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of any prevention, treatment, or rehabilitation programs or services relating to alcohol abuse or drug abuse, whether provided by the Federal Government or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confidentiality protections afforded in connection with any prevention, treatment, or rehabilitation programs or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any penalties provided under law or regulation, and any administrative action (permissive or mandatory), relating to the use of alcohol or drugs by a Federal Government employee or the failure to seek or receive appropriate treatment or rehabilitation services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter which the Director considers appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
