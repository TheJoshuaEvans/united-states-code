{"tag":"section","attrib":{"id":"idb81e674c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3403"},"text":null,"children":[{"tag":"num","attrib":{"value":"3403"},"text":"§ 3403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81e674d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency shall not abolish any position occupied by an employee in order to make the duties of such position available to be performed on a part-time career employment basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e674e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person who is employed on a full-time basis in an agency shall not be required to accept part-time employment as a condition of continued employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81e674f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1057"},"text":"92 Stat. 1057","children":[],"tail":", § 3393; renumbered § 3403, "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1226"},"text":"92 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb820b040-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb820b041-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb820b042-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
