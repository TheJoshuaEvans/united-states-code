{"tag":"section","attrib":{"id":"idb86114bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384"},"text":null,"children":[{"tag":"num","attrib":{"value":"5384"},"text":"§ 5384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance awards in the Senior Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86114be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86114bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage excellence in performance by career appointees, performance awards shall be paid to career appointees in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such awards shall be paid in a lump sum and shall be in addition to the basic pay paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of this title","children":[],"tail":" or any award paid under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4507"},"text":"section 4507 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86114c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No performance award under this section shall be paid to any career appointee whose performance was determined to be less than fully successful at the time of the appointee’s most recent performance appraisal and rating under subchapter II of chapter 43 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of a performance award under this section shall be determined by the agency head but may not be less than 5 percent nor more than 20 percent of the career appointee’s rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The aggregate amount of performance awards paid under this section by an agency during any fiscal year may not exceed the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86114c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 10 percent of the aggregate amount of basic pay paid to career appointees in such agency during the preceding fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86114c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to 20 percent of the average of the annual rates of basic pay paid to career appointees in such agency during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86114c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance awards paid by any agency under this section shall be based on recommendations by performance review boards established by such agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4314"},"text":"section 4314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" less than a majority of the members of any review board referred to in paragraph (1) shall be career appointees whenever making recommendations under such paragraph with respect to a career appointee. The requirement of the preceding sentence shall not apply in any case in which the Office of Personnel Management determines that there exists an insufficient number of career appointees available to comply with the requirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may issue guidance to agencies concerning the proportion of Senior Executive Service salary expenses that may be appropriately applied to payment of performance awards and the distribution of awards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86114cb-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s407/a"},"text":"Pub. L. 95–454, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1172"},"text":"92 Stat. 1172","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tIII/s302"},"text":"Pub. L. 98–615, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3217"},"text":"98 Stat. 3217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/136/tVI/s625/a"},"text":"Pub. L. 101–136, title VI, § 625(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-03"},"text":"Nov. 3, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/822"},"text":"103 Stat. 822","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tVI/s632/a"},"text":"Pub. L. 105–277, div. A, § 101(h) [title VI, § 632(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-480"},"text":"112 Stat. 2681–480","children":[],"tail":", 2681–523.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86114cc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86114cd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86114ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “10 percent” for “3 percent” in subpar. (A) and substituted “20 percent” for “15 percent” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/136"},"text":"Pub. L. 101–136","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s302/1"},"text":"Pub. L. 98–615, § 302(1)","children":[],"tail":", substituted “but may not be less than 5 percent nor more than 20 percent” for “but may not exceed 20 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s302/2"},"text":"Pub. L. 98–615, § 302(2)","children":[],"tail":", substituted provisions limiting the aggregate amount of performance awards paid under this section by an agency during any fiscal year to the greater of 3 percent of the aggregate basic pay of career appointees in that agency during the preceding fiscal year or 15 percent of the average of the annual rates of basic pay of such appointees during such fiscal year for provisions limiting the number of career appointees paid performance awards under this section during any fiscal year to 50 percent of the number of Senior Executive Service positions in such agency, except for an agency having less than 4 such positions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86114cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86114d0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/h/tVI/s632/b"},"text":"Pub. L. 105–277, div. A, § 101(h) [title VI, § 632(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-480"},"text":"112 Stat. 2681–480","children":[],"tail":", 2681–523, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/h/tVI/s632/b"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", or the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"], whichever is later.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86114d1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" effective following expiration of 90-day period beginning on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s307"},"text":"section 307 of Pub. L. 98–615","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb86114d2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb86114d3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Number of Performance Awards for Career Appointees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 306(c) of S. 2939, Ninety-seventh Congress, 2nd Session, as reported ","children":[{"tag":"date","attrib":{"date":"1982-09-22"},"text":"Sept. 22, 1982","children":[],"tail":", and incorporated by reference in "},{"tag":"ref","attrib":{"href":"/us/pl/97/276/s101/e"},"text":"Pub. L. 97–276, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-02"},"text":"Oct. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1189"},"text":"96 Stat. 1189","children":[],"tail":", to be effective as if enacted into law, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/276/s101/e"},"text":"“None of the funds appropriated by this Act or any other Act shall be used by any agency to pay performance awards in fiscal year 1983 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5384"},"text":"section 5384 of title 5","children":[],"tail":", United States Code, or any comparable personnel system established on or after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"October 13, 1978","children":[],"tail":", to more than 20 per centum of the number of Senior Executive Service or comparable personnel system positions in such agency: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That an agency with less than five Senior Executive Service employees or equivalent positions may grant one such performance award.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/51"},"text":"Pub. L. 97–51","children":[],"tail":", §§ 101(c), 124, "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/959"},"text":"95 Stat. 959","children":[],"tail":", 965."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/536/s101/c"},"text":"Pub. L. 96–536, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3167"},"text":"94 Stat. 3167","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/369/s101/c"},"text":"Pub. L. 96–369, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1352"},"text":"94 Stat. 1352","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/304/tIII/s303"},"text":"Pub. L. 96–304, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-08"},"text":"July 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/927"},"text":"94 Stat. 927","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
