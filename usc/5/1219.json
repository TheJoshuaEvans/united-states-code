{"tag":"section","attrib":{"id":"idb7ec32e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219"},"text":null,"children":[{"tag":"num","attrib":{"value":"1219"},"text":"§ 1219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ec32e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Special Counsel shall maintain and make available to the public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ec32e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of any noncriminal matters referred to the head of an agency under section 1213(c), together with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ec32e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the information transmitted to the head of the agency under section 1213(c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any report from the agency under section 1213(c)(1)(B) relating to the matter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, not otherwise prohibited by law, and consented to by the complainant, any comments from the complainant under section 1213(e)(1) relating to the matter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comments or recommendations of the Special Counsel under paragraph (3) or (4) of section 1213(e);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ec32ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of matters referred to heads of agencies under section 1215(c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ec32ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of matters referred to heads of agencies under subsection (e) of section 1214, together with certifications from heads of agencies under such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ec32ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports from heads of agencies under section 1213(g)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ec32f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1219/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Special Counsel shall take steps to ensure that any list or report made available to the public under this section does not contain any information the disclosure of which is prohibited by law or by Executive order requiring that information be kept secret in the interest of national defense or the conduct of foreign affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ec32f1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/13"},"text":"Pub. L. 101–12, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/29"},"text":"103 Stat. 29","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/h/2"},"text":"Pub. L. 115–91, div. A, title X, § 1097(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1624"},"text":"131 Stat. 1624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ec32f2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ec32f3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ec32f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “a list of noncriminal matters referred to heads of agencies under subsection (c) of section 1213, together with reports from heads of agencies under subsection (c)(1)(B) of such section relating to such matters;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
