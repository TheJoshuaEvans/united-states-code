{"tag":"section","attrib":{"id":"idb9224293-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8957"},"text":null,"children":[{"tag":"num","attrib":{"value":"8957"},"text":"§ 8957.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage of restored survivor or disability annuitants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A surviving spouse, disability annuitant, or surviving child whose annuity is terminated and is later restored, may continue enrollment in a dental benefits plan subject to the terms and conditions prescribed in regulations issued by the Office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9224294-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s2"},"text":"Pub. L. 108–496, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/4004"},"text":"118 Stat. 4004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9224295-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9224296-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9224297-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", and applicable to contracts that take effect with respect to the calendar year 2006, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/496/s7"},"text":"section 7 of Pub. L. 108–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
