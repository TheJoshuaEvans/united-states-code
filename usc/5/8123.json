":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s773/a"},"text":"5 U.S.C. 773(a)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s23"},"text":"Sept. 7, 1916, ch. 458, § 23","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/747"},"text":"39 Stat. 747","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1926-06-26/ch695/s3"},"text":"June 26, 1926, ch. 695, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/44/772"},"text":"44 Stat. 772","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-14/ch691/s208"},"text":"Oct. 14, 1949, ch. 691, § 208","children":[],"tail":" “Sec. 23(a)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/865"},"text":"63 Stat. 865","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (c), the words “duly qualified” in former sections 771 and 772 are omitted as unnecessary in view of the definition of “physician” in section 8101.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c) the words “fees for examinations” in former section 773(a) are substituted for “fees or examinations” since the word “or” was erroneously in the 1949 amendment. The words “any sum payable to the employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s771"},"text":"section 771 of this title","children":[],"tail":"” in former section 773(a) are omitted as unnecessary because the same provision appeared in former section 771, which is carried into subsection (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
