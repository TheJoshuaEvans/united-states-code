{"tag":"section","attrib":{"id":"idb89cbea1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329"},"text":null,"children":[{"tag":"num","attrib":{"value":"6329"},"text":"§ 6329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disabled veteran leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbea2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the 12-month period beginning on the first day of employment, any employee who is a veteran with a service-connected disability rated at 30 percent or more is entitled to leave, without loss or reduction in pay, for purposes of undergoing medical treatment for such disability for which sick leave could regularly be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbea3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbea4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The leave credited to an employee under subsection (a) may not exceed 104 hours.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbea5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any leave credited to an employee pursuant to subsection (a) that is not used during the 12-month period described in such subsection may not be carried over and shall be forfeited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbea6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbea7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to verify that leave credited to an employee pursuant to subsection (a) is used for treating a service-connected disability, such employee shall submit to the head of the employing agency certification, in such form and manner as the Director of the Office of Personnel Management may prescribe, that such employee used such leave for purposes of being furnished treatment for such disability by a health care provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbea8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an employee of an office of the legislative branch, the certification described in paragraph (1) shall be prescribed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbea9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of the House of Representatives, by the Committee on House Administration of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbeaa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of the Senate, by the Committee on Rules and Administration of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbeab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of any other office of the legislative branch, by the head of the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbeac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbead-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee” has the meaning given such term in section 2105, and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbeae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the United States Postal Service or the Postal Regulatory Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbeaf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421"},"text":"section 7421 of title 38","children":[],"tail":", an individual occupying a position listed in subsection (b) of such section;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbeb0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “service-connected” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101/16"},"text":"section 101(16) of title 38","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbeb1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “veteran” has the meaning given such term in section 101(2) of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbeb2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/75/s2/a"},"text":"Pub. L. 114–75, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/640"},"text":"129 Stat. 640","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/238/s2/a"},"text":"Pub. L. 115–238, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-07"},"text":"Sept. 7, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2450"},"text":"132 Stat. 2450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/364/s1/a"},"text":"Pub. L. 115–364, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5088"},"text":"132 Stat. 5088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89cbeb3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89cbeb4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89cbeb5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/364"},"text":"Pub. L. 115–364","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/238"},"text":"Pub. L. 115–238","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the term ‘employee’ has the meaning given such term in section 2105, and includes an officer or employee of the United States Postal Service or of the Postal Regulatory Commission;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89cbeb6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89cbeb7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/238/s2/b"},"text":"Pub. L. 115–238, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-07"},"text":"Sept. 7, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2450"},"text":"132 Stat. 2450","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/238/s2/b"},"text":"“With respect to a position listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421/b"},"text":"section 7421(b) of title 38","children":[],"tail":", United States Code, the amendment made by subsection (a) [amending this section] shall apply to any individual appointed to such a position on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-09-07"},"text":"Sept. 7, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb89cbeb8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/75/s2/c"},"text":"Pub. L. 114–75, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/641"},"text":"129 Stat. 641","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/75/s2/c"},"text":"“The amendments made by subsection (a) [enacting this section] shall apply with respect to any employee (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6329/d/1"},"text":"section 6329(d)(1) of title 5","children":[],"tail":", United States Code, as added by subsection (a)) hired on or after the date that is 1 year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89cbeb9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/364/s1/b"},"text":"Pub. L. 115–364, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5088"},"text":"132 Stat. 5088","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/364/s1/b"},"text":"“Not later than 9 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":"], the Committee on House Administration of the House of Representatives, the Committee on Rules and Administration of the Senate, and the head of each other office of the legislative branch shall prescribe regulations governing the application of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6329"},"text":"section 6329 of title 5","children":[],"tail":", United States Code, including the certification requirement under subsection (c) of such section, to employees of the House of Representatives, employees of the Senate, and employees of such office, respectively.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/75/s2/d"},"text":"Pub. L. 114–75, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/641"},"text":"129 Stat. 641","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/75/s2/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 9 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Personnel Management shall prescribe regulations with respect to the leave provided by the amendment in subsection (a) [enacting this section] for employees, but not including employees of the United States Postal Service or the Postal Regulatory Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Postmaster General shall prescribe regulations for such leave with respect to officers and employees of the United States Postal Service and the Postal Regulatory Commission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
