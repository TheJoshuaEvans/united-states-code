{"tag":"section","attrib":{"id":"idb90592f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e"},"text":null,"children":[{"tag":"num","attrib":{"value":"8440e"},"text":"§ 8440e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the uniformed services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90592f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90592f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “basic pay” means basic pay payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of title 37","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “full TSP member” means a member described in subsection (e)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “member” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of title 37","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary concerned” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90592f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90592fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member eligible to participate in the Thrift Savings Plan by virtue of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/b"},"text":"section 211(b) of title 37","children":[],"tail":" may contribute to the Thrift Savings Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90592fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), an election to contribute to the Thrift Savings Fund under this section may be made as provided under section 8432(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90592fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb90592fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (A), any individual who is a member as of the effective date that applies with respect to such individual under section 663 of the National Defense Authorization Act for Fiscal Year 2000 may make the first such election during the 60-day period beginning on such effective date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90592ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election made under this subparagraph shall take effect on the first day of the first applicable pay period beginning after the close of the 60-day period referred to in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9059300-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this section, the provisions of this subchapter and subchapter VII shall apply with respect to members making contributions to the Thrift Savings Fund, and such members shall, for purposes of this subchapter and subchapter VII, be considered employees within the meaning of section 8401(11).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9059301-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9059302-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9059303-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount contributed by a member described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/a/1"},"text":"section 211(a)(1) of title 37","children":[],"tail":" for any pay period out of basic pay may not exceed the maximum percentage of such member’s basic pay for such pay period allowable under section 8440f."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9059304-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount contributed by a member described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/a/2"},"text":"section 211(a)(2) of title 37","children":[],"tail":" for any pay period out of any compensation received under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of title 37","children":[],"tail":" may not exceed the maximum percentage of such member’s compensation for such pay period (received under such section 206) allowable under section 8440f."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9059305-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member making contributions to the Thrift Savings Fund out of basic pay, or out of compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s206"},"text":"section 206 of title 37","children":[],"tail":", may also contribute (by direct transfer to the Fund) any part of any special or incentive pay that such member receives under chapter 5 of title 37."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9059306-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of title 37","children":[],"tail":" shall be considered to waive any dollar limitation under the Internal Revenue Code of 1986 which otherwise applies with respect to the Thrift Savings Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9059307-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modernized Retirement System.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9059308-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"TSP contributions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary concerned shall make contributions to the Thrift Savings Fund, in accordance with section 8432 (except to the extent the requirements under such section are modified by this subsection), for the benefit of a member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9059309-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who first enters a uniformed service on or after ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb905930a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb905930b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first entered a uniformed service before ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb905930c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed fewer than 12 years of service in the uniformed services as of ","children":[{"tag":"date","attrib":{"date":"2017-12-31"},"text":"December 31, 2017","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb905930d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the election described in section 1409(b)(4)(B) or 12729(f)(2) of title 10 to receive Thrift Savings Plan contributions under this subsection in exchange for the reduced multipliers described in section 1409(b)(4)(A) or 12739(f)(1) of title 10, as applicable, for purposes of calculating the retired pay of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb905930e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount contributed under this subsection by the Secretary concerned for the benefit of a full TSP member for any pay period shall not be more than 5 percent of the member’s basic pay for such pay period. Any such contribution under this subsection, though in accordance with section 8432 as provided in paragraph (1), is instead of, and not in addition to, amounts contributable under section 8432 as provided in section 8432(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb905930f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing and duration of contributions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9059310-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automatic contributions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall make a contribution described in section 8432(c)(1) under this subsection for the benefit of a member described in paragraph (1) for any pay period during the period that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9059311-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" begins—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9059312-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the day that is 60 days afer the date the member first enters a uniformed service, in the case of a member described in paragraph (1)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9059313-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the date the member makes the election described in paragraph (1)(B), in the case of a member making such an election; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9059314-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends on the day such member completes 26 years of service as a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9059315-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching contributions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary concerned shall make a contribution described in section 8432(c)(2) under this subsection for the benefit of a member described in paragraph (1) for any pay period during the period that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9059316-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" begins—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9059317-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the day that is 2 years and 1 day after the date the member first enters a uniformed service, in the case of a member described in paragraph (1)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9059318-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or after the date the member makes the election described in paragraph (1)(B), in the case of a member making such an election; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9059319-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ends on the day such member completes 26 years of service as a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb905931a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440e/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protections for spouses and former spouses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 8435 shall apply to a full TSP member in the same manner as such section is applied to an employee or Member under such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb905931b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s661/a/2/A"},"text":"Pub. L. 106–65, div. A, title VI, § 661(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/670"},"text":"113 Stat. 670","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 661(c)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–167; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s138/a/6"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 138(a)(6)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–233; "},{"tag":"ref","attrib":{"href":"/us/pl/108/469/s1/d/8"},"text":"Pub. L. 108–469, § 1(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-21"},"text":"Dec. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3892"},"text":"118 Stat. 3892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s632/a"},"text":"Pub. L. 114–92, div. A, title VI, § 632(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/845"},"text":"129 Stat. 845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb905931c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb905931d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb905931e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 663 of the National Defense Authorization Act for Fiscal Year 2000, referred to in subsec. (b)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s663"},"text":"section 663 of Pub. L. 106–65","children":[],"tail":", which is set out as an Effective Date note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (d)(3), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb905931f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s632/a/1"},"text":"Pub. L. 114–92, § 632(a)(1)","children":[],"tail":", added pars. (1) to (4) and struck out former pars. (1) and (2) which defined “member” and “basic pay”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s632/a/2"},"text":"Pub. L. 114–92, § 632(a)(2)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/d"},"text":"section 211(d) of title 37","children":[],"tail":", no contribution under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/c"},"text":"section 8432(c) of this title","children":[],"tail":" may be made for the benefit of a member making contributions to the Thrift Savings Fund under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/469"},"text":"Pub. L. 108–469","children":[],"tail":" substituted “as provided under section 8432(b)” for “only during a period provided under section 8432(b), subject to the same conditions as prescribed under paragraph (2) (A)–(D) thereof”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “as of the effective date that applies with respect to such individual under section 663 of the National Defense Authorization Act for Fiscal Year 2000” for “as of the effective date described in paragraph (1) of section 663(a) of the National Defense Authorization Act for Fiscal Year 2000 (or, if applicable, paragraph (2) thereof)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s138/a/6/A"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 138(a)(6)(A)]","children":[],"tail":", substituted “the maximum percentage of such member’s basic pay for such pay period allowable under section 8440f.” for “5 percent of such member’s basic pay for such pay period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s138/a/6/B"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 138(a)(6)(B)]","children":[],"tail":", substituted “the maximum percentage of such member’s compensation for such pay period (received under such section 206) allowable under section 8440f.” for “5 percent of such compensation, payable to such member for such pay period.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9059320-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb9059321-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment; Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", with certain implementation requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s635"},"text":"section 635 of Pub. L. 114–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9059322-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s663"},"text":"Pub. L. 106–65, div. A, title VI, § 663","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/673"},"text":"113 Stat. 673","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 661(a)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–167, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the amendments made by this subtitle [subtitle F (§§ 661–663) of title VI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, and amending sections 8351, 8432b, 8433, 8439, and 8473 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of Title 37","children":[],"tail":"] shall take effect 180 days after the date of the enactment of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001 ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postponement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may postpone by up to 180 days after the date that would otherwise apply under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date as of which the amendments made by this subtitle shall take effect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date as of which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/a/2"},"text":"section 211(a)(2) of title 37","children":[],"tail":", United States Code (as added by this subtitle) shall take effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postponement authority under this subsection may be exercised only to the extent that the failure to do so would prevent the Federal Retirement Thrift Investment Board from being able to provide timely and accurate services to investors or would place an excessive burden on the administrative capacity of the Board to accommodate participants in the Thrift Savings Plan, as determined by the Secretary of Defense after consultation with the Executive Director (appointed by the Board).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) includes the authority to postpone the effective date of the amendments made by this subtitle (apart from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/a/2"},"text":"section 211(a)(2) of title 37","children":[],"tail":", United States Code), and the effective date of such section 211(a)(2), by different lengths of time."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall notify the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives], the Committee on Government Reform [now Committee on Oversight and Accountability] of the House of Representatives, and the Committee on Governmental Affairs [now Committee on Homeland Security and Governmental Affairs] of the Senate of any determination made under this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9059323-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s661/b"},"text":"Pub. L. 106–65, div. A, title VI, § 661(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/672"},"text":"113 Stat. 672","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 661(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–167, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/398/s1/dA"},"text":"“Not later than the 180th day after the date of the enactment of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001 [","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"], the Executive Director (appointed by the Federal Retirement Thrift Investment Board) shall issue regulations to implement the amendments made by this subtitle [subtitle F (§§ 661–663) of title VI of div. A of "},{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":", enacting this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, and amending sections 8351, 8432b, 8433, 8439, and 8473 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s211"},"text":"section 211 of Title 37","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
