{"tag":"section","attrib":{"id":"idb8c2e50b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8143b"},"text":"§ 8143b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees in fire protection activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c2e50c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e50d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee in fire protection activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employee in fire protection activities” means an employee employed as a firefighter (including a wildland firefighter), paramedic, emergency medical technician, rescue worker, ambulance personnel, or hazardous material worker who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e50e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is trained in fire suppression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e50f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the legal authority and responsibility to engage in fire suppression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e510-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the prevention, control, or extinguishment of fires or response to emergency situations in which life, property, or the environment is at risk, including the prevention, control, suppression, or management of wildland fires; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e511-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs the activities described in subparagraph (C) as a primary responsibility of the job of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e512-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “rule” has the meaning given the term in section 804.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e513-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e514-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Illnesses and Diseased ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002146"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002146"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":" So in original. Probably should be “"},{"tag":"inline","attrib":{},"text":"Diseases","children":[],"tail":"”."}],"tail":null},{"tag":"inline","attrib":{},"text":" Deemed to Be Proximately Caused by Employment in Fire Protection Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e515-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a claim under this subchapter of disability or death of an employee who has been employed for not less than 5 years in aggregate as an employee in fire protection activities, an illness or disease specified on the list established under paragraph (2) shall be deemed to be proximately caused by the employment of that employee, if the employee is diagnosed with that illness or disease not later than 10 years after the last activedate ","children":[{"tag":"ref","attrib":{"idref":"fn002147"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002147"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" of employment as an employee in fire protection activities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e516-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of initial list","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established under this section the following list of illnesses and diseases:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e517-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bladder cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e518-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Brain cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e519-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chronic obstructive pulmonary disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e51a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Colorectal cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e51b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Esophageal cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e51c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kidney cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e51d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leukemias.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e51e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lung cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e51f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mesothelioma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e520-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Multiple myeloma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e521-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-Hodgkin lymphoma.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e522-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prostate cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e523-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Skin cancer (melanoma).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e524-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sudden cardiac event or stroke suffered while, or not later than 24 hours after, engaging in the activities described in subsection (a)(1)(C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e525-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Testicular cancer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e526-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thyroid cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e527-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additions to the list.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e528-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb8c2e529-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8c2e52a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Director of the National Institute for Occupational Safety and Health and any advisory committee determined appropriate by the Secretary, periodically review the list established under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8c52e1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that the weight of the best available scientific evidence warrants adding an illness or disease to the list established under paragraph (2), as described in subparagraph (B) of this paragraph, make such an addition through a rule that clearly identifies that scientific evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c52e1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A rule issued by the Secretary under clause (i) shall be considered to be a major rule for the purposes of chapter 8.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c52e1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis for determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall add an illness or disease to the list established under paragraph (2) based on the weight of the best available scientific evidence that there is a significant risk to employees in fire protection activities of developing that illness or disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c52e1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Available expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining significant risk for purposes of subparagraph (B), the Secretary may accept as authoritative, and may rely upon, recommendations, risk assessments, and scientific studies (including analyses of National Firefighter Registry data pertaining to Federal firefighters) by the National Institute for Occupational Safety and Health, the National Toxicology Program, the National Academies of Sciences, Engineering, and Medicine, and the International Agency for Research on Cancer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c52e1f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIII/s5305/a/1/A"},"text":"Pub. L. 117–263, div. E, title LIII, § 5305(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3251"},"text":"136 Stat. 3251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c52e20-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c52e21-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8c52e22-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIII/s5305/a/1/C"},"text":"Pub. L. 117–263, div. E, title LIII, § 5305(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3253"},"text":"136 Stat. 3253","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIII/s5305/a/1/C"},"text":"“The amendments made by this paragraph [enacting this section] shall apply to claims for compensation filed on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e23-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Research Cooperation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIII/s5305/a/2"},"text":"Pub. L. 117–263, div. E, title LIII, § 5305(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3253"},"text":"136 Stat. 3253","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIII/s5305/a/2"},"text":"“Not later than 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary of Labor (referred to in this subsection as the ‘Secretary’) shall establish a process by which an employee in fire protection activities, as defined in subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143b"},"text":"section 8143b of title 5","children":[],"tail":", United States Code, as added by paragraph (1) of this subsection (referred to in this subsection as an ‘employee in fire protection activities’) filing a claim under chapter 81 of title 5, United States Code, as amended by this subsection, relating to an illness or disease on the list established under subsection (b)(2) of such section 8143b (referred to in this subsection as ‘ ‘the list’ [sic]) as the list may be updated under such section 8143b, shall be informed about, and offered the opportunity to contribute to science by voluntarily enrolling in, the National Firefighter Registry or a similar research or public health initiative conducted by the Centers for Disease Control and Prevention.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e24-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Agenda for Further Review","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIII/s5305/a/3"},"text":"Pub. L. 117–263, div. E, title LIII, § 5305(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3253"},"text":"136 Stat. 3253","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIII/s5305/a/3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 3 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary [of Labor] shall—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the best available scientific evidence of the risk to an employee in fire protection activities of developing breast cancer, gynecological cancers, and rhabdomyolysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" add breast cancer, gynecological cancers, and rhabdomyolysis to the list, by rule in accordance with subsection (b)(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143b"},"text":"section 8143b of title 5","children":[],"tail":", United States Code, as added by paragraph (1) of this subsection, if the Secretary determines that such evidence supports that addition; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Education and Labor [now Committee on Education and the Workforce] of the House of Representatives a report containing—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the Secretary after making the evaluation required under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of the Secretary under subparagraph (B).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[“The list” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5305/a/3"},"text":"section 5305(a)(3) of Pub. L. 117–263","children":[],"tail":", set out above, defined as in subsec. (b)(2) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5305/a/2"},"text":"section 5305(a)(2) of Pub. L. 117–263","children":[],"tail":", set out as a note above.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
