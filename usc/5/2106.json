{"tag":"section","attrib":{"id":"idb7f11596-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2106"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106"},"text":"§ 2106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of this title, “Member of Congress” means the Vice President, a member of the Senate or the House of Representatives, a Delegate to the House of Representatives, and the Resident Commissioner from Puerto Rico.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7f11597-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/409"},"text":"80 Stat. 409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/405/tII/s204/b"},"text":"Pub. L. 91–405, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-09-22"},"text":"Sept. 22, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/852"},"text":"84 Stat. 852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/7"},"text":"Pub. L. 96–54, § 2(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/381"},"text":"93 Stat. 381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f11598-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7f11599-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","chil