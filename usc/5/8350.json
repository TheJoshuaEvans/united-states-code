{"tag":"section","attrib":{"id":"idb8f035e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350"},"text":null,"children":[{"tag":"num","attrib":{"value":"8350"},"text":"§ 8350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement counseling","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f035e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, the term “retirement counselor”, when used with respect to an agency, means an employee of the agency who is designated by the head of the agency to furnish information on benefits under this subchapter and chapter 84 of this title and counseling services relating to such benefits to other employees of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f035ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management shall establish a training program for all retirement counselors of agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f035eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f035ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The training program established under subsection (b) of this section shall provide for comprehensive training in the provisions and administration of this subchapter and chapter 84 of this title, shall be designed to promote fully informed retirement decisions by employees and Members under this subchapter and individuals subject to chapter 84 of this title, and shall be revised as necessary to assure that the information furnished to retirement counselors of agencies under the program is current.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall conduct a training session under the training program at least once every 3 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f035ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8350/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once each year, each retirement counselor of an agency shall successfully complete a training session conducted under the training program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f035ef-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tII/s205/a"},"text":"Pub. L. 99–335, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/592"},"text":"100 Stat. 592","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/556/tII/s202"},"text":"Pub. L. 99–556, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3135"},"text":"100 Stat. 3135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8f035f0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8f035f1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8f035f2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/556"},"text":"Pub. L. 99–556","children":[],"tail":" substituted “subsection (b)” for “subsection (b)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8f035f3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8f035f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/b/3"},"text":"section 702(b)(3) of Pub. L. 99–335","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8f035f5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enhancing Financial Literacy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/469/s2"},"text":"Pub. L. 108–469, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-21"},"text":"Dec. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3892"},"text":"118 Stat. 3892","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/469/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Retirement Thrift Investment Board (in this section referred to as the ‘Board’) shall periodically evaluate whether the tools available to participants provide the information needed to understand, evaluate, and compare financial products, services, and opportunities offered through the Thrift Savings Plan. The Board shall use these evaluations to improve its existing education program for Thrift Savings Plan participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Financial Literacy Efforts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall annually report to the Committee on Governmental Affairs [now Committee on Homeland Security and Governmental Affairs] of the Senate and the Committee on Government Reform [now Committee on Oversight and Accountability] of the House of Representatives on its Thrift Savings Plan education efforts on behalf of plan participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the retirement training offered by Office of Personnel Management under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8350"},"text":"section 8350 of title 5","children":[],"tail":", United States Code, the Office, in consultation with the Board, shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-12-21"},"text":"Dec. 21, 2004","children":[],"tail":"], develop and implement a retirement financial literacy and education strategy for Federal employees that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall educate Federal employees on the need for retirement savings and investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information related to how Federal employees can receive additional information on how to plan for retirement and calculate what their retirement investment should be in order to meet their retirement goals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report to the Committee on Governmental Affairs [now Committee on Homeland Security and Governmental Affairs] of the Senate and the Committee on Government Reform [now Committee on Oversight and Accountability] of the House of Representatives on the strategy described under paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
