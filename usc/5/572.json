{"tag":"section","attrib":{"id":"idb7bc977f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572"},"text":null,"children":[{"tag":"num","attrib":{"value":"572"},"text":"§ 572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7bc9780-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may use a dispute resolution proceeding for the resolution of an issue in controversy that relates to an administrative program, if the parties agree to such proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc9781-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency shall consider not using a dispute resolution proceeding if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc9782-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a definitive or authoritative resolution of the matter is required for precedential value, and such a proceeding is not likely to be accepted generally as an authoritative precedent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc9783-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter involves or may bear upon significant questions of Government policy that require additional procedures before a final resolution may be made, and such a proceeding would not likely serve to develop a recommended policy for the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc9784-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining established policies is of special importance, so that variations among individual decisions are not increased and such a proceeding would not likely reach consistent results among individual decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc9785-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter significantly affects persons or organizations who are not parties to the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc9786-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full public record of the proceeding is important, and a dispute resolution proceeding cannot provide such a record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc9787-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency must maintain continuing jurisdiction over the matter with authority to alter the disposition of the matter in the light of changed circumstances, and a dispute resolution proceeding would interfere with the agency’s fulfilling that requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc9788-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s572/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alternative means of dispute resolution authorized under this subchapter are voluntary procedures which supplement rather than limit other available agency dispute resolution techniques.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7bc9789-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/552/s4/b"},"text":"Pub. L. 101–552, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2739"},"text":"104 Stat. 2739","children":[],"tail":", § 582; renumbered § 572, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bc978a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bc978b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7bc978c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 572 of former Title 5, Executive Departments and Government Officers and Employees, was transferred to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2257"},"text":"section 2257 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7bc978d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 572 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s592"},"text":"section 592 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bc978e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s582"},"text":"section 582 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
