{"tag":"section","attrib":{"id":"idb82c97df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303"},"text":null,"children":[{"tag":"num","attrib":{"value":"4303"},"text":"§ 4303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions based on unacceptable performance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82c97e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this section, an agency may reduce in grade or remove an employee for unacceptable performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c97e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c97e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee whose reduction in grade or removal is proposed under this section is entitled to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82c97e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 30 days’ advance written notice of the proposed action which identifies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb82c97e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific instances of unacceptable performance by the employee on which the proposed action is based; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82c97e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the critical elements of the employee’s position involved in each instance of unacceptable performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c97e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be represented by an attorney or other representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c97e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable time to answer orally and in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c97e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a written decision which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb82c97e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a reduction in grade or removal under this section, specifies the instances of unacceptable performance by the employee on which the reduction in grade or removal is based, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82c97ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless proposed by the head of the agency, has been concurred in by an employee who is in a higher position than the employee who proposed the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may, under regulations prescribed by the head of such agency, extend the notice period under subsection (b)(1)(A) of this section for not more than 30 days. An agency may extend the notice period for more than 30 days only in accordance with regulations issued by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c97ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The decision to retain, reduce in grade, or remove an employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c97ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made within 30 days after the date of expiration of the notice period, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a reduction in grade or removal, may be based only on those instances of unacceptable performance by the employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82c97ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which occurred during the 1-year period ending on the date of the notice under subsection (b)(1)(A) of this section in connection with the decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c97f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the notice and other requirements of this section are complied with.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c97f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, because of performance improvement by the employee during the notice period, the employee is not reduced in grade or removed, and the employee’s performance continues to be acceptable for 1 year from the date of the advance written notice provided under subsection (b)(1)(A) of this section, any entry or other notation of the unacceptable performance for which the action was proposed under this section shall be removed from any agency record relating to the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c97f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee who is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c97f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a preference eligible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the competitive service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the excepted service and covered by subchapter II of chapter 75,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and who has been reduced in grade or removed under this section is entitled to appeal the action to the Merit Systems Protection Board under section 7701.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c97f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c97f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction to the grade previously held of a supervisor or manager who has not completed the probationary period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3321/a/2"},"text":"section 3321(a)(2) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction in grade or removal of an employee in the competitive service who is serving a probationary or trial period under an initial appointment or who has not completed 1 year of current continuous employment under other than a temporary appointment limited to 1 year or less,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction in grade or removal of an employee in the excepted service who has not completed 1 year of current continuous employment in the same or similar positions, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c97fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4303/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any removal or demotion under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s714"},"text":"section 714 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82c97fb-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/440"},"text":"80 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s203/a"},"text":"Pub. L. 95–454, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1133"},"text":"92 Stat. 1133","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/376/s2/b"},"text":"Pub. L. 101–376, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/462"},"text":"104 Stat. 462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/41/tII/s202/b/2"},"text":"Pub. L. 115–41, title II, § 202(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-23"},"text":"June 23, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/873"},"text":"131 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82c97fc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb82c97fd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb82c97fe-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2004"},"text":"5 U.S.C. 2004","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-30/ch1123/s5"},"text":"Sept. 30, 1950, ch. 1123, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1098"},"text":"64 Stat. 1098","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “required by this chapter” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82c97ff-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82c9800-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/41"},"text":"Pub. L. 115–41","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/376"},"text":"Pub. L. 101–376","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “Any employee who is a preference eligible or is in the competitive service and who has been reduced in grade or removed under this section is entitled to appeal the action to the Merit Systems Protection Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701"},"text":"section 7701 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Actions based on unacceptable performance” for “Performance-rating plans; requirements for” in section catchline and in text substituted provisions relating to actions based on unacceptable performance, for provisions relating to requirements for performance-rating plans."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82c9801-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c9802-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/376/s2/c"},"text":"Pub. L. 101–376, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/462"},"text":"104 Stat. 462","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/376/s2/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7511"},"text":"section 7511 of this title","children":[],"tail":"] shall apply with respect to any personnel action taking effect on or after the effective date of this Act [see below].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/376/s4"},"text":"Pub. L. 101–376, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/463"},"text":"104 Stat. 463","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/376/s4"},"text":"“This Act and the amendments made by this Act [amending this section, sections 7511 and 7701 of this title, and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7501"},"text":"section 7501 of this title","children":[],"tail":"] shall become effective on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":"], and, except as provided in section 2(c) [set out above], shall apply with respect to any appeal or other proceeding brought on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c9803-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
