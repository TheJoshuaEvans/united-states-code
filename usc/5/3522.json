{"tag":"section","attrib":{"id":"idb820b0f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522"},"text":null,"children":[{"tag":"num","attrib":{"value":"3522"},"text":"§ 3522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency plans; approval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb820b0f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before obligating any resources for voluntary separation incentive payments, the head of each agency shall submit to the Office of Personnel Management a plan outlining the intended use of such incentive payments and a proposed organizational chart for the agency once such incentive payments have been completed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb820b0f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The plan of an agency under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb820b0fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific positions and functions to be reduced or eliminated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b0fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which categories of employees will be offered incentives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b0fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time period during which incentives may be paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b0fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and amounts of voluntary separation incentive payments to be offered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82321fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the agency will operate without the eliminated positions and functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82321ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management shall review each agency’s plan an ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “and”."}],"tail":" may make any appropriate modifications in the plan, in consultation with the Director of the Office of Management and Budget. A plan under this section may not be implemented without the approval of the Directive "},{"tag":"ref","attrib":{"idref":"fn002068"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “Director”."}],"tail":" of the Office of Personnel Management."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8232200-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/1/A"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2292"},"text":"116 Stat. 2292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8232201-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8232202-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8232203-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1313/a/4"},"text":"section 1313(a)(4) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3521"},"text":"section 3521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
