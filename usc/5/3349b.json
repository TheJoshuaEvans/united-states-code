{"tag":"section","attrib":{"id":"idb819855c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3349b"},"text":"§ 3349b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holdover provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 3345 through 3349a shall not be construed to affect any statute that authorizes a person to continue to serve in any office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb819855d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the expiration of the term for which such person is appointed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb819855e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until a successor is appointed or a specified period of time has expired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb819855f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-615"},"text":"112 Stat. 2681–615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8198560-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8198561-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr