{"tag":"section","attrib":{"id":"idb92242cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981"},"text":null,"children":[{"tag":"num","attrib":{"value":"8981"},"text":"§ 8981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92242ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “employee” means an employee defined under section 8901(1) and an employee of the District of Columbia courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “annuitant”, “member of family”, and “dependent” have the meanings as such terms are defined under paragraphs (3), (5), and (9), respectively, of section 8901.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible individual” refers to an individual described in paragraph (1), (2), or (8), without regard to whether the individual is enrolled in a health benefits plan under chapter 89.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Office” means the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “qualified company” means a company (or consortium of companies or an employee organization defined under section 8901(8)) that offers indemnity, preferred provider organization, health maintenance organization, or discount vision programs and if required is licensed to issue applicable coverage in any number of States, taking any subsidiaries of such a company into account (and, in the case of a consortium, considering the member companies and any subsidiaries thereof, collectively).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “employee organization” means an association or other organization of employees which is national in scope, or in which membership is open to all employees of a Government agency who are eligible to enroll in a health benefits plan under chapter 89.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92242d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92242d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “covered TRICARE-eligible individual”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb92242d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an individual entitled to medical care under chapter 55 of title 10, pursuant to section 1076d, 1076e, 1079(a), 1086(c), or 1086(d) of such title, who the Secretary of Defense determines in accordance with an agreement entered into under subparagraph (B) should be an eligible individual for purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb924b2d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an individual covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1110b"},"text":"section 1110b of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b2d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8981/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall enter into an agreement with the Director of the Office relating to classes of individuals described in subparagraph (A)(i) who should be eligible individuals for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b2da-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s3"},"text":"Pub. L. 108–496, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/4006"},"text":"118 Stat. 4006","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/356/tI/s117/a/2"},"text":"Pub. L. 109–356, title I, § 117(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2027"},"text":"120 Stat. 2027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVII/s715/a/2"},"text":"Pub. L. 114–328, div. A, title VII, § 715(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2221"},"text":"130 Stat. 2221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b2db-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b2dc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b2dd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s715/a/2/A"},"text":"Pub. L. 114–328, § 715(a)(2)(A)","children":[],"tail":", substituted “paragraph (1), (2), or (8)” for “paragraph (1) or (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s715/a/2/B"},"text":"Pub. L. 114–328, § 715(a)(2)(B)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/356"},"text":"Pub. L. 109–356","children":[],"tail":", which directed insertion of “and an employee of the District of Columbia courts” at end of par. (1), was executed by making the insertion before the period, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b2de-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb924b2df-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the first contract year for chapter 89A or 89B of this title, as applicable, that begins on or after "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s715/c"},"text":"section 715(c) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb924b2e0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", and applicable to contracts that take effect with respect to the calendar year 2006, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/496/s7"},"text":"section 7 of Pub. L. 108–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
