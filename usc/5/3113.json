{"tag":"section","attrib":{"id":"idb7fcfc04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3113"},"text":null,"children":[{"tag":"num","attrib":{"value":"3113"},"text":"§ 3113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on reemployment after conviction of certain crimes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An employee shall be separated from service and barred from reemployment in the Federal service, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fcfc05-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3113/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee is convicted of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s201/b"},"text":"section 201(b) of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfc06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3113/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such violation related to conduct prohibited under section 1010(a) of the Controlled Substances Import and Export Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s960/a"},"text":"21 U.S.C. 960(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7fcfc07-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/61/tVI/s638/a"},"text":"Pub. L. 105–61, title VI, § 638(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-10"},"text":"Oct. 10, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1316"},"text":"111 Stat. 1316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fcfc08-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7fcfc09-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7fcfc0a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/61/tVI/s638/c"},"text":"Pub. L. 105–61, title VI, § 638(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-10"},"text":"Oct. 10, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1317"},"text":"111 Stat. 1317","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/61/tVI/s638/c"},"text":"“This section [enacting this section] shall apply during fiscal year 1998 and each fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
