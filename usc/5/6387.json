{"tag":"section","attrib":{"id":"idb8a17a14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6387"},"text":null,"children":[{"tag":"num","attrib":{"value":"6387"},"text":"§ 6387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management shall prescribe regulations necessary for the administration of this subchapter. The regulations prescribed under this subchapter shall, to the extent appropriate, be consistent with the regulations prescribed by the Secretary of Labor to carry out title I of the Family and Medical Leave Act of 1993.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a17a15-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tII/s201/a/1"},"text":"Pub. L. 103–3, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/23"},"text":"107 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a16-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a17a17-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8a17a18-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family and Medical Leave Act of 1993, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 2611 et seq.) of chapter 28 of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17a19-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a17a1a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b/1"},"text":"section 405(b)(1) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
