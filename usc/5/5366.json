{"tag":"section","attrib":{"id":"idb85c5a9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366"},"text":null,"children":[{"tag":"num","attrib":{"value":"5366"},"text":"§ 5366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85c5a9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of the termination of any benefits available to an employee under this subchapter on the grounds such employee declined a reasonable offer of a position the grade or pay of which was equal to or greater than his retained grade or pay, such termination may be appealed to the Office of Personnel Management under procedures prescribed by the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5aa0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this subchapter shall be construed to affect the right of any employee to appeal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85c5aa1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 5112(b) or 5346(c) of this title, or otherwise, any reclassification of a position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85c5aa2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under procedures prescribed by the Office of Personnel Management, any reduction-in-force action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5aa3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of any appeal procedures (other than those described in subsection (a) of this section) or any grievance procedure negotiated under the provisions of chapter 71 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5aa4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action which is the basis of an individual’s entitlement to benefits under this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5aa5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5366/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any termination of any such benefits under this subchapter,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not be treated as appealable under such appeals procedures or grievable under such grievance procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85c5aa6-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/1"},"text":"Pub. L. 95–454, title VIII, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1221"},"text":"92 Stat. 1221","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
