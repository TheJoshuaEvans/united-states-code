{"tag":"section","attrib":{"id":"idb78a8b2b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78a8b2c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency shall designate a senior employee of the agency as the Evaluation Officer of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b2d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Evaluation Officer of an agency shall be appointed or designated without regard to political affiliation and based on demonstrated expertise in evaluation methodology and practices and appropriate expertise to the disciplines of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b2e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Evaluation Officer of an agency shall, to the extent practicable, coordinate activities with agency officials necessary to carry out the functions required under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b2f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Evaluation Officer of each agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continually assess the coverage, quality, methods, consistency, effectiveness, independence, and balance of the portfolio of evaluations, policy research, and ongoing evaluation activities of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess agency capacity to support the development and use of evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and implement an agency evaluation policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s313/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, develop, and implement the plans required under section 312.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78a8b34-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tI/s101/a/2"},"text":"Pub. L. 115–435, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5531"},"text":"132 Stat. 5531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb78a8b35-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb78a8b36-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb78a8b37-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
