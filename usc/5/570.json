{"tag":"section","attrib":{"id":"idb7ba2752-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s570"},"text":null,"children":[{"tag":"num","attrib":{"value":"570"},"text":"§ 570.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any agency action relating to establishing, assisting, or terminating a negotiated rulemaking committee under this subchapter shall not be subject to judicial review. Nothing in this section shall bar judicial review of a rule if such judicial review is otherwise provided by law. A rule which is the product of negotiated rulemaking and is subject to judicial review shall not be accorded any greater deference by a court than a rule which is the product of other rulemaking procedures.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7ba2753-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/648/s3/a"},"text":"Pub. L. 101–648, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4976"},"text":"104 Stat. 4976","children":[],"tail":", § 590; renumbered § 570, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/a/2"},"text":"Pub. L. 102–354, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ba2754-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ba2755-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ba2756-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s590"},"text":"section 590 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
