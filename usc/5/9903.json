{"tag":"section","attrib":{"id":"idb92e2947-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903"},"text":null,"children":[{"tag":"num","attrib":{"value":"9903"},"text":"§ 9903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attracting highly qualified experts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e2948-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may carry out a program using the authority provided in subsection (b) in order to attract highly qualified experts in needed occupations, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2949-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e294a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint personnel from outside the civil service and uniformed services (as such terms are defined in section 2101) to positions in the Department of Defense without regard to any provision of this title governing the appointment of employees to positions in the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e294b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the rates of basic pay for positions to which employees are appointed under paragraph (1) at rates not in excess of the maximum rate of basic pay authorized for senior-level positions under section 5376, as increased by locality-based comparability payments under section 5304, notwithstanding any provision of this title governing the rates of pay or classification of employees in the executive branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e294c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay any employee appointed under paragraph (1) payments in addition to basic pay within the limits applicable to the employee under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e294d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Term of Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e294e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the service of an employee under an appointment made pursuant to this section may not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e294f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, in the case of a particular employee, extend the period to which service is limited under paragraph (1) by up to 1 additional year if the Secretary determines that such action is necessary to promote the Department of Defense’s national security missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2950-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Additional Payments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2951-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total amount of the additional payments paid to an employee under this section for any 12-month period may not exceed the lesser of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e2952-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 in fiscal year 2004, which may be adjusted annually thereafter by the Secretary, with a percentage increase equal to one-half of 1 percentage point less than the percentage by which the Employment Cost Index, published quarterly by the Bureau of Labor Statistics, for the base quarter of the year before the preceding calendar year exceeds the Employment Cost Index for the base quarter of the second year before the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e2953-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount equal to 50 percent of the employee’s annual rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, the term “base quarter” has the meaning given such term by section 5302(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2954-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee appointed under this section is not eligible for any bonus, monetary award, or other monetary incentive for service, except for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e2955-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments authorized under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e2956-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee who is assigned in support of a contingency operation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13"},"text":"section 101(a)(13) of title 10","children":[],"tail":"), allowances and any other payments authorized under chapter 59."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2957-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this subsection or of section 5307, no additional payments may be paid to an employee under this section in any calendar year if, or to the extent that, the employee’s total annual compensation will exceed the maximum amount of total annual compensation payable at the salary set in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":". In computing an employee’s total annual compensation for purposes of the preceding sentence, any payment referred to in paragraph (2)(B) shall be excluded."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2958-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Number of Highly Qualified Experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of highly qualified experts appointed and retained by the Secretary under subsection (b)(1) shall not exceed 2,500 at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2959-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event that the Secretary terminates this program, in the case of an employee who, on the day before the termination of the program, is serving in a position pursuant to an appointment under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e295a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the termination of the program does not terminate the employee’s employment in that position before the expiration of the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e295b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period for which the employee was appointed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e295c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period to which the employee’s service is limited under subsection (c), including any extension made under this section before the termination of the program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e295d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9903/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of basic pay prescribed for the position under this section may not be reduced as long as the employee continues to serve in the position without a break in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92e295e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1101/a/1"},"text":"Pub. L. 108–136, div. A, title XI, § 1101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1632"},"text":"117 Stat. 1632","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1105"},"text":"Pub. L. 112–81, div. A, title XI, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1612"},"text":"125 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92e295f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92e2960-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92e2961-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1105/1"},"text":"Pub. L. 112–81, § 1105(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “An employee appointed under this section is not eligible for any bonus, monetary award, or other monetary incentive for service except for payments authorized under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1105/2"},"text":"Pub. L. 112–81, § 1105(2)","children":[],"tail":", inserted at end “In computing an employee’s total annual compensation for purposes of the preceding sentence, any payment referred to in paragraph (2)(B) shall be excluded.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92e2962-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb92e2963-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Maximum Rate Under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"5 U.S.C. 5376","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"For reference to maximum rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/d/3"},"text":"section 2(d)(3) of Pub. L. 110–372","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb92e2964-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Policy on Senior Mentors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXI/s1105"},"text":"Pub. L. 112–239, div. A, title XI, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1973"},"text":"126 Stat. 1973","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tXI/s1105"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall provide written notice to the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] at least 60 days before implementing any change in the policy regarding senior mentors issued on or about ","children":[{"tag":"date","attrib":{"date":"2010-04-01"},"text":"April 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Changes implemented before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"] shall not be affected by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb92e2965-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disclosure of Senior Mentors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1124"},"text":"Pub. L. 112–81, div. A, title XI, § 1124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1618"},"text":"125 Stat. 1618","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tXI/s1124"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement to Disclose Names of Senior Mentors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall disclose the names of senior mentors serving in the Department of Defense by publishing a list of the names on the publicly available website of the Department of Defense. The list shall be updated at least quarterly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Mentor Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘senior mentor’ has the meaning provided in the memorandum from the Secretary of Defense relating to policy on senior mentors, dated ","children":[{"tag":"date","attrib":{"date":"2010-04-01"},"text":"April 1, 2010","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb92e2966-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirements for Department of Defense Senior Mentors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tXI/s1102"},"text":"Pub. L. 111–383, div. A, title XI, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4382"},"text":"124 Stat. 4382","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/383/dA/tXI/s1102"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall issue appropriate policies and procedures to ensure that all senior mentors employed by the Department of Defense are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hired as highly qualified experts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9903"},"text":"section 9903 of title 5","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to comply with all applicable Federal laws and regulations on personnel and ethics matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior Mentor Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘senior mentor’ means a retired flag, general, or other military officer or retired senior civilian official who provides expert experience-based mentoring, teaching, training, advice, and recommendations to senior military officers, staffs, and students as they participate in war games, warfighting courses, operational planning, operational exercises, and decision-making exercises.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
