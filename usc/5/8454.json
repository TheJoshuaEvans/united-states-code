{"tag":"section","attrib":{"id":"idb908040c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8454"},"text":null,"children":[{"tag":"num","attrib":{"value":"8454"},"text":"§ 8454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical examination","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An annuitant receiving a disability retirement annuity from the Fund shall be examined under the direction of the Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb908040d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8454/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of 1 year from the date of the disability retirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb908040e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8454/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually thereafter until becoming 60 years of age;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless the disability is permanent in character. If the annuitant fails to submit to examination as required by this section, payment of the annuity shall be suspended until continuance of the disability is satisfactorily established.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb908040f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/568"},"text":"100 Stat. 568","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
