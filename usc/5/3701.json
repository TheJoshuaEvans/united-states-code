],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever is appropriate in the context in which such term is used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8256bf7-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/tII/s209/c/1"},"text":"Pub. L. 107–347, title II, § 209(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2925"},"text":"116 Stat. 2925","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8256bf8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8256bf9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8256bfa-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8256bfb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children