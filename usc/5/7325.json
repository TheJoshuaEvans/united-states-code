{"tag":"section","attrib":{"id":"idb8b21bf5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7325"},"text":null,"children":[{"tag":"num","attrib":{"value":"7325"},"text":"§ 7325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political activity permitted; employees residing in certain municipalities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management may prescribe regulations permitting employees, without regard to the prohibitions in paragraphs (2) and (3) of section 7323(a) and paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7323/b"},"text":"section 7323(b) of this title","children":[],"tail":", to take an active part in political management and political campaigns involving the municipality or other political subdivision in which they reside, to the extent the Office considers it to be in their domestic interest, when—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21bf6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7325/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the municipality or political subdivision is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21bf7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7325/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bf8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7325/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in Maryland or Virginia and in the immediate vicinity of the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bf9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7325/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a municipality in which the majority of voters are employed by the Government of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bfa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7325/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office determines that because of special or unusual circumstances which exist in the municipality or political subdivision it is in the domestic interest of the employees and individuals to permit that political participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21bfb-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94/s2/a"},"text":"Pub. L. 103–94, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1004"},"text":"107 Stat. 1004","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tIII/s308"},"text":"Pub. L. 104–93, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/966"},"text":"109 Stat. 966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/230/s3/f"},"text":"Pub. L. 112–230, § 3(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1617"},"text":"126 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b21bfc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b21bfd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8b21bfe-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7325, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/526"},"text":"80 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/44"},"text":"Pub. L. 96–54, § 2(a)(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/384"},"text":"93 Stat. 384","children":[],"tail":", related to penalties, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b21bff-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230"},"text":"Pub. L. 112–230","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “the municipality or political subdivision is in Maryland or Virginia and in the immediate vicinity of the District of Columbia, or is a municipality in which the majority of voters are employed by the Government of the United States; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93"},"text":"Pub. L. 104–93","children":[],"tail":" inserted “and paragraph (2) of section 7323(b)” after “section 7323(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b21c00-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b21c01-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230"},"text":"Pub. L. 112–230","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/230/s5/a"},"text":"section 5(a) of Pub. L. 112–230","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
