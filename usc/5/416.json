C)(ii), is Ex. Ord. No. 13526, ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 707, 1013, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79d9df6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6701/c/1"},"text":"Pub. L. 118–159, § 6701(c)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6702/c/1"},"text":"Pub. L. 118–159, § 6702(c)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6701/c/2/A"},"text":"Pub. L. 118–159, § 6701(c)(2)(A)","children":[],"tail":", (B), inserted “; support for written submission” after “made” in heading and “in writing” after “may report the complaint or information” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6701/c/2/C"},"text":"Pub. L. 118–159, § 6701(c)(2)(C)","children":[],"tail":", inserted “in writing” after “such complaint or information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6701/c/2/D"},"text":"Pub. L. 118–159, § 6701(c)(2)(D)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6701/c/3"},"text":"Pub. L. 118–159, § 6701(c)(3)","children":[],"tail":", added pars. (1) and (2), redesignated former par. (2) as (3), and struck out former par. (1) which required the Inspector General to determine the credibility of the complaint or information."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s6702/c/2"},"text":"Pub. L. 118–159, § 6702(c)(2)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
