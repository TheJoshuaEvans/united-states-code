{"tag":"section","attrib":{"id":"idb79d9dc3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416"},"text":null,"children":[{"tag":"num","attrib":{"value":"416"},"text":"§ 416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional provisions with respect to Inspectors General of the intelligence community","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79d9dc4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79d9dc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “intelligence committees” means the Permanent Select Committee on Intelligence of the House of Representatives and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Urgent concern","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “urgent concern” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79d9dc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A serious or flagrant problem, abuse, violation of law or Executive order, or deficiency relating to the funding, administration, or operations of an intelligence activity involving classified information, but does not include differences of opinions concerning public policy matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dc8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A false statement to Congress, or a willful withholding from Congress, on an issue of material fact relating to the funding, administration, or operation of an intelligence activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dc9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An action, including a personnel action described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/a/2/A"},"text":"section 2302(a)(2)(A) of this title","children":[],"tail":" constituting reprisal or threat of reprisal prohibited under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s407/c"},"text":"section 407(c) of this title","children":[],"tail":" in response to an employee’s reporting an urgent concern in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “employee” includes a former employee or former contractor, if the complaint or information reported pursuant to this section arises from or relates to the period during which the former employee or former contractor was an employee or contractor, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dcb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “intelligence community” has the meaning given such term in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9dcc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaint or Information With Respect to Urgent Concern.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79d9dcd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"To whom reports may be made; support for written submission.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79d9dce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspector general of department of defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Reconnaissance Office, or the National Security Agency, or of a contractor of any of those Agencies, who intends to report to Congress a complaint or information with respect to an urgent concern may report the complaint or information in writing to the Inspector General of the Department of Defense (or designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dcf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspector general of intelligence community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of an element of the intelligence community, an employee assigned or detailed to an element of the intelligence community, or an employee of a contractor to the intelligence community, who intends to report to Congress a complaint or information with respect to an urgent concern may report such complaint or information in writing to the Inspector General of the Intelligence Community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dd0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspector general of department of justice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of the Federal Bureau of Investigation, or of a contractor of the Bureau, who intends to report to Congress a complaint or information with respect to an urgent concern may report the complaint or information in writing to the Inspector General of the Department of Justice (or designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dd1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other appropriate inspector general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any other employee of, or contractor to, an executive agency, or element or unit thereof, determined by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/a/2/C/ii"},"text":"section 2302(a)(2)(C)(ii) of this title","children":[],"tail":", to have as its principal function the conduct of foreign intelligence or counterintelligence activities, who intends to report to Congress a complaint or information with respect to an urgent concern may report the complaint or information in writing to the appropriate Inspector General (or designee) under this chapter, section 17 of the Central Intelligence Agency Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3517"},"text":"50 U.S.C. 3517","children":[],"tail":"), or section 103H(k) of the National Security Act of 1947 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3033/k"},"text":"50 U.S.C. 3033(k)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dd2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support for written submission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79d9dd3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasonable support necessary to ensure that an employee can submit a complaint or information under this paragraph in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79d9dd4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such submission is not feasible, shall create a written record of the employee’s verbal complaint or information and treat such written record as a written submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dd5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designee to report complaint or information to inspector general within 7 days","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a designee of an Inspector General under this section receives a complaint or information of an employee with respect to an urgent concern, that designee shall report the complaint or information to the Inspector General within 7 calendar days of receipt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dd6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designees of inspector general of department of defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspectors General of the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Reconnaissance Office, and the National Security Agency shall be designees of the Inspector General of the Department of Defense for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9dd7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Determinations and Transmittals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79d9dd8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with paragraph (2), the Inspector General shall determine whether a complaint or information reported under subsection (b) appears credible. Upon making such a determination, the Inspector General shall transmit to the head of the establishment notice of that determination, together with the complaint or information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dd9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General shall make the determination under paragraph (1) with respect to a complaint or information reported under subsection (b) not later than the end of the 14-calendar-day period beginning on the date on which the employee who reported the complaint or information confirms to the Inspector General the intent of the employee to report to Congress that complaint or information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dda-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflict of interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the head of an establishment determines that a complaint or information transmitted under paragraph (1) would create a conflict of interest for the head of the establishment, the head of the establishment shall return the complaint or information to the Inspector General with that determination and the Inspector General shall make the transmission to the Director of National Intelligence and, if the establishment is within the Department of Defense, to the Secretary of Defense. In such a case, the requirements of this section for the head of the establishment apply to each recipient of the Inspector General’s transmission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9ddb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forwarding Transmittals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon receipt of a transmittal from the Inspector General under subsection (c), the head of the establishment shall, within 7 calendar days of such receipt, forward such transmittal to the intelligence committees, together with any comments the head of the establishment considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9ddc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submitting Complaint or Information to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79d9ddd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Inspector General does not find credible under subsection (c) a complaint or information submitted to the Inspector General under subsection (b), or does not transmit the complaint or information to the head of the establishment in accurate form under subsection (c), the employee (subject to paragraph (2)) may submit the complaint or information to Congress by contacting either or both of the intelligence committees directly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9dde-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The employee may contact the intelligence committees directly as described in paragraph (1) only if the employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79d9ddf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before making such a contact, furnishes to the head of the establishment, through the Inspector General, a statement of the employee’s complaint or information and notice of the employee’s intent to contact the intelligence committees directly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9de0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains and follows from the head of the establishment, through the Inspector General, direction on how to contact the intelligence committees in accordance with appropriate security practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9de1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence committee receipt of complaint or information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member or employee of one of the intelligence committees who receives a complaint or information under paragraph (1) does so in that member or employee’s official capacity as a member or employee of that committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9de2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General shall notify an employee who reports a complaint or information under this section of each action taken under this section with respect to the complaint or information. Such notice shall be provided not later than 3 days after any such action is taken.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9de3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action taken by the head of an establishment or an Inspector General under subsections (b) through (f) shall not be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9de4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Submission and Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who has submitted a complaint or information to an Inspector General under this section may notify any member of the Permanent Select Committee on Intelligence of the House of Representatives or the Select Committee on Intelligence of the Senate, or a staff member of either such Committee, of the fact that such individual has made a submission to that particular Inspector General, and of the date on which such submission was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79d9de5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection for Individuals Making Authorized Disclosures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79d9de6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may disclose classified information to an Inspector General of an element of the intelligence community in accordance with the applicable security standards and procedures established under section 102A or 803 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3024"},"text":"50 U.S.C. 3024","children":[],"tail":", 3162a), chapter 12 of the Atomic Energy Act of 1954 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2161"},"text":"42 U.S.C. 2161","children":[],"tail":" et seq.), Executive Order 13526 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note; relating to Classified National Security Information), or any applicable provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79d9de7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure without clearance or authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79d9de8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A disclosure under paragraph (1) of classified information made by an individual without appropriate clearance or authority to access such classified information at the time of the disclosure, but that is otherwise made in accordance with applicable security standards and procedures, shall be treated as an authorized disclosure that does not violate a covered provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9de9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in subparagraph (A) may be construed to limit or modify the obligation of an individual to appropriately store, handle, or disseminate classified information in accordance with applicable security guidance and procedures, including with respect to the removal or retention of classified information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79d9dea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered provision defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “covered provision” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79d9deb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any otherwise applicable nondisclosure agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79d9dec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any otherwise applicable regulation or order issued under the authority of chapter 18 of the Atomic Energy Act of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2271"},"text":"42 U.S.C. 2271","children":[],"tail":" et seq.) or Executive Order 13526;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79d9ded-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s798"},"text":"section 798 of title 18","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79d9dee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s416/i/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law with respect to the unauthorized disclosure of national security information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79d9def-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4242"},"text":"136 Stat. 4242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXVII"},"text":"Pub. L. 118–159, div. F, title LXVII","children":[],"tail":", §§ 6701(c), 6702(c), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2512"},"text":"138 Stat. 2512","children":[],"tail":", 2514.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79d9df0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idb79d9df1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments Not Shown in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was derived from section 8H of the Inspector General Act of 1978, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", which was set out in the former Appendix to this title, and as it existed as of "},{"tag":"date","attrib":{"date":"2021-10-19"},"text":"Oct. 19, 2021","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/95/452/s8H"},"text":"Section 8H of Pub. L. 95–452","children":[],"tail":" was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tV/s502/b"},"text":"Pub. L. 117–103, div. X, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/985"},"text":"136 Stat. 985","children":[],"tail":", and by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVI/s6609/b"},"text":"Pub. L. 117–263, div. F, title LXVI, § 6609(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3560"},"text":"136 Stat. 3560","children":[],"tail":", prior to being repealed and reenacted as this section by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(b), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4242"},"text":"136 Stat. 4242","children":[],"tail":", 4361. For applicability of those amendments to this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s5/b"},"text":"section 5(b) of Pub. L. 117–286","children":[],"tail":", set out in a Transitional and Savings Provisions note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452/s8H"},"text":"Section 8H of Pub. L. 95–452","children":[],"tail":" was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) in subsection (h)(1) [restated as subsection (a)(2) of this section], by redesignating subparagraphs (A), (B), and (C) as clauses (i), (ii), and (iii), respectively (and indenting such clauses accordingly);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) by redesignating subsection (h)(1) and (2) [restated as subsection (a)(2) and (1) of this section, respectively] as subparagraphs (A) and (B), respectively (and indenting such subparagraphs accordingly);","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) in the matter preceding subparagraph (A),