{"tag":"section","attrib":{"id":"idb89cbe90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6327"},"text":null,"children":[{"tag":"num","attrib":{"value":"6327"},"text":"§ 6327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence in connection with serving as a bone-marrow or organ donor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbe91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee in or under an Executive agency is entitled to leave without loss of or reduction in pay, leave to which otherwise entitled, credit for time or service, or performance or efficiency rating, for the time necessary to permit such employee to serve as a bone-marrow or organ donor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbe92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee may, in any calendar year, use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbe93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6327/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed 7 days of leave under this section to serve as a bone-marrow donor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbe94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6327/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to exceed 30 days of leave under this section to serve as an organ donor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbe95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbe96-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/329/tVI/s629/a/1"},"text":"Pub. L. 103–329, title VI, § 629(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2423"},"text":"108 Stat. 2423","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/56/s1/b"},"text":"Pub. L. 106–56, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-24"},"text":"Sept. 24, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/407"},"text":"113 Stat. 407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89cbe97-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89cbe98-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb89cbe99-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 6327 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6328"},"text":"section 6328 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89cbe9a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/56"},"text":"Pub. L. 106–56","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Not to exceed 7 days of leave may be used under this section by an employee in a calendar year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
