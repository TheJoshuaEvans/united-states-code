ref":"/us/stat/71/491"},"text":"71 Stat. 491","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/3/A"},"text":"Pub. L. 88–428, § 1(3)(A)","children":[],"tail":", (C), "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1014 (as applicable to § 1002(a) (1st sentence)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s14"},"text":"Mar. 7, 1942, ch. 166, § 14","children":[],"tail":" (as applicable to § 2(a) (1st sentence)), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/147"},"text":"56 Stat. 147","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/e"},"text":"Apr. 4, 1953, ch. 17, § 1(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1002(a) (96th through 120th words of 1st sentence, for definition purposes).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only that portion of the source law which is applicable to civilian officers and employees and their dependents is codified in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the word “agency” is substituted for “department”. The words “including such term when used in the amendment made by section 16” are omitted as surplusage. The words “an Executive agency and a military department” are coextensive with and substituted for “any executive department, independent establishment, or agency (including corporations) in the executive branch of the Federal Government” in view of the definitions in sections 105 and 102, and on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s933a"},"text":"5 U.S.C. 933a","children":[],"tail":" which provides that general legislation governing employment, compensation, and the status of employees of the United States applies to employees of the General Accounting Office in the same manner as if they were in the executive branch."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3)(A), the word “lawful” is omitted as unnecessary in view of the accepted recognition of the fact that the word “wife” means a lawful wife. In paragraph (3)(E), the words “head of the agency concerned or his designee” are substituted for “head of the department concerned, or subordinate designated by him”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in paragraphs (5) and (6), which do not appear in, but are based on, the source law are created for legislative convenience.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8742820-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8742821-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Par. (6)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “housing” for “quarters”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8742822-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8742823-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/e"},"text":"Pub. L. 105–85, div. A, title VI, § 603(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1783"},"text":"111 Stat. 1783","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/85/dA/tVI/s603/e"},"text":"“This section [amending this section, sections 708, 2830, 2882, 7572, and 7573 of Title 10, Armed Forces, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s107"},"text":"section 107 of Title 32","children":[],"tail":", National Guard, sections 101, 403, 405, 406, 420, 427, 551, and 1014 of Title 37, Pay and Allowances of the Uniformed Services, and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3803"},"text":"section 3803 of Title 50","children":[],"tail":", War and National Defense, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s403a"},"text":"section 403a of Title 37","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s403"},"text":"section 403 of Title 37","children":[],"tail":"] and the amendments made by this section shall take effect on "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8742824-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Accounting for Civilian Employees and Contractors of United States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tV/s569/e"},"text":"Pub. L. 104–106, div. A, title V, § 569(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/352"},"text":"110 Stat. 352","children":[],"tail":", directed Secretary of State to carry out comprehensive study of provisions of this subchapter and any other law or regulation establishing procedures for accounting for civilian employees of the United States or contractors of the United States who serve with or accompany the Armed Forces in the field to determine the means, if any, by which those procedures may be improved, and further provided for submission of report to Congress not later than one year after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", on results of study."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8742825-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Benefits for United States Hostages in Iraq and Kuwait and United States Hostages Captured in Lebanon","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tV/s599C"},"text":"Pub. L. 101–513, title V, § 599C","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2064"},"text":"104 Stat. 2064","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tIII/s302/a"},"text":"Pub. L. 102–138, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/707"},"text":"105 Stat. 707","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/499/s5/a"},"text":"Pub. L. 102–499, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3266"},"text":"106 Stat. 3266","children":[],"tail":", provided for payment of benefits during fiscal year 1991 and thereafter for United States hostages in Iraq and Kuwait and United States hostages captured in Lebanon."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8742826-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hostage Relief","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1967"},"text":"94 Stat. 1967","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/83/s5/c/2"},"text":"Pub. L. 102–83, § 5(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/406"},"text":"105 Stat. 406","children":[],"tail":", known as the “Hostage Relief Act of 1980”, provided for benefits for United States civil service and uniformed service personnel who were placed in a captive status during a hostage period beginning on "},{"tag":"date","attrib":{"date":"1979-11-04"},"text":"Nov. 4, 1979","children":[],"tail":", due to the seizure of the United States Embassy in Iran."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8742827-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8742828-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 12268","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12268, ","children":[{"tag":"date","attrib":{"date":"1981-01-15"},"text":"Jan. 15, 1981","children":[],"tail":", 46 F.R. 4671, provided for the implementation of the Hostage Relief Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/pl/96/449"},"text":"Pub. L. 96–449","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8742829-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 12313","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12313, ","children":[{"tag":"date","attrib":{"date":"1981-07-13"},"text":"July 13, 1981","children":[],"tail":", 46 F.R. 36689, designated "},{"tag":"date","attrib":{"date":"1981-01-11"},"text":"Jan. 11, 1981","children":[],"tail":", as date on which all citizens and resident aliens of the United States who had been placed in captive status as a result of seizure of United States Embassy in Iran were returned to United States or otherwise accounted for and were no longer under foreign control."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
