{"tag":"section","attrib":{"id":"idb8742803-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561"},"text":null,"children":[{"tag":"num","attrib":{"value":"5561"},"text":"§ 5561.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8742804-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” means an Executive agency and a military department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8742805-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means an employee in or under an agency who is a citizen or national of the United States or an alien admitted to the United States for permanent residence, but does not include a part-time or intermittent employee or native labor casually hired on an hourly or daily basis. However, such an employee who enters a status listed in paragraph (5)(A)–(E) of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8742806-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inside the continental United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742807-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a resident at or in the vicinity of his place of employment in a territory or possession of the United States or in a foreign country and who was not living there solely as a result of his employment;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is an employee for the purpose of this subchapter only on a determination by the head of the agency concerned that this status is the proximate result of employment by the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8742808-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “dependent” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8742809-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wife;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb874280a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unmarried child (including an unmarried dependent stepchild or adopted child) under 21 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb874280b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent mother or father;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb874280c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dependent designated in official rec­ords; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb874280d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual determined to be dependent by the head of the agency concerned or his designee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb874280e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “active service” means active Federal service by an employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb874280f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “missing status” means the status of an employee who is in active service and is officially carried or determined to be absent in a status of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8742810-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" missing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742811-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" missing in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742812-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interned in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742813-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" captured, beleaguered, or besieged by a hostile force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742814-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detained in a foreign country against his will;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include the status of an employee for a period during which he is officially determined to be absent from his post of duty without authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8742815-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “pay and allowances” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8742816-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742817-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742818-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incentive pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8742819-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic allowance for housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb874281a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic allowance for subsistence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb874281b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5561/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" station per diem allowances for not more than 90 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb874281c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/489"},"text":"80 Stat. 489","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tVI/s603/d/3"},"text":"Pub. L. 105–85, div. A, title VI, § 603(d)(3)","children":