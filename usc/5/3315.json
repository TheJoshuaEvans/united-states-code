{"tag":"section","attrib":{"id":"idb8100ea1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3315"},"text":null,"children":[{"tag":"num","attrib":{"value":"3315"},"text":"§ 3315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registers; preference eligibles furloughed or separated","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8100ea2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A preference eligible who has been separated or furloughed without delinquency or misconduct, on request, is entitled to have his name placed on appropriate registers and employment lists for every position for which his qualifications have been established, in the order named by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3313"},"text":"section 3313 of this title","children":[],"tail":". This subsection applies to registers and employment lists maintained by the Office of Personnel Management, an Executive agency, or the government of the District of Columbia."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8100ea3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may declare a preference eligible who has been separated or furloughed without pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7512"},"text":"section 7512 of this title","children":[],"tail":" to be entitled to the benefits of subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8100ea4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-