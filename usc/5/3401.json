{"tag":"section","attrib":{"id":"idb81e671e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401"},"text":null,"children":[{"tag":"num","attrib":{"value":"3401"},"text":"§ 3401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e671f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e6720-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6721-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6722-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency in the judicial branch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6723-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6724-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Botanic Garden; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6725-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Office of the Architect of the Capitol; but does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb81e6726-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government controlled corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e6727-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tennessee Valley Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e6728-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Virgin Islands Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e6729-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation, Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e672a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e672b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/1/F/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Agency, Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e672c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “part-time career employment” means part-time employment of 16 to 32 hours a week (or 32 to 64 hours during a biweekly pay period in the case of a flexible or compressed work schedule under subchapter II of chapter 61 of this title) under a schedule consisting of an equal or varied number of hours per day, whether in a position which would be part-time without regard to this section or one established to allow job-sharing or comparable arrangements, but does not include employment on a temporary or intermittent basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81e672d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1056"},"text":"92 Stat. 1056","children":[],"tail":", § 3391; renumbered § 3401 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1226"},"text":"92 Stat. 1226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/221/s3"},"text":"Pub. L. 97–221, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-23"},"text":"July 23, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/233"},"text":"96 Stat. 233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tVI/s615/b/1/B"},"text":"Pub. L. 97–468, title VI, § 615(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2578"},"text":"96 Stat. 2578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/15"},"text":"Pub. L. 102–378, § 2(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1347"},"text":"106 Stat. 1347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3548/a/1"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3548(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2868"},"text":"110 Stat. 2868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81e672e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81e672f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81e6730-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", which directed amendment of par. (1) by striking cl. (v) and redesignating cls. (vi), (vii), and (viii) as (v), (vi), and (vii), respectively, was executed by striking cl. (iv), relating to the Panama Canal Company, and redesignating cls. (v), (vi), and (vii) as (iv), (v), and (vi), respectively, to reflect the probable intent of Congress, because par. (1) does not contain a cl. (viii) and the amendments were included in a series of conforming amendments relating to the Panama Canal."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (1)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":", which directed the amendment of cl. (iv) by substituting “Virgin Islands” for “Virgin Island”, was executed by making the substitution in cl. (iii) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Par. (1)(iii) to (viii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" struck out cl. (iii) which excluded the Alaska Railroad, and redesignated cls. (iv) to (viii) as (iii) to (vii), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/221"},"text":"Pub. L. 97–221","children":[],"tail":" inserted “(or 32 to 64 hours during a biweekly pay period in the case of a flexible or compressed work schedule under subchapter II of chapter 61 of this title)” after “week”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/c/1/B"},"text":"Pub. L. 95–454, § 906(c)(1)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3391"},"text":"section 3391 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/c/2/A"},"text":"Pub. L. 95–454, § 906(c)(2)(A)","children":[],"tail":", substituted “chapter” for “subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81e6731-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e6732-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/468"},"text":"Pub. L. 97–468","children":[],"tail":" effective on date of transfer of Alaska Railroad to the State ["},{"tag":"date","attrib":{"date":"1985-01-05"},"text":"Jan. 5, 1985","children":[],"tail":"], pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1203"},"text":"section 1203 of Title 45","children":[],"tail":", Railroads, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/s615/b"},"text":"section 615(b) of Pub. L. 97–468","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e6733-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb81e6734-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s1"},"text":"Section 1 of Pub. L. 95–437","children":[],"tail":" provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/437/s1"},"text":"“This Act [enacting this chapter, amending sections 8347, 8716, 8906, and 8913 of this title, and enacting provisions set out as notes under this section and sections 3407 and 8906 of this title] may be cited as the ‘Federal Employees Part-Time Career Employment Act of 1978’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb81e6735-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s2"},"text":"Pub. L. 95–437, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1055"},"text":"92 Stat. 1055","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/437/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" many individuals in our society possess great productive potential which goes unused because they cannot meet the requirements of a standard workweek; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" part-time permanent employment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides older individuals with a gradual transition into retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides employment opportunities to handicapped individuals or others who require a reduced workweek;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides parents opportunities to balance family responsibilities with the need for additional income;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits students who must finance their own education or vocational training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits the Government, as an employer, by increasing productivity and job satisfaction, while lowering turnover rates and absenteeism, offering management more flexibility in meeting work requirements, and filling shortages in various occupations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits society by offering a needed alternative for those individuals who require or prefer shorter hours (despite the reduced income), thus increasing jobs available to reduce unemployment while retaining the skills of individuals who have training and experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose of this Act [enacting this chapter, amending sections 8347, 8716, 8906, and 8913 of this title, and enacting provisions set out as notes under this section and sections 3407 and 8906 of this title] is to provide increased part-time career employment opportunities throughout the Federal Government.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
