{"tag":"section","attrib":{"id":"idb7ff467c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132"},"text":null,"children":[{"tag":"num","attrib":{"value":"3132"},"text":"§ 3132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and exclusions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ff467d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff467e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means an Executive agency, except a Government corporation and the Government Accountability Office, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff467f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agency or unit thereof excluded from coverage by the President under subsection (c) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4680-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation, the Drug Enforcement Administration, the Central Intelligence Agency, the Office of the Director of National Intelligence, the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Security Agency, Department of Defense intelligence activities the civilian employees of which are subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1590"},"text":"section 1590 of title 10","children":[],"tail":", and, as determined by the President, an Executive agency, or unit thereof, whose principal function is the conduct of foreign intelligence or counterintelligence activities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4681-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Election Commission or the Election Assistance Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4682-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Comptroller of the Currency, the Office of Thrift Supervision,,","children":[{"tag":"ref","attrib":{"idref":"fn002050"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002050"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" the Resolution Trust Corporation, the Farm Credit Administration, the Federal Housing Finance Agency, the National Credit Union Administration, the Bureau of Consumer Financial Protection, and the Office of Financial Research;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4683-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4684-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commodity Futures Trading Commission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4685-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Senior Executive Service position” means any position in an agency which is classified above GS–15 pursuant to section 5108 or in level IV or V of the Executive Schedule, or an equivalent position, which is not required to be filled by an appointment by the President by and with the advice and consent of the Senate, and in which an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff4686-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directs the work of an organizational unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4687-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is held accountable for the success of one or more specific programs or projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4688-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitors progress toward organizational goals and periodically evaluates and makes appropriate adjustments to such goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4689-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervises the work of employees other than personal assistants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff468a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise exercises important policy-making, policy-determining, or other executive functions;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7ff468b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any position in the Foreign Service of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7ff468c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative law judge position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7ff468d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any position established as a qualified position in the excepted service by the Secretary of Homeland Security under section 226 ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. See References in Text note below."}],"tail":" of the Homeland Security Act of 2002; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7ff468e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/2/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any position established as a qualified position in the excepted service by the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599f"},"text":"section 1599f of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff468f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “senior executive” means a member of the Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4690-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “career appointee” means an individual in a Senior Executive Service position whose appointment to the position or previous appointment to another Senior Executive Service position was based on approval by the Office of Personnel Management of the executive qualifications of such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4691-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “limited term appointee” means an individual appointed under a nonrenewable appointment for a term of 3 years or less to a Senior Executive Service position the duties of which will expire at the end of such term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4692-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “limited emergency appointee” means an individual appointed under a nonrenewable appointment, not to exceed 18 months, to a Senior Executive Service position established to meet a bona fide, unanticipated, urgent need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4693-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “noncareer appointee” means an individual in a Senior Executive Service position who is not a career appointee, a limited term appointee, or a limited emergency appointee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4694-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “career reserved position” means a position which is required to be filled by a career appointee and which is designated under subsection (b) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4695-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “general position” means any position, other than a career reserved position, which may be filled by either a career appointee, noncareer appointee, limited emergency appointee, or limited term appointee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4696-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4697-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of paragraph (8) of subsection (a) of this section, the Office shall prescribe the criteria and regulations governing the designation of career reserved positions. The criteria and regulations shall provide that a position shall be designated as a career reserved position only if the filling of the position by a career appointee is necessary to ensure impartiality, or the public’s confidence in the impartiality, of the Government. The head of each agency shall be responsible for designating career reserved positions in such agency in accordance with such criteria and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b698-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall periodically review general positions to determine whether the positions should be designated as career reserved. If the Office determines that any such position should be so designated, it shall order the agency to make the designation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b699-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the provisions of any other law, any position to be designated as a Senior Executive Service position (except a position in the Executive Office of the President) which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb801b69a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under the Executive Schedule, or for which the rate of basic pay is determined by reference to the Executive Schedule, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb801b69b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the day before the date of the enactment of the Civil Service Reform Act of 1978 was specifically required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2102"},"text":"section 2102 of this title","children":[],"tail":" or otherwise required by law to be in the competitive service,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be designated as a career reserved position if the position entails direct responsibility to the public for the management or operation of particular government programs or functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b69c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 1 of each year, the head of each agency shall publish in the Federal Register a list of positions in the agency which were career reserved positions during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b69d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency may file an application with the Office setting forth reasons why it, or a unit thereof, should be excluded from the coverage of this subchapter. The Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb801b69e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the application and stated reasons,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b69f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake a review to determine whether the agency or unit should be excluded from the coverage of this subchapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b6a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completion of its review, recommend to the President whether the agency or unit should be excluded from the coverage of this subchapter.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If the Office recommends that an agency or unit thereof be excluded from the coverage of this subchapter, the President may, on written determination, make the exclusion for the period determined by the President to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any agency or unit which is excluded from coverage under subsection (c) of this section shall make a sustained effort to bring its personnel system into conformity with the Senior Executive Service to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may at any time recommend to the President that any exclusion previously granted to an agency or unit thereof under subsection (c) of this section be revoked. Upon recommendation of the Office, the President may revoke, by written determination, any exclusion made under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb801b6a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agency is excluded under subsection (c) of this section, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b6a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3132/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any exclusion is revoked under subsection (e) of this section,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Office shall, within 30 days after the action, transmit to the Congress written notice of the exclusion or revocation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb801b6a6-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s402/a"},"text":"Pub. L. 95–454, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1155"},"text":"92 Stat. 1155","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/12"},"text":"Pub. L. 96–54, § 2(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/187/tII/s203"},"text":"Pub. L. 96–187, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-01-08"},"text":"Jan. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1368"},"text":"93 Stat. 1368","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/325/s2/c"},"text":"Pub. L. 100–325, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-30"},"text":"May 30, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/581"},"text":"102 Stat. 581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s742/c"},"text":"Pub. L. 101–73, title VII, § 742(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/437"},"text":"103 Stat. 437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/9/A"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(9)(A)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1441; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1841"},"text":"Pub. L. 101–624, title XVIII, § 1841","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3835"},"text":"104 Stat. 3835","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tIV/s402/b"},"text":"Pub. L. 102–496, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3184"},"text":"106 Stat. 3184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIII/s1351/b"},"text":"Pub. L. 102–550, title XIII, § 1351(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3969"},"text":"106 Stat. 3969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s501/d"},"text":"Pub. L. 103–359, title V, § 501(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3429"},"text":"108 Stat. 3429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA