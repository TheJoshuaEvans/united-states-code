{"tag":"section","attrib":{"id":"idb92e2a35-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10205"},"text":null,"children":[{"tag":"num","attrib":{"value":"10205"},"text":"§ 10205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service step adjustments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e2a36-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “calendar week of active service” includes all periods of leave with pay or other paid time off, and periods of non-pay status which do not cumulatively equal one 40-hour workweek.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2a37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member whose current performance is at an acceptable level of competence shall have a service step adjustment as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2a38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member in service step 1, 2, or 3 shall be advanced successively to the next higher service step at the beginning of the first pay period immediately following the completion of 52 calendar weeks of active service in the member’s service step.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2a39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member in service step 4, 5, 6, 7, 8, 9, 10, or 11 shall be advanced successively to the next higher service step at the beginning of the first pay period immediately following the completion of 104 calendar weeks of active service in the member’s service step.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2a3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member in service step 12 shall be advanced successively to the next higher service step at the beginning of the first pay period immediately following the completion of 156 calendar weeks of active service in the member’s service step.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92e2a3b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282/s2/a"},"text":"Pub. L. 111–282, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3036"},"text":"124 Stat. 3036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92e2a3c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92e2a3d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb92e2a3e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first pay period which begins after ","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/282/s5"},"text":"section 5 of Pub. L. 111–282","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
