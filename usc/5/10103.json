{"tag":"section","attrib":{"id":"idb92e29b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103"},"text":null,"children":[{"tag":"num","attrib":{"value":"10103"},"text":"§ 10103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career paths","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e29b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that appropriate career paths for personnel of the Agency are identified, including the education, training, experience, and assignments necessary for career progression within the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish information on the career paths described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education, Training, and Experience","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that all personnel of the Agency are provided the opportunity to acquire the education, training, and experience necessary to qualify for promotion within the Agency, including, as appropriate, the opportunity to participate in the Rotation Program established under section 844 of the Homeland Security Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish a policy for assigning Agency personnel to positions that provides for a balance between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for such personnel to serve in career enhancing positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the need to require service in a position for a sufficient period of time to provide the stability necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e29bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the duties of that position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e29bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for responsibility and accountability for actions taken in that position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92e29be-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s621/a"},"text":"Pub. L. 109–295, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1413"},"text":"120 Stat. 1413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92e29bf-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92e29c0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92e29c1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 844 of the Homeland Security Act of 2002, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s414"},"text":"section 414 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
