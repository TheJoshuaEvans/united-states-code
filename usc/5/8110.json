{"tag":"section","attrib":{"id":"idb8be29ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110"},"text":null,"children":[{"tag":"num","attrib":{"value":"8110"},"text":"§ 8110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Augmented compensation for dependents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be2a00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section, “dependent” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be2a01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a wife, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8be2a02-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" she is a member of the same household as the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2a03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" she is receiving regular contributions from the employee for her support; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2a04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has been ordered by a court to contribute to her support;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2a05-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a husband, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8be2a06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he is a member of the same household as the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2a07-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he is receiving regular contributions from the employee for his support; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2a08-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has been ordered by a court to contribute to his support;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2a09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an unmarried child, while living with the employee or receiving regular contributions from the employee toward his support, and who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8be2a0a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under 18 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2a0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over 18 years of age and incapable of self-support because of physical or mental disability; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2a0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent, while wholly dependent on and supported by the employee.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding paragraph (3) of this subsection, compensation payable for a child that would otherwise end because the child has reached 18 years of age shall continue if he is a student as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":" at the time he reaches 18 years of age for so long as he continues to be such a student or until he marries."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be2a0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A disabled employee with one or more dependents is entitled to have his basic compensation for disability augmented—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be2a0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the rate of 8⅓ percent of his monthly pay if that compensation is payable under section 8105 or 8107(a) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2a0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the rate of 8⅓ percent of the difference between his monthly pay and his monthly wage-earning capacity if that compensation is payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8106/a"},"text":"section 8106(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be2a10-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/539"},"text":"80 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/53"},"text":"Pub. L. 90–83, § 1(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/210"},"text":"81 Stat. 210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s6"},"text":"Pub. L. 93–416, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1145"},"text":"88 Stat. 1145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be2a11-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"hist