{"tag":"section","attrib":{"id":"idb8100e7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3311"},"text":null,"children":[{"tag":"num","attrib":{"value":"3311"},"text":"§ 3311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference eligibles; examinations; crediting experience","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In examinations for the competitive service in which experience is an element of qualification, a preference eligible is entitled to credit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8100e7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for service in the armed forces when his employment in a similar vocation to that for which examined was interrupted by the service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8100e7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for all experience material to the position for which examined, including experience gained in religious, civic, welfare, service, and organizational activities, regardless of whether he received pay therefor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8100e7e-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/420"},"text":"80 Stat. 420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8100e7f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8100e80-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8100e81-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s853"},"text":"5 U.S.C. 853","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-06-27/ch287/s4"},"text":"June 27, 1944, ch. 287, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/388"},"text":"58 Stat. 388","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “for the competitive service” are added after “examinations” for clarity. Application of this section to the excepted service in the executive branch and to the government of the District of Columbia, as provided in former section 858, is carried into section 3320.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “service in the armed forces” are substituted for “in the military or naval service of the United States” on authority of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/s305/a"},"text":"Act of July 26, 1947, ch. 343, § 305(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/508"},"text":"61 Stat. 508","children":[],"tail":". The word “actual” is omitted as surplusage."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2), the words “material to the position for which examined” are substituted for “valuable” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
