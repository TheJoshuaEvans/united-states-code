{"tag":"section","attrib":{"id":"idb90a75c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476"},"text":null,"children":[{"tag":"num","attrib":{"value":"8476"},"text":"§ 8476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90a75ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall meet—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than once during each month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at additional times at the call of the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a75cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in sections 8472(g)(1)(C) and 8474(a)(1) of this title, the Board shall perform the functions and exercise the powers of the Board on a majority vote of a quorum of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy on the Board shall not impair the authority of a quorum of the Board to perform the functions and exercise the powers of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a75d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members of the Board shall constitute a quorum for the transaction of business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a75d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Board who is not an officer or employee of the Federal Government shall be compensated at the daily rate of basic pay for level IV of the Executive Schedule for each day during which such member is engaged in performing a function of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Board shall be paid travel, per diem, and other necessary expenses under subchapter I of chapter 57 of this title while traveling away from such member’s home or regular place of business in the performance of the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbdc4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments authorized under this subsection shall be paid from the Thrift Savings Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90cbdc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8476/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The accrued annual leave of any employee who is a member of the Board or the Council shall not be charged for any time used in performing services for the Board or the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90cbdc6-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/581"},"text":"100 Stat. 581","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/9/K"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(9)(K)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1442.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90cbdc7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90cbdc8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb90cbdc9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsec. (d)(1), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90cbdca-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" substituted “level IV of the Executive Schedule” for “grade GS–18 of the General Schedule”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90cbdcb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90cbdcc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
