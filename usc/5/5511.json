{"tag":"section","attrib":{"id":"idb86386c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5511"},"text":null,"children":[{"tag":"num","attrib":{"value":"5511"},"text":"§ 5511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding pay; employees removed for cause","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86386c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (b) of this section, the earned pay of an employee removed for cause may not be withheld or confiscated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86386c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an employee indebted to the United States is removed for cause, the pay accruing to the employee shall be applied in whole or in part to the satisfaction of any claim or indebtedness due the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86386c3-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/477"},"text":"80 Stat. 477","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86386c4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86386c5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86386c6-5e84-11f1-a692-ec26948f6fea"},"text":"\