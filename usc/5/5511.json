 U.S.C. 46a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-02-24/ch287"},"text":"Feb. 24, 1931, ch. 287","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1415"},"text":"46 Stat. 1415","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “From and after ","children":[{"tag":"date","attrib":{"date":"1931-02-24"},"text":"February 24, 1931","children":[],"tail":"” are omitted as executed. The word “employee” is coextensive with and substituted for “civil employee of the United States” in view of the definition of “employee” in section 2105."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
