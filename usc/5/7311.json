{"tag":"section","attrib":{"id":"idb8b21b76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7311"},"text":null,"children":[{"tag":"num","attrib":{"value":"7311"},"text":"§ 7311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loyalty and striking","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An individual may not accept or hold a position in the Government of the United States or the government of the District of Columbia if he—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21b77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocates the overthrow of our constitutional form of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21b78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an organization that he knows advocates the overthrow of our constitutional form of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21b79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7311/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in a strike, or asserts the right to strike, against the Government of the United States or the government of the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21b7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7311/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of an organization of employees of the Government of the United States or of individuals employed by the government of the District of Columbia that he knows asserts the right to strike against the Government of the United States or the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21b7b-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/524"},"text":"80 Stat. 524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b21b7c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8b21b7d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8b21b7e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s118p"},"text":"5 U.S.C. 118p","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-09/ch690/s1"},"text":"Aug. 9, 1955, ch. 690, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/624"},"text":"69 Stat. 624","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[Uncodified].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-06-29/ch479/s3"},"text":"June 29, 1956, ch. 479, § 3","children":[],"tail":", (as applicable to the "},{"tag":"html:a","attrib":{"href":"/us/act/1955-08-09/ch690/s1"},"text":"Act of Aug. 9, 1955, ch. 690, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/624"},"text":"69 Stat. 624","children":[],"tail":"), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/453"},"text":"70 Stat. 453","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “position” is coextensive with and is substituted for “office or employment”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraphs (1) and (2), the words “in the United States” in former section 118p(1), (2) are omitted as unnecessary in view of the reference to “our constitutional form of government”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraphs (3) and (4), the reference to the “government of the District of Columbia” is added on authority of the Act of ","children":[{"tag":"date","attrib":{"date":"1956-06-29"},"text":"June 29, 1956","children":[],"tail":", in order to make these paragraphs meaningful with respect to individuals employed by the government of the District of Columbia. The words “From and after "},{"tag":"date","attrib":{"date":"1956-07-01"},"text":"July 1, 1956","children":[],"tail":"”, appearing in the Act of "},{"tag":"date","attrib":{"date":"1956-06-29"},"text":"June 29, 1956","children":[],"tail":", are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8b21b7f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8b21b80-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 10450","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10450, ","children":[{"tag":"date","attrib":{"date":"1953-04-27"},"text":"Apr. 27, 1953","children":[],"tail":", 18 F.R. 2489, as amended by Ex. Ord. No. 10491, "},{"tag":"date","attrib":{"date":"1953-10-15"},"text":"Oct. 15, 1953","children":[],"tail":", 18 F.R. 6583; Ex. Ord. No. 10531, "},{"tag":"date","attrib":{"date":"1954-05-27"},"text":"May 27, 1954","children":[],"tail":", 19 F.R. 3069; Ex. Ord. No. 10548, "},{"tag":"date","attrib":{"date":"1954-08-03"},"text":"Aug. 3, 1954","children":[],"tail":", 19 F.R. 4871; Ex. Ord. No. 10550, "},{"tag":"date","attrib":{"date":"1954-08-06"},"text":"Aug. 6, 1954","children":[],"tail":", 19 F.R. 4981; Ex. Ord. No. 11605, "},{"tag":"date","attrib":{"date":"1971-07-02"},"text":"July 2, 1971","children":[],"tail":", 36 F.R. 12831; Ex. Ord. No. 11785, "},{"tag":"date","attrib":{"date":"1974-06-04"},"text":"June 4, 1974","children":[],"tail":", 39 F.R. 20053; Ex. Ord. No. 12107, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1055, which related to security requirements for Government employees, was revoked by Ex. Ord. No. 13467, § 3(a), as added by Ex. Ord. No. 13764, § 3(v), "},{"tag":"date","attrib":{"date":"2017-01-17"},"text":"Jan. 17, 2017","children":[],"tail":", 82 F.R. 8128, which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of Title 50","children":[],"tail":", War and National Defense, and which contains additional construction provisions related to the revocation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8b21b81-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 11605","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11605. ","children":[{"tag":"date","attrib":{"date":"1971-07-02"},"text":"July 2, 1971","children":[],"tail":", 36 F.R. 12831, which amended Ex. Ord. No. 10450, "},{"tag":"date","attrib":{"date":"1953-04-27"},"text":"Apr. 27, 1953","children":[],"tail":", 18 F.R. 2489, which related to security requirements for government employees, was revoked by Ex. Ord. No. 11785, "},{"tag":"date","attrib":{"date":"1974-06-04"},"text":"June 4, 1974","children":[],"tail":", 39 F.R. 20053, set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8b21b82-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11785. Security Requirements for Governmental Employees","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11785, ","children":[{"tag":"date","attrib":{"date":"1974-06-04"},"text":"June 4, 1974","children":[],"tail":", 39 F.R. 20053, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by the Constitution and statutes of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"5 U.S.C. 1101","children":[],"tail":" "},{"tag":"i","attrib":{},"text":"et seq., ","children":[],"tail":"3301, 3571, 7301, 7313, 7501(c), 7512, 7532, and 7533; and as President of the United States, and finding such action necessary in the best interests of national security, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. Section 12 of Executive Order No. 10450 of "},{"tag":"date","attrib":{"date":"1953-04-27"},"text":"April 27, 1953","children":[],"tail":", as amended [set out as a note under this section], is revised to read in its entirety as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 12. Executive Order No. 9835 of "},{"tag":"date","attrib":{"date":"1947-03-21"},"text":"March 21, 1947","children":[],"tail":", as amended, is hereby revoked.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. Neither the Attorney General, nor the Subversive Activities Control Board, nor any other agency shall designate organizations pursuant to section 12 of Executive Order No. 10450, as amended, nor circulate nor publish a list of organizations previously so designated. The list of organizations previously designated is hereby abolished and shall not be used for any purpose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. Subparagraph (5) of paragraph (a) of section 8 of Executive Order No. 10450, as amended, is revised to read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Knowing membership with the specific intent of furthering the aims of, or adherence to and active participation in, any foreign or domestic organization, association, movement, group, or combination of persons (hereinafter referred to as organizations) which unlawfully advocates or practices the commission of acts of force or violence to prevent others from exercising their rights under the Constitution or laws of the United States or of any State, or which seeks to overthrow the Government of the United States or any State or subdivision thereof by unlawful means.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. Executive Order No. 11605 of "},{"tag":"date","attrib":{"date":"1971-07-02"},"text":"July 2, 1971","children":[],"tail":", is revoked."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Richard Nixon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
