{"tag":"section","attrib":{"id":"idb90a75ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474"},"text":null,"children":[{"tag":"num","attrib":{"value":"8474"},"text":"§ 8474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90a75ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall appoint, without regard to the provisions of law governing appointments in the competitive service, an Executive Director by action agreed to by a majority of the members of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director shall have substantial experience, training, and expertise in the management of financial investments and pension benefit plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a75b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Executive Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the policies established by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invest and manage the Thrift Savings Fund in accordance with the investment policies and other policies established by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase annuity contracts and provide for the payment of other benefits under subchapter III of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the provisions of this subchapter and subchapter III of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations (other than regulations relating to fiduciary responsibilities) as may be necessary for the administration of this subchapter and subchapter III of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet from time to time with the Council upon request of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a75b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Executive Director may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such regulations as may be necessary to carry out the responsibilities of the Executive Director under this section, other than regulations relating to fiduciary responsibilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint such personnel as may be necessary to carry out the provisions of this subchapter and subchapter III of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to approval by the Board, procure the services of experts and consultants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure directly from an Executive agency, the United States Postal Service, or the Postal Regulatory Commission any information necessary to carry out the provisions of this subchapter or subchapter III of this chapter and policies of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such payments out of sums in the Thrift Savings Fund as the Executive Director determines are necessary to carry out the provisions of this subchapter and subchapter III of this chapter and the policies of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the compensation, per diem, and travel expenses of individuals appointed under paragraphs (2), (3), and (7) of this subsection from the Thrift Savings Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and use the services of individuals employed intermittently in the Government service and reimburse such individuals for travel expenses, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of this title","children":[],"tail":", including per diem as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5702"},"text":"section 5702 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise expressly prohibited by law or the policies of the Board, delegate any of the Executive Director’s functions to such employees under the Board as the Executive Director may designate and authorize such successive redelegations of such functions to such employees under the Board as the Executive Director may consider to be necessary or appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8474/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other actions as are appropriate to carry out the functions of the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90a75c1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/580"},"text":"100 Stat. 580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/b"},"text":"Pub. L. 109–435, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3241"},"text":"120 Stat. 3241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90a75c2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90a75c3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90a75c4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
