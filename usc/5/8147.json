ubstituted for “each executive department and each agency or instrumentality of the United States or other establishment”. The words “(hereinafter called ‘agency’)” are omitted as unnecessary because “agency or instrumentality” is substituted for “agency” in the remainder of this subsection and in subsection (c). The words “occurring after ","children":[{"tag":"date","attrib":{"date":"1960-12-01"},"text":"December 1, 1960","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c52e5a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c52e5b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8147(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 785(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 4, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/488/s10/c"},"text":"Pub. L. 89–488, § 10(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/255"},"text":"80 Stat. 255","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “performed” is substituted for “rendered” to conform to the style of title 5. The words “sections 8131 and 8132 of this title” are substituted for “sections 26 and 27” to reflect the codification of those sections in title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c52e5c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c52e5d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “section 9101(2)” for “section 856”, and “chapter 91” for “sections 841–869”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" inserted “during the first fifteen days of October following the furnishing of the statement” after “its control” and substituted “July 1 through June 30 expense period” for “fiscal year” and “the fiscal year beginning in the next calendar year” for “the next fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s26"},"text":"Pub. L. 93–416, § 26","children":[],"tail":", substituted “Office of Management and Budget” for “Bureau of the Budget”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s25"},"text":"Pub. L. 93–416, § 25","children":[],"tail":", inserted reference to the United States Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c52e5e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c52e5f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s25"},"text":"section 25 of Pub. L. 93–416","children":[],"tail":" applicable to cases where injury or death occurred prior to "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", but only to a period beginning on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s26"},"text":"section 26 of Pub. L. 93–416","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", and applicable to any death or injury occurring on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e60-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Government Publishing Office Payment of Cost of Administration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/275/tIII/s313"},"text":"Pub. L. 105–275, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2460"},"text":"112 Stat. 2460","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1301/b"},"text":"“For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147"},"text":"section 8147 of title 5","children":[],"tail":", United States Code, the Government Publishing Office is not considered an agency which is required by statute to submit an annual budget pursuant to or as provided by chapter 91 of title 31, United States Code, and is not required to pay an additional amount for the cost of administration.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e61-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Fiscal Year 1994 Prohibition on Payments to Individuals Convicted of Issuing False Statements or Fraud","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/112/tI/s102"},"text":"Pub. L. 103–112, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-21"},"text":"Oct. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1089"},"text":"107 Stat. 1089","children":[],"tail":", Department of Labor Appropriation Act, 1994, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/112/tI/s102"},"text":"“None of the funds in the Employees’ Compensation Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147"},"text":"5 U.S.C. 8147","children":[],"tail":" shall be expended for payment of compensation, benefits, and expenses to any individual convicted of a violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1920"},"text":"18 U.S.C. 1920","children":[],"tail":", or of any felony fraud related to the application for or receipt of benefits under subchapters I or III of chapter 81 of title 5, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e62-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit Into Fund Between July 1, and ","children":[{"tag":"date","attrib":{"date":"1976-07-15"},"text":"July 15, 1976","children":[],"tail":", of Specified Part of "},{"tag":"date","attrib":{"date":"1975-08-15"},"text":"August 15, 1975","children":[],"tail":", Statement"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/274/tI/s120"},"text":"Pub. L. 94–274, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/389"},"text":"90 Stat. 389","children":[],"tail":", provided that for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147/b"},"text":"5 U.S.C. 8147(b)","children":[],"tail":", each agency and instrumentality of the United States dependent upon an annual appropriation and having an employee who is or may be entitled to compensation benefits under this subchapter or any extension or application thereof shall deposit in the Treasury to the credit of the Employees’ Compensation Fund, no later than "},{"tag":"date","attrib":{"date":"1976-07-15"},"text":"July 15, 1976","children":[],"tail":", but no earlier than "},{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", 25 per centum of the amount stated in the "},{"tag":"date","attrib":{"date":"1975-08-15"},"text":"August 15, 1975","children":[],"tail":", statement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e63-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Personnel Not Affected by 1967 Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases authorized under amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/71"},"text":"section 1(71) of Pub. L. 90–83","children":[],"tail":" not applicable to specified personnel, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s7"},"text":"section 7 of Pub. L. 90–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8103"},"text":"section 8103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
