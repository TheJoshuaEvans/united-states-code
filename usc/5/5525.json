{"tag":"section","attrib":{"id":"idb86840cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5525"},"text":null,"children":[{"tag":"num","attrib":{"value":"5525"},"text":"§ 5525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment and assignment of pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The head of each agency may establish procedures under which each employee of the agency is permitted to make allotments and assignments of amounts out of his pay for such purpose as the head of the agency considers appropriate. For purposes of this section, the term “agency” includes the Office of the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb86840cc-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/481"},"text":"80 Stat. 481","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/68/tI/s133/b/1"},"text":"Pub. L. 107–68, title I, § 133(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/582"},"text":"115 Stat. 582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86840cd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86840ce-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86840cf-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col