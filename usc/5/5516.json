[{"tag":"html:p","attrib":{},"text":"[Uncodified].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-03-31/ch154/s11"},"text":"Mar. 31, 1956, ch. 154, § 11","children":[],"tail":" “(k)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/77"},"text":"70 Stat. 77","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2(c) “(z)” of the Act of ","children":[{"tag":"date","attrib":{"date":"1956-03-31"},"text":"Mar. 31, 1956","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/68"},"text":"70 Stat. 68","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t47/s1551c/z"},"text":"section 1551c(z) of title 47","children":[],"tail":", District of Columbia Code) contains a definition of “employee” that is applicable to this section. Accordingly, the last sentence of subsection (a) is added to preserve the application of the source law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb865cff9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb865cffa-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “Mayor” for “Commissione