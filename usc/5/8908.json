rib":{"href":"/us/usc/t5/s8903a"},"text":"section 8903a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/53/s3/a/1"},"text":"Pub. L. 99–53, § 3(a)(1)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/342"},"text":"Pub. L. 94–342","children":[],"tail":" designated existing provisions as subsec. (a), added subsec. (b), and substituted “employees and survivor annuitants” for “employee” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91fd1b1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91fd1b2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" applicable with respect to termination of marriage taking effect before, on, or after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", except that benefits are payable only with respect to amounts accruing for periods beginning on first day of month beginning after the later of termination of marriage or "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see section 101(f) [title VI, § 633(b)] of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8341"},"text":"section 8341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91fd1b3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91fd1b4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/342/s2"},"text":"Pub. L. 94–342, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-06"},"text":"July 6, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/808"},"text":"90 Stat. 808","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/342/s2"},"text":"“The amendments made by the first section of this Act [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":", or on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1976-07-06"},"text":"July 6, 1976","children":[],"tail":"], whichever date is later. Such amendments shall apply with respect to individuals whose survivor annuities are restored before, on, or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91fd1b5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Insurance Coverage for Restored Disability Annuitants","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that subsec. (c) of this section shall apply with respect to any individual whose disability annuity is or was restored under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8337/e"},"text":"section 8337(e) of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", directing that the Office of Personnel Management notify each individual of any rights which such individual may have under subsec. (c) of this section, including any procedures or deadlines which might apply with respect to the exercise of those rights, directing that such notification be provided to any individual who, as of the 90th day after "},{"tag":"date","attrib":{"date":"1985-06-17"},"text":"June 17, 1985","children":[],"tail":", is receiving a disability annuity which was restored to such individual under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8337/e"},"text":"section 8337(e) of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", directing that nothing in subsec. (c) of this section be construed to authorize coverage under this chapter in the case of any individual who becomes enrolled in a health benefits plan under subsec. (c) of this section for any period before the date as of which such individual becomes so enrolled, and directing that such rule of construction apply with respect to any individual receiving a disability annuity which is or was restored under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8337/e"},"text":"section 8337(e) of this title","children":[],"tail":" after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", and before the expiration of the 90-day period beginning on "},{"tag":"date","attrib":{"date":"1985-06-17"},"text":"June 17, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/53/s3/c"},"text":"section 3(c) of Pub. L. 99–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8706"},"text":"section 8706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
