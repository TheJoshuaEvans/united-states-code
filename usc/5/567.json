{"tag":"section","attrib":{"id":"idb7ba2739-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s567"},"text":null,"children":[{"tag":"num","attrib":{"value":"567"},"text":"§ 567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A negotiated rulemaking committee shall terminate upon promulgation of the final rule under consideration, unless the committee’s charter contains an earlier termination date or the agency, after consulting the committee, or the committee itself specifies an earlier termination date.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7ba273a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/648/s3/a"},"text":"Pub. L. 101–648, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4974"},"text":"104 Stat. 4974","children":[],"tail":", § 587; renumbered § 567, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/a/2"},"text":"Pub. L. 102–354, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ba273b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ba273c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ba273d-5e84-11f1-a692-ec26948f6fea"},"text":null,"ch