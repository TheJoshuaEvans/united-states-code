{"tag":"section","attrib":{"id":"idb908049c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8463"},"text":null,"children":[{"tag":"num","attrib":{"value":"8463"},"text":"§ 8463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each annuity payable from the Fund is stated as an annual amount, one-twelfth of which, rounded to the next lower dollar, constitutes the monthly rate payable on the first business day of the first month beginning after the month for which it has accrued.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb908049d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/574"},"text":"100 Stat. 574","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
