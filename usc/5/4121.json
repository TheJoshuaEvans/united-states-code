{"tag":"section","attrib":{"id":"idb82a4d97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4121"},"text":null,"children":[{"tag":"num","attrib":{"value":"4121"},"text":"§ 4121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific training programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In consultation with the Office of Personnel Management, the head of each agency shall establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82a4d98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4121/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive management succession program to provide training to employees to develop managers for the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4d99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4121/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a program to provide training to managers on actions, options, and strategies a manager may use in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82a4d9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4121/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to employees with unacceptable performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4121/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring employees and improving employee performance and productivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4121/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting employee performance appraisals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82a4d9d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/tII/s201/b/1"},"text":"Pub. L. 108–411, title II, § 201(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2311"},"text":"118 Stat. 2311","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
