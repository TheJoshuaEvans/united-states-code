{"tag":"section","attrib":{"id":"idb798bc55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414"},"text":null,"children":[{"tag":"num","attrib":{"value":"414"},"text":"§ 414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions concerning the Corporation for National and Community Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb798bc56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the provisions of paragraphs (7) and (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/a"},"text":"section 406(a) of this title","children":[],"tail":", it is within the exclusive jurisdiction of the Inspector General of the Corporation for National and Community Service to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb798bc57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and determine the compensation of such officers and employees in accordance with section 195(b) of the National and Community Service Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651f/b"},"text":"42 U.S.C. 12651f(b)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb798bc58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the temporary and intermittent services of and compensate such experts and consultants, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as may be necessary to carry out the functions, powers, and duties of the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb798bc59-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date on which the Chief Executive Officer of the Corporation for National and Community Service transmits any report to the Congress under subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405"},"text":"section 405 of this title","children":[],"tail":", the Chief Executive Officer shall transmit such report to the Board of Directors of such Corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb798bc5a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Audit Reports by Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date on which the Chief Executive Officer of the Corporation for National and Community Service transmits a report described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/c"},"text":"section 405(c) of this title","children":[],"tail":" to the Board of Directors as provided under subsection (b) of this section, the Chief Executive Officer shall also transmit any audit report which is described in the statement required under section 405(c)(4) to the Board of Directors. All such audit reports shall be placed on the agenda for review at the next scheduled meeting of the Board of Directors following such transmittal. The Chief Executive Officer of the Corporation shall be present at such meeting to provide any information relating to such audit reports."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb798bc5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report of Problem, Abuse, or Deficiency to Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date on which the Inspector General of the Corporation for National and Community Service reports a problem, abuse, or deficiency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405/e"},"text":"section 405(e) of this title","children":[],"tail":" to the Chief Executive Officer of the Corporation, the Chief Executive Officer shall report such problem, abuse, or deficiency to the Board of Directors."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb798bc5c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4235"},"text":"136 Stat. 4235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb798bc5d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb798bc5e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[