{"tag":"section","attrib":{"id":"idb8c073a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8120"},"text":null,"children":[{"tag":"num","attrib":{"value":"8120"},"text":"§ 8120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of injury","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Immediately after an injury to an employee which results in his death or probable disability, his immediate superior shall report to the Secretary of Labor. The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c073a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8120/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the information that the report shall contain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8120/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the immediate superior to make supplemental reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8120/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain such additional reports and information from employees as are agreed on by the Secretary and the head of the employing agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c073a8-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80