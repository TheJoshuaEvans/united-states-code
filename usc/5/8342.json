ag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 2261(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Mar. 23, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/373/s2"},"text":"Pub. L. 89–373, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/78"},"text":"80 Stat. 78","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 2251(j) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Apr. 25, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/407/s1"},"text":"Pub. L. 89–407, § 1","children":[],"tail":" (less words before 1st comma), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/131"},"text":"80 Stat. 131","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the amendment is made for consistency within the subchapter and to reflect that it is the individual, rather than the position, that is subject to the subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the last sentence of subsection (c), the words “this subsection” are substituted for “section 11” to reflect the codification of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8e69930-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8e69931-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Employees’ Retirement System Act of 1986, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/514"},"text":"100 Stat. 514","children":[],"tail":". Title III of the Federal Employees’ Retirement System Act of 1986 amended sections 3121 and 6103 of Title 26, Internal Revenue Code, "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s1005"},"text":"section 1005 of Title 39","children":[],"tail":", Postal Service, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"section 410 of Title 42","children":[],"tail":", The Public Health and Welfare, enacted provisions set out as notes under sections 8331, 8401, 8432, and 8472 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of Title 26","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of this title","children":[],"tail":". Section 302 of that Act is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8e69932-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/361"},"text":"Pub. L. 106–361","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Payment of the lump-sum credit under subsection (a) of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) may be made only if any current spouse and any former spouse of the employee or Member are notified of the employee or Member’s application; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) shall be subject to the terms of a court decree of divorce, annulment, or legal separation or any court order or court approved property settlement agreement incident to such decree if—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the decree, order, or agreement expressly relates to any portion of the lump-sum credit involved; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) payment of the lump-sum credit would extinguish entitlement of the employee’s or Member’s spouse or former spouse to a survivor annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8341/h"},"text":"section 8341(h) of this title","children":[],"tail":" or to any portion of an annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8345/j"},"text":"section 8345(j) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" inserted “or 8334(d)(2)” after “8343a” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":" amended last sentence of subsec. (a) generally. Prior to amendment, last sentence read as follows: “In applying this subsection with respect to an employee or Member who becomes subject to chapter 84 of this title, entitlement to payment of the lump-sum credit shall be determined without regard to paragraph (1) or (3) if, and to the extent that, such lump-sum credit relates to service of a type described in clauses (i) through (iii) of section 302(a)(1)(C) of the Federal Employees’ Retirement System Act of 1986.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" inserted “, or chapter 84 of this title,” in pars. (1)(B) and (3), substituted “Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343a"},"text":"section 8343a of this title","children":[],"tail":", the” for “The” in second sentence, and inserted provisions regarding entitlement by an employee or Member who becomes subject to chapter 84 of this title to payment of a lump-sum credit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251"},"text":"Pub. L. 99–251","children":[],"tail":" amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “in any case in which there is a former spouse, shall be subject to the terms of a court order or decree issued with respect to such former spouse if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the order or decree expressly relates to any portion of the lump-sum credit involved, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) payment of the lump-sum credit would extinguish entitlement of the former spouse to a survivor annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8341/h"},"text":"section 8341(h) of this title","children":[],"tail":" or to any portion of an annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8345/j"},"text":"section 8345(j) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s2/5/A"},"text":"Pub. L. 98–615, § 2(5)(A)","children":[],"tail":", substituted “Subject to subsection (j) of this section, an” for “An” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s2/5/B"},"text":"Pub. L. 98–615, § 2(5)(B)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/346"},"text":"Pub. L. 97–346","children":[],"tail":" substituted “such a position” for “such position” in par. (1)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s303/c"},"text":"Pub. L. 97–253, § 303(c)","children":[],"tail":", substituted provisions that an employee or Member who is separated from the service for at least 31 consecutive days or is transferred to a position in which he is not subject to this subchapter for 31 days, and who files an application with the Office of Personnel Management for payment of a lump-sum credit, is not reemployed in a position subject to this subchapter at the time of filing, and will not be eligible for an annuity within 31 days of filing, is entitled to be paid the lump-sum credit and upon receipt of such payment, all annuity rights based on the service upon which the credit is based are voided until reemployment under this subchapter occurs for provisions that such employee or Member who was separated from the service, or was transferred to a position in which he did not continue subject to this subchapter, was entitled to be paid the lump-sum credit if his separation or transfer occurred and application for payment was filed with the Office of Personnel Management at least 31 days before the earliest commencing date of any annuity for which he was eligible, that the receipt of payment of the lump-sum credit by the individual voided all annuity rights under this subchapter until he was reemployed in the service subject to this subchapter, and that this subsection also applied to an employee or Member separated before "},{"tag":"date","attrib":{"date":"1956-10-01"},"text":"October 1, 1956","children":[],"tail":", after completing at least 20 years of civilian service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a) to (c), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission” and “Office” for “Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8e69933-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8e69934-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" effective with respect to any annuity having a commencement date later than "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s7001/b/3"},"text":"section 7001(b)(3) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334"},"text":"section 8334 of this title","children":[