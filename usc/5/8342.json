s/pl/97/253/s303/d/2"},"text":"Section 303(d)(2) of Pub. L. 97–253","children":[],"tail":" provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/253/s303/d/2"},"text":"“The amendment made by subsection (c) [amending this section] shall take effect ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"October 1, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8e69938-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8e69939-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reestablishment of Right To Receive Annuity by Judges Who Received Lump-sum Credit","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/504/s2"},"text":"Pub. L. 96–504, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2741"},"text":"94 Stat. 2741","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/504/s2"},"text":"“A present or former justice or judge of the United States, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of title 28","children":[],"tail":", United States Code, who, prior to the effective date of this section ["},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":"], voided his right to receive an annuity under subchapter III of chapter 83 of title 5, United States Code, by applying for and receiving a refund of his lump-sum credit while serving as such a justice or judge may, upon application filed with the Office of Personnel Management within one year following the effective date of this section, redeposit such refund with interest computed under section 8334(e) of such title 5 and thereby reestablish his right to receive an annuity under such subchapter effective on the date he otherwise was eligible to receive an annuity. The surviving spouse of any such justice or judge who dies before the effective date of this section may apply to make such redeposit within one year following the effective date of this section and receive both (1) the amount of the annuity which the justice or judge would have been entitled to receive before his death had application been made by him for the annuity and (2) any survivor annuity the justice or judge could have provided under the provisions of law in effect at the time of separation from the service on which title to the annuity is based.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
