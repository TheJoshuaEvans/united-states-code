{"tag":"section","attrib":{"id":"idb8e69908-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342"},"text":null,"children":[{"tag":"num","attrib":{"value":"8342"},"text":"§ 8342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum benefits; designation of beneficiary; order of precedence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8e69909-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (j) of this section, an employee or Member who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e6990a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8e6990b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from the service for at least thirty-one consecutive days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8e6990c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transferred to a position in which he is not subject to this subchapter, or chapter 84 of this title, and remains in such a position for at least thirty-one consecutive days;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e6990d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an application with the Office of Personnel Management for payment of the lump-sum credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e6990e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not reemployed in a position in which he is subject to this subchapter, or chapter 84 of this title, at the time he files the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e6990f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not become eligible to receive an annuity within thirty-one days after filing the application,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to be paid the lump-sum credit. Except as provided in section 8343a or 8334(d)(2) of this title, the receipt of the payment of the lump-sum credit by the employee or Member voids all annuity rights under this subchapter based on the service on which the lump-sum credit is based, until the employee or Member is reemployed in the service subject to this subchapter. In applying this subsection to an employee or Member who becomes subject to chapter 84 (other than by an election under title III of the Federal Employees’ Retirement System Act of 1986) and who, while subject to such chapter, files an application with the Office for a payment under this subsection—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e69910-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitlement to payment of the lump-sum credit shall be determined without regard to paragraph (1) or (3) if, or to the extent that, such lump-sum credit relates to service of a type described in clauses (i) through (iii) of section 302(a)(1)(C) of the Federal Employees’ Retirement System Act of 1986; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e69911-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if, or to the extent that, the lump-sum credit so relates to service of a type referred to in clause (i), it shall (notwithstanding section 8331(8)) consist of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8e69912-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which any unrefunded amount described in section 8331(8)(A) or (B) relating to such service, exceeds 1.3 percent of basic pay for such service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8e69913-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/a/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the amount payable under subclause (I), computed in a manner consistent with applicable provisions of section 8331(8).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e69914-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Office, a present or former employee or Member may designate a beneficiary or beneficiaries for the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e69915-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lump-sum benefits authorized by subsections (d)–(f) of this section shall be paid to the person or persons surviving the employee or Member and alive at the date title to the payment arises in the following order of precedence, and the payment bars recovery by any other person:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"First, to the beneficiary or beneficiaries designated by the employee or Member in a signed and witnessed writing received in the Office before his death. For this purpose, a designation, change, or cancellation of beneficiary in a will or other document not so executed and filed has no force or effect.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Second, if there is no designated beneficiary, to the widow or widower of the employee or Member.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Third, if none of the above, to the child or children of the employee or Member and descendants of deceased children by representation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Fourth, if none of the above, to the parents of the employee or Member or the survivor of them.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Fifth, if none of the above, to the duly appointed executor or administrator of the estate of the employee or Member.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sixth, if none of the above, to such other next of kin of the employee or Member as the Office determines to be entitled under the laws of the domicile of the employee or Member at the date of his death.","children":[],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the purpose of this subsection, “child” includes a natural child and an adopted child, but does not include a stepchild.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e69916-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an employee or Member dies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e69917-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without a survivor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e69918-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a survivor or survivors and the right of all survivors terminates before a claim for survivor annuity is filed;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or if a former employee or Member not retired dies, the lump-sum credit shall be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e69919-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If all annuity rights under this subchapter based on the service of a deceased employee or Member terminate before the total annuity paid equals the lump-sum credit, the difference shall be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e6991a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an annuitant dies, annuity accrued and unpaid shall be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e6991b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annuity accrued and unpaid on the termination, except by death, of the annuity of an annuitant or survivor annuitant shall be paid to that individual. Annuity accrued and unpaid on the death of a survivor annuitant shall be paid in the following order of precedence, and the payment bars recovery by any other person:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"First, to the duly appointed executor or administrator of the estate of the survivor annuitant.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Second, if there is no executor or administrator, payment may be made, after 30 days from the date of death of the survivor annuitant, to such next of kin of the survivor annuitant as the Office determines to be entitled under the laws of the domicile of the survivor annuitant at the date of his death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e6991c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deducted and withheld from the basic pay of an employee or Member from the first day of the first month which begins after he has performed sufficient service (excluding service which the employee or Member elects to eliminate for the purpose of annuity computation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of this title","children":[],"tail":") to entitle him to the maximum annuity provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of this title","children":[],"tail":", together with interest on the amounts at the rate of 3 percent a year compounded annually from the date of the deductions to the date of retirement or death, shall be applied toward any deposit due under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334"},"text":"section 8334 of this title","children":[],"tail":", and any balance not so required is deemed a voluntary contribution for the purpose of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343"},"text":"section 8343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e6991d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e6991e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from the service before ","children":[{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e6991f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continues in the service after ","children":[{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", without break in service of 1 workday or more;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to the benefits of subsection (h) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8e69920-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8e69921-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8e69922-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of the lump-sum credit under subsection (a) may be made only if the spouse, if any, and any former spouse of the employee or Member are notified of the employee or Member’s application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8e69923-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office shall prescribe regulations under which the lump-sum credit shall not be paid without the consent of a spouse or former spouse of the employee or Member where the Office has received such additional information and documentation as the Office may require that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8e69924-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court order bars payment of the lump-sum credit in order to preserve the court’s ability to award an annuity under section 8341(h) or section 8345(j); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8e69925-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the lump-sum credit would extinguish the entitlement of the spouse or former spouse, under a court order on file with the Office, to a survivor annuity under section 8341(h) or to any portion of an annuity under section 8345(j).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e69926-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8e69927-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification of a spouse or former spouse under this subsection shall be made in accordance with such requirements as the Office shall by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8e69928-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under the regulations, the Office may provide that paragraph (1)(A) of this subsection may be waived with respect to a spouse or former spouse if the employee or Member establishes to the satisfaction of the Office that the whereabouts of such spouse or former spouse cannot be determined.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8e69929-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8342/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall prescribe regulations under which this subsection shall be applied in any case in which the Office receives two or more such orders or decrees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8e6992a-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/579"},"text":"80 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/81"},"text":"Pub. L. 90–83, § 1(81)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/217"},"text":"81 Stat. 217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/253/tIII/s303/c"},"text":"Pub. L. 97–253, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/794"},"text":"96 Stat. 794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/346/s3/f"},"text":"Pub. L. 97–346, § 3(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1648"},"text":"96 Stat. 1648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s2/5"},"text":"Pub. L. 98–615, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3201"},"text":"98 Stat. 3201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/251/tII/s208"},"text":"Pub. L. 99–251, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/25"},"text":"100 Stat. 25","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tII"},"text":"Pub. L. 99–335, title II","children":[],"tail":", §§ 204(b)(2), 207(h), "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/592"},"text":"100 Stat. 592","children":[],"tail":", 596; "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s105/b"},"text":"Pub. L. 100–238, title I, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1746"},"text":"101 Stat. 1746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVII/s7001/b/2/D"},"text":"Pub. L. 101–508, title VII, § 7001(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-329"},"text":"104 Stat. 1388–329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/361/s3/a"},"text":"Pub. L. 106–361, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1402"},"text":"114 Stat. 1402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8e6992b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8e6992c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8e6992d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1966 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{