{"tag":"section","attrib":{"id":"idb890d7e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5946"},"text":null,"children":[{"tag":"num","attrib":{"value":"5946"},"text":"§ 5946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership fees; expenses of attendance at meetings; limitations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as authorized by a specific appropriation, by express terms in a general appropriation, or by sections 4109 and 4110 of this title, appropriated funds may not be used for payment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb890d7e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5946/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" membership fees or dues of an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":" or an individual employed by the government of the District of Columbia in a society or association; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb890d7e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5946/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses of attendance of an individual at meetings or conventions of members of a society or association.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This section does not prevent the use of appropriations for the Department of Agriculture for expenses incident to the delivery of lectures, the giving of instructions, or the acquiring of information at meetings by its employees on subjects relating to the authorized work of the Department.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb890d7e4-5e84-11f1-a692-ec26948f6fea"},"t