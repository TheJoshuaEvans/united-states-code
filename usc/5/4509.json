{"tag":"section","attrib":{"id":"idb82f090b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4509"},"text":null,"children":[{"tag":"num","attrib":{"value":"4509"},"text":"§ 4509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of cash award to Executive Schedule officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No officer may receive a cash award under the provisions of this subchapter, if such officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f090c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4509/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serves in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f090d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4509/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive Schedule position under subchapter II of chapter 53; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f090e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4509/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position for which the compensation is set in statute by reference to a section or level under subchapter II of chapter 53; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f090f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4509/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was appointed to such position by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f0910-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/425/s2/a"},"text":"Pub. L. 103–425, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4370"},"text":"108 Stat. 4370","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
