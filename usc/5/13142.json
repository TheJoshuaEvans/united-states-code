{"tag":"section","attrib":{"id":"idb937c5da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13142"},"text":null,"children":[{"tag":"num","attrib":{"value":"13142"},"text":"§ 13142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This subchapter shall be subject to the rules and regulations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13142/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" and administered by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb937c5dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13142/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ethics of the House of Representatives, with respect to Members, officers, and employees of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb937c5dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13142/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of Senators and legislative branch officers and employees other than those officers and employees specified in subparagraph (A), the committee to which reports filed by such officers and employees under subchapter I are transmitted under that subchapter, except that the authority of this section may be delegated by such committee with respect to such officers and employees;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13142/2"},"text":null,"children":[{