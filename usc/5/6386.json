{"tag":"section","attrib":{"id":"idb8a17a0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6386"},"text":null,"children":[{"tag":"num","attrib":{"value":"6386"},"text":"§ 6386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An employee enrolled in a health benefits plan under chapter 89 who is placed in a leave status under section 6382 may elect to continue the health benefits enrollment of the employee while in such leave status and arrange to pay currently into the Employees Health Benefits Fund (described in section 8909), the appropriate employee contributions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8a17a10-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tII/s201/a/1"},"text":"Pub. L. 103–3, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/23"},"text":"107 Stat. 23","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a11-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17a12-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a17a13-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b/1"},"text":"section 405(b)(1) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
