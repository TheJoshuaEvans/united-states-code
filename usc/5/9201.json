{"tag":"section","attrib":{"id":"idb926fd46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201"},"text":null,"children":[{"tag":"num","attrib":{"value":"9201"},"text":"§ 9201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agency” means “Executive agency” as such term is defined in section 105 and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service and the Postal Regulatory Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Executive Office of the President;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appointing authority” means an employee in the executive branch of the Government of the United States that has authority to make appointments to positions in the civil service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “conditional offer” means an offer of employment in a position in the civil service that is conditioned upon the results of a criminal history inquiry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “criminal history record information”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraphs (B) and (C), has the meaning given the term in section 9101(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any information described in the first sentence of section 9101(a)(2) that has been sealed or expunged pursuant to law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes information collected by a criminal justice agency, relating to an act or alleged act of juvenile delinquency, that is analogous to criminal history record information (including such information that has been sealed or expunged pursuant to law); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “suspension” has the meaning given the term in section 7501.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd51-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/a"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1605"},"text":"133 Stat. 1605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb926fd52-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb926fd53-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb926fd54-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/b/1"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1607"},"text":"133 Stat. 1607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tXI/s1122/b/1"},"text":"“Not later than 1 year after the date of enactment of this subtitle [subtitle A of title XI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", approved "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], the Director of the Office of Personnel Management shall issue such regulations as are necessary to carry out chapter 92 of title 5, United States Code (as added by this subtitle).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
