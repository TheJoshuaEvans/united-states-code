{"tag":"section","attrib":{"id":"idb85ecaf6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373"},"text":null,"children":[{"tag":"num","attrib":{"value":"5373"},"text":"§ 5373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on pay fixed by administrative action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85ecaf7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b) and by the Government Employees Salary Reform Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/78/400"},"text":"78 Stat. 400","children":[],"tail":") and notwithstanding the provisions of other statutes, the head of an Executive agency or military department who is authorized to fix by administrative action the annual rate of basic pay for a position or employee may not fix the rate at more than the rate for level IV of the Executive Schedule. This section does not impair the authorities provided by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecaf8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 248, 482, 1766, and 1819 of title 12, section 206 of the Bank Conservation Act, sections 2B(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002098"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002098"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 21A(e)(4) "},{"tag":"ref","attrib":{"idref":"fn002098"},"text":"1","children":[],"tail":" of the Federal Home Loan Bank Act, section 2A(i) "},{"tag":"ref","attrib":{"idref":"fn002098"},"text":"1","children":[],"tail":" of the Home Owners’ Loan Act, and sections 5.11 and 5.58 of the Farm Credit Act of 1971;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecaf9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s831b"},"text":"section 831b of title 16","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecafa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 403a–403c, 403e–403h, and 403j of title 50; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecafb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002099"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Two pars. (4) have been enacted."}],"tail":" section 4802."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecafc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" section 2(a)(7) of the Commodity Exchange Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/a/7"},"text":"7 U.S.C. 2(a)(7)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecafd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5373/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) shall not affect the authority of the Secretary of Defense or the Secretary of a military department to fix the pay of a civilian employee paid from nonappropriated funds, except that the annual rate of basic pay (including any portion of such pay attributable to comparability with private-sector pay in a locality) of such an employee may not be fixed at a rate greater than the rate for level III of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85ecafe-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/473"},"text":"80 Stat. 473","children":[],"tail":", § 5363; renumbered § 5373, "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/3/A/ii"},"text":"Pub. L. 95–454, title VIII, § 801(a)(3)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1221"},"text":"92 Stat. 1221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3302/e/4"},"text":"Pub. L. 96–70, title III, § 3302(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/498"},"text":"93 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tVII/s742/b"},"text":"Pub. L. 101–73, title VII, § 742(b)","children":