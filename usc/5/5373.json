,"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2212"},"text":"5 U.S.C. 2212","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/426/s308"},"text":"Pub. L. 88–426, § 308","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/432"},"text":"78 Stat. 432","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 6, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/631/s3/e"},"text":"Pub. L. 88–631, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/1008"},"text":"78 Stat. 1008","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “head of an Executive agency or military department” are coextensive with and substituted for “head of any executive department, independent establishment, or agency in the executive branch” because of the definitions in sections 102 and 105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform to the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85ecb02-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85ecb03-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Government Employees Salary Reform Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/78/400"},"text":"78 Stat. 400","children":[],"tail":"), referred to in subsec. (a), is "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/400"},"text":"78 Stat. 400","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsec. (a), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 206 of the Bank Conservation Act, referred to in subsec. (a)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s206"},"text":"section 206 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 2B(b) and 21A(e)(4) of the Federal Home Loan Bank Act, referred to in subsec. (a)(1), were classified to former sections 1422b(b) and 1441a(e)(4), respectively, of Title 12, Banks and Banking. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1422b"},"text":"Section 1422b of Title 12","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1204/1"},"text":"Pub. L. 110–289, div. A, title II, § 1204(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2786"},"text":"122 Stat. 2786","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a"},"text":"Section 1441a of Title 12","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s364/b"},"text":"Pub. L. 111–203, title III, § 364(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1555"},"text":"124 Stat. 1555","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2A(i) of the Home Owners’ Loan Act, referred to in subsec. (a)(1), probably should be a reference to section 3(g) of the Home Owners’ Loan Act, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-13/ch64"},"text":"act June 13, 1933, ch. 64","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s301"},"text":"Pub. L. 101–73, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/278"},"text":"103 Stat. 278","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1462a/g"},"text":"section 1462a(g) of Title 12","children":[],"tail":", Banks and Banking, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s369/3/B"},"text":"Pub. L. 111–203, title III, § 369(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1558"},"text":"124 Stat. 1558","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 5.11 and 5.58 of the Farm Credit Act of 1971, referred to in subsec. (a)(1), are classified to sections 2245 and 2277a–7, respectively, of Title 12, Banks and Banking.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 403a–403c, 403e–403h, and 403j of title 50, referred to in subsec. (a)(3), were editorially reclassified to sections 3501 to 3503, 3505, 3323, 3506, 3507, 3508, and 3510, respectively, of Title 50, War and National Defense. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403e–1"},"text":"Section 403e–1 of Title 50","children":[],"tail":", included within the reference to sections 403e–403h of Title 50, was enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/98/215/tIV/s402"},"text":"Pub. L. 98–215, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-12-09"},"text":"Dec. 9, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1477"},"text":"97 Stat. 1477","children":[],"tail":", after subsec. (a)(3) was enacted, and subsequently editorially reclassified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3323"},"text":"section 3323 of Title 50","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level III of the Executive Schedule, referred to in subsec. (b), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85ecb04-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10702/c/3/A"},"text":"Pub. L. 107–171, § 10702(c)(3)(A)","children":[],"tail":", which directed amendment of par. (2) by striking “or” at end, could not be executed because the word “or” did not appear at the end. See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123/s8/d/1/C/i"},"text":"Pub. L. 107–123, § 8(d)(1)(C)(i)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10702/c/3/B"},"text":"Pub. L. 107–171, § 10702(c)(3)(B)","children":[],"tail":", which directed substitution of “; or” for the period at the end, could not be executed because there was no period at the end. See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123/s8/d/1/C/ii"},"text":"Pub. L. 107–123, § 8(d)(1)(C)(ii)","children":[],"tail":", substituted “; or” for the period at the end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10702/c/3/C"},"text":"Pub. L. 107–171, § 10702(c)(3)(C)","children":[],"tail":", added par. (4) relating to section 2(a)(7) of the Commodity Exchange Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123/s8/d/1/C/iii"},"text":"Pub. L. 107–123, § 8(d)(1)(C)(iii)","children":[],"tail":", added par. (4) relating to section 4802."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" designated existing provisions as subsec. (a), substituted “(a) Except as provided in subsection (b) and” for “Except as provided”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" redesignated pars. (2) to (4) as (1) to (3), respectively, and struck out former par. (1) which read as follows: “section 1202 of the Panama Canal Act of 1979;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" substituted “rate for level IV of the Executive Schedule.” for “maximum rate for GS–18.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s1209"},"text":"Pub. L. 101–73, § 1209","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “sections 248, 481, 1437, 1439, and 1819 of title 12;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s742/b"},"text":"Pub. L. 101–73, § 742(b)","children":[],"tail":", inserted references to sections 1437 and 1439 of title 12."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" substituted “section 1202 of the Panama Canal Act of 1979” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t2/s121"},"text":"section 121 of title 2","children":[],"tail":", Canal Zone Code ("},{"tag":"ref","attrib":{"href":"/us/stat/76A/15"},"text":"76A Stat. 15","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85ecb05-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85ecb06-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123"},"text":"Pub. L. 107–123","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2001-10-01"},"text":"Oct. 1, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/123/s11"},"text":"section 11 of Pub. L. 107–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78ee"},"text":"section 78ee of Title 15