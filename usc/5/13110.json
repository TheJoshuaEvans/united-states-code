{"tag":"section","attrib":{"id":"idb9355554-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13110"},"text":null,"children":[{"tag":"num","attrib":{"value":"13110"},"text":"§ 13110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Comptroller General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9355555-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Financial Disclosure Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall have access to financial disclosure reports filed under this subchapter for the purposes of carrying out the Comptroller General’s statutory responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9355556-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1992-12-31"},"text":"December 31, 1992","children":[],"tail":", and regularly thereafter, the Comptroller General shall conduct a study to determine whether the provisions of this subchapter are being carried out effectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9355557-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":