{"tag":"section","attrib":{"id":"idb7b7dc63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554"},"text":null,"children":[{"tag":"num","attrib":{"value":"554"},"text":"§ 554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7b7dc64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies, according to the provisions thereof, in every case of adjudication required by statute to be determined on the record after opportunity for an agency hearing, except to the extent that there is involved—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter subject to a subsequent trial of the law and the facts de novo in a court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc66-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection or tenure of an employee, except a ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" administrative law judge appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceedings in which decisions rest solely on inspections, tests, or elections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conduct of military or foreign affairs functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cases in which an agency is acting as an agent for a court; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certification of worker representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Persons entitled to notice of an agency hearing shall be timely informed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time, place, and nature of the hearing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal authority and jurisdiction under which the hearing is to be held; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matters of fact and law asserted.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"When private persons are the moving parties, other parties to the proceeding shall give prompt notice of issues controverted in fact or law; and in other instances agencies may by rule require responsive pleading. In fixing the time and place for hearings, due regard shall be had for the convenience and necessity of the parties or their representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agency shall give all interested parties opportunity for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission and consideration of facts, arguments, offers of settlement, or proposals of adjustment when time, the nature of the proceeding, and the public interest permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the parties are unable so to determine a controversy by consent, hearing and decision on notice and in accordance with sections 556 and 557 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The employee who presides at the reception of evidence pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s556"},"text":"section 556 of this title","children":[],"tail":" shall make the recommended decision or initial decision required by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s557"},"text":"section 557 of this title","children":[],"tail":", unless he becomes unavailable to the agency. Except to the extent required for the disposition of ex parte matters as authorized by law, such an employee may not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult a person or party on a fact in issue, unless on notice and opportunity for all parties to participate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible to or subject to the supervision or direction of an employee or agent engaged in the performance of investigative or prosecuting functions for an agency.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An employee or agent engaged in the performance of investigative or prosecuting functions for an agency in a case may not, in that or a factually related case, participate or advise in the decision, recommended decision, or agency review pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s557"},"text":"section 557 of this title","children":[],"tail":", except as witness or counsel in public proceedings. This subsection does not apply—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b7dc75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/d/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining applications for initial licenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b7dc76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/d/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to proceedings involving the validity or application of rates, facilities, or practices of public utilities or carriers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b7dc77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/d/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the agency or a member or members of the body comprising the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s554/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agency, with like effect as in the case of other orders, and in its sound discretion, may issue a declaratory order to terminate a controversy or remove uncertainty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7b7dc79-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/384"},"text":"80 Stat. 384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/251/s2/a/1"},"text":"Pub. L. 95–251, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/183"},"text":"92 Stat. 183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7b7dc7a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7b7dc7b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7b7dc7c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s1004"},"text":"5 U.S.C. 1004","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-06-11/ch324/s5"},"text":"June 11, 1946, ch. 324, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/239"},"text":"60 Stat. 239","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “employee” is substituted for “officer or employee of the United States” in view of the definition of “employee” in section 2105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the word “naval” is omitted as included in “military”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(5), the word “or” is substituted for “and” since the exception is applicable if any one of the factors are involved.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(6), the word “worker” is substituted for “employee”, since the latter is defined in section 2105 as meaning Federal employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “When” is substituted for “In instances in which”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the comma after the word “hearing” is omitted to correct an editorial error.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “The employee” and “such an employee” are substituted in the first two sentences for “The same officers” and “such officers” in view of the definition of “employee” in section 2105. The word “officer” is omitted in the third and fourth sentences as included in “employee” as defined in section 2105. The prohibition in the third and fourth sentences is restated in positive form. In paragraph (C) of the last sentence, the words “in any manner” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7b7dc7d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7b7dc7e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 554 of former Title 5, Executive Departments and Government Officers and Employees, was transferred to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2246"},"text":"section 2246 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7b7dc7f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/251"},"text":"Pub. L. 95–251","children":[],"tail":" substituted “administrative law judge” for “hearing examiner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
