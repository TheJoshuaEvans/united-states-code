{"tag":"section","attrib":{"id":"idb90cbe80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501"},"text":null,"children":[{"tag":"num","attrib":{"value":"8501"},"text":"§ 8501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90cbe81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Federal service” means service performed after 1952 in the employ of the United States or an instrumentality of the United States which is wholly or partially owned by the United States, but does not include service (except service to which subchapter II of this chapter applies) performed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90cbe82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an elective official in the executive or legislative branch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a member of the armed forces or the Commissioned Corps of the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by members of the Foreign Service for whom payments are provided under section 609(b)(1) of the Foreign Service Act of 1980;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the United States, the Commonwealth of Puerto Rico, and the Virgin Islands by an individual who is not a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual excluded by regulations of the Office of Personnel Management from the operation of subchapter III of chapter 83 of this title because he is paid on a contract or fee basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual receiving nominal pay and allowances of $12 or less a year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a hospital, home, or other institution of the United States by a patient or inmate thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe89-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a student-employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5351"},"text":"section 5351 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual serving on a temporary basis in case of fire, storm, earthquake, flood, or other similar emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe8b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual employed under a Federal relief program to relieve him from unemployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe8c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a member of a State, county, or community committee under the Agricultural Stabilization and Conservation Service or of any other board, council, committee, or other similar body, unless the board, council, committee, or other body is composed exclusively of individuals otherwise in the full-time employ of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90cbe8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by an officer or a member of the crew on or in connection with an American vessel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb90cbe8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by or bareboat chartered to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90cbe8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/1/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose business is conducted by a general agent of the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"if contributions on account of the service are required to be made to an unemployment fund under a State unemployment compensation law under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3305/g"},"text":"section 3305(g) of title 26","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal wages” means all pay and allowances, in cash and in kind, for Federal service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal employee” means an individual who has performed Federal service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “compensation” means cash benefits payable to an individual with respect to his unemployment including any portion thereof payable with respect to dependents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “benefit year” means the benefit year as defined by the applicable State unemployment compensation law, and if not so defined the term means the period prescribed in the agreement under this subchapter with a State or, in the absence of such an agreement, the period prescribed by the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, and the Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographical sense, means the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbe96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “base period” means the base period as defined by the applicable State unemployment compensation law for the benefit year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90cbe97-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/585"},"text":"80 Stat. 585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/tI/s116/e/1"},"text":"Pub. L. 94–566, title I, § 116(e)(1)","children":[],"tail":", title II, § 214(b), "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2672"},"text":"90 Stat. 2672","children":[],"tail":", 2678; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/215/s4/a"},"text":"Pub. L. 96–215, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-25"},"text":"Mar. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/124"},"text":"94 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2314/h"},"text":"Pub. L. 96–465, title II, § 2314(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2168"},"text":"94 Stat. 2168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90cbe98-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision"