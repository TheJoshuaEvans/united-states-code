":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/420"},"text":"74 Stat. 420","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/778"},"text":"Pub. L. 86–778","children":[],"tail":", §§ 531(e), 542(d), "},{"tag":"html:a","attrib":{"href":"/us/stat/74/984"},"text":"74 Stat. 984","children":[],"tail":", 986."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (4) of former section 1361(a) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(A), the word “official” is substituted for “officer” because of the definition of “officer” in section 2104. The words “of the Government of the United States” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(E), the words “by regulations of the Civil Service Commission from the operation of subchapter III of chapter 83 of this title” are substituted for “by Executive order from the operation of the Civil Service Retirement Act of 1930” on authority of the Civil Service Retirement Act Amendments of 1956, which are carried into subchapter III of chapter 83.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(K), the words “Agricultural Stabilization and Conservation Service” are substituted for “Production and Marketing Administration” on authority of Secretary’s memorandum 1320, supp. 4 of ","children":[{"tag":"date","attrib":{"date":"1953-11-02"},"text":"November 2, 1953","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(L), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1606/g"},"text":"section 1606(g) of Title 26","children":[],"tail":", Internal Revenue Code of 1939” in former section 1361(a)(13) are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of former section 1361 is omitted as its substance is included in paragraph (1)(D).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former section 1361(f) is omitted as unnecessary as the full title of the Secretary of Labor is set out the first time it is used in each section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraphs (6) and (7) are added on authority of section 1101(a)(1), (2) of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Act of Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/647"},"text":"49 Stat. 647","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1301/a/1"},"text":"42 U.S.C. 1301(a)(1)","children":[],"tail":", (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90cbe9b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb90cbe9c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 609(b)(1) of the Foreign Service Act of 1980, referred to in par. (1)(C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4009/b/1"},"text":"section 4009(b)(1) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90cbe9d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215"},"text":"Pub. L. 96–215","children":[],"tail":" inserted “or the Commissioned Corps of the National Oceanic and Atmospheric Administration” after “armed forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" substituted “members of the Foreign Service for whom payments are provided under section 609(b)(1) of the Foreign Service Act of 1980” for “Foreign Service personnel for whom special separation allowances are provided under chapter 14 of title 22”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s116/e/1"},"text":"Pub. L. 94–566, § 116(e)(1)","children":[],"tail":", added the Virgin Islands in definition of “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s214/b"},"text":"Pub. L. 94–566, § 214(b)","children":[],"tail":", added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes"