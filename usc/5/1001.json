{"tag":"section","attrib":{"id":"idb7de01e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001"},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"§ 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7de01e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de01e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory committee.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7de01e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advisory committee” means a committee, board, commission, council, conference, panel, task force, or other similar group, or any subcommittee or other subgroup thereof (hereafter in this paragraph referred to as “committee”) that is established or utilized to obtain advice or recommendations for the President or one or more agencies or officers of the Federal Government and that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7de01e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established by statute or reorganization plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7de01e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established or utilized by the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7de01ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established or utilized by one or more agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de01eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advisory committee” excludes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7de01ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee that is composed wholly of full-time, or permanent part-time, officers or employees of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7de01ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a committee that is created by the National Academy of Sciences or the National Academy of Public Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de01ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de01ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential advisory committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Presidential advisory committee” means an advisory committee that advises the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7de01f0-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7de01f1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7de01f2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7de01f3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1001","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (FACA § 3)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/463/s3"},"text":"Pub. L. 92–463, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/153/s2/a"},"text":"Pub. L. 105–153, § 2(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 17, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/2689"},"text":"111 Stat. 2689","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Although not mentioned in the explanation contained in H. Rept. 117–193, in par. (1), “ ‘Administrator’ means the Administrator of General Services” substituted for “ ‘Director’ means the Director of the Office of Management and Budget” because of section 5F of Reorganization Plan No. 1 of 1977 (5 U.S.C. App.).]","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7de01f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7de01f5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Act","children":[],"tail":null},{"tag":"p"