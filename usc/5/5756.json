{"tag":"section","attrib":{"id":"idb889ac55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756"},"text":null,"children":[{"tag":"num","attrib":{"value":"5756"},"text":"§ 5756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home marketing incentive payment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb889ac56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed under subsection (b), an agency may pay to an employee who transfers in the interest of the Government an amount to encourage the employee to aggressively market the employee’s residence at the official station from which transferred when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residence is entered into a relocation services program established under a contract in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724c"},"text":"section 5724c of this title","children":[],"tail":" to arrange for the purchase of the residence;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee finds a buyer who completes the purchase of the residence through the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac59-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of the residence results in a reduced cost to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac5a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5756/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations shall include a limitation on the maximum amount payable with respect to an employee’s residence. The Administrator shall establish the limitation in consultation with the Director of the Office of Management and Budget. For fiscal years 1997 and 1998, the maximum amount shall be the amount equal to five percent of the sale price of the residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb889ac5d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1717"},"text":"Pub. L. 104–201, div. A, title XVII, § 1717","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2757"},"text":"110 Stat. 2757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb889ac5e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb889ac5f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb889ac60-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5722"},"text":"section 5722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
