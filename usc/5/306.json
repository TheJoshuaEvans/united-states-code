{"tag":"section","attrib":{"id":"idb78819ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency strategic plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78819eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than the first Monday in February of any year following the year in which the term of the President commences under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s101"},"text":"section 101 of title 3","children":[],"tail":", the head of each agency shall make available on the public website of the agency a strategic plan and notify the President and Congress of its availability. Such plan shall contain—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78819ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive mission statement covering the major functions and operations of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general goals and objectives, including outcome-oriented goals, for the major functions and operations of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how any goals and objectives contribute to the Federal Government priority goals required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1120/a"},"text":"section 1120(a) of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of how the goals and objectives are to be achieved, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb78819f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the operational processes, skills and technology, and the human, capital, information, and other resources required to achieve those goals and objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78819f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the agency is working with other agencies to achieve its goals and objectives as well as relevant Federal Government priority goals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the goals and objectives incorporate views and suggestions obtained through congressional consultations required under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the performance goals provided in the plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115/a"},"text":"section 1115(a) of title 31","children":[],"tail":", including the agency priority goals required by "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1120/b"},"text":"section 1120(b) of title 31","children":[],"tail":", if applicable, contribute to the general goals and objectives in the strategic plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of those key factors external to the agency and beyond its control that could significantly affect the achievement of the general goals and objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the program evaluations used in establishing or revising general goals and objectives, with a schedule for future program evaluations to be conducted, and citations to relevant provisions of the plans required under section 312, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78819f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the head of an agency required to develop a plan described in subsection (a) or (b) of section 312, an assessment of the coverage, quality, methods, effectiveness, and independence of the statistics, evaluation, research, and analysis efforts of the agency, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb78819f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the activities and operations of the agency that are currently being evaluated and analyzed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78819f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the evaluations, research, and analysis efforts and related activities of the agency support the needs of various divisions within the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78819f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the evaluation research and analysis efforts and related activities of the agency address an appropriate balance between needs related to organizational learning, ongoing program management, performance management, strategic management, interagency and private sector coordination, internal and external oversight, and accountability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78819fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the agency uses methods and combinations of methods that are appropriate to agency divisions and the corresponding research questions being addressed, including an appropriate combination of formative and summative evaluation research and analysis approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78819fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which evaluation and research capacity is present within the agency to include personnel and agency processes for planning and implementing evaluation activities, disseminating best practices and findings, and incorporating employee views and feedback; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78819fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/a/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the agency has the capacity to assist agency staff and program offices to develop the capacity to use evaluation research and analysis approaches and data in the day-to-day operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78819fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The strategic plan shall cover a period of not less than 4 years following the fiscal year in which the plan is submitted. As needed, the head of the agency may make adjustments to the strategic plan to reflect significant changes in the environment in which the agency is operating, with appropriate notification of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78819fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The performance plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115/b"},"text":"section 1115(b) of title 31","children":[],"tail":" shall be consistent with the agency’s strategic plan. A performance plan may not be submitted for a fiscal year not covered by a current strategic plan under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78819ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When developing or making adjustments to a strategic plan, the agency shall consult periodically with the Congress, including majority and minority views from the appropriate authorizing, appropriations, and oversight committees, and shall solicit and consider the views and suggestions of those entities potentially affected by or interested in such a plan. The agency shall consult with the appropriate committees of Congress at least once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7881a00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The functions and activities of this section shall be considered to be inherently governmental functions. The drafting of strategic plans under this section shall be performed only by Federal employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7881a01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section the term “agency” means an Executive agency defined under section 105, but does not include the Central Intelligence Agency, the Government Accountability Office, the United States Postal Service, and the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7881a02-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352/s2"},"text":"Pub. L. 111–352, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3866"},"text":"124 Stat. 3866","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/tI/s101/c"},"text":"Pub. L. 115–435, title I, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5533"},"text":"132 Stat. 5533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/190/s7/a"},"text":"Pub. L. 118–190, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2656"},"text":"138 Stat. 2656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7881a03-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7881a04-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7881a05-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 306, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s3"},"text":"Pub. L. 103–62, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/286"},"text":"107 Stat. 286","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIX/s902"},"text":"Pub. L. 106–65, div. A, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/717"},"text":"113 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/b"},"text":"Pub. L. 109–435, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3241"},"text":"120 Stat. 3241","children":[],"tail":", related to strategic plans, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/111/352/s2"},"text":"Pub. L. 111–352, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3866"},"text":"124 Stat. 3866","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7881a06-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/190/s7/a/1"},"text":"Pub. L. 118–190, § 7(a)(1)","children":[],"tail":", inserted “, as applicable” after “section 312”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/190/s7/a/2"},"text":"Pub. L. 118–190, § 7(a)(2)","children":[],"tail":", inserted “with respect to the head of an agency required to develop a plan described in subsection (a) or (b) of section 312,” before “an assessment” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/s101/c/1"},"text":"Pub. L. 115–435, § 101(c)(1)","children":[],"tail":", substituted semicolon for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/s101/c/2"},"text":"Pub. L. 115–435, § 101(c)(2)","children":[],"tail":", inserted “, and citations to relevant provisions of the plans required under section 312; and” after “to be conducted” and struck out period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/s101/c/3"},"text":"Pub. L. 115–435, § 101(c)(3)","children":[],"tail":", added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7881a07-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7881a08-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIV/s403"},"text":"Pub. L. 115–435, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5557"},"text":"132 Stat. 5557","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/435/tIV/s403"},"text":"“Except as otherwise provided, this Act [see Short Title of 2019 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of this title","children":[],"tail":"], and the amendments made by this Act, shall take effect on the date that is 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7881a09-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIV/s401"},"text":"Pub. L. 115–435, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5556"},"text":"132 Stat. 5556","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/435/tIV/s401"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this Act [see Short Title of 2019 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of this title","children":[],"tail":"], or the amendments made by this Act, may be construed—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the disclosure of information or records that are exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", United States Code (commonly known as the ‘Freedom of Information Act’);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create or expand an exemption from disclosure under such section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to override, limit, or otherwise affect intellectual property rights, including rights under titles 17 and 35, United States Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to affect the authority of a Federal agency regarding the use, disclosure, or licensing of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confidential business information that could be withheld under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", United States Code; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data assets restricted from disclosure under a contract or other binding, written agreement; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the independence, responsibilities, or work products of an Inspector General of any agency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “agency” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/s401"},"text":"section 401 of Pub. L. 115–435","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s101/e/4/A"},"text":"section 101(e)(4)(A) of Pub. L. 115–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s311"},"text":"section 311 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7881a0a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"GAO Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tI/s101/d"},"text":"Pub. L. 115–435, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5533"},"text":"132 Stat. 5533","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/435/tI/s101/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 2 years after the date on which each strategic plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306/a"},"text":"section 306(a) of title 5","children":[],"tail":", Un