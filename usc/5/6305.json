{"tag":"section","attrib":{"id":"idb89803d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305"},"text":null,"children":[{"tag":"num","attrib":{"value":"6305"},"text":"§ 6305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home leave; leave for Chiefs of Missions; leave for crews of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89803d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After 24 months of continuous service outside the United States (or after a shorter period of such service if the employee’s assignment is terminated for the convenience of the Government), an employee may be granted leave of absence, under regulations of the President, at a rate not to exceed 1 week for each 4 months of that service without regard to other leave provided by this subchapter. Leave so granted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89803d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for use in the United States, or if the employee’s place of residence is outside the area of employment, in its territories or possessions including the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4dc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulates for future use without regard to the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6304/b"},"text":"section 6304(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4dc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be made the basis for terminal leave or for a lump-sum payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4dc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may authorize leave of absence to a chief of mission excepted from this subchapter by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6301/2/xii"},"text":"section 6301(2)(xii) of this title","children":[],"tail":" for use in the United States and its territories or possessions. Leave so authorized does not constitute a leave system and may not be made the basis for a lump-sum payment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4dc8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer, crewmember, or other employee serving aboard an oceangoing vessel on an extended voyage may be granted leave of absence, under regulations of the Office of Personnel Management, at a rate not to exceed 2 days for each 30 calendar days of that service without regard to other leave provided by this subchapter. Leave so granted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89a4dc9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accumulates for future use without regard to the limitation in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6304/b"},"text":"section 6304(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4dca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be made the basis for a lump-sum payment, except that civil service mariners of the Military Sealift Command on temporary promotion aboard ship may be paid the difference between their temporary and permanent rates of pay for leave accrued under this section and section 6303 and not otherwise used during the temporary promotion upon the expiration or termination of the temporary promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4dcb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be made the basis for terminal leave except under such special or emergency circumstances as may be prescribed under the regulations of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4dcc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to an officer, crewmember, or other employee of the Department of Defense serving aboard an oceangoing vessel on an extended voyage, the first sentence in the matter preceding paragraph (1) of subsection (c) of this section shall be applied by substituting “7 calendar days” for “30 calendar days”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89a4dcd-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/520"},"text":"80 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/747/s1/1"},"text":"Pub. L. 89–747, § 1(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1179"},"text":"80 Stat. 1179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s1/16"},"text":"Pub. L. 90–623, § 1(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1313"},"text":"82 Stat. 1313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/15"},"text":"Pub. L. 96–54, § 2(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII"},"text":"Pub. L. 96–465, title II","children":[],"tail":", §§ 2312(c), 2314(f)(2), "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2167"},"text":"94 Stat. 2167","children":[],"tail":", 2168; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children"