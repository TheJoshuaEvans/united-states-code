{"tag":"section","attrib":{"id":"idb8be2a1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8111"},"text":null,"children":[{"tag":"num","attrib":{"value":"8111"},"text":"§ 8111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation for services of attendants or vocational rehabilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be2a1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor may pay an employee who has been awarded compensation an additional sum of not more than $1,500 a month, as the Secretary considers necessary, when the Secretary finds that the service of an attendant is necessary constantly because the employee is totally blind, or has lost the use of both hands or both feet, or is paralyzed and unable to walk, or because of other disability resulting from the injury making him so helpless as to require constant attendance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be2a1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay an individual undergoing vocational rehabilitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8104"},"text":"section 8104 of this title","children":[],"tail":" additional compensation necessary for his maintenance, but not to exceed $200 a month."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be2a1e-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{