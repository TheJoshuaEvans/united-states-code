{"tag":"section","attrib":{"id":"idb90f2edd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506"},"text":null,"children":[{"tag":"num","attrib":{"value":"8506"},"text":"§ 8506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90f2ede-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each agency of the United States and each wholly or partially owned instrumentality of the United States shall make available to State agencies which have agreements under this subchapter, or to the Secretary of Labor, as the case may be, such information concerning the Federal service and Federal wages of a Federal employee as the Secretary considers practicable and necessary for the determination of the entitlement of the Federal employee to compensation under this subchapter. The information shall include the findings of the employing agency concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90f2edf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether or not the Federal employee has performed Federal service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90f2ee0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the periods of Federal service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90f2ee1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of Federal wages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90f2ee2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for termination of Federal service.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The employing agency shall make the findings in the form and manner prescribed by regulations of the Secretary. The regulations shall include provision for correction by the employing agency of errors and omissions. This subsection does not apply with respect to Federal service and Federal wages covered by subchapter II of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90f2ee3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agency administering the unemployment compensation law of a State shall furnish the Secretary such information as he considers necessary or appropriate in carrying out this subchapter. The information is deemed the report required by the Secretary for the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s503/a/6"},"text":"section 503(a)(6) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90f2ee4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/589"},"text":"80 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/tIII/s313/a"},"text":"Pub. L. 94–566, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2680"},"text":"90 Stat. 2680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90f2ee5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb90f2ee6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb90f2ee7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail