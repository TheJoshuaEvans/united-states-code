{"tag":"section","attrib":{"id":"idb8c07375-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8117"},"text":null,"children":[{"tag":"num","attrib":{"value":"8117"},"text":"§ 8117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of accrual of right","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c07376-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee other than a Postal Service employee is not entitled to compensation for the first 3 days of temporary disability, except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c07377-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the disability exceeds 14 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07378-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the disability is followed by permanent disability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07379-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8117/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided by sections 8103 and 8104 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c0737a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Postal Service employee is not entitled to compensation or continuation of pay for the first 3 days of temporary disability, except as provided under paragraph (3) of subsection (a). A Postal Service employee may use annual leave, sick leave, or leave without pay during that 3-day period, except that if the disability exceeds 14 days or is followed by permanent disability, the employee may have their sick leave or annual leave reinstated or receive pay for the time spent on leave without pay under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c0737b-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/543"},"text":"80 Stat. 543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s10"},"text":"Pub. L. 93–416, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1145"},"text":"88 Stat. 1145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tIX/s901/a"},"text":"Pub. L. 109–435, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3253"},"text":"120 Stat. 3253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c0737c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c0737d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c0737e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text"