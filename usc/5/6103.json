g":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb893216e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb893216f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6309"},"text":"Section 6309 of this title","children":[],"tail":", referred to in subsec. (b)(1)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/26"},"text":"Pub. L. 94–183, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1058"},"text":"89 Stat. 1058","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8932170-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/17"},"text":"Pub. L. 117–17","children":[],"tail":" inserted item relating to Juneteenth National Independence Day."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/144"},"text":"Pub. L. 98–144","children":[],"tail":" inserted item relating to birthday of Martin Luther King, Jr."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/97"},"text":"Pub. L. 94–97","children":[],"tail":" changed Veterans Day from fourth Monday in October to November 11."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/363"},"text":"Pub. L. 90–363","children":[],"tail":" added Columbus Day, the second Monday in October, to the enumerated legal public holidays, and substituted provisions that Washington’s Birthday, Memorial Day, and Veterans Day are to be celebrated on the third Monday in February, the last Monday in May, and the fourth Monday in October, respectively, for provisions that the above mentioned public holidays are to be celebrated on February 22, May 30, and November 11, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8932171-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8932172-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/144/s2"},"text":"Pub. L. 98–144, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-02"},"text":"Nov. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/917"},"text":"97 Stat. 917","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/144/s2"},"text":"“The amendment made by the first section of this Act [amending this section] shall take effect on the first January 1 that occurs after the two-year period following the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-11-02"},"text":"Nov. 2, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8932173-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1975 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/97"},"text":"Pub. L. 94–97","children":[],"tail":" provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/94/97"},"text":"Pub. L. 94–97","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"Jan. 1, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8932174-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/363/s2"},"text":"Pub. L. 90–363, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/251"},"text":"82 Stat. 251","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/363/s2"},"text":"“The amendment made by subsection (a) of the first section of this Act [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1971-01-01"},"text":"January 1, 1971","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8932175-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Laws of the United States to Observances of Legal Public Holidays","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/363/s1/b"},"text":"Pub. L. 90–363, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-28"},"text":"June 28, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/250"},"text":"82 Stat. 250","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/363/s1/b"},"text":"“Any reference in a law of the United States (in effect on the effective date of the amendment made by subsection (a) of this section) [","children":[{"tag":"date","attrib":{"date":"1971-01-01"},"text":"January 1, 1971","children":[],"tail":"] to the observance of a legal public holiday on a day other than the day prescribed for the observance of such holiday by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6103/a"},"text":"section 6103(a) of title 5","children":[],"tail":", United States Code, as amended by subsection (a), shall on and after such effective date be considered a reference to the day for the observance of such holiday prescribed in such amended section 6103(a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8932176-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8932177-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 10358","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10358, ","children":[{"tag":"date","attrib":{"date":"1952-06-09"},"text":"June 9, 1952","children":[],"tail":", 17 F.R. 1529, as amended by Ex. Ord. No. 11226, "},{"tag":"date","attrib":{"date":"1965-05-27"},"text":"May 27, 1965","children":[],"tail":", 30 F.R. 7213; Ex. Ord. No. 11272, "},{"tag":"date","attrib":{"date":"1966-02-23"},"text":"Feb. 23, 1966","children":[],"tail":", 31 F.R. 3111, which related to the observance of holidays, was revoked by Ex. Ord. No. 11582, "},{"tag":"date","attrib":{"date":"1971-02-11"},"text":"Feb. 11, 1971","children":[],"tail":", 36 F.R. 2957, set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8932178-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11582. Observance of Holidays","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11582, ","children":[{"tag":"date","attrib":{"date":"1971-02-11"},"text":"Feb. 11, 1971","children":[],"tail":", 36 F.R. 2957, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me as President of the United States, it is hereby ordered as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. Except as provided in section 7, this order shall apply to all executive departments, independent agencies, and Government corporations, including their field services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. As used in this order:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) ","children":[{"tag":"i","attrib":{},"text":"Holiday","children":[],"tail":" means the first day of January, the third Monday of February, the last Monday of May, the fourth day of July, the first Monday of September, the second Monday of October, the fourth Monday of October, the fourth Thursday of November, the twenty-fifth day of December, or any other calendar day designated as a holiday by Federal statute or Executive order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) ","children":[{"tag":"i","attrib":{},"text":"Workday","children":[],"tail":" means those hours which comprise in sequence the employee’s regular daily tour of duty within any 24-hour period, whether falling entirely within one calendar day or not."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. (a) Any employee whose basic workweek does not include Sunday and who would ordinarily be excused from work on a holiday falling within his basic workweek shall be excused from work on the next workday of his basic workweek whenever a holiday falls on Sunday."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Any employee whose basic workweek includes Sunday and who would ordinarily be excused from work on a holiday falling within his basic workweek shall be excused from work on the next workday of his basic workweek whenever a holiday falls on a day that has been administratively scheduled as his ","children":[{"tag":"i","attrib":{},"text":"regular","children":[],"tail":" weekly nonworkday in lieu of Sunday."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. The holiday for a full-time employee for whom the head of a department has established the first 40 hours of duty performed within a period of not more than six days of the administrative workweek as his basic workweek because of the impracticability of prescribing a regular schedule of definite hours of duty for each workday, shall be determined as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) If a holiday occurs on Sunday, the head of the department shall designate in advance either Sunday or Monday as the employee’s holiday and the employee’s basic 40-hour tour of duty shall be deemed to include eight hours on the day designated as the employee’s holiday.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) If a holiday occurs on Saturday, the head of the department shall designate in advance either the Saturday or the preceding Friday as the employee’s holiday and the employee’s basic 40-hour tour of duty shall be deemed to include eight hours on the day designated as the employee’s holiday.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) If a holiday occurs on any other day of the week, that day shall be the employee’s holiday, and the employee’s basic 40-hour tour of duty shall be deemed to include eight hours on that day.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) When a holiday is less than a full day, proportionate credit will be given under paragraph (a), (b), or (c) of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 5. Any employee whose workday covers portions of two calendar days and who would, except for this section, ordinarily be excused from work scheduled for the hours of any calendar day on which a holiday falls, shall instead be excused from work on his entire workday which commences on any such calendar day."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 6. In administering the provisions of law relating to pay and leave of absence, the workdays referred to in sections 3, 4, and 5 shall be treated as holidays in lieu of the corresponding calendar holidays."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 7. The provisions of this order shall apply to officers and employees of the Post Office Department and the United States Postal Service (except that sections 3, 4, 5, and 6 shall not apply to the Postal Field Service) until changed by the Postal Service in accordance with the Postal Reorganization Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 8. Executive Order No. 10358 of "},{"tag":"date","attrib":{"date":"1952-06-09"},"text":"June 9, 1952","children":[],"tail":", entitled "},{"tag":"i","attrib":{},"text":"Observance of Holidays by Government Agencies ","children":[],"tail":"and amendatory Executive Orders No. 11226 of "},{"tag":"date","attrib":{"date":"1965-05-27"},"text":"May 27, 1965","children":[],"tail":", and No. 11272 of "},{"tag":"date","attrib":{"date":"1966-02-23"},"text":"February 23, 1966","children":[],"tail":", are revoked."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 9. This order is effective as of "},{"tag":"date","attrib":{"date":"1971-01-01"},"text":"January 1, 1971","children":[],"tail":"."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Richard Nixon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
