{"tag":"section","attrib":{"id":"idb8f76168-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8412a"},"text":"§ 8412a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phased retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f76169-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f7616a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “composite retirement annuity” means the annuity computed when a phased retiree attains full retirement status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f7616b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “full retirement status” means that a phased retiree has ceased employment and is entitled, upon application, to a composite retirement annuity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f7616c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “phased employment” means the less-than-full-time employment of a phased retiree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f7616d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “phased retiree” means a retirement-eligible employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f7616e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes an election under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f7616f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not entered full retirement status;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76170-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “phased retirement annuity” means the annuity payable under this section before full retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76171-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “phased retirement percentage” means the percentage which, when added to the working percentage for a phased retiree, produces a sum of 100 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76172-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “phased retirement period” means the period beginning on the date on which an individual becomes entitled to receive a phased retirement annuity and ending on the date on which the individual dies or separates from phased employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76173-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “phased retirement status” means that a phased retiree is concurrently employed in phased employment and eligible to receive a phased retirement annuity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76174-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “retirement-eligible employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f76175-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an individual who, if the individual separated from the service, would meet the requirements for retirement under subsection (a) or (b) of section 8412; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76176-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f76177-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who, if the individual separated from the service, would meet the requirements for retirement under subsection (d) or (e) of section 8412; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f76178-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an employee described in section 8425 after the date on which the employee is required to be separated from the service by reason of such section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76179-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “working percentage” means the percentage of full-time employment equal to the quotient obtained by dividing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f7617a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours per pay period to be worked by a phased retiree, as scheduled in accordance with subsection (b)(2); by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f7617b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours per pay period to be worked by an employee serving in a comparable position on a full-time basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f7617c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f7617d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the concurrence of the head of the employing agency, and under regulations promulgated by the Director, a retirement-eligible employee who has been employed on a full-time basis for not less than the 3-year period ending on the date on which the retirement-eligible employee makes an election under this subsection may elect to enter phased retirement status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f7617e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f7617f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), at the time of entering phased retirement status, a phased retiree shall be appointed to a position for which the working percentage is 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76180-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may, by regulation, provide for working percentages different from the percentage specified under subparagraph (A), which shall be not less than 20 percent and not more than 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76181-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The working percentage for a phased retiree may not be changed during the phased retiree’s phased retirement period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76182-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f76183-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 20 percent of the hours to be worked by a phased retiree shall consist of mentoring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f76184-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may, by regulation, provide for exceptions to the requirement under clause (i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f76185-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clause (i) shall not apply to a phased retiree serving in the United States Postal Service. Nothing in this clause shall prevent the application of clause (i) or (ii) with respect to a phased retiree serving in the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76186-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A phased retiree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f76187-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be employed in more than one position at any time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76188-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may transfer to another position in the same or a different agency, only if the transfer does not result in a change in the working percentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76189-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retirement-eligible employee may make not more than one election under this subsection during the retirement-eligible employee’s lifetime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f7618a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retirement-eligible employee who makes an election under this subsection may not make an election under section 8420a.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f7618b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f7618c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided under this subsection, the phased retirement annuity for a phased retiree is the product obtained by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f7618d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of an annuity computed under section 8415 that would have been payable to the phased retiree if, on the date on which the phased retiree enters phased retirement status, the phased retiree had separated from service and retired under section 8412 (a) or (b); by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f7618e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the phased retirement percentage for the phased retiree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f7618f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retirement annuity shall be paid in addition to the basic pay for the position to which a phased retiree is appointed during the phased employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76190-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retirement annuity shall be adjusted in accordance with section 8462.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76191-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f76192-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retirement annuity shall not be subject to reduction for any form of survivor annuity, shall not serve as the basis of the computation of any survivor annuity, and shall not be subject to any court order requiring a survivor annuity to be provided to any individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76193-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retirement annuity shall be subject to a court order providing for division, allotment, assignment, execution, levy, attachment, garnishment, or other legal process on the same basis as other annuities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76194-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f76195-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any deposit, or election of an actuarial annuity reduction in lieu of a deposit, for military service or for creditable civilian service for which retirement deductions were not made or refunded, shall be made by a retirement-eligible employee at or before the time the retirement-eligible employee enters phased retirement status. No such deposit may be made, or actuarial adjustment in lieu thereof elected, at the time a phased retiree enters full retirement status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f76196-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subparagraph (A), if a phased retiree does not make such a deposit and dies in service as a phased retiree, a survivor of the phased retiree shall have the same right to make such deposit as would have been available had the employee not entered phased retirement status and died in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76197-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retirement annuity shall commence on the date on which a phased retiree enters phased employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f76198-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No unused sick leave credit may be used in the computation of the phased retirement annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f76199-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All basic pay not in excess of the full-time rate of pay for the position to which a phased retiree is appointed shall be deemed to be basic pay for purposes of sections 8422 and 8423.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f7619a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such procedures as the Director may prescribe, a phased retiree may elect to enter full retirement status at any time. Upon making such an election, a phased retiree shall be entitled to a composite retirement annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f7619b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f7619c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided otherwise under this subsection, a composite retirement annuity is a single annuity computed under regulations prescribed by the Director, equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f7619d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the phased retirement annuity as of the date of full retirement, including any adjustments made under section 8462; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f7619e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f7619f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of an annuity computed under section 8412 that would have been payable at the time of full retirement if the individual had not elected a phased retirement and as if the individual was employed on a full-time basis in the position occupied during the phased retirement period and before any adjustment to provide for a survivor annuity; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the working percentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After computing a composite retirement annuity under paragraph (1), the Director shall adjust the amount of the annuity for any applicable reductions for a survivor annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A composite retirement annuity shall be adjusted in accordance with section 8462, except that subsection (c)(1) of that section shall not apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In computing a composite retirement annuity under paragraph (1)(B)(i), the unused sick leave to the credit of a phased retiree at the time of entry into full retirement status shall be adjusted by dividing the number of hours of unused sick leave by the working percentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such procedures and conditions as the Director may provide, and with the concurrence of the head of employing agency, a phased retiree may elect to terminate phased retirement status and return to a full-time work schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon entering a full-time work schedule based on an election under paragraph (1), the phased retirement annuity of a phased retiree shall terminate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After termination of the phased retirement annuity under this subsection, the individual’s rights under this chapter shall be determined based on the law in effect at the time of any subsequent separation from service. For purposes of this chapter, at the time of the subsequent separation from service, the phased retirement period shall be treated as if it had been a period of part-time employment with the work schedule described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subchapter IV—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the death of a phased retiree shall be deemed to be the death in service of an employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for purposes of section 8442(b)(1)(A)(i), the phased retirement period shall be deemed to have been a period of part-time employment with the work schedule described in subsection (b)(2) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of section 8442(b)(1)(A)(i), the phased retiree shall be deemed to have been at the full-time rate of pay for the position occupied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employment of a phased retiree shall not be deemed to be part-time career employment, as defined in section 3401(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retiree is not eligible to receive an annuity supplement under section 8421.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subchapter III, a phased retiree shall be deemed to be an employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of section 8445(d), retirement shall be deemed to occur on the date on which a phased retiree enters into full retirement status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retiree is not eligible to apply for an annuity under subchapter V.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A phased retiree is not subject to section 8468.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412a/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of chapter 87, a phased retiree shall be deemed to be receiving basic pay at the rate of a full-time employee in the position to which the phased retiree is appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f761b3-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100121/b/1"},"text":"Pub. L. 112–141, div. F, title I, § 100121(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/910"},"text":"126 Stat. 910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8f761b4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8f761b5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8f761b6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2014-11-06"},"text":"Nov. 6, 2014","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s100121/d"},"text":"section 100121(d) of Pub. L. 112–141","children":[],"tail":", set out as an Effective Date of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
