{"tag":"section","attrib":{"id":"idb8232278-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592"},"text":null,"children":[{"tag":"num","attrib":{"value":"3592"},"text":"§ 3592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal from the Senior Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8232279-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b) of this section, a career appointee may be removed from the Senior Executive Service to a civil service position outside of the Senior Executive Service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb823227a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 1-year period of probation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393/d"},"text":"section 3393(d) of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb823227b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time for less than fully successful executive performance as determined under subchapter II of chapter 43 of this title,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that in the case of a removal under paragraph (2) of this subsection the career appointee shall, at least 15 days before the removal, be entitled, upon request, to an informal hearing before an official designated by the Merit Systems Protection Board at which the career appointee may appear and present arguments, but such hearing shall not give the career appointee the right to initiate an action with the Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701"},"text":"section 7701 of this title","children":[],"tail":", nor need the removal action be delayed as a result of the granting of such hearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb823227c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb823227d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, a career appointee in an agency may not be involuntarily removed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb823227e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 120 days after an appointment of the head of the agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823227f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within 120 days after the appointment in the agency of the career appointee’s most immediate supervisor who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8232280-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a noncareer appointee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8232281-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the authority to remove the career appointee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232282-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection does not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8232283-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any removal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4314/b/3"},"text":"section 4314(b)(3) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232284-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disciplinary action initiated before an appointment referred to in paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8232285-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3592/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limited emergency appointee, limited term appointee, or noncareer appointee may be removed from the service at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8232286-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s404/b"},"text":"Pub. L. 95–454, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1165"},"text":"92 Stat. 1165","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s506/b/3"},"text":"Pub. L. 101–194, title V, § 506(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1758"},"text":"103 Stat. 1758","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1321/a/2/A"},"text":"Pub. L. 107–296, title XIII, § 1321(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2297"},"text":"116 Stat. 2297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8232287-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8232288-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8232289-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1321/a/2/A/iv"},"text":"Pub. L. 107–296, § 1321(a)(2)(A)(iv)","children":[],"tail":", struck out last sentence which read as follows: “In the case of a removal under paragraph (3) of this subsection, the career appointee shall have the right to appeal the removal from the Senior Executive Service to the Merit Systems Protection Board under section 7701.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1321/a/2/A/i"},"text":"Pub. L. 107–296, § 1321(a)(2)(A)(i)","children":[],"tail":", inserted “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1321/a/2/A/ii"},"text":"Pub. L. 107–296, § 1321(a)(2)(A)(ii)","children":[],"tail":", struck out “or” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1321/a/2/A/iii"},"text":"Pub. L. 107–296, § 1321(a)(2)(A)(iii)","children":[],"tail":", struck out par. (3) which read as follows: “if the career appointee is not recertified as a senior executive under section 3393a,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/b/3/D"},"text":"Pub. L. 101–194, § 506(b)(3)(D)","children":[],"tail":", inserted at end “In the case of a removal under paragraph (3) of this subsection, the career appointee shall have the right to appeal the removal from the Senior Executive Service to the Merit Systems Protection Board under section 7701.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/b/3/A"},"text":"Pub. L. 101–194, § 506(b)(3)(A)","children":[],"tail":"–(C), added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb823228a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statuto