{"tag":"section","attrib":{"id":"idb7eea493-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1401"},"text":null,"children":[{"tag":"num","attrib":{"value":"1401"},"text":"§ 1401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of agency Chief Human Capital Officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each agency referred to under paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/b"},"text":"section 901(b) of title 31","children":[],"tail":" shall appoint or designate a Chief Human Capital Officer, who shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7eea494-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the head of the agency and other agency officials in carrying out the agency’s responsibilities for selecting, developing, training, and managing a high-quality, productive workforce in accordance with merit system principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea495-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the rules and regulations of the President and the Office of Personnel Management and the laws governing the civil service within the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea496-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such functions as the primary duty of the Chief Human Capital Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7eea497-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1302/a"},"text":"Pub. L. 107–296, title XIII, § 1302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2287"},"text":"116 Stat. 2287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7eea498-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7eea499-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7eea49a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1305"},"text":"section 1305 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date of 2002 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1103"},"text":"section 1103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7eea49b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chief Human Capital Officers Council","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1303"},"text":"Pub. L. 107–296, title XIII, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2288"},"text":"116 Stat. 2288","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXVI/s6604"},"text":"Pub. L. 117–81, div. F, title LXVI, § 6604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2441"},"text":"135 Stat. 2441","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dF/tLXVI/s6604"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a Chief Human Capital Officers Council, consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Personnel Management, who shall act as chairperson of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Director for Management of the Office of Management and Budget, who shall act as vice chairperson of the Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Human Capital Officers of Executive departments and any other members who are designated by the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Human Capital Officers Council shall meet periodically to advise and coordinate the activities of the agencies of its members on such matters as modernization of human resources systems, improved quality of human resources information, and legislation affecting human resources operations and organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Labor Organizations at Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Human Capital Officers Council shall ensure that representatives of Federal employee labor organizations are present at a minimum of 1 meeting of the Council each year. Such representatives shall not be members of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, the Chief Human Capital Officers Council shall submit to Congress a report that includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the activities of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of employment barriers that prevent the agencies of its members from hiring qualified applicants, including those for digital talent positions, and recommendations for addressing the barriers that would allow such agencies to more effectively hire qualified applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the Council submits a report under paragraph (1), the Director of the Office of Personnel Management shall make the report publicly available on the website of the Office of Personnel Management.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
