tes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82f0964-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “National Imagery and Mapping Agency” for “Central Imagery Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" inserted “the Central Imagery Office,” after “Defense Intelligence Agency,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/474"},"text":"Pub. L. 101–474","children":[],"tail":" struck out “, the Administrative Office of the United States Courts,” after “means an Executive agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “chapter” for “subchapter” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t28/s509"},"text":"28 U.S.C. 509","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5108"},"text":"5 U.S.C. 5108","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82f0965-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb82f0966-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in subsec. (a)(1) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82f0967-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82f0968-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-12"},"text":"July 12, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/b"},"text":"section 2(b) of Pub. L. 96–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s305"},"text":"section 305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82f0969-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb82f096a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Design Elements of Pay-for-Performance Systems in Demonstration Projects","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1126"},"text":"Pub. L. 108–136, div. A, title XI, § 1126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1640"},"text":"117 Stat. 1640","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dA/tXI/s1126"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“A pay-for-performance system may not be initiated under chapter 47 of title 5, United States Code, after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":"], unless it incorporates the following elements:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adherence to merit principles set forth in section 2301 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fair, credible, and transparent employee performance appraisal system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A link between elements of the pay-for-performance system, the employee performance appraisal system, and the agency’s strategic plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A means for ensuring employee involvement in the design and implementation of the system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adequate training and retraining for supervisors, managers, and employees in the implementation and operation of the pay-for-performance system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for ensuring ongoing performance feedback and dialogue between supervisors, managers, and employees throughout the appraisal period, and setting timetables for review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective safeguards to ensure that the management of the system is fair and equitable and based on employee performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A means for ensuring that adequate agency resources are allocated for the design, implementation, and administration of the pay-for-performance system.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
