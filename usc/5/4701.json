{"tag":"section","attrib":{"id":"idb82f0956-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701"},"text":null,"children":[{"tag":"num","attrib":{"value":"4701"},"text":"§ 4701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82f0957-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f0958-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means an Executive agency and the Government Publishing Office, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f0959-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f095a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation, the Central Intelligence Agency, the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Security Agency, and, as determined by the President, any Executive agency or unit thereof which is designated by the President and which has as its principal function the conduct of foreign intelligence or counterintelligence activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f095b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f095c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an individual employed in or under an agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f095d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “eligible” means an individual who has qualified for appointment in an agency and whose name has been entered on the appropriate register or list of eligibles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f095e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “demonstration project” means a proj­ect conducted by the Office of Personnel Management, or under its supervision, to determine whether a specified change in personnel management policies or procedures would result in improved Federal personnel management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f095f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “research program” means a planned study of the manner in which public management policies and systems are operating, the effects of those policies and systems, the possibilities for change, and comparisons among policies and systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f0960-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter shall not apply to any position in the Drug Enforcement Administration which is excluded from the competitive service under section 201 of the Crime Control Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s509"},"text":"28 U.S.C. 509","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/90/2425"},"text":"90 Stat. 2425","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f0961-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVI/s601/a"},"text":"Pub. L. 95–454, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1185"},"text":"92 Stat. 1185","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/21"},"text":"Pub. L. 96–54, § 2(a)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/474/s5/g"},"text":"Pub. L. 101–474, § 5(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-30"},"text":"Oct. 30, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1100"},"text":"104 Stat. 1100","children":[],"tail":"; "},{"tag":"ref","