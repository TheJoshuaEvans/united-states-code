{"tag":"section","attrib":{"id":"idb82f0903-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508"},"text":null,"children":[{"tag":"num","attrib":{"value":"4508"},"text":"§ 4508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of awards during a Presidential election year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82f0904-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f0905-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Presidential election period” means any period beginning on June 1 in a calendar year in which the popular election of the President occurs, and ending on January 20 following the date of such election; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0906-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “senior politically appointed officer” means any officer who during a Presidential election period serves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f0907-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a Senior Executive Service position and is not a career appointee as defined under section 3132(a)(4); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0908-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a position of a confidential or policy-determining character under schedule C of subpart C of part 213 of title 5 of the Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f0909-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No senior politically appointed officer may receive an award under the provisions of this subchapter during a Presidential election period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f090a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/425/s2/a"},"text":"Pub. L. 103–425, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4369"},"text":"108 Stat. 4369","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
