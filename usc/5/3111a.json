{"tag":"section","attrib":{"id":"idb7fcfbe8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111a"},"text":"§ 3111a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal internship programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7fcfbe9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Internship Coordinator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency operating an internship program shall appoint an individual within such agency to serve as an internship coordinator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfbea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Online Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fcfbeb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall make publicly available on the Internet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fcfbec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and contact information of the internship coordinator for each agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding application procedures and deadlines for each internship program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfbee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of personnel management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Personnel Management shall make publicly available on the Internet links to the websites where the information described in paragraph (1) is displayed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfbef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fcfbf0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “internship program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fcfbf1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a volunteer service program under section 3111(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbf2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an internship program established under Executive Order 13562, dated ","children":[{"tag":"date","attrib":{"date":"2010-12-27"},"text":"December 27, 2010","children":[],"tail":" (75 Federal Register 82585);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbf3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program operated by a nongovernment organization for the purpose of providing paid internships in agencies under a written agreement that is similar to an internship program established under Executive Order 13562, dated ","children":[{"tag":"date","attrib":{"date":"2010-12-27"},"text":"December 27, 2010","children":[],"tail":" (75 Federal Register 82585); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbf4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a program that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7fcfbf5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is similar to an internship program established under Executive Order 13562, dated ","children":[{"tag":"date","attrib":{"date":"2010-12-27"},"text":"December 27, 2010","children":[],"tail":" (75 Federal Register 82585); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7fcfbf6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized under another statutory provision of law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfbf7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intern” means an individual participating in an internship program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfbf8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3111a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” means an Executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7fcfbf9-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1109/a"},"text":"Pub. L. 112–81, div. A, title XI, § 1109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1614"},"text":"125 Stat. 1614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fcfbfa-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7