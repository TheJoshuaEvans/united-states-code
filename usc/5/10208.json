{"tag":"section","attrib":{"id":"idb9309a55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10208"},"text":null,"children":[{"tag":"num","attrib":{"value":"10208"},"text":"§ 10208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demotions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When a member is changed or demoted from any rank to a lower rank, the Secretary may fix the member’s rate of basic pay at the rate of pay for any step in the lower rank which does not exceed the lowest step in the lower rank for which the rate of basic pay is equal to or greater than the member’s existing rate of basic pay.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9309a56-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282/s2/a"},"text":"Pub. L. 111–282, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3037"},"text":"124 Stat. 3037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9309a57-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9309a58-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9309a59-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first pay period which begins after ","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/282/s5"},"text":"section 5 of Pub. L. 111–282","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
