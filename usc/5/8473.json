{"tag":"section","attrib":{"id":"idb90a758a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473"},"text":null,"children":[{"tag":"num","attrib":{"value":"8473"},"text":"§ 8473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee Thrift Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90a758b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall establish an Employee Thrift Advisory Council. The Council shall be composed of 15 members appointed by the Chairman of the Board in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a758c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chairman shall appoint 15 members of the Council, of whom—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a758d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 shall be appointed to represent the respective labor organizations representing (as exclusive representatives) the first, second, third, and fourth largest numbers of individuals subject to chapter 71 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a758e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed to represent the respective labor organizations which have been accorded exclusive recognition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1203/a"},"text":"section 1203(a) of title 39","children":[],"tail":" representing the largest and second largest numbers of individuals employed by the United States Postal Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a758f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent the labor organization which has been accorded exclusive recognition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1203/a"},"text":"section 1203(a) of title 39","children":[],"tail":" representing the largest number of individuals employed by the United States Postal Service as rural letter carriers;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7590-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed to represent the respective managerial organizations (other than an organization described in paragraph (5)) which consult with the United States Postal Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1004/b"},"text":"section 1004(b) of title 39","children":[],"tail":" and which represent the largest and second largest numbers of individuals employed by the United States Postal Service as managerial personnel;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7591-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent the supervisors’ organization as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1004/h"},"text":"section 1004(h) of title 39","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7592-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent employee organizations having as a purpose promoting the interests of women in Government service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7593-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent the organization representing the largest number of individuals receiving annuities under this chapter or chapter 83 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7594-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent the organization representing the largest number of supervisors and management officials (as defined by section 7103(a));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7595-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent the organization representing the largest number of members of the Senior Executive Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7596-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed to represent participants (under section 8440e) who are members of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a7597-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a7598-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Board shall designate 1 member of the Council to serve as head of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a7599-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Council shall be appointed for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a759a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90a759b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in the Council shall be filled in the manner in which the original appointment was made and shall be subject to any conditions which applied with respect to the original appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90a759c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual chosen to fill a vacancy shall be appointed for the unexpired term of the member replaced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90a759d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of any member shall not expire before the date on which the member’s successor takes office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a759e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council shall act by resolution of a majority of the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a759f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a75a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Board and the Executive Director on matters relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90a75a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investment policies for the Thrift Savings Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90a75a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of this subchapter and subchapter III of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a75a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as the Board may direct with respect to investment funds established in accordance with subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a75a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8473/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of this title","children":[],"tail":" shall not apply to the Council."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90a75a5-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/579"},"text":"100 Stat. 579","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/b/1/N"},"text":"Pub. L. 103–89, § 3(b)(1)(N)","children":[],"tail":", "},{"tag":"date