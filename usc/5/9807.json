{"tag":"section","attrib":{"id":"idb9296f06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807"},"text":null,"children":[{"tag":"num","attrib":{"value":"9807"},"text":"§ 9807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay authority for critical positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9296f07-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “position” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296f08-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which chapter 51 applies, including a position in the Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position under the Executive Schedule under sections 5312 through 5317;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f0a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position established under section 3104; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a senior-level position to which section 5376(a)(1) applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296f0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Authority under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296f0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be exercised only with respect to a position that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296f0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is described as addressing a critical need in the workforce plan under section 9802(b)(2)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296f0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires expertise of an extremely high level in a scientific, technical, professional, or administrative field;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be exercised only to the extent necessary to recruit or retain an individual exceptionally well qualified for the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be exercised only in retaining employees of the Administration or in appointing individuals who were not employees of another Federal agency as defined under section 5102(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296f12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296f13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 5377, the Administrator may fix the rate of basic pay for a position in the Administration in accordance with this section. The Administrator may not delegate this authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of positions with pay fixed under this section may not exceed 10 at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296f15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296f16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of basic pay fixed under this section may not be less than the rate of basic pay (including any comparability payments) which would otherwise be payable for the position involved if this section had never been enacted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The annual rate of basic pay fixed under this section may not exceed the per annum rate of salary payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296f18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9807/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of section 5307, in the case of an employee who, during any calendar year, is receiving pay at a rate fixed under this section, no allowance, differential, bonus, award, or similar cash payment may be paid to such employee if, or to the extent that, when added to basic pay paid or payable to such employee (for service performed in such calendar year as an employee in the executive branch or as an employee outside the executive branch to whom chapter 51 applies), such payment would cause the total to exceed the per annum rate of salary which, as of the end of such calendar year, is payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9296f19-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/201/s3/a"},"text":"Pub. L. 108–201, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-02-24"},"text":"Feb. 24, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/467"},"text":"118 Stat. 467","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
