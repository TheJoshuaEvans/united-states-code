{"tag":"section","attrib":{"id":"idb8256bd4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3597"},"text":null,"children":[{"tag":"num","attrib":{"value":"3597"},"text":"§ 3597.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reemployment following limited appointment in the Foreign Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An employee of any agency who accepts, with the consent of the head of that agency, a limited appointment in the Foreign Service under section 309 of the Foreign Service Act of 1980 is entitled, upon the expiration of that appointment, to be reemployed in that employee’s former position or in a corresponding or higher position in that agency. Upon reemployment under this section, an employee shall be entitled to any within-grade increases in pay which the employee would have received if the employee had remained in the former position in the agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8256bd5-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2301/a"},"text":"Pub. L. 96–465, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2164"},"text":"94 Stat. 2164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8256bd6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8256bd7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8256bd8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 309 of the Foreign Service Act of 1980, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3949"},"text":"section 3949 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8256bd9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8256bda-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
