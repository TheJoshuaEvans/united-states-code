n":[{"tag":"html:span","attrib":{},"text":"Aug. 25, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/749"},"text":"Pub. L. 85–749","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/843"},"text":"72 Stat. 843","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/587/s1"},"text":"Pub. L. 86–587, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/327"},"text":"74 Stat. 327","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1963","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/146"},"text":"Pub. L. 88–146","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/77/252"},"text":"77 Stat. 252","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb882804a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb882804b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the Presidential Transition Act of 1963, referred to in subsecs. (a) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/277/s3"},"text":"section 3 of Pub. L. 88–277","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb882804c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264"},"text":"Pub. L. 105–264","children":[],"tail":" substituted “spent by the Government” for “spent by the United States” and “due the Government” for “due the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1723/b/1"},"text":"Pub. L. 104–201, § 1723(b)(1)","children":[],"tail":", in introductory provisions, substituted “Under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":"” for “Under such regulations as the President may prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/b/2"},"text":"Pub. L. 104–201, § 1715(b)(2)","children":[],"tail":", which directed amendment of subsec. (a) by adding par. (3) at the end, was executed by adding par. (3) after par. (2) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/48/A"},"text":"Pub. L. 102–378, § 2(48)(A)","children":[],"tail":", struck out “; manpower shortage positions” after “trainees” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/48/B"},"text":"Pub. L. 102–378, § 2(48)(B)","children":[],"tail":", redesignated subsec. (e) as (d) and struck out former subsec. (d) which authorized Office to delegate its authority to determine positions for which there was a manpower shortage for purposes of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tII/s206/b/1"},"text":"Pub. L. 101–509, § 529 [title II, § 206(b)(1)]","children":[],"tail":", substituted “any position” for “a position in the United States for which the Office of Personnel Management determines there is a manpower shortage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tII/s206/b/2"},"text":"Pub. L. 101–509, § 529 [title II, § 206(b)(2)]","children":[],"tail":", substituted “the minimum rate of pay payable for a position classified above GS–15 pursuant to section 5108; and” for “the minimum rate of pay prescribed for GS–16; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/398/s6/2"},"text":"Pub. L. 100–398, § 6(2)","children":[],"tail":", inserted at end “In the case of an appointee described in paragraph (1) who has performed transition activities under section 3 of the Presidential Transition Act of 1963 ("},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"3 U.S.C. 102","children":[],"tail":" note), the provisions of paragraphs (1) and (2) may apply to travel and transportation expenses from the place of residence of such appointee (at the time of relocation following the most recent general elections held to determine the electors of the President) to the assigned duty station of such appointee.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/398/s6/1"},"text":"Pub. L. 100–398, § 6(1)","children":[],"tail":", which directed that par. (1) be amended by striking out “or (B)” and inserting “or (C)”, could not be executed because phrase “or (B)” did not appear in par. (1) after the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/325"},"text":"Pub. L. 100–325","children":[],"tail":", see below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325"},"text":"Pub. L. 100–325","children":[],"tail":" inserted reference to Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service in cl. (B) and redesignated a second cl. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/398/s6/3"},"text":"Pub. L. 100–398, § 6(3)","children":[],"tail":", inserted at end “In the case of an appointee described in subsection (a)(1) who has performed transition activities under section 3 of the Presidential Transition Act of 1963 ("},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"3 U.S.C. 102","children":[],"tail":" note), the travel or transportation shall take place at any time after the most recent general elections held to determine the electors of the President.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" directed amendment of subpar. (C) by striking out “, by and with the advice and consent of the Senate,” which was executed to second subpar. (B) by striking out that phrase following “appointed by the President”, as probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":", designated existing provisions as subpars. (A) and (B), and added a second subpar. (B) relating to any person appointed by President."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/a/2"},"text":"Pub. L. 95–454, § 906(a)(2)","children":[],"tail":", substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s409/a"},"text":"Pub. L. 95–454, § 409(a)","children":[],"tail":", inserted reference to a new appointee to the Senior Executive Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", §§ 305, 906(a)(3), struck out “not” before “delegate”, and substituted “Office” for “Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb882804d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb882804e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective