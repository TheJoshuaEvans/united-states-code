{"tag":"section","attrib":{"id":"idb8c2e495-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8138"},"text":null,"children":[{"tag":"num","attrib":{"value":"8138"},"text":"§ 8138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum limit modification for noncitizens and aliens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c2e496-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (b) of this section, the minimum limit on monthly compensation for disability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8112"},"text":"section 8112 of this title","children":[],"tail":" and the minimum limit on monthly pay on which death compensation is computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133"},"text":"section 8133 of this title","children":[],"tail":" do not apply in the case of a noncitizen employee, or a class or classes of noncitizen employees, who sustain injury outside the continental United States. The Secretary of Labor may establish a minimum monthly pay on which death compensation is computed in the case of a class or classes of such noncitizen employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e497-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may remove or modify the minimum limit on monthly compensation for disability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8112"},"text":"section 8112 of this title","children":[],"tail":" and the minimum limit on monthly pay on which death compensation is computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133"},"text":"section 8133 of this title","children":[],"tail":" in the case of an alien employee, or a class or classes of alien employees, of the Canal Zone Government or the Panama Canal Company."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c2e498-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/550"},"text":"80 Stat. 550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c2e499-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e49a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e49b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"te