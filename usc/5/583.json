{"tag":"section","attrib":{"id":"idb7bc9815-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s583"},"text":null,"children":[{"tag":"num","attrib":{"value":"583"},"text":"§ 583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter, an agency may use (with or without reimbursement) the services and facilities of other Federal agencies, State, local, and tribal governments, public and private organizations and agencies, and individuals, with the consent of such agencies, organizations, and individuals. An agency may accept voluntary and uncompensated services for purposes of this subchapter without regard to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7bc9816-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/552/s4/b"},"text":"Pub. L. 101–552, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2745"},"text":"104 Stat. 2745","children":[],"tail":", § 593; renumbered § 583, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/320/s5"},"text":"Pub. L. 104–320, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3871"},"text":"110 Stat. 3871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bc9817-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bc9818-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7bc9819-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 583 to 590 were renumbered sections 573 to 580 of this title, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other prior sections 583 to 590 were renumbered sections 563 to 570 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bc981a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320"},"text":"Pub. L. 104–320","children":[],"tail":" inserted “State, local, and tribal governments,” after “other Federal agencies,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s593"},"text":"section 593 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
