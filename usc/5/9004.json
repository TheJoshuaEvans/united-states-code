{"tag":"section","attrib":{"id":"idb924b3c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004"},"text":null,"children":[{"tag":"num","attrib":{"value":"9004"},"text":"§ 9004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b3c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each eligible individual obtaining long-term care insurance coverage under this chapter shall be responsible for 100 percent of the premiums for such coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholdings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b3ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount necessary to pay the premiums for enrollment may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b3cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee, be withheld from the pay of such employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b3cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an annuitant, be withheld from the annuity of such annuitant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b3cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a member of the uniformed services described in section 9001(3), be withheld from the pay of such member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b3ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a retired member of the uniformed services described in section 9001(4), be withheld from the retired pay or retainer pay payable to such member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b3cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary withholdings for qualified relatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Withholdings to pay the premiums for enrollment of a qualified relative may, upon election of the appropriate eligible individual (described in section 9001(1)–(4)), be withheld under paragraph (1) to the same extent and in the same manner as if enrollment were for such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All amounts withheld under this section shall be paid directly to the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Forms of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any enrollee who does not elect to have premiums withheld under subsection (b) or whose pay, annuity, or retired or retainer pay (as referred to in subsection (b)(1)) is insufficient to cover the withholding required for enrollment (or who is not receiving any regular amounts from the Government, as referred to in subsection (b)(1), from which any such withholdings may be made, and whose premiums are not otherwise being provided for under subsection (b)(2)) shall pay an amount equal to the full amount of those charges directly to the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate Accounting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each carrier participating under this chapter shall maintain records that permit it to account for all amounts received under this chapter (including investment earnings on those amounts) separate and apart from all other funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b3d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable initial costs.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b3d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Employees’ Life Insurance Fund is available, without fiscal year limitation, for reasonable expenses incurred by the Office of Personnel Management in administering this chapter before the start of the 7-year period described in section 9003(d)(2)(B), including reasonable implementation costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b3d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such Fund shall be reimbursed, before the end of the first year of that 7-year period, for all amounts obligated or expended under subparagraph (A) (including lost investment income). Such reimbursement shall be made by carriers, on a pro rata basis, in accordance with appropriate provisions which shall be included in master contracts under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b3d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent costs.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b3d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is hereby established in the Employees’ Life Insurance Fund a Long-Term Care Administrative Account, which shall be available to the Office, without fiscal year limitation, to defray reasonable expenses incurred by the Office in administering this chapter after the start of the 7-year period described in section 9003(d)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b3d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9004/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each master contract under this chapter shall include appropriate provisions under which the carrier involved shall, during each year, make such periodic contributions to the Long-Term Care Administrative Account as necessary to ensure that the reasonable anticipated expenses of the Office in administering this chapter during such year (adjusted to reconcile for any earlier overestimates or underestimates under this subparagraph) are defrayed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b3da-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1002/a"},"text":"Pub. L. 106–265, title I, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/766"},"text":"114 Stat. 766","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
