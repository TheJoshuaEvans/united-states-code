{"tag":"section","attrib":{"id":"idb83faa65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5311"},"text":null,"children":[{"tag":"num","attrib":{"value":"5311"},"text":"§ 5311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The Executive Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Executive Schedule, which is divided into five pay levels, is the basic pay schedule for positions, other than Senior Executive Service positions and positions in the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service, to which this subchapter applies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb83faa66-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/459"},"text":"80 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV"},"text":"Pub. L. 95–454, title IV","children":[],"tail":", §§ 408(b)(1), 414(b)(1), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1173"},"text":"92 Stat. 1173","children":[],"tail":", 1178; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/24"},"text":"Pub. L. 96–54, § 2(a)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/325/s2/h/1"},"text":"Pub. L. 100–325, § 2(h)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1988-05-30"},"text":"May 30, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/582"},"text":"102 Stat. 582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s104/c"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 104(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1447.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb83faa67-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb83faa68-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb83faa69-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2210"},"text":"5 U.S.C. 2210","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/426/s302"},"text":"Pub. L. 88–426, § 302","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/415"},"text":"78 Stat. 415","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “There is hereby established” are omitted as executed. The word “offices” is omitted as included in “positions”. The words “Executive Schedule” are substituted for “Federal Executive Salary Schedule”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb83faa6a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb83faa6b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" struck out “(a)” before “The Executive Schedule, which” and struck out subsec. (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Not later than 180 days after the date of the enactment of the Civil Service Reform Act of 1978, the Director of the Office of Personnel Management shall determine the number and classification of executive level positions in existence in the executive branch on that date of enactment, and shall publish the determination in the Federal Register. Effective beginning on the date of the publication, the number of executive level positions within the executive branch may not exceed the number published under this subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) For the purpose of this subsection, ‘executive level position’ means—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) any office or position in the civil service the rate of pay for which is equal to or greater than the rate of basic pay payable for positions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of this title","children":[],"tail":", or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) any such office or position the rate of pay for which may be fixed by administrative action at a rate equal to or greater than the rate of basic pay payable for positions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"but does not include any Senior Executive Service position (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of this title","children":[],"tail":") or any position in the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325/s2/h/1"},"text":"Pub. L. 100–325, § 2(h)(1)","children":[],"tail":", inserted reference to positions in Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325/s2/h/2"},"text":"Pub. L. 100–325, § 2(h)(2)","children":[],"tail":", substituted “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of this title","children":[],"tail":") or any position in the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service” for “, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a"},"text":"section 3132(a) of this title","children":[],"tail":"” in concluding provision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" inserted “of the Office of Personnel Management” after “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s408/b/1"},"text":"Pub. L. 95–454, § 408(b)(1)","children":[],"tail":", inserted reference to Senior Executive Service positions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s414/b/1"},"text":"Pub. L. 95–454, § 414(b)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb83faa6c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb83faa6d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb83faa6e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-12"},"text":"July 12, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/b"},"text":"section 2(b) of Pub. L. 96–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s305"},"text":"section 305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb83faa6f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 9 months after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s415"},"text":"section 415 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb83faa70-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan for Authorizing Executive Level Positions in Executive Branch; Presidential Submission to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s414/b/2"},"text":"Section 414(b)(2) of Pub. L. 95–454","children":[],"tail":" required President to transmit by "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"Jan. 1, 1980","children":[],"tail":", a plan to Congress for authorizing executive level positions in executive branch."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
