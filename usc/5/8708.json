48f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":" effective on first day of first pay period which begins on or after sixtieth day following "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"December 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s405/a"},"text":"section 405(a) of Pub. L. 90–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8704"},"text":"section 8704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"retroactiveDate","id":"idb913ea25-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Effect of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":" to have no effect in case of an employee who died, was finally separated, or retired prior to "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s405/c"},"text":"section 405(c) of Pub. L. 90–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8704"},"text":"section 8704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
