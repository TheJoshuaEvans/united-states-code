{"tag":"section","attrib":{"id":"idb913ea0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708"},"text":null,"children":[{"tag":"num","attrib":{"value":"8708"},"text":"§ 8708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb913ea10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each period in which an employee is insured under a policy of insurance purchased by the Office of Personnel Management under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8709"},"text":"section 8709 of this title","children":[],"tail":", a sum equal to one-half the amount which is withheld from the pay of the employee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8707"},"text":"section 8707 of this title","children":[],"tail":" shall be contributed from the appropriation or fund which is used to pay him."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb913ea11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an employee is paid by the Chief Administrative Officer of the House of Representatives, the Chief Administrative Officer may contribute the sum required by subsection (a) of this section from the applicable accounts of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb913ea12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the employee is an elected official, the sum required by subsection (a) of this section is contributed from an appropriation or fund available for payment of other salaries of the same office or establishment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb913ea13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb913ea14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, for each period in which an employee continues life insurance after retirement or while in receipt of compensation under subchapter I of chapter 81 of this title because of disease or injury to the employee, as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8706/b"},"text":"section 8706(b) of this title","children":[],"tail":", a sum equal to one-half of the amount which is withheld from the employee’s annuity or compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8707"},"text":"section 8707 of this title","children":[],"tail":" shall be contributed by the Office from annual appropriations which are authorized to be made for that purpose and which may be made available until expended."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb913ea15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Contributions under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb913ea16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made other than with respect to individuals who retire, or commence receiving compensation, after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb913ea17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be made with respect to any individual for months after the calendar month in which such individual becomes 65 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb913ea18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, in the case of any individual who elects coverage under subparagraph (B) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8706/b/3"},"text":"section 8706(b)(3) of this title","children":[],"tail":", be equal to the amount which would apply under this subsection if such individual had instead elected coverage under subparagraph (A) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb913ea19-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Postal Service shall pay the contributions required under this subsection with respect to any individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb913ea1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first becomes an annuitant by reason of retirement from employment with the United States Postal Service after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb913ea1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8708/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commences receiving compensation under subchapter I of chapter 81 of this title (because of disease or injury to the individual) after ","children":[{"tag":"date","attrib":{"date":"1989-12-31"},"text":"December 31, 1989","children":[],"tail":", if the position last held by the individual before commencing to receive such compensation was within the United States Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb913ea1c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/595"},"text":"80 Stat. 595","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/tIV/s403"},"text":"Pub. L. 90–206, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/647"},"text":"81 Stat. 647","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"t