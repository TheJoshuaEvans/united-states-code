{"tag":"section","attrib":{"id":"idb926fd94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9502"},"text":null,"children":[{"tag":"num","attrib":{"value":"9502"},"text":"§ 9502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay authority for critical positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb926fd95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary of the Treasury seeks a grant of authority under section 5377 for critical pay for 1 or more positions at the Internal Revenue Service, the Office of Personnel Management may fix the rate of basic pay, notwithstanding sections 5377(d)(2) and 5307, at any rate up to the salary set in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 5307, no allowance, differential, bonus, award, or similar cash payment may be paid to any employee receiving critical pay at a rate fixed under subsection (a), in any calendar year if, or to the extent that, the employee’s total annual compensation will exceed the maximum amount of total annual compensation payable at the salary set in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd97-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1201/a"},"text":"Pub. L. 105–206, title I, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/712"},"text":"112 Stat. 712","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dD/tI/s107"},"text":"Pub. L. 110–161, div. D, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1977"},"text":"121 Stat. 1977","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb926fd98-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb926fd99-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb926fd9a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" substituted “Office of Personnel Management” for “Office of Management and Budget”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
