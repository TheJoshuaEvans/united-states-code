","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (6), relating to Official Reporters of Debates of the Senate and their employees, is eliminated as unnecessary on authority of the act of ","children":[{"tag":"date","attrib":{"date":"1965-07-27"},"text":"July 27, 1965","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s126–1"},"text":"2 U.S.C. 126–1","children":[],"tail":"). Pursuant to that act, the Official Reporters and their employees became employees of the Senate; accordingly, they are now included within the definition of “Congressional employee” under paragraph (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (8), based on the act of ","children":[{"tag":"date","attrib":{"date":"1966-09-26"},"text":"September 26, 1966","children":[],"tail":" (5 App. U.S.C. 2251(c)), the word “officers” is omitted as included in “employees,” and the words “United States” preceding the words “Botanic Garden” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f115ae-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f115af-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":", inserted “or employee” after “member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/437"},"text":"Pub. L. 110–437","children":[],"tail":" amended par. (9) generally. Prior to amendment, p