{"tag":"section","attrib":{"id":"idb7f1159f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107"},"text":null,"children":[{"tag":"num","attrib":{"value":"2107"},"text":"§ 2107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional employee","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this title, “Congressional employee” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f115a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of either House of Congress, of a committee of either House, or of a joint committee of the two Houses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an elected officer of either House who is not a Member of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Legislative Counsel of either House and an employee of his office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member or employee of the Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of a Member of Congress if the pay of the employee is paid by the Secretary of the Senate or the Chief Administrative Officer of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"status":"repealed","id":"idb7f115a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"[(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/5/A"},"text":"Pub. L. 90–83, § 1(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/196"},"text":"81 Stat. 196","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Architect of the Capitol and an employee of the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Botanic Garden; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f115a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2107/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Office of Congressional Accessibility Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f115a9-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/409"},"text":"80 Stat. 409","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/5"},"text":"Pub. L. 90–83, § 1(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/196"},"text":"81 Stat. 196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/510/tIV/s442/a"},"text":"Pub. L. 91–510, title IV, § 442(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1191"},"text":"84 Stat. 1191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s215/1"},"text":"Pub. L. 104–186, title II, § 215(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1745"},"text":"110 Stat. 1745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/437/tIV/s422/c"},"text":"Pub. L. 110–437, title IV, § 422(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-20"},"text":"Oct. 20, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4997"},"text":"122 Stat. 4997","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s7/a"},"text":"Pub. L. 111–145, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-04"},"text":"Mar. 4, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/55"},"text":"124 Stat. 55","children":[]