{"tag":"section","attrib":{"id":"idb9296e88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801"},"text":null,"children":[{"tag":"num","attrib":{"value":"9801"},"text":"§ 9801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296e89-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administration” means the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e8b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “critical need” means a specific and important safety, management, engineering, science, research, or operations requirement of the Administration’s mission that the Administration is unable to fulfill because the Administration lacks the appropriate employees because—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e8c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the inability to fill positions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees do not possess the requisite skills;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” means an individual employed in or under the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “workforce plan” means the plan required under section 9802(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Government Reform, Science, and Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Governmental Affairs, Commerce, Science, and Transportation, and Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “redesignation bonus” means a bonus under section 9804 paid to an individual described in subsection (a)(2) thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “supervisor” has the meaning given such term by section 7103(a)(10); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9801/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “management official” has the meaning given such term by section 7103(a)(11).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9296e96-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/201/s3/a"},"text":"Pub. L. 108–201, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-02-24"},"text":"Feb. 24, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/461"},"text":"118 Stat. 461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9296e97-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note"