{"tag":"section","attrib":{"id":"idb8c2e4cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142"},"text":null,"children":[{"tag":"num","attrib":{"value":"8142"},"text":"§ 8142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peace Corps volunteers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c2e4d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section, “volunteer” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e4d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a volunteer enrolled in the Peace Corps under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504"},"text":"section 2504 of title 22","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a volunteer leader enrolled in the Peace Corps under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2505"},"text":"section 2505 of title 22","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicant for enrollment as a volunteer or volunteer leader during a period of training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507/a"},"text":"section 2507(a) of title 22","children":[],"tail":" before enrollment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e4d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this section, this subchapter applies to a volunteer, except that entitlement to disability compensation payments does not commence until the day after the date of termination of his service as a volunteer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e4d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e4d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a volunteer is deemed receiving monthly pay at the minimum rate for GS–7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a volunteer leader referred to by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2505"},"text":"section 2505 of title 22","children":[],"tail":", or a volunteer with one or more minor children as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504"},"text":"section 2504 of title 22","children":[],"tail":", is deemed receiving monthly pay at the minimum rate for GS–11;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an injury suffered by a volunteer when he is outside the several States and the District of Columbia is deemed proximately caused by his employment, unless the injury or disease is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e4d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caused by willful misconduct of the volunteer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e4da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caused by the volunteer’s intention to bring about the injury or death of himself or of another; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e4db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proximately caused by the intoxication of the injured volunteer; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the period of service of an individual as a volunteer includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e4dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any period of training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507/a"},"text":"section 2507(a) of title 22","children":[],"tail":" before enrollment as a volunteer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e4de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period between enrollment as a volunteer and the termination of service as a volunteer by the President or by death or resignation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e4df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e4e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall authorize the Director of the Peace Corps to furnish medical benefits to a volunteer, who is injured during the volunteer’s period of service, for a period of 120 days following the termination of such service if the Director certifies that the volunteer’s injury probably meets the requirements under subsection (c)(3). The Secretary may then certify vouchers for these expenses for such volunteer out of the Employees’ Compensation Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the form and content of the certification required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification under paragraph (1) will cease to be effective if the volunteer sustains compensable disability in connection with volunteer service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8142/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection may be construed to authorize the furnishing of any medical benefit that the Secretary of Labor is not otherwise authorized to reimburse for former Peace Corps volunteers who receive treatment for injury or disease proximately caused by their service in the Peace Corps in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c2e4e4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/552"},"text":"80 Stat. 552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/64"},"text":"Pub. L. 90–83, § 1(64)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/212"},"text":"81 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s23/b"},"text":"Pub. L. 93–416, § 23(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1150"},"text":"88 Stat. 1150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tI/s102"},"text":"Pub. L. 115–256, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3652"},"text":"132 Stat. 3652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c2e4e5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e4e6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e4e7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1966 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t22/s2504/d"},"text":"22 U.S.C. 2504(d)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/293/s5/d"},"text":"Pub. L. 87–293, § 5(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/613"},"text":"75 Stat. 613","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is based on sections 2504(a), 2505, and 2507(a) of title 22.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Subject to the provisions of this section” are added for clarity and to conform to the style of sections 8140 and 8141. The words “of the United States Government” are omitted as unnecessary in view of the definition of “employee” in section 8101(1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “outside the several States, territories and possessions of the United States, and the District of Columbia” are substituted for “abroad” on authority of section 2522(a), (b) of title 22. References to “the general schedule established by the Classification Act of 1949, as amended” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(4) is added on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2522/e"},"text":"section 2522(e) of title 22","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e4e8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1967 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8142"},"text":"Section 8142 of title 5","children":[],"tail":" was derived from "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504/d"},"text":"section 2504(d) of title 22","children":[],"tail":". This amendment reflects changes, effected by the act of "},{"tag":"date","attrib":{"date":"1966-09-13"},"text":"Sept. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/572"},"text":"Public Law 89–572","children":[],"tail":", section 4, "},{"tag":"ref","attrib":{"href":"/us/stat/80/765"},"text":"80 Stat. 765","children":[],"tail":", in the definitions applicable to section 2504(d) by virtue of section 2522(a), (b) of title 22."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c2e4e9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c2e4ea-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256"},"text":"Pub. L. 115–256","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" inserted provision relating to a volunteer with one or more minor children."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c2e4eb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c2e4ec-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", and applicable to any injury or death occurring on or after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s23/a"},"text":"section 23(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
