{"tag":"section","attrib":{"id":"idb878e2dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570"},"text":null,"children":[{"tag":"num","attrib":{"value":"5570"},"text":"§ 5570.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for disability or death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb878e2de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb878e2df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb878e2e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual in the Civil Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual rendering personal service to the United States similar to the service of an individual in the Civil Service (other than as a member of the uniformed services); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb878e2e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “family member”, as used with respect to an employee, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb878e2e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any dependent of such employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual (other than a dependent under subparagraph (A)) who is a member of the employee’s family or household.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e2e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall prescribe regulations under which an agency head may pay compensation for the disability or death of an employee or a family member of an employee if, as determined by the President, the disability or death was caused by hostile action and was a result of the individual’s relationship with the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e2e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any compensation otherwise payable to an individual under this section in connection with any disability or death shall be reduced by any amounts payable to such individual under any other program funded in whole or in part by the United States (excluding any amount payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569/d"},"text":"section 5569(d) of this title","children":[],"tail":") in connection with such disability or death, except that nothing in this subsection shall result in the reduction of any amount below zero."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e2e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by the President under subsection (b) shall be conclusive and shall not be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e2e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation under this section may include payment (whether by advancement or reimbursement) for any medical or health expenses relating to the death or disability involved to the extent that such expenses are not covered under subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569"},"text":"section 5569 of this title","children":[],"tail":" (other than because of paragraph (2) of such subsection)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e2e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies with respect to any disability or death resulting from an injury which occurs after ","children":[{"tag":"date","attrib":{"date":"1981-01-21"},"text":"January 21, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e2ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5570/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any benefit or payment pursuant to this section shall be paid out of funds available for salaries and expenses of the relevant agency of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb878e2eb-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s803/a"},"text":"Pub. L. 99–399, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/882"},"text":"100 Stat. 882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb878e2ec-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb878e2ed-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb878e2ee-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Civilian Service Recognition","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/73"},"text":"Pub. L. 112–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-20"},"text":"Dec. 20, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/784"},"text":"125 Stat. 784","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/73"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Civilian Service Recognition Act of 2011’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PRESENTATION OF UNITED STATES FLAG ON BEHALF OF FEDERAL CIVILIAN EMPLOYEES WHO DIE OF INJURIES INCURRED IN CONNECTION WITH THEIR EMPLOYMENT.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of a request under subsection (b), the head of an executive agency may give a flag of the United States for an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was an employee of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies of injuries incurred in connection with such individual’s employment with the Federal Government, suffered as a result of a criminal act, an act of terrorism, a natural disaster, or other circumstance as determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Flag","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency may furnish a flag for a deceased employee described in subsection (a) upon the request of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee’s widow or widower, child, sibling, or parent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no request is received from an individual described in paragraph (1), an individual other than the next of kin as determined by the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classified Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may disclose information necessary to show that a deceased individual is an employee described in subsection (a) to the extent that such information is not classified and to the extent that such disclosure does not endanger the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Notification of Flag Benefit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency shall provide appropriate notice to employees of the agency of the flag benefit provided for under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management, in coordination with the Secretary of Defense and the Secretary of Homeland Security, may prescribe regulations to implement this section. Any such regulations shall provide for the head of an executive agency to consider the conditions and circumstances surrounding the death of an employee and nature of the service of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘employee’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":", United States Code, and includes an officer or employee of the United States Postal Service or of the Postal Regulatory Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘executive agency’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", United States Code, and includes the United States Postal Service and the Postal Regulatory Commission.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb878e2ef-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb878e2f0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of the President under this section delegated to the Secretary of State to be exercised in consultation with the Secretary of Labor, see Ex. Ord. No. 12598, ","children":[{"tag":"date","attrib":{"date":"1987-06-17"},"text":"June 17, 1987","children":[],"tail":", 52 F.R. 23421, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569"},"text":"section 5569 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
