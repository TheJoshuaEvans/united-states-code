{"tag":"section","attrib":{"id":"idb8873b1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729"},"text":null,"children":[{"tag":"num","attrib":{"value":"5729"},"text":"§ 5729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation expenses; prior return of family","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":", an agency shall pay from its appropriations, not more than once before the return to the United States of an employee whose post of duty is outside the continental United States, the expenses of transporting his immediate family and of shipping his household goods and personal effects from his post of duty to his actual place of residence when—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he has acquired eligibility for that transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public interest requires the return of the immediate family for compelling personal reasons of a humanitarian or compassionate nature, such as may involve physical or mental health, death of a member of the immediate family, or obligation imposed by authority or circumstances over which the individual has no control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b1f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":", an agency shall reimburse from its appropriations an employee whose post of duty is outside the continental United States for the proper transportation expenses of returning his immediate family and his household goods and personal effects to the United States, when—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their return was made at the expense of the employee before his return and for other than reasons of public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he acquires eligibility for those transportation expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5729/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to appropriations for the Foreign Service of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8873b23-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/505"},"text":"80 Stat. 505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1723/b/1"},"text":"Pub. L. 104–201, div. A, title XVII, § 1723(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2759"},"text":"110 Stat. 2759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/9"},"text":"Pub. L. 105–264, § 6(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2356"},"text":"112 Stat. 2356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b24-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8873b25-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8873b26-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"