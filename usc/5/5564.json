{"tag":"section","attrib":{"id":"idb876984e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564"},"text":null,"children":[{"tag":"num","attrib":{"value":"5564"},"text":"§ 5564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and transportation; dependents; household and personal effects; motor vehicles; sale of bulky items; claims for proceeds; appropriation chargeable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb876984f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, “household and personal effects” and “household effects” may include, in addition to other authorized weight allowances, one privately owned motor vehicle which may be shipped at United States expense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8769850-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Transportation (including packing, crating, draying, temporarily storing, and unpacking of household and personal effects) may be provided for the dependents and household and personal effects of an employee in active service (without regard to pay grade) who is officially reported as dead, injured, or absent for more than 29 days in a status listed in section 5561(5) (A)–(E) of this title to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8769851-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official residence of record for the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8769852-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residence of his dependent, next of kin, or other person entitled to the effects under regulations prescribed by the head of the agency concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8769853-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another location determined in advance or later approved by the head of the agency concerned or his designee on request of the employee (if injured) or his dependent, next of kin, or other person described in paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8769854-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an employee described in subsection (b) of this section is in an injured status, transportation of dependents and household and personal effects may be provided under this section only when prolonged hospitalization or treatment is anticipated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8769855-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation on request of a dependent may be authorized under this section only when there is a reasonable relationship between the circumstances of the dependent and the destination requested.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8769856-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Instead of providing transportation for dependents under this section, when the travel has been completed the head of the agency concerned may authorize—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8769857-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement for the commercial cost of the transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8769858-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monetary allowance, instead of transportation, as authorized by statute for the whole or that part of the travel for which transportation in kind was not furnished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8769859-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the agency concerned may store the household and personal effects of an employee described in subsection (b) of this section until proper disposition can be made. The cost of the storage and transportation (including packing, crating, draying, temporarily storing, and unpacking) of household and personal effects shall be charged against appropriations currently available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb876985a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the head of the agency concerned determines that an emergency exists and that a sale would be in the best interests of the United States, he may provide for the public or private sale of motor vehicles and other bulky items of the household and personal effects of an employee described in subsection (b) of this section. Before a sale, and if practicable, a reasonable effort shall be made to determine the desires of interested persons. The net proceeds from the sale shall be sent to the owner or other person entitled thereto under regulations prescribed by the head of the agency concerned. If there is no owner or other person entitled thereto, or if the owner or other person or their addresses are not ascertained within 1 year from the date of sale, the net proceeds may be covered into the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb876985b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim for net proceeds covered into the Treasury under subsection (g) of this section may be filed with the Administrator of General Services by the owner, his heir or next of kin, or his legal representative at any time before the end of 5 years from the date the proceeds are covered into the Treasury. When a claim is filed, the Administrator of General Services shall allow or disallow it. A claim that is allowed shall be paid from the appropriation for refunding money erroneously received and covered. If a claim is not filed before the end of 5 years from the date the proceeds are covered into the Treasury, it is barred from being acted on by the Administrator of General Services or the courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb876985c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not amend or repeal—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb876985d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2575, 2733, 4712, 6522, or 9712 of title 10;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb876985e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 507 ","children":[{"tag":"ref","attrib":{"idref":"fn002111"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb876985f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5564/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8769860-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"