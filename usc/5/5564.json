,"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 29, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/217/s1/d"},"text":"Pub. L. 85–217, § 1(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/492"},"text":"71 Stat. 492","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/8"},"text":"Pub. L. 88–428, § 1(8)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1014 (as applicable to § 1012 (1st sentence)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s14"},"text":"Mar. 7, 1942, ch. 166, § 14","children":[],"tail":" (as applicable to § 12 (1st sentence)), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/147"},"text":"56 Stat. 147","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/e"},"text":"Apr. 4, 1953, ch. 17, § 1(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (12th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (13th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (11th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (9th and 10th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (2d–4th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (5th–7th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(i)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1012 (8th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only that portion of the source law which is applicable to civilian officers and employees and their dependents is codified in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Beginning ","children":[{"tag":"date","attrib":{"date":"1950-06-25"},"text":"June 25, 1950","children":[],"tail":", and” are omitted as executed. The words “not to exceed” are omitted as unnecessary. The words “outside the United States, or in Alaska or Hawaii” are substituted for “outside the continental limits of the United States or in Alaska”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Transportation . . . may be provided” are substituted for “may be moved”. The words “an employee . . . for more than 28 days in a status listed in section 5561(5)(A)–(E) of this title” are substituted for “person . . . for a period of thirty days or more in any status listed in section 2 of this Act” for clarity and to conform to the definitions in section 5561(2) and (5). In paragraph (1), the words “the employee” are substituted for “any such person”. In paragraph (3), the words “head of the agency concerned or his designee” are substituted for “head of the department concerned or by such person as he may designate”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “employee” is substituted for “person”. The words “transportation . . . may be provided under this section only when” are substituted for “movement . . . provided for herein may be authorized only in cases where”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “on request of a dependent may be provided under . . . only” are substituted for “No . . . shall be authorized pursuant to . . . upon application by dependents unless”. The words “condition and” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), the words “reimbursement for” are substituted for “the payment in money of amounts equal to”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the word “employee” is substituted for “person”. The words “such time as” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “United States” are substituted for “Government” to conform to the style of this title. The word “employee” is substituted for “person”. The words “under . . . prescribed” are substituted for “in accordance with . . . issued”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the words “under subsection (g) of this section” are substituted for “under authority of this section”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (i), the words “the provisions of” are omitted as surplusage. Paragraph (3) is substituted for “the Federal Tort Claims Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/60/842-847"},"text":"60 Stat. 842–847","children":[],"tail":"), as amended;” to reflect the correct citation of that Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8769864-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8769865-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\