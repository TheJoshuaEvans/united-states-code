{"tag":"section","attrib":{"id":"idb819859c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3361"},"text":null,"children":[{"tag":"num","attrib":{"value":"3361"},"text":"§ 3361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion; competitive service; examination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb819859d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":" In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may be promoted in the competitive service only if he has passed an examination or is specifically excepted from examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3302"},"text":"section 3302 of this title","children":[],"tail":". This section does not take from the President any authority conferred by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3301"},"text":"section 3301 of this title","children":[],"tail":" that is consistent with the provisions of this title governing the competitive service."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb819859e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DOD Promotions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Promotions in the competitive service within the Department of Defense may be made based on demonstrated skills and qualifications without regard to minimum time-in-grade requirements, subject to agency policies and applicable merit system principles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attr