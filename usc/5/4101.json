{"tag":"section","attrib":{"id":"idb8256c67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101"},"text":"§ 4101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8256c68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency”, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4102"},"text":"section 4102 of this title","children":[],"tail":", means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8256c69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent establishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government corporation subject to chapter 91 of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Publishing Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee”, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4102"},"text":"section 4102 of this title","children":[],"tail":", means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8256c70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed in or under an agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commissioned officer of the Environmental Science Services Administration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government” means the Government of the United States and the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “training” means the process of providing for and making available to an employee, and placing or enrolling the employee in, a planned, prepared, and coordinated program, course, curriculum, subject, system, or routine of instruction or education, in scientific, professional, technical, mechanical, trade, clerical, fiscal, administrative, or other fields which will improve individual and organizational performance and assist in achieving the agency’s mission and performance goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government facility” means property owned or substantially controlled by the Government and the services of any civilian and military personnel of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “non-Government facility” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8256c76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of a State or of a territory or possession of the United States including the Commonwealth of Puerto Rico, and an interstate governmental organization, or a unit, subdivision, or instrumentality of any of the foregoing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign government or international organization, or instrumentality of either, which is designated by the President as eligible to provide training under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a medical, scientific, technical, educational, research, or professional institution, foundation, or organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business, commercial, or industrial firm, corporation, partnership, proprietorship, or other organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals other than civilian or military personnel of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4101/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services and property of any of the foregoing furnishing the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8256c7c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/432"},"text":"80 Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s224/a"},"text":"Pub. L. 90–206, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/642"},"text":"81 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/a/8"},"text":"Pub. L. 97–258, § 3(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/1"},"text":"Pub. L. 103–226, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/111"},"text":"108 Stat. 111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8256c7d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8256c7e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8256c7f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\