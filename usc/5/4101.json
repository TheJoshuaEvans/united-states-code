:[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of “Commission” in former section 2302(4) is omitted as unnecessary as the title “Civil Service Commission” is fully set out the first time it is used in each section of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8256c80-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8256c81-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" substituted “fields which will improve individual and organizational performance and assist in achieving the agency’s mission and performance goals;” for “fields which are or will be directly related to the performance by the employee of official duties for the Government, in order to increase the knowledge, proficiency, ability, skill, and qualifications of the employee in the performance of official duties;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “chapter 91” for “sections 846–852 or 856–859”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":" substituted “Environmental Science Services Ad