{"tag":"section","attrib":{"id":"idb9309a79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001"},"text":null,"children":[{"tag":"num","attrib":{"value":"11001"},"text":"§ 11001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced personnel security programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9309a7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enhanced Personnel Security Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of National Intelligence shall direct each agency to implement a program to provide enhanced security review of covered individuals—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309a7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9309a7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 5 years after the date of the enactment of the Intelligence Authorization Act for Fiscal Year 2016; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the backlog of overdue periodic reinvestigations of covered individuals is eliminated, as determined by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9309a7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensiveness.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309a80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sources of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The enhanced personnel security program of an agency shall integrate relevant and appropriate information from various sources, including government, publicly available, and commercial data sources, consumer reporting agencies, social media, and such other sources as determined by the Director of National Intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information obtained and integrated from sources described in paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9309a82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to any criminal or civil legal proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial information relating to the covered individual, including the credit worthiness of the covered individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly available information, whether electronic, printed, or other form, including relevant security or counterintelligence information about the covered individual or information that may suggest ill intent, vulnerability to blackmail, compulsive behavior, allegiance to another country, change in ideology, or that the covered individual lacks good judgment, reliability, or trustworthiness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data maintained on any terrorist or criminal watch list maintained by any agency, State or local government, or international organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9309a86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reviews of Covered Individuals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309a87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reviews.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9309a88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The enhanced personnel security program of an agency shall require that, not less than 2 times every 5 years, the head of the agency shall conduct or request the conduct of automated record checks and checks of information from sources under subsection (b) to ensure the continued eligibility of each covered individual to access classified information and hold a sensitive position unless more frequent reviews of automated record checks and checks of information from sources under subsection (b) are conducted on the covered individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a89-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except for a covered individual who is subject to more frequent reviews to ensure the continued eligibility of the covered individual to access classified information and hold a sensitive position, the reviews under subparagraph (A) shall consist of random or aperiodic checks of covered individuals, such that each covered individual is subject to at least 2 reviews during the 5-year period beginning on the date on which the agency implements the enhanced personnel security program of an agency, and during each 5-year period thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A review of the information relating to the continued eligibility of a covered individual to access classified information and hold a sensitive position under subparagraph (A) may not be conducted until after the end of the 120-day period beginning on the date the covered individual receives the notification required under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a8b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Results","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency shall take appropriate action if a review under paragraph (1) finds relevant information that may affect the continued eligibility of a covered individual to access classified information and hold a sensitive position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a8c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information for covered individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency shall ensure that each covered individual is adequately advised of the types of relevant security or counterintelligence information the covered individual is required to report to the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed to affect the authority of an agency to determine the appropriate weight to be given to information relating to a covered individual in evaluating the continued eligibility of the covered individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of the president","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed as limiting the authority of the President to direct or perpetuate periodic reinvestigations of a more comprehensive nature or to delegate the authority to direct or perpetuate such reinvestigations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on other reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Reviews conducted under paragraph (1) are in addition to investigations and reinvestigations conducted pursuant to section 3001 of the Intelligence Reform and Terrorism Prevention Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341"},"text":"50 U.S.C. 3341","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9309a90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309a91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” has the meaning given that term in section 3001 of the Intelligence Reform and Terrorism Prevention Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341"},"text":"50 U.S.C. 3341","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “consumer reporting agency” has the meaning given that term in section 603 of the Fair Credit Reporting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681a"},"text":"15 U.S.C. 1681a","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered individual” means an individual employed by an agency or a contractor of an agency who has been determined eligible for access to classified information or eligible to hold a sensitive position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s11001/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “enhanced personnel security program” means a program implemented by an agency at the direction of the Director of National Intelligence under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9309a95-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tIII/s306/a/1"},"text":"Pub. L. 114–113, div. M, title III, § 306(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2914"},"text":"129 Stat. 2914","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6711"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2225"},"text":"133 Stat. 2225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dG/tIII/s7327/b"},"text":"Pub. L. 118–31, div. G, title III, § 7327(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1044"},"text":"137 Stat. 1044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9309a96-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9309a97-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9309a98-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Intelligence Authorization Act for Fiscal Year 2016, referred to in subsec. (a)(2)(A), is the date of enactment of div. M of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9309a99-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7327/b/1"},"text":"Pub. L. 118–31, § 7327(b)(1)","children":[],"tail":", redesignated subsec. (e) as (d) and struck out former subsec. (d) which provided for review by the Inspector General of each agency of the enhanced personnel security program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7327/b/2"},"text":"Pub. L. 118–31, § 7327(b)(2)","children":[],"tail":", inserted “and” after the semicolon at end of par. (3) and substituted a period for “; and” at end of par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s7327/b/1/B"},"text":"Pub. L. 118–31, § 7327(b)(1)(B)","children":[],"tail":", redesignated subsec. (e) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “Review” for “Audit” in heading and “review” for “audit” in text of pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9309a9a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9309a9b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Resolution of Backlog of Overdue Periodic Reinvestigations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tIII/s306/b"},"text":"Pub. L. 114–113, div. M, title III, § 306(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2916"},"text":"129 Stat. 2916","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dM/tIII/s306/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of National Intelligence shall develop and implement a plan to eliminate the backlog of overdue periodic reinvestigations of covered individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use a risk-based approach to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify high-risk populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize reinvestigations that are due or overdue to be conducted; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use random automated record checks of covered individuals that shall include all covered individuals in the pool of individuals subject to a one-time check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘covered individual’ means an individual who has been determined eligible for access to classified information or eligible to hold a sensitive position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term ‘periodic reinvestigations’ has the meaning given such term in section 3001(a)(7) of the Intelligence Reform and Terrorism Prevention Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341/a/7"},"text":"50 U.S.C. 3341(a)(7)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
