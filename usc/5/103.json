{"tag":"section","attrib":{"id":"idb7835f93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government corporation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7835f94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government corporation” means a corporation owned or controlled by the Government of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7835f95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government controlled corporation” does not include a corporation owned by the Government of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7835f96-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7835f97-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7835f98-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The section is supplied to avoid the necessity for defining “Government corporation” and “Government controlled corporation” each time it is used in this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
