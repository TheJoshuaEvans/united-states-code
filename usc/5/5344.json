{"tag":"section","attrib":{"id":"idb859e99d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5344"},"text":null,"children":[{"tag":"num","attrib":{"value":"5344"},"text":"§ 5344.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of wage increase; retroactive pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb859e99e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5344/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each increase in rates of basic pay granted, pursuant to a wage survey, to prevailing rate employees is effective not later than the first day of the first pay period which begins on or after the 45th day, excluding Saturdays and Sundays, following the date the wage survey is ordered to be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb859e99f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5344/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Retroactive pay is payable by reason of an increase in rates of basic pay referred to in subsection (a) of this section only when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb859e9a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5344/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is in the service of the Government of the United States, including service in the armed forces, or the government of the District of Columbia on the date of the issuance of the order granting the increase; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb859e9a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5344/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual retired or died during the period beginning on the effective date of the increase and ending on the date of issuance of the order granting the increase, and only for services performed during that period.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For the purpose of this subsection, service in the armed forces includes the period provided by statute for the mandatory restoration of the individual to a position in or under the Government of the United States or the government of the District of Columbia after he is relieved from training and service in the armed forces or discharged from hospitalization following that training and service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb859e9a2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/392/s1/a"},"text":"Pub. L. 92–392, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-19"},"text":"Aug. 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/568"},"text":"86 Stat. 568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb859e9a3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb859e9a4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb859e9a5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising subsec. (a) of this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/471"},"text":"80 Stat. 471","children":[],"tail":" (formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5343"},"text":"section 5343 of this title","children":[],"tail":") prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/92/392/s1/a"},"text":"section 1(a) of Pub. L. 92–392","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb859e9a6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb859e9a7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first applicable pay period beginning on or after 90th day after ","children":[{"tag":"date","attrib":{"date":"1972-08-19"},"text":"Aug. 19, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/392/s15/a"},"text":"section 15(a) of Pub. L. 92–392","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5341"},"text":"section 5341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
