{"tag":"section","attrib":{"id":"idb884f0c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d"},"text":null,"children":[{"tag":"num","attrib":{"value":"5724d"},"text":"§ 5724d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation and moving expenses for immediate family of certain deceased Federal employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb884f0c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by the President, the head of the agency concerned (or a designee) may determine that a covered employee died as a result of personal injury sustained while in the performance of the employee’s duty and authorize or approve the payment by the agency, from Government funds, of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb884f0c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any qualified expense of the immediate family of the covered employee attributable to a change in their place of residence, if the place where the immediate family will reside following the death of the employee is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb884f0ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" different from the place where the immediate family resided at the time of the employee’s death; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb884f0cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb884f0cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any expense of preparing and transporting the remains of the deceased to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb884f0cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the place where the immediate family will reside following the death of the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb884f0ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other place appropriate for interment as is determined by the agency head (or designee).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb884f0cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Duplicate Payment of Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No expenses may be paid under this section if those expenses are paid from Government funds under section 5742 or any other authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb884f0d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb884f0d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb884f0d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer, as defined in section 5541;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb884f0d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee in or under the Federal Bureau of Investigation who is not described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb884f0d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customs and border protection officer, as defined in section 8331(31); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb884f0d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any nuclear materials courier, as defined in section 8331(27); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb884f0d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5724d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified expense”, as used with respect to an immediate family changing its place of residence, means the transportation expenses of the immediate family, the expenses of moving (including transporting, packing, crating, temporarily storing, draying, and unpacking) the household goods and personal effects of such immediate family, not in excess of 18,000 pounds net weight, and, when authorized or approved by the agency head (or designee), the transportation of 1 privately owned motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb884f0d7-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/178/s2/a"},"text":"Pub. L. 111–178, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-06-09"},"text":"June 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1262"},"text":"124 Stat. 1262","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXI/s3144"},"text":"Pub. L. 116–283, div. C, title XXXI, § 3144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4387"},"text":"134 Stat. 4387","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb884f0d8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb884f0d9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb884f0da-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subpar. (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb884f0db-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb884f0dc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"No Relevance as to Compensation Claims","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/178/s2/b"},"text":"Pub. L. 111–178, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-06-09"},"text":"June 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1263"},"text":"124 Stat. 1263","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/178/s2/b"},"text":"“No determination made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724d"},"text":"section 5724d of title 5","children":[],"tail":", United States Code, shall be deemed relevant to or be considered in connection with any claim for compensation under chapter 81 of that title or under any other law under which compensation may be provided on account of death or personal injury, nor shall any determination made with respect to any such claim be deemed relevant to or be considered in connection with any request for payment of expenses under such section 5724d.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb884f0dd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb884f0de-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation Under Section 2(a) of the Special Agent Samuel Hicks Families of Fallen Heroes Act","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2011-09-12"},"text":"Sept. 12, 2011","children":[],"tail":", 76 F.R. 57621, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Administrator of General Services","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you the function conferred upon the President by section 2(a) of the Special Agent Samuel Hicks Families of Fallen Heroes Act ("},{"tag":"ref","attrib":{"href":"/us/pl/111/178"},"text":"Public Law 111–178","children":[],"tail":") to prescribe the applicable regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
