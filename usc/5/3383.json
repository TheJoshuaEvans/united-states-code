/s10"},"text":"section 10 of Pub. L. 92–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3381"},"text":"section 3381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
