s 7th sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1883-01-16/ch27/s3"},"text":"Jan. 16, 1883, ch. 27, § 3","children":[],"tail":" (less last 24 words of 6th sentence, and less 7th sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/22/404"},"text":"22 Stat. 404","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[Uncodified].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1949 Reorg. Plan No. 5, § 4, eff. ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 19, 1949","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/1069"},"text":"63 Stat. 1069","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the District of Columbia” are substituted for “Washington”. The words “at least three individuals in the service of the United States” are substituted for a “a suitable number of persons, not less than three, in the official service of the United States”. So much of the first three sentences of former section 635 as related to the offices of the Chief Examiner and the Secretary are omitted because the offices were abolished by 1949 Reorg. Plan No. 5, § 4. So much of the first sentence as imposed a duty on the Chief Examiner, under the Commission’s direction, to act with the examining boards to secure accuracy, uniformity, and justice in all their proceedings is restated in section 1104(a)(1). The fourth sentence of former section 635, authorizing the Commission to employ a stenographer and a messenger, is omitted as obsolete. The remainder is rewritten for clarity. The text of 1949 Reorg. Plan No. 5, § 4, is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Chairman, United States Civil Service Commission” are substituted for “chief examiner” on authority of 1949 Reorg. Plan No. 5, § 2(a)(2). The words “at all times” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e52e44-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7e52e45-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Administrative procedure” for “Boards of examiners” in section catchline, and in text provisions relating to administrative procedure applicable to administration of this chapter for provisions relating to boards of examiners for the United States Civil Service Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7e52e46-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Su