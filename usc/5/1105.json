{"tag":"section","attrib":{"id":"idb7e52e3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1105"},"text":null,"children":[{"tag":"num","attrib":{"value":"1105"},"text":"§ 1105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1103/b"},"text":"section 1103(b) of this title","children":[],"tail":", in the exercise of the functions assigned under this chapter, the Director shall be subject to subsections (b), (c), and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of this title","children":[],"tail":", notwithstanding subsection (a) of such section 553."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7e52e40-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/400"},"text":"80 Stat. 400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s201/a"},"text":"Pub. L. 95–454, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1121"},"text":"92 Stat. 1121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e52e41-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7e52e42-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7e52e43-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag"