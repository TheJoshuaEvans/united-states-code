{"tag":"section","attrib":{"id":"idb7b7dc48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553"},"text":null,"children":[{"tag":"num","attrib":{"value":"553"},"text":"§ 553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule making","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7b7dc49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies, according to the provisions thereof, except to the extent that there is involved—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military or foreign affairs function of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter relating to agency management or personnel or to public property, loans, grants, benefits, or contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" General notice of proposed rule making shall be published in the Federal Register, unless persons subject thereto are named and either personally served or otherwise have actual notice thereof in accordance with law. The notice shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the time, place, and nature of public rule making proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reference to the legal authority under which the rule is proposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either the terms or substance of the proposed rule or a description of the subjects and issues involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Internet address of a summary of not more than 100 words in length of the proposed rule, in plain language, that shall be posted on the Internet website under section 206(d) of the E-Government Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" note) (commonly known as regulations.gov)."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Except when notice or hearing is required by statute, this subsection does not apply—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b7dc51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to interpretative rules, general statements of policy, or rules of agency organization, procedure, or practice; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7b7dc52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/b/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the agency for good cause finds (and incorporates the finding and a brief statement of reasons therefor in the rules issued) that notice and public procedure thereon are impracticable, unnecessary, or contrary to the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After notice required by this section, the agency shall give interested persons an opportunity to participate in the rule making through submission of written data, views, or arguments with or without opportunity for oral presentation. After consideration of the relevant matter presented, the agency shall incorporate in the rules adopted a concise general statement of their basis and purpose. When rules are required by statute to be made on the record after opportunity for an agency hearing, sections 556 and 557 of this title apply instead of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The required publication or service of a substantive rule shall be made not less than 30 days before its effective date, except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7b7dc55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantive rule which grants or recognizes an exemption or relieves a restriction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpretative rules and statements of policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7b7dc57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as otherwise provided by the agency for good cause found and published with the rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7b7dc58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s553/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency shall give an interested person the right to petition for the issuance, amendment, or repeal of a rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7b7dc59-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/383"},"text":"80 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/9/s2"},"text":"Pub. L. 118–9, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-07-25"},"text":"July 25, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/55"},"text":"137 Stat. 55","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7b7dc5a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7b7dc5b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7b7dc5c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s1003"},"text":"5 U.S.C. 1003","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-06-11/ch324/s4"},"text":"June 11, 1946, ch. 324, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/238"},"text":"60 Stat. 238","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “or naval” are omitted as included in “military”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “when” is substituted for “in any situation in which”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “for oral presentation” are substituted for “to present the same orally in any manner”. The words “sections 556 and 557 of this title apply instead of this subsection” are substituted for “the requirements of sections 1006 and 1007 of this title shall apply in place of the provisions of this subsection”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7b7dc5d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7b7dc5e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 206(d) of the E-Government Act of 2002, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/s206/d"},"text":"section 206(d) of Pub. L. 107–347","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7b7dc5f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 553 of former Title 5, Executive Departments and Government Officers and Employees, was transferred to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2245"},"text":"section 2245 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7b7dc60-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/9"},"text":"Pub. L. 118–9","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb7b7dc61-5e84-11f1-a692-ec26948f6fea"},"tex