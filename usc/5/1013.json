ate":"1981-03-17"},"text":"Mar. 17, 1981","children":[],"tail":", 46 F.R. 17751; Ex. Ord. No. 12305, "},{"tag":"date","attrib":{"date":"1981-05-05"},"text":"May 5, 1981","children":[],"tail":", 46 F.R. 25421; Ex. Ord. No. 12336, "},{"tag":"date","attrib":{"date":"1981-12-21"},"text":"Dec. 21, 1981","children":[],"tail":", 46 F.R. 62239, superseded by Ex. Ord. No. 12399, "},{"tag":"date","attrib":{"date":"1982-12-31"},"text":"Dec. 31, 1982","children":[],"tail":", 48 F.R. 379."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12110, ","children":[{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1069, superseded by Ex. Ord. No. 12258, "},{"tag":"date","attrib":{"date":"1980-12-31"},"text":"Dec. 31, 1980","children":[],"tail":", 46 F.R. 1251."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11948, ","children":[{"tag":"date","attrib":{"date":"1976-12-20"},"text":"Dec. 20, 1976","children":[],"tail":", 41 F.R. 55705, as amended by Ex. Ord. No. 12007, "},{"tag":"date","attrib":{"date":"1977-08-22"},"text":"Aug. 22, 1977","children":[],"tail":", 42 F.R. 42839; Ex. Ord. No. 12029, "},{"tag":"date","attrib":{"date":"1977-12-14"},"text":"Dec. 14, 1977","children":[],"tail":", 42 F.R. 63631, superseded by Ex. Ord. No. 12110, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1069."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11827, ","children":[{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", 40 F.R. 1217, as amended by Ex. Ord. No. 11915, "},{"tag":"date","attrib":{"date":"1976-05-10"},"text":"May 10, 1976","children":[],"tail":", 41 F.R. 19195, superseded by Ex. Ord. No. 11948, "},{"tag":"date","attrib":{"date":"1976-12-20"},"text":"Dec. 20, 1976","children":[],"tail":", 41 F.R. 55705."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb7e04c8d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12838. Termination and Limitation of Federal Advisory Committees","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12838, ","children":[{"tag":"date","attrib":{"date":"1993-02-10"},"text":"Feb. 10, 1993","children":[],"tail":", 58 F.R. 8207, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including the Federal Advisory Committee Act (“FACA”), as amended ([former] 5 U.S.C. App.) [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001"},"text":"5 U.S.C. 1001","children":[],"tail":" et seq.], it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. Each executive department and agency shall terminate not less than one-third of the advisory committees subject to FACA (and not required by statute) that are sponsored by the department or agency by no later than the end of fiscal year 1993."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. Within 90 days, the head of each executive department and agency shall submit to the Director of the Office of Management and Budget, for each advisory committee subject to FACA sponsored by that department or agency: (a) a detailed justification for the continued existence, or a brief description in support of the termination, of any advisory committee not required by statute; and (b) a detailed recommendation for submission to the Congress to continue or to terminate any advisory committee required by statute. The Administrator of General Services shall prepare such justifications and recommendations for each advisory committee subject to FACA and not sponsored by a department or agency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. Effective immediately, executive departments and agencies shall not create or sponsor a new advisory committee subject to FACA unless the committee is required by statute or the agency head (a) finds that compelling considerations necessitate creation of such a committee, and (b) receives the approval of the Director of the Office of Management and Budget. Such approval shall be granted only sparingly and only if compelled by considerations of national security, health or safety, or similar national interests. These requirements shall apply in addition to the notice and other approval requirements of FACA."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. The Director of the Office of Management and Budget shall issue detailed instructions regarding the implementation of this order, including exemptions necessary for the delivery of essential services and compliance with applicable law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 5. All independent regulatory commissions and agencies are requested to comply with the provisions of this order."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7e04c8e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Certain Federal Advisory Committees","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions providing for the termination of certain Federal advisory committees are contained in the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12379, ","children":[{"tag":"date","attrib":{"date":"1982-08-17"},"text":"Aug. 17, 1982","children":[],"tail":", 47 F.R. 36099."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12305, ","children":[{"tag":"date","attrib":{"date":"1981-05-05"},"text":"May 5, 1981","children":[],"tail":", 46 F.R. 25421."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12029, ","children":[{"tag":"date","attrib":{"date":"1977-12-14"},"text":"Dec. 14, 1977","children":[],"tail":", 42 F.R. 63631."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12007, ","children":[{"tag":"date","attrib":{"date":"1977-08-22"},"text":"Aug. 22, 1977","children":[],"tail":", 42 F.R. 42839."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
