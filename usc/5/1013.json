{"tag":"section","attrib":{"id":"idb7e04c7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013"},"text":null,"children":[{"tag":"num","attrib":{"value":"1013"},"text":"§ 1013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of advisory committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7e04c7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e04c7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory committees in existence on ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"january 5, 1973","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each advisory committee that is in existence on ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"January 5, 1973","children":[],"tail":", shall terminate not later than the expiration of the 2-year period following that date unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e04c7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an advisory committee established by the President or an officer of the Federal Government, such advisory committee is renewed by the President or that officer by appropriate action prior to the expiration of such 2-year period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e04c7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an advisory committee established by an Act of Congress, its duration is otherwise provided for by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"january 5, 1973","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each advisory committee established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"January 5, 1973","children":[],"tail":", shall terminate not later than the expiration of the 2-year period beginning on the date of its establishment unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e04c80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an advisory committee established by the President or an officer of the Federal Government ","children":[{"tag":"ref","attrib":{"idref":"fn002031"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002031"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" such advisory committee is renewed by the President or such officer by appropriate action prior to the end of such period; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e04c81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an advisory committee established by an Act of Congress, its duration is otherwise provided for by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e04c82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e04c83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Upon renewal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the renewal of an advisory committee, the advisory committee shall file a charter in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1008/c"},"text":"section 1008(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Upon expiration of successive 2-year periods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An advisory committee established by an Act of Congress shall file a charter in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1008/c"},"text":"section 1008(c) of this title","children":[],"tail":" upon the expiration of each successive 2-year period following the date of enactment of the Act establishing the advisory committee."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e04c85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on action prior to filing charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An advisory committee required to file a charter under this subsection shall not take any action (other than preparation and filing of the charter) prior to the date on which the charter is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e04c86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1013/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Successive Two-Year Periods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An advisory committee that is renewed by the President or an officer of the Federal Government may be continued only for successive 2-year periods by appropriate action taken by the President or the officer prior to the date on which the advisory committee would otherwise terminate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e04c87-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4204"},"text":"136 Stat. 4204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e04c88-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7e04c89-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7e04c8a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1013","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (FACA § 14)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/463/s14"},"text":"Pub. L. 92–463, § 14","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/776"},"text":"86 Stat. 776","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1) (matter before subparagraph (A)), the date “","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"January 5, 1973","children":[],"tail":"” is substituted for “the effective date of this Act”, and in subsection (a)(2) (matter before subparagraph (A)), the date “"},{"tag":"date","attrib":{"date":"1973-01-05"},"text":"January 5, 1973","children":[],"tail":"” is substituted for “such effective date”, for clarity. In accordance with section 16 (formerly section 15) of the Federal Advisory Committee Act ("},{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Public Law 92–463","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/776"},"text":"86 Stat. 776","children":[],"tail":"), which provides “this Act shall become effective upon the expiration of ninety days following the date of enactment”, the effective date of the Act is "},{"tag":"date","attrib":{"date":"1973-01-05"},"text":"January 5, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb7e04c8b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7e04c8c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Continuance of Certain Federal Advisory Committees","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 14354, ","children":[{"tag":"date","attrib":{"date":"2025-09-29"},"text":"Sept. 29, 2025","children":[],"tail":", 90 F.R. 48145, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, and consistent with chapter 10 of title 5, United States Code (commonly known as the Federal Advisory Committee Act), it is hereby ordered:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. Each advisory committee listed below is continued until "},{"tag":"date","attrib":{"date":"2027-09-30"},"text":"September 30, 2027","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) Committee for the Preservation of the White House; Executive Order 11145, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s110"},"text":"3 U.S.C. 110","children":[],"tail":" note](Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) President’s Commission on White House Fellowships; Executive Order 11183, as amended (Office of Personnel Management).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) President’s National Security Telecommunications Advisory Committee; Executive Order 12382, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s901"},"text":"47 U.S.C. 901","children":[],"tail":" note] (Department of Homeland Security)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) National Industrial Security Program Policy Advisory Committee; Executive Order 12829, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note] (National Archives and Records Administration)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e) Trade and Environment Policy Advisory Committee; Executive Order 12905 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155"},"text":"19 U.S.C. 2155","children":[],"tail":" note] (Office of the United States Trade Representative)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(f) Presidential Advisory Council on HIV/AIDS; Executive Order 12963, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–1"},"text":"42 U.S.C. 300cc–1","children":[],"tail":" note] (Department of Health and Human Services)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(g) President’s Committee for People with Intellectual Disabilities; Executive Order 12994, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"42 U.S.C. 15001","children":[],"tail":" note] (Department of Health and Human Services)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(h) Advisory Board on Radiation and Worker Health; Executive Order 13179 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7384"},"text":"42 U.S.C. 7384","children":[],"tail":" note] (Department of Health and Human Services)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) President’s Council on Sports, Fitness, and Nutrition; Executive Order 13265, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300u"},"text":"42 U.S.C. 300u","children":[],"tail":" note] (Department of Health and Human Services)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(j) Interagency Task Force on Veterans Small Business Development; Executive Order 13540 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s657b"},"text":"15 U.S.C. 657b","children":[],"tail":" note] (Small Business Administration)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(k) State, Local, Tribal, and Private Sector (SLTPS) Policy Advisory Committee; Executive Order 13549 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note] (National Archives and Records Administration)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(l) Bears Ears National Monument Advisory Committee; Proclamation 9558 of ","children":[{"tag":"date","attrib":{"date":"2016-12-28"},"text":"December 28, 2016","children":[],"tail":", as amended [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(m) Gold Butte National Monument Advisory Committee; Proclamation 9559 of ","children":[{"tag":"date","attrib":{"date":"2016-12-28"},"text":"December 28, 2016","children":[],"tail":" [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(n) Avi Kwa Ame National Monument Advisory Committee; Proclamation 10533 of ","children":[{"tag":"date","attrib":{"date":"2023-03-21"},"text":"March 21, 2023","children":[],"tail":" [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(o) Baaj Nwaavjo I’tah Kukveni-Ancestral Footprints of the Grand Canyon National Monument Advisory Committee; Proclamation 10606 of ","children":[{"tag":"date","attrib":{"date":"2023-08-08"},"text":"August 8, 2023","children":[],"tail":" [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(p) Religious Liberty Commission; Executive Order 14291 [90 F.R. 19417] (Department of Justice).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(q) Chuckwalla National Monument Advisory Committee; Proclamation 10881 of ","children":[{"tag":"date","attrib":{"date":"2025-01-14"},"text":"January 14, 2025","children":[],"tail":" [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(r) Sáttítla Highlands National Monument Advisory Committee; Proclamation 10882 of ","children":[{"tag":"date","attrib":{"date":"2025-01-14"},"text":"January 14, 2025","children":[],"tail":" [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of Agriculture)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(s) Good Neighbor Environmental Board; Executive Order 12916, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3473"},"text":"19 U.S.C. 3473","children":[],"tail":" note] (Environmental Protection Agency)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(t) President’s Board of Advisors on Historically Black Colleges and Universities; Executive Order 14283 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1060"},"text":"20 U.S.C. 1060","children":[],"tail":" note] (Department of Education)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(u) President’s Council of Advisors on Science and Technology; Executive Order 14177 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6601"},"text":"42 U.S.C. 6601","children":[],"tail":" note] (Department of Energy)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(v) Grand Staircase-Escalante National Monument Advisory Committee; Proclamation 6920 of ","children":[{"tag":"date","attrib":{"date":"1996-09-18"},"text":"September 18, 1996","children":[],"tail":", as amended [listed in a table under "},{"tag":"ref","attrib":{"href":"/us/usc/t54/s320301"},"text":"54 U.S.C. 320301","children":[],"tail":"] (Department of the Interior)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 2. Notwithstanding the provisions of any other Executive Order, the functions of the President under the Federal Advisory Committee Act [chapter 10 of title 5, United States Code] that are applicable to the committees listed in section 1 of this order shall be performed by the head of the department or agency designated after each committee, in accordance with the regulations, guidelines, and procedures established by the Administrator of General Services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 3. Sections 1 and 2 of Executive Order 14109 of "},{"tag":"date","attrib":{"date":"2023-09-29"},"text":"September 29, 2023","children":[],"tail":", are hereby superseded by sections 1 and 2 of this order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 4. This order shall be effective "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 5. "},{"tag":"i","attrib":{},"text":"General Provisions","children":[],"tail":". (a) Nothing in this order shall be construed to impair or otherwise affect:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) the authority granted by law to an executive department or agency, or the head thereof; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) the functions of the Director of the Office of Management and Budget relating to budgetary, administrative, or legislative proposals.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) This order shall be implemented consistent with applicable law and subject to the availability of appropriations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) This order is not intended to, and does not, create any right or benefit, substantive or procedural, enforceable at law or in equity by any party against the United States, its departments, agencies, or entities, its officers, employees, or agents, or any other person.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions providing for the continuance of certain Federal advisory committees were contained in the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 14109, ","children":[{"tag":"date","attrib":{"date":"2023-09-29"},"text":"Sept. 29, 2023","children":[],"tail":", 88 F.R. 68447, partially superseded by Ex. Ord. No. 14354, § 3, "},{"tag":"date","attrib":{"date":"2025-09-29"},"text":"Sept. 29, 2025","children":[],"tail":", 90 F.R. 48146."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 14048, ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"Sept. 30, 2021","children":[],"tail":", 86 F.R. 55465, partially superseded by Ex. Ord. No. 14109, § 3, "},{"tag":"date","attrib":{"date":"2023-09-29"},"text":"Sept. 29, 2023","children":[],"tail":", 88 F.R. 68449."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13889, ","children":[{"tag":"date","attrib":{"date":"2019-09-27"},"text":"Sept. 27, 2019","children":[],"tail":", 84 F.R. 52743, as amended by Ex. Ord. No. 13935, § 4(a), "},{"tag":"date","attrib":{"date":"2020-07-09"},"text":"July 9, 2020","children":[],"tail":", 85 F.R. 4