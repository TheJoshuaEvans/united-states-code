{"tag":"section","attrib":{"id":"idb908049e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464"},"text":null,"children":[{"tag":"num","attrib":{"value":"8464"},"text":"§ 8464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement and termination of annuities of employees and Members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb908049f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90804a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90804a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an annuity payable from the Fund commences on the first day of the month after—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb90804a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separation from the service, in the case of an employee or Member retiring under section 8412, or subsection (a), (b)(1)(B), or (d) of section 8414; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90804a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay ceases, and the applicable age and service requirements are met, in the case of an employee or Member retiring under section 8413;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90804a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity payable from the Fund commences on the day after separation from the service in the case of an employee retiring under subsection (b)(1)(A) or (c) of section 8414; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90804a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity payable from the Fund commences on the day after separation from the service or the day after pay ceases and the requirements for title to an annuity are met in the case of an employee or Member retiring under section 8451.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90804a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding paragraph (1)(A)(i), an annuity payable from the Fund commences on the day after separation from the service in the case of an employee or Member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90804a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who retires under section 8412; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90804a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose separation occurs upon the expiration of a term (or other period) for which the individual was appointed or elected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90804a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this chapter, the annuity of an annuitant under subchapter II or V of this chapter terminates on the date death or other terminating event occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90804aa-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/574"},"text":"100 Stat. 574","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tXI/s1109/c/2"},"text":"Pub. L. 105–261, div. A, title XI, § 1109(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2145"},"text":"112 Stat. 2145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/58/tVI/s651/b"},"text":"Pub. L. 106–58, title VI, § 651(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/480"},"text":"113 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/39