{"tag":"section","attrib":{"id":"idb92bb878-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813"},"text":null,"children":[{"tag":"num","attrib":{"value":"9813"},"text":"§ 9813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited appointments to Senior Executive Service positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92bb879-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92bb87a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “career reserved position” means a position in the Administration designated under section 3132(b) which may be filled only by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92bb87b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a career appointee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb87c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a limited emergency appointee or a limited term appointee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb92bb87d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, immediately before entering the career reserved position, was serving under a career or career-conditional appointment outside the Senior Executive Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb92bb87e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose limited emergency or limited term appointment is approved in advance by the Office of Personnel Management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb87f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “limited emergency appointee” has the meaning given under section 3132; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb880-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “limited term appointee” means an individual appointed to a Senior Executive Service position in the Administration to meet a bona fide temporary need, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb881-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of career reserved positions which are filled by an appointee as described under subsection (a)(1)(B) may not exceed 10 percent of the total number of Senior Executive Service positions allocated to the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb882-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding sections 3132 and 3394(b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92bb883-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator may appoint an individual to any Senior Executive Service position in the Administration as a limited term appointee under this section for a period of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92bb884-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 years or less to a position the duties of which will expire at the end of such term; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb885-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year or less to a position the duties of which are continuing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb886-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in rare circumstances, the Administrator may authorize an extension of a limited appointment under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92bb887-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1)(A) for a period not to exceed 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb888-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1)(B) for a period not to exceed 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb889-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limited term appointee who has been appointed in the Administration from a career or career-conditional appointment outside the Senior Executive Service shall have reemployment rights in the agency from which appointed, or in another agency, under requirements and conditions established by the Office of Personnel Management. The Office shall have the authority to direct such placement in any agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb88a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding section 3394(b) and section 3395—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92bb88b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited term appointee serving under a term prescribed under this section may be reassigned to another Senior Executive Service position in the Administration, the duties of which will expire at the end of a term of 4 years or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb88c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited term appointee serving under a term prescribed under this section may be reassigned to another continuing Senior Executive Service position in the Administration, except that the appointee may not serve in 1 or more positions in the Administration under such appointment in excess of 1 year, except that in rare circumstances, the Administrator may approve an extension up to an additional 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb88d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limited term appointee may not serve more than 7 consecutive years under any combination of limited appointments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb88e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9813/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 5384, the Administrator may authorize performance awards to limited term appointees in the Administration in the same amounts and in the same manner as career appointees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92bb88f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/201/s3/a"},"text":"Pub. L. 108–201, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-02-24"},"text":"Feb. 24, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/473"},"text":"118 Stat. 473","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
