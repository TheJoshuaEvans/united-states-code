{"tag":"section","attrib":{"id":"idb82a4da7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301"},"text":null,"children":[{"tag":"num","attrib":{"value":"4301"},"text":"§ 4301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise expressly provided, for the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82a4da8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82a4da9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4daa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Publishing Office;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82a4dab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82a4dac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency, the Defense Intelligence Agency, the National Geospatial-Intelligence Agency, the National Security Agency, or any Executive agency or unit thereof which is designated by the President and the principal function of which is the conduct of foreign intelligence or counterintelligence activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82a4dad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/1/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4dae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means an individual employed in or under an agency, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82a4daf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee outside the United States who is paid in accordance with local native prevailing wage rates for the area in which employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual in the Foreign Service of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician, dentist, nurse, or other employee in the Veterans Health Administration of the Department of Veterans Affairs whose pay is fixed under chapter 73 of title 38;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative law judge appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual in the Senior Executive Service or the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual appointed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual occupying a position not in the competitive service excluded from coverage of this subchapter by regulations of the Office of Personnel Management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4db6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who (i) is serving in a position under a temporary appointment for less than one year, (ii) agrees to serve without a performance evaluation, and (iii) will not be considered for a reappointment or for an increase in pay based in whole or in part on performance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4db7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unacceptable performance” means performance of an employee which fails to meet established performance standards in one or more critical elements of such employee’s position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82a4db8-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/440"},"text":"80 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/c/8"},"text":"Pub. L. 91–375, § 6(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/776"},"text":"84 Stat. 776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/251/s2/a/1"},"text":"Pub. L. 95–251, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","ch