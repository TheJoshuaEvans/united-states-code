r","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 11, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/101"},"text":"Pub. L. 85–101","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/293"},"text":"71 Stat. 293","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/857/s13/p"},"text":"Pub. L. 85–857, § 13(p)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/1266"},"text":"72 Stat. 1266","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Mar. 26, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/290"},"text":"Pub. L. 88–290","children":[],"tail":", “Sec. 306(b)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/78/170"},"text":"78 Stat. 170","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the term “Executive agency” is substituted for the reference to “executive departments, the independent establishments and agencies in the executive branch, including corporations wholly owned by the United States” and “the General Accounting Office”. The exception of “a Government controlled corporation” is added in subparagraph (vii) to preserve the application of this chapter to “corporations wholly owned by the United States”. The exceptions for Production credit corporations and Federal intermediate credit banks in former section 2001(b)(5), (6) are omitted as they are no longer “corporations wholly owned by the United States”. Under the Farm Credit Act of 1956, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/70/659"},"text":"70 Stat. 659","children":[],"tail":", the production credit corporations were merged in the Federal intermediate credit banks, and pursuant to that Act the Federal intermediate credit banks have ceased to be corporations owned by the United States. The exceptions for Federal land banks and banks for cooperatives in former section 2001(b)(7), (8) are omitted as included within the exception of “a Government controlled corporation” in subparagraph (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (2) is supplied because the definition of “employee” in section 2105 does not encompass individuals employed by the government of the District of Columbia. The definition in paragraph (2) does not encompass members of the uniformed services as they are not “employed” in or under an agency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (2)(E) is based on the third and fifth sentences, respectively, of former sections 1010 and 1011, which are carried into sections 5362 and 559, respectively, and ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782/s1106/a"},"text":"section 1106(a) of the Act of Oct. 28, 1949, ch. 782","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82a4dbc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82a4dbd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", in introductory provisions, substituted “Except as otherwise expressly provided, for the purpose of” for “For the purpose of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Par. (1)(ii) ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “National Imagery and Mapping Agency” for “Central Imagery Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (1)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" inserted “the Central Imagery Office,” after “Defense Intelligence Agency,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Veterans Health Administration of the Department of Veterans Affairs” for “Department of Medicine and Surgery, Veterans’ Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/474"},"text":"Pub. L. 101–474","children":[],"tail":" redesignated subpar. (C) as (B) and struck out former subpar. (B) which included Administrative Office of United States Courts within definition of “agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325"},"text":"Pub. L. 100–325","children":[],"tail":" inserted reference to Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted provisions defining “agency”, “employee”, and “unacceptable performance” for provisions defining “agency” and “employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/251"},"text":"Pub. L. 95–251","children":[],"tail":" substituted “administrative law judge” for “hearing examiner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Par. (1)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" repealed cl. (ii) which excluded postal field service from definition of “agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82a4dbe-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb82a4dbf-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in par. (1)(B) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82a4dc0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag