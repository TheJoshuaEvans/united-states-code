{"tag":"section","attrib":{"id":"idb7a71367-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500"},"text":null,"children":[{"tag":"num","attrib":{"value":"500"},"text":"§ 500.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative practice; general provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7a71368-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a71369-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a7136a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State, a territory or possession of the United States including a Commonwealth, or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a7136b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is a member in good standing of the bar of the highest court of a State may represent a person before an agency on filing with the agency a written declaration that he is currently qualified as provided by this subsection and is authorized to represent the particular person in whose behalf he acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a7136c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is duly qualified to practice as a certified public accountant in a State may represent a person before the Internal Revenue Service of the Treasury Department on filing with that agency a written declaration that he is currently qualified as provided by this subsection and is authorized to represent the particular person in whose behalf he acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a7136d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a7136e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant or deny to an individual who is not qualified as provided by subsection (b) or (c) of this section the right to appear for or represent a person before an agency or in an agency proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a7136f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize or limit the discipline, including disbarment, of individuals who appear in a representative capacity before an agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a71370-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize an individual who is a former employee of an agency to represent a person before an agency when the representation is prohibited by statute or regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a71371-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent an agency from requiring a power of attorney as a condition to the settlement of a controversy involving the payment of money.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a71372-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (b)–(d) of this section do not apply to practice before the United States Patent and Trademark Office with respect to patent matters that continue to be covered by chapter 3 (sections 31–33) of title 35.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a71373-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s500/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a participant in a matter before an agency is represented by an individual qualified under subsection (b) or (c) of this section, a notice or other written communication required or permitted to be given the participant in the matter shall be given to the representative in addition to any other service specifically required by statute. When a participant is represented by more than one such qualified representative, service on any one of the representatives is sufficient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7a71374-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/1/A"},"text":"Pub. L. 90–83, § 1(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/195"},"text":"81 Stat. 195","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/2"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–583.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7a71375-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7a71376-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7a71377-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Revised Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"500(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 1014.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/332/s3"},"text":"Pub. L. 89–332, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1281"},"text":"79 Stat. 1281","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"500(b)–(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 1012.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/332/s1"},"text":"Pub. L. 89–332, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1281"},"text":"79 Stat. 1281","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"500(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 1013.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/332/s2"},"text":"Pub. L. 89–332, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1281"},"text":"79 Stat. 1281","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of “State” in subsection (a)(2) is supplied for convenience and is based on the words “State, possession, territory, Commonwealth, or District of Columbia” in subsections (a) and (b) of 5 App. U.S.C. 1012.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “This section does not” are substituted for “nothing herein shall be construed”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(3), the word “employee” is substituted for “officer or employee” to conform to the definition of “employee” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"5 U.S.C. 2105","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7a71378-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7a71379-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “United States Patent and Trademark Office” for “Patent Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7a7137a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7a7137b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":