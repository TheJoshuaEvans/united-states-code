{"tag":"section","attrib":{"id":"idb8a8a581-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106"},"text":null,"children":[{"tag":"num","attrib":{"value":"7106"},"text":"§ 7106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a8a582-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b) of this section, nothing in this chapter shall affect the authority of any management official of any agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a8a583-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the mission, budget, organization, number of employees, and internal security practices of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a584-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with applicable laws—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a8a585-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire, assign, direct, layoff, and retain employees in the agency, or to suspend, remove, reduce in grade or pay, or take other disciplinary action against such employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a8a586-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assign work, to make determinations with respect to contracting out, and to determine the personnel by which agency operations shall be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a8a587-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to filling positions, to make selections for appointments from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a8a588-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among properly ranked and certified candidates for promotion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a8a589-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate source; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a8a58a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take whatever actions may be necessary to carry out the agency mission during emergencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a8a58b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall preclude any agency and any labor organization from negotiating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a8a58c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the election of the agency, on the numbers, types, and grades of employees or positions assigned to any organizational subdivision, work project, or tour of duty, or on the technology, methods, and means of performing work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a58d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures which management officials of the agency will observe in exercising any authority under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a58e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate arrangements for employees adversely affected by the exercise of any authority under this section by such management officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a8a58f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s701"},"text":"Pub. L. 95–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1198"},"text":"92 Stat. 1198","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a8a590-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a8a591-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a8a592-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
