{"tag":"section","attrib":{"id":"idb89a4de6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307"},"text":null,"children":[{"tag":"num","attrib":{"value":"6307"},"text":"§ 6307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sick leave; accrual and accumulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89a4de7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee is entitled to sick leave with pay which accrues on the basis of one-half day for each full biweekly pay period, except that sick leave with pay accrues to a member of the Firefighting Division of the Fire Department of the District of Columbia on the basis of two-fifths of a day for each full biweekly pay period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4de8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sick leave provided by this section, which is not used by an employee, accumulates for use in succeeding years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4de9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sick leave provided by this section may be used for purposes relating to the adoption of a child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4dea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When required by the exigencies of the situation, a maximum of 30 days sick leave with pay may be advanced for serious disability or ailment, or for purposes relating to the adoption of a child, except that a maximum of 24 days sick leave with pay may be advanced to a member of the Firefighting Division of the Fire Department of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4deb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(e)(1)”."}],"tail":" For the purpose of this subsection, the term “family member” shall have such meaning as the Office of Personnel Management shall by regulation prescribe, except that such term shall include any individual who meets the definition given that term, for purposes of the leave transfer program under subchapter III, under regulations prescribed by the Office (as in effect on "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":")."}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89a4dec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3) and in addition to any other allowable purpose, sick leave may be used by an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89a4ded-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to give care or otherwise attend to a family member having an illness, injury, or other condition which, if an employee had such condition, would justify the use of sick leave by such an employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89a4dee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes relating to the death of a family member, including to make arrangements for or attend the funeral of such family member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4def-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89a4df0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Sick leave may be used by an employee for the purposes provided under paragraph (2) only to the extent the amount used for such purposes does not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89a4df1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 hours in any year, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89a4df2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to an additional 64 hours in any year, but only to the extent the use of such additional hours does not cause the amount of sick leave to the employee’s credit to fall below 80 hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89a4df3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a part-time employee or an employee on an uncommon tour of duty, the Office of Personnel Management shall establish limitations that are proportional to those prescribed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4df4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89a4df5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall be effective during the 3-year period that begins upon the expiration of the 2-month period that begins on the date of the enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89a4df6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6307/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 6 months before the date on which this subsection is scheduled to cease to be effective, the Office shall submit a report to Congress in which it shall evaluate the operation of this subsection and make recommendations as to whether or not this subsection should be continued beyond such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89a4df7-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/520"},"text":"80 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/329/tVI/s629/b/1"},"text":"Pub. L. 103–329, title VI, § 629(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2423"},"text":"108 Stat. 2423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/388/s2"},"text":"Pub. L. 103–388, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4079"},"text":"108 Stat. 4079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89a4df8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb89a4df9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb89a4dfa-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2063"},"text":"5 U.S.C. 2063","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-10-30/ch631/s204"},"text":"Oct. 30, 1951, ch. 631, § 204","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/681"},"text":"65 Stat. 681","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 21, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/471/s6/b"},"text":"Pub. L. 88–471, § 6(b)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/78/583"},"text":"78 Stat. 583","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “officer”, referring to an officer of the Firefighting Division, is omitted as covered by the words “a member of the Firefighting Division”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “with pay” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89a4dfb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb89a4dfc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (d)(4)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/388"},"text":"Pub. L. 103–388","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89a4dfd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/329/s629/b/1/B"},"text":"Pub. L. 103–329, § 629(b)(1)(B)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/388"},"text":"Pub. L. 103–388","children":[],"tail":" added subsec. (d) relating to use of sick leave for purposes relating to family member."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/329/s629/b/1/A"},"text":"Pub. L. 103–329, § 629(b)(1)(A)","children":[],"tail":", (C), redesignated subsec. (c) as (d) and inserted “or for purposes relating to the adoption of a child,” after “ailment,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89a4dfe-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89a4dff-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/329/tVI/s629/b/3"},"text":"Pub. L. 103–329, title VI, § 629(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2423"},"text":"108 Stat. 2423","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/329/tVI/s629/b/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall prescribe regulations under which any employee who used or uses annual leave for an adoption-related purpose, after ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and before the date as of which sick leave first becomes available for such purpose as a result of the enactment of this subsection may, upon appropriate written application, elect to have such employee’s leave accounts adjusted to reflect the amount of annual leave and sick leave, respectively, which would remain had sick leave been used instead of all or any portion of the annual leave actually used, as designated by the employee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An application under this paragraph may not be approved unless it is submitted—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":"] or such later date as the Office may prescribe;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such form and manner as the Office shall require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by an individual who is an employee as of the time of application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this paragraph, the term ‘employee’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6301/2"},"text":"section 6301(2) of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89a4e00-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adoptions During Fiscal Year 1991","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s536"},"text":"Pub. L. 101–509, title V, § 536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1470"},"text":"104 Stat. 1470","children":[],"tail":", for fiscal year 1991, authorized sick leave provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6307"},"text":"section 6307 of this title","children":[],"tail":" to be approved for purposes related to the adoption of a child."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
