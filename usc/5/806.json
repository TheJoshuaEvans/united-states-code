{"tag":"section","attrib":{"id":"idb7d92003-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s806"},"text":null,"children":[{"tag":"num","attrib":{"value":"806"},"text":"§ 806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability; severability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7d92004-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter shall apply notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d92005-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any provision of this chapter or the application of any provision of this chapter to any person or circumstance, is held invalid, the application of such provision to other persons or circumstances, and the remainder of this chapter, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7d92006-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tII/s251"},"text":"Pub. L. 104–121, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/873"},"text":"110 Stat. 873","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
