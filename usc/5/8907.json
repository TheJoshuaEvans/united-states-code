{"tag":"section","attrib":{"id":"idb91fd197-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8907"},"text":null,"children":[{"tag":"num","attrib":{"value":"8907"},"text":"§ 8907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to individuals eligible to enroll","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91fd198-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall make available to each individual eligible to enroll in a health benefits plan under this chapter such information, in a form acceptable to the Office after consultation with the carrier, as may be necessary to enable the individual to exercise an informed choice among the types of plans described by sections 8903 and 8903a of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91fd199-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each enrollee in a health benefits plan shall be issued an appropriate document setting forth or summarizing the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91fd19a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services or benefits, including maximums, limitations, and exclusions, to which the enrollee or the enrollee and any eligible family members are entitled thereunder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91fd19b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedure for obtaining benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91fd19c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8907/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" principal provisions of the plan affecting the enrollee and any eligible family members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91fd19d-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/605"},"text":"80 Stat. 605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s3/5"},"text":"Pub. L. 98–615, § 3(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3204"},"text":"98 Stat. 3204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/53/s2/d"},"text":"Pub. L. 99–53, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-06-17"},"text":"June 17, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/94"},"text":"99 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91fd19e-5e84-11f1-a692-ec26948f