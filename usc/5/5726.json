ll}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s73b–1/e"},"text":"5 U.S.C. 73b–1(e)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/707/s301/c/2"},"text":"Pub. L. 86–707, § 301(c)(2)","children":[],"tail":", (d) (as applicable to the Administrative Expenses Act of 1946, as amended), "},{"tag":"html:a","attrib":{"href":"/us/stat/74/796"},"text":"74 Stat. 796","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “employee” is substituted for “civilian officer or employee” in view of the definition of “employee” in sections 5721 and 2105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “including a new appointee and a student trainee to the extent authorized by sections 5722 and 5723 of this title” are substituted for “including any new appointee in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s73b–3"},"text":"section 73b–3 of this title","children":[],"tail":"” for clarity and reflect the codification of former section 73b–3 in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb884f0f9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb884f0fa-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5726(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 73b–4c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 21, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/516/s2"},"text":"Pub. L. 89–516, § 2","children":[],"tail":" “Sec. 25”, "},{"tag":"html:a","attrib":{"href":"/us/stat/80/324"},"text":"80 Stat. 324","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amendment of subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5726"},"text":"5 U.S.C. 5726","children":[],"tail":" reflects the addition of a new subsection (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5726"},"text":"5 U.S.C. 5726","children":[],"tail":" was derived from subsection (e) of section 1 of the Administrative Expenses Act of 1946, as amended ("},{"tag":"ref","attrib":{"href":"/us/stat/74/796"},"text":"74 Stat. 796","children":[],"tail":"). In the codification of subsection (e), the words “7,000 pounds net weight” were substituted for “the maximum weight limitation provided by subsection (a)”. During the pendency of the codification bill, "},{"tag":"ref","attrib":{"href":"/us/pl/89/516/s1/a/2"},"text":"section 1(a)(2) of Public Law 89–516","children":[],"tail":", amended subsection (a) of section 1 of the Administrative Expenses Act of 1946 to increase the maximum weight limitation from 7,000 to 11,000 pounds. Thus, the amendment of subsection (b) is necessary to reflect the current weight limitation applicable."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “employee” is substituted for “civilian officer or employee” to conform to the definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721/2"},"text":"5 U.S.C. 5721(2)","children":[],"tail":" and 2105. The words “including a new appointee and a student trainee to the extent authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5723"},"text":"section 5723 of this title","children":[],"tail":"” are substituted for “including any new appointee in accordance with section 7(b) of this Act, as amended” for clarity and to reflect the codification of section 7(b) in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5723"},"text":"5 U.S.C. 5723","children":[],"tail":". The words “continental United States” are coextensive with and substituted for “continental United States, excluding Alaska” on authority of the definition of “continental United States” in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721/3"},"text":"5 U.S.C. 5721(3)","children":[],"tail":". The words “head of the agency concerned” are substituted for “head of the Executive Department or agency concerned” to conform to the definition in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721/1"},"text":"5 U.S.C. 5721(1)","children":[],"tail":". In the penultimate sentence, the words “sections 5723(a) and 5724(a) of this title” are substituted for “section 1 or 7(b) of this Act” to reflect the codification of sections 1 and 7(b) in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5723/a"},"text":"5 U.S.C. 5723(a)","children":[],"tail":" and 5724(a); and the word “officer” is omitted as included in “employee”. In the last sentence, the words “under this subsection” are inserted for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) of section 25 of the Administrative Expenses Act of 1946 (added by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/516/s2"},"text":"section 2 of Public Law 89–516","children":[],"tail":") is omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb884f0fb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb884f0fc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1723/b/3"},"text":"Pub. L. 104–201, § 1723(b)(3)","children":[],"tail":", substituted “as authorized under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":"” for “as the President may by regulation authorize”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1723/b/1"},"text":"Pub. L. 104–201, § 1723(b)(1)","children":[],"tail":", substituted “Under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":"” for “Under such regulations as the President may prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":" substituted “18,000” for “11,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb884f0fd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb884f0fe-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5722"},"text":"section 5722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb884f0ff-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment; Promulgation of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":" and promulgation of regulations for amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-11-14"},"text":"Nov. 14, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/151/s118/c"},"text":"section 118(c) of Pub. L. 98–151","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8873af0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funding of Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":" to be carried out by agencies by use of funds appropriated or otherwise available for administrative expenses of such agencies, and do not authorize appropriation of funds in amounts exceeding sums already authorized to be appropriated for such agencies, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/151/s118/b"},"text":"section 118(b) of Pub. L. 98–151","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
