il":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A) and (B), the words “sections 404 and 405 of title 37” and “sections 406 and 409 of title 37” are substituted for the references to “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s253"},"text":"section 253 of title 37","children":[],"tail":"” on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1962-09-07/s12/b"},"text":"section 12(b) of the Act of Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/497"},"text":"76 Stat. 497","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":"” are substituted for “in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s73b–1"},"text":"section 73b–1 of this title","children":[],"tail":", and Executive Order Numbered 9805, as amended” to reflect the codification of former section 73b–1 in this title and in view of the revocation of Executive Order No. 9805 by Executive Order No. 11012 of "},{"tag":"date","attrib":{"date":"1962-03-27"},"text":"Mar. 27, 1962","children":[],"tail":". The reference only to section 5724 is sufficient since that section contains the applicable substantive law, including the authority of the President to prescribe regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82a4d1c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82a4d1d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/b/1/A"},"text":"Pub. L. 117–263, § 626(b)(1)(A)","children":[],"tail":", substituted “sections 405 and 452” for “sections 474 and 475”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s626/b/1/B"},"text":"Pub. L. 117–263, § 626(b)(1)(B)","children":[],"tail":", substituted “sections 452 and 453(c)” for “sections 476 and 479”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/B"},"text":"Pub. L. 112–81, § 631(f)(4)(B)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/B"},"text":"Pub. L. 112–81, § 631(f)(4)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", substituted “474” for “404” and “475” for “405” in subpar. (A), and “476” for “406” and “479” for “409” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"