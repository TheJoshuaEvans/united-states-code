{"tag":"section","attrib":{"id":"idb82a4d0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109"},"text":null,"children":[{"tag":"num","attrib":{"value":"4109"},"text":"§ 4109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82a4d0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency, under the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4118/a/8"},"text":"section 4118(a)(8) of this title","children":[],"tail":" and from appropriations or other funds available to the agency, may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82a4d0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay all or a part of the pay (except overtime, holiday, or night differential pay) of an employee of the agency selected and assigned for training under this chapter, for the period of training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4d0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay, or reimburse the employee for, all or a part of the necessary expenses of the training, without regard to section 3324(a) and (b) of title 31, including among the expenses the necessary costs of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82a4d0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel and per diem instead of subsistence under subchapter I of chapter 57 of this title or, in the case of commissioned officers of the National Oceanic and Atmospheric Administration, sections 405 and 452 of title 37, and the Joint Travel Regulations for the Uniformed Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of immediate family, household goods and personal effects, packing, crating, temporarily storing, draying, and unpacking under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":" or, in the case of commissioned officers of the National Oceanic and Atmospheric Administration, sections 452 and 453(c) of title 37, and the Joint Travel Regulations for the Uniformed Services, when the estimated costs of transportation and related services are less than the estimated aggregate per diem payments for the period of training;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition and matriculation fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" library and laboratory services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase or rental of books, materials, and supplies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82a4d14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services or facilities directly related to the training of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4d15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expenses of training do not include membership fees except to the extent that the fee is a necessary cost directly related to the training itself or that payment of the fee is a condition precedent to undergoing the training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4d16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a)(1) of this section, the Administrator, Federal Aviation Administration, may pay an individual training to be an air traffic controller of such Administration, and the Secretary of Defense may pay an individual training to be an air traffic controller of the Department of Defense, during the period of such training, at the applicable rate of basic pay for the hours of training officially ordered or approved in excess of forty hours in an administrative workweek.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4d17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a)(1), a firefighter who is subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5545b"},"text":"section 5545b of this title","children":[],"tail":" shall be paid basic pay and overtime pay for the firefighter’s regular tour of duty while attending agency sanctioned training."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82a4d18-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/436"},"text":"80 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":", § 1(4), "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/196"},"text":"81 Stat. 196","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/19"},"text":"Pub. L. 96–54, § 2(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/a/9"},"text":"Pub. L. 97–258, § 3(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/276/s151/a"},"text":"Pub. L. 97–276, § 151(a)","ch