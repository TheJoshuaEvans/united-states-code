{"tag":"section","attrib":{"id":"idb8c2e500-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8143a"},"text":"§ 8143a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of the National Teacher Corps","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of this section, this subchapter applies to a member of the National Teacher Corps. In administering this subchapter for a member covered by this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e501-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “performance of duty” does not include an act of a member while—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e502-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on authorized leave; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e503-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" absent from his assigned post of duty, except while participating in an activity authorized by or under the direction or supervision of the Commissioner of Education; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e504-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8143a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in computing compensation for disability or death, the monthly pay of a member is deemed his actual pay or that received at the minimum rate for GS–6, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c2e505-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/66/A"},"text":"Pub. L. 90–83, § 1(66)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/212"},"text":"81 Stat. 212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c2e506-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e507-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e508-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8143a","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20: 1105(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/329/s515/b"},"text":"Pub. L. 89–329, § 515(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/1257"},"text":"79 Stat. 1257","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “a member of the National Teacher Corps” are substituted for “such members” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1102"},"text":"20 U.S.C. 1102","children":[],"tail":", 1105(a). In paragraph (1)(B), the words “Commissioner of Education” are substituted for “Commissioner” on authority of "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1141/f"},"text":"20 U.S.C. 1141(f)","children":[],"tail":". In paragraph (2), the words “at the minimum rate for GS–6” are substituted for “under the entrance salary for grade 6,” and the reference to the General Schedule of the Classification Act of 1949 is omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c2e509-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb8c2e50a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Commissioner of Education of Department of Health, Education, and Welfare transferred to Secretary of Education by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3441/a/1"},"text":"section 3441(a)(1) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
