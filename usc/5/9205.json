{"tag":"section","attrib":{"id":"idb926fd7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9205"},"text":null,"children":[{"tag":"num","attrib":{"value":"9205"},"text":"§ 9205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb926fd7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management shall by rule establish procedures providing for an appeal from any adverse action taken under section 9204 by not later than 30 days after the date of the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An adverse action taken under section 9204 (including a determination in an appeal from such an action under subsection (a) of this section) shall not be subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures under chapter 75; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subsection (a) of this section, appeal or judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd82-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/a"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1607"},"text":"133 Stat. 1607","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
