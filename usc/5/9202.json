{"tag":"section","attrib":{"id":"idb926fd55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202"},"text":null,"children":[{"tag":"num","attrib":{"value":"9202"},"text":"§ 9202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on requests for criminal history record information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb926fd56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inquiries Prior to Conditional Offer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsections (b) and (c), an employee of an agency may not request, in oral or written form (including through the Declaration for Federal Employment (Office of Personnel Management Optional Form 306) or any similar successor form, the USAJOBS internet website, or any other electronic means) that an applicant for an appointment to a position in the civil service disclose criminal history record information regarding the applicant before the appointing authority extends a conditional offer to the applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Otherwise Required by Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition under subsection (a) shall not apply with respect to an applicant for a position in the civil service if consideration of criminal history record information prior to a conditional offer with respect to the position is otherwise required by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Certain Positions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd59-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under subsection (a) shall not apply with respect to an applicant for an appointment to a position—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd5a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that requires a determination of eligibility described in clause (i), (ii), or (iii) of section 9101(b)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a Federal law enforcement officer (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s115/c"},"text":"section 115(c) of title 18","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified by the Director of the Office of Personnel Management in the regulations issued under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management shall issue regulations identifying additional positions with respect to which the prohibition under subsection (a) shall not apply, giving due consideration to positions that involve interaction with minors, access to sensitive information, or managing financial transactions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with civil rights laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb926fd60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with, and in no way supersede, restrict, or limit the application of title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.) or other relevant Federal civil rights laws; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb926fd61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9202/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all hiring activities conducted pursuant to the regulations are conducted in a manner consistent with relevant Federal civil rights laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd62-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/a"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1606"},"text":"133 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb926fd63-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb926fd64-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb926fd65-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (c)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb926fd66-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb926fd67-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI"},"text":"Pub. L. 116–92, div. A, title XI","children":[],"tail":", subtitle B, § 1122(b)(2), "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1608"},"text":"133 Stat. 1608","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dA/tXI"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9202"},"text":"Section 9202 of title 5","children":[],"tail":", United States Code (as added by this subtitle), shall take effect on the date that is 2 years after the date of enactment of this subtitle ["},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
