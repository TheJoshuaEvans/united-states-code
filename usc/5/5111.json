{"tag":"section","attrib":{"id":"idb8363404-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111"},"text":null,"children":[{"tag":"num","attrib":{"value":"5111"},"text":"§ 5111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation and restoration of authority to classify positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8363405-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the Office of Personnel Management finds that an agency is not placing positions in classes and grades in conformance with or consistently with published standards, it may revoke or suspend the authority granted to the agency by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5107"},"text":"section 5107 of this title","children":[],"tail":" and require that prior approval of the Office be secured before an action placing a position in a class and grade becomes effective for payroll and other personnel purposes. The Office may limit the revocation or suspension to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8363406-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the departmental or field service, or any part thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8363407-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a geographic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8363408-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization unit or group of organization units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8363409-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certain types of classification actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb836340a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classes in particular occupational groups or grades; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb836340b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classes for which standards have not been published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb836340c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After revocation or suspension, the Office may restore the authority to the extent that it is satisfied that later actions placing positions in classes and grades will be in conformance with or consistent with published standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb836340d-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/455"},"text":"80 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb836340e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb836340f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8363410-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s1104"},"text":"5 U.S.C. 1104","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-28/ch782/s504"},"text":"Oct. 28, 1949, ch. 782, § 504","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/959"},"text":"63 Stat. 959","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “in whole or in part” are omitted as unnecessary in view of the specific authority to limit the revocation or suspension. The words “The Commission may limit the revocation or suspension to” are substituted for “Such revocations or suspensions may be limited, in the discretion of the Commission, to” to eliminate redundancy.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “After revocation or suspension” are substituted for “After all or part of the authority of the department has been revoked or suspended”. The words “may restore” are substituted for “may at any time restore” to eliminate redundancy.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8363411-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8363412-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” and “Office” for “Civil Service Commission” and “Commission”, respectively, wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8363413-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8363414-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
