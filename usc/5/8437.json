{"tag":"section","attrib":{"id":"idb900d7fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437"},"text":null,"children":[{"tag":"num","attrib":{"value":"8437"},"text":"§ 8437.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thrift Savings Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb900d7fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury of the United States a Thrift Savings Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900d7fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Thrift Savings Fund consists of the sum of all amounts contributed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of this title","children":[],"tail":" and all amounts deposited under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8479/b"},"text":"section 8479(b) of this title","children":[],"tail":", increased by the total net earnings from investments of sums in the Thrift Savings Fund or reduced by the total net losses from investments of the Thrift Savings Fund, and reduced by the total amount of payments made from the Thrift Savings Fund (including payments for administrative expenses)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900d7fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sums in the Thrift Savings Fund are appropriated and shall remain available without fiscal year limitation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb900d7fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to invest under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8438"},"text":"section 8438 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d7ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay benefits or purchase annuity contracts under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d800-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the administrative expenses of the Federal Retirement Thrift Investment Management System prescribed in subchapter VII of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d801-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make distributions for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440/b"},"text":"section 8440(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d802-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make loans to employees and Members as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/g"},"text":"section 8433(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d803-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase insurance as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8479/b/2"},"text":"section 8479(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900d804-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative expenses incurred to carry out this subchapter and subchapter VII of this chapter shall be paid first out of any sums in the Thrift Savings Fund forfeited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/g"},"text":"section 8432(g) of this title","children":[],"tail":" and then out of net earnings in such Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900d805-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb900d806-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (d) and paragraphs (2) and (3), sums in the Thrift Savings Fund credited to the account of an employee, Member, former employee, or former Member may not be used for, or diverted to, purposes other than for the exclusive benefit of the employee, Member, former employee, or former Member or his beneficiaries under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d807-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), sums in the Thrift Savings Fund may not be assigned or alienated and are not subject to execution, levy, attachment, garnishment, or other legal process. For the purposes of this paragraph, a loan made from such Fund to an employee or Member shall not be considered to be an assignment or alienation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb900d808-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Moneys due or payable from the Thrift Savings Fund to any individual and, in the case of an individual who is an employee or Member (or former employee or Member), the balance in the account of the employee or Member (or former employee or Member) shall be subject to legal process for the enforcement of the individual’s legal obligations to provide child support or make alimony payments as provided in section 459 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s659"},"text":"42 U.S.C. 659","children":[],"tail":"), the enforcement of an order for restitution under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3663A"},"text":"section 3663A of title 18","children":[],"tail":", forfeiture under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/g/5"},"text":"section 8432(g)(5) of this title","children":[],"tail":", an obligation of the Executive Director to make a transfer under section 415(d)(3) of the Congressional Accountability Act of 1995 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1415/d/3"},"text":"2 U.S.C. 1415(d)(3)","children":[],"tail":"), or an obligation of the Executive Director to make a payment to another person under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8467"},"text":"section 8467 of this title","children":[],"tail":", and shall be subject to a Federal tax levy under section 6331 of the Internal Revenue Code of 1986. For the purposes of this paragraph, an amount contributed for the benefit of an individual under section 8432(c)(1) (including any earnings attributable thereto) shall not be considered part of the balance in such individual’s account unless such amount is nonforfeitable, as determined under applicable provisions of section 8432(g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900d809-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sums in the Thrift Savings Fund shall not be appropriated for any purpose other than the purposes specified in this section and may not be used for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb900d80a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8437/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All sums contributed to the Thrift Savings Fund by an employee or Member or by an employing agency for the benefit of such employee or Member and all net earnings in such Fund attributable to investment of such sums are held in such Fund in trust for such employee or Member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb900d80b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/550"},"text":"100 Stat. 550","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI"},"text":"Pub. L. 100–238, title I","children":[],"tail":", §§ 116, 117(a), "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1751"},"text":"101 Stat. 1751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/i/16"},"text":"Pub. L. 103–226, § 9(i)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/122"},"text":"108 Stat. 122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/358/s2/b/4"},"text":"Pub. L. 103–358, § 2(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3421"},"text":"108 Stat. 3421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/31/dB/tI/s108"},"text":"Pub. L. 111–31, div. B, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1856"},"text":"123 Stat. 1856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/267/s1"},"text":"Pub. L. 112–267, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2440"},"text":"126 Stat. 2440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/tI/s111/b"},"text":"Pub. L. 115–397, title I, § 111(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5311"},"text":"132 Stat. 5311","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb900d80c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb900d80d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb900d80e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6331 of the Internal Revenue Code of 1986, referred to in subsec. (e)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6331"},"text":"section 6331 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb900d80f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" inserted “an obligation of the Executive Director to make a transfer under section 415(d)(3) of the Congressional Accountability Act of 1995 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1415/d/3"},"text":"2 U.S.C. 1415(d)(3)","children":[],"tail":"),” before “or an obligation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/267"},"text":"Pub. L. 112–267","children":[],"tail":", in first sentence, substituted “659),” for “659)” and inserted “, and shall be subject to a Federal tax levy under section 6331 of the Internal Revenue Code of 1986” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31"},"text":"Pub. L. 111–31","children":[],"tail":" which directed substitution of “the enforcement of an order for restitution under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3663A"},"text":"section 3663A of title 18","children":[],"tail":", forfeiture under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/g/5"},"text":"section 8432(g)(5) of this title","children":[],"tail":", or an obligation of the Executive Director to make a payment to another person under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8467"},"text":"section 8467 of this title","children":[],"tail":"” for “or relating to the enforcement of a judgment for the physically, sexually, or emotionally abusing a child as provided under section 8467(a)” in the first sentence, was executed by making the substitution for “or relating to the enforcement of a judgment for physically, sexually, or emotionally abusing a child as provided under section 8467(a)”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" substituted “section 8433(g)” for “section 8433(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/358"},"text":"Pub. L. 103–358","children":[],"tail":" substituted “or relating to the enforcement of a judgment for physically, sexually, or emotionally abusing a child as provided under section 8467(a).” for period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s117/a/1"},"text":"Pub. L. 100–238, § 117(a)(1)","children":[],"tail":", struck out “attributable to sums contributed to such Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/c"},"text":"section 8432(c) of this title","children":[],"tail":"” after “such Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s117/a/2"},"text":"Pub. L. 100–238, § 117(a)(2)","children":[],"tail":", inserted “subsection (d) and” after “Subject to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s116"},"text":"Pub. L. 100–238, § 116","children":[],"tail":", inserted at end “For the purposes of this paragraph, an amount contributed for the benefit of an individual under section 8432(c)(1) (including any earnings attributable thereto) shall not be considered part of the balance in such individual’s account unless such amount is nonforfeitable, as determined under applicable provisions of section 8432(g).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb900d810-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb900d811-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/397"},"text":"Pub. L. 115–397","children":[],"tail":" applicable with respect to claims made on or after "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/397/s111/c"},"text":"section 111(c) of Pub. L. 115–397","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1415"},"text":"section 1415 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb900d812-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/358"},"text":"Pub. L. 103–358","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", and applicable with respect to any decree, order, or other legal process, or notice of agreement received by Office of Personnel Management or Executive Director of Federal Retirement Thrift Investment Board on or after "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/358/s3"},"text":"section 3 of Pub. L. 103–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8345"},"text":"section 8345 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-10"},"text":"Mar. 10, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/j"},"text":"section 9(j) of Pub. L. 103–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351"},"text":"section 8351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb900d813-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s117/b"},"text":"Pub. L. 100–238, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1751"},"text":"101 Stat. 1751","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/238/tI/s117/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on the first day of the first month beginning on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb900d814-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disposition of Amounts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/267/s2"},"text":"Pub. L. 112–267, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2440"},"text":"126 Stat. 2440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/267/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Any potential revenue gain attributable to the enactment of this Act [amending this section], as determined by the Director of the Congressional Budget Office—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited in the general fund of the Treasury of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used solely for purposes of deficit reduction.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
