{"tag":"section","attrib":{"id":"idb9309aea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13102"},"text":null,"children":[{"tag":"num","attrib":{"value":"13102"},"text":"§ 13102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9309aeb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this subchapter shall be administered by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309aec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Government Ethics, the designated agency ethics official, or the Secretary concerned, as appropriate, with regard to officers and employees described in paragraphs (1) through (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13103/f"},"text":"section 13103(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309aed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Ethics of the Senate and the Committee on Ethics of the House of Representatives, as appropriate, with regard to officers and employees described in paragraphs (9) and (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13103/f"},"text":"section 13103(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309aee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Judicial Conference in the case of an officer or employee described in paragraphs (11) and (12) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13103/f"},"text":"section 13103(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9309aef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation by Judicial Conference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Judicial Conference may delegate any authority it has under this subchapter to an ethics committee established by the Judicial Conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9309af0-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4270"},"text":"136 Stat. 4270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9309af1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9309af2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb9309af3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"13102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (EGA § 111)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/521/tI/s111"},"text":"Pub. L. 95–521, title I, § 111","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/101/194/tII/s202"},"text":"Pub. L. 101–194, title II, § 202","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1744"},"text":"103 Stat. 1744","children":[],"tail":"; amended "},{"tag":"html:a","attrib":{"href":"/us/pl/101/280/s3/1"},"text":"Pub. L. 101–280, § 3(1)","children":[],"tail":", (9), "},{"tag":"html:span","attrib":{},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/152"},"text":"104 Stat. 152","children":[],"tail":", 157."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “Committee on Ethics of the House of Representatives” are substituted for “Committee on Standards of Official Conduct of the House of Representatives” because of House Resolution No. 5, 112th Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"January 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9309af4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9309af5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transmittal of Financial Disclosure Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/tIX/s902"},"text":"Pub. L. 101–194, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1780"},"text":"103 Stat. 1780","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/17"},"text":"Pub. L. 117–286, § 4(c)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4356"},"text":"136 Stat. 4356","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/286/s4/c/17"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Select Committee on Ethics shall transmit a copy of each report filed with it under subchapter I of chapter 131 of title 5, United States Code, (other than a report filed by a Member of Congress) to the head of the employing office of the individual filing the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the head of the employing office shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of a Member, the Member by whom that person is employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee of a Committee, the chairman and ranking minority member of such Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee on the leadership staff, the Member of the leadership on whose staff such person serves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other employee of the legislative branch, the head of the office in which such individual serves.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
