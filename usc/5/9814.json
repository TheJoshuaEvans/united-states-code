{"tag":"section","attrib":{"id":"idb92bb890-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814"},"text":null,"children":[{"tag":"num","attrib":{"value":"9814"},"text":"§ 9814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92bb891-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding section 5334, the Administrator may set the pay of an employee paid under the General Schedule at any step within the pay range for the grade of the position, if such employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92bb892-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses unusually high or unique qualifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb893-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is assigned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92bb894-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new duties, without a change of position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb895-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a new position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb896-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an exercise of the authority under this section relates to a current employee selected for another position within the Administration, a determination shall be made that the employee’s contribution in the new position will exceed that in the former position, before setting pay under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb897-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pay as set under this section is basic pay for such purposes as pay set under section 5334.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb898-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employee serves for at least 1 year in the position for which the pay determination under this section was made, or a successor position, the pay earned under such position may be used in succeeding actions to set pay under chapter 53.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb899-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before setting any employee’s pay under this section, the Administrator shall submit a plan to the Office of Personnel Management and the appropriate committees of Congress, that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92bb89a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for approval of actions to set pay under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb89b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of approval required to set pay under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb89c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all types of actions and positions to be covered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb89d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship between the exercise of authority under this section and the use of other pay incentives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb89e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9814/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process to evaluate the effectiveness of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92bb89f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/201/s3/a"},"text":"Pub. L. 108–201, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-02-24"},"text":"Feb. 24, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/474"},"text":"118 Stat. 474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92bb8a0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92bb8a1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92bb8a2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
