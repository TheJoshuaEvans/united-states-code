 95–521, title V, § 502","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/101/194/tVI/s601/a"},"text":"Pub. L. 101–194, title VI, § 601(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1761"},"text":"103 Stat. 1761","children":[],"tail":"; amended "},{"tag":"html:a","attrib":{"href":"/us/pl/101/280/s7/a/1"},"text":"Pub. L. 101–280, § 7(a)(1)","children":[],"tail":", (b), "},{"tag":"html:span","attrib":{},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/161"},"text":"104 Stat. 161","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/650/tIII/s319"},"text":"Pub. L. 101–650, title III, § 319","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/198/s6"},"text":"Pub. L. 102–198, § 6","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/1624"},"text":"105 Stat. 1624","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/378/s4/b/3"},"text":"Pub. L. 102–378, § 4(b)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/1357"},"text":"106 Stat. 1357","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s371"},"text":"section 371 of title 28","children":[],"tail":"” are substituted for “subsection (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s371"},"text":"section 371 of title 28","children":[],"tail":"” for clarity and to update an obsolete reference in the law. Subsection (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s371"},"text":"section 371 of title 28","children":[],"tail":", United States Code, was redesignated as subsection (e) by section 654(a)(1)(B) of the Floyd D. Spence National Defense Authorization Act for Fiscal Year 2001 ("},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA/tVI/s654/a/1/B"},"text":"Public Law 106–398, § 1 [div. A, title VI, § 654(a)(1)(B)]","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–165)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb937c600-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb937c601-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–15, referred to in subsec. (a), is contained in the General Schedule, which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb937c602-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb937c603-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb937c604-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tI/s116/b"},"text":"Pub. L. 119–37, div. C, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/571"},"text":"139 Stat. 571","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/37/dC/tI/s116/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to compensation received in fiscal year 2026 or any succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
