{"tag":"section","attrib":{"id":"idb937c5f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144"},"text":null,"children":[{"tag":"num","attrib":{"value":"13144"},"text":"§ 13144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on outside employment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb937c5f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Member or an officer or employee who is a noncareer officer or employee and who occupies a position classified above GS–15 of the General Schedule or, in the case of positions not under the General Schedule, for which the rate of basic pay is equal to or greater than 120 percent of the minimum rate of basic pay payable for GS–15 of the General Schedule shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive compensation for affiliating with or being employed by a firm, partnership, association, corporation, or other entity which provides professional services involving a fiduciary relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit that Member’s, officer’s, or employee’s name to be used by any such firm, partnership, association, corporation, or other entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive compensation for practicing a profession which involves a fiduciary relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve for compensation as an officer or member of the board of any association, corporation, or other entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive compensation for teaching, without the prior notification and approval of the appropriate entity referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13142"},"text":"section 13142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb937c5f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Teaching Compensation of Justices and Judges Retired From Regular Active Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13143/a"},"text":"section 13143(a) of this title","children":[],"tail":", any compensation for teaching approved under subsection (a)(5) of this section shall not be treated as outside earned income—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when received by a justice of the United States retired from regular active service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s371/b"},"text":"section 371(b) of title 28","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when received by a judge of the United States retired from regular active service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s371/b"},"text":"section 371(b) of title 28","children":[],"tail":", for teaching performed during any calendar year for which such judge has met the requirements of subsection (e) of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s371"},"text":"section 371 of title 28","children":[],"tail":", as certified in accordance with such subsection; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when received by a justice or judge of the United States retired from regular active service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb937c5fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13144/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Treatment as Fiduciary Relationship","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the relationship between a Member who is a Representative in, or Delegate or Resident Commissioner to, the Congress and who is providing care directly to a patient in the form of medical services or dental services and the patient to whom such care is provided shall not be considered a fiduciary relationship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb937c5fc-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4304"},"text":"136 Stat. 4304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tI/s116/a"},"text":"Pub. L. 119–37, div. C, title I, § 116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/571"},"text":"139 Stat. 571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb937c5fd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb937c5fe-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb937c5ff-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"t