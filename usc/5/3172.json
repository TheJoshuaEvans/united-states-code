{"tag":"section","attrib":{"id":"idb804284e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172"},"text":null,"children":[{"tag":"num","attrib":{"value":"3172"},"text":"§ 3172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential Innovation Fellows Program advisory board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb804284f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall continue an advisory board to advise the Director of the Presidential Innovation Fellows Program by recommending such priorities and standards as may be beneficial to fulfill the mission of the Presidential Innovation Fellows Program and assist in identifying potential projects and placements for fellows. The advisory board may not participate in the selection process under section 3171(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8042850-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair; Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall designate a representative to serve as the Chair of the advisory board. In addition to the Chair, the membership of the advisory board shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8042851-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Director for Management of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8042852-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Personnel Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8042853-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Office of Electronic Government of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8042854-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant to the President and Chief Technology Officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8042855-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals as may be designated by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8042856-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advisory board may consult with industry, academia, or nonprofits to ensure the Presidential Innovation Fellows Program is continually identifying opportunities to apply advanced skillsets and innovative practices in effective ways to address the Nation’s most significant challenges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8042857-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/1/s2/a"},"text":"Pub. L. 115–1, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-20"},"text":"Jan. 20, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/4"},"text":"131 Stat. 4","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
