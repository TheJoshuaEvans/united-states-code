{"tag":"section","attrib":{"id":"idb924b3e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9006"},"text":null,"children":[{"tag":"num","attrib":{"value":"9006"},"text":"§ 9006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies, reports, and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b3e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9006/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions Relating to Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each master contract under this chapter shall contain provisions requiring the carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b3e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9006/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish such reasonable reports as the Office of Personnel Management determines to be necessary to enable it to carry out its functions under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b3e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9006/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the Office and representatives of the Government Accountability Office to examine such records of the carrier as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9006/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions Relating to Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal agency shall keep such records, make such certifications, and furnish the Office, the carrier, or both, with such information and reports as the Office may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9006/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports by the Government Accountability Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government Accountability Office shall prepare and submit to the President, the Office of Personnel Management, and each House of Congress, before the end of the third and fifth years during which the program under this chapter is in effect, a written report evaluating such program. Each such report shall include an analysis of the competitiveness of the program, as compared to both group and individual coverage generally available to individuals in the private insurance market. The Office shall cooperate with the Government Accountability Office to provide periodic evaluations of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b3ec-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1002/a"},"text":"Pub. L. 106–265, title I, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/768"},"text":"114 Stat. 768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b3ed-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b3ee-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b3ef-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in heading and two places in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
