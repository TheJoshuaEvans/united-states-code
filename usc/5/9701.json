{"tag":"section","attrib":{"id":"idb9296e41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701"},"text":null,"children":[{"tag":"num","attrib":{"value":"9701"},"text":"§ 9701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of human resources management system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9296e42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this part, the Secretary of Homeland Security may, in regulations prescribed jointly with the Director of the Office of Personnel Management, establish, and from time to time adjust, a human resources management system for some or all of the organizational units of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any system established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296e44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be flexible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be contemporary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not waive, modify, or otherwise affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public employment principles of merit and fitness set forth in section 2301, including the principles of hiring based on merit, fair treatment without regard to political affiliation or other nonmerit considerations, equal pay for equal work, and protection of employees against reprisal for whistleblowing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of section 2302, relating to prohibited personnel practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of law referred to in section 2302(b)(1), (8), and (9); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any provision of law implementing any provision of law referred to in section 2302(b)(1), (8), and (9) by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb9296e4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for equal employment opportunity through affirmative action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb9296e4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing any right or remedy available to any employee or applicant for employment in the civil service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of this part (as described in subsection (c)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule or regulation prescribed under any provision of law referred to in any of the preceding subparagraphs of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that employees may organize, bargain collectively, and participate through labor organizations of their own choosing in decisions which affect them, subject to any exclusion from coverage or limitation on negotiability established by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the use of a category rating system for evaluating applicants for positions in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Nonwaivable Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The other provisions of this part as referred to in subsection (b)(3)(D), are (to the extent not otherwise specified in subparagraph (A), (B), (C), or (D) of subsection (b)(3))—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296e53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparts A, B, E, G, and H of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapters 41, 45, 47, 55, 57, 59, 72, 73, and 79, and this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations Relating to Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall constitute authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296e56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to modify the pay of any employee who serves in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive Schedule position under subchapter II of chapter 53 of title 5, United States Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position for which the rate of basic pay is fixed in statute by reference to a section or level under subchapter II of chapter 53 of such title 5;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e59-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fix pay for any employee or position at an annual rate greater than the maximum amount of cash compensation allowable under section 5307 of such title 5 in a year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e5a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exempt any employee from the application of such section 5307.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions to Ensure Collaboration With Employee Representatives.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296e5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to ensure that the authority of this section is exercised in collaboration with, and in a manner that ensures the participation of employee representatives in the planning, development, and implementation of any human resources management system or adjustments to such system under this section, the Secretary of Homeland Security and the Director of the Office of Personnel Management shall provide for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of proposal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Director shall, with respect to any proposed system or adjustment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to each employee representative representing any employees who might be affected, a written description of the proposed system or adjustment (including the reasons why it is considered necessary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give each representative 30 calendar days (unless extraordinary circumstances require earlier action) to review and make recommendations with respect to the proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give any recommendations received from any such representatives under clause (ii) full and fair consideration in deciding whether or how to proceed with the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pre-implementation congressional notification, consultation, and mediation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following receipt of recommendations, if any, from employee representatives with respect to a proposal described in subparagraph (A), the Secretary and the Director shall accept such modifications to the proposal in response to the recommendations as they determine advisable and shall, with respect to any parts of the proposal as to which they have not accepted the recommendations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e62-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify Congress of those parts of the proposal, together with the recommendations of employee representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet and confer for not less than 30 calendar days with any representatives who have made recommendations, in order to attempt to reach agreement on whether or how to proceed with those parts of the proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the Secretary’s option, or if requested by a majority of the employee representatives who have made recommendations, use the services of the Federal Mediation and Conciliation Service during such meet and confer period to facilitate the process of attempting to reach agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e66-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any part of the proposal as to which the representatives do not make a recommendation, or as to which their recommendations are accepted by the Secretary and the Director, may be implemented immediately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to any parts of the proposal as to which recommendations have been made but not accepted by the Secretary and the Director, at any time after 30 calendar days have elapsed since the initiation of the congressional notification, consultation, and mediation procedures set forth in subparagraph (B), if the Secretary determines, in the Secretary’s sole and unreviewable discretion, that further consultation and mediation is unlikely to produce agreement, the Secretary may implement any or all of such parts, including any modifications made in response to the recommendations as the Secretary determines advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall promptly notify Congress of the implementation of any part of the proposal and shall furnish with such notice an explanation of the proposal, any changes made to the proposal as a result of recommendations from employee representatives, and of the reasons why implementation is appropriate under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a proposal described in subparagraph (A) is implemented, the Secretary and the Director shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a method for each employee representative to participate in any further planning or development which might become necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give each employee representative adequate access to information to make that participation productive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any procedures necessary to carry out this subsection shall be established by the Secretary and the Director jointly as internal rules of departmental procedure which shall not be subject to review. Such procedures shall include measures to ensure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of employees within a unit with respect to which a labor organization is accorded exclusive recognition, representation by individuals designated or from among individuals nominated by such organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any employees who are not within such a unit, representation by any appropriate organization which represents a substantial percentage of those employees or, if none, in such other manner as may be appropriate, consistent with the purposes of the subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair and expeditious handling of the consultation and mediation process described in subparagraph (B) of paragraph (1), including procedures by which, if the number of employee representatives providing recommendations exceeds 5, such representatives select a committee or other unified representative with which the Secretary and Director may meet and confer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of representatives in a manner consistent with the relative number of employees represented by the organizations or other representatives involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions Relating to Appellate Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9296e72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the Department are entitled to fair treatment in any appeals that they bring in decisions relating to their employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in prescribing regulations for any such appeals procedures, the Secretary and the Director of the Office of Personnel Management—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should ensure that employees of the Department are afforded the protections of due process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toward that end, should be required to consult with the Merit Systems Protection Board before issuing any such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9296e77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any regulations under this section which relate to any matters within the purview of chapter 77—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9296e78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be issued only after consultation with the Merit Systems Protection Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall ensure the availability of procedures which shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9296e7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with requirements of due process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9296e7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, to the maximum extent practicable, for the expeditious handling of any matters involving the Department; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9296e7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall modify procedures under chapter 77 only insofar as such modifications are designed to further the fair, efficient, and expeditious resolution of matters involving the employees of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions Relating to Labor-Management Relations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as conferring authority on the Secretary of Homeland Security to modify any of the provisions of section 842 of the Homeland Security Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9296e7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9701/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective 5 years after the conclusion of the transition period defined under section 1501 of the Homeland Security Act of 2002, all authority to issue regulations under this section (including regulations which would modify, supersede, or terminate any regulations previously issued under this section) shall cease to be available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9296e7f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s841/a/2"},"text":"Pub. L. 107–296, title VIII, § 841(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2230"},"text":"116 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9296e80-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9296e81-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9296e82-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 842 of the Homeland Security Act of 2002, referred to in subsec. (g), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s412"},"text":"section 412 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1501 of the Homeland Security Act of 2002, referred to in subsec. (h), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s541"},"text":"section 541 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9296e83-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9296e84-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb9296e85-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Allowances and Benefits for Personnel Abroad","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/83/tV/s546"},"text":"Pub. L. 111–83, title V, § 546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2177"},"text":"123 Stat. 2177","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/83/tV/s546"},"text":"“For fiscal year 2010 and thereafter, the Secretary [of Homeland Security] may provide to personnel appointed or assigned to serve abroad, allowances and benefits similar to those provided under chapter 9 of title I of the Foreign Service Act of 1990 [1980] (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081"},"text":"22 U.S.C. 4081","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
