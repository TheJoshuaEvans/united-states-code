{"tag":"section","attrib":{"id":"idb8c2e4b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141"},"text":null,"children":[{"tag":"num","attrib":{"value":"8141"},"text":"§ 8141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil Air Patrol volunteers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c2e4ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this section, this subchapter applies to a volunteer civilian member of the Civil Air Patrol, except a Civil Air Patrol Cadet under 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e4bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In administering this subchapter for a member of the Civil Air Patrol covered by this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e4bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly pay of a member is deemed the rate of basic pay payable for step 1 of grade GS–9 in the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":" for the purpose of computing compensation for disability or death;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the percentages applicable to payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133"},"text":"section 8133 of this title","children":[],"tail":" are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c2e4be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 45 percent for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/a/2"},"text":"section 8133(a)(2) of this title","children":[],"tail":", if the member dies fully or currently insured under subchapter II of chapter 7 of title 42, with no additional payments for a child or children while the widow or widower remains eligible for payments under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/a/2"},"text":"section 8133(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e4bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/a/3"},"text":"section 8133(a)(3) of this title","children":[],"tail":" for one child and 10 percent additional for each additional child, but not to exceed a total of 75 percent, if the member died fully or currently insured under subchapter II of chapter 7 of title 42; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c2e4c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/a/4"},"text":"section 8133(a)(4) of this title","children":[],"tail":", if one parent was wholly dependent on the deceased member at the time of his death and the other was not dependent to any extent; 16 percent to each, if both were wholly dependent; and if one was or both were partly dependent, a proportionate amount in the discretion of the Secretary of Labor;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment may not be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/a/5"},"text":"section 8133(a)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “performance of duty” means only active service, and travel to and from that service, rendered in performance or support of operational missions of the Civil Air Patrol under direction of the Department of the Air Force and under written authorization by competent authority covering a specific assignment and prescribing a time limit for the assignment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e4c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor or his designee shall inform the Commissioner of Social Security when a claim is filed and eligibility for compensation is established under section 8133(a)(2) or (3) of this title, and the Commissioner of Social Security shall certify to the Secretary of Labor as to whether or not the member concerned was fully or currently insured under subchapter II of chapter 7 of title 42 at the time of his death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e4c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor or his designee may inform the Secretary of the Air Force or his designee when a claim is filed. The Secretary of the Air Force, on request of the Secretary of Labor, shall advise him of the facts concerning the injury and whether or not the member was rendering service, or engaged in travel to or from service, in performance or support of an operational mission of the Civil Air Patrol at the time of injury. This subsection does not dispense with the report of the immediate superior of the member required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8120"},"text":"section 8120 of this title","children":[],"tail":", or other reports agreed on under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c2e4c5-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/551"},"text":"80 Stat. 551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1258/a"},"text":"Pub. L. 98–94, title XII, § 1258(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/702"},"text":"97 Stat. 702","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/e/4"},"text":"Pub. L. 103–296, title I, § 108(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1486"},"text":"108 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c2e4c6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e4c7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e4c8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s803"},"text":"5 U.S.C. 803","children":[],"tail":" (less (d))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-03/ch926/s1"},"text":"Aug. 3, 1956, ch. 926, § 1","children":[],"tail":" “Sec. 3 (less (d))”, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/980"},"text":"70 Stat. 980","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) of former section 803, providing for retroactive applicability, is omitted as executed (see Table II).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c2e4c9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8c2e4ca-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter II of chapter 7 of title 42, referred to in text, is section 401 et seq. of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c2e4cb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" substituted “Commissioner of Social Security” for “Secretary of Health, Education, and Welfare” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s1258/a/1"},"text":"Pub. L. 98–94, § 1258(a)(1)","children":[],"tail":", inserted “under 18 years of age” after “Civil Air Patrol Cadet”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/s1258/a/2"},"text":"Pub. L. 98–94, § 1258(a)(2)","children":[],"tail":", substituted “the rate of basic pay payable for step 1 of grade GS–9 in the General Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"” for “$300”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c2e4cc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c2e4cd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"Mar. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s110/a"},"text":"section 110(a) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c2e4ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94/tXII/s1258/b"},"text":"Pub. L. 98–94, title XII, § 1258(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/702"},"text":"97 Stat. 702","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/94/tXII/s1258/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by subsection (a)(1) [amending this section] shall apply only to deaths or injuries occurring on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by subsection (a)(2) [amending this section] shall apply only to the computation of compensation payable for periods commencing on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1983-09-24"},"text":"Sept. 24, 1983","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
