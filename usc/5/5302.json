{"tag":"section","attrib":{"id":"idb8387e4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302"},"text":"§ 5302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8387e4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “statutory pay system” means a pay system under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8387e4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter III, relating to the General Schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8387e4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 403 of the Foreign Service Act of 1980, relating to the Foreign Service of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8387e4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 74 of title 38, relating to the Veterans Health Administration (other than a position subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7451"},"text":"section 7451 of title 38","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “ECI” means the Employment Cost Index (wages and salaries, private industry workers) published quarterly by the Bureau of Labor Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the “base quarter” for any year is the 3-month period ending on September 30 of such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “pay agent” means the agent designated by the President under section 5304(d)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “locality” or “pay locality” means any locality, as established or modified under section 5304;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “pay disparity”, as used with respect to a locality, means the extent to which rates of pay payable under the General Schedule are generally lower than the rates paid for the same levels of work by non-Federal workers in the same locality; except as otherwise required in this subchapter, a pay disparity shall be expressed as a single percentage which, if uniformly applied to employees within the locality who are receiving rates of pay under the General Schedule, would cause the rates payable to such employees to become substantially equal (when considered in the aggregate) to the rates paid to non-Federal workers for the same levels of work in the same locality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “comparability payment” means a payment payable under section 5304;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “rates of pay under the General Schedule”, “rates of pay for the General Schedule”, or “scheduled rates of basic pay” means the rates of basic pay under the General Schedule as established by section 5332, excluding pay under section 5304 and any other additional pay of any kind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8387e56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “General Schedule position” means any position to which subchapter III applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8387e57-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":