{"tag":"section","attrib":{"id":"idb88e66bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5942a"},"text":"§ 5942a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate maintenance allowance for duty at Johnston Island","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb88e66be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of this title","children":[],"tail":", and under regulations prescribed by the President, an employee of an Executive agency (other than a Government corporation) who is assigned to a post of duty at Johnston Island, a possession of the United States in the Pacific Ocean, is entitled to receive a separate maintenance allowance if the head of the employing agency finds that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88e66bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it is necessary for the employee to maintain the employee’s spouse or dependents, or both, at a location other than Johnston Island—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb890d7c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of dangerous or adverse living conditions at Johnston Island; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb890d7c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the convenience of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb890d7c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allowance is needed to help the employee meet the additional expenses involved in maintaining the employee’s spouse or dependents, or both, at such other location rather than at the post.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb890d7c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5942a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations prescribed by the President shall include provisions for determining the rate at which an allowance under this section shall be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb890d7c4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1092/a/1"},"text":"Pub. L. 102–190, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1486"},"text":"105 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb890d7c5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb890d7c6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb890d7c7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1092/b"},"text":"Pub. L. 102–190, div. A, title X, § 1092(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1487"},"text":"105 Stat. 1487","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/190/dA/tX/s1092/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on the first day of the first month beginning on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb890d7c8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb890d7c9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section to prescribe regulations delegated to the Office of Personnel Management by section 8(4) of Ex. Ord. No. 11609, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
