":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":", see 1989 Amendment below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/280"},"text":"Pub. L. 101–280","children":[],"tail":", inserted “3393a,” after “1215,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12"},"text":"Pub. L. 101–12","children":[],"tail":" substituted “1215” for “1207”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" inserted provision referring to commissioned officers of the uniformed services serving on active duty in such agency in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81e66ba-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e66bb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applied as if effective "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":", to correspond to the effective date of the repeal of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of Title 10","children":[],"tail":", Armed Forces, to reflect the probable intent of Congress. See Effective Date of Repeal note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e66bc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e66bd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/d"},"text":"section 506(d) of Pub. L. 101–194","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3151"},"text":"section 3151 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},