{"tag":"section","attrib":{"id":"idb801b6d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134"},"text":null,"children":[{"tag":"num","attrib":{"value":"3134"},"text":"§ 3134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on noncareer and limited appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb801b6d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During each calendar year, each agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb801b6d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine its needs for employment of noncareer appointees for the fiscal year beginning in the following year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b6d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Office of Personnel Management, in accordance with regulations prescribed by the Office, a written request for authority to employ a specific number of noncareer appointees for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of noncareer appointees in each agency shall be determined annually by the Office on the basis of demonstrated need of the agency. The total number of noncareer appointees in all agencies may not exceed 10 percent of the total number of Senior Executive Service positions in all agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the 10 percent limitation of subsection (b) of this section, the Office may adjust the number of noncareer positions authorized for any agency under subsection (b) of this section if emergency needs arise that were not anticipated when the original authorizations were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of Senior Executive Service positions in any agency which are filled by noncareer appointees may not at any time exceed the greater of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb801b6d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the total number of Senior Executive Service positions in the agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb801b6d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of positions in the agency which were filled on the date of the enactment of the Civil Service Reform Act of 1978 by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb801b6d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncareer executive assignments under subpart F of part 305 of title 5, Code of Federal Regulations, as in effect on such date, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb801b6da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointments to level IV or V of the Executive Schedule which were not required on such date to be made by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection shall not apply in the case of any agency having fewer than 4 Senior Executive Service positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb801b6db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3134/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of limited emergency appointees and limited term appointees in all agencies may not exceed 5 percent of the total number of Senior Executive Service positions in all agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb801b6dc-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s402/a"},"text":"Pub. L. 95–454, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1159"},"text":"92 Stat. 1159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb801b6dd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb801b6de-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb801b6df-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Civil Service Reform Act of 1978, referred to in subsec. (d)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level IV or V of the Executive Schedule, referred to in subsec. (d)(2)(B), are set out in sections 5315 and 5316 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb801b6e0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb801b6e1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b), of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
