{"tag":"section","attrib":{"id":"idb8a8a5af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112"},"text":null,"children":[{"tag":"num","attrib":{"value":"7112"},"text":"§ 7112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of appropriate units for labor organization representation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a8a5b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Authority shall determine the appropriateness of any unit. The Authority shall determine in each case whether, in order to ensure employees the fullest freedom in exercising the rights guaranteed under this chapter, the appropriate unit should be established on an agency, plant, installation, functional, or other basis and shall determine any unit to be an appropriate unit only if the determination will ensure a clear and identifiable community of interest among the employees in the unit and will promote effective dealings with, and efficiency of the operations of the agency involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a8a5b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A unit shall not be determined to be appropriate under this section solely on the basis of the extent to which employees in the proposed unit have organized, nor shall a unit be determined to be appropriate if it includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a8a5b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7135/a/2"},"text":"section 7135(a)(2) of this title","children":[],"tail":", any management official or supervisor;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a confidential employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee engaged in personnel work in other than a purely clerical capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee engaged in administering the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both professional employees and other employees, unless a majority of the professional employees vote for inclusion in the unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee engaged in intelligence, counterintelligence, investigative, or security work which directly affects national security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee primarily engaged in investigation or audit functions relating to the work of individuals employed by an agency whose duties directly affect the internal security of the agency, but only if the functions are undertaken to ensure that the duties are discharged honestly and with integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a8a5b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee who is engaged in administering any provision of law relating to labor-management relations may not be represented by a labor organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a8a5ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which represents other individuals to whom such provision applies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is affiliated directly or indirectly with an organization which represents other individuals to whom such provision applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a8a5bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two or more units which are in an agency and for which a labor organization is the exclusive representative may, upon petition by the agency or labor organization, be consolidated with or without an election into a single larger unit if the Authority considers the larger unit to be appropriate. The Authority shall certify the labor organization as the exclusive representative of the new larger unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a8a5bd-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s701"},"text":"Pub. L. 95–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1200"},"text":"92 Stat. 1200","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/54"},"text":"Pub. L. 102–378, § 2(54)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1354"},"text":"106 Stat. 1354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a8a5be-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a8a5bf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a8a5c0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" struck out “(1)” after subsec. (a) designation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a8a5c1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a8a5c2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
