{"tag":"section","attrib":{"id":"idb937c5d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13141"},"text":null,"children":[{"tag":"num","attrib":{"value":"13141"},"text":"§ 13141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13141/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charitable organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “charitable organization” means an organization described in section 170(c) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c"},"text":"26 U.S.C. 170(c)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13141/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Honorarium","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “honorarium” means a payment of money or any thing of value for an appearance, speech or article (including a series of appearances, speeches, or articles if the subject matter is directly related to the individual’s official duties or the payment is made because of the individual’s status with the Government) by a Member, officer or employee, excluding any actual and necessary travel expenses incurred by such individual (and one relative) to the extent that such expenses are paid or reimbursed by any other person, and the amount otherwise determined shall be reduced by the amount of any such expenses to the extent that such expenses are not paid or reimbursed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13141/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Member” means a Senator in, a Representative in, or a Delegate or Resident Commissioner to, the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13141/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officer or employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “officer or employee” means any officer or employee of the Government except any special Government employee (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202"},"text":"section 202 of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13141/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “travel expenses” means, with respect to a Member, officer or employee, or a relative of any such individual, the cost of transportation, and the cost of lodging and meals while away from his or her residence or principal place of employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb937c5d6-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4302"},"text":"136 Stat. 4302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb937c5d7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb937c5d8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb937c5d9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children