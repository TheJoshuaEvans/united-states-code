{"tag":"section","attrib":{"id":"idb90a74d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8466a"},"text":"§ 8466a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Embezzlement or conversion of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90a74d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Embezzling and Conversion Generally.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a74d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for a representative payee to embezzle or in any manner convert all or any part of the amounts received from payments received as a representative payee to a use other than for the use and benefit of the minor or individual on whose behalf such payments were received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a74d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Office determines that a representative payee has embezzled or converted payments as described in paragraph (1), the Office shall promptly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90a74d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke the certification for payment of benefits to the representative payee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90a74da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certify payment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb90a74db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to another representative payee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90a74dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the interest of the individual under this title would be served thereby, to the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90a74dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8466a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates subsection (a)(1) shall be fined under title 18, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90a74de-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/126/s2/b/2"},"text":"Pub. L. 116–126, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/175"},"text":"134 Stat. 175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90a74df-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90a74e0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb90a74e1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on ","children":[{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", and applicable on and after the effective date of regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/pl/116/126/s3/b/1"},"text":"section 3(b)(1) of Pub. L. 116–126","children":[],"tail":", see sections 4 and 3(b) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/126"},"text":"Pub. L. 116–126","children":[],"tail":", set out respectively as an Effective Date of 2020 Amendment note and a Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb90a74e2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Regulations to carry out this section to be promulgated by Office of Personnel Management no later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", with allowance for additional regulations relating to administration of representative payee program, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/126/s3/b"},"text":"section 3(b) of Pub. L. 116–126","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
