{"tag":"section","attrib":{"id":"idb937c5c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13126"},"text":null,"children":[{"tag":"num","attrib":{"value":"13126"},"text":"§ 13126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall, no later than April 30 of each year in which the second session of a Congress begins, submit to the Congress a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13126/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the actions taken by the Director during a 2-year period ending on December 31 of the preceding year in order to carry out the Director’s functions and responsibilities under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13126/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Director may consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb937c5cb-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4302"},"text":"136 Stat. 4302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb937c5cc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb937c5cd-5e84-11f1-a692-