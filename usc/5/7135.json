{"tag":"section","attrib":{"id":"idb8ad5fef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7135"},"text":null,"children":[{"tag":"num","attrib":{"value":"7135"},"text":"§ 7135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of existing laws, recognitions, agreements, and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ad5ff0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing contained in this chapter shall preclude—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ad5ff1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the renewal or continuation of an exclusive recognition, certification of an exclusive representative, or a lawful agreement between an agency and an exclusive representative of its employees, which is entered into before the effective date of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ad5ff2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the renewal, continuation, or initial according of recognition for units of management officials or supervisors represented by labor organizations which historically or traditionally represent management officials or supervisors in private industry and which hold exclusive recognition for units of such officials or supervisors in any agency on the effective date of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ad5ff3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Policies, regulations, and procedures established under and decisions issued under Executive Orders 11491, 11616, 11636, 11787, and 11838, or under any other Executive order, as in effect on the effective date of this chapter, shall remain in full force and effect until revised or revoked by the President, or unless superseded by specific provisions of this chapter or by regulations or decisions issued pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ad5ff4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s701"},"text":"Pub. L. 95–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1215"},"text":"92 Stat. 1215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ad5ff5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ad5ff6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8ad5ff7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this chapter, referred to in text, as 90 days after the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Orders 11491, 11616, 11636, and 11838, referred to in subsec. (b), are set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7101"},"text":"section 7101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 11787, referred to in subsec. (b), which was set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701"},"text":"section 7701 of this title","children":[],"tail":", was revoked by Ex. Ord. No. 12553, "},{"tag":"date","attrib":{"date":"1986-02-25"},"text":"Feb. 25, 1986","children":[],"tail":", 51 F.R. 7237."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8ad5ff8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8ad5ff9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section