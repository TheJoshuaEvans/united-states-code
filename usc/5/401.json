t":"122 Stat. 2668","children":[],"tail":"; renumbered § 12, "},{"tag":"html:a","attrib":{"href":"/us/pl/110/409/s7/a"},"text":"Pub. L. 110–409, § 7(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4305"},"text":"122 Stat. 4305","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/113/126/tIV"},"text":"Pub. L. 113–126, title IV","children":[],"tail":", §§ 402(2), 412(2), "},{"tag":"html:span","attrib":{},"text":"July 7, 2014","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/128/1408"},"text":"128 Stat. 1408","children":[],"tail":", 1409; "},{"tag":"html:a","attrib":{"href":"/us/pl/115/141/dP/tV/s501/a/2"},"text":"Pub. L. 115–141, div. P, title V, § 501(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/132/1090"},"text":"132 Stat. 1090","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “Veterans Affairs” are inserted in the list of Departments, and the words “Veterans’ Administration” are deleted from the list of Administrations, to update obsolete references in the law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “the Resolution Trust Corporation” have been omitted as obsolete because section 21A(m)(1) of the Federal Home Loan Bank Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a/m/1"},"text":"12 U.S.C. 1441a(m)(1)","children":[],"tail":") provided for termination of the Resolution Trust Corporation not later than "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", and the authority and responsibilities of the Resolution Trust Corporation were transferred to the Federal Deposit Insurance Corporation under section 40(n)(4) of the Federal Deposit Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831q/n/4"},"text":"12 U.S.C. 1831q(n)(4)","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraphs (1) and (3), the words “of the United States” are inserted after “Export-Import Bank” to correct errors in the law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the words “Veterans Affairs” are inserted in the list of Secretaries, and the words “Veterans’ Affairs” are deleted from the list of Administrators, to update obsolete references in the law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the words “the Director of” are inserted before “the Office of Personnel Management” to correct an error in the law. The Office of Personnel Management is headed by a director (rather than an administrator) as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1102/a"},"text":"section 1102(a) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the words “the Chairperson of the Thrift Depositor Protection Oversight Board” are omitted because the Thrift Depositor Protection Oversight Board was abolished by section 14(a) through (d) of the Homeowners Protection Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/216"},"text":"Public Law 105–216","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/908"},"text":"112 Stat. 908","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the words “the chief executive officer of the Resolution Trust Corporation” are omitted because section 21A(m)(1) of the Federal Home Loan Bank Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1441a/m/1"},"text":"12 U.S.C. 1441a(m)(1)","children":[],"tail":") provided for termination of the Resolution Trust Corporation not later than "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", and the authority and responsibilities of the Resolution Trust Corporation were transferred to the Federal Deposit Insurance Corporation under section 40(n)(4) of the Federal Deposit Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1831q/n/4"},"text":"12 U.S.C. 1831q(n)(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb78cd486-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb78cd487-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452/s13"},"text":"Pub. L. 95–452, § 13","children":[],"tail":", formerly § 12, "},{"tag":"date","attrib":{"date":"1978-10-12"},"text":"Oct. 12, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1109"},"text":"92 Stat. 1109","children":[],"tail":", renumbered § 13 by "},{"tag":"ref","attrib":{"href":"/us/pl/110/409/s7/a"},"text":"Pub. L. 110–409, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4305"},"text":"122 Stat. 4305","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/409/s7/a"},"text":"“The provisions of this Act [see Tables for classification] and the amendments made by this Act [amending sections 5315 and 5316 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3522"},"text":"section 3522 of Title 42","children