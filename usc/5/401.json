] may be cited as the ‘Intelligence Community Whistleblower Protection Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb78cd48e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1988 Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504/tI/s101"},"text":"Pub. L. 100–504, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2515"},"text":"102 Stat. 2515","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/504/tI/s101"},"text":"“This title [see Tables for classification] may be cited as the ‘Inspector General Act Amendments of 1988’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb78cd48f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452/s1"},"text":"Pub. L. 95–452, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-12"},"text":"Oct. 12, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1101"},"text":"92 Stat. 1101","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/452/s1"},"text":"“That this Act [see Tables for classification] be cited as the ‘Inspector General Act of 1978’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb78cd490-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Merger of Office of Inspector General of United States Information Agency With Office of Inspector General of Department of State; Transfer of Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title IV], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–37; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/140/s1/a"},"text":"“That notwithstanding any other provision of law, (1) the Office of the Inspector General of the United States Information Agency is hereby merged with the Office of the Inspector General of the Department of State; (2) the functions exercised and assigned to the Office of the Inspector General of the United States Information Agency before the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":"] (including all related functions) are transferred to the Office of the Inspector General of the Department of State; and (3) the Inspector General of the Department of State shall also serve as the Inspector General of the United States Information Agency.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tIV"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title IV]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–47, provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tI/s101/a/tIV"},"text":"“That notwithstanding any other provision of law, the merger of the Office of Inspector General of the United States Information Agency with the Office of Inspector General of the Department of State provided for in the Departments of Commerce, Justice, and State, the Judiciary and Related Agencies Appropriations Act, 1996, contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Public Law 104–134","children":[],"tail":" [set out above], is effective hereafter.”"}],"tail":"\n]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For abolition of Office of Inspector General of the United States Information Agency and transfer of functions to Office of Inspector General of Department of State and Foreign Service, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6533"},"text":"section 6533 of Title 22","children":[],"tail":", Foreign Relations and Intercourse.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb78cd491-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payment Authority Subject to Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504/tI/s112"},"text":"Pub. L. 100–504, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2530"},"text":"102 Stat. 2530","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/504/tI/s112"},"text":"“Any authority to make payments under this title [see Tables for classification] shall be effective only to such extent as provided in appropriations Acts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
