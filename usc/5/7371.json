{"tag":"section","attrib":{"id":"idb8b48cc0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371"},"text":null,"children":[{"tag":"num","attrib":{"value":"7371"},"text":"§ 7371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory removal from employment of law enforcement officers convicted of felonies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b48cc1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48cc2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “conviction notice date” means the date on which an agency that employs a law enforcement officer has notice that the officer has been convicted of a felony that is entered by a Federal or State court, regardless of whether that conviction is appealed or is subject to appeal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48cc3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “law enforcement officer” has the meaning given that term under section 8331(20) or 8401(17).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48cc4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any law enforcement officer who is convicted of a felony shall be removed from employment as a law enforcement officer on the last day of the first applicable pay period following the conviction notice date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48cc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48cc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not prohibit the removal of an individual from employment as a law enforcement officer before a conviction notice date if the removal is properly effected other than under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48cc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not prohibit the employment of any individual in any position other than that of a law enforcement officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48cc8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the conviction is overturned on appeal, the removal shall be set aside retroactively to the date on which the removal occurred, with back pay under section 5596 for the period during which the removal was in effect, unless the removal was properly effected other than under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48cc9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48cca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If removal is required under this section, the agency shall deliver written notice to the employee as soon as practicable, and not later than 5 calendar days after the conviction notice date. The notice shall include a description of the specific reasons for the removal, the date of removal, and the procedures made applicable under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48ccb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The procedures under section 7513(b)(2), (3), and (4), (c), (d), and (e) shall apply to any removal under this section. The employee may use the procedures to contest or appeal a removal, but only with respect to whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b48ccc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee is a law enforcement officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48ccd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee was convicted of a felony; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48cce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conviction was overturned on appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48ccf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7371/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A removal required under this section shall occur on the date specified in subsection (b) regardless of whether the notice required under paragraph (1) of this subsection and the procedures made applicable under paragraph (2) of this subsection have been provided or completed by that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b48cd0-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/3/tVI/s639/a"},"text":"Pub. L. 106–554, § 1(a)(3) [title VI, § 639(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–168.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b48cd1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b48cd2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b48cd3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/3/tVI/s639/c"},"text":"Pub. L. 106–554, § 1(a)(3) [title VI, § 639(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–168, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/3/tVI/s639/c"},"text":"“The amendments made by this section [enacting this subchapter] shall take effect 30 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"] and shall apply to any conviction of a felony entered by a Federal or State court on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
