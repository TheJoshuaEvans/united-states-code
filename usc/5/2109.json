{"tag":"section","attrib":{"id":"idb7f35edb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109"},"text":"§ 2109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air traffic controller; Secretary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f35edc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “air traffic controller” or “controller” means a civilian employee of the Department of Transportation or the Department of Defense who, in an air traffic control facility or flight service station facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f35edd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is actively engaged—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7f35ede-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the separation and control of air traffic; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7f35edf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in providing preflight, inflight, or airport advisory service to aircraft operators; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f35ee0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the immediate supervisor of any employee described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f35ee1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2109/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary”, when used in connection with “air traffic controller” or “controller”, means the Secretary of Transportation with respect to controllers in the Department of Transportation, and the Secretary of Defense with respect to controllers in the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f35ee2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297/s1/a"},"text":"Pub. L. 92–297, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/141"},"text":"86 Stat. 141","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s1/a"},"text":"Pub. L. 96–347, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1150"},"text":"94 Stat. 1150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tII/s207/b"},"text":"Pub. L. 99–335, title II, § 207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/594"},"text":"100 Stat. 594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f35ee3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f35ee4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f35ee5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" amended par. (1) generally including within term “air traffic controller” or “controller” references to a flight service station facility and to employment providing preflight, inflight, or airport advisory service to aircraft operators and striking out provision that regulations prescribed by the Secretary be used in determining who is an air traffic controller."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347"},"text":"Pub. L. 96–347","children":[],"tail":" substituted “controller; Secretary” for “controller” in section catchline, and in text included employees of the Department of Defense within the meaning of air traffic controller or controller and defined “Secretary” to mean Secretary of Transportation with respect to controllers in the Department of Transportation and Secretary of Defense with respect to controllers in the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7f35ee6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","at