{"tag":"section","attrib":{"id":"idb8198510-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347"},"text":null,"children":[{"tag":"num","attrib":{"value":"3347"},"text":"§ 3347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8198511-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Sections 3345 and 3346 are the exclusive means for temporarily authorizing an acting official to perform the functions and duties of any office of an Executive agency (including the Executive Office of the President, and other than the Government Accountability Office) for which appointment is required to be made by the President, by and with the advice and consent of the Senate, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198512-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a statutory provision expressly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8198513-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizes the President, a court, or the head of an Executive department, to designate an officer or employee to perform the functions and duties of a specified office temporarily in an acting capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8198514-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designates an officer or employee to perform the functions and duties of a specified office temporarily in an acting capacity; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198515-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President makes an appointment to fill a vacancy in such office during the recess of the Senate pursuant to clause 3 of section 2 of article II of the United States Constitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8198516-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3347/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any statutory provision providing general authority to the head of an Executive agency (including the Executive Office of the President, and other than the Government Accountability Office) to delegate duties statutorily vested in that agency head to, or to reassign duties among, officers or employees of such Executive agency, is not a statutory provision to which subsection (a)(1) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8198517-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-613"},"text":"112 Stat. 2681–613","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/tV/s5011"},"text":"Pub. L. 106–31, title V, § 5011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/112"},"text":"113 Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8198518-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8198519-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb819851a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3347, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/426"},"text":"80 Stat. 426","children":[],"tail":", provided for Presidential authority relating to details, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-611"},"text":"112 Stat. 2681–611","children":[],"tail":", 2681–616, effective 30 days after "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb819851b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in introductory provisions of subsec. (a) and in subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31"},"text":"Pub. L. 106–31","children":[],"tail":" substituted “subsection (a)(1)” for “subsection (a)(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb819851c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb819851d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and applicable to any office that becomes vacant after such effective date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s151/d"},"text":"section 151(d) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
