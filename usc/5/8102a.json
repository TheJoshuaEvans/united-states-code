{"tag":"section","attrib":{"id":"idb8be2958-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102a"},"text":"§ 8102a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death gratuity for injuries incurred in connection with employee’s service with an Armed Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be2959-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Death Gratuity Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States shall pay a death gratuity of up to $100,000 to or for the survivor prescribed by subsection (d) immediately upon receiving official notification of the death of an employee who dies of injuries incurred in connection with the employee’s service with an Armed Force in a contingency operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be295a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retroactive Payment in Certain Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the discretion of the Secretary concerned, subsection (a) may apply in the case of an employee who died, on or after ","children":[{"tag":"date","attrib":{"date":"2001-10-07"},"text":"October 7, 2001","children":[],"tail":", and before the date of enactment of this section, as a result of injuries incurred in connection with the employee’s service with an Armed Force in the theater of operations of Operation Enduring Freedom or Operation Iraqi Freedom."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be295b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The death gratuity payable under this section shall be reduced by the amount of any death gratuity provided under section 413 of the Foreign Service Act of 1980, section 1603 of the Emergency Supplemental Appropriations Act for Defense, the Global War on Terror, and Hurricane Recovery, 2006, or any other law of the United States based on the same death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be295c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Survivors.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be295d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (5), a death gratuity payable upon the death of a person covered by subsection (a) shall be paid to or for the living survivor highest on the following list:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8be295e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be295f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s children, as prescribed by paragraph (2), in equal shares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2960-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If designated by the employee, any one or more of the following persons:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8be2961-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s parents or persons in loco parentis, as prescribed by paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be2962-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s brothers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be2963-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s sisters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2964-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s parents or persons in loco parentis, as prescribed by paragraph (3), in equal shares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2965-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee’s brothers and sisters in equal shares.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Subparagraphs (C) and (E) of this paragraph include brothers and sisters of the half blood and those through adoption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2966-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1)(B) applies, without regard to age or marital status, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8be2967-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legitimate children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2968-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopted children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be2969-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stepchildren who were a part of the decedent’s household at the time of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be296a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illegitimate children of a female decedent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be296b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" illegitimate children of a male decedent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8be296c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have been acknowledged in writing signed by the decedent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be296d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have been judicially determined, before the decedent’s death, to be his children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be296e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who have been otherwise proved, by evidence satisfactory to the employing agency, to be children of the decedent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be296f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whose support the decedent had been judicially ordered to contribute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2970-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraphs (C) and (D) of paragraph (1), so far as they apply to parents and persons in loco parentis, include fathers and mothers through adoption, and persons who stood in loco parentis to the decedent for a period of not less than one year at any time before the decedent became an employee. However, only one father and one mother, or their counterparts in loco parentis, may be recognized in any case, and preference shall be given to those who exercised a parental relationship on the date, or most nearly before the date, on which the decedent became an employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2971-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person covered by this section may designate another person to receive an amount payable under this section. The designation shall indicate the percentage of the amount, to be specified only in 10 percent increments, that the designated person may receive. The balance of the amount of the death gratuity shall be paid to or for the living survivors of the person concerned in accordance with subparagraphs (A) through (E) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2972-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person entitled to all or a portion of a death gratuity under paragraph (1) or (4) dies before the person receives the death gratuity, it shall be paid to the living survivor next in the order prescribed by paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2973-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person covered by this section has a spouse, but designates a person other than the spouse to receive all or a portion of the amount payable under this section, the head of the agency, or other entity, in which that person is employed shall provide notice of the designation to the spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be2974-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be2975-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “contingency operation” has the meaning given to that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1482a/c"},"text":"section 1482a(c) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2976-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “employee” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":", but also includes a nonappropriated fund instrumentality employee, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1587/a/1"},"text":"section 1587(a)(1) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be2977-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXI/s1105/a"},"text":"Pub. L. 110–181, div. A, title XI, § 1105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/347"},"text":"122 Stat. 347","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1121/a/1"},"text":"Pub. L. 112–81, div. A, title XI, § 1121(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1616"},"text":"125 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be2978-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8be2979-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8be297a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 413 of the Foreign Service Act of 1980, referred to in subsec. (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3973"},"text":"section 3973 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1603 of the Emergency Supplemental Appropriations Act for Defense, the Global War on Terror, and Hurricane Recovery, 2006, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/234/s1603"},"text":"section 1603 of Pub. L. 109–234","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2006-06-15"},"text":"June 15, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/443"},"text":"120 Stat. 443","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (d)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8be297b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1121/a/1"},"text":"Pub. L. 112–81, § 1121(a)(1)","children":[],"tail":", substituted “A person covered by this section may designate another person to receive an amount payable under this section.” for “Beginning on the date of the enactment of this paragraph, a person covered by this section may designate another person to receive not more than 50 percent of the amount payable under this section.” and struck out “up to the maximum of 50 percent” after “increments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s1121/b"},"text":"Pub. L. 112–81, § 1121(b)","children":[],"tail":", added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8be297c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8be297d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1121/a/2"},"text":"Pub. L. 112–81, div. A, title XI, § 1121(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1616"},"text":"125 Stat. 1616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/81/dA/tXI/s1121/a/2"},"text":"“The amendments made by this subsection [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":"] and apply to the payment of a death gratuity based on any death occurring on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
