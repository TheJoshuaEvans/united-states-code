{"tag":"section","attrib":{"id":"idb9165b0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716"},"text":null,"children":[{"tag":"num","attrib":{"value":"8716"},"text":"§ 8716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9165b0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may prescribe regulations necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9165b0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations of the Office may prescribe the time at which and the conditions under which an employee is eligible for coverage under this chapter. The Office, after consulting the head of the agency or other employing authority concerned, may exclude an employee on the basis of the nature and type of his employment or conditions pertaining to it, such as short-term appointment, seasonal, intermittent employment, and employment of like nature. The Office may not exclude—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9165b0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee or group of employees solely on the basis of the hazardous nature of employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9165b10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a teacher in the employ of the Board of Education of the District of Columbia, whose pay is fixed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1501"},"text":"section 1501 of title 31","children":[],"tail":", District of Columbia Code, on the basis of the fact that the teacher is serving under a temporary appointment if the teacher has been so employed by the Board for a period or periods totaling not less than two school years; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9165b11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee who is occupying a position on a part-time career employment basis (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3401/2"},"text":"section 3401(2) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9165b12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8716/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall prescribe regulations to effect the application and operation of this chapter to an individual named by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8701/a/8"},"text":"section 8701(a)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9165b13-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/599"},"text":"80 Stat. 59