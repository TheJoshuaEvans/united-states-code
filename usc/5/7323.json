{"tag":"section","attrib":{"id":"idb8b21bb6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323"},"text":null,"children":[{"tag":"num","attrib":{"value":"7323"},"text":"§ 7323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political activity authorized; prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b21bb7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the provisions of subsection (b), an employee may take an active part in political management or in political campaigns, except an employee may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21bb8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use his official authority or influence for the purpose of interfering with or affecting the result of an election;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bb9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly solicit, accept, or receive a political contribution from any person, unless such person is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21bba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the same Federal labor organization as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103/4"},"text":"section 7103(4) of this title","children":[],"tail":" or a Federal employee organization which as of the date of enactment of the Hatch Act Reform Amendments of 1993 had a multicandidate political committee (as defined under section 315(a)(4) of the Federal Election Campaign Act of 1971 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s441a/a/4"},"text":"2 U.S.C. 441a(a)(4)","children":[],"tail":")); "},{"tag":"ref","attrib":{"idref":"fn002134"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002134"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bbb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a subordinate employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bbc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the solicitation is for a contribution to the multicandidate political committee (as defined under section 315(a)(4) of the Federal Election Campaign Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s441a/a/4"},"text":"2 U.S.C. 441a(a)(4)","children":[],"tail":")) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of such Federal labor organization as defined under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103/4"},"text":"section 7103(4) of this title","children":[],"tail":" or a Federal employee organization which as of the date of the enactment of the Hatch Act Reform Amendments of 1993 had a multicandidate political committee (as defined under section 315(a)(4) of the Federal Election Campaign Act of 1971 ("},{"tag":"ref","attrib":{"href":"/us/usc/t2/s441a/a/4"},"text":"2 U.S.C. 441a(a)(4)","children":[],"tail":")); "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bbd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" run for the nomination or as a candidate for election to a partisan political office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bbe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly solicit or discourage the participation in any political activity of any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21bbf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an application for any compensation, grant, contract, ruling, license, permit, or certificate pending before the employing office of such employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bc0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the subject of or a participant in an ongoing audit, investigation, or enforcement action being carried out by the employing office of such employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b21bc1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21bc2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the Federal Election Commission (except one appointed by the President, by and with the advice and consent of the Senate), may not request or receive from, or give to, an employee, a Member of Congress, or an officer of a uniformed service a political contribution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bc3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21bc4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No employee described under subparagraph (B) (except one appointed by the President, by and with the advice and consent of the Senate), may take an active part in political management or political campaigns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The provisions of subparagraph (A) shall apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b21bc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an employee of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8b21bc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Election Commission or the Election Assistance Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bc8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bc9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secret Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bcb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bcc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bcd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Merit Systems Protection Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bcf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Special Counsel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bd0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Criminal Investigation of the Internal Revenue Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bd1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/XI"},"text":null,"children":[{"tag":"num","attrib":{"value":"XI"},"text":"(XI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Investigative Programs of the United States Customs Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bd2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/XII"},"text":null,"children":[{"tag":"num","attrib":{"value":"XII"},"text":"(XII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Law Enforcement of the Bureau of Alcohol, Tobacco, and Firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bd3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/XIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"XIII"},"text":"(XIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Geospatial-Intelligence Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b21bd4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/i/XIV"},"text":null,"children":[{"tag":"num","attrib":{"value":"XIV"},"text":"(XIV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Director of National Intelligence; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b21bd5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person employed in a position described under section 3132(a)(4), 5372, 5372a, or 5372b of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bd6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No employee of the Criminal Division or National Security Division of the Department of Justice (except one appointed by the President, by and with the advice and consent of the Senate), may take an active part in political management or political campaigns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bd7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term “active part in political management or in a political campaign” means those acts of political management or political campaigning which were prohibited for employees of the competitive service before ","children":[{"tag":"date","attrib":{"date":"1940-07-19"},"text":"July 19, 1940","children":[],"tail":", by determinations of the Civil Service Commission under the rules prescribed by the President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b21bd8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee retains the right to vote as he chooses and to express his opinion on political subjects and candidates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21bd9-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94/s2/a"},"text":"Pub. L. 103–94, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1002"},"text":"107 Stat. 1002","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s501/k"},"text":"Pub. L. 103–359, title V, § 501(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3430"},"text":"108 Stat. 3430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1122/a/1"},"text":"Pub. L. 104–201, div. A, title XI, § 1122(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2687"},"text":"110 Stat. 2687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/3/tVI/s645/a/2"},"text":"Pub. L. 106–554, § 1(a)(3) [title VI, § 645(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–170; "},{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVIII/s811/a"},"text":"Pub. L. 107–252, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1727"},"text":"116 Stat. 1727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tI/s1079/a"},"text":"Pub. L. 108–458, title I, § 1079(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3695"},"text":"118 Stat. 3695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s506/b/2"},"text":"Pub. L. 109–177, title V, § 506(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/249"},"text":"120 Stat. 249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 931(a)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4575"},"text":"122 Stat. 4575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b21bda-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b21bdb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8b21bdc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Hatch Act Reform Amendments of 1993, referred to in subsec. (a)(2)(A), (C), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Election Campaign Act of 1971, referred to in subsec. (a)(2)(A), (C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/3"},"text":"86 Stat. 3","children":[],"tail":", which was formerly classified principally to chapter 14 (§ 431 et seq.) of Title 2, The Congress, prior to editorial reclassification and renumbering in Title 52, Voting and Elections, and is now classified principally to chapter 301 (§ 30101 et seq.) of Title 52. Section 315 of this Act is now classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30116"},"text":"section 30116 of Title 52","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8b21bdd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7323, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/525"},"text":"80 Stat. 525","children":[],"tail":", prohibited employee in Executive agency from requesting, receiving from, or giving to, an employee, a Member of Congress, or an officer of a uniformed service, a thing of value for political purposes and provided for removal from service of employee for violation, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b21bde-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2)(B)(i)(XIII). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" inserted “or National Security Division” after “Criminal Division”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2)(B)(i)(XIV). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" added subcl. (XIV)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2)(B)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":" inserted “or the Election Assistance Commission” after “Commission”."}],"tail":"\n"},{"tag"