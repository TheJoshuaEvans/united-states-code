{"tag":"section","attrib":{"id":"idb8fe8d73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d"},"text":null,"children":[{"tag":"num","attrib":{"value":"8432d"},"text":"§ 8432d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified Roth contribution program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fe8d74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified Roth contribution program” means a program described in paragraph (1) of section 402A(b) of the Internal Revenue Code of 1986 which meets the requirements of paragraph (2) of such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “designated Roth contribution” and “elective deferral” have the meanings given such terms in section 402A of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Establish","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Director shall by regulation provide for the inclusion in the Thrift Savings Plan of a qualified Roth contribution program, under such terms and conditions as the Board may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations under subsection (b) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provisions under which an election to make designated Roth contributions may be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any individual who is eligible to make contributions under section 8351, 8432(a), 8440a, 8440b, 8440c, 8440d, or 8440e; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any individual, not described in subparagraph (A), who is otherwise eligible to make elective deferrals under the Thrift Savings Plan;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provisions which may, as a result of enactment of this section, be necessary in order to clarify the meaning of any reference to an “account” made in section 8432(f), 8433, 8434(d), 8435, 8437, or any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provisions which may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fe8d7e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/31/dB/tI/s103/a"},"text":"Pub. L. 111–31, div. B, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-22"},"text":"June 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1853"},"text":"123 Stat. 1853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fe8d7f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fe8d80-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8fe8d81-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 402A of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s402A"},"text":"section 402A of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
