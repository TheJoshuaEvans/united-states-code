{"tag":"section","attrib":{"id":"idb7bc97e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579"},"text":null,"children":[{"tag":"num","attrib":{"value":"579"},"text":"§ 579.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitration proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7bc97ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The arbitrator shall set a time and place for the hearing on the dispute and shall notify the parties not less than 5 days before the hearing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc97eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any party wishing a record of the hearing shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc97ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the preparation of such record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the other parties and the arbitrator of the preparation of such record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish copies to all identified parties and the arbitrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay all costs for such record, unless the parties agree otherwise or the arbitrator determines that the costs should be apportioned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc97f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc97f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The parties to the arbitration are entitled to be heard, to present evidence material to the controversy, and to cross-examine witnesses appearing at the hearing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The arbitrator may, with the consent of the parties, conduct all or part of the hearing by telephone, television, computer, or other electronic means, if each party has an opportunity to participate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The hearing shall be conducted expeditiously and in an informal manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The arbitrator may receive any oral or documentary evidence, except that irrelevant, immaterial, unduly repetitious, or privileged evidence may be excluded by the arbitrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The arbitrator shall interpret and apply relevant statutory and regulatory requirements, legal precedents, and policy directives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc97f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No interested person shall make or knowingly cause to be made to the arbitrator an unauthorized ex parte communication relevant to the merits of the proceeding, unless the parties agree otherwise. If a communication is made in violation of this subsection, the arbitrator shall ensure that a memorandum of the communication is prepared and made a part of the record, and that an opportunity for rebuttal is allowed. Upon receipt of a communication made in violation of this subsection, the arbitrator may, to the extent consistent with the interests of justice and the policies underlying this subchapter, require the offending party to show cause why the claim of such party should not be resolved against such party as a result of the improper conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc97f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The arbitrator shall make the award within 30 days after the close of the hearing, or the date of the filing of any briefs authorized by the arbitrator, whichever date is later, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc97f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties agree to some other time limit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s579/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency provides by rule for some other time limit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7bc97fa-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/552/s4/b"},"text":"Pub. L. 101–552, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2742"},"text":"104 Stat. 2742","children":[],"tail":", § 589; renumbered § 579, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bc97fb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bc97fc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bc97fd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s589"},"text":"section 589 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
