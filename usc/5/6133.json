{"tag":"section","attrib":{"id":"idb8959314-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133"},"text":null,"children":[{"tag":"num","attrib":{"value":"6133"},"text":"§ 6133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; technical assistance; program review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8959315-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall prescribe regulations necessary for the administration of the programs established under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8959316-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8959317-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall provide educational material, and technical aids and assistance, for use by an agency in connection with establishing and maintaining programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8959318-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to provide the most effective materials, aids, and assistance under paragraph (1), the Office shall conduct periodic reviews of programs established by agencies under this subchapter particularly insofar as such programs may affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8959319-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficiency of Government operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb895931a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mass transit facilities and traffic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb895931b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levels of energy consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb895931c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb895931d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased opportunities for full-time and part-time employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb895931e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees’ job satisfaction and nonworklife.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb895931f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8959320-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to employees in the Library of Congress, the authority granted to the Office of Personnel Management under this subchapter shall be exercised by the Librarian of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8959321-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to employees in the Government Publishing Office, the authority granted to the Office of Personnel Management under this subchapter shall be exercised by the Director of the Government Publishing Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8959322-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6133/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to employees of the Architect of the Capitol and the Botanic Garden, the authority granted to the Office of Personnel Management under this subchapter shall be exercised by the Architect of the Capitol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8959323-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/221/s2/a/2"},"text":"Pub. L. 97–221, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date"