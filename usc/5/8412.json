{"tag":"section","attrib":{"id":"idb8f4f131-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412"},"text":null,"children":[{"tag":"num","attrib":{"value":"8412"},"text":"§ 8412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f4f132-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is separated from the service after attaining the applicable minimum retirement age under subsection (h) and completing 30 years of service is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f133-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is separated from the service after becoming 60 years of age and completing 20 years of service is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f134-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is separated from the service after becoming 62 years of age and completing 5 years of service is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f135-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f4f136-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who is separated from the service, except by removal for cause on charges of misconduct or delinquency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f4f137-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completing 25 years of service as a law enforcement officer, member of the Capitol Police or Supreme Court Police, firefighter, nuclear materials courier, or customs and border protection officer, or any combination of such service totaling at least 25 years, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f138-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after becoming 50 years of age and completing 20 years of service as a law enforcement officer, member of the Capitol Police or Supreme Court Police, firefighter, nuclear materials courier, or customs and border protection officer, or any combination of such service totaling at least 20 years,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f4f139-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f4f13a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f4f13b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “affected individual” means an individual covered under this chapter who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8f4f13c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is performing service in a covered position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f4f13d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while on duty, becomes ill or is injured as a direct result of the performance of such duties before the date on which the individual becomes entitled to an annuity under paragraph (1) of this subsection or subsection (e), as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f4f13e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the illness or injury described in subclause (II), is permanently unable to render useful and efficient service in the employee’s covered position, as determined by the agency in which the individual was serving when such individual incurred the illness or injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f4f13f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is appointed to a position in the civil service that—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb8f4f140-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i/IV/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a covered position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb8f4f141-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/i/IV/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is within an agency that regularly appoints individuals to supervisory or administrative positions related to the activities of the former covered position of the individual;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f4f142-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered position” means a position as a law enforcement officer, customs and border protection officer, firefighter, air traffic controller, nuclear materials courier, member of the Capitol Police, or member of the Supreme Court Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f143-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless an affected individual files an election described in subparagraph (E), creditable service by the affected individual in a position described in subparagraph (A)(i)(IV) shall be treated as creditable service in a covered position for purposes of this chapter and determining the amount to be deducted and withheld from the pay of the affected individual under section 8422.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f144-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (B) shall only apply if the affected employee transitions to a position described in subparagraph (A)(i)(IV) without a break in service exceeding 3 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f145-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The service of an affected individual shall no longer be eligible for treatment under subparagraph (B) if such service occurs after the individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f4f146-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transferred to a supervisory or administrative position related to the activities of the former covered position of the individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f4f147-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the age and service requirements that would subject the individual to mandatory separation under section 8425 if such individual had remained in the former covered position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f148-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In accordance with procedures established by the Director of the Office of Personnel Management, an affected individual may file an election to have any creditable service performed by the affected individual treated in accordance with this chapter without regard to subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f149-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this paragraph shall be construed to apply to such affected individual any other pay-related laws or regulations applicable to a covered position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f14a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who is separated from the service, except by removal for cause on charges of misconduct or delinquency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f4f14b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completing 25 years of service as an air traffic controller, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f4f14c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after becoming 50 years of age and completing 20 years of service as an air traffic controller,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f14d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Member who is separated from the service, except by resignation or expulsion—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f4f14e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completing 25 years of service, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f4f14f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after becoming 50 years of age and completing 20 years of service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f150-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f4f151-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is separated from the service after attaining the applicable minimum retirement age under subsection (h) and completing 10 years of service is entitled to an annuity. This subsection shall not apply to an employee or Member who is entitled to an annuity under any other provision of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f4f152-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member entitled to an annuity under this subsection may defer the commencement of such annuity by written election. The date to which the commencement of the annuity is deferred may not precede the 31st day after the date of filing the election, and must precede the date on which the employee or Member becomes 62 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f4f153-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall prescribe regulations under which an election under paragraph (2) shall be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f4f154-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f4f155-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The applicable minimum retirement age under this subsection is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f4f156-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an individual whose date of birth is before ","children":[{"tag":"date","attrib":{"date":"1948-01-01"},"text":"January 1, 1948","children":[],"tail":", 55 years of age;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f157-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an individual whose date of birth is after ","children":[{"tag":"date","attrib":{"date":"1947-12-31"},"text":"December 31, 1947","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1953-01-01"},"text":"January 1, 1953","children":[],"tail":", 55 years of age plus the number of months in the age increase factor determined under paragraph (2)(A);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f158-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an individual whose date of birth is after ","children":[{"tag":"date","attrib":{"date":"1952-12-31"},"text":"December 31, 1952","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":", 56 years of age;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f159-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an individual whose date of birth is after ","children":[{"tag":"date","attrib":{"date":"1964-12-31"},"text":"December 31, 1964","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"January 1, 1970","children":[],"tail":", 56 years of age plus the number of months in the age increase factor determined under paragraph (2)(B); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f15a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for an individual whose date of birth is after ","children":[{"tag":"date","attrib":{"date":"1969-12-31"},"text":"December 31, 1969","children":[],"tail":", 57 years of age."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f4f15b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f4f15c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For an individual whose date of birth occurs during the 5-year period consisting of calendar years 1948 through 1952, the age increase factor shall be equal to two-twelfths times the number of months in the period beginning with January 1948 and ending with December of the year in which the date of birth occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f4f15d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8412/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For an individual whose date of birth occurs during the 5-year period consisting of calendar years 1965 through 1969, the age increase factor shall be equal to two-twelfths times the number of months in the period beginning with January 1965 and ending with December of the year in which the date of birth occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f4f15e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/524"},"text":"100 Stat. 524","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/556/tI/s105/a"},"text":"Pub. L. 99–556, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3131"},"text":"100 Stat. 3131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/428/s3/a"},"text":"Pub. L. 101–428, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-15"},"text":"Oct. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/929"},"text":"104 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXI/s3154/g"},"text":"Pub. L. 105–261, div. C, title XXXI, § 3154(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2255"},"text":"112 Stat. 2255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIII/s308/c/1"},"text":"Pub. L. 106–553, § 1(a)(2) [title III, § 308(c)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"tex