{"tag":"section","attrib":{"id":"idb8800e73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5706b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5706b"},"text":"§ 5706b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interview expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An individual being considered for employment by an agency may be paid travel or transportation expenses under this subchapter for travel to and from pre-employment interviews determined necessary by the agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8800e74-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tII/s206/a/1"},"text":"Pub. L. 101–509, title V, § 529 [title II, § 206(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1457.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8800e75-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8800e76-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8800e77-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990"