s/stat/68/1109"},"text":"68 Stat. 1109","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s933"},"text":"5 U.S.C. 933","children":[],"tail":" (as applicable to "},{"tag":"html:a","attrib":{"href":"/us/usc/t5/s673c"},"text":"5 U.S.C. 673c","children":[],"tail":")."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-06-30/ch212/s503"},"text":"June 30, 1945, ch. 212, § 503","children":[],"tail":" (as applicable to "},{"tag":"html:a","attrib":{"href":"/us/act/1934-03-28/ch102/s23"},"text":"§ 23 of the Act of Mar. 28, 1934, ch. 102","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/522"},"text":"48 Stat. 522","children":[],"tail":", as amended), "},{"tag":"html:a","attrib":{"href":"/us/stat/59/301"},"text":"59 Stat. 301","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), former sections 673c (2d proviso) and 913 are combined and restated for clarity and conciseness. The last 28 words of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/s205/a"},"text":"section 205(a) of the Act of Sept. 1, 1954","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1109"},"text":"68 Stat. 1109","children":[],"tail":", are omitted as executed and covered by technical section 8."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is restated to conform to subsection (a). In former section 933, the words “Classification Act of 1949” were substituted for “Classification Act of 1923” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782/s1106/a"},"text":"section 1106(a) of the Act of Oct. 28, 1949, ch. 782","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/972"},"text":"63 Stat. 972","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86cfc25-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86cfc26-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5544(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 673c (last proviso of 1st par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/504/s405/f"},"text":"Pub. L. 89–504, § 405(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/298"},"text":"80 Stat. 298","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “a part of which is on Sunday” are coextensive with and substituted for “any part of which is within the period commencing at midnight Saturday and ending at midnight Sunday.” The words “is entitled to additional pay” are coextensive with and substituted for “shall be paid extra compensation.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86cfc27-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb86cfc28-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7 of the Fair Labor Standards Act of 1938, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s207"},"text":"section 207 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb86cfc29-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/4"},"text":"Pub. L. 119–4","children":[],"tail":" is based on section 457(b)(1) of of H.R. 8998, from the 118th Congress (Department of the Interior, Environment, and Related Congress, Agencies Appropriations Act, 2025), as passed by the House of Representatives on "},{"tag":"date","attrib":{"date":"2024-07-24"},"text":"July 24, 2024","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/s1807"},"text":"section 1807 of div. A of Pub. L. 119–4","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86cfc2a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/4"},"text":"Pub. L. 119–4","children":[],"tail":" amended section catchline generally, substituting “Wage-board overtime, Sunday rates, and other premium pay” for “Wage-board overtime and Sunday rates; computation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/4"},"text":"Pub. L. 119–4","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":", in third sentence of concluding provisions, substituted “administratively (including travel by the employee to such event and the return of the employee from such event to the employee’s official duty station).” for “administratively.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", which directed the amendment of subsec. (a) by inserting after the fourth sentence “For employees serving outside the United States in areas where Sunday is a routine workday and another day of the week is officially recognized as the day of rest and worship, the Secretary of State may designate the officially recognized day of rest and worship as the day with respect to which the preceding sentence shall apply instead of Sunday.”, was executed by making the insertion after the first sentence of the concluding provisions, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" inserted “and the provisions of section 5543(b)” after “the last two sentences of subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/42/B"},"text":"Pub. L. 102–378, § 2(42)(B)","children":[],"tail":", amended last two sentences generally. Prior to amendment, last two sentences read as follows: “This section, other than the sixth sentence, shall not be applicable to an employee who is subject to the overtime pay provisions of section 7 of the Fair Labor Standards Act of 1938. In the case of an employee who would, were it not for the preceding sentence, be subject to this section, hours of work in excess of 8 hours in a day shall be deemed to be overtime hours for the purposes of such section 7 and hours in a paid nonwork status shall be deemed to be hours of work.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/42/A"},"text":"Pub. L. 102–378, § 2(42)(A)","children":[],"tail":", substituted “2,087” for “2,080”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/42/C"},"text":"Pub. L. 102–378, § 2(42)(C)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" inserted at end “This section, other than the sixth sentence, shall not be applicable to an employee who is subject to the overtime pay provisions of section 7 of the Fair Labor Standards Act of 1938. In the case of an employee who would, were it not for the preceding sentence, be subject to this section, hours of work in excess of 8 hours in a day shall be deemed to be overtime hours for the purposes of such section 7 and hours in a paid nonwork status shall be deemed to be hours of work.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":" substituted “pay” for “basic pay” and provided for determination of pay under section 5343 or 5349 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":" provided that time spent in a travel status away from the official duty station could not qualify as hours of work unless the travel involved the performance of work while traveling, was incident to travel involving the performance of work while traveling, carried out under arduous conditions, or resulting from an event which could not be scheduled or controlled administratively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86cfc2b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86cfc2c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 457(d) of H.R. 8998, from the 118th Congress, as passed by the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"2024-07-24"},"text":"July 24, 2024","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/tVIII/s1807"},"text":"Pub. L. 119–4, div. A, title VIII, § 1807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/30"},"text":"139 Stat. 30","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/4/dA/tVIII/s1807"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5545c"},"text":"section 5545c of this title","children":[],"tail":" and amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5547"},"text":"section 5547 of this title","children":[],"tail":"] shall take effect on the first day of the first applicable pay period beginning on or after either "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":" or the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":"], whichever is later.”"}],"tail":"\n"}],"tail":"\n"}],