4/s414/a/2/B"},"text":"Pub. L. 95–454, § 414(a)(2)(B)","children":[],"tail":", substituted provisions authorizing the Director to establish the maximum number of scientific or professional positions, excepting Senior Executive Service positions, and authorizing the Librarian to establish not more than 8 such positions for provisions authorizing the head of certain named agencies to establish a specified number of scientific or professional positions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s414/a/2/B"},"text":"Pub. L. 95–454, § 414(a)(2)(B)","children":[],"tail":", (C), struck out subsec. (b), redesignated subsec. (c) as (b), and substituted in subsec. (b), as redesignated, “to fix under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5361"},"text":"section 5361 of this title","children":[],"tail":" the pay for positions established under this section” for “to establish and fix the pay of positions under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5361"},"text":"section 5361 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s801/a/3/C"},"text":"Pub. L. 95–454, § 801(a)(3)(C)","children":[],"tail":", substituted in subsec. (b), as redesignated, “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5371"},"text":"section 5371 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5361"},"text":"section 5361 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s414/a/2/C/i"},"text":"Pub. L. 95–454, § 414(a)(2)(C)(i)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" r