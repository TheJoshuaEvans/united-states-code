{"tag":"section","attrib":{"id":"idb8b9477f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901"},"text":null,"children":[{"tag":"num","attrib":{"value":"7901"},"text":"§ 7901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health service programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b94780-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency of the Government of the United States may establish, within the limits of appropriations available, a health service program to promote and maintain the physical and mental fitness of employees under his jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b94781-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A health service program may be established by contract or otherwise, but only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b94782-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consultation with the Secretary of Health, Education, and Welfare and consideration of its recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b94783-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in localities where there are a sufficient number of employees to warrant providing the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b94784-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A health service program is limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b94785-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment of on-the-job illness and dental conditions requiring emergency attention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b94786-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preemployment and other examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b94787-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referral of employees to private physicians and dentists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b94788-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventive programs relating to health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b94789-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Health, Education, and Welfare, on request, shall review a health service program conducted under this section and shall submit comment and recommendations to the head of the agency concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b9478a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When this section authorizes the use of the professional services of physicians, that authorization includes the use of the professional services of surgeons and osteopathic practitioners within the scope of their practice as defined by State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b9478b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7901/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The health programs conducted by the Tennessee Valley Authority are not affected by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b9478c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/530"},"text":"80 Stat. 530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/47"},"text":"Pub. L. 90–83, § 1(47)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/209"},"text":"81 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3548/a/9"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3548(a)(9)","children":[],"t