{"tag":"section","attrib":{"id":"idb8c52e92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8152"},"text":null,"children":[{"tag":"num","attrib":{"value":"8152"},"text":"§ 8152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall, at the end of each fiscal year, prepare a report with respect to the administration of this chapter. Such report shall be submitted to Congress in accordance with the requirement with respect to submission under section 42 of the Longshore ","children":[{"tag":"ref","attrib":{"idref":"fn002148"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002148"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Longshore and”."}],"tail":" Harbor Workers’ Compensation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s942"},"text":"33 U.S.C. 942","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8c52e93-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1102/b/3/A"},"text":"Pub. L. 104–66, title I, § 1102(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/723"},"text":"109 Stat. 723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c52e94-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c52e95-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c52e96-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Affected Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIII/s5305/a/5"},"text":"Pub. L. 117–263, div. E, title LIII, § 5305(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3254"},"text":"136 Stat. 3254","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIII/s5305/a/5"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Beginning on the date that is 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], with respect to each annual report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8152"},"text":"section 8152 of title 5","children":[],"tail":", United States Code, the Secretary [of Labor]—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include in the report the total number of, and demographics regarding, employees in fire protection activities with illnesses and diseases described in the list (as the list may be updated under this subsection [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143b"},"text":"section 8143b of this title","children":[],"tail":" and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143b"},"text":"section 8143b of this title","children":[],"tail":"] and the amendments made by this subsection), as of the date on which that annual report is submitted, which shall be disaggregated by the specific illness or disease for the purposes of understanding the scope of the problem facing those employees; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the report any information with respect to employees in fire protection activities that the Secretary determines to be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, make recommendations in the report for additional actions that could be taken to minimize the risk of adverse health impacts for employees in fire protection activities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[“Employee in fire protection activities” and “the list” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5305/a/5"},"text":"section 5305(a)(5) of Pub. L. 117–263","children":[],"tail":", set out above, defined as in subsecs. (a) and (b)(2), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143b"},"text":"section 8143b of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5305/a/2"},"text":"section 5305(a)(2) of Pub. L. 117–263","children":[],"tail":", set out as a Research Cooperation note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8143b"},"text":"section 8143b of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
