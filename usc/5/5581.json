l":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The exception in paragraph (1)(iv) for employees of the Senate is added on authority of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-01-06/ch1213"},"text":"Act of Jan. 6, 1951, ch. 1213","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1124"},"text":"64 Stat. 1124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s36a"},"text":"2 U.S.C. 36a","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2), the definition of “money due” is substituted for “unpaid compensation”. Paragraph (2)(I) is added on authority of former section 1182(a)(2), which is carried into section 5344.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb878e308-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb878e309-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s36a"},"text":"Section 36a of title 2","children":[],"tail":", referred to in par. (1)(iv), was editorially reclassified as "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4592"},"text":"section 4592 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5344"},"text":"Section 5344 of this title","children":[],"tail":", referred to in par. (2)(I), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":" and provisions relating to retroactive pay formerly contained in section 5344(a)(2) are contained in section 5344(b)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb878e30a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" inserted “and” after cl. (iv)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb878e30b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb878e30c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-12"},"text":"July 12, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/b"},"text":"section 2(b) of Pub. L. 96–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s305"},"text":"section 305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
