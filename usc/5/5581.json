{"tag":"section","attrib":{"id":"idb878e2f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581"},"text":null,"children":[{"tag":"num","attrib":{"value":"5581"},"text":"§ 5581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb878e2f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb878e2f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed by the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include an employee of—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb878e2f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal land bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb878e2f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal intermediate credit bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb878e2f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional bank for cooperatives; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb878e2f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/1/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senate within the purview of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s36a"},"text":"section 36a of title 2","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002112"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002112"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb878e2fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “money due” means the pay and allowances due on account of the services of a deceased employee for the Government of the United States or the government of the District of Columbia. It includes, but is not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb878e2fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" per diem instead of subsistence, mileage, and amounts due in reimbursement of travel expenses, including incidental and miscellaneous expenses in connection therewith for which reimbursement is due;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowances on change of official station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quarters and cost-of-living allowances and overtime or premium pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts due for payment of cash awards for employees’ suggestions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e2ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts due as refund of pay deductions for United States savings bonds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e300-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment for accumulated and current accrued annual or vacation leave equal to the pay the deceased employee would have received had he lived and remained in the service until the end of the period of annual or vacation leave;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e301-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of checks drawn for pay and allowances which were not delivered by the Government to the employee during his lifetime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e302-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of unnegotiated checks returned to the Government because of the death of the employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb878e303-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5581/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retroactive pay under section 5344(a) (2) of this title.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"It does not include benefits, refunds, or interest payable under subchapter III of chapter 83 of this title applicable to the service of the deceased employee, or amounts the disposition of which is otherwise expressly prescribed by Federal statute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb878e304-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966