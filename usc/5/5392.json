{"tag":"section","attrib":{"id":"idb86114e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392"},"text":null,"children":[{"tag":"num","attrib":{"value":"5392"},"text":"§ 5392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of special occupational pay systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86114e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority under this section may be exercised with respect to any occupation or group of occupations to which subchapter III applies (or would apply but for this section).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (a), the President’s pay agent (as referred to in section 5304(d)) may establish one or more special occupational pay systems for any positions within occupations or groups of occupations that the pay agent determines, for reasons of good administration, should not be classified under chapter 51 or subject to subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing special occupational pay systems, the pay agent shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86114e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify occupations or groups of occupations for which chapter 51 and subchapter III do not function adequately;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider alternative approaches for determining the pay for employees in positions in such occupations or groups of occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give thorough consideration to the views of agencies employing such employees and labor organizations representing such employees, as well as other interested parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a proposed plan for determining the pay of such employees in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct one or more public hearings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide each House of Congress with a report at least 90 days in advance of the date the system is to take effect setting forth the details of the proposed plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 30 days before the date the system is to take effect, publish in the Federal Register the details of the final plan for the special occupational pay system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A special occupational pay system may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86114ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a waiver of any law, rule, or regulation that could not be waived under section 4703(c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a rate of basic pay for any employee in excess of the rate payable for level V of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5392/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (d)(2), effective at the beginning of the first applicable pay period commencing on or after the first day of the month in which an adjustment takes effect under section 5303 in the rates of pay under the General Schedule, each rate of pay established under this section shall be adjusted by such amount as the Office considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86114f1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s105/a/1"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 105(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1448.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86114f2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86114f3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb86114f4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level V of the Executive Schedule, referred to in subsec. (d)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (e), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86114f5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb86114f6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
