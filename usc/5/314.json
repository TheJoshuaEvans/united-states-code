{"tag":"section","attrib":{"id":"idb78a8b38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical expertise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78a8b39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency shall designate the head of any statistical agency or unit within the agency, or in the case of an agency that does not have a statistical agency or unit, any senior agency official with appropriate expertise, as a statistical official to advise on statistical policy, techniques, and procedures. Agency officials engaged in statistical activities may consult with any such statistical official as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership on Interagency Council on Statistical Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each statistical official designated under subsection (a) shall serve as a member of the Interagency Council on Statistical Policy established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3504/e/8"},"text":"section 3504(e)(8) of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78a8b3b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added 