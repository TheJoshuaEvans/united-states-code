{"tag":"section","attrib":{"id":"idb8c0740b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8129"},"text":null,"children":[{"tag":"num","attrib":{"value":"8129"},"text":"§ 8129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of overpayments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c0740c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an overpayment has been made to an individual under this subchapter because of an error of fact or law, adjustment shall be made under regulations prescribed by the Secretary of Labor by decreasing later payments to which the individual is entitled. If the individual dies before the adjustment is completed, adjustment shall be made by decreasing later benefits payable under this subchapter with respect to the individual’s death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c0740d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adjustment or recovery by the United States may not be made when incorrect payment has been made to an individual who is without fault and when adjustment or recovery would defeat the purpose of this subchapter or would be against equity and good conscience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c0740e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8129/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A certifying or disbursing official is not liable for an amount certified or paid by him when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c0740f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8129/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustment or recovery of the amount is waived under subsection (b) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07410-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8129/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustment under subsection (a) of this section is not completed before the death of all individuals against whose benefits deductions are authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c07411-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/546"},"text":"80 Stat. 546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c07412-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c07413-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c07414-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s788"},"text":"5 U.S.C. 788","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s38"},"text":"Sept. 7, 1916, ch. 458, § 38","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/749"},"text":"39 Stat. 749","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-14/ch691/s206"},"text":"Oct. 14, 1949, ch. 691, § 206","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/864"},"text":"63 Stat. 864","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Subject to the provisions of sections 786 and 787 of this title” and “if any” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “official” is substituted for “officer” as the definition of “officer” in section 2104 excludes a member of a uniformed service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
