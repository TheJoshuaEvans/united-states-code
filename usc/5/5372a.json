{"tag":"section","attrib":{"id":"idb85ecad6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5372a"},"text":"§ 5372a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract appeals board members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85ecad7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecad8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “contract appeals board member” means a member of an agency board of contract appeals appointed under section 7105(a)(2), (c)(2), or (d)(2) of title 41 or a member of the Civilian Board of Contract Appeals appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105/b/2"},"text":"section 7105(b)(2) of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecad9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “appeals board” means an agency board of contract appeals established pursuant to section 7105(a)(1), (c)(1), or (d)(1) of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecada-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Rates of basic pay for contract appeals board members shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecadb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chairman of an appeals board—the rate of basic pay payable for level IV of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecadc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vice chairman of an appeals board—97 percent of the rate under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecadd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other members of an appeals board—94 percent of the rate under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecade-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rates of pay taking effect under this section shall be printed in the Federal Register and the Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85ecadf-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s104/a/2"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 104(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},