. L. 111–350, § 5(a)(9)(A)","children":[],"tail":", substituted “section 7105(a)(2), (c)(2), or (d)(2) of title 41” for “section 8 of the Contract Disputes Act of 1978” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105/b/2"},"text":"section 7105(b)(2) of title 41","children":[],"tail":"” for “section 42 of the Office of Federal Procurement Policy Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/a/9/B"},"text":"Pub. L. 111–350, § 5(a)(9)(B)","children":[],"tail":", substituted “section 7105(a)(1), (c)(1), or (d)(1) of title 41” for “section 8 of the Contract Disputes Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" inserted “or a member of the Civilian Board of Contract Appeals appointed under section 42 of the Office of Federal Procurement Policy Act” after “of 1978”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85ecae4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85ecae5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVIII/s847/g"},"text":"Pub. L. 109–163, div. A, title VIII, § 847(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3395"},"text":"119 Stat. 3395","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/163/dA/tVIII/s847/g"},"text":"“Section 42 of the Office of Federal Procurement Policy Act, as added by this section, and the amendments and repeals made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s438"},"text":"section 438 of Title 41","children":[],"tail":", Public Contracts, amending this section and sections 601 and 607 of Title 41, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s607"},"text":"section 607 of Title 41","children":[],"tail":"], shall take effect 1 year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb85ecae6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
