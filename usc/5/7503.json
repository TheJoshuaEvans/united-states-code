{"tag":"section","attrib":{"id":"idb8b48cf3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503"},"text":null,"children":[{"tag":"num","attrib":{"value":"7503"},"text":"§ 7503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cause and procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b48cf4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Office of Personnel Management, an employee may be suspended for 14 days or less for such cause as will promote the efficiency of the service (including discourteous conduct to the public confirmed by an immediate supervisor’s report of four such instances within any one-year period or any other pattern of discourteous conduct).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48cf5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee against whom a suspension for 14 days or less is proposed is entitled to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48cf6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advance written notice stating the specific reasons for the proposed action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48cf7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable time to answer orally and in writing and to furnish affidavits and other documentary evidence in support of the answer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48cf8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be represented by an attorney or other representative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48cf9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written decision and the specific reasons therefor at the earliest practicable date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48cfa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Copies of the notice of proposed action, the answer of the employee if written, a summary thereof if made orally, the notice of decision and reasons therefor, and any order effecting ","children":[{"tag":"ref","attrib":{"idref":"fn002141"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002141"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “affecting”."}],"tail":" the suspension, together with any supporting material, shall be maintained by the agency and shall be furnished to the Merit Systems Protection Board upon its request and to the employee affected upon the employee’s request."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b48cfb-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s204/a"},"text":"Pub. L. 95–454, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1135"},"text":"92 Stat. 1135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b48cfc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b48cfd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b48cfe-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b48cff-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information on Appeal Rights","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/b/2"},"text":"Pub. L. 115–91, div. A, title X, § 1097(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1617"},"text":"131 Stat. 1617","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tX/s1097/b/2"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any notice provided to an employee under section 7503(b)(1), section 7513(b)(1), or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7543/b/1"},"text":"section 7543(b)(1) of title 5","children":[],"tail":", United States Code, shall include detailed information with respect to—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right of the employee to appeal an action brought under the applicable section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forums in which the employee may file an appeal described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any limitations on the rights of the employee that would apply because of the forum in which the employee decides to file an appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The information described in subparagraph (A) shall be developed by the Director of the Office of Personnel Management, in consultation with the Special Counsel, the Merit Systems Protection Board, and the Equal Employment Opportunity Commission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
