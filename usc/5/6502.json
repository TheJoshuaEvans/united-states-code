{"tag":"section","attrib":{"id":"idb8a17a3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502"},"text":null,"children":[{"tag":"num","attrib":{"value":"6502"},"text":"§ 6502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive agencies telework requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a17a3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telework Eligibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a3c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this chapter, the head of each executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a3d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a policy under which eligible employees of the agency may be authorized to telework;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a3e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the eligibility for all employees of the agency to participate in telework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify all employees of the agency of their eligibility to telework.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee may not telework under a policy established under this section if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has been officially disciplined for being absent without permission for more than 5 days in any calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee has been officially disciplined for violations of subpart G of the Standards of Ethical Conduct for Employees of the Executive Branch for viewing, downloading, or exchanging pornography, including child pornography, on a Federal Government computer or while performing official Federal Government duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The policy described under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that telework does not diminish employee performance or agency operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require a written agreement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entered into between an agency manager and an employee authorized to telework, that outlines the specific work arrangement that is agreed to; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is mandatory in order for any employee to participate in telework;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that an employee may not be authorized to telework if the performance of that employee does not comply with the terms of the written agreement between the agency manager and that employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except in emergency situations as determined by the head of an agency, not apply to any employee of the agency whose official duties require on a daily basis (every work day)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct handling of secure materials determined to be inappropriate for telework by the agency head; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-site activity that cannot be handled remotely or at an alternate worksite;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be incorporated as part of the continuity of operations plans of the agency in the event of an emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enumerate the circumstances under which employees may be permitted to temporarily perform work requirements and duties from approved overseas locations, provided that, except in emergency situations as determined by the head of the agency, such circumstances shall not include a situation in which an employee’s official duties require on at least a monthly basis the direct handling of secure materials determined to be inappropriate for telework by the agency head.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Telework","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an agency places an employee in investigative leave under section 6329b, the agency may require the employee to, through telework, perform duties similar to the duties that the employee performs on-site if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agency determines that such a requirement would not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pose a threat to the employee or others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the destruction of evidence relevant to an investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in the loss of or damage to Government property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise jeopardize legitimate Government interests;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee is eligible to telework under subsections (a) and (b) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency determines that it would be appropriate for the employee to perform the duties of the employee through telework.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a56-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/a"},"text":"Pub. L. 111–292, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3165"},"text":"124 Stat. 3165","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXI/s1138/d/3"},"text":"Pub. L. 114–328, div. A, title XI, § 1138(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2469"},"text":"130 Stat. 2469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXII/s6202/a/2"},"text":"Pub. L. 117–81, div. F, title LXII, § 6202(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2389"},"text":"135 Stat. 2389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a57-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a17a58-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8a17a59-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (a)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292"},"text":"Pub. L. 111–292","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a17a5a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17a5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a17a5c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Telecommuting Opportunities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXII/s6202"},"text":"Pub. L. 117–81, div. F, title LXII, § 6202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2389"},"text":"135 Stat. 2389","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dF/tLXII/s6202"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DETO Policy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal department and agency shall establish a policy enumerating the circumstances under which employees may be permitted to temporarily perform work requirements and duties from approved overseas locations where there is a related Foreign Service assignment pursuant to an approved Domestically Employed Teleworking Overseas (DETO) agreement, consistent with the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6502"},"text":"section 6502 of title 5","children":[],"tail":", United States code [sic] (relating to the executive agencies telework requirements), as amended by paragraph (2), and DETO requirements, as set forth in the Foreign Affairs Manual and Foreign Affairs Handbook of the Department of State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amendment","children":[],"tail":".—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a17a5d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Amended this section.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to ICASS System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"], the Secretary of State shall revise chapter 900 of volume 6 of the Foreign Affairs Manual, the International Cooperative Administrative Support Services Handbook, the Personnel Operations Handbook, and any other relevant regulations to allow each Federal agency that has enacted a policy under subsection (a) to have access to the International Cooperative Administrative Support Services (ICASS) system.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
