{"tag":"section","attrib":{"id":"idb8828028-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722"},"text":null,"children":[{"tag":"num","attrib":{"value":"5722"},"text":"§ 5722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and transportation expenses of new appointees; posts of duty outside the continental United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8828029-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":" and subject to subsections (b) and (c) of this section, an agency may pay from its appropriations—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb882802a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel expenses of a new appointee and transportation expenses of his immediate family and his household goods and personal effects from the place of actual residence at the time of appointment to the place of employment outside the continental United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882802b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" these expenses on the return of an employee from his post of duty outside the continental United States to the place of his actual residence at the time of assignment to duty outside the continental United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882802c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenses of transporting a privately owned motor vehicle as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5727/c"},"text":"section 5727(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb882802d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency may pay expenses under subsection (a)(1) of this section only after the individual selected for appointment agrees in writing to remain in the Government service for a minimum period of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb882802e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one school year as determined under chapter 25 of title 20, if selected for appointment to a teaching position, except as a substitute, in the Department of Defense under that chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882802f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12 months after his appointment, if selected for appointment to any other position;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless separated for reasons beyond his control which are acceptable to the agency concerned. If the individual violates the agreement, the money spent by the Government for the expenses is recoverable from the individual as a debt due the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8828030-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency may pay expenses under subsection (a)(2) of this section only after the individual has served for a minimum period of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8828031-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one school year as determined under chapter 25 of title 20, if employed in a teaching position, except as a substitute, in the Department of Defense under that chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8828032-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than one nor more than 3 years prescribed in advance by the head of the agency, if employed in any other position;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"unless separated for reasons beyond his control which are acceptable to the agency concerned. These expenses are payable whether the separation is for Government purposes or for personal convenience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8828033-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to appropriations for the Foreign Service of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8828034-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/501"},"text":"80 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII"},"text":"Pub. L. 104–201, div. A, title XVII","children":[],"tail":", §§ 1715(b)(1), 1723(b)(1), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2755"},"text":"110 Stat. 2755","children":[],"tail":", 2759; "},{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/2"},"text":"Pub. L. 105–264, § 6(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2356"},"text":"112 Stat. 2356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8828035-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8828036-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8828037-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s73b–3/a"},"text":"5 U.S.C. 73b–3(a)","children":[],"tail":" (less 3d–6th proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch744/s7"},"text":"Aug. 2, 1946, ch. 744, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/808"},"text":"60 Stat. 808","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-23/ch1010/s2"},"text":"Sept. 23, 1950, ch. 1010, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/985"},"text":"64 Stat. 985","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 30, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/172/s2"},"text":"Pub. L. 87–172, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/409"},"text":"75 Stat. 409","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(1) and (c)(1), the words “under chapter 25 of title 20” are substituted for “under the Defense Department Overseas Teachers Pay and Personnel Practices Act” to reflect the scheduled transfer of that Act from chapter 34 of title 5 to chapter 25 of title 20.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8828038-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8828039-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/2/A"},"text":"Pub. L. 105–264, § 6(2)(A)","children":[],"tail":", substituted “continental United States;” for “United States;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/2/B"},"text":"Pub. L. 105–264, § 6(2)(B)","children":[],"tail":", substituted “Government” for “United States” in two places in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1723/b/1"},"text":"Pub. L. 104–201, § 1723(b)(1)","children":[],"tail":", in introductory provisions, substituted “Under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":"” for “Under such regulations as the President may prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/b/1"},"text":"Pub. L. 104–201, § 1715(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb882803a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb882803b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1725/a"},"text":"Pub. L. 104–201, div. A, title XVII, § 1725(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2760"},"text":"110 Stat. 2760","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tXVII/s1725/a"},"text":"“The amendments made by this title [enacting sections 5737, 5738, and 5756 of this title, amending this section, sections 3375, 5723 to 5724c, 5726 to 5729, and 5731 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1348"},"text":"section 1348 of Title 31","children":[],"tail":", Money and Finance, "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s707"},"text":"section 707 of Title 38","children":[],"tail":", Veterans’ Benefits, and sections 290aa and 299c–4 of Title 42, The Public Health and Welfare] shall take effect 180 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb882803c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1725/b"},"text":"Pub. L. 104–201, div. A, title XVII, § 1725(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2760"},"text":"110 Stat. 2760","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tXVII/s1725/b"},"text":"“The Administrator of General Services shall, not later than the effective date set forth under subsection (a) [set out above], issue final regulations implementing the amendments made by this title [see Effective Date of 1996 Amendment note above].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb882803d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Assessment of Cost Savings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1724"},"text":"Pub. L. 104–201, div. A, title XVII, § 1724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2759"},"text":"110 Stat. 2759","children":[],"tail":", directed Comptroller General, not later than one year after the effective date set forth in "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", to submit to Congress an assessment of costs of Federal travel administration that were saved as a result of the amendments made by title XVII of div. A of "},{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" and the regulations prescribed to carry out the amendments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
