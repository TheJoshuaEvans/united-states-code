{"tag":"section","attrib":{"id":"idb913ea6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714"},"text":null,"children":[{"tag":"num","attrib":{"value":"8714"},"text":"§ 8714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees’ Life Insurance Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb913ea6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amounts withheld from employees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8707"},"text":"section 8707 of this title","children":[],"tail":" and the sums contributed from appropriations and funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8708"},"text":"section 8708 of this title","children":[],"tail":" shall be deposited in the Treasury of the United States to the credit of the Employees’ Life Insurance Fund. The Fund is available without fiscal year limitation for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb913ea6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" premium payments under an insurance policy purchased under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb913ea70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses incurred by the Office of Personnel Management in the administration of this chapter within the limitations that may be specified annually by appropriation acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb913ea71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may invest and reinvest any of the money in the Fund in interest-bearing obligations of the United States, and may sell these obligations for the purposes of the Fund. The interest on and the proceeds from the sale of these obligations, and the income derived from dividend or premium rate adjustments from insurers, become a part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb913ea72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb913ea73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No tax, fee, or other monetary payment may be imposed or collected by any State, the District of Columbia, or the Commonwealth of Puerto Rico, or by any political subdivision or other governmental authority thereof, on, or with respect to, any premium paid under an insurance policy purchased under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb913ea74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8714/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) of this subsection shall not be construed to exempt any company issuing a policy of insurance under this chapter from the imposition, payment, or collection of a tax, fee, or other monetary payment on the net income or profit accruing to or realized by that company from business conducted under this chapter, if that tax, fee, or payment is applicable to a broad range of business activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb913ea75-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/598"},"text":"80 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/tIV/s405/a"},"text":"Pub. L. 96–499, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2606"},"text":"94 Stat. 2606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb913ea76-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb913ea77-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb913ea78-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html