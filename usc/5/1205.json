{"tag":"section","attrib":{"id":"idb7e7789b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1205"},"text":null,"children":[{"tag":"num","attrib":{"value":"1205"},"text":"§ 1205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of information to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or any rule, regulation or policy directive, any member of the Board, or any employee of the Board designated by the Board, may transmit to the Congress on the request of any committee or subcommittee thereof, by report, testimony, or otherwise, information and views on functions, responsibilities, or other matters relating to the Board, without review, clearance, or approval by any other administrative authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7e7789c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s202/a"},"text":"Pub. L. 95–454, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1131"},"text":"92 Stat. 1131","children":[],"tail":", § 1209(a); renumbered § 1205 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/9"},"text":"Pub. L. 101–12, § 3(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/18"},"text":"103 Stat. 18","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e7789d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e7789e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"ch