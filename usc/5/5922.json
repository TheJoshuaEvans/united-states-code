:[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb88bf625-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb88bf626-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb88bf627-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary of State empowered to prescribe regulations, see section 1(b) of Ex. Ord. No. 10903, ","children":[{"tag":"date","attrib":{"date":"1961-01-11"},"text":"Jan. 11, 1961","children":[],"tail":", 26 F.R. 217, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5921"},"text":"section 5921 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
