xt":" Surgical care and treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91b1699-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical care and treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91b169a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Obstetrical benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91b169b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prescribed drugs, medicines, and prosthetic devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91b169c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other medical supplies and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b169d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Organization Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Benefits of the types named under paragraph (1) or (2) of this subsection or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b169e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensive Medical Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Benefits of the types named under paragraph (1) or (2) of this subsection or both.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"All plans contracted for under paragraphs (1) and (2) of this subsection shall include benefits both for costs associated with care in a general hospital and for other health services of a catastrophic nature.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91b169f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91b16a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91b16a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan, other than a prepayment plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8903/4"},"text":"section 8903(4) of this title","children":[],"tail":", may not provide benefits, in the case of any retired enrolled individual who is age 65 or older and is not covered to receive Medicare hospital and insurance benefits under part A of title XVIII of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395c"},"text":"42 U.S.C. 1395c","children":[],"tail":" et seq.), to pay a charge imposed by any health care provider, for inpatient hospital services which are covered for purposes of benefit payments under this chapter and part A of title XVIII of the Social Security Act, to the extent that such charge exceeds applicable limitations on hospital charges established for Medicare purposes under section 1886 of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww"},"text":"42 U.S.C. 1395ww","children":[],"tail":"). Hospital providers who have in force participation agreements with the Secretary of Health and Human Services consistent with sections 1814(a) and 1866 of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395f/a"},"text":"42 U.S.C. 1395f(a)","children":[],"tail":" and 1395cc), whereby the participating provider accepts Medicare benefits as full payment for covered items and services after applicable patient copayments under section 1813 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395e"},"text":"42 U.S.C. 1395e","children":[],"tail":") have been satisfied, shall accept equivalent benefit payments and enrollee copayments under this chapter as full payment for services described in the preceding sentence. The Office of Personnel Management shall notify the Secretary of Health and Human Services if a hospital is found to knowingly and willfully violate this subsection on a repeated basis and the Secretary may invoke appropriate sanctions in accordance with section 1866(b)(2) of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395cc/b/2"},"text":"42 U.S.C. 1395cc(b)(2)","children":[],"tail":") and applicable regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91d86a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb91d86a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan, other than a prepayment plan described in section 8903(4), may not provide benefits, in the case of any retired enrolled individual who is age 65 or older and is not entitled to Medicare supplementary medical insurance benefits under part B of title XVIII of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395j"},"text":"42 U.S.C. 1395j","children":[],"tail":" et seq.), to pay a charge imposed for physicians’ services (as defined in section 1848(j) of such Act, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/j"},"text":"42 U.S.C. 1395w–4(j)","children":[],"tail":") which are covered for purposes of benefit payments under this chapter and under such part, to the extent that such charge exceeds the fee schedule amount under section 1848(a) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/a"},"text":"42 U.S.C. 1395w–4(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb91d86a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Physicians and suppliers who have in force participation agreements with the Secretary of Health and Human Services consistent with section 1842(h)(1) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u/h/1"},"text":"42 U.S.C. 1395u(h)(1)","children":[],"tail":"), whereby the participating provider accepts Medicare benefits (including allowable deductible and coinsurance amounts) as full payment for covered items and services shall accept equivalent benefit and enrollee cost-sharing under this chapter as full payment for services described in clause (i). Physicians and suppliers who are nonparticipating physicians and suppliers for purposes of part B of title XVIII of such Act shall not impose charges that exceed the limiting charge under section 1848(g) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4/g"},"text":"42 U.S.C. 1395w–4(g)","children":[],"tail":") with respect to services described in clause (i) provided to enrollees described in such clause. The Office of Personnel Management shall notify a physician or supplier who is found to have violated this clause and inform them of the requirements of this clause and sanctions for such a violation. The Office of Personnel Management shall notify the Secretary of Health and Human Services if a physician or supplier is found to knowingly and willfully violate this clause on a repeated basis and the Secretary of Health and Human Services may invoke appropriate sanctions in accordance with sections 1128A(a) and 1848(g)(1) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7a/a"},"text":"42 U.S.C. 1320a–7a(a)","children":[],"tail":", 1395w–4(g)(1)) and applicable regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91d86a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary of Health and Human Services determines that a violation of this subsection warrants excluding a provider from participation for a specified period under title XVIII of the Social Security Act, the Office shall enforce a corresponding exclusion of such provider for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91d86a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Secretary of Health and Human Services and the Director of the Office of Personnel Management, and their agents, shall exchange any information necessary to implement this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91d86a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91d86a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1991-12-01"},"text":"December 1, 1991","children":[],"tail":", and periodically thereafter, the Secretary of Health and Human Services (in consultation with the Director of the Office of Personnel Management) shall supply to carriers of plans described in paragraphs (1) through (3) of section 8903 the Medicare program information necessary for them to comply with paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91d86a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, the term “Medicare program information” includes (i) the limitations on hospital charges established for Medicare purposes under section 1886 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395ww"},"text":"42 U.S.C. 1395ww","children":[],"tail":") and the identity of hospitals which have in force agreements with the Secretary of Health and Human Services consistent with section 1814(a) and 1866 of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395f/a"},"text":"42 U.S.C. 1395f(a)","children":[],"tail":" and 1395cc), and (ii) the fee schedule amounts and limiting charges for physicians’ services established under section 1848 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–4"},"text":"42 U.S.C. 1395w–4","children":[],"tail":") and the identity of participating physicians and suppliers who have in force agreements with such Secretary under section 1842(h) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395u/h"},"text":"42 U.S.C. 1395u(h)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91d86aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Office of Personnel Management shall enter into an arrangement with the Secretary of Health and Human Services, to be effective before the first day of the fifth month that begins before each contract year, under which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91d86ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physicians and suppliers (whether or not participating) under the Medicare program will be notified of the requirements of paragraph (1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91d86ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement procedures will be in place to carry out such paragraph (including enforcement of protections against overcharging of beneficiaries); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91d86ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8904/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medicare program information described in paragraph (3)(B)(ii) will be supplied to carriers under paragraph (3)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91d86ae-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/603"},"text":"80 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVII/s7002/f/1"},"text":"Pub. L. 101–508, title VII, § 7002(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-330"},"text":"104 Stat. 1388–330","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/76"},"text":"Pub. L. 102–378, § 2(76)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1355"},"text":"106 Stat. 1355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXI/s11003/a"},"text":"Pub. L. 103–66, title XI, § 11003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/409"},"text":"107 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91d86af-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","