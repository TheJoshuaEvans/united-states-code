n":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91d86b6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXI/s11003/b"},"text":"Pub. L. 103–66, title XI, § 11003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/410"},"text":"107 Stat. 410","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/66/tXI/s11003/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to contract years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91d86b7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVII/s7002/f/2"},"text":"Pub. L. 101–508, title VII, § 7002(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-331"},"text":"104 Stat. 1388–331","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/508/tVII/s7002/f/2"},"text":"“The amendments made by this subsection [amending this section] shall apply with respect to contract years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91d86b8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coverage of Testing for COVID–19: Application With Respect to Federal Civilians","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/127/dF/s6006/c"},"text":"Pub. L. 116–127, div. F, § 6006(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/207"},"text":"134 Stat. 207","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/127/dF/s6006/c"},"text":"“No copayment or other cost sharing may be required for any individual occupying a position in the civil service (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101/1"},"text":"section 2101(1) of title 5","children":[],"tail":", United States Code) enrolled in a health benefits plan, including any plan under chapter 89 of title 5, United States Code, or for any other individual currently enrolled in any plan under chapter 89 of title 5 for in vitro diagnostic products described in paragraph (1) of section 6001(a) [of "},{"tag":"ref","attrib":{"href":"/us/pl/116/127"},"text":"Pub. L. 116–127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–5"},"text":"42 U.S.C. 1320b–5","children":[],"tail":" note] (or the administration of such products) or visits described in paragraph (2) of such section furnished during any portion of the emergency period defined in paragraph (1)(B) of section 1135(g) of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–5/g"},"text":"42 U.S.C. 1320b–5(g)","children":[],"tail":") beginning on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-03-18"},"text":"Mar. 18, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb91d86b9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Mental Health, Alcoholism, and Drug Addiction Benefits; Congressional Findings; Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251/tI/s107"},"text":"Pub. L. 99–251, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/16"},"text":"100 Stat. 16","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/251/tI/s107"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of mental illness, alcoholism, and drug addiction are basic health care services which are needed by approximately 40,000,000 Americans each year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment of mental illness, alcoholism, and drug addiction is increasingly successful;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timely and appropriate treatment of mental illness, alcoholism, and drug addiction is cost effective in terms of restored productivity, reduced utilization of other health services, and reduced social dependence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental illness is a problem of grave concern to the people of the United States and is widely but unnecessarily feared and misunderstood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of the Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that participants in the Federal employees health benefits program should receive adequate benefits coverage for treatment of mental illness, alcoholism, and drug addiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Office of Personnel Management should encourage participating health benefits plans to provide adequate benefits relating to treatment of mental illness, alcoholism, and drug addiction (including benefits relating to coverage for inpatient and outpatient treatment and catastrophic protection benefits).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
