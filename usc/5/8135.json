{"tag":"section","attrib":{"id":"idb8c2e46b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8135"},"text":null,"children":[{"tag":"num","attrib":{"value":"8135"},"text":"§ 8135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c2e46c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The liability of the United States for compensation to a beneficiary in the case of death or of permanent total or permanent partial disability may be discharged by a lump-sum payment equal to the present value of all future payments of compensation computed at 4 percent true discount compounded annually if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e46d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly payment to the beneficiary is less than $50 a month;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e46e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beneficiary is or is about to become a nonresident of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e46f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8135/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor determines that it is for the best interest of the beneficiary.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The probability of the death of the beneficiary before the expiration of the period during which he is entitled to compensation shall be determined according to the most current United States Life Tables, as developed by the United States Department of Health, Education, and Welfare, which shall be updated from time to time, but the lump-sum payment to a widow or widower of the deceased employee may not exceed 60 months’ compensation. The probability of the happening of any other contingency affecting the amount or duration of compensation shall be disregarded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e470-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On remarriage before reaching age 55 a widow or widower entitled to compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133"},"text":"section 8133 of this title","children":[],"tail":", shall be paid a lump sum equal to twenty-four times the monthly compensation payment (excluding compensation on account of another individual) to which he was entitled immediately before the remarriage."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c2e471-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/548"},"text":"80 Stat. 548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/63"},"text":"Pub. L. 90–83, § 1(63)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/211"},"text":"81 St