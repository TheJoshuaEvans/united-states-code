","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e475-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e476-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8135(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 764(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 4, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/488/s8"},"text":"Pub. L. 89–488, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/254"},"text":"80 Stat. 254","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “widower” is substituted for “dependent widower” to conform to the definition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101/11"},"text":"5 U.S.C. 8101(11)","children":[],"tail":". The words “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133"},"text":"section 8133 of title 5","children":[],"tail":"” are substituted for “section 10” to reflect the codification of that section in title 5, United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c2e477-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c2e478-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/303"},"text":"Pub. L. 101–303","children":[],"tail":" substituted “age 55” for “age 60”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s20"},"text":"Pub. L. 93–416, § 20","children":[],"tail":", substituted provisions relating to use of the most current United States Life Tables, for provisions relating to deter­mination by the American Experience Tables of Mortality."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s19"},"text":"Pub. L. 93–416, § 19","children":[],"tail":", substituted “$50” for “$5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s16/b"},"text":"Pub. L. 93–416, § 16(b)","children":[],"tail":", inserted “before reaching age 60” after “On remarriage”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c2e479-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb8c2e47a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Department of Health, Education, and Welfare redesignated the United States Department of Health and Human Services by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508"},"text":"section 3508 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c2e47b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" applicable to cases where injury or death occurred prior to "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", but only to a period beginning on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c2e47c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Personnel Not Affected by 1967 Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases authorized under amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/63"},"text":"section 1(63) of Pub. L. 90–83","children":[],"tail":" not applicable to specified personnel, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s7"},"text":"section 7 of Pub. L. 90–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8103"},"text":"section 8103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
