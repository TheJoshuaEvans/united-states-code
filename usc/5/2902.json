n":[{"tag":"html:a","attrib":{"href":"/us/usc/t4/s42"},"text":"4 U.S.C. 42","children":[],"tail":" (as applicable to civil commissions)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None.]","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s11"},"text":"5 U.S.C. 11","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1875-03-03/ch131/s14"},"text":"Mar. 3, 1875, ch. 131, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/18/420"},"text":"18 Stat. 420","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1896-03-28/ch73"},"text":"Mar. 28, 1896, ch. 73","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/29/75"},"text":"29 Stat. 75","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-03-03/ch1422"},"text":"Mar. 3, 1905, ch. 1422","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/33/990"},"text":"33 Stat. 990","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s12"},"text":"5 U.S.C. 12","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1888-08-08/ch786"},"text":"Aug. 8, 1888, ch. 786","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/25/387"},"text":"25 Stat. 387","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Except as provided by subsections (b) and (c) of this section,” are added on authority of former sections 11 and 12, which are codified in subsections (b) and (c) of this section. The words “the commission of an officer” are substituted for “all civil commissions for officers of the United States” because of the definition of “officer” in section 2104. The words “by the President” are coextensive with and substituted for “by the President, by and with the advice and consent of the Senate, or by the President alone”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “officer in the civil service or uniformed services” are substituted for “officer” because of the definition of “officer” in section 2104. The words “direction and” are omitted as included within “the control”. The words “the Secretary of Defense” are added on authority of the Acts of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/s305/a"},"text":"July 26, 1947, ch. 343, § 305(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/508"},"text":"61 Stat. 508","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-10/ch412/s12/g"},"text":"Aug. 10, 1949, ch. 412, § 12(g)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/591"},"text":"63 Stat. 591","children":[],"tail":". The words “the Secretary of a military department” are substituted for “the Secretary of War, the Secretary of the Navy” (appearing in the Act of "},{"tag":"date","attrib":{"date":"1896-03-28"},"text":"Mar. 28, 1896","children":[],"tail":") because of the definition of “military department” in section 102. The title of the Secretary of War was changed to Secretary of the Army by the "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/s205"},"text":"Act of July 26, 1947, ch. 343, § 205","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":". “Secretary of the Air Force” is included on authority of the "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/s207/a"},"text":"Act of July 26, 1947, ch. 343, § 207(a)","children":[],"tail":", (f), "},{"tag":"ref","attrib":{"href":"/us/stat/61/502"},"text":"61 Stat. 502","children":[],"tail":". The words “Secretary of Commerce” are substituted for “Secretary of Commerce and Labor” on authority of the "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s1"},"text":"Act of Mar. 4, 1913, ch. 141, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/736"},"text":"37 Stat. 736","children":[],"tail":". The words “under the departmental seal” are substituted for “and the departmental seal affixed thereto”. The words “any laws to the contrary notwithstanding” are omitted as unnecessary. The last sentence of "},{"tag":"ref","attrib":{"href":"/us/act/1875-03-03/s14"},"text":"section 14 of the Act of Mar. 3, 1875","children":[],"tail":", is omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “and shall be” and “any laws to the contrary notwithstanding” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f840e2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f840e3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" inserted “the Secretary of Homeland Security,” after “the Secretary of the Interior,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" struck out “the Postmaster General,” after “under the control of”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
