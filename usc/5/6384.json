{"tag":"section","attrib":{"id":"idb8a179f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384"},"text":null,"children":[{"tag":"num","attrib":{"value":"6384"},"text":"§ 6384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment and benefits protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a179f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee who takes leave under section 6382 for the intended purpose of the leave shall be entitled, upon return from such leave—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a179fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be restored by the employing agency to the position held by the employee when the leave commenced; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a179fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be restored to an equivalent position with equivalent benefits, pay, status, and other terms and conditions of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a179fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The taking of leave under section 6382 shall not result in the loss of any employment benefit accrued prior to the date on which the leave commenced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a179fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided by or under law, nothing in this section shall be construed to entitle any restored employee to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a179fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accrual of any employment benefits during any period of leave; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a179ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any right, benefit, or position of employment other than any right, benefit, or position to which the employee would have been entitled had the employee not taken the leave.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As a condition to restoration under subsection (a) for an employee who takes leave under section 6382(a)(1)(D), the employing agency may have a uniformly applied practice or policy that requires each such employee to receive certification from the health care provider of the employee that the employee is able to resume work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6384/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to prohibit an employing agency from requiring an employee on leave under section 6382 to report periodically to the employing agency on the status and intention of the employee to return to work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a02-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tII/s201/a/1"},"text":"Pub. L. 103–3, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/22"},"text":"107 Stat. 22","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a03-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17a04-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a17a05-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b/1"},"text":"section 405(b)(1) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
