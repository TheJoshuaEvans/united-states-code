{"tag":"section","attrib":{"id":"idb7a258a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423"},"text":null,"children":[{"tag":"num","attrib":{"value":"423"},"text":"§ 423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay of Inspectors General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7a258a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Inspectors General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a258a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the annual rate of basic pay of the Inspector General of the Intelligence Community, the Inspector General of the Central Intelligence Agency, and the Special Inspector General for Afghanistan Reconstruction shall be that of an Inspector General as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a258a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of cash bonus or awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/f"},"text":"Section 403(f) of this title","children":[],"tail":" shall apply to the Inspectors General described under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a258aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspectors General of Designated Federal Entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Inspector General of each designated Federal entity (as those terms are defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/a"},"text":"section 415(a) of this title","children":[],"tail":") shall, for pay and all other purposes, be classified at a grade, level, or rank designation, as the case may be, at or above those of a majority of the senior level executives of that designated Federal entity (such as a General Counsel, Chief Information Officer, Chief Financial Officer, Chief Human Capital Officer, or Chief Acquisition Officer). The pay of an Inspector General of a designated Federal entity (as those terms are defined under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/a"},"text":"section 415(a) of this title","children":[],"tail":") shall be not less than the average total compensation (including bonuses) of the senior level executives of that designated Federal entity calculated on an annual basis."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7a258ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision for Newly Appointed Inspectors General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7a258ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3392"},"text":"section 3392 of this title","children":[],"tail":", other than the terms “performance awards” and “awarding of ranks” in subsection (c)(1) of that section, shall apply to career appointees of the Senior Executive Service who are appointed to the position of Inspector General."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7a258ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s423/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonreduction in pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, career Federal employees serving on an appointment made pursuant to statutory authority found other than in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3392"},"text":"section 3392 of this title","children":[],"tail":" shall not suffer a reduction in pay, not including any bonus or performance award, as a result of being appointed to the position of Inspector General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7a258ae-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4255"},"text":"136 Stat. 4255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7a258af-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7a258b0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7a258b1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{