tail":" (see "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s403"},"text":"5 U.S.C. 403","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12651e"},"text":"section 12651e of Title 42","children":[],"tail":", The Public Health and Welfare, and enacting provisions formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/pl/95/452/s3"},"text":"section 3 of Pub. L. 95–452","children":[],"tail":" (see "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s423/a"},"text":"5 U.S.C. 423(a)","children":[],"tail":")] shall have the effect of reducing the rate of pay of any individual serving on the date of enactment of this section ["},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":"] as an Inspector General of—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an establishment as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s401"},"text":"section 401 of title 5","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designated Federal entity as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/a"},"text":"section 415(a) of title 5","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legislative agency for which the position of Inspector General is established by statute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity of the Government for which the position of Inspector General is established by statute.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
