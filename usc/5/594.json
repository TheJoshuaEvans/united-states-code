{"tag":"section","attrib":{"id":"idb7bee13f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594"},"text":null,"children":[{"tag":"num","attrib":{"value":"594"},"text":"§ 594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of the Conference","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To carry out the purposes of this subchapter, the Administrative Conference of the United States may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bee140-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study the efficiency, adequacy, and fairness of the administrative procedure used by administrative agencies in carrying out administrative programs, and make recommendations to administrative agencies, collectively or individually, and to the President, Congress, or the Judicial Conference of the United States, in connection therewith, as it considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bee141-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for interchange among administrative agencies of information potentially useful in improving administrative procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bee142-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect information and statistics from administrative agencies and publish such reports as it considers useful for evaluating and improving administrative procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bee143-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into arrangements with any administrative agency or major organizational unit within an administrative agency pursuant to which the Conference performs any of the functions described in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bee144-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide assistance in response to requests relating to the improvement of administrative procedure in foreign countries, subject to the concurrence of the Secretary of State, the Administrator of the Agency for International Development, or the Director of the United States Information Agency, as appropriate, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7bee145-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assistance shall be limited to the analysis of issues relating to administrative procedure, the provision of training of foreign officials in administrative procedure, and the design or improvement of administrative procedure, where the expertise of members of the Conference is indicated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7bee146-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s594/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assistance may only be undertaken on a fully reimbursable basis, including all direct and indirect administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Payment for services provided by the Conference pursuant to paragraph (4) shall be credited to the operating account for the Conference and shall remain available until expended.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7bee147-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/390"},"text":"80 Stat. 390","children":[],"tail":", § 574; "},{"tag":"ref","attrib":{"href":"/us/pl/101/422/s2"},"text":"Pub. L. 101–422, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-12"},"text":"Oct. 12, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/910"},"text":"104 Stat. 910","children":[],"tail":"; renumbered § 594, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s2/2"},"text":"Pub. L. 102–354, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/403"},"text":"Pub. L. 102–403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-09"},"text":"Oct. 9, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1968"},"text":"106 Stat. 1968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/401/s2/b/1"},"text":"Pub. L. 108–401, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2255"},"text":"118 Stat. 2255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bee148-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7bee149-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7bee14a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s1045c"},"text":"5 U.S.C. 1045c","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 30, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/499/s5"},"text":"Pub. L. 88–499, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/616"},"text":"78 Stat. 616","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bee14b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bee14c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/401"},"text":"Pub. L. 108–401","children":[],"tail":" substituted “purposes” for “purpose” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s574"},"text":"section 574 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/403"},"text":"Pub. L. 102–403","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “enter into arrangements with any administrative agency or major organizational unit within an administrative agency pursuant to which the Conference performs any of the functions described in paragraphs (1), (2), and (3).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/403"},"text":"Pub. L. 102–403","children":[],"tail":" which directed addition of par. (5) at end of section, was executed by adding par. (5) after par. (4) and before concluding provisions, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/422"},"text":"Pub. L. 101–422","children":[],"tail":" added par. (4) and concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7bee14d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7bee14e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Administrative Conference of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Administrative Conference of United States, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s591"},"text":"section 591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb7bee14f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
