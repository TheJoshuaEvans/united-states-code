{"tag":"section","attrib":{"id":"idb7de024e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008"},"text":null,"children":[{"tag":"num","attrib":{"value":"1008"},"text":"§ 1008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose of advisory committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7de024f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advisory committee shall not be established unless establishment is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7de0250-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically authorized by statute or by the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de0251-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined as a matter of formal record, by the head of the agency involved after consultation with the Administrator, with timely notice published in the Federal Register, to be in the public interest in connection with the performance of duties imposed on that agency by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0252-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose of Advisory Committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise specifically provided by statute or Presidential directive, advisory committees shall be utilized solely for advisory functions. Determinations of action to be taken and policy to be expressed with respect to matters upon which an advisory committee reports or makes recommendations shall be made solely by the President or an officer of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0253-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Committee Charters.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7de0254-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advisory committee shall not meet or take any action until an advisory committee charter has been filed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7de0255-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the Administrator in the case of Presidential advisory committees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de0256-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7de0257-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the agency to whom the advisory committee reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7de0258-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standing committees of the Senate and House of Representatives having legislative jurisdiction over the agency to which the advisory committee reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de0259-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of charter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory committee charter shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7de025a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee’s official designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de025b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee’s objectives and the scope of its activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de025c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of time necessary for the committee to carry out its purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de025d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency or official to whom the committee reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de025e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency responsible for providing the necessary support for the committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de025f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the duties for which the committee is responsible, and, if the duties are not solely advisory, a specification of the authority for the duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de0260-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated annual operating costs for the committee in dollars and person-years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de0261-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated number and frequency of committee meetings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de0262-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the committee’s termination date, if less than 2 years from the date of the committee’s establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7de0263-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the charter is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de0264-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1008/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copy of charter to library of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A copy of the advisory committee charter shall be furnished to the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7de0265-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4201"},"text":"136 Stat. 4201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7de0266-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7de0267-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7de0268-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1008","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (FACA § 9)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/463/s9"},"text":"Pub. L. 92–463, § 9","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/773"},"text":"86 Stat. 773","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2) and subsection (c)(1)(A), the word “Administrator” is substituted for “Director” (meaning the Director of the Office of Management and Budget) because of section 5F of Reorganization Plan No. 1 of 1977 (5 U.S.C. App.).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
