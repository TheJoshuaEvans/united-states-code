{"tag":"section","attrib":{"id":"id4cbfc1fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421"},"text":null,"children":[{"tag":"num","attrib":{"value":"10421"},"text":"§ 10421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbfc1fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make grants under this subchapter to States, for use by States and units of local government for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing residential substance abuse treatment programs within State correctional facilities, as well as within local correctional and detention facilities in which inmates are incarcerated for a period of time sufficient to permit substance abuse treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc200-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the establishment and maintenance of drug-free prisons and jails; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc201-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing specialized residential substance abuse treatment programs that identify and provide appropriate treatment to inmates with co-occurring mental health and substance abuse disorders or challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc202-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall consult with the Secretary of Health and Human Services to ensure that projects of substance abuse treatment and related services for State prisoners incorporate applicable components of existing comprehensive approaches including relapse prevention and aftercare services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc203-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10421/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States that demonstrate that they have existing in-prison drug treatment programs that are in compliance with Federal requirements may use funds awarded under this subchapter for treatment and sanctions both during incarceration and after release.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc204-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1901"},"text":"Pub. L. 90–351, title I, § 1901","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s32101/a/3"},"text":"Pub. L. 103–322, title III, § 32101(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1898"},"text":"108 Stat. 1898","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII"},"text":"Pub. L. 107–273, div. B, title II","children":[],"tail":", §§ 2101, 2102(1), "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1792"},"text":"116 Stat. 1792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14012"},"text":"Pub. L. 114–255, div. B, title XIV, § 14012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1297"},"text":"130 Stat. 1297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc205-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc206-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc207-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ff"},"text":"section 3796ff of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbfc208-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1901"},"text":"section 1901 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2601 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10541"},"text":"section 10541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbfc209-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s2102/1"},"text":"Pub. L. 107–273, § 2102(1)","children":[],"tail":", substituted “purpose of—” for “purpose of”, inserted par. (1) designation before “developing”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s2101"},"text":"Pub. L. 107–273, § 2101","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
