{"tag":"section","attrib":{"id":"id4cce1a25-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10565"},"text":null,"children":[{"tag":"num","attrib":{"value":"10565"},"text":"§ 10565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cce1a26-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may promulgate such guidelines, regulations, and procedures as may be necessary to carry out this subchapter, including guidelines, regulations, and procedures relating to the submission and review of applications for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10562"},"text":"section 10562 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce1a27-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a28-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10565/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State, or unit of local government within the State, that receives a grant under this subchapter shall maintain such records as the Attorney General may require to facilitate an effective audit relating to the receipt of the grant, or the use of the grant amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a29-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10565/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General and the Comptroller General of the United States, or a designee thereof, shall have access, for the purpose of audit and examination, to any book, document, or record of a State, or unit of local government within the State, that receives a grant under this subchapter, if, in the determination of the Attorney General, Comptroller General, or designee thereof, the book, document, or record is related to the receipt of the grant, or the use of the grant amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce1a2a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2805"},"text":"Pub. L. 90–351, title I, § 2805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/561/s2/c/1"},"text":"Pub. L. 106–561, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2790"},"text":"114 Stat. 2790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cce1a2b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cce1a2c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cce1a2d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797n"},"text":"section 3797n of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
