{"tag":"section","attrib":{"id":"id4cd063c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613"},"text":null,"children":[{"tag":"num","attrib":{"value":"10613"},"text":"§ 10613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd063c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), in this subchapter, the term “violent offender” means a person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd063c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is charged with or convicted of an offense that is punishable by a term of imprisonment exceeding one year, during the course of which offense or conduct—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd063c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person carried, possessed, or used a firearm or dangerous weapon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there occurred the death of or serious bodily injury to any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there occurred the use of force against the person of another, without regard to whether any of the circumstances described in subparagraph (A) or (B) is an element of the offense or conduct of which or for which the person is charged or convicted; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has 1 or more prior convictions for a felony crime of violence involving the use or attempted use of force against a person with the intent to cause death or serious bodily harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd063ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition for purposes of juvenile drug courts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of juvenile drug courts, the term “violent offender” means a juvenile who has been convicted of, or adjudicated delinquent for, a felony-level offense that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd063cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has as an element, the use, attempted use, or threatened use of physical force against the person or property of another, or the possession or use of a firearm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by its nature, involves a substantial risk that physical force against the person or property of another may be used in the course of committing the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd063cd-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2953"},"text":"Pub. L. 90–351, title I, § 2953","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2301/a"},"text":"Pub. L. 107–273, div. B, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1795"},"text":"116 Stat. 1795","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1141"},"text":"Pub. L. 109–162, title XI, § 1141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3110"},"text":"119 Stat. 3110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s103/a"},"text":"Pub. L. 110–199, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/668"},"text":"122 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd063ce-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd063cf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd063d0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u–2"},"text":"section 3797u–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cd063d1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" inserted “that is punishable by a term of imprisonment exceeding one year” after “convicted of an offense” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" substituted “a felony-level offense that” for “an offense that” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cd063d2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cd063d3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendments and provisions set out as a note below by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" and requirements for grants made under such amendments and note, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60504"},"text":"section 60504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cd063d4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Period for Compliance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s103/b"},"text":"Pub. L. 110–199, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/668"},"text":"122 Stat. 668","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/199/tI/s103/b"},"text":"“Notwithstanding section 2952(2) of the Omnibus Crime Control and Safe Streets Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u–1/2"},"text":"42 U.S.C. 3797u–1(2)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10612/2"},"text":"34 U.S.C. 10612(2)","children":[],"tail":"], each grantee under part EE of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10611"},"text":"34 U.S.C. 10611","children":[],"tail":" et seq.] shall have not more than 3 years from the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":"] to adopt the definition of ‘violent offender’ under such part, as amended by subsection (a) of this section [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
