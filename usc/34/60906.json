{"tag":"section","attrib":{"id":"id4d66b060-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60906"},"text":null,"children":[{"tag":"num","attrib":{"value":"60906"},"text":"§ 60906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b061-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the date that is three years after ","children":[{"tag":"date","attrib":{"date":"2022-08-03"},"text":"August 3, 2022","children":[],"tail":", and annually thereafter, the Director of the National Institute of Justice shall publish statistics on the number of cold case murders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b062-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The statistics published pursuant to subsection (a) shall, at a minimum, be disaggregated by the circumstances of the cold case murder, including the classification of the offense, and by agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b063-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s7"},"text":"Pub. L. 117–164, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1360"},"text":"136 Stat. 1360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
