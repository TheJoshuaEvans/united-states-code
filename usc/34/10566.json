{"tag":"section","attrib":{"id":"id4cce1a2e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566"},"text":null,"children":[{"tag":"num","attrib":{"value":"10566"},"text":"§ 10566.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cce1a2f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Attorney General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year for which a grant is awarded under this subchapter, each State or unit of local government that receives such a grant shall submit to the Attorney General a report, at such time and in such manner as the Attorney General may reasonably require, which report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a30-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary and assessment of the program carried out with the grant, which shall include a comparison of pre-grant and post-grant forensic science capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a31-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average number of days between submission of a sample to a forensic science laboratory or forensic science laboratory system in that State operated by the State or by a unit of local government and the delivery of test results to the requesting office or agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the number and type of cases currently accepted by the laboratory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of any unaccredited forensic science service provider receiving grant funds toward obtaining accreditation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Attorney General may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce1a35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the last day of each fiscal year for which 1 or more grants are awarded under this subchapter, the Attorney General shall submit to the Speaker of the House of Representatives and the President pro tempore of the Senate, a report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of grants awarded under this subchapter for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10566/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the information provided under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce1a38-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2806"},"text":"Pub. L. 90–351, title I, § 2806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/561/s2/c/1"},"text":"Pub. L. 106–561, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2790"},"text":"114 Stat. 2790","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tV/s5001/b/5"},"text":"Pub. L. 107–273, div. B, title V, § 5001(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1814"},"text":"116 Stat. 1814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s9/a/4"},"text":"Pub. L. 114–324, § 9(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1955"},"text":"130 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cce1a39-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cce1a3a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cce1a3b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 3797","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of Title 42, The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cce1a3c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":" added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s5001/b/5/A"},"text":"Pub. L. 107–273, § 5001(b)(5)(A)","children":[],"tail":", inserted “or unit of local government” after “each State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s5001/b/5/B"},"text":"Pub. L. 107–273, § 5001(b)(5)(B)","children":[],"tail":", inserted “, which shall include a comparison of pre-grant and post-grant forensic science capabilities” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s5001/b/5/C"},"text":"Pub. L. 107–273, § 5001(b)(5)(C)","children":[],"tail":"–(E), added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
