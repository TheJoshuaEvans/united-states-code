{"tag":"section","attrib":{"id":"id4d395e9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111"},"text":null,"children":[{"tag":"num","attrib":{"value":"21111"},"text":"§ 21111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National Strategy for Child Exploitation Prevention and Interdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395e9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General of the United States shall create and implement a National Strategy for Child Exploitation Prevention and Interdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-10-13"},"text":"October 13, 2008","children":[],"tail":", and on February 1 of every fourth year thereafter, the Attorney General shall submit to Congress the National Strategy established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required contents of National Strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Strategy established under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of current trends, challenges, and the overall magnitude of the threat of child exploitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of future trends and challenges, including new technologies, that will impact the efforts to combat child exploitation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ea0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Goals and strategic solutions to prevent and interdict child exploitation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ea1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for interagency coordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ea2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engagement with the judicial branches of the Federal Government and State governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ea3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legislative recommendations for combating child exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ea4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation with international, State, local, and Tribal law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ea5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engagement with the private sector and other entities involved in efforts to combat child exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ea6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An analysis of Federal efforts dedicated to combating child exploitation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ea7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the policies and work of the Department of Justice and other Federal programs relating to the prevention and interdiction of child exploitation crimes, including training programs, and investigative and prosecution activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ea8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the efforts of the Department of Justice to cooperate and coordinate with, and provide technical assistance and support to, international, State, local, and Tribal law enforcement agencies and private sector and nonprofit entities with respect to child exploitation prevention and interdiction efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ea9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An estimate of the resources required to effectively respond to child exploitation crimes at scale by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395eaa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each ICAC task force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation, including investigators, forensic interviewers, and analysts of victims, witnesses, and forensics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Homeland Security Investigations, including forensic interviewers and analysts of victims, witnesses, and forensics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ead-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Marshals Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Secret Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criminal investigative offices of the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eb1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any component of an agency described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395eb2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A review of the Internet Crimes Against Children Task Force Program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395eb3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of ICAC task forces and the location of each ICAC task force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eb4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of trained personnel at each ICAC task force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eb5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of Federal grants awarded to each ICAC task force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eb6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the Federal, State, and local cooperation with respect to each ICAC task force, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395eb7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of arrests made by each ICAC task force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395eb8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of criminal referrals to United States attorneys for prosecution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395eb9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of prosecutions and convictions from the referrals described in clause (ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395eba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, if available, of local prosecutions and convictions based on ICAC task force investigations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395ebb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/6/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information determined by the Attorney General demonstrating the level of Federal, State, Tribal, and local coordination and cooperation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ebc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of training needs for each ICAC task force and affiliated agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ebd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of Federal investigative and prosecution activity relating to reported incidents of child exploitation crimes that include a number of factors, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ebe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of investigations, arrests, prosecutions, and convictions for a crime of child exploitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ebf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average sentence imposed and the statutory maximum sentence that could be imposed for each crime of child exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ec0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A review of all available statistical data indicating the overall magnitude of child pornography trafficking in the United States and internationally, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ec1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of foreign and domestic suspects observed engaging in accessing and sharing child pornography;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ec2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of tips or other statistical data from the CyberTipline of the National Center for Missing and Exploited Children and other data indicating the magnitude of child pornography trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ec3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/c/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other statistical data indicating the type, nature, and extent of child exploitation crime in the United States and abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395ec4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of high-level official","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395ec5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall designate a senior official at the Department of Justice with experience in investigating or prosecuting child exploitation cases as the National Coordinator for Child Exploitation Prevention and Interdiction who shall be responsible for coordinating the development of the National Strategy established under subsection (a). The National Coordinator for Child Exploitation Prevention and Interdiction shall be a position in the Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ec6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the official designated under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ec7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as a liaison with all Federal agencies regarding the development of the National Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ec8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working to ensure that there is proper coordination among agencies in developing the National Strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ec9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being knowledgeable about budget priorities and familiar with all efforts within the Department of Justice and the FBI related to child exploitation prevention and interdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21111/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicating the National Strategy to Congress and being available to answer questions related to the strategy at congressional hearings, if requested by committees of appropriate jurisdictions, on the contents of the National Strategy and progress of the Department of Justice in implementing the National Strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395ecb-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401/tI/s101"},"text":"Pub. L. 110–401, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4230"},"text":"122 Stat. 4230","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/206/s6"},"text":"Pub. L. 112–206, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-07"},"text":"Dec. 7, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1493"},"text":"126 Stat. 1493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXII/s8202/a"},"text":"Pub. L. 119–60, div. H, title LXXXII, § 8202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1840"},"text":"139 Stat. 1840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395ecc-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395ecd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395ece-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17611"},"text":"section 17611 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d395ecf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/a/1"},"text":"Pub. L. 119–60, § 8202(a)(1)","children":[],"tail":", substituted “every fourth year” for “every second year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/a/2"},"text":"Pub. L. 119–60, § 8202(a)(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c), which set out the required contents of the National Strategy established under subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/206"},"text":"Pub. L. 112–206","children":[],"tail":" substituted “with experience in investigating or prosecuting child exploitation cases as the National Coordinator for Child Exploitation Prevention and Interdiction who shall be responsible” for “to be responsible” and inserted at end “The National Coordinator for Child Exploitation Prevention and Interdiction shall be a position in the Senior Executive Service.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
