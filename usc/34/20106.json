{"tag":"section","attrib":{"id":"id4d1f1f61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106"},"text":null,"children":[{"tag":"num","attrib":{"value":"20106"},"text":"§ 20106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation to victims of international terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1f62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1f63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International terrorism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international terrorism” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national of the United States” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"section 1101(a) of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1f1f66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “victim” means a person who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d1f1f67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suffered direct physical or emotional injury or death as a result of international terrorism occurring on or after ","children":[{"tag":"date","attrib":{"date":"1983-10-23"},"text":"October 23, 1983","children":[],"tail":", with respect to which an investigation or civil or criminal prosecution was ongoing after "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"April 24, 1996","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1f1f68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date on which the international terrorism occurred, was a national of the United States or an officer or employee of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f1f69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incompetent, incapacitated, or deceased victims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a victim who is less than 18 years of age, incompetent, incapacitated, or deceased, a family member or legal guardian of the victim may receive the compensation under this section on behalf of the victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f1f6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, in no event shall an individual who is criminally culpable for the terrorist act or mass violence receive any compensation under this section, either directly or on behalf of a victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may use the emergency reserve referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101/d/5/A"},"text":"section 20101(d)(5)(A) of this title","children":[],"tail":" to carry out a program to compensate victims of acts of international terrorism that occur outside the United States for expenses associated with that victimization. The amount of compensation awarded to a victim under this subsection shall be reduced by any amount that the victim received in connection with the same act of international terrorism under title VIII of the Omnibus Diplomatic Security and Antiterrorism Act of 1986."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall annually submit to Congress a report on the status and activities of the program under this section, which report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1f6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the procedures for filing and processing of applications for compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the procedures and policies instituted to promote public awareness about the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a complete statistical analysis of the victims assisted under the program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1f1f70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications for compensation submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f1f71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications approved and the amount of each award;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f1f72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications denied and the reasons for the denial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f1f73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average length of time to process an application for compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f1f74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications for compensation pending and the estimated future liability of the program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f75-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20106/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of future program needs and suggested program improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f1f76-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1404C"},"text":"Pub. L. 98–473, title II, § 1404C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dC/s2003/c/1"},"text":"Pub. L. 106–386, div. C, § 2003(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1544"},"text":"114 Stat. 1544","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVI/s624/c"},"text":"Pub. L. 107–56, title VI, § 624(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/373"},"text":"115 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1083/b/4"},"text":"Pub. L. 110–181, div. A, title X, § 1083(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/342"},"text":"122 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f1f77-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1f1f78-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d1f1f79-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Omnibus Diplomatic Security and Antiterrorism Act of 1986, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Pub. L. 99–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/853"},"text":"100 Stat. 853","children":[],"tail":". Title VIII of the Act, known as the “Victims of Terrorism Compensation Act”, enacted sections 5569 and 5570 of Title 5, Government Organization and Employees, sections 1051, 1095, and 2181 to 2185 of Title 10, Armed Forces, and sections 559 and 1013 of Title 37, Pay and Allowances of the Uniformed Services, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6325"},"text":"section 6325 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569"},"text":"section 5569 of Title 5","children":[],"tail":", sections 1051, 1095, and 2181 of Title 10, and "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s559"},"text":"section 559 of Title 37","children":[],"tail":". For complete classification of title VIII to the Code, see Short Title of 1986 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5569"},"text":"section 5569 of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1f1f7a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10603c"},"text":"section 10603c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d1f1f7b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1983-10-23"},"text":"October 23, 1983","children":[],"tail":", with respect to which an investigation or civil or criminal” for “"},{"tag":"date","attrib":{"date":"1988-12-21"},"text":"December 21, 1988","children":[],"tail":" with respect to which an investigation or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" inserted at end “The amount of compensation awarded to a victim under this subsection shall be reduced by any amount that the victim received in connection with the same act of international terrorism under title VIII of the Omnibus Diplomatic Security and Antiterrorism Act of 1986.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d1f1f7c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d1f1f7d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" to pending cases, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1083/c"},"text":"section 1083(c) of Pub. L. 110–181","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1605A"},"text":"section 1605A of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
