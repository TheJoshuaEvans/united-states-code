{"tag":"section","attrib":{"id":"id4d66b064-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907"},"text":null,"children":[{"tag":"num","attrib":{"value":"60907"},"text":"§ 60907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures to promote compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b065-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2022-08-03"},"text":"August 3, 2022","children":[],"tail":", the head of each agency shall promulgate regulations to enforce the right of a designated person to request a review under this chapter and to ensure compliance by the agency with the obligations described in this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b066-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations promulgated under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66b067-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an administrative authority within the agency to receive and investigate complaints relating to a review initiated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901"},"text":"section 60901 of this title","children":[],"tail":" or a reinvestigation initiated under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60903"},"text":"section 60903 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b068-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a course of training for appropriate employees and officers within the agency regarding the procedures, responsibilities, and obligations required under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b069-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain disciplinary sanctions, which may include suspension or termination from employment, for employees of the agency who are shown to have willfully or wantonly failed to comply with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b06a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a procedure for the resolution of complaints filed by the designated person concerning the agency’s handling of a cold case murder investigation or the case file evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b06b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60907/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the head of the agency, or the designee thereof, shall be the final arbiter of the complaint, and that there shall be no judicial review of the final decision of the head of the agency by a complainant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b06c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s8"},"text":"Pub. L. 117–164, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1360"},"text":"136 Stat. 1360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
