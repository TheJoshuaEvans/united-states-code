{"tag":"section","attrib":{"id":"id4d512bef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40704"},"text":null,"children":[{"tag":"num","attrib":{"value":"40704"},"text":"§ 40704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of release generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the collection of a DNA sample from an individual on probation, parole, or supervised release is authorized pursuant to section 40702 or 40703 of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1565"},"text":"section 1565 of title 10","children":[],"tail":", the individual shall cooperate in the collection of a DNA sample as a condition of that probation, parole, or supervised release."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d512bf0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s7/d"},"text":"Pub. L. 106–546, § 7(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2734"},"text":"114 Stat. 2734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512bf1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512bf2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512bf3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14135c"},"text":"section 14135c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
