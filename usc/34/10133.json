{"tag":"section","attrib":{"id":"id4c9e5615-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10133"},"text":null,"children":[{"tag":"num","attrib":{"value":"10133"},"text":"§ 10133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for 100 per centum grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A grant authorized under this subchapter may be up to 100 per centum of the total cost of each project for which such grant is made. The Bureau shall require, whenever feasible as a condition of approval of a grant under this subchapter, that the recipient contribute money, facilities, or services to carry out the purposes for which the grant is sought.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4c9e5616-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s303"},"text":"Pub. L. 90–351, title I, § 303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1178"},"text":"93 Stat. 1178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c9e5617-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c9e5618-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c9e5619-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was f