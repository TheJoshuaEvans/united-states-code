{"tag":"section","attrib":{"id":"id4ca3128d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172"},"text":null,"children":[{"tag":"num","attrib":{"value":"10172"},"text":"§ 10172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds; administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca3128e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount appropriated for this subpart in any fiscal year, 70 percent shall be used to make grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10171/a/1"},"text":"section 10171(a)(1) of this title","children":[],"tail":", 10 percent shall be used to make grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10171/a/2"},"text":"section 10171(a)(2) of this title","children":[],"tail":", 10 percent shall be used to make grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10171/a/3"},"text":"section 10171(a)(3) of this title","children":[],"tail":", and 10 percent for "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10171/a/4"},"text":"section 10171(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca3128f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on grant share of cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under paragraph (1) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10171/a"},"text":"section 10171(a) of this title","children":[],"tail":" may be made for an amount up to 75 percent of the cost of the correctional option contained in the approved application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca31290-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules; report; request for applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca31291-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after funds are first appropriated to carry out this subpart, issue rules to carry out this subpart; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca58292-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 180 days after funds are first appropriated to carry out this subpart—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca58293-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Speaker of the House of Representatives and the President pro tempore of the Senate, a report describing such rules; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca58294-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10172/c/2/B"},"text":null,"children":[{