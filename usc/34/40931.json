{"tag":"section","attrib":{"id":"id4d560df2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40931"},"text":null,"children":[{"tag":"num","attrib":{"value":"40931"},"text":"§ 40931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing evaluations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d560df3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40931/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Statistics (referred to in this section as the “Director”) shall study and evaluate the operations of the National Instant Criminal Background Check System. Such study and evaluation shall include compilations and analyses of the operations and record systems of the agencies and organizations necessary to support such System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560df4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40931/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 31 of each year, the Director shall submit to Congress a report containing the estimates submitted by the States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40912/b"},"text":"section 40912(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560df5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40931/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 31 of each year, the Director shall submit to Congress, and to each State participating in the National Criminal History Improvement Program, a report of the practices of the States regarding the collection, maintenance, automation, and transmittal of information relevant to determining whether a person is prohibited from possessing or receiving a firearm by Federal or State law, by the State or any other agency, or any other records relevant to the National Instant Criminal Background Check System, that the Director considers to be best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560df6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40931/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2009 through 2013 to complete the studies, evaluations, and reports required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d560df7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/180/tII/s201"},"text":"Pub. L. 110–180, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-08"},"text":"Jan. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2570"},"text":"121 Stat. 2570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d560df8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d560df9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d560dfa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
