{"tag":"section","attrib":{"id":"id4d15a9ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12571"},"text":null,"children":[{"tag":"num","attrib":{"value":"12571"},"text":"§ 12571.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In this part—","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“Director” means the Director of the Office of the Police Corps and Law Enforcement Education appointed under section 12553 ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12553"},"text":"Section 12553 of this title","children":[],"tail":" does not provide for the appointment of a Director."}],"tail":" of this title."}],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“educational expenses” means expenses that are directly attributable to—","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"(A) a course of education leading to the award of an associate degree;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"(B) a course of education leading to the award of a baccalaureate degree; or","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"(C) a course of graduate study following award of a baccalaureate degree,","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"including the cost of tuition, fees, books, supplies, and related expenses.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“institution of higher education” has the meaning stated in the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“law enforcement position” means employment as an officer in a State or local police force, or correctional institution.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands of the United States, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d15a9ad-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200202"},"text":"Pub. L. 103–322, title XX, § 200202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2057"},"text":"108 Stat. 2057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/tI/s102/a/13/P"},"text":"Pub. L. 105–244, title I, § 102(a)(13)(P)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-07"},"text":"Oct. 7, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1621"},"text":"112 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d15a9ae-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d15a9af-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d15a9b0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14111"},"text":"section 14111 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d15a9b1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" substituted “section 1001” for “section 1141(a)” in par. defining “institution of higher education”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d15a9b2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d15a9b3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/105/244"},"text":"Pub. L. 105–244","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/244/s3"},"text":"section 3 of Pub. L. 105–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}