{"tag":"section","attrib":{"id":"id4d58589d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41304"},"text":null,"children":[{"tag":"num","attrib":{"value":"41304"},"text":"§ 41304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family and domestic violence: data collection and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d58589e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family violence reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of title 28","children":[],"tail":", the Attorney General shall require, and include in uniform crime reports, data that indicate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d58589f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of the victim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the victim to the offender, for crimes of murder, aggravated assault, simple assault, rape, sexual offenses, and offenses against children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5858a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Crime Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Statistics, through the annual National Crime Survey, shall collect and publish data that more accurately measures the extent of domestic violence in America, especially the physical and sexual abuse of children and the elderly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5858a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated in fiscal years 1989, 1990, 1991, and 1992, such sums as are necessary to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5858a3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7609"},"text":"Pub. L. 100–690, title VII, § 7609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4517"},"text":"102 Stat. 4517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5858a4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5858a5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5858a6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
