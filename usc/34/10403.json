{"tag":"section","attrib":{"id":"id4cbd5051-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403"},"text":null,"children":[{"tag":"num","attrib":{"value":"10403"},"text":"§ 10403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd5052-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this subchapter, a State shall submit to the Attorney General an application at such time, in such form, and containing such assurances and information as the Attorney General may require by guidelines, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5053-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5054-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities proposed to be carried out with such grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd5055-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria by which the State proposes to assess the effectiveness of such activities on achieving the purposes of this subchapter, including the extent to which evidence-based approaches are utilized; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5056-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the State and any unit of local government to which the State provides funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10404/b"},"text":"section 10404(b) of this title","children":[],"tail":", has in effect (or shall have in effect, not later than 1 year after the date that the State submits such application) laws, or has implemented (or shall implement, not later than 1 year after the date that the State submits such application) policies and programs, that provide for a system of graduated sanctions described in subsection (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd5057-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5058-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrant eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a subgrant, a unit of local government, other than a specially qualified unit, shall provide to the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5059-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cbd505a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities proposed to be carried out with such subgrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cbd505b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria by which the unit proposes to assess the effectiveness of such activities on achieving the purposes of this subchapter, including the extent to which evidence-based approaches are utilized; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd505c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assurances as the State shall require, that, to the maximum extent applicable, the unit of local government has in effect (or shall have in effect, not later than 1 year after the date that the unit submits such application) laws, or has implemented (or shall implement, not later than 1 year after the date that the unit submits such application) policies and programs, that provide for a system of graduated sanctions described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd505d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of paragraph (1) shall apply to a specially qualified unit that receives funds from the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10404/e"},"text":"section 10404(e) of this title","children":[],"tail":", except that information that is otherwise required to be submitted to the State shall be submitted to the Attorney General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd505e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the development of the grant application, the States and units of local governments shall take into consideration the needs of the judicial branch in strengthening the juvenile justice system and specifically seek the advice of the chief of the highest court of the State and where appropriate, the chief judge of the local court, with respect to the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd505f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Graduated sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A system of graduated sanctions, which may be discretionary as provided in subsection (e), shall ensure, at a minimum, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5060-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanctions are imposed on a juvenile offender for each delinquent offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5061-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanctions escalate in intensity with each subsequent, more serious delinquent offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5062-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is sufficient flexibility to allow for individualized sanctions and services suited to the individual juvenile offender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5063-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate consideration is given to public safety and victims of crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd5064-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary use of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5065-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or unit of local government may be eligible to receive a grant under this subchapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5066-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its system of graduated sanctions is discretionary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd5067-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it demonstrates that it has promoted the use of a system of graduated sanctions by taking steps to encourage implementation of such a system by juvenile courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5068-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement if graduated sanctions not used","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5069-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile courts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or unit of local government in which the imposition of graduated sanctions is discretionary shall require each juvenile court within its jurisdiction—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cbd506a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has not implemented a system of graduated sanctions, to submit an annual report that explains why such court did not implement graduated sanctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cbd506b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has implemented a system of graduated sanctions but has not imposed graduated sanctions in all cases, to submit an annual report that explains why such court did not impose graduated sanctions in all cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd506c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Units of local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each unit of local government, other than a specially qualified unit, that has 1 or more juvenile courts that use a discretionary system of graduated sanctions shall collect the information reported under subparagraph (A) for submission to the State each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd506d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State and specially qualified unit that has 1 or more juvenile courts that use a discretionary system of graduated sanctions shall collect the information reported under subparagraph (A) for submission to the Attorney General each year. A State shall also collect and submit to the Attorney General the information collected under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd506e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd506f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “discretionary” means that a system of graduated sanctions is not required to be imposed by each and every juvenile court in a State or unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5070-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10403/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sanctions” means tangible, proportional consequences that hold the juvenile offender accountable for the offense committed. A sanction may include counseling, restitution, community service, a fine, supervised probation, or confinement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd5071-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1802"},"text":"Pub. L. 90–351, title I, § 1802","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1861"},"text":"116 Stat. 1861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1168/a"},"text":"Pub. L. 109–162, title XI, § 1168(a)","children":[],"tail":", formerly § 1168, "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3122"},"text":"119 Stat. 3122","children":[],"tail":", renumbered § 1168(a), "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/n/5/A"},"text":"Pub. L. 109–271, § 8(n)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/768"},"text":"120 Stat. 768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd5072-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd5073-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd5074-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–2"},"text":"section 3796ee–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbd5075-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1802"},"text":"section 1802 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20201/a/3"},"text":"Pub. L. 103–322, title II, § 20201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1820"},"text":"108 Stat. 1820","children":[],"tail":", and classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–1"},"text":"section 3796ee–1 of Title 42","children":[],"tail":", The Public Health and Welfare, related to State applications for grants, prior to the general amendment of part R of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbd5076-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a)(1)(B), (b)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1168/a"},"text":"Pub. L. 109–162, § 1168(a)","children":[],"tail":", formerly § 1168, as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":", inserted “, including the extent to which evidence-based approaches are utilized” after “subchapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cbd5077-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cbd5078-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1168/b"},"text":"Pub. L. 109–162, title XI, § 1168(b)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/n/5/B"},"text":"Pub. L. 109–271, § 8(n)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/768"},"text":"120 Stat. 768","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/271/s8/n/5/B"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
