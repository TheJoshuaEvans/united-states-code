{"tag":"section","attrib":{"id":"id4d4c708e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302"},"text":null,"children":[{"tag":"num","attrib":{"value":"40302"},"text":"§ 40302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for improvement of criminal records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c708f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for the improvement of criminal records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, through the Bureau of Justice Statistics, shall, subject to appropriations and with preference to States that, as of ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", have the lowest percent currency of case dispositions in computerized criminal history files and that will utilize funding under this subsection to prioritize the identification and transmittal of felony conviction records and domestic violence records, make a grant to each State to be used—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4c7090-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the creation of a computerized criminal history record system or improvement of an existing system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c7091-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve accessibility to the national instant criminal background system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c7092-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the State in the transmittal of criminal records to the national system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c7093-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish and achieve compliance with an implementation plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40917"},"text":"section 40917 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c7094-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for grants under paragraph (1) a total of $200,000,000 for fiscal year 1994 and all fiscal years thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4c7095-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/159/tI/s106/b"},"text":"Pub. L. 103–159, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1544"},"text":"107 Stat. 1544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210603/b"},"text":"Pub. L. 103–322, title XXI, § 210603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2074"},"text":"108 Stat. 2074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s603/i/1"},"text":"Pub. L. 104–294, title VI, § 603(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3504"},"text":"110 Stat. 3504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tVI/s604/b"},"text":"Pub. L. 115–141, div. S, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1136"},"text":"132 Stat. 1136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4c7096-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4c7097-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4c7098-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/159/s106"},"text":"section 106 of Pub. L. 103–159","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/159/s106"},"text":"section 106 of Pub. L. 103–159","children":[],"tail":" amended former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3759"},"text":"section 3759 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Brady Handgun Violence Prevention Act and not as part of the Crime Identification Technology Act of 1998 which comprises this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d4c7099-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s604/b/1"},"text":"Pub. L. 115–141, § 604(b)(1)","children":[],"tail":", in introductory provisions, substituted “, as of "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":",” for “as of "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"November 30, 1993","children":[],"tail":",” and “files and that will utilize funding under this subsection to prioritize the identification and transmittal of felony conviction records and domestic violence records,” for “files,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s604/b/3/A"},"text":"Pub. L. 115–141, § 604(b)(3)(A)","children":[],"tail":", struck out “upon establishment of the national system,” before “to assist the State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s604/b/2"},"text":"Pub. L. 115–141, § 604(b)(2)","children":[],"tail":", (3)(B), (4), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/s603/i/1"},"text":"Pub. L. 104–294, § 603(i)(1)","children":[],"tail":", amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s210603/b"},"text":"Pub. L. 103–322, § 210603(b)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s210603/b"},"text":"Pub. L. 103–322, § 210603(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s603/i/1"},"text":"Pub. L. 104–294, § 603(i)(1)","children":[],"tail":", struck out “, which may be appropriated from the Violent Crime Reduction Trust Fund established by "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of title 31","children":[],"tail":", United States Code,” after “grants under paragraph (1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d4c709a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d4c709b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s603/i/2"},"text":"Pub. L. 104–294, title VI, § 603(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3504"},"text":"110 Stat. 3504","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/294/tVI/s603/i/2"},"text":"“The amendment made by paragraph (1) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s210603/b"},"text":"section 210603(b) of Pub. L. 103–322","children":[],"tail":", which amended this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40901"},"text":"section 40901 of this title","children":[],"tail":"] shall take effect as if the amendment had been included in section 210603(b) of the Act referred to in paragraph (1) ["},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":"] on the date of the enactment of such Act ["},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
