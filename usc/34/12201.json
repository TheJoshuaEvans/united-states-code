{"tag":"section","attrib":{"id":"id4cfdb4f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201"},"text":null,"children":[{"tag":"num","attrib":{"value":"12201"},"text":"§ 12201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development corporation improvement grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb4f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to provide assistance to community development corporations to upgrade the management and operating capacity of such corporations and to enhance the resources available to enable such corporations to increase their community economic development activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb4fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Skill enhancement grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb4fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to community development corporations to enable such corporations to attain or enhance the business management and development skills of the individuals that manage such corporations to enable such corporations to seek the public and private resources necessary to develop community economic development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb4fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant under paragraph (1) may use amounts received under such grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfdb4fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire training and technical assistance from agencies or institutions that have extensive experience in the development and management of low-income community economic development projects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfdb4fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire such assistance from other highly successful community development corporations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb4ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb500-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to community development corporations to enable such corporations to support an administrative capacity for the planning, development, and management of low-income community economic development projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb501-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant under paragraph (1) may use amounts received under such grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfdb502-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct evaluations of the feasibility of potential low-income community economic development projects that address identified needs in the low-income community and that conform to those projects and activities permitted under subpart 1; ","children":[{"tag":"ref","attrib":{"idref":"fn002098"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002098"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfdb503-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a business plan related to such a potential project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfdb504-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mobilize resources to be contributed to a planned low-income community economic development project or strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb505-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A community development corporation that desires to receive a grant under this section shall prepare and submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb506-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12201/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount available for community development corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided under this section to a community development corporation shall not exceed $75,000 per year. Such corporations may apply for grants under this section for up to 3 consecutive years, except that such corporations shall be required to submit a new application for each grant for which such corporation desires to receive and compete on the basis of such applications in the selection process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb507-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31121"},"text":"Pub. L. 103–322, title III, § 31121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1885"},"text":"108 Stat. 1885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb508-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb509-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfdb50a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subpart 1, referred to in subsec. (c)(2)(A), was in the original “subtitle A”, and was translated as reading “chapter 1”, meaning chapter 1 of subtitle K of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb50b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13841"},"text":"section 13841 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
