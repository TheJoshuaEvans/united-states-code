{"tag":"section","attrib":{"id":"id4ca311f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158"},"text":null,"children":[{"tag":"num","attrib":{"value":"10158"},"text":"§ 10158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest-bearing trust funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca311f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust fund required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or unit of local government shall establish a trust fund in which to deposit amounts received under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca311f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca311fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each amount received under this part (including interest on such amount) shall be expended before the date on which the grant period expires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca311fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or unit of local government that fails to expend an entire amount (including interest on such amount) as required by paragraph (1) shall repay the unexpended portion to the Attorney General not later than 3 months after the date on which the grant period expires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca311fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of future amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State or unit of local government fails to comply with paragraphs (1) and (2), the Attorney General shall reduce amounts to be provided to that State or unit of local government accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca311fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repaid amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received as repayments under this section shall be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10108"},"text":"section 10108 of this title","children":[],"tail":" as if such amounts had not been granted and repaid. Such amounts shall be deposited in the Treasury in a dedicated fund for use by the Attorney General to carry out this part. Such funds are hereby made available to carry out this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca311fe-5