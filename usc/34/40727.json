{"tag":"section","attrib":{"id":"id4d512c9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40727"},"text":null,"children":[{"tag":"num","attrib":{"value":"40727"},"text":"§ 40727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kirk Bloodsworth Post-Conviction DNA Testing Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512c9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish the Kirk Bloodsworth Post-Conviction DNA Testing Grant Program to award grants to States to help defray the costs of post-conviction DNA testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $10,000,000 for each of fiscal years 2017 through 2021 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512ca0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s412"},"text":"Pub. L. 108–405, title IV, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2284"},"text":"118 Stat. 2284","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s12/b"},"text":"Pub. L. 114–324, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1957"},"text":"130 Stat. 1957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512ca1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512ca2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512ca3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14136e"},"text":"section 14136e of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d512ca4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":" substituted “$10,000,000 for each of fiscal years 2017 through 2021” for “$5,000,000 for each of fiscal years 2005 through 2009”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
