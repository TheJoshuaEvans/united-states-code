{"tag":"section","attrib":{"id":"id4cb8952c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10301"},"text":null,"children":[{"tag":"num","attrib":{"value":"10301"},"text":"§ 10301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb8952d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the appeal of service in public safety agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb8952e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to extend the benefits of higher education to qualified and deserving persons who, by virtue of the death of or total disability of an eligible officer, may not be able to afford it otherwise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb8952f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow the family members of eligible officers to attain the vocational and educational status which they would have attained had a parent or spouse not been killed or disabled in the line of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cb89530-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1211"},"text":"Pub. L. 90–351, title I, § 1211","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/238/s2/2"},"text":"Pub. L. 104–238, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3114"},"text":"110 Stat. 3114","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/390/s2/2"},"text":"Pub. L. 105–390, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3495"},"text":"112 Stat. 3495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb89531-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb89532-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb89533-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796d"},"text":"section 3796d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cb89534-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/390"},"text":"Pub. L. 105–390","children":[],"tail":" substituted “public safety” for “civilian Federal law enforcement”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cb89535-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id4cb89536-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/238"},"text":"Pub. L. 104–238","children":[],"tail":", which enacted this subchapter, as the “Federal Law Enforcement Dependents Assistance Act of 1996”, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/238/s1"},"text":"section 1 of Pub. L. 104–238","children":[],"tail":", set out as a Short Title of 1996 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
