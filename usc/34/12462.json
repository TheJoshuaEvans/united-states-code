{"tag":"section","attrib":{"id":"id4d099be7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462"},"text":null,"children":[{"tag":"num","attrib":{"value":"12462"},"text":"§ 12462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this part is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099be8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent crimes involving violence against women, children, and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099be9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the resources and services available to prevent violence against women, children, and youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the impact of exposure to violence in the lives of children and youth so that the intergenerational cycle of violence is interrupted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099beb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement education and services programs to prevent children in vulnerable families from becoming victims or perpetrators of domestic violence, dating violence, sexual assault, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote programs to ensure that children and youth receive the assistance they need to end the cycle of violence and develop mutually respectful, nonviolent relationships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12462/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage collaboration among community-based organizations and governmental agencies serving children and youth, providers of health and mental health services and providers of domestic violence, dating violence, sexual assault, and stalking victim services to prevent violence against women and children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d099bee-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41302"},"text":"Pub. L. 103–322, title IV, § 41302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIV/s401"},"text":"Pub. L. 109–162, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3018"},"text":"119 Stat. 3018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d099bef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d099bf0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d099bf1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043d–1"},"text":"section 14043d–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
