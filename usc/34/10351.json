{"tag":"section","attrib":{"id":"id4cbb05f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351"},"text":null,"children":[{"tag":"num","attrib":{"value":"10351"},"text":"§ 10351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural drug enforcement assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbb05f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the total amount appropriated for this section in any fiscal year:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbb05f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent shall be allocated to and shared equally among rural States as described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb05f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent shall be allocated to the remaining States for use in nonmetropolitan areas within those States, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbb05f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000 to each nonrural State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbb05fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the total funds remaining after the allocation in subparagraph (A), there shall be allocated to each State an amount which bears the same ratio to the amount of remaining funds described as the population of such State bears to the population of all States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbb05fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “rural State” means a State that has a population density of fifty-two or fewer persons per square mile or a State in which the largest county has fewer than one hundred and fifty thousand people, based on the decennial census of 1990 through fiscal year 1997.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbb05fc-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1501"},"text":"Pub. L. 90–351, title I, § 1501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tVIII/s801/a/3"},"text":"Pub. L. 101–647, title VIII, § 801(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4825"},"text":"104 Stat. 4825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXVIII/s180101/b"},"text":"Pub. L. 103–322, title XVIII, § 180101(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2045"},"text":"108 Stat. 2045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbb05fd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbb05fe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbb05ff-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796bb"},"text":"section 3796bb of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbb0600-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1501"},"text":"section 1501 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2601 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10541"},"text":"section 10541 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1501"},"text":"section 1501 of Pub. L. 90–351","children":[],"tail":", title X, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/238"},"text":"82 Stat. 238","children":[],"tail":", was not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbb0601-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s180101/b"},"text":"Pub. L. 103–322, § 180101(b)","children":[],"tail":", substituted “$250,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s180101/c"},"text":"Pub. L. 103–322, § 180101(c)","children":[],"tail":", inserted before period at end “, based on the decennial census of 1990 through fiscal year 1997”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
