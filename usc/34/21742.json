{"tag":"section","attrib":{"id":"id4d3e19fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21742"},"text":null,"children":[{"tag":"num","attrib":{"value":"21742"},"text":"§ 21742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3e19fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate agreements and compacts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consent of Congress is given to any two or more States (acting through State agencies with jurisdiction over adult protective services) to enter into agreements or compacts for cooperative effort and mutual assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3e19fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21742/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in promoting the safety and well-being of elders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21742/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in enforcing their respective laws and policies to promote such safety and well-being.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations on interstate communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director of the State Justice Institute, in consultation with State or local adult protective services, aging, social, and human services and law enforcement agencies, nationally recognized nonprofit associations with expertise in data sharing among criminal justice agencies and familiarity with the issues raised in elder abuse cases, and the Secretary of Health and Human Services, shall submit to Congress legislative proposals relating to the facilitation of interstate agreements and compacts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3e19ff-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIV/s404"},"text":"Pub. L. 115–70, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1215"},"text":"131 Stat. 1215","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
