{"tag":"section","attrib":{"id":"id4d1a6468-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641"},"text":null,"children":[{"tag":"num","attrib":{"value":"12641"},"text":"§ 12641.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force relating to introduction of nonindigenous species","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1a6469-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to convene a law enforcement task force in Hawaii to facilitate the prosecution of violations of Federal laws, and laws of the State of Hawaii, relating to the wrongful conveyance, sale, or introduction of nonindigenous plant and animal species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1a646a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1a646b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The task force shall be composed of representatives of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d1a646c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the United States Attorney for the District of Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a646d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Customs Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a646e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Animal and Plant Health Inspection Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a646f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fish and Wildlife Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6470-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Park Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6471-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Forest Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6472-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Military Customs Inspection Office of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6473-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6474-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office of the Attorney General of the State of Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6475-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hawaii Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6476-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hawaii Department of Land and Natural Resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1a6477-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other individuals as the Attorney General deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1a6478-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall, to the extent practicable, select individuals to serve on the task force who have experience with the enforcement of laws relating to the wrongful conveyance, sale, or introduction of nonindigenous plant and animal species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1a6479-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The task force shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1a647a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the prosecution of violations of Federal and State laws relating to the conveyance, sale, or introduction of nonindigenous plant and animal species into Hawaii; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1a647b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations on ways to strengthen Federal and State laws and law enforcement strategies designed to prevent the introduction of nonindigenous plant and animal species.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1a647c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The task force shall report to the Attorney General, the Secretary of Agriculture, the Secretary of the Interior, and to the Committee on the Judiciary and Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on the Judiciary, Committee on Agriculture, and Committee on Merchant Marine and Fisheries of the House of Representatives on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1a647d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of its enforcement efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1a647e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of existing Federal laws and laws of the State of Hawaii that relate to the introduction of nonindigenous plant and animal species.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Thereafter, the task force shall make such reports as the task force deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1a647f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12641/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall consult with Hawaii agricultural interests and representatives of Hawaii conservation organizations about methods of preventing the wrongful conveyance, sale, or introduction of nonindigenous plant and animal species into Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1a6480-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320108/a"},"text":"Pub. L. 103–322, title XXXII, § 320108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2111"},"text":"108 Stat. 2111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1a6481-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1a6482-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1a6483-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14221"},"text":"section 14221 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d1a6484-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id4d1a6485-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the United States Customs Service of the Department of the Treasury, including functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(1), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":". For establishment of U.S. Customs and Border Protection in the Department of Homeland Security, treated as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/b"},"text":"section 802(b) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d1a6486-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of House Committee on Merchant Marine and Fisheries","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Merchant Marine and Fisheries of House of Representatives abolished and its jurisdiction transferred by House Resolution No. 6, One Hundred Fourth Congress, ","children":[{"tag":"date","attrib":{"date":"1995-01-04"},"text":"Jan. 4, 1995","children":[],"tail":". For treatment of references to Committee on Merchant Marine and Fisheries, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/b/3"},"text":"section 1(b)(3) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
