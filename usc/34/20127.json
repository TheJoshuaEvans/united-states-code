{"tag":"section","attrib":{"id":"id4d2190b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127"},"text":null,"children":[{"tag":"num","attrib":{"value":"20127"},"text":"§ 20127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and transitional pet shelter and housing assistance grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2190b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2190b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting in consultation with the Office of the Violence Against Women ","children":[{"tag":"ref","attrib":{"idref":"fn002161"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002161"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Office on Violence Against Women”."}],"tail":" of the Department of Justice, the Secretary of Housing and Urban Development, and the Secretary of Health and Human Services, shall award grants under this section to eligible entities to carry out programs to provide the assistance described in paragraph (3) with respect to victims of domestic violence, dating violence, sexual assault, or stalking and the pets, service animals, emotional support animals, or horses of such victims."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Memorandum of understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a memorandum of understanding with the head of another Department or agency, as appropriate, to carry out any of the authorities provided to the Secretary under this section.","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2190bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity seeking a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d2190bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities for which a grant under this section is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assurances as the Secretary determines to be necessary to ensure compliance by the entity with the requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the entity, before engaging with any individual domestic violence victim, will disclose to the victim any mandatory duty of the entity to report instances of abuse and neglect (including instances of abuse and neglect of pets, service animals, emotional support animals, or horses).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the requirements of subparagraph (A), each application submitted by an eligible entity under that subparagraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d2190c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not include proposals for any activities that may compromise the safety of a domestic violence victim, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d2190c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" background checks of domestic violence victims; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d2190c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical evaluations to determine the eligibility of such a victim for support services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not include proposals that would require mandatory services for victims or that a victim obtain a protective order in order to receive proposed services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the eligible entity’s understanding of the dynamics of domestic violence, dating violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph shall be construed to require—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d2190c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic violence victims to participate in the criminal justice system in order to receive services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible entities receiving a grant under this section to breach client confidentiality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section may only be used for programs that provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2190c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency and transitional shelter and housing assistance for domestic violence victims with pets, service animals, emotional support animals, or horses, including assistance with respect to any construction or operating expenses of newly developed or existing emergency and transitional pet, service animal, emotional support animal, or horse shelter and housing (regardless of whether such shelter and housing is co-located at a victim service provider or within the community);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short-term shelter and housing assistance for domestic violence victims with pets, service animals, emotional support animals, or horses, including assistance with respect to expenses incurred for the temporary shelter, housing, boarding, or fostering of the pets, service animals, emotional support animals, or horses of domestic violence victims and other expenses that are incidental to securing the safety of such a pet, service animal, emotional support animal, or horse during the sheltering, housing, or relocation of such victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support services designed to enable a domestic violence victim who is fleeing a situation of domestic violence, dating violence, sexual assault, or stalking to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d2190cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" locate and secure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d2190cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe housing with the victim’s pet, service animal, emotional support animal, or horse; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d2190ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe accommodations for the victim’s pet, service animal, emotional support animal, or horse; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the victim with pet, service animal, emotional support animal, or horse related services, such as transportation, care services, and other assistance; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the training of relevant stakeholders on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d2190d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the link between domestic violence, dating violence, sexual assault, or stalking and the abuse and neglect of pets, service animals, emotional support animals, and horses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of domestic violence victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for providing support services to such victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for providing such victims with referrals to victims’ services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d2190d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/3/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of confidentiality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall, as a condition of such receipt, agree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2190d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be bound by the nondisclosure of confidential information requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/b/2"},"text":"section 12291(b)(2) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2190d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the entity shall not condition the receipt of support, housing, or other benefits provided pursuant to this section on the participation of domestic violence victims in any or all of the support services offered to such victims through a program carried out by the entity using grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of assistance provided to victims","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2190da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), assistance provided with respect to a pet, service animal, emotional support animal, or horse of a domestic violence victim using grant funds awarded under this section shall be provided for a period of not more than 24 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section may extend the 24-month period referred to in subparagraph (A) for a period of not more than 6 months in the case of a domestic violence victim who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23d9cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made a good faith effort to acquire permanent housing for the victim and the victim’s pet, service animal, emotional support animal, or horse during that 24-month period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23d9cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been unable to acquire such permanent housing within that period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23d9ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which an eligible entity receives a grant under this section and each year thereafter in which the grant funds are used, the entity shall submit to the Secretary a report that contains, with respect to assistance provided by the entity to domestic violence victims with pets, service animals, emotional support animals, or horses using grant funds received under this section, information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23d9cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of domestic violence victims with pets, service animals, emotional support animals, or horses provided such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose, amount, type of, and duration of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23d9d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23d9d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than November 1 of each even-numbered fiscal year, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that contains a compilation of the information contained in the reports submitted under paragraph (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall transmit a copy of the report submitted under subparagraph (A) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23d9d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office on Violence Against Women of the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23d9d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Community Planning and Development of the Department of Housing and Urban Development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23d9d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administration for Children and Families of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23d9d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23d9d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $3,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount made available under subparagraph (A) in any fiscal year, not more than 5 percent may be used for evaluation, monitoring, salaries, and administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23d9da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23d9db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic violence victim defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “domestic violence victim” means a victim of domestic violence, dating violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23d9dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23d9de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23d9df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23d9e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other organization that has a documented history of effective work concerning domestic violence, dating violence, sexual assault, or stalking (as determined by the Secretary), including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d23d9e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a domestic violence and sexual assault victim service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23d9e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a domestic violence and sexual assault coalition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23d9e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based and culturally specific organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23d9e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other nonprofit, nongovernmental organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23d9e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any organization that works directly with pets, service animals, emotional support animals, or horses and collaborates with any organization referred to in clauses (i) through (iv), including—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id4d23d9e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/V/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an animal shelter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d23d9e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/B/iv/V/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an animal welfare organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emotional support animal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “emotional support animal” means an animal that is covered by the exclusion specified in section 5.303 of title 24, Code of Federal Regulations (or a successor regulation), and that is not a service animal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pet” means a domesticated animal, such as a dog, cat, bird, rodent, fish, turtle, or other animal that is kept for pleasure rather than for commercial purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service animal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “service animal” has the meaning given the term in section 36.104 of title 28, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23d9eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20127/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, terms used in this section ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" shall have the meaning given such terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d23d9ec-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12502/b"},"text":"Pub. L. 115–334, title XII, § 12502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4983"},"text":"132 Stat. 4983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d23d9ed-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d23d9ee-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d23d9ef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to par. (1)(B) and the second time appearing in par. (9)(F), was so in the original, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12502"},"text":"section 12502 of title XII of Pub. L. 115–334","children":[],"tail":". For classification of section 12502 to the Code, see Codification note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d23d9f0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12502/b"},"text":"section 12502(b) of title XII of Pub. L. 115–334","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12502/a"},"text":"Section 12502(a) of Pub. L. 115–334","children":[],"tail":" amended sections 2261A, 2262, 2264, and 2266 of Title 18, Crimes and Criminal Procedure. "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12502/c"},"text":"Section 12502(c) of Pub. L. 115–334","children":[],"tail":" is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d23d9f1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d23d9f2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
