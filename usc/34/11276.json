{"tag":"section","attrib":{"id":"id4cef8394-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11276"},"text":null,"children":[{"tag":"num","attrib":{"value":"11276"},"text":"§ 11276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated review of applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With respect to funds available to carry out parts A, B, C, D, and E, nothing in this subchapter shall be construed to prohibit the Secretary from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cef8395-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11276/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announcing, in a single announcement, the availability of funds for grants under 2 or more of such parts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef8396-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11276/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing applications for grants under 2 or more of such parts in a single, consolidated application review process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cef8397-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s385"},"text":"Pub. L. 93–415, title III, § 385","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3"},"text":"Pub. L. 106–71, § 3","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1041"},"text":"113 Stat. 1041","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cef8398-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cef8399-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cef839a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5731a"},"text":"section 5731a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cef839b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s385"},"text":"section 385 of Pub. L. 93–415","children":[],"tail":" was renumbered section 388 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11280"},"text":"section 11280 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
