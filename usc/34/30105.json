{"tag":"section","attrib":{"id":"id4d408abd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105"},"text":null,"children":[{"tag":"num","attrib":{"value":"30105"},"text":"§ 30105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding for resources to investigate and prosecute intellectual property crimes and other criminal activity involving computers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d408abe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding for resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d408abf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to amounts otherwise authorized for resources to investigate and prosecute intellectual property crimes and other criminal activity involving computers, there are authorized to be appropriated for each of the fiscal years 2009 through 2013—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d408ac0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 to the Director of the Federal Bureau of Investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408ac1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 to the Attorney General for the Criminal Division of the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408ac2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts appropriated under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d408ac3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of additional funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under subsection (a) shall be used by the Director of the Federal Bureau of Investigation and the Attorney General, for the Federal Bureau of Investigation and the Criminal Division of the Department of Justice, respectively, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d408ac4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" hire and train law enforcement officers to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d408ac5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate intellectual property crimes and other crimes committed through the use of computers and other information technology, including through the use of the Internet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408ac6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the prosecution of such crimes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408ac7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable relevant units of the Department of Justice, including units responsible for investigating computer hacking or intellectual property crimes, to procure advanced tools of forensic science and expert computer forensic assistance, including from non-governmental entities, to investigate, prosecute, and study such crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d408ac8-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/403/tIV/s403"},"text":"Pub. L. 110–403, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4273"},"text":"122 Stat. 4273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d408ac9-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d408aca-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d408acb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3713c"},"text":"section 3713c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
