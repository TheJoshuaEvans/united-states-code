{"tag":"section","attrib":{"id":"id4d395de7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983"},"text":null,"children":[{"tag":"num","attrib":{"value":"20983"},"text":"§ 20983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to combat sexual abuse of children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395de8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau of Justice Assistance is authorized to make grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395de9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any law enforcement agency that serves a jurisdiction with 50,000 or more residents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any law enforcement agency that serves a jurisdiction with fewer than 50,000 residents, upon a showing of need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395deb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under this section may be used by the law enforcement agency to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395dec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire additional law enforcement personnel or train existing staff to combat the sexual abuse of children through community education and outreach, investigation of complaints, enforcement of laws relating to sex offender registries, and management of released sex offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ded-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate the use of the Internet to facilitate the sexual abuse of children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase computer hardware and software necessary to investigate sexual abuse of children over the Internet, access local, State, and Federal databases needed to apprehend sex offenders, and facilitate the creation and enforcement of sex offender registries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395def-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall give priority to law enforcement agencies making a showing of need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395df0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20983/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal years 2007 through 2009 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395df1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s625"},"text":"Pub. L. 109–248, title VI, § 625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/636"},"text":"120 Stat. 636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395df2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395df3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395df4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16983"},"text":"section 16983 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
