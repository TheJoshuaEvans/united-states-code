{"tag":"section","attrib":{"id":"id4d2d7713-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501"},"text":null,"children":[{"tag":"num","attrib":{"value":"20501"},"text":"§ 20501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National coordination of AMBER Alert communications network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d2d7714-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination within Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall assign an officer of the Department of Justice to act as the national coordinator of the AMBER Alert communications network regarding abducted children. The officer so designated shall be known as the AMBER Alert Coordinator of the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7715-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In acting as the national coordinator of the AMBER Alert communications network, the Coordinator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d7716-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to eliminate gaps in the network, including gaps in areas of interstate travel (including airports, maritime ports, border crossing areas and checkpoints, and ports of exit from the United States);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7717-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States, territories of the United States, and tribal governments to encourage the development of additional elements (known as local AMBER plans) in the network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7718-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States, territories of the United States, and tribal governments to ensure appropriate regional coordination of various elements of the network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7719-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" act as the nationwide point of contact for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2d771a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of the network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2d771b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional coordination of alerts on abducted children through the network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d771c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Federal Bureau of Investigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out duties under subsection (b), the Coordinator shall notify and consult with the Director of the Federal Bureau of Investigation concerning each child abduction for which an alert is issued through the AMBER Alert communications network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d771d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Coordinator shall cooperate with the Secretary of Transportation, the Secretary of Homeland Security, and the Federal Communications Commission in carrying out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d771e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2005-03-01"},"text":"March 1, 2005","children":[],"tail":", the Coordinator shall submit to Congress a report on the activities of the Coordinator and the effectiveness and status of the AMBER plans of each State that has implemented such a plan. The Coordinator shall prepare the report in consultation with the Secretary of Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2d771f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tIII/s301"},"text":"Pub. L. 108–21, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/660"},"text":"117 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tC/s10001/a/1"},"text":"Pub. L. 116–283, div. H, title C, § 10001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4860"},"text":"134 Stat. 4860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2d7720-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2d7721-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2d7722-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5791"},"text":"section 5791 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d2d7723-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/a/1/A/i"},"text":"Pub. L. 116–283, § 10001(a)(1)(A)(i)","children":[],"tail":", inserted “(including airports, maritime ports, border crossing areas and checkpoints, and ports of exit from the United States)” after “gaps in areas of interstate travel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/a/1/A/ii"},"text":"Pub. L. 116–283, § 10001(a)(1)(A)(ii)","children":[],"tail":", inserted “, territories of the United States, and tribal governments” after “States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/a/1/B"},"text":"Pub. L. 116–283, § 10001(a)(1)(B)","children":[],"tail":", inserted “, the Secretary of Homeland Security,” after “Secretary of Transportation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
