{"tag":"section","attrib":{"id":"id4d323277-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705"},"text":null,"children":[{"tag":"num","attrib":{"value":"20705"},"text":"§ 20705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancing State and local efforts to combat trafficking in persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d323278-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of grant program for law enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d323279-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make grants to States and local law enforcement agencies to establish, develop, expand, or strengthen programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d32327a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to investigate and prosecute acts of severe forms of trafficking in persons, and related offenses that occur, in whole or in part, within the territorial jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d32327b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train law enforcement personnel how to identify victims of severe forms of trafficking in persons and related offenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d32327c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to investigate and prosecute persons who engage in the purchase of commercial sex acts and prioritize the investigations and prosecutions of those cases involving minor victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d32327d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate persons charged with, or convicted of, purchasing or attempting to purchase commercial sex acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d32327e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate and train law enforcement personnel in how to establish trust of persons subjected to trafficking and encourage cooperation with prosecution efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d32327f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, to designate at least 1 prosecutor for cases of severe forms of trafficking in persons (as such term is defined in section 7102(9) ","children":[{"tag":"ref","attrib":{"idref":"fn002178"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002178"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 22)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d323280-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “related offenses” includes violations of tax laws, transacting in illegally derived proceeds, money laundering, racketeering, and other violations of criminal laws committed in connection with an act of sex trafficking or a severe form of trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d323281-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-disciplinary approach required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under subsection (a) may be made only for programs in which the State or local law enforcement agency works collaboratively with social service providers and relevant nongovernmental organizations, including organizations with experience in the delivery of services to persons who are the subject of trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d323282-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of a grant made under this section may not exceed 75 percent of the total costs of the projects described in the application submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d323283-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No limitation on section 20702 grant applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that applies for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20702"},"text":"section 20702 of this title","children":[],"tail":" is not prohibited from also applying for a grant under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d323284-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Attorney General to carry out this section $10,000,000 for each of the fiscal years 2014 through 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d323285-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO evaluation and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2013-03-07"},"text":"March 7, 2013","children":[],"tail":", the Comptroller General of the United States shall conduct a study of and submit to Congress a report evaluating the impact of this section on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d323286-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of law enforcement personnel to identify victims of severe forms of trafficking in persons and investigate and prosecute cases against offenders, including offenders who engage in the purchasing of commercial sex acts with a minor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d323287-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20705/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations, if any, regarding any legislative or administrative action the Comptroller General determines appropriate to improve the ability described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d323288-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/tII/s204"},"text":"Pub. L. 109–164, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-10"},"text":"Jan. 10, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3571"},"text":"119 Stat. 3571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tIII/s302/5"},"text":"Pub. L. 110–457, title III, § 302(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5087"},"text":"122 Stat. 5087","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1242"},"text":"Pub. L. 113–4, title XII, § 1242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/153"},"text":"127 Stat. 153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tIII/s301/c"},"text":"Pub. L. 115–393, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5272"},"text":"132 Stat. 5272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/425/tI/s122"},"text":"Pub. L. 115–425, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5479"},"text":"132 Stat. 5479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d323289-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d32328a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d32328b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/9"},"text":"Section 7102(9) of title 22","children":[],"tail":", referred to in subsec. (a)(1)(F), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/11"},"text":"section 7102(11) of title 22","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d32328c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14044c"},"text":"section 14044c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d32328d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425"},"text":"Pub. L. 115–425","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/393"},"text":"Pub. L. 115–393","children":[],"tail":" substituted “2021” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1242/1/A"},"text":"Pub. L. 113–4, § 1242(1)(A)","children":[],"tail":", struck out “, which involve United States citizens, or aliens admitted for permanent residence, and” after “related offenses”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1242/1/B"},"text":"Pub. L. 113–4, § 1242(1)(B)","children":[],"tail":"–(D), added subpar. (B), redesignated former subpars. (B) to (D) as (C) to (E), respectively, and in subpar. (C) inserted “and prioritize the investigations and prosecutions of those cases involving minor victims” after “commercial sex acts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1242/3"},"text":"Pub. L. 113–4, § 1242(3)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1242/2"},"text":"Pub. L. 113–4, § 1242(2)","children":[],"tail":", (4), redesignated subsec. (d) as (e) and substituted “$10,000,000 for each of the fiscal years 2014 through 2017” for “$20,000,000 for each of the fiscal years 2008 through 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1242/5"},"text":"Pub. L. 113–4, § 1242(5)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":" substituted “$20,000,000 for each of the fiscal years 2008 through 2011” for “$25,000,000 for each of the fiscal years 2006 and 2007”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
