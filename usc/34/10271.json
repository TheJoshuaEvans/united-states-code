{"tag":"section","attrib":{"id":"id4cb169b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10271"},"text":null,"children":[{"tag":"num","attrib":{"value":"10271"},"text":"§ 10271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misuse of Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever embezzles, willfully misapplies, steals, or obtains by fraud or endeavors to embezzle, willfully misapply, steal, or obtain by fraud any funds, assets, or property which are the subject of a grant or contract or other form of assistance pursuant to this chapter, whether received directly or indirectly from the Office of Justice Programs, Bureau of Justice Assistance, the National Institute of Justice, the Bureau of Justice Statistics, or whoever receives, conceals, or retains such funds, assets or property with intent to convert such funds, assets or property to his use or gain, knowing such funds, assets, or property has been embezzled, willfully misapplied, stolen or obtained by fraud, shall be fined not more than $10,000 or imprisoned for not more than five years, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cb169b9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1101"},"text":"Pub. L. 90–351, title I, § 1101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1219"},"text":"93 Stat. 1219","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609E/a"},"text":"Pub. L. 98–473, title II, § 609E(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", 