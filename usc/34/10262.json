{"tag":"section","attrib":{"id":"id4caf1f9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10262"},"text":null,"children":[{"tag":"num","attrib":{"value":"10262"},"text":"§ 10262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local governments to consider courts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may require, as appropriate, that whenever a State or unit of local government or Indian tribe applies for a grant from the Department of Justice, the State, unit, or tribe demonstrate that, in developing the application and distributing funds, the State, unit, or tribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4caf1f9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10262/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered the needs of the judicial branch of the State, unit, or tribe, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4caf1f9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10262/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulted with the chief judicial officer of the highest court of the State, unit, or tribe, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4caf1fa0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10262/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulted with the chief law enforcement officer of the law enforcement agency responsible for the security needs of the judicial branch of the State, unit, or tribe, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4caf1fa1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/tIII/s302/c"},"text":"Pub. L. 110–177, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2539"},"text":"121 Stat. 2539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4caf1fa2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4caf1fa3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4caf1fa4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Court Security Improvement Act of 2007, and not as part of title I of the Omnibus Crime Control and Safe Streets Act of 1968 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3702"},"text":"section 3702 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
