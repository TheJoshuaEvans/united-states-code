{"tag":"section","attrib":{"id":"id4d408a4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904"},"text":null,"children":[{"tag":"num","attrib":{"value":"21904"},"text":"§ 21904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards for issuance and dissemination of alerts through Ashanti Alert communications network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d408a4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of minimum standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Coordinator shall establish minimum standards for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d408a4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of alerts through the Ashanti Alert communications network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408a50-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the dissemination of alerts issued through the Ashanti Alert communications network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d408a51-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d408a52-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The minimum standards established under subsection (a) shall, to the maximum extent practicable (as determined by the Coordinator in consultation with State, Tribal, and local law enforcement agencies), provide for the dissemination of appropriate information relating to the special needs of a missing adult (including health care needs) to the appropriate law enforcement, public health, and other public officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408a53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The minimum standards established under subsection (a) shall, to the maximum extent practicable (as determined by the Coordinator in consultation with State, Tribal, and local law enforcement agencies), provide that the dissemination of an alert through the Ashanti Alert communications network shall be limited to the geographic areas that the missing adult could reasonably reach, considering—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d408a54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances and physical and mental condition of the missing adult;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408a55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modes of transportation available to the missing adult; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408a56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances of the disappearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408a57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The minimum standards established under subsection (a) shall require that, in order for an Ashanti Alert to be issued for a missing adult, the missing adult—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d408a58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suffers from a proven mental or physical disability, as documented by a source determined credible by an appropriate law enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408a59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be missing under circumstances that indicate, as determined by an appropriate law enforcement agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d408a5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the physical safety of the missing adult may be endangered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d408a5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the disappearance of the missing adult may not have been voluntary, including an abduction or kidnapping.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408a5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety, privacy, and civil liberties protections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The minimum standards established under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d408a5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that alerts issued through the Ashanti Alert communications network comply with all applicable Federal, State, Tribal, and local privacy laws and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408a5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include standards that specifically provide for the protection of the civil liberties and sensitive medical information of missing adults; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d408a5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include standards requiring, as appropriate, a review of relevant court records, prior contacts with law enforcement, and other information relevant to the missing adult or the individual reporting, in order to provide protections against domestic violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d408a60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21904/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, Tribal, and local voluntary coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing minimum standards under subsection (a), the Coordinator may not interfere with the system of voluntary coordination between local broadcasters and State, Tribal, and local law enforcement agencies for purposes of regional and local search efforts for missing adults that was in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2018-12-31"},"text":"December 31, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d408a61-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/468/tII/s204"},"text":"Pub. L. 106–468, title II, § 204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/401/s2/5"},"text":"Pub. L. 115–401, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5340"},"text":"132 Stat. 5340","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
