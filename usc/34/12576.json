{"tag":"section","attrib":{"id":"id4d15a9e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576"},"text":null,"children":[{"tag":"num","attrib":{"value":"12576"},"text":"§ 12576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d15a9e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State desiring an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12572"},"text":"section 12572 of this title","children":[],"tail":" shall submit an application to the Director at such time, in such manner, and accompanied by such information as the Director may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15a9e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d15a9e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the scholarship program and the student employment program for which assistance under this part is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the lead agency will work in cooperation with the local law enforcement liaisons, representatives of police labor organizations and police management organizations, and other appropriate State and local agencies to develop and implement interagency agreements designed to carry out this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the State will advertise the scholarship assistance and student employment it will provide under this part and that the State will use such programs to enhance recruitment efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the State will screen and select law enforcement personnel for participation in the scholarship program under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that under such student employment program the State will screen and select, for participation in such program, students who have an interest in undertaking a career in law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that under such scholarship program the State will make scholarship payments to institutions of higher education on behalf of persons who receive scholarships under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to such student employment program, identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15a9ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment tasks that students will be assigned to perform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a9ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation that students will be paid to perform such tasks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a9ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training that students will receive as part of their participation in the program;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify model curriculum and existing programs designed to meet the educational and professional needs of law enforcement personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12576/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the State will promote cooperative agreements with educational and law enforcement agencies to enhance law enforcement personnel recruitment efforts in institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d15a9f2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200207"},"text":"Pub. L. 103–322, title XX, § 200207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2059"},"text":"108 Stat. 2059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d15a9f3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d15a9f4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d15a9f5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14116"},"text":"section 14116 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
