{"tag":"section","attrib":{"id":"id4cfdb543-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223"},"text":null,"children":[{"tag":"num","attrib":{"value":"12223"},"text":"§ 12223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb544-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to receive a grant under this part ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for any fiscal year, a State, Indian tribal, or local prosecutor, in conjunction with the chief executive officer of the jurisdiction in which the program will be placed, shall submit an application to the Attorney General in such form and containing such information as the Attorney General may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb545-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each applicant shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb546-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for funds for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12222"},"text":"section 12222 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb547-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the communities to be served by the grant, including the nature of the youth crime, youth violence, and child abuse problems within such communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb548-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that Federal funds received under this part ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall be used to supplement, not supplant, non-Federal funds that would otherwise be available for activities funded under this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb549-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistical information in such form and containing such information that the Attorney General may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb54a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each applicant shall include a comprehensive plan that shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb54b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the youth violence or child abuse crime problem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb54c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action plan outlining how the applicant will achieve the purposes as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12222"},"text":"section 12222 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb54d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the resources available in the community to implement the plan together with a description of the gaps in the plan that cannot be filled with existing resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb54e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12223/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the requested grant will be used to fill gaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb54f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31703"},"text":"Pub. L. 103–322, title III, § 31703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1891"},"text":"108 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb550-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb551-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfdb552-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsecs. (a) and (b)(3), appearing in the original, is unidentifiable because subtitle Q of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" does not contain parts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb553-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13863"},"text":"section 13863 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
