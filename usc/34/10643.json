{"tag":"section","attrib":{"id":"id4cd2d4d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10643"},"text":null,"children":[{"tag":"num","attrib":{"value":"10643"},"text":"§ 10643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statewide strategic prevention plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd2d4da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10643/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A statewide strategic prevention plan shall be used by the rural State to assist local communities, both directly and through existing State programs and services, in building comprehensive, strategic, and innovative approaches to reducing crime, violence, and substance abuse based on local conditions and needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10643/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan must contain statewide long-term goals and measurable annual objectives for reducing crime, violence, and substance abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10643/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rural State shall be required to develop and report in its plan relevant performance targets and measures for the goals and objectives to track changes in crime, violence, and substance abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10643/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rural State shall form a State crime free communities commission that includes representatives of State and local government, and community leaders who will provide advice and recommendations on relevant community goals and objectives, and performance targets and measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd2d4de-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2987"},"text":"Pub. L. 90–351, title I, § 2987","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11027/b"},"text":"Pub. L. 107–273, div. C, title I, § 11027(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1834"},"text":"116 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd2d4df-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd2d4e0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd2d4e1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797y–2"},"text":"section 3797y–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
