{"tag":"section","attrib":{"id":"id4d512ca5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40728"},"text":null,"children":[{"tag":"num","attrib":{"value":"40728"},"text":"§ 40728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of best practices for evidence retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512ca6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the National Institute of Justice, in consultation with Federal, State, and local law enforcement agencies and government laboratories, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512ca7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40728/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish best practices for evidence retention to focus on the preservation of forensic evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512ca8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40728/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist State, local, and tribal governments in adopting and implementing the best practices established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512ca9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Director of the National Institute of Justice shall publish the best practices established under subsection (a)(1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512caa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40728/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require or obligate compliance with the best practices established under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512cab-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s414"},"text":"Pub. L. 108–405, title IV, § 414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s13/a"},"text":"Pub. L. 114–324, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1958"},"text":"130 Stat. 1958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512cac-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512cad-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512cae-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14136f"},"text":"section 14136f of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
