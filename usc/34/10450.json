{"tag":"section","attrib":{"id":"id4cc47ca9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450"},"text":null,"children":[{"tag":"num","attrib":{"value":"10450"},"text":"§ 10450.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs for criminal charges and protection orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc47caa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, Indian tribal government, or unit of local government, shall not be entitled to funds under this subchapter unless the State, Indian tribal government, or unit of local government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc47cab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that its laws, policies, and practices do not require, in connection with the prosecution of any misdemeanor or felony domestic violence, dating violence, sexual assault, or stalking offense, or in connection with the filing, issuance, registration, modification, enforcement, dismissal, withdrawal or service of a protection order, or a petition for a protection order, to protect a victim of domestic violence, dating violence, sexual assault, or stalking, that the victim bear the costs associated with the filing of criminal charges against the offender, or the costs associated with the filing, issuance, registration, modification, enforcement, dismissal, withdrawal or service of a warrant, protection order, petition for a protection order, or witness subpoena, whether issued inside or outside the State, tribal, or local jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47cac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" gives the Attorney General assurances that its laws, policies and practices will be in compliance with the requirements of paragraph (1) within the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc47cad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period ending on the date on which the next session of the State legislature ends; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc47cae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-10-28"},"text":"October 28, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47caf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds withheld from a State, unit of local government, or Indian tribal government under subsection (a) shall be distributed to other States, units of local government, and Indian tribal government, respectively, pro rata.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47cb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10450/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “protection order” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2266"},"text":"section 2266 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc47cb1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2011"},"text":"Pub. L. 90–351, title I, § 2011","children":[],"tail":", formerly § 2006, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40121/a/3"},"text":"Pub. L. 103–322, title IV, § 40121(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1915"},"text":"108 Stat. 1915","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1101/b/1"},"text":"Pub. L. 106–386, div. B, title I, § 1101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1492"},"text":"114 Stat. 1492","children":[],"tail":"; renumbered § 2011, "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIV/s402/2"},"text":"Pub. L. 107–273, div. A, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1789"},"text":"116 Stat. 1789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s310/b"},"text":"Pub. L. 108–405, title III, § 310(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2276"},"text":"118 Stat. 2276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tI/s101/5"},"text":"Pub. L. 113–4, title I, § 101(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/69"},"text":"127 Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc47cb2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc47cb3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc47cb4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–5"},"text":"section 3796gg–5 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc47cb5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" inserted “modification, enforcement, dismissal, withdrawal” after “registration,” in two places and “, dating violence, sexual assault, or stalking” after “felony domestic violence” and substituted “victim of domestic violence, dating violence, sexual assault, or stalking” for “victim of domestic violence, stalking, or sexual assault”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1101/b/1/A"},"text":"Pub. L. 106–386, § 1101(b)(1)(A)","children":[],"tail":", in section catchline, substituted “Costs” for “Filing costs” and inserted “and protection orders” after “charges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1101/b/1/B/i"},"text":"Pub. L. 106–386, § 1101(b)(1)(B)(i)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “certifies that its laws, policies, and practices do not require, in connection with the prosecution of any misdemeanor or felony domestic violence offense, that the abused bear the costs associated with the filing of criminal charges against the domestic violence offender, or the costs associated with the issuance or service of a warrant, protection order, or witness subpoena; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1101/b/1/B/ii"},"text":"Pub. L. 106–386, § 1101(b)(1)(B)(ii)","children":[],"tail":", substituted “2 years after "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"October 28, 2000","children":[],"tail":"” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1101/b/1/C"},"text":"Pub. L. 106–386, § 1101(b)(1)(C)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cc47cb6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cc47cb7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
