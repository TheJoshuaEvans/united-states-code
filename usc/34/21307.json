{"tag":"section","attrib":{"id":"id4d3bcfcc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21307"},"text":null,"children":[{"tag":"num","attrib":{"value":"21307"},"text":"§ 21307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of increased formula grant funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall allocate an increase in the amount provided to a State under the covered formula grants under this chapter such that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3bcfcd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21307/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent ","children":[{"tag":"ref","attrib":{"idref":"fn002197"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002197"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of”."}],"tail":" the amount of the increase is provided under the program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21301/1/A"},"text":"section 21301(1)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3bcfce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21307/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the amount of the increase is provided under the program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21301/1/B"},"text":"section 21301(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3bcfcf-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"