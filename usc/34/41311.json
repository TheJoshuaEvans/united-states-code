{"tag":"section","attrib":{"id":"id4d5ac91f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41311"},"text":null,"children":[{"tag":"num","attrib":{"value":"41311"},"text":"§ 41311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving Department of Justice data collection on mental illness involved in crime","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5ac920-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, on or after the date that is 90 days after the date on which the Attorney General promulgates regulations under subsection (b), any data prepared by, or submitted to, the Attorney General or the Director of the Federal Bureau of Investigation with respect to the incidences of homicides, law enforcement officers killed, seriously injured, and assaulted, or individuals killed or seriously injured by law enforcement officers shall include data with respect to the involvement of mental illness in such incidences, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac921-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Attorney General shall promulgate or revise regulations as necessary to carry out subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5ac922-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14015"},"text":"Pub. L. 114–255, div. B, title XIV, § 14015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1306"},"text":"130 Stat. 1306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5ac923-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5ac924-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5ac925-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
