{"tag":"section","attrib":{"id":"id4d17f351-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593"},"text":null,"children":[{"tag":"num","attrib":{"value":"12593"},"text":"§ 12593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Bureau of Investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d17f352-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proficiency testing requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f353-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f354-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel at the Federal Bureau of Investigation who perform DNA analyses shall undergo semiannual external proficiency testing by a DNA proficiency testing program meeting the standards issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12591"},"text":"section 12591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f355-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 1 year after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the Director of the Federal Bureau of Investigation shall arrange for periodic blind external tests to determine the proficiency of DNA analysis performed at the Federal Bureau of Investigation laboratory."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f356-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this paragraph, “blind external test” means a test that is presented to the laboratory through a second agency and appears to the analysts to involve routine evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f357-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For 5 years after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the Director of the Federal Bureau of Investigation shall submit to the Committees on the Judiciary of the House and Senate an annual report on the results of each of the tests described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f358-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protection standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f359-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the results of DNA tests performed for a Federal law enforcement agency for law enforcement purposes may be disclosed only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f35a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to criminal justice agencies for law enforcement identification purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f35b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in judicial proceedings, if otherwise admissible pursuant to applicable statues ","children":[{"tag":"ref","attrib":{"idref":"fn002140"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002140"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “statutes”."}],"tail":" or rules; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f35c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for criminal defense purposes, to a defendant, who shall have access to samples and analyses performed in connection with the case in which such defendant is charged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f35d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If personally identifiable information is removed, test results may be disclosed for a population statistics database, for identification research and protocol development purposes, or for quality control purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f35e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f35f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f360-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by virtue of employment or official position, has possession of, or access to, individually identifiable DNA information indexed in a database created or maintained by any Federal law enforcement agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f361-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly discloses such information in any manner to any person or agency not authorized to receive it,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f362-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12593/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who, without authorization, knowingly obtains DNA samples or individually identifiable DNA information indexed in a database created or maintained by any Federal law enforcement agency shall be fined not more than $250,000, or imprisoned for a period of not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d17f363-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210305"},"text":"Pub. L. 103–322, title XXI, § 210305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2070"},"text":"108 Stat. 2070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/546/s8/c"},"text":"Pub. L. 106–546, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2735"},"text":"114 Stat. 2735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tII/s203/e/1"},"text":"Pub. L. 108–405, title II, § 203(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2270"},"text":"118 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d17f364-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d17f365-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d17f366-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14133"},"text":"section 14133 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d17f367-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405"},"text":"Pub. L. 108–405","children":[],"tail":" substituted “$250,000, or imprisoned for a period of not more than one year, or both” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546"},"text":"Pub. L. 106–546","children":[],"tail":" substituted “semiannual” for “, at regular intervals of not to exceed 180 days,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
