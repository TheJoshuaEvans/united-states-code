{"tag":"section","attrib":{"id":"id4d66b052-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60903"},"text":null,"children":[{"tag":"num","attrib":{"value":"60903"},"text":"§ 60903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full reinvestigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b053-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency shall conduct a full reinvestigation of the cold case murder at issue if the review of the case file required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901"},"text":"section 60901 of this title","children":[],"tail":" concludes that a full reinvestigation of such cold case murder would result in probative investigative leads."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b054-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinvestigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A full reinvestigation shall include analyzing all evidence regarding the cold case murder at issue for the purpose of developing probative investigative leads or a likely perpetrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b055-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A reinvestigation required under subsection (a) shall not be conducted by a person who previously investigated the murder at issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b056-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on multiple concurrent reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only one full reinvestigation shall be undertaken at any one time with respect to the same cold case murder victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b057-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s4"},"text":"Pub. L. 117–164, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1359"},"text":"136 Stat. 1359","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
