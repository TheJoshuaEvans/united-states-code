{"tag":"section","attrib":{"id":"id4cbd509b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405"},"text":null,"children":[{"tag":"num","attrib":{"value":"10405"},"text":"§ 10405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd509c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall issue guidelines establishing procedures under which a State or specifically ","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “specially”."}],"tail":" qualified unit of local government that receives funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10404"},"text":"section 10404 of this title","children":[],"tail":" is required to provide notice to the Attorney General regarding the proposed use of funds made available under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd509d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd509e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines referred to in subsection (a) shall include a requirement that such eligible State or unit of local government establish and convene an advisory board to recommend a coordinated enforcement plan for the use of such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd509f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board shall include representation from, if appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or local police department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local sheriff’s department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or local prosecutor’s office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10405/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","chil