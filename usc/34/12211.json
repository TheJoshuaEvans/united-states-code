{"tag":"section","attrib":{"id":"id4cfdb520-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211"},"text":null,"children":[{"tag":"num","attrib":{"value":"12211"},"text":"§ 12211.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb521-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community development corporation” means a private, nonprofit corporation whose board of directors is comprised of business, civic and community leaders, and whose principal purpose includes the provision of low-income housing or community economic development projects that primarily benefit low-income individuals and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb522-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local and private sector contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local and private sector contribution” means the funds available at the local level (by private financial institutions, State and local governments) or by any private philanthropic organization and private, nonprofit organizations that will be committed and used solely for the purpose of financing private business enterprises in conjunction with amounts provided under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb523-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population-losing community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “population-losing community” means any county in which the net population loss is at least 7 percent from ","children":[{"tag":"date","attrib":{"date":"1980-04-01"},"text":"April 1, 1980","children":[],"tail":" to "},{"tag":"date","attrib":{"date":"1990-04-01"},"text":"April 1, 1990","children":[],"tail":", as reported by the Bureau of the Census."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb524-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private business enterprise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private business enterprise” means any business enterprise that is engaged in the manufacture of a product, provision of a service, construction or development of a facility, or that is involved in some other commercial, manufacturing or industrial activity, and that agrees to target job opportunities stemming from investments authorized under this part to certain individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb525-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target area” means any area defined in an application for assistance under this part that has a population whose income does not exceed the median for the area within which the target area is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb526-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12211/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Very low-income community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “very low-income community” means a community in which the median income of the residents of such community does not exceed 50 percent of the median income of the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb527-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31131"},"text":"Pub. L. 103–322, title III, § 31131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1887"},"text":"108 Stat. 1887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb528-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb529-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb52a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13851"},"text":"section 13851 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
