{"tag":"section","attrib":{"id":"id4d4ee207-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504"},"text":null,"children":[{"tag":"num","attrib":{"value":"40504"},"text":"§ 40504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for the assistance of organizations to find missing adults","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4ee208-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make grants to public agencies or nonprofit private organizations, or combinations thereof, for programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4ee209-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist law enforcement and families in locating missing adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee20a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain a national, interconnected database for the purpose of tracking missing adults who are determined by law enforcement to be endangered due to age, diminished mental capacity, or the circumstances of disappearance, when foul play is suspected or circumstances are unknown;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee20b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain statistical information of adults reported as missing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee20c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide informational resources and referrals to families of missing adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee20d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in public notification and victim advocacy related to missing adults; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee20e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish and maintain a national clearinghouse for missing adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4ee20f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may make such rules and regulations as may be necessary to carry out this title.","children":[{"tag":"ref","attrib":{"idref":"fn002215"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002215"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4ee210-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/468/tI/s101"},"text":"Pub. L. 106–468, title I, § 101","children":[],"tail":", formerly § 2, "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2027"},"text":"114 Stat. 2027","children":[],"tail":"; renumbered title I, § 101, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/401/s2/1"},"text":"Pub. L. 115–401, § 2(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5336"},"text":"132 Stat. 5336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4ee211-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4ee212-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d4ee213-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (b), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/468"},"text":"Pub. L. 106–468","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2027"},"text":"114 Stat. 2027","children":[],"tail":", which enacted this section and provisions set out as a note under this section. For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4ee214-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Kristen’s Act, and not as part of Jennifer’s Law which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14665"},"text":"section 14665 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d4ee215-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/401"},"text":"Pub. L. 115–401","children":[],"tail":" substituted “this title” for “this Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d4ee216-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d4ee217-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Funding","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/468/tI/s102"},"text":"Pub. L. 106–468, title I, § 102","children":[],"tail":", formerly § 3, "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2028"},"text":"114 Stat. 2028","children":[],"tail":", renumbered title I, § 102, and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/401/s2/1"},"text":"Pub. L. 115–401, § 2(1)","children":[],"tail":", (2), (4), "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5336"},"text":"132 Stat. 5336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/b"},"text":"Pub. L. 116–277, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3370"},"text":"134 Stat. 3370","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/277/s2/b"},"text":"“To the extent provided in advance in appropriations Acts, the Attorney General is authorized to use funds appropriated for the operationalization, maintenance, and expansion of the National Missing and Unidentified Persons System (NamUs) for the purpose of carrying out this Act [enacting this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
