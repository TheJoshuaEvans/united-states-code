{"tag":"section","attrib":{"id":"id4cbfc1c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408"},"text":null,"children":[{"tag":"num","attrib":{"value":"10408"},"text":"§ 10408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbfc1c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or specially qualified unit that receives funds under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a trust fund in which the government will deposit all payments received under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use amounts in the trust fund (including interest) during the period specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10406/b/1"},"text":"section 10406(b)(1) of this title","children":[],"tail":" and any extension of that period under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10406/b/2"},"text":"section 10406(b)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an official of the State or specially qualified unit to submit reports as the Attorney General reasonably requires, in addition to the annual reports required under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spend the funds only for the purpose of strengthening the juvenile justice system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc1cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, the administrative provisions of subchapter VII shall apply to this subchapter and for purposes of this section any reference in such provisions to this chapter shall be deemed to include a reference to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc1ce-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1807"},"text":"Pub. L. 90–351, title I, § 1807","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1866"},"text":"116 Stat. 1866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc1cf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc1d0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc1d1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–7"},"text":"section 3796ee–7 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
