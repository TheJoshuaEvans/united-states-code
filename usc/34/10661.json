{"tag":"section","attrib":{"id":"id4cd78f37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661"},"text":null,"children":[{"tag":"num","attrib":{"value":"10661"},"text":"§ 10661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants to address public safety and methamphetamine manufacturing, sale, and use in hot spots","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd78f38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Purpose and program authority"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this subchapter to assist States, territories, and Indian tribes (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10554"},"text":"section 10554 of this title","children":[],"tail":")—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out programs to address the manufacture, sale, and use of methamphetamine drugs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the ability of State, territorial, Tribal, and local government institutions of ","children":[{"tag":"ref","attrib":{"idref":"fn002054"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002054"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The word “of” probably should not appear."}],"tail":" to carry out such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, through the Bureau of Justice Assistance in the Office of Justice Programs may make grants to States, territories, and Indian tribes to address the manufacture, sale, and use of methamphetamine to enhance public safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant projects to address methamphetamine manufacture sale and use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under subsection (a) may be used for programs, projects, and other activities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate, arrest and prosecute individuals violating laws related to the use, manufacture, or sale of methamphetamine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f3f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse the Drug Enforcement Administration for expenses related to the clean up of methamphetamine clandestine labs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f40-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support State, Tribal, and local health department and environmental agency services deployed to address methamphetamine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f41-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10661/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure equipment, technology, or support systems, or pay for resources, if the applicant for such a grant demonstrates to the satisfaction of the Attorney General that expenditures for such purposes would result in the reduction in the use, sale, and manufacture of methamphetamine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd78f42-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2996"},"text":"Pub. L. 90–351, title I, § 2996","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tVII/s754"},"text":"Pub. L. 109–177, title VII, § 754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/274"},"text":"120 Stat. 274","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dB/tII/s220/a"},"text":"Pub. L. 110–161, div. B, title II, § 220(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1916"},"text":"121 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd78f43-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd78f44-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd78f45-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797cc"},"text":"section 3797cc of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cd78f46-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/a/1/A"},"text":"Pub. L. 110–161, § 220(a)(1)(A)","children":[],"tail":", inserted “, territories, and Indian tribes (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3797d"},"text":"section 3797d of this title","children":[],"tail":")” after “to assist States” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/a/1/B"},"text":"Pub. L. 110–161, § 220(a)(1)(B)","children":[],"tail":", substituted “, territorial, Tribal, and local” for “and local”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/a/2"},"text":"Pub. L. 110–161, § 220(a)(2)","children":[],"tail":", inserted “, territories, and Indian tribes” after “make grants to States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/a/3"},"text":"Pub. L. 110–161, § 220(a)(3)","children":[],"tail":", inserted “, Tribal,” after “support State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
