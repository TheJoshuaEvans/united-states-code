{"tag":"section","attrib":{"id":"id4ccba8fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531"},"text":null,"children":[{"tag":"num","attrib":{"value":"10531"},"text":"§ 10531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ccba8ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Assistance is authorized to make grants to States, units of local government, and Indian tribes to purchase armor vests for use by State, local, and tribal law enforcement officers and State and local court officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba900-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba901-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributed directly to the State, unit of local government, State or local court, or Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba902-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for the purchase of armor vests for law enforcement officers in the jurisdiction of the grantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba903-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this subchapter, the Director of the Bureau of Justice Assistance may give preferential consideration, if feasible, to an application from a jurisdiction that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba904-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the greatest need for armor vests based on the percentage of law enforcement officers in the department who do not have access to a vest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba905-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, or will institute, a mandatory wear policy that requires on-duty law enforcement officers to wear armor vests whenever feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba906-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a violent crime rate at or above the national average as determined by the Federal Bureau of Investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba907-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides armor vests to law enforcement officers that are uniquely fitted for such officers, including vests uniquely fitted to individual female law enforcement officers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba908-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not received a block grant under the Local Law Enforcement Block Grant program described under the heading “Violent Crime Reduction Programs, State and Local Law Enforcement Assistance” of the Departments of Commerce, Justice, and State, the Judiciary, and Related Agencies Appropriations Act, 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/119"},"text":"Public Law 105–119","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba909-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless all eligible applications submitted by any State or unit of local government within such State for a grant under this section have been funded, such State, together with grantees within the State (other than Indian tribes), shall be allocated in each fiscal year under this section not less than 0.50 percent of the total amount appropriated in the fiscal year for grants pursuant to this section, except that the United States Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands shall each be allocated .25 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba90a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualifying State, unit of local government, or Indian tribe may not receive more than 5 percent of the total amount appropriated in each fiscal year for grants under this section, except that a State, together with the grantees within the State may not receive more than 20 percent of the total amount appropriated in each fiscal year for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba90b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba90c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The portion of the costs of a program provided by a grant under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ccba90d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed 50 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ccba90e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall equal 50 percent, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ccba90f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such grant is to a unit of local government with fewer than 100,000 residents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ccba910-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Bureau of Justice Assistance determines that the quantity of vests to be purchased with such grant is reasonable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ccba911-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such portion does not cause such grant to violate the requirements of subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba912-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds appropriated by Congress for the activities of any agency of an Indian tribal government or the Bureau of Indian Affairs performing law enforcement functions on any Indian lands may be used to provide the non-Federal share of a matching requirement funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba913-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, unit of local government, or Indian tribe may not use funding received under any other Federal grant program to pay or defer the cost, in whole or in part, of the matching requirement under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba914-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may waive in whole or in part, the match requirement of paragraph (1) in the case of fiscal hardship, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba915-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds available under this subchapter shall be awarded, without regard to subsection (c), to each qualifying unit of local government with fewer than 100,000 residents. Any remaining funds available under this subchapter shall be awarded to other qualifying applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba916-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of appropriated funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba917-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “appropriated funds” means any amounts that are appropriated for any of fiscal years 2016 through 2020 to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba918-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10531/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All appropriated funds that are not obligated on or before ","children":[{"tag":"date","attrib":{"date":"2022-12-31"},"text":"December 31, 2022","children":[],"tail":" shall be transferred to the General Fund of the Treasury not later than "},{"tag":"date","attrib":{"date":"2023-01-31"},"text":"January 31, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba919-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2501"},"text":"Pub. L. 90–351, title I, § 2501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/181/s3/a/3"},"text":"Pub. L. 105–181, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-16"},"text":"June 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/513"},"text":"112 Stat. 513","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/517/s3/a"},"text":"Pub. L. 106–517, § 3(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2407"},"text":"114 Stat. 2407","children":[],"tail":", 2408; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tIII/s302/d"},"text":"Pub. L. 110–177, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2539"},"text":"121 Stat. 2539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/8/dB/tII"},"text":"Pub. L. 111–8, div. B, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/583"},"text":"123 Stat. 583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/155"},"text":"Pub. L. 114–155","children":[],"tail":", §§ 3, 5, 7, "},{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/389"},"text":"130 Stat. 389","children":[],"tail":", 390.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba91a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba91b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ccba91c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Departments of Commerce, Justice, and State, the Judiciary, and Related Agencies Appropriations Act, 1998, referred to in subsec. (c)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/119"},"text":"Pub. L. 105–119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2440"},"text":"111 Stat. 2440","children":[],"tail":". Provisions under the heading “Violent Crime Reduction Programs, State and Local Law Enforcement Assistance”, "},{"tag":"ref","attrib":{"href":"/us/stat/111/2452"},"text":"111 Stat. 2452","children":[],"tail":", are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba91d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 3796","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":" of Title 42, The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ccba91e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s2501"},"text":"section 2501 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2601 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10541"},"text":"section 10541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ccba91f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/155/s7"},"text":"Pub. L. 114–155, § 7","children":[],"tail":", substituted “; and” for “; or” at end of par. (3), added par. (4), and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/155/s5"},"text":"Pub. L. 114–155, § 5","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/155/s3"},"text":"Pub. L. 114–155, § 3","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8"},"text":"Pub. L. 111–8","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s302/d/1"},"text":"Pub. L. 110–177, § 302(d)(1)","children":[],"tail":", inserted “and State and local court officers” after “tribal law enforcement officers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s302/d/2"},"text":"Pub. L. 110–177, § 302(d)(2)","children":[],"tail":", inserted “State or local court,” after “government,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/517/s3/a"},"text":"Pub. L. 106–517, § 3(a)","children":[],"tail":", designated first sentence as par. (1), inserted par. heading, substituted “subsection (a)—” and subpars. (A) and (B) for “subsection (a) may not exceed 50 percent.”, and designated second sentence as par. (2) and inserted par. heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/517/s3/b"},"text":"Pub. L. 106–517, § 3(b)","children":[],"tail":", amended heading and text of subsec. (g) generally. Prior to amendment, text read as follows: “At least half of the funds available under this subchapter shall be awarded to units of local government with fewer than 100,000 residents.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ccba920-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id4ccba921-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2000-08-01"},"text":"Aug. 1, 2000","children":[],"tail":", all functions of Director of Bureau of Justice Assistance, other than those enumerated in section 10142(3) through (6) of this title, transferred to Assistant Attorney General for Office of Justice Programs, see section 1000(a)(1) [title I, § 108(b)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10141"},"text":"section 10141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4ccba922-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings of 2000 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/517/s2"},"text":"Pub. L. 106–517, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2407"},"text":"114 Stat. 2407","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/517/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of law enforcement officers who are killed in the line of duty would significantly decrease if every law enforcement officer in the United States had the protection of an armor vest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to studies, between 1985 and 1994, 709 law enforcement officers in the United States were killed in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation estimates that the risk of fatality to law enforcement officers while not wearing an armor vest is 14 times higher than for officers wearing an armor vest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to studies, between 1985 and 1994, bullet-resistant materials helped save the lives of more than 2,000 law enforcement officers in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Executive Committee for Indian Country Law Enforcement Improvements reports that violent crime in Indian country has risen sharply, despite a decrease in the national crime rate, and has concluded that there is a ‘public safety crisis in Indian country’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4ccba923-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purpose of 1998 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/181/s2"},"text":"Pub. L. 105–181, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-16"},"text":"June 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/512"},"text":"112 Stat. 512","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/181/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of law enforcement officers who are killed in the line of duty would significantly decrease if every law enforcement officer in the United States had the protection of an armor vest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to studies, between 1985 and 1994, 709 law enforcement officers in the United States were feloniously killed in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation estimates that the risk of fatality to law enforcement officers while not wearing an armor vest is 14 times higher than for officers wearing an armor vest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice estimates that approximately 150,000 State, local, and tribal law enforcement officers, nearly 25 percent, are not issued body armor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" according to studies, between 1985 and 1994, bullet-resistant materials helped save the lives of more than 2,000 law enforcement officers in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Executive Committee for Indian Country Law Enforcement Improvements reports that violent crime in Indian country has risen sharply, despite a decrease in the national crime rate, and has concluded that there is a ‘public safety crisis in Indian country’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this Act [see Short Title of 1998 Act note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"] is to save lives of law enforcement officers by helping State, local, and tribal law enforcement agencies provide officers with armor vests.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
