{"tag":"section","attrib":{"id":"id4d34a403-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916"},"text":null,"children":[{"tag":"num","attrib":{"value":"20916"},"text":"§ 20916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direction to the Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d34a404-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that sex offenders provide certain Internet related information to sex offender registries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, using the authority provided in section 114(a)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn002186"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002186"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Sex Offender Registration and Notification Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20914/a/7"},"text":"34 U.S.C. 20914(a)(7)","children":[],"tail":"], shall require that each sex offender provide to the sex offender registry those Internet identifiers the sex offender uses or will use of any type that the Attorney General determines to be appropriate under that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.]. These records of Internet identifiers shall be subject to the Privacy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"5 U.S.C. 552a","children":[],"tail":") to the same extent as the other records in the National Sex Offender Registry."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a405-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeliness of reporting of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, using the authority provided in section 112(b) of the Sex Offender Registration and Notification Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20912/b"},"text":"34 U.S.C. 20912(b)","children":[],"tail":"], shall specify the time and manner for keeping current information required to be provided under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a406-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure to general public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, using the authority provided in section 118(b)(4) of the Sex Offender Registration and Notification Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20920/b/4"},"text":"34 U.S.C. 20920(b)(4)","children":[],"tail":"], shall exempt from disclosure all information provided by a sex offender under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a407-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to sex offenders of new requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure that procedures are in place to notify each sex offender of changes in requirements that apply to that sex offender as a result of the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a408-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d34a409-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Of “social networking website”","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this Act, the term “social networking website”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d34a40a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an Internet website—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d34a40b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that allows users, through the creation of web pages or profiles or by other means, to provide information about themselves that is available to the public or to other users; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d34a40c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that offers a mechanism for communication with other users where such users are likely to include a substantial number of minors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d34a40d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose primary purpose is to facilitate online social interactions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d34a40e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any contractors or agents used by the website to act on behalf of the website in carrying out the purposes of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a40f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Of “Internet identifiers”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this Act, the term “Internet identifiers” means electronic mail addresses and other designations used for self-identification or routing in Internet communication or posting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a410-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20916/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A term defined for the purposes of the Sex Offender Registration and Notification Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20901"},"text":"34 U.S.C. 20901","children":[],"tail":" et seq.] has the same meaning in this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d34a411-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/400/s2"},"text":"Pub. L. 110–400, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4224"},"text":"122 Stat. 4224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a412-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d34a413-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d34a414-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Sex Offender Registration and Notification Act, referred to in subsecs. (a) and (e)(3), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/590"},"text":"120 Stat. 590","children":[],"tail":", which is classified principally to this subchapter. Section 114(a)(7) of the Act was redesignated section 114(a)(8) of the Act by "},{"tag":"ref","attrib":{"href":"/us/pl/114/119/s6/a/1/A"},"text":"Pub. L. 114–119, § 6(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/22"},"text":"130 Stat. 22","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2006 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/400"},"text":"Pub. L. 110–400","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4224"},"text":"122 Stat. 4224","children":[],"tail":", known as the Keeping the Internet Devoid of Sexual Predators Act of 2008, and also known as the KIDS Act of 2008, which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20917"},"text":"section 20917 of this title","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20981"},"text":"section 20981 of this title","children":[],"tail":", and enacted provisions set out as notes under sections 10101 and 20981 of this title. For complete classification of this Act to the Code, see Short Title of 2008 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d34a415-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Keeping the Internet Devoid of Sexual Predators Act of 2008, also known as the KIDS Act of 2008, and not as part of the Sex Offender Registration and Notification Act which comprises this subchapter, or as part of the Adam Walsh Child Protection and Safety Act of 2006 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16915a"},"text":"section 16915a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
