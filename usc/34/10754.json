{"tag":"section","attrib":{"id":"id4cda00c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10754"},"text":null,"children":[{"tag":"num","attrib":{"value":"10754"},"text":"§ 10754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State, Indian Tribe, unit of local government, or community-based nonprofit organization that receives a grant under this subchapter shall submit to the Attorney General an evaluation not later than 1 year after receipt of the grant in such form and containing such information as the Attorney General, in consultation with the Secretary of Health and Human Services, may reasonably require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cda00c4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3054"},"text":"Pub. L. 90–351, title I, § 3054","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/281/s2/a"},"text":"Pub. L. 116–281, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3384"},"text":"134 Stat. 3384","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
