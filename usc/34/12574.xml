<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id4d15a9d5-5dcd-11f1-b11b-9e551e93f87d" identifier="/us/usc/t34/s12574"><num value="12574">§ 12574.</num><heading> Scholarships</heading><subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="id4d15a9d6-5dcd-11f1-b11b-9e551e93f87d" identifier="/us/usc/t34/s12574/a"><num value="a" class="bold">(a)</num><heading class="bold"> Period of award</heading><content><p style="-uslm-lc:I11" class="indent0">Scholarships awarded under this part shall be for a period of 1 academic year.</p>
</content>
</subsection>
<subsection style="-uslm-lc:I19" class="indent2 firstIndent-2" id="id4d15a9d7-5dcd-11f1-b11b-9e551e93f87d" identifier="/us/usc/t34/s12574/b"><num value="b" class="bold">(b)</num><heading class="bold"> Use of scholarships</heading><content><p style="-uslm-lc:I11" class="indent0">Each individual awarded a scholarship under this part may use the scholarship for educational expenses at an institution of higher education.</p>
</content>
</subsection>
<sourceCredit id="id4d15a9d8-5dcd-11f1-b11b-9e551e93f87d">(<ref href="/us/pl/103/322/tXX/s200205">Pub. L. 103–322, title XX, § 200205</ref>, <date date="1994-09-13">Sept. 13, 1994</date>, <ref href="/us/stat/108/2059">108 Stat. 2059</ref>.)</sourceCredit>
