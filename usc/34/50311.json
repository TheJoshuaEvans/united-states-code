{"tag":"section","attrib":{"id":"id4d5d134f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50311"},"text":null,"children":[{"tag":"num","attrib":{"value":"50311"},"text":"§ 50311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of a Badge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may award, and a Member of Congress or the Attorney General may present, in the name of Congress a Federal Law Enforcement Congressional Badge of Bravery to a Federal law enforcement officer who is cited by the Attorney General, upon the recommendation of the Federal Board, for performing an act of bravery while in the line of duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d5d1350-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/298/tI/s101"},"text":"Pub. L. 110–298, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-31"},"text":"July 31, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2986"},"text":"122 Stat. 2986","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d1351-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d1352-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d1353-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15241"},"text":"section 15241 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
