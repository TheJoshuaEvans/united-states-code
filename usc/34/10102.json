{"tag":"section","attrib":{"id":"id4c94e0e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102"},"text":null,"children":[{"tag":"num","attrib":{"value":"10102"},"text":"§ 10102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and functions of Assistant Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c94e0e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific, general and delegated powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c94e0e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and disseminate information on the conditions and progress of the criminal justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c94e0ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain liaison with the executive and judicial branches of the Federal and State governments in matters relating to criminal justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c94e0eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information to the President, the Congress, the judiciary, State and local governments, and the general public relating to criminal justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c94e0ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain liaison with public and private educational and research institutions, State and local governments, and governments of other nations relating to criminal justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c94e0ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and provide staff support to coordinate the activities of the Office and the Bureau of Justice Assistance, the National Institute of Justice, the Bureau of Justice Statistics, the Office for Victims of Crime, and the Office of Juvenile Justice and Delinquency Prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c94e0ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise such other powers and functions as may be vested in the Assistant Attorney General pursuant to this chapter or by delegation of the Attorney General, including placing special conditions on all grants, and determining priority purposes for formula grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c94e0ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Attorney General shall submit an annual report to the President and to the Congress not later than March 31 of each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c94e0f0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s102"},"text":"Pub. L. 90–351, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s603/a"},"text":"Pub. L. 98–473, title II, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2078"},"text":"98 Stat. 2078","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s236"},"text":"Pub. L. 107–296, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2162"},"text":"116 Stat. 2162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1152"},"text":"Pub. L. 109–162, title XI, § 1152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3113"},"text":"119 Stat. 3113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c94e0f1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c94e0f2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4c94e0f3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"ta