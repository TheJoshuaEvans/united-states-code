{"tag":"section","attrib":{"id":"id4d0296d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311"},"text":null,"children":[{"tag":"num","attrib":{"value":"12311"},"text":"§ 12311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0296da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, after consultation with victim advocates and individuals who have expertise in treating sex offenders, shall establish criteria and develop training programs to assist probation and parole officers and other personnel who work with released sex offenders in the areas of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0296db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0296dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0296dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relapse prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0296de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure, to the extent practicable, that training programs developed under subsection (a) are available in geographically diverse locations throughout the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0296df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0296e0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40152"},"text":"Pub. L. 103–322, title IV, § 40152","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1920"},"text":"108 Stat. 1920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s108"},"text":"Pub. L. 109–162, title I, § 108","children":[],"tail":", title XI, § 1167, "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2984"},"text":"119 Stat. 2984","children":[],"tail":", 3121; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s2/a"},"text":"Pub. L. 109–271, § 2(a)","children":[],"tail":", (b), "},{"tag":"d