L. 115–385, § 402(b)(2)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B). Prior to amendment, text read as follows: “There are authorized to be appropriated to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11245"},"text":"section 11245 of this title","children":[],"tail":" such sums as may be necessary for fiscal years 2009, 2010, 2011, 2012, and 2013.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s402/b/3"},"text":"Pub. L. 115–385, § 402(b)(3)","children":[],"tail":", substituted “each of fiscal years 2019 through 2020” for “fiscal year 2009 and such sums as may be necessary for fiscal years 2010, 2011, 2012, and 2013”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s11/1"},"text":"Pub. L. 110–378, § 11(1)","children":[],"tail":", substituted “are authorized” for “is authorized”, “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5714–25"},"text":"section 5714–25 of this title","children":[],"tail":" and part E) $140,000,000 for fiscal year 2009” for “part E of this subchapter) $105,000,000 for fiscal year 2004”, and “2010, 2011, 2012, and 2013” for “2005, 2006, 2007, and 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s11/2"},"text":"Pub. L. 110–378, § 11(2)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, inserted “(other than "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5714–25"},"text":"section 5714–25 of this title","children":[],"tail":")” before period, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s11/3"},"text":"Pub. L. 110–378, § 11(3)","children":[],"tail":", substituted “are authorized” for “is authorized” and “$25,000,000 for fiscal year 2009 and such sums as may be necessary for fiscal years 2010, 2011, 2012, and 2013” for “such sums as may be necessary for fiscal years 2004, 2005, 2006, 2007, and 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96/s117/a"},"text":"Pub. L. 108–96, § 117(a)","children":[],"tail":", substituted “$105,000,000 for fiscal year 2004, and such sums as may be necessary for fiscal years 2005, 2006, 2007, and 2008” for “such sums as may be necessary for fiscal years 2000, 2001, 2002, and 2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96/s117/c"},"text":"Pub. L. 108–96, § 117(c)","children":[],"tail":", substituted “45 percent and, in those fiscal years in which continuation grant obligations and the quality and number of applicants for parts A and B warrant not more than 55 percent” for “not less than 20 percent, and not more than 30 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96/s117/b"},"text":"Pub. L. 108–96, § 117(b)","children":[],"tail":", substituted “2004, 2005, 2006, 2007, and 2008” for “2000, 2001, 2002, and 2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/m"},"text":"Pub. L. 106–71, § 3(m)","children":[],"tail":", amended section catchline and text generally, substituting provisions relating to appropriations for fiscal years 2000 to 2003 for provisions relating to appropriations for fiscal years 1993 to 1996."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/n/2"},"text":"Pub. L. 106–71, § 3(n)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/i"},"text":"Pub. L. 102–586, § 3(i)","children":[],"tail":", which directed the amendment of section “366 of the Juvenile Justice and Delinquency Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5751"},"text":"42 U.S.C. 5751","children":[],"tail":")”, was executed to this section, which is section 385 of the Juvenile Justice and Delinquency Prevention Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/415"},"text":"Pub. L. 93–415","children":[],"tail":"), to reflect the probable intent of Congress and the intervening renumbering of "},{"tag":"ref","attrib":{"href":"/us/pl/93/415/s366"},"text":"section 366 of Pub. L. 93–415","children":[],"tail":" as section 385 by "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/A/ii"},"text":"section 3(g)(1)(A)(ii) of Pub. L. 102–586","children":[],"tail":". See notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/i/1/A"},"text":"Pub. L. 102–586, § 3(i)(1)(A)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “To carry out the purposes of part A of this subchapter there are authorized to be appropriated such sums as may be necessary for fiscal years 1989, 1990, 1991, and 1992.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/i/1/B"},"text":"Pub. L. 102–586, § 3(i)(1)(B)","children":[],"tail":", added pars. (3) to (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/i/2"},"text":"Pub. L. 102–586, § 3(i)(2)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Subject to paragraph (2), to carry out the purposes of part B of this subchapter, there are authorized to be appropriated $5,000,000 for fiscal year 1989 and such sums as may be necessary for each of the fiscal years 1990, 1991, and 1992.”"}],