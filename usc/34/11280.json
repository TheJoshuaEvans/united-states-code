{"tag":"section","attrib":{"id":"id4cef83e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280"},"text":null,"children":[{"tag":"num","attrib":{"value":"11280"},"text":"§ 11280.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cef83e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cef83e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter (other than part E) $127,421,000 for each of fiscal years 2019 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parts A and B","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amount appropriated under paragraph (1) for a fiscal year, the Secretary shall reserve not less than 90 percent to carry out parts A and B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part B","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount reserved under subparagraph (A), 45 percent and, in those fiscal years in which continuation grant obligations and the quality and number of applicants for parts A and B warrant not more than 55 percent, shall be reserved to carry out part B.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parts C and D","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each fiscal year, after reserving the amounts required by paragraph (2), the Secretary shall use the remaining amount (if any) to carry out parts C and D (other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11245"},"text":"section 11245 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic estimate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated under paragraph (1), such sums as may be necessary shall be made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11245"},"text":"section 11245 of this title","children":[],"tail":" for each of fiscal years 2019 through 2020."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part E","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out part E $25,000,000 for each of fiscal years 2019 through 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cef83f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11280/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate identification required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds appropriated to carry out this subchapter may be combined with funds appropriated under any other Act if the purpose of combining such funds is to make a single discretionary grant, or a single discretionary payment, unless such funds are separately identified in all grants and contracts and are used for the purposes specified in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cef83f2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"