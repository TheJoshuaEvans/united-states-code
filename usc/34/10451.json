{"tag":"section","attrib":{"id":"id4cc47cb8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10451"},"text":null,"children":[{"tag":"num","attrib":{"value":"10451"},"text":"§ 10451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Polygraph testing prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc47cb9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible for grants under this subchapter, a State, Indian tribal government, territorial government, or unit of local government shall certify that, not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":", their laws, policies, or practices will ensure that no law enforcement officer, prosecuting officer or other government official shall ask or require an adult, youth, or child victim of an alleged sex offense as defined under Federal, tribal, State, territorial, or local law to submit to a polygraph examination or other truth telling device as a condition for proceeding with the investigation of such an offense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47cba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prosecution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The refusal of a victim to submit to an examination described in subsection (a) shall not prevent the investigation, charging, or prosecution of the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc47cbb-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2013"},"text":"Pub. L. 90–351, title I, § 2013","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s101/g"},"text":"Pub. L. 109–162, title I, § 101(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2975"},"text":"119 Stat. 2975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc47cbc-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc47cbd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc47cbe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–8"},"text":"section 3796gg–8 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cc47cbf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4cc47cc0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until the beginning of fiscal year 2007, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s4"},"text":"section 4 of Pub. L. 109–162","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10261"},"text":"section 10261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
