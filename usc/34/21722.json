{"tag":"section","attrib":{"id":"id4d3e19d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722"},"text":null,"children":[{"tag":"num","attrib":{"value":"21722"},"text":"§ 21722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective interagency coordination and Federal data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3e19d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Secretary of Health and Human Services shall, on an annual basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3e19d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect from Federal law enforcement agencies, other agencies as appropriate, and Federal prosecutors’ offices statistical data related to elder abuse cases, including cases or investigations where one or more victims were elders, or the case or investigation involved a financial scheme or scam that was either targeted directly toward or largely affected elders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish on the website of the Department of Justice in a publicly accessible manner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3e19d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the data collected under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for collecting additional data relating to elder abuse, including recommendations for ways to improve data reporting across Federal, State, and local agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data collected under subsection (a)(1) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3e19dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of investigations initiated by Federal law enforcement agencies, other agencies as appropriate, and Federal prosecutors’ offices related to elder abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number and types of elder abuse cases filed in Federal courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each case described in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3e19df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the district where the case originated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the style of the case, including the case name and number;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the act or acts giving rise to the elder abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a scheme or scam, a description of such scheme or scam giving rise to the elder abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about each alleged perpetrator of the elder abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outcome of the case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HHS requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall, on an annual basis, provide to the Attorney General statistical data collected by the Secretary relating to elder abuse cases investigated by adult protective services, which shall be included in the summary published under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on individual data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the information reported under this section shall include specific individually identifiable data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3e19e7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tII/s202"},"text":"Pub. L. 115–70, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1211"},"text":"131 Stat. 1211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
