{"tag":"section","attrib":{"id":"id4d1338ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12521"},"text":null,"children":[{"tag":"num","attrib":{"value":"12521"},"text":"§ 12521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased penalties for drug-dealing in “drug-free” zones","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pursuant to its authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of title 28","children":[],"tail":", the United States Sentencing Commission shall amend its sentencing guidelines to provide an appropriate enhancement for a defendant convicted of violating "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s860"},"text":"section 860 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d1338ad-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIX/s90102"},"text":"Pub. L. 103–322, title IX, § 90102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1987"},"text":"108 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1338ae-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1338af-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1338b0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14051"},"text":"section 14051 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90102"},"text":"section 90102 of Pub. L. 103–322","children":[],"tail":" which is also listed in a table relating to sentencing guidelines set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
