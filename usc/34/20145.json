{"tag":"section","attrib":{"id":"id4d28bc89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20145"},"text":null,"children":[{"tag":"num","attrib":{"value":"20145"},"text":"§ 20145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of barriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d28bc8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency may not require a survivor of human trafficking who is less than 18 years of age or a homeless youth to obtain the consent or signature of the parent or guardian of the survivor or homeless youth to receive a copy of a Government-issued identity card issued to the survivor or homeless youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d28bc8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency may not charge a survivor of human trafficking or a homeless youth a fee to obtain a copy of a Government-issued identity card issued to the survivor or homeless youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d28bc8c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/tIV/s402"},"text":"Pub. L. 117–347, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6208"},"text":"136 Stat. 6208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d28bc8d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d28bc8e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d28bc8f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/s3"},"text":"Pub. L. 117–347, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6199"},"text":"136 Stat. 6199","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/347/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/s1"},"text":"section 1 of Pub. L. 117–347","children":[],"tail":", set out as a Short Title of 2023 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘computer’ includes a computer network and any interactive electronic device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cybercrime against individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘cybercrime against individuals’ has the meaning given that term in section 1401(a) [of the] Violence Against Women Act Reauthorization Act of 2022 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s30107/a"},"text":"34 U.S.C. 30107(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Homeless youth","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘homeless youth’ has the meaning given the term ‘homeless children and youths’ in section 725 of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11434a"},"text":"42 U.S.C. 11434a","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
