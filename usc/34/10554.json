{"tag":"section","attrib":{"id":"id4cce19c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554"},"text":null,"children":[{"tag":"num","attrib":{"value":"10554"},"text":"§ 10554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce19c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “school” means an elementary or secondary school, including a Bureau-funded school (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021"},"text":"section 2021 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unit of local government” means a county, municipality, town, township, village, parish, borough, or other unit of general government below the State level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian tribe” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “evidence-based” means a program, practice, technology, or equipment that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cce19cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrates a statistically significant effect on relevant outcomes based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cce19cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strong evidence from not less than 1 well-designed and well-implemented experimental study;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cce19ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moderate evidence from not less than 1 well-designed and well-implemented quasi-experimental study; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cce19cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promising evidence from not less than 1 well-designed and well-implemented correlational study with statistical controls for selection bias;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce19d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates a rationale based on high-quality research findings or positive evaluation that such program, practice, technology, or equipment is likely to improve relevant outcomes, and includes ongoing efforts to examine the effects of the program, practice, technology, or equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce19d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of technology or equipment, demonstrates that use of the technology or equipment is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cce19d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistent with best practices for school security, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4cce19d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable standards for school security established by a Federal or State government agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cce19d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" findings and recommendations of public commissions and task forces established to make recommendations or set standards for school security; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cce19d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliant with all applicable codes, including building and life safety codes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10554/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “tribal organization” has the same meaning given the term in section 5304(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 25."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce19d7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2704"},"text":"Pub. L. 90–351, title I, § 2704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1108/b"},"text":"Pub. L. 106–386, div. B, title I, § 1108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1502"},"text":"114 Stat. 1502","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tV/s502/4"},"text":"Pub. L. 115–141, div. S, title V, § 502(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1131"},"text":"132 Stat. 1131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cce19d8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cce19d9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cce19da-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797d"},"text":"section 3797d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cce19db-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/4/A"},"text":"Pub. L. 115–141, § 502(4)(A)","children":[],"tail":", substituted “an” for “a public” and inserted “, including a Bureau-funded school (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021"},"text":"section 2021 of title 25","children":[],"tail":")” after “secondary school”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/4/B"},"text":"Pub. L. 115–141, § 502(4)(B)","children":[],"tail":"–(D), added pars. (4) and (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
