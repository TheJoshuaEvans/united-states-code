{"tag":"section","attrib":{"id":"id4cbb062b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10363"},"text":null,"children":[{"tag":"num","attrib":{"value":"10363"},"text":"§ 10363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of State applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbb062c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau shall make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10361/a"},"text":"section 10361(a) of this title","children":[],"tail":" to carry out the projects described in the application submitted by an applicant under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10362"},"text":"section 10362 of this title","children":[],"tail":" upon determining that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbb062d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10363/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application is consistent with the requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb062e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10363/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the approval of the application, the Bureau has made an affirmative finding in writing that the proposed project has been reviewed in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbb062f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10362"},"text":"section 10362 of this title","children":[],"tail":" shall be considered approved, in whole or in part, by the Bureau not later than 45 days after first received unless the Bureau informs the applicant of specific reasons for disapproval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbb0630-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval notice and reconsideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Bureau shall not disapprove any application without first affording the applicant reasonable notice and an opportunity for reconsideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbb0631-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1603"},"text":"Pub. L. 90–351, title I, § 1603","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/521/s4/a/3"},"text":"Pub. L. 102–521, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3405"},"text":"106 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbb0632-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbb0633-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbb0634-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796cc–2"},"text":"section 3796cc–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
