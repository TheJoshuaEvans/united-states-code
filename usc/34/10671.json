{"tag":"section","attrib":{"id":"id4cd78f7a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671"},"text":null,"children":[{"tag":"num","attrib":{"value":"10671"},"text":"§ 10671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd78f7b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage qualified individuals to enter and continue employment as prosecutors and public defenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f7c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f7d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prosecutor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “prosecutor” means a full-time employee of a State or unit of local government who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f7e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is continually licensed to practice law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecutes criminal or juvenile delinquency cases at the State or unit of local government level (including supervision, education, or training of other persons prosecuting such cases).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public defender","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public defender” means an attorney who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is continually licensed to practice law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f82-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cd78f83-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full-time employee of a State or unit of local government who provides legal representation to indigent persons in criminal or juvenile delinquency cases (including supervision, education, or training of other persons providing such representation);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a full-time employee of a nonprofit organization operating under a contract with a State or unit of local government, who devotes substantially all of the employee’s full-time employment to providing legal representation to indigent persons in criminal or juvenile delinquency cases (including supervision, education, or training of other persons providing such representation); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employed as a full-time Federal defender attorney in a defender organization established pursuant to subsection (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3006A"},"text":"section 3006A of title 18","children":[],"tail":" that provides legal representation to indigent persons in criminal or juvenile delinquency cases."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), the term “student loan” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cd78f88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made, insured, or guaranteed under part B of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1071"},"text":"20 U.S.C. 1071","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made under part D or E of title IV of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1087a"},"text":"20 U.S.C. 1087a","children":[],"tail":" et seq. and 1087aa et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan made under section 428C or 455(g) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"20 U.S.C. 1078–3","children":[],"tail":" and 1087e(g))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of parent PLUS loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “student loan” does not include any of the following loans:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cd78f8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made to the parents of a dependent student under section 428B of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–2"},"text":"20 U.S.C. 1078–2","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal Direct PLUS Loan made to the parents of a dependent student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A loan made under section 428C or 455(g) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1078–3"},"text":"20 U.S.C. 1078–3","children":[],"tail":" and 1087e(g)) to the extent that such loan was used to repay a loan described in clause (i) or (ii)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall establish a program by which the Department of Justice shall assume the obligation to repay a student loan, by direct payments on behalf of a borrower to the holder of such loan, in accordance with subsection (d), for any borrower who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed as a prosecutor or public defender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not in default on a loan for which the borrower seeks forgiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive repayment benefits under subsection (c), a borrower shall enter into a written agreement that specifies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower will remain employed as a prosecutor or public defender for a required period of service of not less than three years, unless involuntarily separated from that employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the borrower is involuntarily separated from employment on account of misconduct, or voluntarily separates from employment, before the end of the period specified in the agreement, the borrower will repay the Attorney General the amount of any benefits received by such employee under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the borrower is required to repay an amount to the Attorney General under subparagraph (B) and fails to repay such amount, a sum equal to that amount shall be recoverable by the Federal Government from the employee (or such employee’s estate, if applicable) by such methods as are provided by law for the recovery of amounts owed to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General may waive, in whole or in part, a right of recovery under this subsection if it is shown that recovery would be against equity and good conscience or against the public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General shall make student loan payments under this section for the period of the agreement, subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount repaid by, or recovered from, an individual or the estate of an individual under this subsection shall be credited to the appropriation account from which the amount involved was originally paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merger","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount credited under subparagraph (A) shall be merged with other sums in such account and shall be available for the same purposes and period, and subject to the same limitations, if any, as the sums with which the amount was merged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Student loan payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Student loan repayments made by the Attorney General under this section shall be made subject to such terms, limitations, or conditions as may be mutually agreed upon by the borrower and the Attorney General in an agreement under paragraph (1), except that the amount paid by the Attorney General under this section shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cd78f9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000 for any borrower in any calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aggregate total of $60,000 in the case of any borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78fa0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall authorize the Attorney General to pay any amount to reimburse a borrower for any repayments made by such borrower prior to the date on which the Attorney General entered into an agreement with the borrower under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fa1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78fa2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the required period of service under an agreement under subsection (d), the borrower and the Attorney General may, subject to paragraph (2), enter into an additional agreement in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78fa3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement entered into under paragraph (1) may require the borrower to remain employed as a prosecutor or public defender for less than three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fa4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis; priority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78fa5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Attorney General shall provide repayment benefits under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78fa6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving priority to borrowers who have the least ability to repay their loans, except that the Attorney General shall determine a fair allocation of repayment benefits among prosecutors and public defenders, and among employing entities nationwide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78fa7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78fa8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall give priority in providing repayment benefits under this section in any fiscal year to a borrower who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78fa9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received repayment benefits under this section during the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78faa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed less than three years of the first required period of service specified for the borrower in an agreement entered into under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to issue such regulations as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Inspector General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than three years after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Inspector General of the Department of Justice shall submit to Congress a report on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78fad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the program authorized under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78fae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such program on the hiring and retention of prosecutors and public defenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78faf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2008-08-14"},"text":"August 14, 2008","children":[],"tail":", the Comptroller General shall conduct a study of, and report to Congress on, the impact that law school accreditation requirements and other factors have on the costs of law school and student access to law school, including the impact of such requirements on racial and ethnic minorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10671/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $25,000,000 for fiscal year 2009 and such sums as may be necessary for each of the five succeeding fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd78fb1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3001"},"text":"Pub. L. 90–351, title I, § 3001","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/315/tIX/s952"},"text":"Pub. L. 110–315, title IX, § 952","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-08-14"},"text":"Aug. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3470"},"text":"122 Stat. 3470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd78fb2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd78fb3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cd78fb4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsec. (b)(3)(A)(i), (ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Parts B, D, and E of title IV of the Act are classified to parts B (§ 1071 et seq.), D (§ 1087a et seq.), and E (§ 1087aa et seq.), respectively, of subchapter IV of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd78fb5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797cc–21"},"text":"section 3797cc–21 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s3001"},"text":"section 3001 of Pub. L. 90–351","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10681"},"text":"section 10681 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cd78fb6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id4cd78fb7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","a