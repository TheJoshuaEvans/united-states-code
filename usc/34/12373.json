{"tag":"section","attrib":{"id":"id4d0751cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12373"},"text":null,"children":[{"tag":"num","attrib":{"value":"12373"},"text":"§ 12373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation in developing programs in making grants under this part","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The State Justice Institute shall ensure that model programs carried out pursuant to grants made under this part are developed with the participation of law enforcement officials, public and private nonprofit victim advocates, including national, State, tribal, and local domestic violence and sexual assault programs and coalitions, legal experts, prosecutors, defense attorneys, and recognized experts on gender bias in the courts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d0751cc-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40413"},"text":"Pub. L. 103–322, title IV, § 40413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1944"},"text":"108 Stat. 1944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tIV/s1406/c/1"},"text":"Pub. L. 106–386, div. B, title IV, § 1406(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1516"},"text":"114 Stat. 1516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0751cd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0751ce-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0751cf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13993"},"text":"section 13993 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d0751d0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":" inserted “, including national, State, tribal, and local domestic violence and sexual assault programs and coalitions” after “victim advocates”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
