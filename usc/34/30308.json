{"tag":"section","attrib":{"id":"id4d4545ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30308"},"text":null,"children":[{"tag":"num","attrib":{"value":"30308"},"text":"§ 30308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement that accreditation organizations adopt accreditation standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4545ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for Federal grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, an organization responsible for the accreditation of Federal, State, local, or private prisons, jails, or other penal facilities may not receive any new Federal grants during any period in which such organization fails to meet any of the requirements of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4545ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive Federal grants, an accreditation organization referred to in subsection (a) must meet the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4545ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At all times after 90 days after ","children":[{"tag":"date","attrib":{"date":"2003-09-04"},"text":"September 4, 2003","children":[],"tail":", the organization shall have in effect, for each facility that it is responsible for accrediting, accreditation standards for the detection, prevention, reduction, and punishment of prison rape."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4545f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At all times after 1 year after the date of the adoption of the final rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s30307/a/4"},"text":"section 30307(a)(4) of this title","children":[],"tail":", the organization shall, in addition to any other such standards that it may promulgate relevant to the detection, prevention, reduction, and punishment of prison rape, adopt accreditation standards consistent with the national standards adopted pursuant to such final rule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4545f1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/79/s9"},"text":"Pub. L. 108–79, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-04"},"text":"Sept. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/987"},"text":"117 Stat. 987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4545f2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4545f3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4545f4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15608"},"text":"section 15608 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
