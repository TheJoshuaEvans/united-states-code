{"tag":"section","attrib":{"id":"id4cc95ee8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472"},"text":null,"children":[{"tag":"num","attrib":{"value":"10472"},"text":"§ 10472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95ee9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “mental illness” means a diagnosable mental, behavioral, or emotional disorder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95eea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of sufficient duration to meet diagnostic criteria within the most recent edition of the Diagnostic and Statistical Manual of Mental Disorders published by the American Psychiatric Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95eeb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has resulted in functional impairment that substantially interferes with or limits 1 or more major life activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95eec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “preliminarily qualified offender with mental illness, mental retardation, or co-occurring mental and substance abuse disorders” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95eed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95eee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously or currently has been diagnosed by a qualified mental health professional as having a mental illness, mental retardation, or co-occurring mental illness and substance abuse disorders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manifests obvious signs of mental illness, mental retardation, or co-occurring mental illness and substance abuse disorders during arrest or confinement or before any court; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ef0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deemed eligible by designated judges;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95ef1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “court-ordered assisted outpatient treatment” means a program through which a court may order a treatment plan for an eligible patient that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95ef2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires such patient to obtain outpatient mental health treatment while the patient is not currently residing in a correctional facility or inpatient treatment facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ef3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is designed to improve access and adherence by such patient to intensive behavioral health services in order to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95ef4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avert relapse, repeated hospitalizations, arrest, incarceration, suicide, property destruction, and violent behavior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95ef5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such patient with the opportunity to live in a less restrictive alternative to incarceration or involuntary hospitalization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95ef6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “eligible patient” means an adult, mentally ill person who, as determined by a court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95ef7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a history of violence, incarceration, or medically unnecessary hospitalizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ef8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without supervision and treatment, may be a danger to self or others in the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ef9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is substantially unlikely to voluntarily participate in treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95efa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be unable, for reasons other than indigence, to provide for any of his or her basic needs, such as food, clothing, shelter, health, or safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95efb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a history of mental illness or a condition that is likely to substantially deteriorate if the person is not provided with timely treatment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95efc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10472/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" due to mental illness, lacks capacity to fully understand or lacks judgment to make informed decisions regarding his or her need for treatment, care, or supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc95efd-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2202"},"text":"Pub. L. 90–351, title I, § 2202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/515/s3/a"},"text":"Pub. L. 106–515, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2400"},"text":"114 Stat. 2400","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14002/b"},"text":"Pub. L. 114–255, div. B, title XIV, § 14002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1288"},"text":"130 Stat. 1288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc95efe-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc95eff-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc95f00-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ii–1"},"text":"section 3796ii–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cc95f01-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2202"},"text":"section 2202 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tV/s50001/a/3"},"text":"Pub. L. 103–322, title V, § 50001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1956"},"text":"108 Stat. 1956","children":[],"tail":", related to prohibition of participation by violent offenders, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(b)(1)(A)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–21; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc95f02-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
