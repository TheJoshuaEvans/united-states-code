{"tag":"section","attrib":{"id":"id4ced1325-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245"},"text":null,"children":[{"tag":"num","attrib":{"value":"11245"},"text":"§ 11245.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic estimate of incidence and prevalence of youth homelessness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced1326-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic estimate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2008-10-08"},"text":"October 8, 2008","children":[],"tail":", and at 5-year intervals thereafter, the Secretary, in consultation with the United States Interagency Council on Homelessness, shall prepare and submit to the Committee on Education and Labor of the House of Representatives and the Committee on the Judiciary of the Senate, and make available to the public, a report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1327-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by using the best quantitative and qualitative social science research methods available, containing an estimate of the incidence and prevalence of runaway and homeless individuals who are not less than 13 years of age but are less than 26 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1328-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes with such estimate an assessment of the characteristics of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1329-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced132a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the results of conducting a survey of, and direct interviews with, a representative sample of runaway and homeless individuals who are not less than 13 years of age but are less than 26 years of age, to determine past and current—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced132b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" socioeconomic characteristics of such individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced132c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" barriers to such individuals obtaining—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ced132d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe, quality, and affordable housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ced132e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive and affordable health insurance and health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ced132f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incomes, public benefits, supportive services, and connections to caring adults; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1330-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary determines, in consultation with States, units of local government, and national nongovernmental organizations concerned with homelessness, may be useful.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1331-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11245/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary enters into any contract with a non-Federal entity for purposes of carrying out subsection (a), such entity shall be a nongovernmental organization, or an individual, determined by the Secretary to have appropriate expertise in quantitative and qualitative social science research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced1332-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s345"},"text":"Pub. L. 93–415, title III, § 345","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/378/s6"},"text":"Pub. L. 110–378, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4070"},"text":"122 Stat. 4070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced1333-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced1334-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced1335-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–25"},"text":"section 5714–25 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ced1336-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s345"},"text":"section 345 of title III of Pub. L. 93–415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/i"},"text":"Pub. L. 106–71, § 3(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1038"},"text":"113 Stat. 1038","children":[],"tail":", related to study of runaways to determine the percent who have been sexually abused, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI/s115"},"text":"Pub. L. 108–96, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1170"},"text":"117 Stat. 1170","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ced1337-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id4ced1338-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
