{"tag":"section","attrib":{"id":"id4cce1a0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564"},"text":null,"children":[{"tag":"num","attrib":{"value":"10564"},"text":"§ 10564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cce1a0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or unit of local government that receives a grant under this subchapter shall use the grant to do any one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out all or a substantial part of a program intended to improve the quality and timeliness of forensic science or medical examiner services in the State, including such services provided by the laboratories operated by the State and those operated by units of local government within the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a0f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To eliminate a backlog in the analysis of forensic science evidence, including firearms examination, latent prints, impression evidence, toxicology, digital evidence, fire evidence, controlled substances, forensic pathology, questionable documents, and trace evidence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a10-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To train, assist, and employ forensic laboratory personnel and medicolegal death investigators, as needed, to eliminate such a backlog.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a11-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To address emerging forensic science issues (such as statistics, contextual bias, and uncertainty of measurement) and emerging forensic science technology (such as high throughput automation, statistical software, and new types of instrumentation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a12-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To educate and train forensic pathologists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a13-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To fund medicolegal death investigation systems to facilitate accreditation of medical examiner and coroner offices and certification of medicolegal death investigators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce1a14-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted categories of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (c) and (d), a grant awarded for the purpose set forth in subsection (a)(1)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a15-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only be used for program expenses relating to facilities, personnel, computerization, equipment, supplies, accreditation and certification, education, and training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a16-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used for any general law enforcement or nonforensic investigatory function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce1a17-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a18-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States receiving minimum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a State that receives a grant under this subchapter (including grants received by units of local government within a State) in an amount that does not exceed 0.6 percent of the total amount made available to carry out this subchapter for a fiscal year, not more than 80 percent of the total amount of the grant may be used for the costs of any new facility constructed as part of a program described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a19-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a State that receives a grant under this subchapter in an amount that exceeds 0.6 percent of the total amount made available to carry out this subchapter for a fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cce1a1a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 80 percent of the amount of the grant up to that 0.6 percent may be used for the costs of any new facility constructed as part of a program described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce1a1b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 40 percent of the amount of the grant in excess of that 0.6 percent may be used for the costs of any new facility constructed as part of a program described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce1a1c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of the total amount of a grant awarded under this subchapter may be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce1a1d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Backlog defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a backlog in the analysis of forensic science evidence exists if such evidence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce1a1e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been stored in a laboratory, medical examiner’s office, coroner’s office, law enforcement storage facility, or medical facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce1a1f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10564/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been subjected to all appropriate forensic testing because of a lack of resources or personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce1a20-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2804"},"text":"Pub. L. 90–351, title I, § 2804","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/561/s2/c/1"},"text":"Pub. L. 106–561, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2789"},"text":"114 Stat. 2789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tV/s5001/b/4"},"text":"Pub. L. 107–273, div. B, title V, § 5001(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1814"},"text":"116 Stat. 1814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s311/a"},"text":"Pub. L. 108–405, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2276"},"text":"118 Stat. 2276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s9/a/3"},"text":"Pub. L. 114–324, § 9(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1955"},"text":"130 Stat. 1955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cce1a21-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cce1a22-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cce1a23-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797m"},"text":"section 3797m of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cce1a24-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324/s9/a/3/A"},"text":"Pub. L. 114–324, § 9(a)(3)(A)","children":[],"tail":", inserted “impression evidence,” after “latent prints,” and “digital evidence, fire evidence,” after “toxicology,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324/s9/a/3/B"},"text":"Pub. L. 114–324, § 9(a)(3)(B)","children":[],"tail":", inserted “and medicolegal death investigators” after “laboratory personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324/s9/a/3/C"},"text":"Pub. L. 114–324, § 9(a)(3)(C)","children":[],"tail":", added pars. (4) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/s311/a/1"},"text":"Pub. L. 108–405, § 311(a)(1)","children":[],"tail":", substituted “shall use the grant to do any one or more of the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) To carry out”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"for “shall use the grant to carry out” and added pars. (2) and (3).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/s311/a/2"},"text":"Pub. L. 108–405, § 311(a)(2)","children":[],"tail":", substituted “for the purpose set forth in subsection (a)(1)” for “under this subchapter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/s311/a/3"},"text":"Pub. L. 108–405, § 311(a)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s5001/b/4/A"},"text":"Pub. L. 107–273, § 5001(b)(4)(A)","children":[],"tail":", inserted “or unit of local government” after “A State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s5001/b/4/B"},"text":"Pub. L. 107–273, § 5001(b)(4)(B)","children":[],"tail":", inserted “(including grants received by units of local government within a State)” after “under this subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
