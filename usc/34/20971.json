{"tag":"section","attrib":{"id":"id4d36eea9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971"},"text":null,"children":[{"tag":"num","attrib":{"value":"20971"},"text":"§ 20971.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jimmy Ryce State civil commitment programs for sexually dangerous persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36eeaa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Attorney General shall make grants to jurisdictions for the purpose of establishing, enhancing, or operating effective civil commitment programs for sexually dangerous persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36eeab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall not make any grant under this section for the purpose of establishing, enhancing, or operating any transitional housing for a sexually dangerous person in or near a location where minors or other vulnerable persons are likely to come into contact with that person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36eeac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36eead-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, a jurisdiction shall, before the expiration of the compliance period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d36eeae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have established a civil commitment program for sexually dangerous persons that is consistent with guidelines issued by the Attorney General; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d36eeaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a plan for the establishment of such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36eeb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The compliance period referred to in paragraph (1) expires on the date that is 2 years after ","children":[{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":". However, the Attorney General may, on a case-by-case basis, extend the compliance period that applies to a jurisdiction if the Attorney General considers such an extension to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395db1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395db2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each civil commitment program for which funding is required under this section shall require the issuance of timely notice to a State official responsible for considering whether to pursue civil commitment proceedings upon the impending release of any person incarcerated by the State who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395db3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a sexually violent offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395db4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been deemed by the State to be at high risk for recommitting any sexual offense against a minor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395db5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall further require that upon receiving notice under subparagraph (A), the State official shall consider whether or not to pursue a civil commitment proceeding, or any equivalent proceeding required under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395db6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than January 31 of each year, beginning with 2008, the Attorney General shall submit to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives a report on the progress of jurisdictions in implementing this section and the rate of sexually violent offenses for each jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395db7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395db8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “civil commitment program” means a program that involves—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395db9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure civil confinement, including appropriate control, care, and treatment during such confinement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395dba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate supervision, care, and treatment for individuals released following such confinement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dbb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “sexually dangerous person” means a person suffering from a serious mental illness, abnormality, or disorder, as a result of which the individual would have serious difficulty in refraining from sexually violent conduct or child molestation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dbc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “jurisdiction” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20911"},"text":"section 20911 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395dbd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20971/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2007 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395dbe-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tIII/s301"},"text":"Pub. L. 109–248, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/617"},"text":"120 Stat. 617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395dbf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395dc0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395dc1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16971"},"text":"section 16971 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
