{"tag":"section","attrib":{"id":"id4d07522b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12405"},"text":null,"children":[{"tag":"num","attrib":{"value":"12405"},"text":"§ 12405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance, training, and evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may provide technical assistance and training in furtherance of the purposes of this part, and may provide for the evaluation of programs that receive funds under this part, in addition to any evaluation requirements that the Attorney General may prescribe for grantees. The technical assistance, training, and evaluations authorized by this section may be carried out directly by the Attorney General, or through contracts or other arrangements with other entities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d07522c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40606"},"text":"Pub. L. 103–322, title IV, § 40606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1952"},"text":"108 Stat. 1952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d07522d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d07522e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d07522f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14035"},"text":"section 14035 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
