{"tag":"section","attrib":{"id":"id4d4ee259-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40508"},"text":null,"children":[{"tag":"num","attrib":{"value":"40508"},"text":"§ 40508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4ee25a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", and biennially thereafter, the Attorney General shall submit to the Committee on the Judiciary of the House of Representatives and the Committee on the Judiciary of the Senate a report describing the status of the NCIC database and NamUs databases."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4ee25b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall describe, to the extent available, information on the process of information sharing between the NCIC database and NamUs databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4ee25c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s5"},"text":"Pub. L. 117–327, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4457"},"text":"136 Stat. 4457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4ee25d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4ee25e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4ee25f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Billy’s Law, also known as the Help Find the Missing Act, and not as part of Jennifer’s Law which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d4ee260-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d4ee261-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “NCIC database” and “NamUs databases” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s6"},"text":"section 6 of Pub. L. 117–327","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40506"},"text":"section 40506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
