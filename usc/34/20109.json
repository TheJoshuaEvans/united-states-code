{"tag":"section","attrib":{"id":"id4d1f1f91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109"},"text":null,"children":[{"tag":"num","attrib":{"value":"20109"},"text":"§ 20109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault survivors’ notification grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1f92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may make grants as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20103/c/1/A"},"text":"section 20103(c)(1)(A) of this title","children":[],"tail":" to States to develop and disseminate to entities described in subsection (c)(1) of this section written notice of applicable rights and policies for sexual assault survivors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a grant awarded under subsection (a) shall make its best effort to ensure that each entity described in subsection (c)(1) provides individuals who identify as a survivor of a sexual assault, and who consent to receiving such information, with written notice of applicable rights and policies regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1f94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right not to be charged fees for or otherwise prevented from pursuing a sexual assault evidence collection kit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to have a sexual assault medical forensic examination regardless of whether the survivor reports to or cooperates with law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of a sexual assault advocate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of protective orders and policies related to their enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies regarding the storage, preservation, and disposal of sexual assault evidence collection kits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process, if any, to request preservation of sexual assault evidence collection kits or the probative evidence from such kits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of victim compensation and restitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of written notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a grant awarded under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1f9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the written notice described in subsection (b) to medical centers, hospitals, forensic examiners, sexual assault service providers, State and local law enforcement agencies, and any other State agency or department reasonably likely to serve sexual assault survivors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the written notice described in subsection (b) publicly available on the Internet website of the attorney general of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision to promote compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may provide such technical assistance and guidance as necessary to help recipients meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any system developed and implemented under this section may be integrated with an existing case management system operated by the recipient of the grant if the system meets the requirements listed in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f1fa0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1404F"},"text":"Pub. L. 98–473, title II, § 1404F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/236/s3"},"text":"Pub. L. 114–236, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-10-07"},"text":"Oct. 7, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/967"},"text":"130 Stat. 967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f1fa1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1f1fa2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1f1fa3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10603f"},"text":"section 10603f of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
