{"tag":"section","attrib":{"id":"id4cce19e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10556"},"text":null,"children":[{"tag":"num","attrib":{"value":"10556"},"text":"§ 10556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cce19ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10556/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No funds to provide firearms or training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts provided as a grant under this subchapter may be used for the provision to any person of a firearm or training in the use of a firearm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce19eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10556/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter may be construed to preclude or contradict any other provision of law authorizing the provision of firearms or training in the use of firearms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce19ec-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2706"},"text":"Pub. L. 90–351, title I, § 2706","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tV/s502/6"},"text":"Pub. L. 115–141, div. S, title V, § 502(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1132"},"text":"132 Stat. 1132","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
