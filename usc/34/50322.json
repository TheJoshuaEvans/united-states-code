{"tag":"section","attrib":{"id":"id4d5d13a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322"},"text":null,"children":[{"tag":"num","attrib":{"value":"50322"},"text":"§ 50322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d13a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or local agency head may nominate for a State and Local Law Enforcement Badge an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d13a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a State or local law enforcement officer working within the agency of the State or local agency head making the nomination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d13aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d13ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sustained a physical injury while—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d5d13ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in the lawful duties of the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d5d13ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing an act characterized as bravery by the State or local agency head making the nomination; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d13ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" put the individual at personal risk when the injury described in clause (i) occurred; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d13af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while not injured, performed an act characterized as bravery by the State or local agency head making the nomination that placed the individual at risk of serious physical injury or death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d13b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A nomination under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d13b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written narrative, of not more than 2 pages, describing the circumstances under which the nominee performed the act of bravery described in subsection (a) and how the circumstances meet the criteria described in such subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full name of the nominee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the home mailing address of the nominee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency in which the nominee served on the date when such nominee performed the act of bravery described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the occupational title and grade or rank of the nominee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the field office address of the nominee on the date when such nominee performed the act of bravery described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of years of government service by the nominee as of the date when such nominee performed the act of bravery described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d13b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or local agency head shall submit each nomination under subsection (a) to the Office not later than February 15 of the year following the date on which the nominee performed the act of bravery described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d13b9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/298/tII/s202"},"text":"Pub. L. 110–298, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-31"},"text":"July 31, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2990"},"text":"122 Stat. 2990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d13ba-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d13bb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d13bc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15252"},"text":"section 15252 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
