{"tag":"section","attrib":{"id":"id4d0c0d70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493"},"text":null,"children":[{"tag":"num","attrib":{"value":"12493"},"text":"§ 12493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Housing and Urban Development Gender-based Violence Prevention Office and Violence Against Women Act Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0c0d71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development shall establish a Gender-based Violence Prevention Office with a Violence Against Women Act Director (in this section referred to as the “Director”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0d72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, among other duties—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0d73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support implementation of this subpart;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0d74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with Federal agencies on legislation, implementation, and other issues affecting the housing provisions under this part, as well as other issues related to advancing housing protections for victims of domestic violence, dating violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7d75-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with State and local governments and agencies, including State housing finance agencies, regarding advancing housing protections and access to housing for victims of domestic violence, dating violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7d76-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that technical assistance and support are provided to each appropriate agency and housing providers regarding implementation of this part, as well as other issues related to advancing housing protections for victims of domestic violence, dating violence, sexual assault, and stalking, including compliance with this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7d77-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement internal systems to track, monitor, and address compliance failures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7d78-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the housing needs and barriers faced by victims of sexual assault, as well as sexual coercion and sexual harassment by a public housing agency or owner or manager of housing assisted under a covered housing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7d79-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12493/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0e7d7a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41413"},"text":"Pub. L. 103–322, title IV, § 41413","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s602"},"text":"Pub. L. 117–103, div. W, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/883"},"text":"136 Stat. 883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0e7d7b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0e7d7c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0e7d7d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s602"},"text":"Pub. L. 117–103, div. W, title VI, § 602","children":[],"tail":", which directed the addition of this section to chapter 2 of subtitle N of title IV of the Violence Against Women Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491"},"text":"34 U.S.C. 12491","children":[],"tail":" et seq.), was executed by adding this section to chapter 2 of subtitle N of title IV of the Violent Crime Control and Law Enforcement Act of 1994 to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d0e7d7e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d0e7d7f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
