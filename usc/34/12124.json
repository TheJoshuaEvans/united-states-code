{"tag":"section","attrib":{"id":"id4cf8fa05-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124"},"text":null,"children":[{"tag":"num","attrib":{"value":"12124"},"text":"§ 12124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correctional job training and placement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf8fa06-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to encourage and support job training programs, and job placement programs, that provide services to incarcerated persons or ex-offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8fa07-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8fa08-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correctional institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “correctional institution” means any prison, jail, reformatory, work farm, detention center, or halfway house, or any other similar institution designed for the confinement or rehabilitation of criminal offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa09-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correctional job training or placement program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “correctional job training or placement program” means an activity that provides job training or job placement services to incarcerated persons or ex-offenders, or that assists incarcerated persons or ex-offenders in obtaining such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa0a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex-offender","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ex-offender” means any individual who has been sentenced to a term of probation by a Federal or State court, or who has been released from a Federal, State, or local correctional institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa0b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incarcerated person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “incarcerated person” means any individual incarcerated in a Federal or State correctional institution who is charged with or convicted of any criminal offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8fa0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8fa0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish within the Department of Justice an Office of Correctional Job Training and Placement. The Office shall be headed by a Director, who shall be appointed by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall carry out this subsection not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8fa0f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, acting through the Director of the Office of Correctional Job Training and Placement, in consultation with the Secretary of Labor, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8fa10-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in coordinating the activities of the Federal Bonding Program of the Department of Labor, the activities of the Department of Labor related to the certification of eligibility for targeted jobs credits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s51"},"text":"section 51 of title 26","children":[],"tail":" with respect to ex-offenders, and any other correctional job training or placement program of the Department of Justice or Department of Labor;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa11-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical assistance to State and local employment and training agencies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8fa12-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive financial assistance under this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8fa13-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive financial assistance through other programs carried out by the Department of Justice or Department of Labor, for activities related to the development of employability;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa14-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and implement the use of special staff training materials, and methods, for developing the staff competencies needed by State and local agencies to assist incarcerated persons and ex-offenders in gaining marketable occupational skills and job placement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa15-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to Congress an annual report on the activities of the Office of Correctional Job Training and Placement, and the status of correctional job training or placement programs in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa16-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with other Federal agencies carrying out correctional job training or placement programs to ensure coordination of such programs throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa17-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with, and provide outreach to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8fa18-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State job training coordinating councils, administrative entities, and private industry councils, with respect to programs carried out under this Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8fa19-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other State and local officials, with respect to other employment or training programs carried out by the Department of Justice or Department of Labor;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa1a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect from States information on the training accomplishments and employment outcomes of a sample of incarcerated persons and ex-offenders who were served by employment or training programs carried out, or that receive financial assistance through programs carried out, by the Department of Justice or Department of Labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8fa1b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8fa1c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect from States and local governments information on the development and implementation of correctional job training or placement programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8fa1d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12124/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such information, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf8fa1e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20418"},"text":"Pub. L. 103–322, title II, § 20418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1835"},"text":"108 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf8fa1f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf8fa20-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cf8fa21-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(2)(A), (6)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1796"},"text":"108 Stat. 1796","children":[],"tail":", known as the Violent Crime Control and Law Enforcement Act of 1994. For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf8fa22-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13725"},"text":"section 13725 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
