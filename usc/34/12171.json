{"tag":"section","attrib":{"id":"id4cfb6a8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171"},"text":null,"children":[{"tag":"num","attrib":{"value":"12171"},"text":"§ 12171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfb6a8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may make grants to qualified community organizations to assist in meeting the costs of qualified programs which are designed to recruit and retain applicants to police departments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with the Ounce of Prevention Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may consult with the Ounce of Prevention Council in making grants under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6a8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified community organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization is a qualified community organization which is eligible to receive a grant under subsection (a) if the organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has training and experience in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfb6a91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with a police department and with teachers, counselors, and similar personnel,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing services to the community in which the organization is located,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and managing services and techniques to recruit individuals to become members of a police department and to assist such individuals in meeting the membership requirements of police departments,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and managing services and techniques to assist in the retention of applicants to police departments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing other programs that contribute to the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6a96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program is a qualified program for which a grant may be made under subsection (a) if the program is designed to recruit and train individuals from underrepresented neighborhoods and localities and if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overall design of the program is to recruit and retain applicants to a police department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program provides recruiting services which include tutorial programs to enable individuals to meet police force academic requirements and to pass entrance examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program provides counseling to applicants to police departments who may encounter problems throughout the application process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program provides retention services to assist in retaining individuals to stay in the application process of a police department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6a9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To qualify for a grant under subsection (a), a qualified organization shall submit an application to the Attorney General in such form as the Attorney General may prescribe. Such application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include documentation from the applicant showing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfb6a9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intended use of grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expected results from the use of grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6aa0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demographic characteristics of the population to be served, including age, disability, race, ethnicity, and languages used; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aa1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances satisfactory to the Attorney General that the program for which a grant is made will meet the applicable requirements of the program guidelines prescribed by the Attorney General under subsection (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6aa2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Attorney General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date that an application for a grant under subsection (a) is received, the Attorney General shall consult with the police department which will be involved with the applicant and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6aa3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the application and disburse the grant funds applied for; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aa4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove the application and inform the applicant that the application is not approved and provide the applicant with the reasons for the disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6aa5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant disbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall disburse funds under a grant under subsection (a) in accordance with regulations of the Attorney General which shall ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6aa6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority is given to applications for areas and organizations with the greatest showing of need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aa7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that grant funds are equitably distributed on a geographic basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aa8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of underserved populations are recognized and addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6aa9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under subsection (a) shall be made for a period not longer than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6aaa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6aab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each year of a grant period for a grant under subsection (a), the recipient of the grant shall file a performance report with the Attorney General explaining the activities carried out with the funds received and assessing the effectiveness of such activities in meeting the purpose of the recipient’s qualified program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there was more than one recipient of a grant, each recipient shall file such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall suspend the funding of a grant, pending compliance, if the recipient of the grant does not file the report required by this subsection or uses the grant for a purpose not authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6aae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall, by regulation, prescribe guidelines on content and results for programs receiving a grant under subsection (a). Such guidelines shall be designed to establish programs which will be effective in training individuals to enter instructional programs for police departments and shall include requirements for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6aaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals providing recruiting services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ab0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals providing tutorials and other academic assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ab1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals providing retention services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ab2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12171/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the content and duration of recruitment, retention, and counseling programs and the means and devices used to publicize such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfb6ab3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s30801"},"text":"Pub. L. 103–322, title III, § 30801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1857"},"text":"108 Stat. 1857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfb6ab4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfb6ab5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfb6ab6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13811"},"text":"section 13811 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
