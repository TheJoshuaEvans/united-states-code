{"tag":"section","attrib":{"id":"id4cc47c8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449"},"text":null,"children":[{"tag":"num","attrib":{"value":"10449"},"text":"§ 10449.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rape exam payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc47c8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc47c8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, Indian tribal government, or unit of local government shall not be entitled to funds under this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See References in Text note below."}],"tail":" unless the State, Indian tribal government, unit of local government, or another governmental entity—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc47c8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurs the full out-of-pocket cost of forensic medical exams described in subsection (b) for victims of sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc47c90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates with health care providers in the region to notify victims of sexual assault of the availability of rape exams at no cost to the victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds withheld from a State or unit of local government under paragraph (1) shall be distributed to other States or units of local government pro rata. Funds withheld from an Indian tribal government under paragraph (1) shall be distributed to other Indian tribal governments pro rata.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47c92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, Indian tribal government, or unit of local government shall be deemed to incur the full out-of-pocket cost of forensic medical exams for victims of sexual assault if any government entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc47c93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides such exams to victims free of charge to the victim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranges for victims to obtain such exams free of charge to the victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47c95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or Indian tribal government may use Federal grant funds under this subchapter to pay for forensic medical exams performed by trained examiners for victims of sexual assault, except that such funds may not be used to pay for forensic medical exams by any State, Indian tribal government, or territorial government that requires victims of sexual assault to seek reimbursement for such exams from their insurance carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47c96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncooperation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc47c97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be in compliance with this section, a State, Indian tribal government, or unit of local government shall comply with subsection (b) without regard to whether the victim participates in the criminal justice system or cooperates with law enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States, territories, and Indian tribal governments shall have 3 years from the date of enactment of this Act ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to come into compliance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47c99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc47c9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or unit of local government shall not be entitled to funds under this subchapter unless the State or unit of local government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc47c9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that its judicial administrative policies and practices include notification to domestic violence offenders of the requirements delineated in section 922(g)(8) and (g)(9) of title 18 and any applicable related Federal, State, or local laws; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc47c9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" gives the Attorney General assurances that its judicial administrative policies and practices will be in compliance with the requirements of subparagraph (A) within the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc47c9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period ending on the date on which the next session of the State legislature ends; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc47c9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10449/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds withheld from a State or unit of local government under subsection (a) shall be distributed to other States and units of local government, pro rata.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc47ca0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2010"},"text":"Pub. L. 90–351, title I, § 2010","children":[],"tail":", formerly § 2005, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40121/a/3"},"text":"Pub. L. 103–322, title IV, § 40121(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1914"},"text":"108 Stat. 1914","children":[],"tail":"; renumbered § 2010, "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIV/s402/2"},"text":"Pub. L. 107–273, div. A, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1789"},"text":"116 Stat. 1789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s310/b"},"text":"Pub. L. 108–405, title III, § 310(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2276"},"text":"118 Stat. 2276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s101/f"},"text":"Pub. L. 109–162, title I, § 101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2974"},"text":"119 Stat. 2974","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s2/j"},"text":"Pub. L. 109–271, § 2(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/753"},"text":"120 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tI/s101/4"},"text":"Pub. L. 113–4, title I, § 101(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/69"},"text":"127 Stat. 69","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc47ca1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc47ca2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cc47ca3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a)(1), was in the original “this subchapter”, and was translated as reading “this part”, meaning part T of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this Act, referred to in subsec. (d)(2), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc47ca4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–4"},"text":"section 3796gg–4 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc47ca5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s101/4/A"},"text":"Pub. L. 113–4, § 101(4)(A)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “A State, Indian tribal government, or unit of local government, shall not be entitled to funds under this subchapter unless the State, Indian tribal government, unit of local government, or another governmental entity incurs the full out-of-pocket cost of forensic medical exams described in subsection (b) of this section for victims of sexual assault.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s101/4/B"},"text":"Pub. L. 113–4, § 101(4)(B)","children":[],"tail":", inserted “or” after the semicolon in par. (1), substituted a period for “; or” in par. (2), and struck out par. (3) which related to reimbursement of victims for the cost of exams under certain conditions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s101/4/C"},"text":"Pub. L. 113–4, § 101(4)(C)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) related to a rule of construction and a compliance period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":" designated existing provisions as par. (1), inserted par. heading, struck out “Nothing” before “in this section”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cc47ca6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cc47ca7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cc47ca8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" not effective until the beginning of fiscal year 2007, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s4"},"text":"section 4 of Pub. L. 109–162","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10261"},"text":"section 10261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
