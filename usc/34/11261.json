{"tag":"section","attrib":{"id":"id4ced133e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11261"},"text":null,"children":[{"tag":"num","attrib":{"value":"11261"},"text":"§ 11261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced133f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to nonprofit private agencies for the purpose of providing street-based services to runaway and homeless, and street youth, who have been subjected to, or are at risk of being subjected to, sexual abuse, prostitution, sexual exploitation, severe forms of trafficking in persons (as defined in section 7102(9) ","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 22), or sex trafficking (as defined in section 7102(10) "},{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":" of title 22)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1340-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting applicants to receive grants under subsection (a), the Secretary shall give priority to public and nonprofit private agencies that have experience in providing services to runaway and homeless, and street youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced1341-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s351"},"text":"Pub. L. 93–415, title III, § 351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/n/1/C"},"text":"Pub. L. 106–71, § 3(n)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1040"},"text":"113 Stat. 1040","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/378/s7"},"text":"Pub. L. 110–378, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4071"},"text":"122 Stat. 4071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tII/s201/2"},"text":"Pub. L. 114–22, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/248"},"text":"129 Stat. 248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced1342-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced1343-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ced1344-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7102(9) and (10) of title 22, referred to in subsec. (a), was redesignated section 7102(11) and (12), respectively, of title 22 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced1345-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–41"},"text":"section 5714–41 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced1346-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22"},"text":"Pub. L. 114–22","children":[],"tail":" substituted “sexual exploitation, severe forms of trafficking in persons (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/9"},"text":"section 7102(9) of title 22","children":[],"tail":"), or sex trafficking (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/10"},"text":"section 7102(10) of title 22","children":[],"tail":")” for “or sexual exploitation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378"},"text":"Pub. L. 110–378","children":[],"tail":" inserted “public and” after “priority to”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
