{"tag":"section","attrib":{"id":"id4cfdb59b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253"},"text":null,"children":[{"tag":"num","attrib":{"value":"12253"},"text":"§ 12253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb59c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this subpart ","children":[{"tag":"ref","attrib":{"idref":"fn002102"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002102"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall, not later than 90 days after the 1-year period in which the grant is required to be expended, submit a report to the Attorney General regarding the family unity demonstration project for which the grant was expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb59d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb59e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the number of prisoners who submitted applications to participate in the project and the number of prisoners who were placed in community correctional facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb59f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state, with respect to prisoners placed in the project, the number of prisoners who are returned to that jurisdiction and custody and the reasons for such return;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the nature and scope of educational and training activities provided to prisoners participating in the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the number, and describe the scope of, contracts made with public and nonprofit private community-based organizations to carry out such project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12253/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the effectiveness of the project in accomplishing the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12241"},"text":"section 12241 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb5a3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31913"},"text":"Pub. L. 103–322, title III, § 31913","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1895"},"text":"108 Stat. 1895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb5a4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb5a5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfdb5a6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subpart, referred to in subsec. (a), was in the original “this title” and was translated as reading “this chapter”, meaning chapter 1 of subtitle S of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb5a7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13893"},"text":"section 13893 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
