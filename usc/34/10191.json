{"tag":"section","attrib":{"id":"id4ca582bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191"},"text":null,"children":[{"tag":"num","attrib":{"value":"10191"},"text":"§ 10191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime prevention campaign grant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca582bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may provide a grant to a national private, nonprofit organization that has expertise in promoting crime prevention through public outreach and media campaigns in coordination with law enforcement agencies and other local government officials, and representatives of community public interest organizations, including schools and youth-serving organizations, faith-based, and victims’ organizations and employers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To request a grant under this section, an organization described in subsection (a) shall submit an application to the Attorney General in such form and containing such information as the Attorney General may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization that receives a grant under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and promote national public communications campaigns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and distribute publications and other educational materials that promote crime prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and maintain web sites and related web-based materials and tools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and deliver training for law enforcement personnel, community leaders, and other partners in public safety and hometown security initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and deliver technical assistance to States, local jurisdictions, and crime prevention practitioners and associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate a coalition of Federal, national, and statewide organizations and communities supporting crime prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design, deliver, and assess demonstration programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate McGruff-related programs, including McGruff Club;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate the Teens, Crime, and Community Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate crime prevention programs and trends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2007, $7,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2008, $8,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2009, $9,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10191/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2010, $10,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca582ce-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s519"},"text":"Pub. L. 90–351, title I, § 519","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s626"},"text":"Pub. L. 109–248, title VI, § 626","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/636"},"text":"120 Stat. 636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ca582cf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ca582d0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ca582d1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3765"},"text":"section 3765 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ca582d2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s519"},"text":"section 519 of Pub. L. 90–351","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/208"},"text":"82 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/644/tI/s7/7"},"text":"Pub. L. 91–644, title I, § 7(7)","children":