{"tag":"section","attrib":{"id":"id4ceaa216-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11191"},"text":null,"children":[{"tag":"num","attrib":{"value":"11191"},"text":"§ 11191.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Materials produced, procured, or distributed both using funds appropriated to carry out this chapter and for the purpose of preventing hate crimes that result in acts of physical violence, shall not recommend or require any action that abridges or infringes upon the constitutionally protected rights of free speech, religion, or equal protection of juveniles or of their parents or legal guardians.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ceaa217-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tII/s299J"},"text":"Pub. L. 93–415, title II, § 299J","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12220"},"text":"Pub. L. 107–273, div. C, title II, § 12220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1893"},"text":"116 Stat. 1893","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ceaa218-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ceaa219-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ceaa21a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References i