{"tag":"section","attrib":{"id":"id4cef83b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279"},"text":null,"children":[{"tag":"num","attrib":{"value":"11279"},"text":"§ 11279.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cef83b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug abuse education and prevention services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “drug abuse education and prevention services”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means services to runaway and homeless youth to prevent or reduce the illicit use of drugs by such youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual, family, group, and peer counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drop-in services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to runaway and homeless youth in rural areas (including the development of community support groups);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and training relating to the illicit use of drugs by runaway and homeless youth, to individuals involved in providing services to such youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to improve the availability of local drug abuse prevention services to runaway and homeless youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home-based services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “home-based services”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means services provided to youth and their families for the purpose of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing such youth from running away, or otherwise becoming separated, from their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting runaway youth to return to their families; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes services that are provided in the residences of families (to the extent practicable), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intensive individual and family counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training relating to life skills and parenting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeless youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “homeless”, used with respect to a youth, means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 21 years of age, or, in the case of a youth seeking shelter in a center under part A, less than 18 years of age, or is less than a higher maximum age if the State where the center is located has an applicable State or local law (including a regulation) that permits such higher maximum age in compliance with licensure requirements for child-and youth-serving ","children":[{"tag":"ref","attrib":{"idref":"fn002073"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002073"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" facilities; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the purposes of part B, not less than 16 years of age and either—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4cef83c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 22 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cef83c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 22 years of age, as of the expiration of the maximum period of stay permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11222/a/2"},"text":"section 11222(a)(2) of this title","children":[],"tail":" if such individual commences such stay before reaching 22 years of age;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for whom it is not possible to live in a safe environment with a relative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has no other safe alternative living arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Runaway youth","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “runaway”, used with respect to a youth, means an individual who is less than 18 years of age and who absents himself or herself from home or a place of legal residence without the permission of a parent or legal guardian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Street-based services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “street-based services”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means services provided to runaway and homeless youth, and street youth, in areas where they congregate, designed to assist such youth in making healthy personal choices regarding where they live and how they behave; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of and outreach to runaway and homeless youth, and street youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crisis intervention and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and referral for housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and referral for transitional living and health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advocacy, education, and prevention services related to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4cef83d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alcohol and drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cef83d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sexual exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cef83d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sexually transmitted diseases, including human immunodeficiency virus (HIV); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cef83d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/5/B/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical and sexual assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Street youth","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “street youth” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a runaway youth; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indefinitely or intermittently a homeless youth; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spends a significant amount of time on the street or in other areas that increase the risk to such youth for sexual abuse, sexual exploitation, prostitution, or drug abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional living youth project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transitional living youth project” means a project that provides shelter and services designed to promote a transition to self-sufficient living and to prevent long-term dependency on social services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef83dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Youth at risk of separation from the family","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “youth at risk of separation from the family” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cef83dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is less than 18 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cef83de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cef83df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a history of running away from the family of such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose parent, guardian, or custodian is not willing to provide for the basic needs of such individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cef83e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11279/8/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is at risk of entering the child welfare system or juvenile justice system as a result of the lack of services available to the family to meet such needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cef83e2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s387"},"text":"Pub. L. 93–415, title III, § 387","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/p"},"text":"Pub. L. 106–71, § 3(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1041"},"text":"113 Stat. 1041","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI/s116"},"text":"Pub. L. 108–96, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1170"},"text":"117 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/378/s10"},"text":"Pub. L. 110–378, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4072"},"text":"122 Stat. 4072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cef83e3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cef83e4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cef83e5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5732a"},"text":"section 5732a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cef83e6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s10/a/1"},"text":"Pub. L. 110–378, § 10(a)(1)","children":[],"tail":", substituted “The term ‘homeless’, used with respect to a youth, means” for “The term ‘homeless youth’ means” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s10/a/2/A"},"text":"Pub. L. 110–378, § 10(a)(2)(A)","children":[],"tail":", substituted “less than” for “not more than” in two places and inserted “, or is less than a higher maximum age if the State where the center is located has an applicable State or local law (including a regulation) that permits such higher maximum age in compliance with licensure requirements for child-and youth-serving facilities” after “18 years of age”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s10/a/2/B"},"text":"Pub. L. 110–378, § 10(a)(2)(B)","children":[],"tail":", substituted “age and either—” for “age;” and added subcls. (I) and (II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s10/b"},"text":"Pub. L. 110–378, § 10(b)","children":[],"tail":", added par. (4) and redesignated former pars. (4) to (7) as (5) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96"},"text":"Pub. L. 108–96","children":[],"tail":" inserted “, or, in the case of a youth seeking shelter in a center under part A, not more than 18 years of age” after “of age”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
