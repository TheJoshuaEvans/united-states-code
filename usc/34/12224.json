{"tag":"section","attrib":{"id":"id4cfdb554-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12224"},"text":null,"children":[{"tag":"num","attrib":{"value":"12224"},"text":"§ 12224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds; limitations on grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb555-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative cost limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall use not more than 5 percent of the funds available under this program for the purposes of administration and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb556-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this part ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may be renewed for up to 2 additional years after the first fiscal year during which the recipient receives its initial grant under this part,"},{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":" subject to the availability of funds, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb557-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12224/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General determines that the funds made available to the recipient during the previous years were used in a manner required under the approved application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb558-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12224/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General determines that an additional grant is necessary to implement the community prosecution program described in the comprehensive plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12223"},"text":"section 12223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb559-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31704"},"text":"Pub. L. 103–322, title III, § 31704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1891"},"text":"108 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb55a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb55b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfdb55c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (b), appearing in the original, is unidentifiable because subtitle Q of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" does not contain parts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb55d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13864"},"text":"section 13864 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
