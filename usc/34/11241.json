{"tag":"section","attrib":{"id":"id4ced12e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11241"},"text":null,"children":[{"tag":"num","attrib":{"value":"11241"},"text":"§ 11241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With respect to matters relating to the health, education, employment, and housing of runaway and homeless youth, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced12e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11241/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conjunction with the Attorney General, shall coordinate the activities of agencies of the Department of Health and Human Services with activities under any other Federal juvenile crime control, prevention, and juvenile offender accountability program and with the activities of other Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11241/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate the activities of agencies of the Department of Health and Human Services with the activities of other Federal entities and with the activities of entities that are eligible to receive grants under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11241/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult, as appropriate, the Secretary of Housing and Urban Development to ensure coordination of programs and services for homeless youth.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced12e7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s341"},"text":"Pub. L. 93–415, title III, § 341","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/C"},"text":"Pub. L. 102–586, § 3(g)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5023"},"text":"106 Stat. 5023","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/g"},"text":"Pub. L. 106–71, § 3(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1038"},"text":"113 Stat. 1038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI/s112"},"text":"Pub. L. 108–96, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1169"},"text":"117 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced12e8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced12e9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced12ea-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–21"},"text":"section 5714–21 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ced12eb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s341"},"text":"section 341 of Pub. L. 93–415","children":[],"tail":" was renumbered section 380 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11271"},"text":"section 11271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced12ec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96"},"text":"Pub. L. 108–96","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71"},"text":"Pub. L. 106–71","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “With respect to matters relating to the health, education, employment, and housing of runaway and homeless youth, the Secretary shall coordinate the activities of agencies of the Department of Health and Human Services with the activities of other Federal entities and with the activities of entities that are eligible to receive grants under this subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
