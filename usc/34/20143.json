{"tag":"section","attrib":{"id":"id4d23dac3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143"},"text":null,"children":[{"tag":"num","attrib":{"value":"20143"},"text":"§ 20143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for young witness assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d23dac4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Assistance of the Office of Justice Programs may make grants to State and local prosecutors and law enforcement agencies in support of juvenile and young adult witness assistance programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dac5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made available under this section may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23dac6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the needs of juvenile and young adult witnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dac7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop appropriate program goals and objectives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dac8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop and administer a variety of witness assistance services, which includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23dac9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling services to young witnesses dealing with trauma associated in witnessing a violent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23daca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre- and post-trial assistance for the youth and their family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23dacb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing education services if the child is removed from or changes their school for safety concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23dacc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protective services for young witnesses and their families when a serious threat of harm from the perpetrators or their associates is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23dacd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community outreach and school-based initiatives that stimulate and maintain public awareness and support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dace-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23dacf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “juvenile” means an individual who is age 17 or younger.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dad0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “young adult” means an individual who is age 21 or younger but not a juvenile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dad1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dad2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20143/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $3,000,000 for each of fiscal years 2006 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d23dad3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1136"},"text":"Pub. L. 109–162, title XI, § 1136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3109"},"text":"119 Stat. 3109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/c"},"text":"Pub. L. 109–271, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/766"},"text":"120 Stat. 766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d23dad4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d23dad5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d23dad6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3743"},"text":"section 3743 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d23dad7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":" substituted “The Director of the Bureau of Justice Assistance of the Office of Justice Programs may” for “The Attorney General, acting through the Bureau of Justice Assistance, may”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
