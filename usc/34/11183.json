{"tag":"section","attrib":{"id":"id4ceaa1c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11183"},"text":null,"children":[{"tag":"num","attrib":{"value":"11183"},"text":"§ 11183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Whenever the Administrator, after giving reasonable notice and opportunity for hearing to a recipient of financial assistance under this subchapter, finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ceaa1c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11183/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program or activity for which the grant or contract involved was made has been so changed that it no longer complies with this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa1c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11183/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the operation of such program or activity there is failure to comply substantially with any provision of this subchapter;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Administrator shall initiate such proceedings as are appropriate.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ceaa1ca-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tII/s299B"},"text":"Pub. L. 93–415, title II, § 299B","children":[],"tail":", formerly § 293, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7266/4"},"text":"Pub. L. 100–690, title VII, § 7266(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "}