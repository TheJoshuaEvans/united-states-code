{"tag":"section","attrib":{"id":"id4ced1292-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213"},"text":null,"children":[{"tag":"num","attrib":{"value":"11213"},"text":"§ 11213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced1293-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application by a public or private entity for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a"},"text":"section 11211(a) of this title","children":[],"tail":" may be approved by the Secretary after taking into consideration, with respect to the State in which such entity proposes to provide services under this part—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1294-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographical distribution in such State of the proposed services under this part for which all grant applicants request approval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1295-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which areas of such State have the greatest need for such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1296-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting applications for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a"},"text":"section 11211(a) of this title","children":[],"tail":", the Secretary shall give priority to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1297-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible applicants who have demonstrated experience in providing services to runaway and homeless youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1298-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible applicants that request grants of less than $200,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced1299-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s313"},"text":"Pub. L. 93–415, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1131"},"text":"88 Stat. 1131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/115/s7/a/4"},"text":"Pub. L. 95–115, § 7(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1058"},"text":"91 Stat. 1058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/509/s18/e"},"text":"Pub. L. 96–509, § 18(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-08"},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2762"},"text":"94 Stat. 2762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s653"},"text":"Pub. L. 98–473, title II, § 653","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2123"},"text":"98 Stat. 2123","children":[],"tail":"; renumbered § 316 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §§ 7271(c)(1), 7275(a), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4453"},"text":"102 Stat. 4453","children":[],"tail":", 4457; renumbered § 313 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/d"},"text":"Pub. L. 102–586, § 3(d)","children":[],"tail":", (g)(2)(D), "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5022"},"text":"106 Stat. 5022","children":[],"tail":", 5025; "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/d"},"text":"Pub. L. 106–71, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1037"},"text":"113 Stat. 1037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced129a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced129b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced129c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5713"},"text":"section 5713 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ced129d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s313"},"text":"section 313 of Pub. L. 93–415","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5712a"},"text":"section 5712a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced129e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71"},"text":"Pub. L. 106–71","children":[],"tail":" inserted section catchline and amended text generally. Prior to amendment, text read as follows: “An application by a State, locality, or private entity for a grant under section 5711(a), (c), or (d) of this title may be approved by the Secretary only if it is consistent with the applicable provisions of section 5711(a), (c), or (d) of this title and meets the requirements set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5712"},"text":"section 5712 of this title","children":[],"tail":". Priority shall be given to grants smaller than $200,000. In considering grant applications under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5711/a"},"text":"section 5711(a) of this title","children":[],"tail":", priority shall be given to organizations which have a demonstrated experience in the provision of service to runaway and homeless youth and their families.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/d"},"text":"Pub. L. 102–586, § 3(d)","children":[],"tail":", substituted “section 5711(a), (c), or (d) of this title” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5711/a"},"text":"section 5711(a) of this title","children":[],"tail":"” in two places in first sentence and substituted “$200,000” for “$150,000” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/1"},"text":"Pub. L. 100–690, § 7271(c)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5711/a"},"text":"section 5711(a) of this title","children":[],"tail":"” for “this part” in three places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “private entity” for “nonprofit private agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/509"},"text":"Pub. L. 96–509","children":[],"tail":" substituted “$150,000” for “$100,000” and “organizations which have a demonstrated experience in the provision of service to runaway and homeless youth and their families” for “any applicant whose program budget is smaller than $150,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/115"},"text":"Pub. L. 95–115","children":[],"tail":" substituted “$100,000” and “$150,000” for “$75,000” and “$100,000”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ced129f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ced12a0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7296/a"},"text":"section 7296(a) of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ced12a1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s670/a"},"text":"section 670(a) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/