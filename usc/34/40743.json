{"tag":"section","attrib":{"id":"id4d539cce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40743"},"text":null,"children":[{"tag":"num","attrib":{"value":"40743"},"text":"§ 40743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expungement of profiles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The expungement requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12592/d"},"text":"section 12592(d) of this title","children":[],"tail":" shall apply to any DNA profile or DNA data collected pursuant to this subchapter for purposes of inclusion in the National DNA Index System."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d539ccf-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/253/s4"},"text":"Pub. L. 112–253, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2408"},"text":"126 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d539cd0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d539cd1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d539cd2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/253"},"text":"Pub. L. 112–253","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2407"},"text":"126 Stat. 2407","children":[],"tail":", known as the Katie Sepich Enhanced DNA Collection Act of 2012, which is classified principally to this subchapter. For complete classification of this Act to the Code, see Short Title of 2013 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d539cd3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14137b"},"text":"section 14137b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
