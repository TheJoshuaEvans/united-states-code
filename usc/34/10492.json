{"tag":"section","attrib":{"id":"id4ccba87c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10492"},"text":null,"children":[{"tag":"num","attrib":{"value":"10492"},"text":"§ 10492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General may make grants to States and local law enforcement agencies and to organizations representing State or local law enforcement personnel to provide family support services and mental health services to law enforcement personnel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ccba87d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2302"},"text":"Pub. L. 90–351, title I, § 2302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210201/a/3"},"text":"Pub. L. 103–322, title XXI, § 210201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2062"},"text":"108 Stat. 2062","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/32/s2/3"},"text":"Pub. L. 116–32, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-25"},"text":"July 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1036"},"text":"133 Stat. 1036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba87e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba87f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba880-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796jj–1"},"text":"section 3796jj–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ccba881-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/32"},"text":"Pub. L. 116–32","children":[],"tail":" inserted “and mental health services” after “family support services”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
