{"tag":"section","attrib":{"id":"id4ca0c7c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156"},"text":null,"children":[{"tag":"num","attrib":{"value":"10156"},"text":"§ 10156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca0c7c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation among States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c7c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount appropriated for this part, the Attorney General shall, except as provided in paragraph (2), allocate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca0c7c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of such remaining amount to each State in amounts that bear the same ratio of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ca0c7ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total population of a State to—","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca0c7cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total population of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c7cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 50 percent of such remaining amount to each State in amounts that bear the same ratio of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ca0c7cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average annual number of part 1 violent crimes of the Uniform Crime Reports of the Federal Bureau of Investigation reported by such State for the three most recent years reported by such State to—","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca0c7ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average annual number of such crimes reported by all States for such years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If carrying out paragraph (1) would result in any State receiving an allocation less than 0.25 percent of the total amount (in this paragraph referred to as a “minimum allocation State”), then paragraph (1), as so carried out, shall not apply, and the Attorney General shall instead—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca0c7d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocate 0.25 percent of the total amount to each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c7d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the amount remaining after carrying out subparagraph (A), carry out paragraph (1) in a manner that excludes each minimum allocation State, including the population of and the crimes reported by such State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation between States and units of local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts allocated under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c7d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent shall be for direct grants to States, to be allocated under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent shall be for grants to be allocated under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation for State governments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c7d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts allocated under subsection (b)(1), each State may retain for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10152"},"text":"section 10152 of this title","children":[],"tail":" an amount that bears the same ratio of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca0c7d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total expenditures on criminal justice by the State government in the most recently completed fiscal year to—","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c7d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total expenditure on criminal justice by the State government and units of local government within the State in such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remaining amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (e)(1), any amounts remaining after the allocation required by paragraph (1) shall be made available to units of local government by the State for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10152"},"text":"section 10152 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations to local governments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c7db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts allocated under subsection (b)(2), grants for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10152"},"text":"section 10152 of this title","children":[],"tail":" shall be made directly to units of local government within each State in accordance with this subsection, subject to subsection (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca0c7dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From the amounts referred to in paragraph (1) with respect to a State (in this subsection referred to as the “local amount”), the Attorney General shall allocate to each unit of local government an amount which bears the same ratio to such share as the average annual number of part 1 violent crimes reported by such unit to the Federal Bureau of Investigation for the 3 most recent calendar years for which such data is available bears to the number of part 1 violent crimes reported by all units of local government in the State in which the unit is located to the Federal Bureau of Investigation for such years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c7de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), for fiscal years 2006, 2007, and 2008, the Attorney General shall allocate the local amount to units of local government in the same manner that, under the Local Government Law Enforcement Block Grants program in effect immediately before ","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":", the reserved amount was allocated among reporting and nonreporting units of local government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annexed units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a unit of local government in the State has been annexed since the date of the collection of the data used by the Attorney General in making allocations pursuant to this section, the Attorney General shall pay the amount that would have been allocated to such unit of local government to the unit of local government that annexed it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of disparate allocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca0c7e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of this part, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ca0c7e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General certifies that a unit of local government bears more than 50 percent of the costs of prosecution or incarceration that arise with respect to part 1 violent crimes reported by a specified geographically constituent unit of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca0c7e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" but for this paragraph, the amount of funds allocated under this section to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4ca0c7e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any one such specified geographically constituent unit of local government exceeds 150 percent of the amount allocated to the unit of local government certified pursuant to clause (i); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4ca0c7e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one such specified geographically constituent unit of local government exceeds 400 percent of the amount allocated to the unit of local government certified pursuant to clause (i),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then in order to qualify for payment under this subsection, the unit of local government certified pursuant to clause (i), together with any such specified geographically constituent units of local government described in clause (ii), shall submit to the Attorney General a joint application for the aggregate of funds allocated to such units of local government. Such application shall specify the amount of such funds that are to be distributed to each of the units of local government and the purposes for which such funds are to be used. The units of local government involved may establish a joint local advisory board for the purposes of carrying out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c7e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this paragraph, the term “geographically constituent unit of local government” means a unit of local government that has jurisdiction over areas located within the boundaries of an area over which a unit of local government certified pursuant to clause (i) has jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on allocations to units of local government","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c7e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No unit of local government shall receive a total allocation under this section that exceeds such unit’s total expenditures on criminal justice services for the most recently completed fiscal year for which data are available. Any amount in excess of such total expenditures shall be allocated proportionally among units of local government whose allocations under this section do not exceed their total expenditures on such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations under $10,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the allocation under this section to a unit of local government is less than $10,000 for any fiscal year, the direct grant to the State under subsection (c) shall be increased by the amount of such allocation, to be distributed (for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10152"},"text":"section 10152 of this title","children":[],"tail":") among State police departments that provide criminal justice services to units of local government and units of local government whose allocation under this section is less than $10,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-reporting units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No allocation under this section shall be made to a unit of local government that has not reported at least three years of data on part 1 violent crimes of the Uniform Crime Reports to the Federal Bureau of Investigation within the immediately preceding 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds not used by the State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General determines, on the basis of information available during any grant period, that any allocation (or portion thereof) under this section to a State for such grant period will not be required, or that a State will be unable to qualify or receive funds under this part, or that a State chooses not to participate in the program established under this part, then such State’s allocation (or portion thereof) shall be awarded by the Attorney General to units of local government, or combinations thereof, within such State, giving priority to those jurisdictions with the highest annual number of part 1 violent crimes of the Uniform Crime Reports reported by the unit of local government to the Federal Bureau of Investigation for the three most recent calendar years for which such data are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for Puerto Rico","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c7ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All funds set aside for Commonwealth government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, the amounts allocated under subsection (a) to Puerto Rico, 100 percent shall be for direct grants to the Commonwealth government of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c7ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No local allocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (c) and (d) shall not apply to Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Units of local government in Louisiana","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section with respect to the State of Louisiana, the term “unit of local government” means a district attorney or a parish sheriff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c7f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10156/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part 1 violent crimes to include human trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “part 1 violent crimes” shall include severe forms of trafficking in persons (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca0c7f1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s505"},"text":"Pub. L. 90–351, title I, § 505","children":[],"tail":", as 