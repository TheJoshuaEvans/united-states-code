{"tag":"section","attrib":{"id":"id4cbfc1d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409"},"text":null,"children":[{"tag":"num","attrib":{"value":"10409"},"text":"§ 10409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbfc1d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (4), for each fiscal year for which a grant or subgrant is awarded under this subchapter, each State or specially qualified unit of local government that receives such a grant shall submit to the Attorney General a grant report, and each unit of local government that receives such a subgrant shall submit to the State a subgrant report, at such time and in such manner as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each grant report required by paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities carried out with such grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such activities included any subgrant, a summary of the activities carried out with each such subgrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of such activities on achieving the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrant report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each subgrant report required by paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the activities carried out with such subgrant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of such activities on achieving the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may waive the requirement of an assessment in paragraph (2)(C) for a State or specially qualified unit of local government, or in paragraph (3)(B) for a unit of local government, if the Attorney General determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the activities are such that assessing their effectiveness would not be practical or insightful;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the grant or subgrant is such that carrying out the assessment would not be an effective use of those amounts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources available to the State or unit are such that carrying out the assessment would pose a financial hardship on the State or unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc1e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the last day of each fiscal year for which 1 or more grants are awarded under this subchapter, the Attorney General shall submit to Congress a report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the information provided under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment by the Attorney General of the grant program carried out under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Attorney General considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc1e4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1808"},"text":"Pub. L. 90–351, title I, § 1808","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1867"},"text":"116 Stat. 1867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc1e5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc1e6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc1e7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–8"},"text":"section 3796ee–8 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
