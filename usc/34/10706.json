{"tag":"section","attrib":{"id":"id4cda002f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706"},"text":null,"children":[{"tag":"num","attrib":{"value":"10706"},"text":"§ 10706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cda0030-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of applicable committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “applicable committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda0031-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0032-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cda0033-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All grants awarded by the Attorney General under this subchapter shall be subject to the following accountability provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda0034-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda0035-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “unresolved audit finding” means a finding in the final audit report of the Inspector General of the Department of Justice that the audited grantee has utilized grant funds for an unauthorized expenditure or otherwise unallowable cost that is not closed or resolved within 12 months after the date on which the final audit report is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0036-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", and in each fiscal year thereafter, the Inspector General of the Department of Justice shall conduct audits of recipients of grants awarded by the Attorney General under this subchapter to prevent waste, fraud, and abuse of funds by grantees. The Inspector General shall determine the appropriate number of grantees to be audited each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0037-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of grant funds under this subchapter that is found to have an unresolved audit finding shall not be eligible to receive grant funds under this subchapter during the first 2 fiscal years beginning after the end of the 12-month period described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0038-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this subchapter, the Attorney General shall give priority to eligible applicants that did not have an unresolved audit finding during the 3 fiscal years before submitting an application for a grant under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0039-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an entity is awarded grant funds under this subchapter during the 2-fiscal-year period during which the entity is barred from receiving grants under subparagraph (C), the Attorney General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cda003a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit an amount equal to the amount of the grant funds that were improperly awarded to the grantee into the General Fund of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cda003b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to recoup the costs of the repayment to the fund from the grant recipient that was erroneously awarded grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda003c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda003d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph and the grant programs under this subchapter, the term “nonprofit organization” means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and is exempt from taxation under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda003e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A nonprofit organization that holds money in offshore accounts for the purpose of avoiding paying the tax described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s511/a"},"text":"section 511(a) of title 26","children":[],"tail":" may not—"}],"tail":null},{"tag":"clause","attrib":{"id":"id4cda003f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be party to a contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10701/b"},"text":"section 10701(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cda0040-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive a subaward under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10701/b"},"text":"section 10701(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0041-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each nonprofit organization that receives a subaward or is party to a contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10701/b"},"text":"section 10701(b) of this title","children":[],"tail":" and uses the procedures prescribed in regulations to create a rebuttable presumption of reasonableness for the compensation of its officers, directors, trustees, and key employees, shall disclose, in the application for such contract or subaward, the process for determining such compensation, including the independent persons involved in reviewing and approving such compensation, the comparability data used, and contemporaneous substantiation of the deliberation and decision. Upon request, the Attorney General shall make the information disclosed under this subparagraph available for public inspection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0042-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda0043-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts made available to the Attorney General under this subchapter may be used by the Attorney General, or by any State, unit of local government, or entity awarded a grant, subaward, or contract under this subchapter, to host or support any expenditure for conferences that uses more than $20,000 in funds made available by the Attorney General, unless the head of the relevant agency, bureau, or program office provides prior written authorization that the funds may be expended to host or support the conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0044-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Written authorization under subparagraph (A) shall include a written estimate of all costs associated with the conference, including the cost of all food, beverages, audio-visual equipment, honoraria for speakers, and entertainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0045-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Attorney General shall submit to the applicable committees an annual report on all conference expenditures approved by the Attorney General under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0046-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning in the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", the Attorney General shall submit to the applicable committees an annual certification—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda0047-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" indicating whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cda0048-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all audits issued by the Inspector General of the Department of Justice under paragraph (1) have been completed and reviewed by the appropriate Assistant Attorney General or Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cda0049-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all mandatory exclusions required under paragraph (1)(C) have been issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cda004a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all reimbursements required under paragraph (1)(E) have been made; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda004b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes a list of any grant recipients excluded under paragraph (1) from the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cda004c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing duplicative grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda004d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the Attorney General awards a grant to an applicant under this subchapter, the Attorney General shall compare potential grant awards with other grants awarded under this subchapter by the Attorney General to determine if duplicate grant awards are awarded for the same purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda004e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Attorney General awards duplicate grants under this subchapter to the same applicant for the same purpose, the Attorney General shall submit to the applicable committees a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda004f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all duplicate grants awarded under this subchapter, including the total dollar amount of any duplicate grants awarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0050-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10706/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason the Attorney General awarded the duplicate grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cda0051-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3026"},"text":"Pub. L. 90–351, title I, § 3026","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tVII/s701/a"},"text":"Pub. L. 114–198, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/735"},"text":"130 Stat. 735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cda0052-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cda0053-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cda0054-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797ff–5"},"text":"section 3797ff–5 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
