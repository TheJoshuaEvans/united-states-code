{"tag":"section","attrib":{"id":"id4d075253-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421"},"text":null,"children":[{"tag":"num","attrib":{"value":"12421"},"text":"§ 12421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and services to end abuse in later life","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall make grants to eligible entities in accordance with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d075254-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory and permissible activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d075255-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant under this section shall use the funds received under the grant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d075256-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training programs to assist law enforcement agencies, prosecutors, agencies of States or units of local government, population specific organizations, victim service providers, victim advocates, or relevant officers in Federal, tribal, State, territorial, and local courts in recognizing and addressing instances of abuse in later life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075257-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide or enhance services for victims of abuse in later life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075258-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or support multidisciplinary collaborative community responses to victims of abuse in later life; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075259-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct cross-training for law enforcement agencies, prosecutors, agencies of States or units of local government, attorneys, health care providers, population specific organizations, faith-based leaders, victim advocates, victim service providers, courts, and first responders to better serve older victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d07525a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity receiving a grant under this section may use the funds received under the grant to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d07525b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training programs to assist attorneys, health care providers, faith-based leaders, community-based organizations, or other professionals who may identify or respond to abuse in later life; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d07525c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach activities and awareness campaigns to ensure that victims of abuse in later life receive appropriate assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d07525d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may waive 1 or more of the activities described in subparagraph (A) upon making a determination that the activity would duplicate services available in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d07525e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving a grant under this section may use not more than 10 percent of the total funds received under the grant for an activity described in subparagraph (B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07525f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall be eligible to receive a grant under this section if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d075260-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the entity is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d075261-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075262-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075263-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal government or tribal organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075264-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a population specific organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075265-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075266-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, tribal, or territorial domestic violence or sexual assault coalition; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d075267-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the entity demonstrates that it is part of a multidisciplinary partnership that includes, at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d075268-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d075269-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prosecutor’s office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d07526a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d07526b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit program or government agency with demonstrated experience in assisting individuals 50 years of age or over.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07526c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Attorney General shall give priority to proposals providing services to culturally specific and underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07526d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12421/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d07526e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40801"},"text":"Pub. L. 103–322, title IV, § 40801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tII/s1209/a"},"text":"Pub. L. 106–386, div. B, title II, § 1209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1508"},"text":"114 Stat. 1508","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tII/s204/a"},"text":"Pub. L. 113–4, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/82"},"text":"127 Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tII/s204/2"},"text":"Pub. L. 117–103, div. W, title II, § 204(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/857"},"text":"136 Stat. 857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d07526f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075270-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d075271-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14041"},"text":"section 14041 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d075272-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/B"},"text":"Pub. L. 117–103, § 204(2)(B)","children":[],"tail":", (C)(i), (ii), inserted introductory provisions, struck out subsec. (a) which defined “exploitation”, “later life”, and “neglect”, struck out subsec. (b) designation and heading and text of par. (1) of former subsec. (b) which authorized the Attorney General to make grants to eligible entities, and redesignated pars. (2) to (5) of former subsec. (b) as pars. (1) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/A"},"text":"Pub. L. 117–103, § 204(2)(A)","children":[],"tail":", substituted “Training” for “Enhanced training” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iii/I"},"text":"Pub. L. 117–103, § 204(2)(C)(iii)(I)","children":[],"tail":", struck out “, including domestic violence, dating violence, sexual assault, stalking, exploitation, and neglect” after “life” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iii/II/aa"},"text":"Pub. L. 117–103, § 204(2)(C)(iii)(II)(aa)","children":[],"tail":", substituted “victim advocates, or” for “victim advocates, and” and “abuse in later life” for “elder abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iii/II/bb"},"text":"Pub. L. 117–103, § 204(2)(C)(iii)(II)(bb)","children":[],"tail":", substituted “leaders, victim advocates, victim service providers, courts, and first responders to better serve older victims” for “advocates, victim service providers, and courts to better serve victims of abuse in later life”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iii/III/aa"},"text":"Pub. L. 117–103, § 204(2)(C)(iii)(III)(aa)","children":[],"tail":", substituted “community-based organizations, or other professionals who may identify or respond to abuse in later life” for “or other community-based organizations in recognizing and addressing instances of abuse in later life”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iii/III/bb"},"text":"Pub. L. 117–103, § 204(2)(C)(iii)(III)(bb)","children":[],"tail":", which directed amendment of cl. (ii) by striking “elder abuse and”, could not be executed because the words “elder abuse and” did not appear in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iv/I/aa"},"text":"Pub. L. 117–103, § 204(2)(C)(iv)(I)(aa)","children":[],"tail":", struck out “with demonstrated experience in assisting individuals over 50 years of age” after “organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iv/I/bb"},"text":"Pub. L. 117–103, § 204(2)(C)(iv)(I)(bb)","children":[],"tail":", struck out “with demonstrated experience in addressing domestic violence, dating violence, sexual assault, and stalking” after “provider”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/iv/II"},"text":"Pub. L. 117–103, § 204(2)(C)(iv)(II)","children":[],"tail":", substituted “50 years of age or over.” for “in later life;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s204/2/C/v"},"text":"Pub. L. 117–103, § 204(2)(C)(v)","children":[],"tail":", substituted “$10,000,000” for “$9,000,000” and “2023 through 2027” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" amended section generally. Prior to amendment, section defined terms for this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d075273-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d075274-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d075275-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
