{"tag":"section","attrib":{"id":"id4d512c93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40726"},"text":null,"children":[{"tag":"num","attrib":{"value":"40726"},"text":"§ 40726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DNA identification of missing persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512c94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make grants to promote the use of forensic DNA technology to identify missing persons and unidentified human remains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State or unit of local government that receives funding under this section shall be required to submit the DNA profiles of such missing persons and unidentified human remains to the National Missing Persons DNA Database of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $2,000,000 for each of fiscal years 2017 through 2021 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512c97-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s308"},"text":"Pub. L. 108–405, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2275"},"text":"118 Stat. 2275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s8/c"},"text":"Pub. L. 114–324, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1954"},"text":"130 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512c98-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512c99-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512c9a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14136d"},"text":"section 14136d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d512c9b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":" substituted “fiscal years 2017 through 2021” for “fiscal years 2005 through 2009”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
