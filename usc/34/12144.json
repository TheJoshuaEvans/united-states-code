{"tag":"section","attrib":{"id":"id4cfb6a6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12144"},"text":null,"children":[{"tag":"num","attrib":{"value":"12144"},"text":"§ 12144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To request a grant under this part the chief local elected official of an area shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12144/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Attorney General an application in such form, at such time, and in accordance with such procedures, as the Attorney General shall establish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12144/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assurance that funds received under this part shall be used to supplement, not supplant, non-Federal funds that would otherwise be available for programs funded under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfb6a70-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s30304"},"text":"Pub. L. 103–322, title III, § 30304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1845"},"text":"108 Stat. 1845","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfb6a71-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfb6a72-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfb6a73-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13774"},"text":"section 13774 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
