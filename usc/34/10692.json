{"tag":"section","attrib":{"id":"id4cd78fce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10692"},"text":null,"children":[{"tag":"num","attrib":{"value":"10692"},"text":"§ 10692.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile sex offender treatment grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd78fcf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10692/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make juvenile sex offender treatment grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78fd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10692/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this subchapter, the Attorney General may make grants to units of local government, Indian tribal governments, correctional facilities, other public and private entities, and multijurisdictional or regional consortia thereof for activities specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78fd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10692/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An activity referred to in paragraph (1) is any program, project, or other activity to assist in the treatment of juvenile sex offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fd2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10692/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile sex offender defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “juvenile sex offender” is a sex offender who had not attained the age of 18 years at the time of his or her offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10692/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $10,000,000 for each of fiscal years 2007 through 2009 to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd78fd4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3012"},"text":"Pub. L. 90–351, title I, § 3012","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s623"},"text":"Pub. L. 109–248, title VI, § 623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/635"},"text":"120 Stat. 635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd78fd5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd78fd6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd78fd7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797ee–1"},"text":"section 3797ee–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
