{"tag":"section","attrib":{"id":"id4cbd4fc4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382"},"text":null,"children":[{"tag":"num","attrib":{"value":"10382"},"text":"§ 10382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd4fc5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be made under this subchapter unless an application has been submitted to, and approved by, the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fc6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subchapter shall be submitted in such form, and contain such information, as the Attorney General may prescribe by regulation or guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fc7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the regulations or guidelines established by the Attorney General, each application for a grant under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd4fc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a long-term strategy and detailed implementation plan that reflects consultation with community groups and appropriate private and public agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a specific public safety need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the applicant’s inability to address the need without Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fcb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify related governmental and community initiatives which complement or will be coordinated with the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fcc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that there has been appropriate coordination with all affected agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fcd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline the initial and ongoing level of community support for implementing the proposal including financial and in-kind contributions or other tangible commitments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify plans for obtaining necessary support and continuing the proposed program, project, or activity following the conclusion of Federal support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fcf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the application is for a grant for hiring or rehiring additional career law enforcement officers, specify plans for the assumption by the applicant of a progressively larger share of the cost in the course of time, looking toward the continuation of the increased hiring level using State or local sources of funding following the conclusion of Federal support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the impact, if any, of the increase in police resources on other components of the criminal justice system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain how the grant will be utilized to reorient the affected law enforcement agency’s mission toward community-oriented policing or enhance its involvement in or commitment to community-oriented policing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fd2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that the applicant will, to the extent practicable, seek, recruit, and hire members of racial and ethnic minority groups and women in order to increase their ranks within the sworn positions in the law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd4fd4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small jurisdictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, in relation to applications under this subchapter of units of local government or law enforcement agencies having jurisdiction over areas with populations of less than 50,000, the Attorney General may waive 1 or more of the requirements of subsection (c) and may otherwise make special provisions to facilitate the expedited submission, processing, and approval of such applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fd5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10382/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, in relation to applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10381/b"},"text":"section 10381(b) of this title","children":[],"tail":" for grants of less than $1,000,000, the Attorney General may waive 1 or more of the requirements of subsection (c) and may otherwise make special provisions to facilitate the expedited submission, processing, and approval of such applications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd4fd6-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1702"},"text":"Pub. L. 90–351, title I, § 1702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tI/s10003/a/3"},"text":"Pub. L. 103–322, title I, § 10003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1811"},"text":"108 Stat. 1811","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI"},"text":"Pub. L. 109–162, title XI","children":[],"tail":", §§ 1111(c)(2)(I), 1163(b), "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3102"},"text":"119 Stat. 3102","children":[],"tail":", 3120.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd4fd7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd4fd8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd4fd9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796dd–1"},"text":"section 3796dd–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbd4fda-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1111/c/2/I"},"text":"Pub. L. 109–162, § 1111(c)(2)(I)","children":[],"tail":", struck out “and reflects consideration of the statewide strategy under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3753/a/1"},"text":"section 3753(a)(1) of this title","children":[],"tail":"” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1163/b"},"text":"Pub. L. 109–162, § 1163(b)","children":[],"tail":", substituted “section 3796dd(b)” for “section 3796dd(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cbd4fdb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cbd4fdc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1111/c/2/I"},"text":"section 1111(c)(2)(I) of Pub. L. 109–162","children":[],"tail":" applicable with respect to the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", and each fiscal year thereafter, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1111/d"},"text":"section 1111(d) of Pub. L. 109–162","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10151"},"text":"section 10151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
