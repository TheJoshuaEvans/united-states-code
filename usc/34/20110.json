{"tag":"section","attrib":{"id":"id4d1f1fa4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110"},"text":null,"children":[{"tag":"num","attrib":{"value":"20110"},"text":"§ 20110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1fa5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Director to establish rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may establish such rules, regulations, guidelines, and procedures as are necessary to carry out any function of the Director under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fa6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of sums under this subchapter shall keep such records as the Director shall prescribe, including records that fully disclose the amount and disposition by such recipient of such sums, the total cost of the undertaking for which such sums are used, and that portion of the cost of the undertaking supplied by other sources, and such other records as will facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fa7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access of Director to books and records for purpose of audit and examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall have access, for purpose of audit and examination, to any books, documents, papers, and records of the recipient of sums under this subchapter that, in the opinion of the Director, may be related to the expenditure of funds received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fa8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revealing research or statistical information; prohibition; immunity from legal proceedings; permission; admission of information as evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by Federal law, no officer or employee of the Federal Government, and no recipient of sums under this subchapter, shall use or reveal any research or statistical information furnished under this subchapter by any person and identifiable to any specific private person for any purpose other than the purpose for which such information was obtained in accordance with this subchapter. Such information, and any copy of such information, shall be immune from legal process and shall not, without the consent of the person furnishing such information, be admitted as evidence or used for any purpose in any action, suit, or other judicial, legislative, or administrative proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fa9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall on the ground of race, color, religion, national origin, handicap, or sex be excluded from participation in, denied the benefits of, subjected to discrimination under, or denied employment in connection with, any undertaking funded in whole or in part with sums made available under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1faa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with provisions; notice and hearing; power of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after reasonable notice and opportunity for a hearing on the record, the Director finds that a State has failed to comply substantially with any provision of this subchapter or a rule, regulation, guideline, or procedure issued under this subchapter, or an application submitted in accordance with this subchapter or the provisions of any other applicable law, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1fab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate payments to such State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend payments to such State until the Director is satisfied that such noncompliance has ended; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action as the Director deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, on ","children":[{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":", and on June 30 every two years thereafter, report to the President and to the Congress on the revenue derived from each source described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101"},"text":"section 20101 of this title","children":[],"tail":" and on the effectiveness of the activities supported under this subchapter. The Director may include in such report recommendations for legislation to improve this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1faf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20110/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity receiving sums made available under this subchapter for administrative purposes shall certify that such sums will not be used to supplant State or local funds, but will be used to increase the amount of such funds that would, in the absence of Federal funds, be made available for these purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f1fb0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1407"},"text":"Pub. L. 98–473, title II, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2176"},"text":"98 Stat. 2176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s48"},"text":"Pub. L. 99–646, § 48","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3605"},"text":"100 Stat. 3605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7123/b/10"},"text":"Pub. L. 100–690, title VII, § 7123(b)(10)","children":[],"tail":"–(14), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4421"},"text":"102 Stat. 4421","children":[],"tail":", 4422; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXIII"},"text":"Pub. L. 103–322, title XXIII","children":[],"tail":", §§ 230206, 230207, "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2080"},"text":"108 Stat. 2080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/9"},"text":"Pub. L. 104–294, title VI, § 604(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3507"},"text":"110 Stat. 3507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f1fb1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1f1fb2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d1f1fb3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (h), was in the original “this Act”, and was translated as reading “this chapter”, meaning chapter XIV of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", to reflect the probable intent of Congress, and subsequently was translated as “this subchapter” after chapter 112 of Title 42, The Public Health and Welfare, was editorially reclassified as this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1f1fb4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10604"},"text":"section 10604 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d1f1fb5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s230207"},"text":"Pub. L. 103–322, § 230207","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s230207"},"text":"Pub. L. 103–322, § 230207","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":", substituted “and on June 30 every two years thereafter” for “and on December 31 every 2 years thereafter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s230206"},"text":"Pub. L. 103–322, § 230206","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7123/b/10"},"text":"Pub. L. 100–690, § 7123(b)(10)","children":[],"tail":", substituted “Director” for “Attorney General” in two places and “under this chapter” for “under this chapter and may delegate to any officer or employee of the Department of Justice any such function as the Attorney General deems appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7123/b/11"},"text":"Pub. L. 100–690, § 7123(b)(11)","children":[],"tail":", substituted “Director” for “Attorney General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7123/b/12"},"text":"Pub. L. 100–690, § 7123(b)(12)","children":[],"tail":", which directed substitution of “Director” for “Attorney General or any duly authorized representative of the Attorney General”, was executed by making substitution in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7123/b/13"},"text":"Pub. L. 100–690, § 7123(b)(13)","children":[],"tail":", substituted “Director” for “Attorney General” two places in introductory provisions and in pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7123/b/14"},"text":"Pub. L. 100–690, § 7123(b)(14)","children":[],"tail":", substituted “Director” for “Attorney General” in two places and “on "},{"tag":"date","attrib":{"date":"1990-12-31"},"text":"December 31, 1990","children":[],"tail":", and on December 31 every 2 years thereafter” for “no later than "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" redesignated subsec. (h) as (g) and substituted “1402”, which was translated as “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10601"},"text":"section 10601 of this title","children":[],"tail":"” for “1302”, which had been editorially translated as “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10601"},"text":"section 10601 of this title","children":[],"tail":"”, thereby requiring no change in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d1f1fb6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d1f1fb7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d1f1fb8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" not applicable with respect to a State compensation program that was an eligible State crime victim compensation program on "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", until "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7129"},"text":"section 7129 of Pub. L. 100–690","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101"},"text":"section 20101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
