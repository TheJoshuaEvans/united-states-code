{"tag":"section","attrib":{"id":"id4cf8f9d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121"},"text":null,"children":[{"tag":"num","attrib":{"value":"12121"},"text":"§ 12121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force on prison construction standardization and techniques","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf8f9d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Corrections shall, subject to availability of appropriations, establish a task force composed of Federal, State, and local officials expert in prison construction, and of at least an equal number of engineers, architects, and construction experts from the private sector with expertise in prison design and construction, including the use of cost-cutting construction standardization techniques and cost-cutting new building materials and technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f9da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall work in close cooperation and communication with other State and local officials responsible for prison construction in their localities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f9db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The task force shall work to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8f9dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and recommend standardized construction plans and techniques for prison and prison component construction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f9dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and recommend new construction technologies, techniques, and materials,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to reduce prison construction costs at the Federal, State, and local levels and make such construction more efficient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f9de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The task force shall disseminate information described in subsection (c) to State and local officials involved in prison construction, through written reports and meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f9df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion and evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The task force shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8f9e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work to promote the implementation of cost-saving efforts at the Federal, State, and local levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f9e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and advise on the results and effectiveness of such cost-saving efforts as adopted, broadly disseminating information on the results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f9e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12121/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent feasible, certify the effectiveness of the cost-savings efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf8f9e3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20406"},"text":"Pub. L. 103–322, title II, § 20406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1826"},"text":"108 Stat. 1826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf8f9e4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf8f9e5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf8f9e6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13721"},"text":"section 13721 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
