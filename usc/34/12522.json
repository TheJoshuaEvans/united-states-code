{"tag":"section","attrib":{"id":"id4d1338b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12522"},"text":null,"children":[{"tag":"num","attrib":{"value":"12522"},"text":"§ 12522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced penalties for illegal drug use in Federal prisons and for smuggling drugs into Federal prisons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1338b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the Federal Government that the use or distribution of illegal drugs in the Nation’s Federal prisons will not be tolerated and that such crimes shall be prosecuted to the fullest extent of the law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1338b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sentencing guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to its authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of title 28","children":[],"tail":", the United States Sentencing Commission shall amend its sentencing guidelines to appropriately enhance the penalty for a person convicted of an offense—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1338b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s844"},"text":"section 844 of title 21","children":[],"tail":" involving simple possession of a controlled substance within a Federal prison or other Federal detention facility; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1338b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s841/b"},"text":"section 841(b) of title 21","children":[],"tail":" involving the smuggling of a controlled substance into a Federal prison or other Federal detention facility or the distribution or intended distribution of a controlled substance within a Federal prison or other Federal detention facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1338b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No probation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, the court shall not sentence a person convicted of an offense described in subsection (b) to probation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1338b7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIX/s90103"},"text":"Pub. L. 103–322, title IX, § 90103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1987"},"text":"108 Stat. 1987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1338b8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1338b9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1338ba-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14052"},"text":"section 14052 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90103"},"text":"section 90103 of Pub. L. 103–322","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s90103"},"text":"section 90103 of Pub. L. 103–322","children":[],"tail":" is also listed in a table relating to sentencing guidelines set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
