{"tag":"section","attrib":{"id":"id4d66b06f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60909"},"text":null,"children":[{"tag":"num","attrib":{"value":"60909"},"text":"§ 60909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case that more than one agency conducted the initial investigation of a cold case murder, each agency shall coordinate their case file review or full reinvestigation such that there is only one joint case file review or full reinvestigation occurring at a time in compliance with section 60901(f) or 60903(d) of this title, as applicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d66b070-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s10"},"text":"Pub. L. 117–164, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1361"},"text":"136 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
