{"tag":"section","attrib":{"id":"id4d36ee91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962"},"text":null,"children":[{"tag":"num","attrib":{"value":"20962"},"text":"§ 20962.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools SAFE Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36ee92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Schools Safely Acquiring Faculty Excellence Act of 2006”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General of the United States shall, upon request of the chief executive officer of a State, conduct fingerprint-based checks of the national crime information databases (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534/f/3/A"},"text":"section 534(f)(3)(A) of title 28","children":[],"tail":") pursuant to a request submitted by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a child welfare agency for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d36ee95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a background check required under section 471(a)(20) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s671/a/20"},"text":"42 U.S.C. 671(a)(20)","children":[],"tail":"] on individuals under consideration as prospective foster or adoptive parents; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d36ee96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an investigation relating to an incident of abuse or neglect of a minor; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private or public elementary school, a private or public secondary school, a local educational agency, or State educational agency in that State, on individuals employed by, under consideration for employment by, or otherwise in a position in which the individual would work with or around children in the school or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fingerprint-based check","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where possible, the check shall include a fingerprint-based check of State criminal history databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General and the States may charge any applicable fees for the checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual having information derived as a result of a check under subsection (b) may release that information only to appropriate officers of child welfare agencies, public or private elementary or secondary schools, or educational agencies or other persons authorized by law to receive that information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who knowingly exceeds the authority in subsection (b), or knowingly releases information in violation of subsection (e), shall be imprisoned not more than 10 years or fined under title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child welfare agency defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “child welfare agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or local agency responsible for administering the plan under part B or part E of title IV of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s620"},"text":"42 U.S.C. 620","children":[],"tail":" et seq., 670 et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other public agency, or any other private agency under contract with the State or local agency responsible for administering the plan under part B or part E of title IV of the Social Security Act, that is responsible for the licensing or approval of foster or adoptive parents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20962/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of education terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “elementary school”, “local educational agency”, “secondary school”, and “State educational agency” have the meanings given to those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36eea0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s153"},"text":"Pub. L. 109–248, title I, § 153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/610"},"text":"120 Stat. 610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/b"},"text":"Pub. L. 114–95, title IX, § 9215(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2166"},"text":"129 Stat. 2166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36eea1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36eea2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d36eea3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Parts B and E of title IV of the Act are classified generally to part B (§ 620 et seq.) and part E (§ 670 et seq.), respectively, of subchapter IV of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36eea4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/s153"},"text":"section 153 of Pub. L. 109–248","children":[],"tail":". Subsec. (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/s153"},"text":"section 153 of Pub. L. 109–248","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16962"},"text":"section 16962 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d36eea5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d36eea6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d36eea7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
