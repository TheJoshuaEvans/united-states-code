{"tag":"section","attrib":{"id":"id4d5d12e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103"},"text":null,"children":[{"tag":"num","attrib":{"value":"50103"},"text":"§ 50103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d12e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter authorizes the use of Federal law enforcement personnel to investigate violations of criminal law other than violations with respect to which investigation is authorized by other provisions of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d12e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the Attorney General or the Federal law enforcement community to exercise any direction, supervision, or control over any police force or other criminal justice agency of an applicant for Federal law enforcement assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d12e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Racial balance in criminal justice agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the Attorney General or the Federal law enforcement community—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d12ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to condition the availability or amount of Federal law enforcement assistance upon the adoption by an applicant for such assistance of, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d12eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deny or discontinue such assistance upon the failure of such applicant to adopt,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"a percentage ratio, quota system, or other program to achieve racial balance in any criminal justice agency of such applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d12ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal supplantation of State funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided under this chapter may be used to supplant State or local funds that would otherwise be made available for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d12ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorities unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to limit any authority to provide emergency assistance otherwise provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d12ee-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609O"},"text":"Pub. L. 98–473, title II, § 609O","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2105"},"text":"98 Stat. 2105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d12ef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d12f0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d12f1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10503"},"text":"section 10503 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
