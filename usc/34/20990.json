{"tag":"section","attrib":{"id":"id4d395e64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990"},"text":null,"children":[{"tag":"num","attrib":{"value":"20990"},"text":"§ 20990.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National registry of substantiated cases of child abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395e65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, in consultation with the Attorney General, shall create a national registry of substantiated cases of child abuse or neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information in the registry described in subsection (a) shall be supplied by States and Indian tribes, or, at the option of a State, by political subdivisions of such State, to the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The registry described in subsection (a) shall collect in a central electronic registry information on persons reported to a State, Indian tribe, or political subdivision of a State as perpetrators of a substantiated case of child abuse or neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395e6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information to be provided to the Secretary of Health and Human Services under this section shall relate to substantiated reports of child abuse or neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State, Indian tribe, or political subdivision of a State has an electronic register of cases of child abuse or neglect equivalent to the registry established under this section that it maintains pursuant to a requirement or authorization under any other provision of law, the information provided to the Secretary of Health and Human Services under this section shall be coextensive with that in such register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information provided to the Secretary of Health and Human Services under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395e6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in a standardized electronic form determined by the Secretary of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain case-specific identifying information that is limited to the name of the perpetrator and the nature of the substantiated case of child abuse or neglect, and that complies with clauses (viii) and (ix) of section 5106a(b)(2)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002194"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002194"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not be construed to require a State, Indian tribe, or political subdivision of a State to modify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an equivalent register of cases of child abuse or neglect that it maintains pursuant to a requirement or authorization under any other provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other record relating to child abuse or neglect, regardless of whether the report of abuse or neglect was substantiated, unsubstantiated, or determined to be unfounded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information contained in the national registry shall only be accessible to any Federal, State, Indian tribe, or local government entity, or any agent of such entities, that has a need for such information in order to carry out its responsibilities under law to protect children from child abuse and neglect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall establish standards for the dissemination of information in the national registry of substantiated cases of child abuse or neglect. Such standards shall comply with clauses (viii) and (ix) of section 5106a(b)(2)(A) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 42."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e75-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e76-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall conduct a study on the feasibility of establishing data collection standards for a national child abuse and neglect registry with recommendations and findings concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395e77-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs and benefits of such data collection standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e78-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection standards currently employed by each State, Indian tribe, or political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e79-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection standards that should be considered to establish a model of promising practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e7a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a due process procedure for a national registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e7b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", the Secretary of Homeland Security shall submit to the Committees on the Judiciary in the House of Representatives and the United States Senate and the Senate Committee on Health, Education, Labor and Pensions and the House Committee on Education and the Workforce a report containing the recommendations and findings of the study on data collection standards for a national child abuse registry authorized under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e7c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20990/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $500,000 for the period of fiscal years 2006 and 2007 to carry out the study required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395e7d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s633"},"text":"Pub. L. 109–248, title VI, § 633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/642"},"text":"120 Stat. 642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395e7e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395e7f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d395e80-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b/2/A"},"text":"Section 5106a(b)(2)(A) of title 42","children":[],"tail":", referred to in subsecs. (c)(2)(B) and (f), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5106a/b/2/B"},"text":"section 5106a(b)(2)(B) of title 42","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI/s115/c/2/A"},"text":"Pub. L. 111–320, title I, § 115(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3469"},"text":"124 Stat. 3469","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395e81-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16990"},"text":"section 16990 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
