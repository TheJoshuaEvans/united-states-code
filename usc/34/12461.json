{"tag":"section","attrib":{"id":"id4d099bda-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461"},"text":null,"children":[{"tag":"num","attrib":{"value":"12461"},"text":"§ 12461.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099bdb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former United States Advisory Board on Child Abuse suggests that domestic violence may be the single major precursor to child abuse and neglect fatalities in this country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bdc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies suggest that as many as 10,000,000 children witness domestic violence every year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bdd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies suggest that among children and teenagers, recent exposure to violence in the home was a significant factor in predicting a child’s violent behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bde-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a study by the Nurse-Family Partnership found that children whose parents did not participate in home visitation programs that provided coaching in parenting skills, advice and support, were almost 5 times more likely to be abused in their first 2 years of life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099bdf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child’s exposure to domestic violence seems to pose the greatest independent risk for being the victim of any act of partner violence as an adult;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099be0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children exposed to domestic violence are more likely to believe that using violence is an effective means of getting one’s needs met and managing conflict in close relationships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099be1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" children exposed to abusive parenting, harsh or erratic discipline, or domestic violence are at increased risk for juvenile crime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099be2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12461/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a national survey of more than 6,000 American families, 50 percent of men who frequently assaulted their wives also frequently abused their children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d099be3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41301"},"text":"Pub. L. 103–322, title IV, § 41301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIV/s401"},"text":"Pub. L. 109–162, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3017"},"text":"119 Stat. 3017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d099be4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d099be5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d099be6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043d"},"text":"section 14043d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
