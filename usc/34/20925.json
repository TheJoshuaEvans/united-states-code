{"tag":"section","attrib":{"id":"id4d36ed7e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925"},"text":null,"children":[{"tag":"num","attrib":{"value":"20925"},"text":"§ 20925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and availability of registry management and website software","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36ed7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to develop and support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall, in consultation with the jurisdictions, develop and support software to enable jurisdictions to establish and operate uniform sex offender registries and Internet sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ed80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The software should facilitate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ed81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediate exchange of information among jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ed82-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public access over the Internet to appropriate information, including the number of registered sex offenders in each jurisdiction on a current basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ed83-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full compliance with the requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ed84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication of information to community notification program participants as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20923"},"text":"section 20923 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ed85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20925/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make the first complete edition of this software available to jurisdictions within 2 years of ","children":[{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36ed86-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s123"},"text":"Pub. L. 109–248, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/598"},"text":"120 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36ed87-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36ed88-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d36ed89-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b)(3), was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/590"},"text":"120 Stat. 590","children":[],"tail":", known as the Sex Offender Registration and Notification Act. For complete classification of title I to the Code, see Short Title of 2006 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36ed8a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16923"},"text":"section 16923 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
