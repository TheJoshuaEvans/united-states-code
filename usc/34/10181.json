{"tag":"section","attrib":{"id":"id4ca5829e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181"},"text":null,"children":[{"tag":"num","attrib":{"value":"10181"},"text":"§ 10181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca5829f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No grant may be made under this part unless an application has been submitted to the Director in which the applicant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth a program or project which is eligible for funding pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10171"},"text":"section 10171 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the services to be provided, performance goals, and the manner in which the program is to be carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the method to be used to evaluate the program or project in order to determine its impact and effectiveness in achieving the stated goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to conduct such evaluation according to the procedures and terms established by the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10181/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each applicant for funds under this part shall certify that its program or project meets all the applicable requirements of this section, that all the applicable information contained in the application is correct, and that the applicant will comply with all the applicable provisions of this part and all other applicable Federal laws. Such certification shall be made in a form acceptable to the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca582a5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s517"},"text":"Pub. L. 90–351, title I, § 517","children":[],"tail":", formerly § 513, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6091/a"},"text":"Pub. L. 100–690, title VI, § 6091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4336"},"text":"102 Stat. 4336","children":[],"tail":"; renumbered § 517 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXVIII/s1801/a/4"},"text":"Pub. L. 101–647, title XVIII, § 1801(a)(4)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":"