{"tag":"section","attrib":{"id":"id4ca582ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10182"},"text":null,"children":[{"tag":"num","attrib":{"value":"10182"},"text":"§ 10182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of award","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Bureau may provide financial aid and assistance to programs or projects under this part for a period of not to exceed 4 years. Grants made pursuant to this part may be extended or renewed by the Bureau for an additional period of up to 2 years if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10182/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the program or project indicates that it has been effective in achieving the stated goals or offers the potential for improving the functioning of the criminal justice system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10182/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant that conducts such program or project agrees to provide at least one-half of the total cost of such program or project from any source of funds, including Federal grants, available to the eligible jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca582b1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s518"},"text":"Pub. L. 90–351, title I, § 518","children":[],"tail":", formerly § 514, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6091/a"},"text":"Pub. L. 100–690, title VI, § 6091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4336"},"text":"102 Stat. 4336","children":[],"tail":"; renumbered § 518 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXVIII/s1801/a/5"},"text":"Pub. L. 101–647, title XVIII, § 1801(a)(5)","children":[],"tail":", (6), "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4847"},"text":"104 Stat. 4847","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ca582b2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ca582b3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ca582b4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3764"},"text":"section 3764 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ca582b5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s518"},"text":"section 518 of Pub. L. 90–351","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag"