{"tag":"section","attrib":{"id":"id4cc6ecda-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453"},"text":null,"children":[{"tag":"num","attrib":{"value":"10453"},"text":"§ 10453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Deputy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc6ecdb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Office on Violence Against Women a Deputy Director for Tribal Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc6ecdc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc6ecdd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002038"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002038"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Deputy Director shall under the guidance and authority of the Director of the Office on Violence Against Women—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc6ecde-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee and manage the administration of grants to and contracts with Indian tribes, tribal courts, tribal organizations, or tribal nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ecdf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that, if a grant under this Act or a contract pursuant to such a grant is made to an organization to perform services that benefit more than 1 Indian tribe, the approval of each Indian tribe to be benefitted shall be a prerequisite to the making of the grant or letting of the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate development of Federal policy, protocols, and guidelines on matters relating to violence against Indian women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Director of the Office on Violence Against Women concerning policies, legislation, implementation of laws, and other issues relating to violence against Indian women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Office on Violence Against Women in the annual consultations under section 20126 ","children":[{"tag":"ref","attrib":{"idref":"fn002039"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, coordination, and support to other offices and bureaus in the Department of Justice to develop policy and to enforce Federal laws relating to violence against Indian women, including through litigation of civil and criminal actions relating to those laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a liaison with the judicial branches of Federal, State, and tribal governments on matters relating to violence against Indian women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support enforcement of tribal protection orders and implementation of full faith and credit educational projects and comity agreements between Indian tribes and States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ece6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that adequate tribal technical assistance that is developed and provided by entities having expertise in tribal law, customary practices, and Federal Indian law is made available to Indian tribes, tribal courts, tribal organizations, and tribal nonprofit organizations for all programs relating to violence against Indian women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc6ece7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc6ece8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Director shall ensure that a portion of the tribal set-aside funds from any grant awarded under this Act, the Violence Against Women Act of 1994 (title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":"), or the Violence Against Women Act of 2000 (division B of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Public Law 106–386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/1491"},"text":"114 Stat. 1491","children":[],"tail":") is used to enhance the capacity of Indian tribes to address the safety of Indian women."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ece9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Deputy Director shall ensure that some portion of the tribal set-aside funds from any grant made under this subchapter is used to hold offenders accountable through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc6ecea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancement of the response of Indian tribes to crimes of domestic violence, dating violence, sexual assault, and stalking against Indian women, including legal services for victims and Indian-specific offender programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6eceb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and maintenance of tribal domestic violence shelters or programs for battered Indian women, including sexual assault services, that are based upon the unique circumstances of the Indian women to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ecec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of tribal educational awareness programs and materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6eced-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for customary tribal activities to strengthen the intolerance of an Indian tribe to violence against Indian women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ecee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10453/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development, implementation, and maintenance of tribal electronic databases for tribal protection order registries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc6ecef-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2016"},"text":"Pub. L. 90–351, title I, § 2016","children":[],"tail":", formerly § 2008, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIX/s907"},"text":"Pub. L. 109–162, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3082"},"text":"119 Stat. 3082","children":[],"tail":"; renumbered § 2016 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s7/a/1/B"},"text":"Pub. L. 109–271, § 7(a)(1)(B)","children":[],"tail":", (C), (4), "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/763"},"text":"120 Stat. 763","children":[],"tail":", 764.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc6ecf0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc6ecf1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cc6ecf2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (b)(1)(B) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/197"},"text":"82 Stat. 197","children":[],"tail":", known as the Omnibus Crime Control and Safe Streets Act of 1968. For complete classification of this Act to the Code, see Short Title of 1968 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20126"},"text":"Section 20126 of this title","children":[],"tail":", referred to in subsec. (b)(1)(E), was in the original “section 903” and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s903"},"text":"section 903 of Pub. L. 109–162","children":[],"tail":", to reflect the probable intent of Congress, because there is no "},{"tag":"ref","attrib":{"href":"/us/pl/90/351/s903"},"text":"section 903 of Pub. L. 90–351","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 1994, referred to in subsec. (c)(1), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 2000, referred to in subsec. (c)(1), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1491"},"text":"114 Stat. 1491","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2000 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc6ecf3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–11"},"text":"section 3796gg–11 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc6ecf4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271/s7/a/4"},"text":"Pub. L. 109–271, § 7(a)(4)","children":[],"tail":", inserted “that is developed and provided by entities having expertise in tribal law, customary practices, and Federal Indian law” after “technical assistance”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cc6ecf5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4cc6ecf6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until the beginning of fiscal year 2007, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s4"},"text":"section 4 of Pub. L. 109–162","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10261"},"text":"section 10261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
