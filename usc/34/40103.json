te","attrib":{"topic":"miscellaneous","id":"id4d4a0034-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Violent Crime Reduction Trust Fund To Fund Activities Authorized by the Brady Handgun Violence Prevention Act and the National Child Protection Act of 1993","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For appropriations for amounts authorized in subsec. (b) of this section from the Violent Crime Reduction Trust Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12631"},"text":"section 12631 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s210603/a"},"text":"section 210603(a) of Pub. L. 103–322","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
