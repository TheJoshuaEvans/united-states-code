{"tag":"section","attrib":{"id":"id4d4a0022-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103"},"text":null,"children":[{"tag":"num","attrib":{"value":"40103"},"text":"§ 40103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for improvement of child abuse crime information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4a0023-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4a0024-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding grants for improvement of child abuse crime information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4a0025-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Attorney General shall, subject to appropriations and with preference to States that, as of ","children":[{"tag":"date","attrib":{"date":"1993-12-20"},"text":"December 20, 1993","children":[],"tail":", have in computerized criminal history files the lowest percentages of charges and dispositions of identifiable child abuse cases, make a grant to each State to be used—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4a0026-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the computerization of criminal history files for the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4a0027-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the improvement of existing computerized criminal history files for the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4a0028-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve accessibility to the national criminal history background check system for the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4a0029-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the State in the transmittal of criminal records to, or the indexing of criminal history record in, the national criminal history background check system for the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4a002a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the State in paying all or part of the cost to the State of conducting background checks on persons who are employed by or volunteer with a public, not-for-profit, or voluntary qualified entity to reduce the amount of fees charged for such background checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a002b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated for grants under paragraph (1) a total of $20,000,000 for fiscal years 1999, 2000, 2001, and 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4a002c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding State funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective 1 year after ","children":[{"tag":"date","attrib":{"date":"1993-12-20"},"text":"December 20, 1993","children":[],"tail":", the Attorney General may reduce, by up to 10 percent, the allocation to a State for a fiscal year under title I of the Omnibus Crime Control and Safe Streets Act of 1968 ["},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"34 U.S.C. 10101","children":[],"tail":" et seq.] that is not in compliance with the requirements of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4a002d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/209/s4"},"text":"Pub. L. 103–209, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2493"},"text":"107 Stat. 2493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320928/d"},"text":"Pub. L. 103–322, title XXXII, § 320928(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2132"},"text":"108 Stat. 2132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/251/tII/s222/c"},"text":"Pub. L. 105–251, title II, § 222(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-09"},"text":"Oct. 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1885"},"text":"112 Stat. 1885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4a002e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4a002f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d4a0030-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Omnibus Crime Control and Safe Streets Act of 1968, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/197"},"text":"82 Stat. 197","children":[],"tail":". Title I of the Act is classified principally to chapter 101 (§ 10101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title of 1968 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4a0031-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","childre