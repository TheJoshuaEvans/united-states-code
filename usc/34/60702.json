{"tag":"section","attrib":{"id":"id4d66b024-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60702"},"text":null,"children":[{"tag":"num","attrib":{"value":"60702"},"text":"§ 60702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General of the United States is authorized to establish and carry out a program, to be known as the “Project Safe Neighborhoods Block Grant Program” within the Office of Justice Programs at the Department of Justice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d66b025-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/185/s3"},"text":"Pub. L. 115–185, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-18"},"text":"June 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1485"},"text":"132 Stat. 1485","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
