{"tag":"section","attrib":{"id":"id4c9e5626-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10141"},"text":null,"children":[{"tag":"num","attrib":{"value":"10141"},"text":"§ 10141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Bureau of Justice Assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c9e5627-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the Department of Justice, under the general authority of the Attorney General, a Bureau of Justice Assistance (hereafter in this subchapter referred to as the “Bureau”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c9e5628-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau shall be headed by a Director (hereafter in this subchapter referred to as the “Director”) who shall be appointed by the President. The Director shall report to the Attorney General through the Assistant Attorney General. The Director shall have final authority for all grants, cooperative agreements, and contracts awarded by the Bureau. The Director shall not engage in any employment other than that of serving as the Director, nor shall the Director hold any office in, or act in any capacity for, any organization, agency, or institution with which the Bureau makes any contract or other arrangement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c9e5629-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s401"},"text":"Pub. L. 90–351, title I, § 401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6091/a"},"text":"Pub. L. 100–690, title VI, § 6091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4328"},"text":"102 Stat. 4328","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/h/2"},"text":"Pub. L. 112–166, § 2(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1285"},"text":"126 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c9e562a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c9e562b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c9e562c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3741"},"text":"section 3741 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4c9e562d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s401"},"text":"section 401 of Pub. L. 90–351","children":[],"tail":", title I, as added "},{"tag":"ref","attrib":{"href":"/