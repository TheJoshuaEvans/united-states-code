{"tag":"section","attrib":{"id":"id4cda00bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753"},"text":null,"children":[{"tag":"num","attrib":{"value":"10753"},"text":"§ 10753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cda00bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10751"},"text":"section 10751 of this title","children":[],"tail":" to carry out the projects described in the application submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10752"},"text":"section 10752 of this title","children":[],"tail":" upon determining that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda00bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application is consistent with the requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda00be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the approval of the application, the Attorney General has made an affirmative finding in writing that the proposed project has been reviewed in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cda00bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10752"},"text":"section 10752 of this title","children":[],"tail":" shall be considered approved, in whole or in part, by the Attorney General not later than 90 days after first received, unless the Attorney General informs the applicant of specific reasons for disapproval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cda00c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds received under this subchapter shall not be used for land acquisition or construction projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cda00c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval notice and reconsideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may not disapprove any application without first affording the applicant reasonable notice and an opportunity for reconsideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cda00c2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3053"},"text":"Pub. L. 90–351, title I, § 3053","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/281/s2/a"},"text":"Pub. L. 116–281, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3384"},"text":"134 Stat. 3384","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
