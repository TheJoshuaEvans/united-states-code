{"tag":"section","attrib":{"id":"id4d029700-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321"},"text":null,"children":[{"tag":"num","attrib":{"value":"12321"},"text":"§ 12321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of abused person’s address","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d029701-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the United States Postal Service shall promulgate regulations to secure the confidentiality of domestic violence shelters and abused persons’ addresses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d029702-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations under subsection (a) shall require—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d029703-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual, the presentation to an appropriate postal official of a valid, outstanding protection order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e0f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a domestic violence shelter, the presentation to an appropriate postal authority of proof from a State domestic violence coalition that meets the requirements of section 10410 ","children":[{"tag":"ref","attrib":{"idref":"fn002107"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 42 verifying that the organization is a domestic violence shelter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e0f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure for certain purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations under subsection (a) shall not prohibit the disclosure of addresses to State or Federal agencies for legitimate law enforcement or other governmental purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e0f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing compilations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compilations of addresses existing at the time at which order is presented to an appropriate postal official shall be excluded from the scope of the regulations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d04e0f7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40281"},"text":"Pub. L. 103–322, title IV, § 40281","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1938"},"text":"108 Stat. 1938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d04e0f8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d04e0f9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d04e0fa-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10410"},"text":"Section 10410 of title 42","children":[],"tail":", referred to in subsec. (b)(2), was generally amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3497"},"text":"124 Stat. 3497","children":[],"tail":", and, as so amended, no longer contains provisions relating to grants for State domestic violence coalitions. See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10411"},"text":"section 10411 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d04e0fb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13951"},"text":"section 13951 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
