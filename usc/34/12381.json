{"tag":"section","attrib":{"id":"id4d0751d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381"},"text":null,"children":[{"tag":"num","attrib":{"value":"12381"},"text":"§ 12381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of circuit studies; education and training grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0751d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to gain a better understanding of the nature and the extent of gender bias in the Federal courts, the circuit judicial councils are encouraged to conduct studies of the instances, if any, of gender bias in their respective circuits and to implement recommended reforms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0751d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters for examination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The studies under subsection (a) may include an examination of the effects of gender on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0751d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment of litigants, witnesses, attorneys, jurors, and judges in the courts, including before magistrate and bankruptcy judges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interpretation and application of the law, both civil and criminal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment of defendants in criminal cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treatment of victims of violent crimes in judicial proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sentencing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sentencing alternatives and the nature of supervision of probation and parole;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointments to committees of the Judicial Conference and the courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case management and court sponsored alternative dispute resolution programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection, retention, promotion, and treatment of employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointment of arbitrators, experts, and special masters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the admissibility of the victim’s past sexual history in civil and criminal cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aspects of the topics listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12372"},"text":"section 12372 of this title","children":[],"tail":" that pertain to issues within the jurisdiction of the Federal courts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0751e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrative Office of the United States Courts shall act as a clearinghouse to disseminate any reports and materials issued by the gender bias task forces under subsection (a) and to respond to requests for such reports and materials. The gender bias task forces shall provide the Administrative Office of the Courts of the United States ","children":[{"tag":"ref","attrib":{"idref":"fn002117"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Administrative Office of the United States Courts”."}],"tail":" with their reports and related material."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0751e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12381/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing education and training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Judicial Center, in carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s620/b/3"},"text":"section 620(b)(3) of title 28","children":[],"tail":", shall include in the educational programs it prepares, including the training programs for newly appointed judges, information on the aspects of the topics listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12372"},"text":"section 12372 of this title","children":[],"tail":" that pertain to issues within the jurisdiction of the Federal courts, and shall prepare materials necessary to implement this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0751e3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40421"},"text":"Pub. L. 103–322, title IV, § 40421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1944"},"text":"108 Stat. 1944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tIV/s1406/b/1"},"text":"Pub. L. 106–386, div. B, title IV, § 1406(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1516"},"text":"114 Stat. 1516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0751e4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0751e5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0751e6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14001"},"text":"section 14001 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d0751e7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":" amended heading and text of subsec. (d) generally, substituting provisions relating to continuing education and training programs for provisions relating to model programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
