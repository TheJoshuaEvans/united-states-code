{"tag":"section","attrib":{"id":"id4ccba89d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10494"},"text":null,"children":[{"tag":"num","attrib":{"value":"10494"},"text":"§ 10494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A law enforcement agency or organization desiring to receive a grant under this subchapter shall submit to the Attorney General an application at such time, in such manner, and containing or accompanied by such information as the Attorney General may reasonably require. Such application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba89e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10494/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the law enforcement agency shall match all Federal funds with an equal amount of cash or in-kind goods or services from other non-Federal sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba89f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10494/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a statement from the highest ranking law enforcement official from the State or locality or from the highest ranking official from the organization applying for the grant that attests to the need and intended use of services to be provided with grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba8a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10494/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that the Attorney General or the Comptroller General of the United States shall have access to all records related to the receipt and use of grant funds received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba8a1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2304"},"text":"Pub. L. 90–351, title I, § 2304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210201/a/3"},"text":"Pub. L. 103–322, title XXI, § 210201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2063"},"text":"108 Stat. 2063","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba8a2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba8a3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba8a4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796jj–3"},"text":"section 3796jj–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
