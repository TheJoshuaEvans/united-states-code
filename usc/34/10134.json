{"tag":"section","attrib":{"id":"id4c9e561b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10134"},"text":null,"children":[{"tag":"num","attrib":{"value":"10134"},"text":"§ 10134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Data collected by the Bureau shall be used only for statistical or research purposes, and shall be gathered in a manner that precludes their use for law enforcement or any purpose relating to a private person or public agency other than statistical or research purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4c9e561c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s304"},"text":"Pub. L. 90–351, title I, § 304","children":[],"tail":", formerly § 305, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1179"},"text":"93 Stat. 1179","children":[],"tail":"; renumbered § 304, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s605/d"},"text":"Pub. L. 98–473, title II, § 605(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2080"},"text":"98 Stat. 2080","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1115/b"},"text":"Pub. L. 109–162, title XI, § 1115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3104"},"text":"119 Stat. 3104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c9e561d-5dcd-1