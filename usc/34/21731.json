{"tag":"section","attrib":{"id":"id4d3e19e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21731"},"text":null,"children":[{"tag":"num","attrib":{"value":"21731"},"text":"§ 21731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3e19ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the collection of statistical data under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21722/a/1"},"text":"section 21722(a)(1) of this title","children":[],"tail":" begins and once each year thereafter, the Director of the Office for Victims of Crime shall submit a report to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives that addresses, to the extent data are available, the nature, extent, and amount of funding under the Victims of Crime Act of 1984 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10601"},"text":"42 U.S.C. 10601","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002205"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002205"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for victims of crime who are elders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3e19ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21731/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of victims’ assistance, victims’ compensation, and discretionary grants under which elder abuse victims (including elder victims of financial abuse, financial exploitation, and fraud) received assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21731/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for improving services for victims of elder abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3e19ee-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIII/s302"},"text":"Pub. L. 115–70, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1212"},"text":"131 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d3e19ef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d3e19f0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d3e19f1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Victims of Crime Act of 1984, referred to in subsec. (a), is chapter XIV of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2170"},"text":"98 Stat. 2170","children":[],"tail":", which was classified principally to chapter 112 (§ 10601 et seq.) of Title 42, The Public Health and Welfare, prior to editorial reclassification as chapter 201 (§ 20101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title of 1984 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
