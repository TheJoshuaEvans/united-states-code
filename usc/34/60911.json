{"tag":"section","attrib":{"id":"id4d66b073-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911"},"text":null,"children":[{"tag":"num","attrib":{"value":"60911"},"text":"§ 60911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66b074-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “designated person” means an immediate family member or someone similarly situated, as defined by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b075-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “immediate family member” means a parent, parent-in-law, grandparent, grandparent-in-law, sibling, spouse, child, or step-child of a murder victim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b076-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “victim” means a natural person who died as a result of a cold case murder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b077-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “murder” means any criminal offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1111/a"},"text":"section 1111(a) of title 18","children":[],"tail":" or any offense the elements of which are substantially identical to such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b078-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “agency” means a Federal law enforcement entity with jurisdiction to engage in the detection, investigation, or prosecution of a cold case murder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b079-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “cold case murder” means a murder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d66b07a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed more than three years prior to the date of an application by a designated person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901/a"},"text":"section 60901(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b07b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" previously investigated by a Federal law enforcement entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b07c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which all probative investigative leads have been exhausted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b07d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60911/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which no likely perpetrator has been identified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b07e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s12"},"text":"Pub. L. 117–164, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1361"},"text":"136 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
