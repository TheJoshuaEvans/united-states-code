{"tag":"section","attrib":{"id":"id4cbfc242-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10425"},"text":null,"children":[{"tag":"num","attrib":{"value":"10425"},"text":"§ 10425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State that receives a grant under this subchapter shall submit to the Attorney General an evaluation not later than March 1 of each year in such form and containing such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cbfc243-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1905"},"text":"Pub. L. 90–351, title I, § 1905","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s32101/a/3"},"text":"Pub. L. 103–322, title III, § 32101(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1900"},"text":"108 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc244-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc245-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc246-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ff–4"},"text":"sectio