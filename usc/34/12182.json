{"tag":"section","attrib":{"id":"id4cfb6ac0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182"},"text":null,"children":[{"tag":"num","attrib":{"value":"12182"},"text":"§ 12182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfb6ac1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this part as the “Secretary”) may, in accordance with this subpart, provide nonrefundable lines of credit to community development corporations for the establishment, maintenance or expansion of revolving loan funds to be utilized to finance projects intended to provide business and employment opportunities for low-income, unemployed, or underemployed individuals and to improve the quality of life in urban and rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6ac2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revolving loan funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6ac3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive assessment of applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under subsection (a) of this section, the Secretary shall establish and implement a competitive process for the solicitation and consideration of applications from eligible entities for lines of credit for the capitalization of revolving funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ac4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a line of credit under this subpart an applicant shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfb6ac5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a community development corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6ac6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit an application to the Secretary that shall include a strategic investment plan that identifies and describes the economic characteristics of the target area to be served, the types of business to be assisted and the impact of such assistance on low-income, underemployed, and unemployed individuals in the target area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6ac7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate previous experience in the development of low-income housing or community or business development projects in a low-income community and provide a record of achievement with respect to such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6ac8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have secured one or more commitments from local sources for contributions (either in cash or in kind, letters of credit or letters of commitment) in an amount that is at least equal to the amount requested in the application submitted under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ac9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12182/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of paragraph (2)(D), the Secretary may reduce local contributions to not less than 25 percent of the amount of the line of credit requested by the community development corporation if the Secretary determines such to be appropriate in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12186"},"text":"section 12186 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfb6aca-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31112"},"text":"Pub. L. 103–322, title III, § 31112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1882"},"text":"108 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfb6acb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfb6acc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfb6acd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13822"},"text":"section 13822 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
