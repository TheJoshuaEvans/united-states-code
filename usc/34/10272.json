{"tag":"section","attrib":{"id":"id4cb169c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10272"},"text":null,"children":[{"tag":"num","attrib":{"value":"10272"},"text":"§ 10272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Falsification or concealment of facts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whoever knowingly and willfully falsifies, conceals, or covers up by trick, scheme, or device, any material fact in any application for assistance submitted pursuant to this chapter or in any records required to be maintained pursuant to this chapter shall be subject to prosecution under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cb169c1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1102"},"text":"Pub. L. 90–351, title I, § 1102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1219"},"text":"93 Stat. 1219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb169c2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb169c3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb169c4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","chil