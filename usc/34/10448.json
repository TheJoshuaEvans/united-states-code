{"tag":"section","attrib":{"id":"id4cc47c7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448"},"text":null,"children":[{"tag":"num","attrib":{"value":"10448"},"text":"§ 10448.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General terms and conditions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc47c80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonmonetary assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the assistance provided under this subchapter, the Attorney General may request any Federal agency to use its authorities and the resources granted to it under Federal law (including personnel, equipment, supplies, facilities, and managerial, technical, and advisory services) in support of State, tribal, and local assistance efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47c81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 month after the end of each even-numbered fiscal year, the Attorney General shall submit to the Committee on the Judiciary of the House of Representatives and the Committee on the Judiciary of the Senate a report that includes, for each State and for each grantee Indian tribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc47c82-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of grants made and funds distributed under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c83-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the purposes for which those grants were provided and an evaluation of their progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statistical summary of persons served, detailing the nature of victimization, and providing data on age, sex, relationship of victim to offender, geographic distribution, race, ethnicity, language, and disability, and the membership of persons served in any underserved population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc47c85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of programs funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc47c86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10448/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations or guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the Attorney General shall publish proposed regulations or guidelines implementing this subchapter. Not later than 180 days after "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the Attorney General shall publish final regulations or guidelines implementing this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc47c87-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2009"},"text":"Pub. L. 90–351, title I, § 2009","children":[],"tail":", formerly § 2004, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40121/a/3"},"text":"Pub. L. 103–322, title IV, § 40121(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1914"},"text":"108 Stat. 1914","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1103/b/4"},"text":"Pub. L. 106–386, div. B, title I, § 1103(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1497"},"text":"114 Stat. 1497","children":[],"tail":"; renumbered § 2009, "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIV/s402/2"},"text":"Pub. L. 107–273, div. A, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1789"},"text":"116 Stat. 1789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s310/b"},"text":"Pub. L. 108–405, title III, § 310(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2276"},"text":"118 Stat. 2276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s3/b/3"},"text":"Pub. L. 109–162, § 3(b)(3)","children":[],"tail":", title XI, §§ 1134(b), 1135(c), "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2971"},"text":"119 Stat. 2971","children":[],"tail":", 3108, 3109; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":", §§ 2(d), 8(b), "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/752"},"text":"120 Stat. 752","children":[],"tail":", 766.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc47c88-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc47c89-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc47c8a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–3"},"text":"section 3796gg–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc47c8b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", §§ 1134(b) and 1135(c), which directed an amendment substantially identical to that made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s3/b/3"},"text":"Pub. L. 109–162, § 3(b)(3)","children":[],"tail":", were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":", §§ 2(d) and 8(b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s3/b/3"},"text":"Pub. L. 109–162, § 3(b)(3)","children":[],"tail":", substituted “Not later than 1 month after the end of each even-numbered fiscal year, the Attorney General shall submit” for “Not later than 180 days after the end of each fiscal year for which grants are made under this subchapter, the Attorney General shall submit” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":" inserted “, and the membership of persons served in any underserved population” before the semicolon."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
