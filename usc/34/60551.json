{"tag":"section","attrib":{"id":"id4d66afe5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551"},"text":null,"children":[{"tag":"num","attrib":{"value":"60551"},"text":"§ 60551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offender reentry research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66afe6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Institute of Justice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Institute of Justice may conduct research on juvenile and adult offender reentry, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66afe7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a study identifying the number and characteristics of minor children who have had a parent incarcerated, and the likelihood of such minor children becoming adversely involved in the criminal justice system some time in their lifetime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66afe8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a study identifying a mechanism to compare rates of recidivism (including rearrest, violations of parole, probation, post-incarceration supervision, and reincarceration) among States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66afe9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a study on the population of offenders released from custody who do not engage in recidivism and the characteristics (housing, employment, treatment, family connection) of that population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66afea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Justice Statistics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Bureau of Justice Statistics may conduct research on offender reentry, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66afeb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of special populations (including prisoners with mental illness or substance abuse disorders, female offenders, juvenile offenders, offenders with limited English proficiency, and the elderly) that present unique reentry challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66afec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies to determine which offenders are returning to prison, jail, or a juvenile facility and which of those returning offenders represent the greatest risk to victims and community safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66afed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual reports on the demographic characteristics of the population reentering society from prisons, jails, and juvenile facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66afee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national recidivism study every 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66afef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a study of parole, probation, or post-incarceration supervision violations and revocations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66aff0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60551/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a study concerning the most appropriate measure to be used when reporting recidivism rates (whether rearrest, reincarceration, or any other valid, evidence-based measure).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66aff1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s241"},"text":"Pub. L. 110–199, title II, § 241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/690"},"text":"122 Stat. 690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d66aff2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d66aff3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d66aff4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17551"},"text":"section 17551 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
