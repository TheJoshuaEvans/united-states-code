{"tag":"section","attrib":{"id":"id4cf43f35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312"},"text":null,"children":[{"tag":"num","attrib":{"value":"11312"},"text":"§ 11312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and functions of the Administrator","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf43f36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such arrangements as are necessary and appropriate to facilitate coordination and policy development among all activities funded through the Department of Justice relating to delinquency prevention (including the preparation of an annual comprehensive plan for facilitating such coordination and policy development);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf43f37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide adequate staff and resources necessary to properly carry out this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf43f38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 180 days after the end of each fiscal year, submit a report to the chairman of the Committee on Education and the Workforce of the House of Representatives and the chairman of the Committee on the Judiciary of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf43f39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing activities and accomplishments of grant activities funded under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf43f3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing procedures followed to disseminate grant activity products and research findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf43f3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing activities conducted to develop policy and to coordinate Federal agency and interagency efforts related to delinquency prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf43f3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11312/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying successful approaches and making recommendations for future activities to be conducted under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf43f3d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tV/s503"},"text":"Pub. L. 93–415, title V, § 503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12222/a"},"text":"Pub. L. 107–273, div. C, title II, § 12222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-