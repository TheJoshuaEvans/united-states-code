{"tag":"section","attrib":{"id":"id4cce19ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552"},"text":null,"children":[{"tag":"num","attrib":{"value":"10552"},"text":"§ 10552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cce19ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To request a grant under this subchapter, the chief executive of a State, unit of local government, or Indian tribe shall submit an application to the COPS Director or the BJA Director, as the case may be, at such time, in such manner, and accompanied by such information as the COPS Director or the BJA Director may require. Each application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cce19ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a detailed explanation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cce19af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intended uses of funds provided under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce19b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the activities funded under the grant will meet the purpose of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be accompanied by an assurance that the application was prepared after consultation with individuals not limited to law enforcement officers (such as school violence researchers, licensed mental health professionals, social workers, teachers, principals, and other school personnel) to ensure that the improvements to be funded under the grant are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cce19b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with a comprehensive approach to preventing school violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce19b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individualized to the needs of each school at which those improvements are to be made;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an assurance that the applicant shall maintain and report such data, records, and information (programmatic and financial) as the COPS Director or the BJA Director may reasonably require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cce19b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a certification, made in a form acceptable to the COPS Director or the BJA Director, as the case may be, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cce19b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs to be funded by the grant meet all the requirements of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce19b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all the information contained in the application is correct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cce19b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will comply with all provisions of this subchapter and all other applicable Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce19b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the COPS Director and the BJA Director shall each promulgate guidelines to implement this section (including the information that must be included and the requirements that the States, units of local government, and Indian tribes must meet) in submitting the applications required under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce19ba-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2702"},"text":"Pub. L. 90–351, title I, § 2702","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1108/b"},"text":"Pub. L. 106–386, div. B, title I, § 1108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1502"},"text":"114 Stat. 1502","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/j/2"},"text":"Pub. L. 109–271, § 8(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/767"},"text":"120 Stat. 767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tV/s502/2"},"text":"Pub. L. 115–141, div. S, title V, § 502(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1130"},"text":"132 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cce19bb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cce19bc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cce19bd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797b"},"text":"section 3797b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cce19be-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/2/A/i"},"text":"Pub. L. 115–141, § 502(2)(A)(i)","children":[],"tail":", in introductory provisions, substituted “the COPS Director or the BJA Director, as the case may be,” for “the Director” after “application to” and “the COPS Director or the BJA Director may” for “the Director may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/2/A/iii/I"},"text":"Pub. L. 115–141, § 502(2)(A)(iii)(I)","children":[],"tail":", substituted “licensed mental health professionals” for “child psychologists” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/2/A/ii"},"text":"Pub. L. 115–141, § 502(2)(A)(ii)","children":[],"tail":", (iii)(II), (iv), added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/2/B"},"text":"Pub. L. 115–141, § 502(2)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"October 28, 2000","children":[],"tail":"” and “COPS Director and the BJA Director shall each” for “Director shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":" substituted “Director” for “Attorney General” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
