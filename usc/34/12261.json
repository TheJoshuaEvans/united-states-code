{"tag":"section","attrib":{"id":"id4cfdb5a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12261"},"text":null,"children":[{"tag":"num","attrib":{"value":"12261"},"text":"§ 12261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb5aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the funds available to carry out this part for the benefit of Federal prisoners, the Attorney General, acting through the Director of the Bureau of Prisons, shall select eligible prisoners to live in community correctional facilities with their children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb5ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General contracting authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this part,","children":[{"tag":"ref","attrib":{"idref":"fn002103"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002103"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Attorney General may enter into contracts with appropriate public or private agencies to provide housing, sustenance, services, and supervision of inmates eligible for placement in community correctional facilities under this part."},{"tag":"ref","attrib":{"idref":"fn002103"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb5ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of State facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the discretion of the Attorney General, Federal participants may be placed in State projects as defined in subpart 1. For such participants, the Attorney General shall, with funds available under section 13883(b)(2) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 42, reimburse the State for all project costs related to the Federal participant’s placement, including administrative costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb5ad-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31921"},"text":"Pub. L. 103–322, title III, § 31921","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1896"},"text":"108 Stat. 1896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb5ae-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb5af-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfdb5b0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (b), was in the original “this title” and was translated as reading “this subtitle”, meaning subtitle S of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13883"},"text":"Section 13883 of title 42","children":[],"tail":", referred to in subsec. (c), was omitted from the Code as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb5b1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13901"},"text":"section 13901 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
