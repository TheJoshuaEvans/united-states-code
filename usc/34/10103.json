{"tag":"section","attrib":{"id":"id4c94e0fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10103"},"text":null,"children":[{"tag":"num","attrib":{"value":"10103"},"text":"§ 10103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Weed and Seed Strategies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c94e0fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office an Office of Weed and Seed Strategies, headed by a Director appointed by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c94e0fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may assist States, units of local government, and neighborhood and community-based organizations in developing Weed and Seed strategies, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10104"},"text":"section 10104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c94e0fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $60,000,000 for fiscal year 2006, and such sums as may be necessary for each of fiscal years 2007, 2008, and 2009, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c94e0fe-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s103"},"text":"Pub. L. 90–351, title I, § 103","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1121/a"},"text":"Pub. L. 109–162, title XI, § 1121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3104"},"text":"119 Stat. 3104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c972aef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c972af0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c972af1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712a"},"text":"section 3712a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4c972af2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4c972af3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1121/c"},"text":"Pub. L. 109–162, title XI, § 1121(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3107"},"text":"119 Stat. 3107","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/n/1"},"text":"Pub. L. 109–271, § 8(n)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/767"},"text":"120 Stat. 767","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/271/s8/n/1"},"text":"“This section [enacting this section and sections 10104 and 10105 of this title and provisions set out as a note below] and the amendments made by this section take effect with respect to appropriations for fiscal year 2007 and for each fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4c972af4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Abolishment of Executive Office of Weed and Seed; Transfers of Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1121/b"},"text":"Pub. L. 109–162, title XI, § 1121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3107"},"text":"119 Stat. 3107","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/162/tXI/s1121/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abolishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Office of Weed and Seed is abolished.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are hereby transferred to the Office of Weed and Seed Strategies all functions and activities performed immediately before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":"] by the Executive Office of Weed and Seed Strategies.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
