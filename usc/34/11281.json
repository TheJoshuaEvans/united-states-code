{"tag":"section","attrib":{"id":"id4cef83fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11281"},"text":null,"children":[{"tag":"num","attrib":{"value":"11281"},"text":"§ 11281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cef83fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"None of the funds contained in this subchapter may be used for any program of distributing sterile needles or syringes for the hypodermic injection of any illegal drug.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cef83fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual or entity who receives any funds contained in this subchapter and who carries out any program described in subsection (a) shall account for all funds used for such program separately from any funds contained in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cef83ff-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s389"},"text":"Pub. L. 93–415, title III, § 389","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI/s120"},"text":"Pub. L. 108–96, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1171"},"text":"117 Stat. 1171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cef8400-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cef8401-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cef8402-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5752"},"text":"section 5752 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
