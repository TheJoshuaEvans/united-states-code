{"tag":"section","attrib":{"id":"id4cc6ed5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462"},"text":null,"children":[{"tag":"num","attrib":{"value":"10462"},"text":"§ 10462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc6ed5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible grantee shall submit an application to the Attorney General that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc6ed5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains a certification by the chief executive officer of the State, Indian tribal government, court, or local government entity that the conditions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10461/c"},"text":"section 10461(c) of this title","children":[],"tail":" are met or will be met within the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc6ed60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period ending on the date on which the next session of the State or Indian tribal legislature ends; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc6ed61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years of ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":" or, in the case of the condition set forth in subsection "},{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 10461(c)(4) "},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the expiration of the 2-year period beginning on "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"October 28, 2000","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes plans to further the purposes stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10461/a"},"text":"section 10461(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the agency or office or groups of agencies or offices responsible for carrying out the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes documentation from victim service providers and, as appropriate, population specific organizations demonstrating their participation in developing the application, and identifying such programs in which such groups will be consulted for development and implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc6ed65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this subchapter, the Attorney General shall give priority to applicants that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc6ed66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not currently provide for centralized handling of cases involving domestic violence, dating violence, sexual assault, or stalking by police, prosecutors, and courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a commitment to strong enforcement of laws, and prosecution of cases, involving domestic violence, dating violence, sexual assault, or stalking, including the enforcement of protection orders from other States and jurisdictions (including tribal jurisdictions);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have established cooperative agreements or can demonstrate effective ongoing collaborative arrangements with neighboring jurisdictions to facilitate the enforcement of protection orders from other States and jurisdictions (including tribal jurisdictions); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in applications describing plans to further the purposes stated in paragraph (4) or (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10461/b"},"text":"section 10461(b) of this title","children":[],"tail":", will give priority to using the grant to develop and install data collection and communication systems, including computerized systems, and training on how to use these systems effectively to link police, prosecutors, courts, and tribal jurisdictions for the purpose of identifying and tracking protection orders and violations of protection orders, in those jurisdictions where such systems do not exist or are not fully effective."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc6ed6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall annually compile and broadly disseminate (including through electronic publication) information about successful data collection and communication systems that meet the purposes described in this section. Such dissemination shall target States, State and local courts, Indian tribal governments, and units of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc6ed6b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2102"},"text":"Pub. L. 90–351, title I, § 2102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40231/a/3"},"text":"Pub. L. 103–322, title IV, § 40231(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1933"},"text":"108 Stat. 1933","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1101/a/3"},"text":"Pub. L. 106–386, div. B, title I, § 1101(a)(3)","children":[],"tail":", (b)(3), "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1492"},"text":"114 Stat. 1492","children":[],"tail":", 1493; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s102/c"},"text":"Pub. L. 109–162, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2977"},"text":"119 Stat. 2977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tI/s102/a/2"},"text":"Pub. L. 113–4, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/72"},"text":"127 Stat. 72","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc95e6c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc95e6d-5dcd-11