{"tag":"section","attrib":{"id":"id4d17f369-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12601"},"text":null,"children":[{"tag":"num","attrib":{"value":"12601"},"text":"§ 12601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cause of action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d17f36a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any governmental authority, or any agent thereof, or any person acting on behalf of a governmental authority, to engage in a pattern or practice of conduct by law enforcement officers or by officials or employees of any governmental agency with responsibility for the administration of juvenile justice or the incarceration of juveniles that deprives persons of rights, privileges, or immunities secured or protected by the Constitution or laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f36b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Attorney General has reasonable cause to believe that a violation of paragraph (1) ","children":[{"tag":"ref","attrib":{"idref":"fn002141"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002141"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (a) of this section”."}],"tail":" has occurred, the Attorney General, for or in the name of the United States, may in a civil action obtain appropriate equitable and declaratory relief to eliminate the pattern or practice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d17f36c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210401"},"text":"Pub. L. 103–322, title XXI, § 210401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2071"},"text":"108 Stat. 2071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d17f36d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d17f36e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d17f36f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14141"},"text":"section 14141 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
