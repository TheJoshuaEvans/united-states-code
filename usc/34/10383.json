{"tag":"section","attrib":{"id":"id4cbd4fdd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10383"},"text":null,"children":[{"tag":"num","attrib":{"value":"10383"},"text":"§ 10383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd4fde-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for grants made for hiring or rehiring additional career law enforcement officers, a grant under this subchapter may be renewed for up to 2 additional years after the first fiscal year during which a recipient receives its initial grant, if the Attorney General determines that the funds made available to the recipient were used in a manner required under an approved application and if the recipient can demonstrate significant progress in achieving the objectives of the initial application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fdf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for hiring","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made for hiring or rehiring additional career law enforcement officers may be renewed for up to 5 years, subject to the requirements of subsection (a), but notwithstanding the limitation in that subsection concerning the number of years for which grants may be renewed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fe0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant for a period exceeding 1 year may be renewed as provided in this section, except that the total duration of such a grant including any renewals may not exceed 3 years, or 5 years if it is a grant made for hiring or rehiring additional career law enforcement officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd4fe1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1703"},"text":"Pub. L. 90–351, title I, § 1703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tI/s10003/a/3"},"text":"Pub. L. 103–322, title I, § 10003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1812"},"text":"108 Stat. 1812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd4fe2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd4fe3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd4fe4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796dd–2"},"text":"section 3796dd–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
