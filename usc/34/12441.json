{"tag":"section","attrib":{"id":"id4d075286-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12441"},"text":null,"children":[{"tag":"num","attrib":{"value":"12441"},"text":"§ 12441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to protect the privacy and confidentiality of victims of domestic violence, dating violence, sexual assault, and stalking","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General, through the Director of the Office on Violence Against Women, may award grants under this part to States, Indian tribes, territories, or local agencies or nonprofit, nongovernmental organizations to ensure that personally identifying information of adult, youth, and child victims of domestic violence, sexual violence, stalking, and dating violence shall not be released or disclosed to the detriment of such victimized persons.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d075287-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41101"},"text":"Pub. L. 103–322, title IV, § 41101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s107"},"text":"Pub. L. 109–162, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2983"},"text":"119 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d075288-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075289-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d07528a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043b"},"text":"section 14043b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
