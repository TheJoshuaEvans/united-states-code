{"tag":"section","attrib":{"id":"id4d66b058-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60904"},"text":null,"children":[{"tag":"num","attrib":{"value":"60904"},"text":"§ 60904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and updates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b059-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency shall consult with the designated person who filed the written application pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901"},"text":"section 60901 of this title","children":[],"tail":" and provide him or her with periodic updates during the case file review and full reinvestigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b05a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explanation of conclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency shall meet with the designated person and discuss the evidence to explain to the designated person who filed the written application pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901"},"text":"section 60901 of this title","children":[],"tail":" its decision whether or not to engage in the full reinvestigation provided for under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60903"},"text":"section 60903 of this title","children":[],"tail":" at the conclusion of the case file review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b05b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s5"},"text":"Pub. L. 117–164, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1359"},"text":"136 Stat. 1359","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
