{"tag":"section","attrib":{"id":"id4cc95f37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479"},"text":null,"children":[{"tag":"num","attrib":{"value":"10479"},"text":"§ 10479.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health responses in the judicial system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc95f38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pretrial screening and supervision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award grants to States, units of local government, territories, Indian Tribes, nonprofit agencies, or any combination thereof, to develop, implement, or expand pretrial services programs to improve the identification and outcomes of individuals with mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this subsection may be may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" behavioral health needs and risk screening of defendants, including verification of interview information, mental health evaluation, and criminal history screening;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment of risk of pretrial misconduct through objective, statistically validated means, and presentation to the court of recommendations based on such assessment, including services that will reduce the risk of pre-trial misconduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" followup review of defendants unable to meet the conditions of pretrial release;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of process and results of pre-trial service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f3f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervision of defendants who are on pretrial release, including reminders to defendants of scheduled court dates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f40-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting on process and results of pretrial services programs to relevant public and private mental health stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f41-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection and analysis necessary to make available information required for assessment of risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f42-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Behavioral health assessments and intervention","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f43-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award grants to States, units of local government, territories, Indian Tribes, nonprofit agencies, or any combination thereof, to develop, implement, or expand a behavioral health screening and assessment program framework for State or local criminal justice systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f44-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this subsection may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f45-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotion of the use of validated assessment tools to gauge the criminogenic risk, substance abuse needs, and mental health needs of individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiatives to match the risk factors and needs of individuals to programs and practices associated with research-based, positive outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing methods for identifying and treating individuals who are most likely to benefit from coordinated supervision and treatment strategies, and identifying individuals who can do well with fewer interventions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative decision-making among the heads of criminal justice agencies, mental health systems, judicial systems, substance abuse systems, and other relevant systems or agencies for determining how treatment and intensive supervision services should be allocated in order to maximize benefits, and developing and utilizing capacity accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, unit of local government, territory, Indian Tribe, or nonprofit agency that receives a grant under this section shall, in accordance with subsection (b)(2), use grant funds for the expenses of a treatment program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries, personnel costs, equipment costs, and other costs directly related to the operation of the program, including costs relating to enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f4b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments for treatment providers that are approved by the State or Indian Tribe and licensed, if necessary, to provide needed treatment to program participants, including aftercare supervision, vocational training, education, and job placement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f4c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments to public and nonprofit private entities that are approved by the State or Indian Tribe and licensed, if necessary, to provide alcohol and drug addiction treatment to offenders participating in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement of non-Federal funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be used to supplement, and not supplant, non-Federal funds that would otherwise be available for programs described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of a grant made under this section may not exceed 50 percent of the total costs of the program described in an application under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f50-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To request a grant under this section, a State, unit of local government, territory, Indian Tribe, or nonprofit agency shall submit an application to the Attorney General in such form and containing such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f51-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall ensure that, to the extent practicable, the distribution of grants under this section is equitable and includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f52-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a unit of local government, territory, Indian Tribe, or nonprofit agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in rural, suburban, Tribal, and urban jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, each grantee under this section during that fiscal year shall submit to the Attorney General a report on the effectiveness of activities carried out using such grant. Each report shall include an evaluation in such form and containing such information as the Attorney General may reasonably require. The Attorney General shall specify the dates on which such reports shall be submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall be subject to the following accountability provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit requirement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “unresolved audit finding” means a finding in the final audit report of the Inspector General of the Department of Justice under subparagraph (C) that the audited grantee has used grant funds for an unauthorized expenditure or otherwise unallowable cost that is not closed or resolved within 1 year after the date on which ","children":[{"tag":"ref","attrib":{"idref":"fn002046"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should appear."}],"tail":" final audit report is issued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", and in each fiscal year thereafter, the Inspector General of the Department of Justice shall conduct audits of grantees under this section to prevent waste, fraud, and abuse of funds by grantees. The Inspector General shall determine the appropriate number of grantees to be audited each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final audit report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Justice shall submit to the Attorney General a final report on each audit conducted under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grantees under this section about which there is an unresolved audit finding shall not be eligible to receive a grant under this section during the 2 fiscal years beginning after the end of the 1-year period described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Attorney General shall give priority to applicants that did not have an unresolved audit finding during the 3 fiscal years before submitting an application for a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an entity receives a grant under this section during the 2-fiscal-year period during which the entity is prohibited from receiving grants under subparagraph (D), the Attorney General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95f5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit an amount equal to the amount of the grant that was improperly awarded to the grantee into the General Fund of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95f60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to recoup the costs of the repayment under clause (i) from the grantee that was erroneously awarded grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit agency requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph and the grant program under this section, the term “nonprofit agency” means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and is exempt from taxation under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may not award a grant under this section to a nonprofit agency that holds money in an offshore account for the purpose of avoiding paying the tax described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s511/a"},"text":"section 511(a) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each nonprofit agency that is awarded a grant under this section and uses the procedures prescribed in regulations to create a rebuttable presumption of reasonableness for the compensation of its officers, directors, trustees, and key employees, shall disclose to the Attorney General, in the application for the grant, the process for determining such compensation, including the independent persons involved in reviewing and approving such compensation, the comparability data used, and contemporaneous substantiation of the deliberation and decision. Upon request, the Attorney General shall make the information disclosed under this subparagraph available for public inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than $20,000 of the amounts made available to the Department of Justice to carry out this section may be used by the Attorney General, or by any individual or entity awarded a grant under this section to host, or make any expenditures relating to, a conference unless the Deputy Attorney General provides prior written authorization that the funds may be expended to host the conference or make such expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Written approval under subparagraph (A) shall include a written estimate of all costs associated with the conference, including the cost of all food, beverages, audio-visual equipment, honoraria for speakers, and entertainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Attorney General shall submit an annual report to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives on all conference expenditures approved under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning in the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the Attorney General shall submit to the Committee on the Judiciary and the Committee on Appropriations of the Senate and the Committee on the Judiciary and the Committee on Appropriations of the House of Representatives an annual certification—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95f6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" indicating whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95f6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all final audit reports issued by the Office of the Inspector General under paragraph (1) have been completed and reviewed by the appropriate Assistant Attorney General or Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95f6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all mandatory exclusions required under paragraph (1)(D) have been issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95f6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reimbursements required under paragraph (1)(F) have been made; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95f6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes a list of any grantees excluded under paragraph (1)(D) from the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing duplicative grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the Attorney General awards a grant to an applicant under this section, the Attorney General shall compare the possible grant with any other grants awarded to the applicant under this Act to determine whether the grants are for the same purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Attorney General awards multiple grants to the same applicant for the same purpose, the Attorney General shall submit to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ccba862-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all duplicate grants awarded, including the total dollar amount of any such grants awarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ccba863-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10479/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason the Attorney General awarded the duplicate grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba864-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2209"},"text":"Pub. L. 90–351, title I, § 2209","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14004"},"text":"Pub. L. 114–255, div. B, title XIV, § 14004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1291"},"text":"130 Stat. 1291","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba865-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba866-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ccba867-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (i)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/197"},"text":"82 Stat. 197","children":[],"tail":", known as the Omnibus Crime Control and Safe Streets Act of 1968. For complete classification of this Act to the Code, see Short Title of 1968 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba868-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ii–8"},"text":"section 3796ii–8 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ccba869-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2209"},"text":"section 2209 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tV/s50001/a/3"},"text":"Pub. L. 103–322, title V, § 50001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1958"},"text":"108 Stat. 1958","children":[],"tail":", related to technical assistance, training, and evaluation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(b)(1)(A)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–21; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
