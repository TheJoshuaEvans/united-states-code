{"tag":"section","attrib":{"id":"id4d643f0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60504"},"text":null,"children":[{"tag":"num","attrib":{"value":"60504"},"text":"§ 60504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or an amendment made by this Act shall be construed as creating a right or entitlement to assistance or services for any individual, program, or grant recipient. Each grant made under this Act or an amendment made by this Act shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made as competitive grants ","children":[{"tag":"ref","attrib":{"idref":"fn002231"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002231"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “as a competitive grant”."}],"tail":" to eligible entities for a 12-month period, except that grants awarded under section 113 "},{"tag":"ref","attrib":{"idref":"fn002232"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002232"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60521"},"text":"section 60521 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60531"},"text":"section 60531 of this title","children":[],"tail":", and section 60532 "},{"tag":"ref","attrib":{"idref":"fn002232"},"text":"2","children":[],"tail":" of this title or under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10631"},"text":"section 10631 of this title","children":[],"tail":" may be made for a 24-month period; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that services for participants, when necessary and appropriate, be transferred from programs funded under this Act or the amendment made by this Act, respectively, to State and community-based programs not funded under this Act or the amendment made by this Act, respectively, before the expiration of the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f0f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/s6"},"text":"Pub. L. 110–199, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/660"},"text":"122 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/h"},"text":"Pub. L. 115–391, title V, § 502(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5231"},"text":"132 Stat. 5231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f10-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f11-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d643f12-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children"