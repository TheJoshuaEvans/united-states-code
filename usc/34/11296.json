{"tag":"section","attrib":{"id":"id4cf1cdc2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296"},"text":null,"children":[{"tag":"num","attrib":{"value":"11296"},"text":"§ 11296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight and accountability","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"All grants awarded by the Department of Justice that are authorized under this subchapter shall be subject to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf1cdc3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For 2 of the fiscal years in the period of fiscal years 2014 through 2023, the Inspector General of the Department of Justice shall conduct audits of the recipient of grants under this subchapter to prevent waste, fraud, and abuse by the grantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdc4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the recipient of grant funds under this subchapter is found to have an unresolved audit finding, then that entity shall not be eligible to receive grant funds under this subchapter during the 2 fiscal years beginning after the 12-month period described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdc5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an entity is awarded grant funds under this subchapter during the 2-fiscal-year period in which the entity is barred from receiving grants under paragraph (2), the Attorney General shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf1cdc6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit an amount equal to the grant funds that were improperly awarded to the grantee into the General Fund of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdc7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to recoup the costs of the repayment to the fund from the grant recipient that was erroneously awarded grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “unresolved audit finding” means an audit report finding in the final report of the Inspector General of the Department of Justice that the grantee has utilized grant funds for an unauthorized expenditure or otherwise unallowable cost that is not closed or resolved within a 12-month period beginning on the date when the final audit report is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf1cdca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section and the grant programs described in this subchapter, the term “nonprofit”, relating to an entity, means the entity is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and is exempt from taxation under section 501(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdcb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall not award a grant under any grant program described in this subchapter to a nonprofit organization that holds money in off-shore accounts for the purpose of avoiding paying the tax described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s511/a"},"text":"section 511(a) of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdcc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each nonprofit organization that is awarded a grant under this subchapter and uses the procedures prescribed in regulations under section 53.4958–6 of title 26 of the Code of Federal Regulations to create a rebuttable presumption of reasonableness of the compensation for its officers, directors, trustees and key employees, shall disclose to the Attorney General the process for determining such compensation, including the independent persons involved in reviewing and approving such compensation, the comparability data used, and contemporaneous substantiation of the deliberation and decision. Upon request, the Attorney General shall make the information available for public inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdcd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference expenditures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf1cdce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No amounts authorized to be appropriated under this subchapter may be used to host or support any expenditure for conferences that uses more than $20,000 unless the Deputy Attorney General or the appropriate Assistant Attorney General, Director, or principal deputy director as the Deputy Attorney General may designate, provides prior written authorization that the funds may be expended to host a conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdcf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Written approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Written approval under subparagraph (A) shall include a written estimate of all costs associated with the conference, including the cost of all food and beverages, audio/visual equipment, honoraria for speakers, and any entertainment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Attorney General shall submit an annual report to the Committee on the Judiciary of the Senate, the Committee on the Judiciary of the House of Representatives, and the Committee on Education and the Workforce of the House of Representatives on all conference expenditures approved by operation of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on lobbying activity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf1cdd2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts authorized to be appropriated under this subchapter may not be utilized by any grant recipient to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cf1cdd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobby any representative of the Department of Justice regarding the award of any grant funding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cf1cdd4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobby any representative of a Federal, State, local, or tribal government regarding the award of grant funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdd5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Attorney General determines that any recipient of a grant under this subchapter has violated subparagraph (A), the Attorney General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cf1cdd6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the grant recipient to repay the grant in full; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cf1cdd7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the grant recipient from receiving another grant under this subchapter for not less than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cdd8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11296/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, submitting an application for a grant under this subchapter shall not be considered lobbying activity in violation of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf1cdd9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIV/s408"},"text":"Pub. L. 93–415, title IV, § 408","children":[],"tail":", formerly § 407, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/38/s4"},"text":"Pub. L. 113–38, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-09-30"},"text":"Sept. 30, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/529"},"text":"127 Stat. 529","children":[],"tail":"; renumbered § 408, "},{"tag":"ref","attrib":{"href":"/us/pl/115/267/s2/e/1"},"text":"Pub. L. 115–267, § 2(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3760"},"text":"132 Stat. 3760","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tII/s202/e/1"},"text":"Pub. L. 115–393, title II, § 202(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5271"},"text":"132 Stat. 5271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/267/s3/b"},"text":"Pub. L. 115–267, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3760"},"text":"132 Stat. 3760","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf1cdda-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf1cddb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf1cddc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267/s2/e/1"},"text":"Pub. L. 115–267, § 2(e)(1)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/s202/e/1"},"text":"Pub. L. 115–393, § 202(e)(1)","children":[],"tail":", identically renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/93/415/s407"},"text":"section 407 of Pub. L. 93–415","children":[],"tail":" as section 408."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5776a"},"text":"section 5776a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cf1cddd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s408"},"text":"section 408 of Pub. L. 93–415","children":[],"tail":" was renumbered section 409 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11297"},"text":"section 11297 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cf1cdde-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267/s3/b"},"text":"Pub. L. 115–267, § 3(b)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cf1cddf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cf1cde0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267"},"text":"Pub. L. 115–267","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", with amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/115/267/s2"},"text":"section 2 of Pub. L. 115–267","children":[],"tail":" applicable to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"Sept. 30, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/267/s4"},"text":"section 4 of Pub. L. 115–267","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11291"},"text":"section 11291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
