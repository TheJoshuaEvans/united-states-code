{"tag":"section","attrib":{"id":"id4d28bc93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301"},"text":null,"children":[{"tag":"num","attrib":{"value":"20301"},"text":"§ 20301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d28bc94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over 3,400,000 reports of suspected child abuse and neglect are made each year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation and prosecution of child abuse cases is extremely complex, involving numerous agencies and dozens of personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a key to a child victim healing from abuse is access to supportive and healthy families and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditionally, community agencies and professionals have different roles in the prevention, investigation, and intervention process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such cases, too often the system does not pay sufficient attention to the needs and welfare of the child victim, aggravating the trauma that the child victim has already experienced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a national need to enhance coordination among community agencies and professionals involved in the intervention system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multidisciplinary child abuse investigation and prosecution programs have been developed that increase the reporting of child abuse cases, reduce the trauma to the child victim, improve positive outcomes for the child, and increase the successful prosecution of child abuse offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such programs have proven effective, and with targeted Federal assistance, have expanded dramatically throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bc9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" State chapters of children’s advocacy center networks are needed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bc9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist local communities in coordinating their multidisciplinary child abuse investigation, prosecution, and intervention services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bc9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20301/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide oversight of, and training and technical assistance in, the effective delivery of evidence-informed programming, and operations of centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d28bc9f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s211"},"text":"Pub. L. 101–647, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4792"},"text":"104 Stat. 4792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s6/a"},"text":"Pub. L. 102–586, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5029"},"text":"106 Stat. 5029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/a"},"text":"Pub. L. 115–424, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5465"},"text":"132 Stat. 5465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/1"},"text":"Pub. L. 117–354, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6274"},"text":"136 Stat. 6274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d28bca0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d28bca1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d28bca2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13001"},"text":"section 13001 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d28bca3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/1/A"},"text":"Pub. L. 117–354, § 3(1)(A)","children":[],"tail":", substituted “3,400,000” for “3,300,000” and struck out “, and drug abuse is associated with a significant portion of these” after “year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/1/B"},"text":"Pub. L. 117–354, § 3(1)(B)","children":[],"tail":", (C), added par. (3) and redesignated former pars. (3) to (8) as (4) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/1/D"},"text":"Pub. L. 117–354, § 3(1)(D)","children":[],"tail":", inserted “, and operations of centers” after “programming”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/a/1"},"text":"Pub. L. 115–424, § 2(a)(1)","children":[],"tail":", substituted “3,300,000” for “2,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/a/2"},"text":"Pub. L. 115–424, § 2(a)(2)","children":[],"tail":", inserted “improve positive outcomes for the child,” before “and increase” and substituted semicolon for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/a/3"},"text":"Pub. L. 115–424, § 2(a)(3)","children":[],"tail":", substituted “have expanded dramatically throughout the United States; and” for “could be duplicated in many jurisdictions throughout the country.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/a/4"},"text":"Pub. L. 115–424, § 2(a)(4)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Pars. (3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" added pars. (3) and (5) and redesignated former pars. (3), (4), and (5) as (4), (6), and (7), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
