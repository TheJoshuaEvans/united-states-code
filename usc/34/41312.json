{"tag":"section","attrib":{"id":"id4d5ac926-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41312"},"text":null,"children":[{"tag":"num","attrib":{"value":"41312"},"text":"§ 41312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on female genital mutilation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2021-01-05"},"text":"January 5, 2021","children":[],"tail":", and annually thereafter, the Attorney General, in consultation with the Secretary of Homeland Security, the Secretary of State, the Secretary of Health and Human Services, and the Secretary of Education, shall submit to Congress a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5ac927-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41312/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the number of women and girls in the United States at risk of or who have been subjected to female genital mutilation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac928-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41312/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protections available and actions taken, if any, by Federal, State, and local agencies to protect such women and girls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac929-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41312/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by Federal agencies to educate and assist communities and key stakeholders about female genital mutilation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5ac92a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/309/s4"},"text":"Pub. L. 116–309, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-05"},"text":"Jan. 5, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4924"},"text":"134 Stat. 4924","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
