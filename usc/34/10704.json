{"tag":"section","attrib":{"id":"id4cda0012-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10704"},"text":null,"children":[{"tag":"num","attrib":{"value":"10704"},"text":"§ 10704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this subchapter, the Attorney General shall distribute funds in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda0013-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10704/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitably addresses the needs of underserved populations, including rural and tribal communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0014-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10704/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focuses on communities that have been disproportionately impacted by opioid abuse as evidenced in part by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda0015-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10704/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high rates of primary treatment admissions for heroin and other opioids;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0016-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10704/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high rates of drug poisoning deaths from heroin and other opioids; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0017-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10704/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lack of accessibility to treatment providers and facilities and to emergency medical services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cda0018-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3024"},"text":"Pub. L. 90–351, title I, § 3024","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tII/s201/a/1"},"text":"Pub. L. 114–198, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/713"},"text":"130 Stat. 713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cda0019-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cda001a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cda001b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797ff–3"},"text":"section 3797ff–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
