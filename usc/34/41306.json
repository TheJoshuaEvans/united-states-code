{"tag":"section","attrib":{"id":"id4d5858b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306"},"text":null,"children":[{"tag":"num","attrib":{"value":"41306"},"text":"§ 41306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress on banking law offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5858b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5858ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall compile and collect data concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5858bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and number of civil and criminal investigations, prosecutions, and related proceedings, and civil enforcement and recovery proceedings, in progress with respect to banking law offenses under sections 981, 1008, 1032, and 3322(d) of title 18 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833a"},"text":"section 1833a of title 12","children":[],"tail":" and conspiracies to commit any such offense, including inactive investigations of such offenses;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5858bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigations, prosecutions, and related proceedings described in subparagraph (A) which are inactive as of the close of the reporting period but have not been closed or declined; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5858be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unaddressed referrals which allege criminal misconduct involving offenses described in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and the reasons such matters are inactive and the referrals unaddressed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and number of such matters closed, settled, or litigated to conclusion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results achieved, including convictions and pretrial diversions, fines and penalties levied, restitution assessed and collected, and damages recovered, in such matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis and report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall analyze and report to the Congress on the data described in paragraph (1) and its coordination and other related activities named in section 41501(c)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002219"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002219"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “41501(c)(3)”."}],"tail":" of this title and shall provide such report on the data monthly through "},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":", and quarterly after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5858c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specifics of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5858c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorize data as to various types of financial institutions and appropriate dollar loss categories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclose data for each Federal judicial district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the activities of the Financial Institution Fraud Unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" list—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5858c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of institutions, categorized by failed and open institutions, in which evidence of significant fraud, unlawful activity, insider abuse or serious misconduct has been alleged or detected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil, criminal, and administrative enforcement actions, including those of the Federal financial institutions regulatory agencies, brought against offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any settlements or judgments obtained against offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indictments, guilty pleas, or verdicts obtained against offenders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41306/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources allocated in pursuit of investigations, prosecutions, and sentencings (including indictments, guilty pleas, or verdicts obtained against offenders) and related proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5858cc-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2546"},"text":"Pub. L. 101–647, title XXV, § 2546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4885"},"text":"104 Stat. 4885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5858cd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5858ce-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5858cf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s522"},"text":"section 522 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
