{"tag":"section","attrib":{"id":"id4cbfc1c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10407"},"text":null,"children":[{"tag":"num","attrib":{"value":"10407"},"text":"§ 10407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of private sector","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds or a portion of funds allocated under this subchapter may be used by a State or unit of local government that receives a grant under this subchapter to contract with private, nonprofit entities, or community-based organizations to carry out the purposes specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10401/b"},"text":"section 10401(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cbfc1c2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1806"},"text":"Pub. L. 90–351, title I, § 1806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1866"},"text":"116 Stat. 1866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc1c3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc1c4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc1c5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codifica