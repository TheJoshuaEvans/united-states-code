{"tag":"section","attrib":{"id":"id4d58582b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106"},"text":null,"children":[{"tag":"num","attrib":{"value":"41106"},"text":"§ 41106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews of criminal records of applicants for private security officer employment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d58582c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Private Security Officer Employment Authorization Act of 2004”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d58582d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d58582e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment of private security officers in the United States is growing rapidly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d58582f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private security officers function as an adjunct to, but not a replacement for, public law enforcement by helping to reduce and prevent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585830-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such private security officers protect individuals, property, and proprietary information, and provide protection to such diverse operations as banks, hospitals, research and development centers, manufacturing facilities, defense and aerospace contractors, high technology businesses, nuclear power plants, chemical companies, oil and gas refineries, airports, communication facilities and operations, office complexes, schools, residential properties, apartment complexes, gated communities, and others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585831-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sworn law enforcement officers provide significant services to the citizens of the United States in its public areas, and are supplemented by private security officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585832-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threat of additional terrorist attacks requires cooperation between public and private sectors and demands professional, reliable, and responsible security officers for the protection of people, facilities, and institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585833-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trend in the Nation toward growth in such security services has accelerated rapidly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585834-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such growth makes available more public sector law enforcement officers to combat serious and violent crimes, including terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585835-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American public deserves the employment of qualified, well-trained private security personnel as an adjunct to sworn law enforcement officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585836-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private security officers and applicants for private security officer positions should be thoroughly screened and trained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d585837-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d585838-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “employee” includes both a current employee and an applicant for employment as a private security officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585839-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized employer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “authorized employer” means any person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d58583a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs private security officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d58583b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized by regulations promulgated by the Attorney General to request a criminal history record information search of an employee through a State identification bureau pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d58583c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private security officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private security officer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d58583d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an individual other than an employee of a Federal, State, or local government, whose primary duty is to perform security services, full or part time, for consideration, whether armed or unarmed and in uniform or plain clothes (except for services excluded from coverage under this section if the Attorney General determines by regulation that such exclusion would serve the public interest); but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d58583e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d58583f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees whose duties are primarily internal audit or credit functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d585840-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of electronic security system companies acting as technicians or monitors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d585841-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees whose duties primarily involve the secure movement of prisoners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585842-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “security services” means acts to protect people or property as defined by regulations promulgated by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585843-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State identification bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State identification bureau” means the State entity designated by the Attorney General for the submission and receipt of criminal history record information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d585844-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal history record information search","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d585845-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d585846-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of fingerprints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An authorized employer may submit to the State identification bureau of a participating State, fingerprints or other means of positive identification, as determined by the Attorney General, of an employee of such employer for purposes of a criminal history record information search pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d585847-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee rights","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d585848-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An authorized employer shall obtain written consent from an employee to submit to the State identification bureau of the participating State the request to search the criminal history record information of the employee under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d585849-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An authorized employer shall provide to the employee confidential access to any information relating to the employee received by the authorized employer pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d58584a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing information to the State identification bureau","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receipt of a request for a criminal history record information search from an authorized employer pursuant to this section, submitted through the State identification bureau of a participating State, the Attorney General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d58584b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" search the appropriate records of the Criminal Justice Information Services Division of the Federal Bureau of Investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d58584c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly provide any resulting identification and criminal history record information to the submitting State identification bureau requesting the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d58584d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of information","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d58584e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of the criminal history record information from the Attorney General by the State identification bureau, the information shall be used only as provided in clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d58584f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d585850-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a participating State that has no State standards for qualification to be a private security officer, the State shall notify an authorized employer as to the fact of whether an employee has been—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id4d585851-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convicted of a felony, an offense involving dishonesty or a false statement if the conviction occurred during the previous 10 years, or an offense involving the use or attempted use of physical force against the person of another if the conviction occurred during the previous 10 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d585852-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charged with a criminal felony for which there has been no resolution during the preceding 365 days; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d585853-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participating State that has State standards for qualification to be a private security officer, the State shall use the information received pursuant to this section in applying the State standards and shall only notify the employer of the results of the application of the State standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d585854-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency of requests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An authorized employer may request a criminal history record information search for an employee only once every 12 months of continuous employment by that employee unless the authorized employer has good cause to submit additional requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585855-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-12-17"},"text":"December 17, 2004","children":[],"tail":", the Attorney General shall issue such final or interim final regulations as may be necessary to carry out this section, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d585856-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures relating to the security, confidentiality, accuracy, use, submission, dissemination, destruction of information and audits, and record keeping;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d585857-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for qualification as an authorized employer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d585858-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imposition of reasonable fees necessary for conducting the background checks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585859-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties for use of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever knowingly and intentionally uses any information obtained pursuant to this section other than for the purpose of determining the suitability of an individual for employment as a private security officer shall be fined under title 18, or imprisoned for not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d58585a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d58585b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Federal Bureau of Investigation may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d58585c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect fees to process background checks provided for by this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d58585d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such fees at a level to include an additional amount to defray expenses for the automation of fingerprint identification and criminal justice information services and associated costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d58585e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any fee collected under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d58585f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/515"},"text":"Public Law 101–515","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/104/99"},"text":"Public Law 104–99","children":[],"tail":", be credited to the appropriation to be used for salaries and other expenses incurred through providing the services described in such Public Laws and in subparagraph (A);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d585860-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for expenditure only to pay the costs of such activities and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d585861-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d585862-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as restricting the right of a State to assess a reasonable fee on an authorized employer for the costs to the State of administering this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585863-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41106/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State opt out","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may decline to participate in the background check system authorized by this section by enacting a law or issuing an order by the Governor (if consistent with State law) providing that the State is declining to participate pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d585864-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6402"},"text":"Pub. L. 108–458, title VI, § 6402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3755"},"text":"118 Stat. 3755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d585865-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d585866-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d585867-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/515"},"text":"Public Law 101–515","children":[],"tail":", referred to in subsec. (d)(4)(B)(i), is "},{"tag":"ref","attrib":{"href":"/us/pl/101/515"},"text":"Pub. L. 101–515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2101"},"text":"104 Stat. 2101","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/99"},"text":"Public Law 104–99","children":[],"tail":", referred to in subsec. (d)(4)(B)(i), is "},{"tag":"ref","attrib":{"href":"/us/pl/104/99"},"text":"Pub. L. 104–99","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-26"},"text":"Jan. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/26"},"text":"110 Stat. 26","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d585868-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
