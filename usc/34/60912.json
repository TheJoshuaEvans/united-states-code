{"tag":"section","attrib":{"id":"id4d66b07f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912"},"text":null,"children":[{"tag":"num","attrib":{"value":"60912"},"text":"§ 60912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b080-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each agency shall submit an annual report to the Committees on the Judiciary of the House of Representatives and of the Senate describing actions taken and results achieved under this chapter during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b081-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report described in subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66b082-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of written applications filed with the agency pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901/a"},"text":"section 60901(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b083-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of extensions granted, and an explanation of reasons provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901/h"},"text":"section 60901(h) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b084-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of full reinvestigations initiated and closed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60903"},"text":"section 60903 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b085-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60912/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statistics and individualized information on topics that include identified suspects, arrests, charges, and convictions for reviews under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60901"},"text":"section 60901 of this title","children":[],"tail":" and reinvestigations under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60903"},"text":"section 60903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b086-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s13"},"text":"Pub. L. 117–164, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1361"},"text":"136 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
