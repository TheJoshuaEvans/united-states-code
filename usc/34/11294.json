,"id":"id4cf1cd97-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf1cd98-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5775"},"text":"section 5775 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cf1cd99-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s405"},"text":"section 405 of Pub. L. 93–415","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5774"},"text":"section 5774 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7286"},"text":"Pub. L. 100–690, title VII, § 7286","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4460"},"text":"102 Stat. 4460","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cf1cd9a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267/s2/d/1/A"},"text":"Pub. L. 115–267, § 2(d)(1)(A)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/s202/d/1/A"},"text":"Pub. L. 115–393, § 202(d)(1)(A)","children":[],"tail":", amended par. (7) identically, striking out “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11292/1/A"},"text":"section 11292(1)(A) of this title","children":[],"tail":")” after “missing children”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267/s2/d/1/B"},"text":"Pub. L. 115–267, § 2(d)(1)(B)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/s202/d/1/B"},"text":"Pub. L. 115–393, § 202(d)(1)(B)","children":[],"tail":", amended par. (8) identically, substituting “parents” for “legal custodians” and “parents’ ” for “custodians’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267/s2/d/2"},"text":"Pub. L. 115–267, § 2(d)(2)","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/s202/d/2"},"text":"Pub. L. 115–393, § 202(d)(2)","children":[],"tail":", amended subpar. (A) identically, substituting “parents” for “legal custodians”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/38/s2/c/1"},"text":"Pub. L. 113–38, § 2(c)(1)","children":[],"tail":", inserted “schools, school leaders, teachers, State and local educational agencies, homeless shelters and service providers,” after “children,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/38/s2/c/2"},"text":"Pub. L. 113–38, § 2(c)(2)","children":[],"tail":", inserted “and schools” after “communities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71"},"text":"Pub. L. 106–71","children":[],"tail":" inserted “the Center and with” before “public agencies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204"},"text":"Pub. L. 101–204","children":[],"tail":" substituted “clearinghouses” for “clearinghouse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7287"},"text":"Pub. L. 100–690, § 7287","children":[],"tail":", added pars. (7) to (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cf1cd9b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cf1cd9c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/267"},"text":"Pub. L. 115–267","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", and applicable to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"Sept. 30, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/267/s4"},"text":"section 4 of Pub. L. 115–267","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11291"},"text":"section 11291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cf1cd9d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7296/a"},"text":"section 7296(a) of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
