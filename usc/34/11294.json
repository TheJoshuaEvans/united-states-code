{"tag":"section","attrib":{"id":"id4cf1cd81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294"},"text":null,"children":[{"tag":"num","attrib":{"value":"11294"},"text":"§ 11294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf1cd82-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Administrator; description of research, demonstration projects, and service programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator is authorized to make grants to and enter into contracts with the Center and with public agencies or nonprofit private organizations, or combinations thereof, for research, demonstration projects, or service programs designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf1cd83-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate parents, children, schools, school leaders, teachers, State and local educational agencies, homeless shelters and service providers, and community agencies and organizations in ways to prevent the abduction and sexual exploitation of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information to assist in the locating and return of missing children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid communities and schools in the collection of materials which would be useful to parents in assisting others in the identification of missing children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to increase knowledge of and develop effective treatment pertaining to the psychological consequences, on both parents and children, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf1cd87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abduction of a child, both during the period of disappearance and after the child is recovered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cd88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sexual exploitation of a missing child;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect detailed data from selected States or localities on the actual investigative practices utilized by law enforcement agencies in missing children’s cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address the particular needs of missing children by minimizing the negative impact of judicial and law enforcement procedures on children who are victims of abuse or sexual exploitation and by promoting the active participation of children and their families in cases involving abuse or sexual exploitation of children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address the needs of missing children and their families following the recovery of such children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the likelihood that individuals under 18 years of age will be removed from the control of such individuals’ parents without such parents’ consent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or operate statewide clearinghouses to assist in locating and recovering missing children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf1cd8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities of grant applicants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering grant applications under this subchapter, the Administrator shall give priority to applicants who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf1cd8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have demonstrated or demonstrate ability in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf1cd90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locating missing children or locating and reuniting missing children with their parents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cd91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing other services to missing children or their families; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf1cd92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research relating to missing children; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cd93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to subparagraphs (A) and (B) of paragraph (1), substantially utilize volunteer assistance.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Administrator shall give first priority to applicants qualifying under subparagraphs (A) and (B) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf1cd94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11294/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal fund expenditures requisite for receipt of Federal assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive assistance under this subchapter for a fiscal year, applicants shall give assurance that they will expend, to the greatest extent practicable, for such fiscal year an amount of funds (without regard to any funds received under any Federal law) that is not less than the amount of funds they received in the preceding fiscal year from State, local, and private sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf1cd95-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIV/s405"},"text":"Pub. L. 93–415, title IV, § 405","children":[],"tail":", formerly § 406, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s660"},"text":"Pub. L. 98–473, title II, § 660","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2128"},"text":"98 Stat. 2128","children":[],"tail":"; renumbered § 405 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §