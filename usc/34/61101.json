{"tag":"section","attrib":{"id":"id4d66b089-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101"},"text":null,"children":[{"tag":"num","attrib":{"value":"61101"},"text":"§ 61101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bridging Immigration-related Deficits Experienced Nationwide Reimbursement Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b08a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Justice a fund, to be known as the “Bridging Immigration-related Deficits Experienced Nationwide (BIDEN) Reimbursement Fund” (referred to in this section as the “Fund”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b08b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall use amounts appropriated or otherwise made available for the Fund for grants to eligible States, State agencies, and units of local government, pursuant to their existing statutory authorities, for any of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66b08c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Locating and apprehending aliens who have committed a crime under Federal, State, or local law, in addition to being unlawfully present in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b08d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collection and analysis of law enforcement investigative information within the United States to counter gang or other criminal activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b08e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Investigating and prosecuting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d66b08f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crimes committed by aliens within the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b090-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug and human trafficking crimes committed within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b091-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Court operations related to the prosecution of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d66b092-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crimes committed by aliens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b093-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug and human trafficking crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b094-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Temporary criminal detention of aliens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b095-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transporting aliens described in paragraph (1) within the United States to locations related to the apprehension, detention, and prosecution of such aliens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b096-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vehicle maintenance, logistics, transportation, and other support provided to law enforcement agencies by a State agency to enhance the ability to locate and apprehend aliens who have committed crimes under Federal, State, or local law, in addition to being unlawfully present in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b097-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available for the purposes described in subsection (b), there is appropriated to the Attorney General for fiscal year 2025, out of any money in the Treasury not otherwise appropriated, not to exceed $3,500,000,000, to remain available until ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":", for the Fund for qualified and documented expenses that achieve any such purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b098-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s61101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant eligibility of completed, ongoing, or new activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may provide grants under this section to State agencies and units of local government for expenditures made by State agencies or units of local government for completed, ongoing, or new activities determined to be eligible for such grant funding that occurred on or after ","children":[{"tag":"date","attrib":{"date":"2021-01-20"},"text":"January 20, 2021","children":[],"tail":". Amounts made available under this section shall be distributed to more than 1 State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b099-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tX/s100055"},"text":"Pub. L. 119–21, title X, § 100055","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/392"},"text":"139 Stat. 392","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
