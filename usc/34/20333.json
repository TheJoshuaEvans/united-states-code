{"tag":"section","attrib":{"id":"id4d2b06a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333"},"text":null,"children":[{"tag":"num","attrib":{"value":"20333"},"text":"§ 20333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialized technical assistance and training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d2b06a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to develop model programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2b06a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall make grants to national organizations to develop 1 or more model technical assistance and training programs to improve the judicial system’s handling of child abuse and neglect cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2b06a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An organization to which a grant is made pursuant to paragraph (1) shall be one that has broad membership among juvenile and family court judges and has demonstrated experience in providing training and technical assistance for judges, attorneys, child welfare personnel, and lay child advocates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2b06a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to juvenile and family courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2b06a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to improve the judicial system’s handling of child abuse and neglect cases, the Administrator shall make grants to State courts or judicial administrators for programs that provide or contract for, the implementation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2b06a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical assistance to judicial personnel and attorneys in juvenile and family courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b06aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative reform in juvenile and family courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2b06ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The criteria established for the making of grants pursuant to paragraph (1) shall give priority to programs that improve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2b06ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for determining whether child service agencies have made reasonable efforts to prevent placement of children in foster care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b06ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for determining whether child service agencies have, after placement of children in foster care, made reasonable efforts to reunite the family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b06ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for coordinating information and services among health professionals, social workers, law enforcement professionals, prosecutors, defense attorneys, and juvenile and family court personnel, consistent with subchapter I; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b06af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for improving the judicial response to children who are vulnerable to human trafficking, to the extent an appropriate screening tool exists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2b06b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make grants under subsections (a) and (b) consistent with sections 11172, 11183, and 11186 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2b06b1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s223"},"text":"Pub. L. 101–647, title II, § 223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4797"},"text":"104 Stat. 4797","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12221/b/1/D"},"text":"Pub. L. 107–273, div. C, title II, § 12221(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1894"},"text":"116 Stat. 1894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tV/s503"},"text":"Pub. L. 115–393, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5277"},"text":"132 Stat. 5277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/h/5"},"text":"Pub. L. 115–424, § 2(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5470"},"text":"132 Stat. 5470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2b06b2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2b06b3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2b06b4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13023"},"text":"section 13023 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d2b06b5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424"},"text":"Pub. L. 115–424","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to sections 11183 and 11186 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/393"},"text":"Pub. L. 115–393","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “sections 5666, 5673, and 5676 of this title” for “section 5665a, 5673, and 5676 of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d2b06b6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d2b06b7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" effective on the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", and applicable only with respect to fiscal years beginning on or after the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s12223"},"text":"section 12223 of Pub. L. 107–273","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
