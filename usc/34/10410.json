{"tag":"section","attrib":{"id":"id4cbfc1e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410"},"text":null,"children":[{"tag":"num","attrib":{"value":"10410"},"text":"§ 10410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit of local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unit of local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a county, township, city, or political subdivision of a county, township, or city, that is a unit of local government as determined by the Secretary of Commerce for general statistical purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any law enforcement district or judicial enforcement district that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cbfc1ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established under applicable State law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cbfc1ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the authority, in a manner independent of other State entities, to establish a budget and raise revenues; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia and the recognized governing body of an Indian tribe or Alaskan Native village that carries out substantial governmental duties and powers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specially qualified unit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specially qualified unit” means a unit of local government which may receive funds under this subchapter only in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10404/e"},"text":"section 10404(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands (the “partial States”) shall collectively be considered as 1 State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10404/a"},"text":"section 10404(a) of this title","children":[],"tail":", the amount allocated to a partial State shall bear the same proportion to the amount collectively allocated to the partial States as the population of the partial State bears to the collective population of the partial States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “juvenile” means an individual who is 17 years of age or younger.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Juvenile justice expenditures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “juvenile justice expenditures” means expenditures in connection with the juvenile justice system, including expenditures in connection with such system to carry out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbfc1f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10401/b"},"text":"section 10401(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbfc1f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities associated with prosecutorial and judicial services and corrections as reported to the Bureau of the Census for the fiscal year preceding the fiscal year for which a determination is made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10410/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Part 1 violent crimes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “part 1 violent crimes” means murder and nonnegligent manslaughter, forcible rape, robbery, and aggravated assault as reported to the Federal Bureau of Investigation for purposes of the Uniform Crime Reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc1f8-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1809"},"text":"Pub. L. 90–351, title I, § 1809","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1867"},"text":"116 Stat. 1867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc1f9-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc1fa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc1fb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–9"},"text":"section 3796ee–9 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
