{"tag":"section","attrib":{"id":"id4c999b85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111"},"text":null,"children":[{"tag":"num","attrib":{"value":"10111"},"text":"§ 10111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of financial management systems of Office of Justice Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c999b86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of accounting activities and procurement activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Attorney General of the Office of Justice Programs, in coordination with the Chief Information Officer and Chief Financial Officer of the Department of Justice, shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all accounting activities for all elements of the Office of Justice Programs are carried out under the direct management of the Office of the Comptroller; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all procurement activities for all elements of the Office are carried out under the direct management of the Office of Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further consolidation of procurement activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Attorney General, in coordination with the Chief Information Officer and Chief Financial Officer of the Department of Justice, shall ensure that, on and after ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all procurement activities for all elements of the Office are carried out through a single management office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all contracts and purchase orders used in carrying out those activities are processed through a single procurement system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation of financial management systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Attorney General, in coordination with the Chief Information Officer and Chief Financial Officer of the Department of Justice, shall ensure that, on and after ","children":[{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":", all financial management activities (including human resources, payroll, and accounting activities, as well as procurement activities) of all elements of the Office are carried out through a single financial management system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Achieving compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Attorney General shall undertake a scheduled consolidation of operations to achieve compliance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to achieving compliance with the requirements of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4c999b90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a), the consolidation of operations shall be initiated not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c999b91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10111/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b) and (c), the consolidation of operations shall be initiated not later than ","children":[{"tag":"date","attrib":{"date":"2006-09-30"},"text":"September 30, 2006","children":[],"tail":", and shall be carried out by the Office of Administration, in consultation with the Chief Information Officer and the Office of Audit, Assessment, and Management."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c999b92-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1162"},"text":"Pub. L. 109–162, title XI, § 1162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3118"},"text":"119 Stat. 3118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c999b93-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c999b94-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c999b95-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Violence Against Women and Department of Justice Reauthorization Act of 2005, and not as part of title I of the Omnibus Crime Control and Safe Streets Act of 1968 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3715a"},"text":"section 3715a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
