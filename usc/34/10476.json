{"tag":"section","attrib":{"id":"id4cc95f22-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10476"},"text":null,"children":[{"tag":"num","attrib":{"value":"10476"},"text":"§ 10476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure that, to the extent practicable, an equitable geographic distribution of grant awards is made that considers the special needs of rural communities, Indian tribes, and Alaska Natives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cc95f23-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2206"},"text":"Pub. L. 90–351, title I, § 2206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/515/s3/a"},"text":"Pub. L. 106–515, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2401"},"text":"114 Stat. 2401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc95f24-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc95f25-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc95f26-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ii–5"},"text":"section 3796ii–5 of Title 42","children"