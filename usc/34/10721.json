{"tag":"section","attrib":{"id":"id4cda0066-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10721"},"text":null,"children":[{"tag":"num","attrib":{"value":"10721"},"text":"§ 10721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cda0067-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Assistance is authorized to enter into a cooperative agreement with or make a grant to an eligible entity for the purpose of improving the identification, investigation, and prosecution of white collar crime (including each category of such crimes set forth in paragraphs (1) through (3) of subsection (b)) by providing comprehensive, direct, and practical training and technical assistance to law enforcement officers, investigators, auditors and prosecutors in States and units of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cda0068-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" White collar crime defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the term “white collar crime” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda0069-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-tech crime, including cyber and electronic crime and related threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda006a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic crime, including financial fraud and mortgage fraud; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda006b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Internet-based crime against children and child pornography.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cda006c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3031"},"text":"Pub. L. 90–351, title I, § 3031","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/76/s3/a"},"text":"Pub. L. 115–76, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-11-02"},"text":"Nov. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1247"},"text":"131 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cda006d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cda006e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id4cda006f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of part MM of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", which is classified to this subchapter, as the “National White Collar Crime Control Act of 2017”, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/351/s3030"},"text":"section 3030 of Pub. L. 90–351","children":[],"tail":", set out as a Short Title of 1968 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
