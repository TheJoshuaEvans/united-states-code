{"tag":"section","attrib":{"id":"id4d2d7724-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502"},"text":null,"children":[{"tag":"num","attrib":{"value":"20502"},"text":"§ 20502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards for issuance and dissemination of alerts through AMBER Alert communications network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d2d7725-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of minimum standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the AMBER Alert Coordinator of the Department of Justice shall establish minimum standards for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d7726-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of alerts through the AMBER Alert communications network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7727-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the dissemination of alerts issued through the network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7728-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d7729-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minimum standards established under subsection (a) shall be adoptable on a voluntary basis only.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d772a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minimum standards shall, to the maximum extent practicable (as determined by the Coordinator in consultation with State, territorial, tribal, and local law enforcement agencies), provide that appropriate information relating to the special needs of an abducted child (including health care needs) are disseminated to the appropriate law enforcement, public health, and other public officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d772b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The minimum standards shall, to the maximum extent practicable (as determined by the Coordinator in consultation with State, territorial, tribal, and local law enforcement agencies), provide that the dissemination of an alert through the AMBER Alert communications network be limited to the geographic areas most likely to facilitate the recovery of the abducted child concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d772c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out activities under subsection (a), the Coordinator may not interfere with the current system of voluntary coordination between local broadcasters and State, territorial, tribal, and local law enforcement agencies for purposes of the AMBER Alert communications network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d772d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d772e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coordinator shall cooperate with the Secretary of Transportation, the Secretary of Homeland Security, and the Federal Communications Commission in carrying out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d772f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coordinator shall also cooperate with local broadcasters and State, territorial, tribal, and local law enforcement agencies in establishing minimum standards under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2d7730-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tIII/s302"},"text":"Pub. L. 108–21, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/661"},"text":"117 Stat. 661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tC/s10001/a/2"},"text":"Pub. L. 116–283, div. H, title C, § 10001(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4861"},"text":"134 Stat. 4861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2d7731-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2d7732-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2d7733-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5791a"},"text":"section 5791a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d2d7734-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/a/2/A"},"text":"Pub. L. 116–283, § 10001(a)(2)(A)","children":[],"tail":", inserted “, territorial, tribal,” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/a/2/B/i"},"text":"Pub. L. 116–283, § 10001(a)(2)(B)(i)","children":[],"tail":", inserted “, the Secretary of Homeland Security,” after “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/a/2/B/ii"},"text":"Pub. L. 116–283, § 10001(a)(2)(B)(ii)","children":[],"tail":", inserted “, territorial, tribal,” after “State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
