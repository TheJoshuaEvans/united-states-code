{"tag":"section","attrib":{"id":"id4d075277-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431"},"text":null,"children":[{"tag":"num","attrib":{"value":"12431"},"text":"§ 12431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d075278-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with national nonprofit, nongovernmental organizations whose primary expertise is in domestic violence, shall establish a task force to coordinate research on domestic violence and to report to Congress on any overlapping or duplication of efforts on domestic violence issues. The task force shall be comprised of representatives from all Federal agencies that fund such research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d075279-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds appropriated under this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d07527a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a coordinated strategy to strengthen research focused on domestic violence education, prevention, and intervention strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07527b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track and report all Federal research and expenditures on domestic violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07527c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify gaps and duplication of efforts in domestic violence research and governmental expenditures on domestic violence issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d07527d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Task Force shall report to Congress annually on its work under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d07527e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “domestic violence” has the meaning given such term by section 10447 ","children":[{"tag":"ref","attrib":{"idref":"fn002122"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002122"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d07527f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12431/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $500,000 for each of fiscal years 2001 through 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d075280-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40901"},"text":"Pub. L. 103–322, title IV, § 40901","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tIV/s1407"},"text":"Pub. L. 106–386, div. B, title IV, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1517"},"text":"114 Stat. 1517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d075281-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075282-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d075283-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10447"},"text":"Section 10447 of this title","children":[],"tail":", referred to in subsec. (d), was subsequently repealed and a new section 10447 enacted which does not define “domestic violence”. However, such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d075284-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14042"},"text":"section 14042 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
