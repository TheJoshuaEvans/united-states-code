{"tag":"section","attrib":{"id":"id4caa3df4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10236"},"text":null,"children":[{"tag":"num","attrib":{"value":"10236"},"text":"§ 10236.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District of Columbia matching fund source","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated by the Congress for the activities of any agency of the District of Columbia government or the United States Government performing law enforcement functions in and for the District of Columbia may be used to provide the non-Federal share of the cost of programs or projects funded under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4caa3df5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s817"},"text":"Pub. L. 90–351, title I, § 817","children":[],"tail":", formerly § 824, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1214"},"text":"93 Stat. 1214","children":[],"tail":"; renumbered § 817, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609B/f"},"text":"Pub. L. 98–473, title II, § 609B(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2093"},"text":"98 Stat. 2093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4caa3df6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4caa3df7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4caa3df8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3789m"},"text":"section 3789m of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4caa3df9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s817"},"text":"section 817 of Pub. L. 90–351","children":[],"tail":" was renumbered section 811 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10230"},"text":"section 10230 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
