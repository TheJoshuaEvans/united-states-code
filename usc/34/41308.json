{"tag":"section","attrib":{"id":"id4d5858dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308"},"text":null,"children":[{"tag":"num","attrib":{"value":"41308"},"text":"§ 41308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State requirements for reporting missing children","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each State reporting under the provisions of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s41307"},"text":"section 41307 of this title","children":[],"tail":" shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5858dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that no law enforcement agency within the State establishes or maintains any policy that requires the observance of any waiting period before accepting a missing child or unidentified person report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that no law enforcement agency within the State establishes or maintains any policy that requires the removal of a missing person entry from its State law enforcement system, the National Crime Information Center computer database, or the NamUs databases based solely on the age of the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that each such report and all necessary and available information, which, with respect to each missing child report, shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5858e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, date of birth, sex, race, height, weight, and eye and hair color of the child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recent photograph of the child, if available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and location of the last known contact with the child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the category under which the child is reported missing;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entered within 2 hours of receipt into the State law enforcement system, the National Crime Information Center computer networks, and the NamUs databases and made available to the Missing Children Information Clearinghouse within the State or other agency designated within the State to receive such reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that after receiving reports as provided in paragraph (3), the law enforcement agency that entered the report into the National Crime Information Center or the NamUs databases shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5858e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no later than 30 days after the original entry of the record into the State law enforcement system, National Crime Information Center computer networks, and the NamUs databases, verify and update such record with any additional information, including, where available, medical and dental records and a photograph taken during the previous 180 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institute or assist with appropriate search and investigative procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the National Center for Missing and Exploited Children of each report received relating to a child reported missing from a foster care family home or childcare institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain close liaison with State and local child welfare systems and the National Center for Missing and Exploited Children for the exchange of information and technical assistance in the missing children cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41308/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant permission to the National Crime Information Center Terminal Contractor for the State to update the missing person record in the National Crime Information Center computer networks with additional information learned during the investigation relating to the missing person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5858ea-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVII/s3702"},"text":"Pub. L. 101–647, title XXXVII, § 3702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4967"},"text":"104 Stat. 4967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s154/a"},"text":"Pub. L. 109–248, title I, § 154(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/611"},"text":"120 Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s116/b"},"text":"Pub. L. 114–22, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/244"},"text":"129 Stat. 244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2/c/2"},"text":"Pub. L. 117–327, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4455"},"text":"136 Stat. 4455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5858eb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5858ec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5858ed-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5780"},"text":"section 5780 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d5858ee-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2/c/2/A"},"text":"Pub. L. 117–327, § 2(c)(2)(A)","children":[],"tail":", substituted “, the National Crime Information Center computer database, or the NamUs databases” for “or the National Crime Information Center computer database”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2/c/2/B"},"text":"Pub. L. 117–327, § 2(c)(2)(B)","children":[],"tail":", substituted “, the National Crime Information Center computer networks, and the NamUs databases” for “and the National Crime Information Center computer networks” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2/c/2/C/i"},"text":"Pub. L. 117–327, § 2(c)(2)(C)(i)","children":[],"tail":", inserted “or the NamUs databases” after “National Crime Information Center” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2/c/2/C/ii"},"text":"Pub. L. 117–327, § 2(c)(2)(C)(ii)","children":[],"tail":", substituted “, National Crime Information Center computer networks, and the NamUs databases” for “and National Crime Information Center computer networks”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/1"},"text":"Pub. L. 114–22, § 116(b)(1)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/2"},"text":"Pub. L. 114–22, § 116(b)(2)","children":[],"tail":", added subpar. (B) and redesignated former subpars. (B) and (C) as (C) and (D), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/3/A"},"text":"Pub. L. 114–22, § 116(b)(3)(A)","children":[],"tail":", substituted “paragraph (3)” for “paragraph (2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/3/B"},"text":"Pub. L. 114–22, § 116(b)(3)(B)","children":[],"tail":", substituted “30 days” for “60 days” and inserted “and a photograph taken during the previous 180 days” after “dental records”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/3/C"},"text":"Pub. L. 114–22, § 116(b)(3)(C)","children":[],"tail":", (E), struck out “and” at end of subpar. (B) and added subpar. (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/3/F"},"text":"Pub. L. 114–22, § 116(b)(3)(F)","children":[],"tail":", inserted “State and local child welfare systems and” before “the National Center for Missing and Exploited Children” and substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/3/D"},"text":"Pub. L. 114–22, § 116(b)(3)(D)","children":[],"tail":", redesignated subpar. (C) as (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s116/b/3/G"},"text":"Pub. L. 114–22, § 116(b)(3)(G)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":" added par. (2), redesignated former pars. (2) and (3) as (3) and (4), respectively, and substituted “within 2 hours of receipt” for “immediately” in concluding provisions of par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d5858ef-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d5858f0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327"},"text":"Pub. L. 117–327","children":[],"tail":" applicable with respect to reports made before, on, or after "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40506/c/3"},"text":"section 40506(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
