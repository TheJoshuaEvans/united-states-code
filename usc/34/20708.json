{"tag":"section","attrib":{"id":"id4d3232b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708"},"text":null,"children":[{"tag":"num","attrib":{"value":"20708"},"text":"§ 20708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for specialized human trafficking training and technical assistance for service providers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3232b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Act of trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “act of trafficking” means an act or practice described in paragraph (9) ","children":[{"tag":"ref","attrib":{"idref":"fn002181"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002181"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3232b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally recognized Indian tribal government, as determined by the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit or for-profit organization (including a tribal nonprofit or for-profit organization);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (including tribal institutions of higher education).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the United States Virgin Islands, the Commonwealth of the Northern Mariana Islands, American Samoa, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim of trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “victim of trafficking” means a person subjected to an act of trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may award grants to eligible entities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training to identify and protect victims of trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the quality and quantity of services offered to trafficking survivors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve victim service providers’ partnerships with Federal, State, tribal, and local law enforcement agencies and other relevant entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train law enforcement personnel to identify and protect victims of trafficking, including training such personnel to utilize Federal, State, or local resources to assist victims of trafficking, which may include programs to build law enforcement capacity to identify and respond to human trafficking that are funded through the Office of Community Oriented Policing Services of the Department of Justice, such as the Interdiction for the Protection of Children Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train law enforcement or State or local prosecutors to identify, investigate, or prosecute acts of trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train law enforcement or State or local prosecutors to utilize laws that prohibit acts of trafficking and to assist in the development of State and local laws to prohibit acts of trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance on the range of services available to victim service providers who serve trafficking victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and distribute materials, including materials identifying best practices in accordance with Federal law and policies, to support victim service providers working with human trafficking victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and disseminate other publicly available materials in accordance with Federal law to help build capacity of service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training at relevant conferences, through webinars, or through other mechanisms in accordance with Federal law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist service providers in developing additional resources such as partnerships with Federal, State, tribal, and local law enforcement agencies and other relevant entities in order to access a range of available services in accordance with Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section may use not more than 5 percent of the total amount of such grant for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonexclusivity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to restrict the ability of an eligible entity to apply for or obtain funding from any other source to carry out the training described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $10,000,000 for each of the fiscal years 2007 through 2011 to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3232d0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/tII/s208"},"text":"Pub. L. 109–164, title II, § 208","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s111"},"text":"Pub. L. 109–162, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2984"},"text":"119 Stat. 2984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1212/b/2/D"},"text":"Pub. L. 113–4, title XII, § 1212(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/144"},"text":"127 Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/392/s10/a"},"text":"Pub. L. 115–392, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5254"},"text":"132 Stat. 5254","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/164/s208"},"text":"§ 208 of Pub. L. 109–164","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tI"},"text":"Pub. L. 117–347, title I","children":[],"tail":", §§ 101(a), 106(a), "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6200"},"text":"136 Stat. 6200","children":[],"tail":", 6204.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d3232d1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d3232d2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d3232d3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":", referred to in subsec. (a)(1), was redesignated par. (11) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d3232d4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14044f"},"text":"section 14044f of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d3232d5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/s101/a"},"text":"Pub. L. 117–347, § 101(a)","children":[],"tail":", inserted before semicolon at end “, which may include programs to build law enforcement capacity to identify and respond to human trafficking that are funded through the Office of Community Oriented Policing Services of the Department of Justice, such as the Interdiction for the Protection of Children Program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392/s10/a/1"},"text":"Pub. L. 115–392, § 10(a)(1)","children":[],"tail":", substituted “specialized human trafficking training and technical assistance for service providers” for “law enforcement training programs” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392/s10/a/2"},"text":"Pub. L. 115–392, § 10(a)(2)","children":[],"tail":", substituted “means—” and subpars. (A) to (F) for “means a State or a local government.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392/s10/a/3"},"text":"Pub. L. 115–392, § 10(a)(3)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Attorney General may award grants to eligible entities to provide training to State and local law enforcement personnel to identify and protect victims of trafficking.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392/s10/a/4"},"text":"Pub. L. 115–392, § 10(a)(4)","children":[],"tail":", added pars. (4) to (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" substituted “paragraph (9)” for “paragraph (8)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
