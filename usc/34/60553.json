{"tag":"section","attrib":{"id":"id4d66b003-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553"},"text":null,"children":[{"tag":"num","attrib":{"value":"60553"},"text":"§ 60553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Addressing the needs of children of incarcerated parents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b004-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66b005-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this section, the Attorney General may collect data and develop best practices of State corrections departments and child protection agencies relating to the communication and coordination between such State departments and agencies to ensure the safety and support of children of incarcerated parents (including those in foster care and kinship care), and the support of parent-child relationships between incarcerated (and formerly incarcerated) parents and their children, as appropriate to the health and well-being of the children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66b006-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The best practices developed under paragraph (1) shall include information related to policies, procedures, and programs that may be used by States to address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d66b007-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of the parent-child bond during incarceration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b008-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental self-improvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66b009-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parental involvement in planning for the future and well-being of their children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b00a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the development of best practices described in subsection (a), the Attorney General shall disseminate to States and other relevant entities such best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b00b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60553/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that States and other relevant entities should use the best practices developed and disseminated in accordance with this section to evaluate and improve the communication and coordination between State corrections departments and child protection agencies to ensure the safety and support of children of incarcerated parents (including those in foster care and kinship care), and the support of parent-child relationships between incarcerated (and formerly incarcerated) parents and their children, as appropriate to the health and well-being of the children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b00c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s243"},"text":"Pub. L. 110–199, title II, § 243","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/691"},"text":"122 Stat. 691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d66b00d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d66b00e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d66b00f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17553"},"text":"section 17553 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
