{"tag":"section","attrib":{"id":"id4cf8f97e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109"},"text":null,"children":[{"tag":"num","attrib":{"value":"12109"},"text":"§ 12109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for incarceration on tribal lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf8f97f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, of amounts made available to the Attorney General to carry out programs relating to offender incarceration, the Attorney General shall reserve $35,000,000 for each of fiscal years 2011 through 2015 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f980-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8f981-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts reserved under subsection (a), the Attorney General shall provide grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8f982-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to Indian tribes for purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cf8f983-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction and maintenance of jails on Indian land for the incarceration of offenders subject to tribal jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cf8f984-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entering into contracts with private entities to increase the efficiency of the construction of tribal jails; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cf8f985-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing alternatives to incarceration in tribal jails;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f986-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to Indian tribes for the construction of tribal justice centers that combine tribal police, courts, and corrections services to address violations of tribal civil and criminal laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f987-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to consortia of Indian tribes for purposes of constructing and operating regional detention centers on Indian land for long-term incarceration of offenders subject to tribal jurisdiction, as the applicable consortium determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f988-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"in ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" providing grants under this subsection, the Attorney General shall take into consideration applicable—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8f989-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reservation crime rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f98a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual tribal court convictions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f98b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bed space needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f98c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Because of the Federal nature and responsibility for providing public safety on Indian land, the Federal share of the cost of any activity carried out using a grant under this subsection shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f98d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an Indian tribe or consortium of Indian tribes, as applicable, shall submit to the Attorney General an application in such form and containing such information as the Attorney General may by regulation require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f98e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", the Attorney General, in coordination with the Bureau of Indian Affairs and in consultation with tribal leaders, tribal law enforcement officers, and tribal corrections officials, shall submit to Congress a long-term plan to address incarceration in Indian country, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8f98f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of proposed activities for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8f990-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction, operation, and maintenance of juvenile (in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2453/a/3"},"text":"section 2453(a)(3) of title 25","children":[],"tail":") and adult detention facilities (including regional facilities) in Indian country;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f991-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracting with State and local detention centers, on approval of the affected tribal governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f992-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternatives to incarceration, developed in cooperation with tribal court systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f993-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment and consideration of the construction of Federal detention facilities in Indian country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f994-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12109/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other alternatives as the Attorney General, in coordination with the Bureau of Indian Affairs and in consultation with Indian tribes, determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf8f995-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20109"},"text":"Pub. L. 103–322, title II, § 20109","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–20; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s244"},"text":"Pub. L. 111–211, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2294"},"text":"124 Stat. 2294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf8f996-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf8f997-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf8f998-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13709"},"text":"section 13709 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cf8f999-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s20109"},"text":"section 20109 of Pub. L. 103–322","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1818"},"text":"108 Stat. 1818","children":[],"tail":", authorized appropriations prior to the general amendment of subtitle A of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cf8f99a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s244/a"},"text":"Pub. L. 111–211, § 244(a)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “Notwithstanding any other provision of this part other than "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s13708/a/2"},"text":"section 13708(a)(2) of this title","children":[],"tail":", from amounts appropriated to carry out sections 13703 and 13704 of this title, the Attorney General shall reserve, to carry out this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 0.3 percent in each of fiscal years 1996 and 1997; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 0.2 percent in each of fiscal years 1998, 1999, and 2000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s244/b/1"},"text":"Pub. L. 111–211, § 244(b)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “From the amounts reserved under subsection (a) of this section, the Attorney General may make grants to Indian tribes for the purposes of constructing jails on tribal lands for the incarceration of offenders subject to tribal jurisdiction.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s244/b/2"},"text":"Pub. L. 111–211, § 244(b)(2)","children":[],"tail":", inserted “or consortium of Indian tribes, as applicable,” after “Indian tribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s244/b/3"},"text":"Pub. L. 111–211, § 244(b)(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
