{"tag":"section","attrib":{"id":"id4d07521e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12403"},"text":null,"children":[{"tag":"num","attrib":{"value":"12403"},"text":"§ 12403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An application for a grant under this part shall be submitted in such form and manner, and contain such information, as the Attorney General may prescribe. In addition, applications shall include documentation showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d07521f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12403/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for grant funds and that State or local funding, as the case may be, does not already cover these operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d075220-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12403/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intended use of the grant funds, including a plan of action to increase record input; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d075221-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12403/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of expected results from the use of the grant funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d075222-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40604"},"text":"Pub. L. 103–322, title IV, § 40604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1951"},"text":"108 Stat. 1951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d075223-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075224-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d075225-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14033"},"text":"section 14033 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
