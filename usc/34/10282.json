{"tag":"section","attrib":{"id":"id4cb3da62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282"},"text":null,"children":[{"tag":"num","attrib":{"value":"10282"},"text":"§ 10282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cb3da63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No benefit shall be paid under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb3da64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the fatal or catastrophic injury was caused by the intentional misconduct of the public safety officer or by such officer’s intention to bring about his death, disability, or injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb3da65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the public safety officer was voluntarily intoxicated at the time of his fatal or catastrophic injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb3da66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the public safety officer was performing his duties in a grossly negligent manner at the time of his fatal or catastrophic injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb3da67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any individual who would otherwise be entitled to a benefit under this subchapter if such individual’s actions were a substantial contributing factor to the fatal or catastrophic injury of the public safety officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb3da68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any individual employed in a capacity other than a civilian capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb3da69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a benefit is payable under this subchapter, the Bureau—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb3da6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall presume that none of the limitations described in subsection (a) apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb3da6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10282/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not determine that a limitation described in subsection (a) applies, absent clear and convincing evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cb3da6c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1202"},"text":"Pub. L. 90–351, title I, § 1202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609F"},"text":"Pub. L. 98–473, title II, § 609F","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2099"},"text":"98 Stat. 2099","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXIII/s1301/b"},"text":"Pub. L. 101–647, title XIII, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4834"},"text":"104 Stat. 4834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1164/b"},"text":"Pub. L. 109–162, title XI, § 1164(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3120"},"text":"119 Stat. 3120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1086/b/1/C"},"text":"Pub. L. 112–239, div. A, title X, § 1086(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1966"},"text":"126 Stat. 1966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/36/s5"},"text":"Pub. L. 115–36, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-02"},"text":"June 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/852"},"text":"131 Stat. 852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb3da6d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb3da6e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb3da6f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796a"},"text":"section 3796a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cb3da70-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1202"},"text":"section 1202 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1220"},"text":"93 Stat. 1220","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/411/tII/s204/a/2"},"text":"Pub. L. 98–411, title II, § 204(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-30"},"text":"Aug. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1561"},"text":"98 Stat. 1561","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609Z"},"text":"Pub. L. 98–473, title II, § 609Z","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2107"},"text":"98 Stat. 2107","children":[],"tail":", contained provisions similar to this section, prior to the general amendment of part L of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s609F"},"text":"section 609F of Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1202"},"text":"section 1202 of Pub. L. 90–351","children":[],"tail":", title VII, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/236"},"text":"82 Stat. 236","children":[],"tail":", was set out in the Appendix to Title 18, Crimes and Criminal Procedure, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/308/s104/b"},"text":"Pub. L. 99–308, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/459"},"text":"100 Stat. 459","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cb3da71-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/36"},"text":"Pub. L. 115–36","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/C/i"},"text":"Pub. L. 112–239, § 1086(b)(1)(C)(i)","children":[],"tail":", substituted “fatal” for “death” wherever appearing except in par. (1) following “bring about his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/C/ii"},"text":"Pub. L. 112–239, § 1086(b)(1)(C)(ii)","children":[],"tail":", substituted “bring about his death, disability, or injury” for “bring about his death or catastrophic injury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" inserted “with respect” before “to any individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Pars. (1) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" inserted “or catastrophic injury” after “death” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cb3da72-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cb3da73-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/36/s6"},"text":"Pub. L. 115–36, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-02"},"text":"June 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/852"},"text":"131 Stat. 852","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/36/s6"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10288"},"text":"section 10288 of this title","children":[],"tail":" and amending this section and sections 10285 and 10302 of this title] shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-06-02"},"text":"June 2, 2017","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" apply to any benefit claim or application under part L of title I of the Omnibus Crime Control and Safe Streets Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796"},"text":"42 U.S.C. 3796","children":[],"tail":" et seq.) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10281"},"text":"34 U.S.C. 10281","children":[],"tail":" et seq.] that is—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pending before the Bureau of Justice Assistance on the date of enactment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received by the Bureau on or after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cb3da74-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", and applicable to matters pending on "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", or filed or accruing after that date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/d"},"text":"section 1086(d) of Pub. L. 112–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10251"},"text":"section 10251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cb3da75-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and not applicable with respect to injuries occurring before "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1303"},"text":"section 1303 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10281"},"text":"section 10281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
