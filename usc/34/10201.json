{"tag":"section","attrib":{"id":"id4ca582d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201"},"text":null,"children":[{"tag":"num","attrib":{"value":"10201"},"text":"§ 10201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca582d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines and comprehensive evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To increase the efficiency and effectiveness of programs funded under this subchapter, the National Institute of Justice shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop guidelines, in cooperation with the Bureau of Justice Assistance, to assist State and local units of government to conduct program evaluations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a reasonable number of comprehensive evaluations of programs funded under section 10156 (formula grants) and section 10171 (discretionary grants) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for selecting programs for review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting programs for review, the Director of the National Institute of Justice should consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the program establishes or demonstrates a new and innovative approach to drug or crime control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the program to be evaluated and the number of similar programs funded under section 10156 (formula grants) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the program has a high potential to be replicated in other jurisdictions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there is substantial public awareness and community involvement in the program. Routine auditing, monitoring, and internal assessment of a State and local drug control program’s progress shall be the sole responsibility of the Bureau of Justice Assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Justice shall annually report to the President, the Attorney General, and the Congress on the nature and findings of the evaluation and research and development activities funded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca582de-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s520"},"text":"Pub. L. 90–351, title I, § 520","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6091/a"},"text":"Pub. L. 100–690, title VI, § 6091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4337"},"text":"102 Stat. 4337","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXVIII/s1801/b"},"text":"Pub. L. 101–647, title XVIII, § 1801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4848"},"text":"104 Stat. 4848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1111/c/2/B"},"text":"Pub. L. 109–162, title XI, § 1111(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3101"},"text":"119 Stat. 3101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ca582df-5dcd-1