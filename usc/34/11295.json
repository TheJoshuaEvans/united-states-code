{"tag":"section","attrib":{"id":"id4cf1cd9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295"},"text":null,"children":[{"tag":"num","attrib":{"value":"11295"},"text":"§ 11295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf1cd9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of priorities and criteria; publication in Federal Register","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the programs authorized by this subchapter, the Administrator shall establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf1cda0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual research, demonstration, and service program priorities for making grants and contracts pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11294"},"text":"section 11294 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cda1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria based on merit for making such grants and contracts.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Not less than 60 days before establishing such priorities and criteria, the Administrator shall publish in the Federal Register for public comment a statement of such proposed priorities and criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf1cda2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive selection process for grant or contract exceeding $50,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant or contract exceeding $50,000 shall be made under this subchapter unless the grantee or contractor has been selected by a competitive process which includes public announcement of the availability of funds for such grant or contract, general criteria for the selection of recipients or contractors, and a description of the application process and application review process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf1cda3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple grants or contracts to same grantee or contractor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Multiple grants or contracts to the same grantee or contractor within any 1 year to support activities having the same general purpose shall be deemed to be a single grant for the purpose of this subsection, but multiple grants or contracts to the same grantee or contractor to support clearly distinct activities shall be considered separate grants or contractors.","children":[{"tag":"ref","attrib":{"idref":"fn002078"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002078"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “contracts.”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf1cda4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIV/s406"},"text":"Pub. L. 93–415, title IV, § 406","children":[],"tail":", formerly § 407, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s660"},"text":"Pub. L. 98–473, title II, § 660","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2129"},"text":"98 Stat. 2129","children":[],"tail":"; renumbered § 406 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §§ 7288, 7290, "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4461"},"text":"102 Stat. 4461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf1cda5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf1cda6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf1cda7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5776"},"text":"section 5776 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cf1cda8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s406"},"text":"section 406 of Pub. L. 93–415","children":[],"tail":" was renumbered section 405 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11294"},"text":"section 11294 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cf1cda9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7290/b"},"text":"Pub. L. 100–690, § 7290(b)","children":[],"tail":", which purported to make technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5775"},"text":"section 5775 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act, could not be executed to text because of general amendment of section by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7288"},"text":"Pub. L. 100–690, § 7288","children":[],"tail":", see below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7288"},"text":"Pub. L. 100–690, § 7288","children":[],"tail":", amended section generally. Prior to amendment, section read as follows: “The Administrator, in consultation with the Advisory Board, shall establish annual research, demonstration, and service program priorities for making grants and contracts pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5775"},"text":"section 5775 of this title","children":[],"tail":" and, not less than 60 days before establishing such priorities, shall publish in the Federal Register for public comment a statement of such proposed priorities.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cf1cdaa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cf1cdab-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7296/a"},"text":"section 7296(a) of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
