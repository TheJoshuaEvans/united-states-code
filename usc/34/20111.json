{"tag":"section","attrib":{"id":"id4d1f1fb9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111"},"text":null,"children":[{"tag":"num","attrib":{"value":"20111"},"text":"§ 20111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office for Victims of Crime","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1fba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office established within Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Justice an Office for Victims of Crime (hereinafter in this subchapter referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fbb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Director; authority; restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Director (referred to in this subchapter as the “Director”), who shall be appointed by the President. The Director shall report to the Attorney General through the Assistant Attorney General for the Office of Justice Programs and shall have final authority for all grants, cooperative agreements, and contracts awarded by the Office. The Director shall not engage in any employment other than that of serving as the Director, nor shall the Director hold any office in, or act in any capacity for, any organization, agency, or institution with which the Office makes any contract or other agreement under this subchapter.","children":[{"tag":"ref","attrib":{"idref":"fn002154"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002154"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1fbc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall have the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1fbd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administering funds made available by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101"},"text":"section 20101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fbe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing funds to eligible States pursuant to sections 20102 and 20103 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fbf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing programs in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20103/c"},"text":"section 20103(c) of this title","children":[],"tail":" on terms and conditions determined by the Director to be consistent with that subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fc0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperating with and providing technical assistance to States, units of local government, and other public and private organizations or international agencies involved in activities related to crime victims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fc1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20111/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other functions as the Attorney General may delegate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f1fc2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1411"},"text":"Pub. L. 98–473, title II, § 1411","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7123/a"},"text":"Pub. L. 100–690, title VII, § 7123(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4420"},"text":"102 Stat. 4420","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/h/5"},"text":"Pub. L. 112–166, § 2(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1285"},"text":"126 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f1fc3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","childr