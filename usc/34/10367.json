{"tag":"section","attrib":{"id":"id4cbb0651-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10367"},"text":null,"children":[{"tag":"num","attrib":{"value":"10367"},"text":"§ 10367.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Local entity” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of this subchapter, the term “local entity” means a child support enforcement agency, law enforcement agency, prosecuting attorney, or unit of local government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cbb0652-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1607"},"text":"Pub. L. 90–351, title I, § 1607","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/521/s4/a/3"},"text":"Pub. L. 102–521, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3406"},"text":"106 Stat. 3406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbb0653-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbb0654-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbb0655-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796cc–6"},"text":"section 3796cc–6 of Title 42","children":[],"tail":", The Public Health and Welf