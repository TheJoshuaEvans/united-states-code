{"tag":"section","attrib":{"id":"id4d61f50d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60104"},"text":null,"children":[{"tag":"num","attrib":{"value":"60104"},"text":"§ 60104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any person who is found in violation of the regulations established by sections 60101 to 60104 of this title shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f50e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be liable to the United States for a civil penalty in an amount not to exceed $10,000 for each violation and, in addition, to the United States for the costs of prosecution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f50f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make restitution to any entity of the United States, of a State, or of an inferior political subdivision of a State, which expends funds for the purpose of apprehending any violent prisoner who escapes from a prisoner transport company as the result, in whole or in part, of a violation of regulations promulgated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60103/a"},"text":"section 60103(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f510-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/560/s5"},"text":"Pub. L. 106–560, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2786"},"text":"114 Stat. 2786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f511-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f512-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d61f513-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13726c"},"text":"section 13726c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
