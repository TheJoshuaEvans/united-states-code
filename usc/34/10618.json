{"tag":"section","attrib":{"id":"id4cd063fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10618"},"text":null,"children":[{"tag":"num","attrib":{"value":"10618"},"text":"§ 10618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A State, Indian tribal government, or unit of local government that receives funds under this subchapter during a fiscal year shall submit to the Attorney General a description and an evaluation report on a date specified by the Attorney General regarding the effectiveness of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cd063fb-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2958"},"text":"Pub. L. 90–351, title I, § 2958","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2301/a"},"text":"Pub. L. 107–273, div. B, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1797"},"text":"116 Stat. 1797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd063fc-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd063fd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd063fe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","