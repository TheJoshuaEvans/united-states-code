"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Virgin Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3bcff5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21502/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in, and subject to the requirements of, section 127 of the Adam Walsh Child Protection and Safety Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16927"},"text":"42 U.S.C. 16927","children":[],"tail":"),"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" a Federally recognized Indian tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3bcff6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minor” means an individual who has not attained the age of 18 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3bcff7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Sex Offender Registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Sex Offender Registry” means the National Sex Offender Registry established by section 119 of the Adam Walsh Child Protection and Safety Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16919"},"text":"42 U.S.C. 16919","children":[],"tail":")."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3bcff8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21502/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sex offender under SORNA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sex offender under SORNA” has the meaning given the term “sex offender” in section 111 of the Adam Walsh Child Protection and Safety Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16911"},"text":"42 U.S.C. 16911","children":[],"tail":")."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3bcff9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21502/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sex offense against a minor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3bcffa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21502/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sex offense against a minor” means a specified offense against a minor, as defined in section 111 of the Adam Walsh Child Protection and Safety Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16911"},"text":"42 U.S.C. 16911","children":[],"tail":")."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3bcffb-5