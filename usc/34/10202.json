{"tag":"section","attrib":{"id":"id4ca582e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202"},"text":null,"children":[{"tag":"num","attrib":{"value":"10202"},"text":"§ 10202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca582e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau shall prepare both a “Program Brief” and “Implementation Guide” document for proven programs and projects to be funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The functions, powers, and duties specified in this subchapter to be carried out by the Bureau shall not be transferred elsewhere in the Department of Justice unless specifically hereafter authorized by the Congress by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, a grantee that uses funds made available under this subchapter to purchase an armor vest or body armor shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca582eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any requirements established for the use of grants made under subchapter XXIV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a written policy requiring uniformed patrol officers to wear an armor vest or body armor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds to purchase armor vests or body armor that meet any performance standards established by the Director of the Bureau of Justice Assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the terms “armor vest”and “body armor” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10533"},"text":"section 10533 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca582ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trauma Kits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca582f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “trauma kit” means a first aid response kit, which includes a bleeding control kit that can be used for controlling a life-threatening hemorrhage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for trauma kits.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca582f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, a grantee may only purchase a trauma kit using funds made available under this subchapter if the trauma kit meets the performance standards established by the Director of the Bureau of Justice Assistance under paragraph (3)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to separately acquire","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in subparagraph (A) shall prohibit a grantee from separately acquiring the components of a trauma kit and assembling complete trauma kits that meet the performance standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance standards and optional agency best practices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Director of the Bureau of Justice Assistance, in consultation with organizations representing trauma surgeons, emergency medical response professionals, emergency physicians, other medical professionals, relevant law enforcement agencies of States and units of local government, professional law enforcement organizations, local law enforcement labor or representative organizations, and law enforcement trade associations, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca582f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and publish performance standards for trauma kits that are eligible for purchase using funds made available under this subchapter that, at a minimum, require the components described in paragraph (4) to be included in a trauma kit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and publish optional best practices for law enforcement agencies regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ca582f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training law enforcement officers in the use of trauma kits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca582f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment and maintenance of trauma kits in law enforcement vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca582f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment, location, and maintenance of trauma kits in law enforcement agency or other government facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca582fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Components","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The components of a trauma kit described in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca582fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tourniquet recommended by the Committee on Tactical Combat Casualty Care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bleeding control bandage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pair of nonlatex protective gloves and a pen-type marker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pair of blunt-ended scissors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca582ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" instructional documents developed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ca58300-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the “Stop the Bleed” national awareness campaign of the Department of Homeland Security, or any successor thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca58301-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the American College of Surgeons Committee on Trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca58302-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the American Red Cross; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca58303-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any partner of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca58304-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bag or other container adequately designed to hold the contents of the kit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca58305-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any additional trauma kit supplies that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ca58306-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are approved by a State, local, or Tribal law enforcement agency or first responders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca58307-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can adequately treat a traumatic injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ca58308-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10202/d/4/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be stored in a readily available kit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca58309-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s521"},"text":"Pub. L. 90–351, title I, § 521","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6091/a"},"text":"Pub. L. 100–690, title VI, § 6091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4337"},"text":"102 Stat. 4337","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/155/s6"},"text":"Pub. L. 114–155, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-16"},"text":"May 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/390"},"text":"130 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXII/s8203"},"text":"Pub. L. 119–60, div. H, title LXXXII, § 8203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1844"},"text":"139 Stat. 1844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ca5830a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ca5830b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ca5830c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3766a"},"text":"section 3766a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ca5830d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s521"},"text":"section 521 of Pub. L. 90–351","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/208"},"text":"82 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/644/tI/s7/9"},"text":"Pub. L. 91–644, title I, § 7(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1888"},"text":"84 Stat. 1888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/83/s2"},"text":"Pub. L. 93–83, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-06"},"text":"Aug. 6, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/215"},"text":"87 Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/503/tI"},"text":"Pub. L. 94–503, title I","children":[],"tail":", §§ 127, 128(a), "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2424"},"text":"90 Stat. 2424","children":[],"tail":", related to recordkeeping requirements, prior to the general amendment of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/96/157"},"text":"Pub. L. 96–157","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ca5830e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/155"},"text":"Pub. L. 114–155","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
