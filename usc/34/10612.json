{"tag":"section","attrib":{"id":"id4cd063ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10612"},"text":null,"children":[{"tag":"num","attrib":{"value":"10612"},"text":"§ 10612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of participation by violent offenders","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd063bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10612/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue regulations or guidelines to ensure that the programs authorized in this subchapter do not permit participation by violent offenders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10612/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately suspend funding for any grant under this subchapter, pending compliance, if the Attorney General finds that violent offenders are participating in any program funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd063bd-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2952"},"text":"Pub. L. 90–351, title I, § 2952","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2301/a"},"text":"Pub. L. 107–273, div. B, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1795"},"text":"116 Stat. 1795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd063be-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd063bf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd063c0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u–1"},"text":"section 3797u–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cd063c1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cd063c2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s103/c"},"text":"Pub. L. 110–199, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/668"},"text":"122 Stat. 668","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/199/tI/s103/c"},"text":"“Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":"], the Secretary [probably should be “the Attorney General”] shall revise any regulations or guidelines described in section 2952 of the Omnibus Crime Control and Safe Streets Act of 1968 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u–1"},"text":"42 U.S.C. 3797u–1","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10612"},"text":"34 U.S.C. 10612","children":[],"tail":"] in accordance with the amendments made by subsection (a) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10613"},"text":"section 10613 of this title","children":[],"tail":"]. Such regulations shall specify that grant amounts under part EE of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10611"},"text":"34 U.S.C. 10611","children":[],"tail":" et seq.] shall be reduced for any drug court that does not adopt the definition of ‘violent offender’ under such part, as amended by subsection (a) of this section, within 3 years after such date of enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
