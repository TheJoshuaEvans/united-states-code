{"tag":"section","attrib":{"id":"id4cd2d4e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644"},"text":null,"children":[{"tag":"num","attrib":{"value":"10644"},"text":"§ 10644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd2d4e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The rural State shall provide training and technical assistance, including through such groups as the National Crime Prevention Council, to assist local communities in developing Crime Prevention Plans that reflect statewide strategic goals and objectives, and performance targets and measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rural State shall provide a report on its statewide strategic plan to the Attorney General, including information about—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd2d4e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involvement of relevant State-level agencies to assist communities in the development and implementation of their Crime Prevention Plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd2d4e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for local applications for Community Grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd2d4e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community progress toward reducing crime, violence, and substance abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10644/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in the third year of the program, States must certify that the local grantee’s project funded under the community grant is generally consistent with statewide strategic goals and objectives, and performance targets and measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd2d4e9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2988"},"text":"Pub. L. 90–351, title I, § 2988","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11027/b"},"text":"Pub. L. 107–273, div. C, title I, § 11027(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1835"},"text":"116 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd2d4ea-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd2d4eb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd2d4ec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797y–3"},"text":"section 3797y–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
