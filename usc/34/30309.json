{"tag":"section","attrib":{"id":"id4d4545f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309"},"text":null,"children":[{"tag":"num","attrib":{"value":"30309"},"text":"§ 30309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4545f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carnal knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “carnal knowledge” means contact between the penis and the vulva or the penis and the anus, including penetration of any sort, however slight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4545f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inmate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “inmate” means any person incarcerated or detained in any facility who is accused of, convicted of, sentenced for, or adjudicated delinquent for, violations of criminal law or the terms and conditions of parole, probation, pretrial release, or diversionary program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4545f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jail","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “jail” means a confinement facility of a Federal, State, or local law enforcement agency to hold—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4545f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons pending adjudication of criminal charges; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4545fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons committed to confinement after adjudication of criminal charges for sentences of 1 year or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4545fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HIV","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “HIV” means the human immunodeficiency virus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4545fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oral sodomy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “oral sodomy” means contact between the mouth and the penis, the mouth and the vulva, or the mouth and the anus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4545fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Police lockup","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “police lockup” means a temporary holding facility of a Federal, State, or local law enforcement agency to hold—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4545fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inmates pending bail or transport to jail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4545ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inebriates until ready for release; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454600-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juveniles pending parental custody or shelter placement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454601-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prison","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “prison” means any confinement facility of a Federal, State, or local government, whether administered by such government or by a private organization on behalf of such government, and includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d454602-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any local jail or police lockup; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454603-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any juvenile facility used for the custody or care of juvenile inmates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454604-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prison rape","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prison rape” includes the rape of an inmate in the actual or constructive control of prison officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454605-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rape","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rape” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d454606-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carnal knowledge, oral sodomy, sexual assault with an object, or sexual fondling of a person, forcibly or against that person’s will;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454607-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carnal knowledge, oral sodomy, sexual assault with an object, or sexual fondling of a person not forcibly or against the person’s will, where the victim is incapable of giving consent because of his or her youth or his or her temporary or permanent mental or physical incapacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454608-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carnal knowledge, oral sodomy, sexual assault with an object, or sexual fondling of a person achieved through the exploitation of the fear or threat of physical violence or bodily injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454609-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault with an object","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual assault with an object” means the use of any hand, finger, object, or other instrument to penetrate, however slightly, the genital or anal opening of the body of another person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45460a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual fondling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual fondling” means the touching of the private body parts of another person (including the genitalia, anus, groin, breast, inner thigh, or buttocks) for the purpose of sexual gratification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45460b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms and conditions described in paragraphs (9) and (10) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d45460c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" custodial or medical personnel gathering physical evidence, or engaged in other legitimate medical treatment, in the course of investigating prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45460d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a health care provider’s hands or fingers or the use of medical devices in the course of appropriate medical treatment unrelated to prison rape; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45460e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30309/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of a health care provider’s hands or fingers and the use of instruments to perform body cavity searches in order to maintain security and safety within the prison or detention facility, provided that the search is conducted in a manner consistent with constitutional requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d45460f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/79/s10"},"text":"Pub. L. 108–79, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-04"},"text":"Sept. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/987"},"text":"117 Stat. 987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d454610-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d454611-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d454612-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15609"},"text":"section 15609 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
