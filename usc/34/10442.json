":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1789"},"text":"116 Stat. 1789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tIX/s901/a"},"text":"Pub. L. 117–103, div. W, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/910"},"text":"136 Stat. 910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc232a7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc232a8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cc232a9-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 1994, referred to in subsec. (c)(2)(A), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 2000, referred to in subsec. (c)(2)(B), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":", "},