{"tag":"section","attrib":{"id":"id4cc2329b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442"},"text":null,"children":[{"tag":"num","attrib":{"value":"10442"},"text":"§ 10442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office on Violence Against Women","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc2329c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established within the Department of Justice, under the general authority of the Attorney General, an Office on Violence Against Women (in this subchapter referred to as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc2329d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be a separate and distinct office within the Department of Justice, not subsumed by any other office, headed by a Director, who shall report to the Attorney General and serve as Counsel to the Attorney General on the subject of violence against women, and who shall have final authority over all grants, cooperative agreements, and contracts awarded by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc2329e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the general authority of the Attorney General, the Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc2329f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have sole jurisdiction over all duties and functions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10444"},"text":"section 10444 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be solely responsible for coordination with other departments, agencies, or offices of all activities authorized or undertaken under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc232a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Violence Against Women Act of 1994 (title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc232a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10442/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Violence Against Women Act of 2000 (division B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Public Law 106–386","children":[],"tail":");"}],"tail":"\