{"tag":"section","attrib":{"id":"id4cb8956e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10306"},"text":null,"children":[{"tag":"num","attrib":{"value":"10306"},"text":"§ 10306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cb8956f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a spouse or child of a Federal law enforcement officer killed in the line of duty on or after ","children":[{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":",,"},{"tag":"ref","attrib":{"idref":"fn002023"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002023"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" and a spouse or child of a public safety officer killed in the line of duty on or after "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":", shall be eligible for assistance under this part, subject to the other limitations of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89570-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall (unless prospective assistance has been provided) provide retroactive assistance to a person eligible under this section for each month in which the person pursued a program of education at an eligible educational institution. The Attorney General shall apply the limitations contained in this part to retroactive assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89571-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prospective assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may provide prospective assistance to a person eligible under this section on the same basis as assistance to a person otherwise eligible. In applying the limitations on assistance under this part, the Attorney General shall include assistance provided retroactively. A person eligible under this section may waive retroactive assistance and apply only for prospective assistance on the same basis as a person otherwise eligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cb89572-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1216"},"text":"Pub. L. 90–351, title I, § 1216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/238/s2/2"},"text":"Pub. L. 104–238, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3115"},"text":"110 Stat. 3115","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/390/s2/5"},"text":"Pub. L. 105–390, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3496"},"text":"112 Stat. 3496","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/276/s1/a"},"text":"Pub. L. 106–276, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-02"},"text":"Oct. 2, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/812"},"text":"114 Stat. 812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1086/b/1/G"},"text":"Pub. L. 112–239, div. A, title X, § 1086(b)(1)(G)","children":[],"tail":", (J), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1968"},"text":"126 Stat. 1968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/61/s5"},"text":"Pub. L. 117–61, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-18"},"text":"Nov. 18, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1479"},"text":"135 Stat. 1479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb89573-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb89574-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb89575-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796d–5"},"text":"section 3796d–5 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":