{"tag":"section","attrib":{"id":"id4cd0634d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593"},"text":null,"children":[{"tag":"num","attrib":{"value":"10593"},"text":"§ 10593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd0634e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program for which a grant is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10591/1"},"text":"section 10591(1) of this title","children":[],"tail":" shall comply with the following requirements:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd0634f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall ensure that all providers of substance abuse treatment are approved by the State or Indian Tribe and are licensed, if necessary, to provide medical and other health services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06350-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall ensure appropriate coordination and consultation with the Single State Authority for Substance Abuse of the State (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60521/e"},"text":"section 60521(e) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06351-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall consist of clinically-appropriate, comprehensive, and long-term family treatment, including the treatment of the nonviolent parent drug offender, the child of such offender, and any other appropriate member of the family of the offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06352-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall be provided in a residential setting that is not a hospital setting or an intensive outpatient setting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06353-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall provide that if a nonviolent parent drug offender who participates in that program does not successfully complete the program the offender shall serve an appropriate sentence of imprisonment with respect to the underlying crime involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06354-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall ensure that a determination is made as to whether a nonviolent drug offender has completed the substance abuse treatment program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06355-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall include the implementation of a system of graduated sanctions (including incentives) that are applied based on the accountability of the nonviolent parent drug offender involved throughout the course of that program to encourage compliance with that program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06356-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall develop and implement a reentry plan for each participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd06357-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prison-based programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A program for which a grant is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10591/2"},"text":"section 10591(2) of this title","children":[],"tail":" shall comply with the following requirements:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd06358-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall integrate techniques to assess the strengths and needs of immediate and extended family of the incarcerated parent to support a treatment plan of the incarcerated parent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06359-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall ensure that each participant in that program has access to consistent and uninterrupted care if transferred to a different correctional facility within the State or other relevant entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd0635a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program shall be located in an area separate from the general population of the prison.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd0635b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall give priority consideration to grant applications for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10591"},"text":"section 10591 of this title","children":[],"tail":" that are submitted by a nonprofit organization that demonstrates a relationship with State and local criminal justice agencies, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd0635c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the judiciary and prosecutorial agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd0635d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10593/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the local corrections agencies, which shall be documented by a written agreement that details the terms of access to facilities and participants and provides information on the history of the organization of working with correctional populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd0635e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2923"},"text":"Pub. L. 90–351, title I, § 2923","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s113"},"text":"Pub. L. 110–199, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/675"},"text":"122 Stat. 675","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/b/2"},"text":"Pub. L. 115–391, title V, § 502(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5228"},"text":"132 Stat. 5228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd0635f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd06360-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd06361-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797s–2"},"text":"section 3797s–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cd06362-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cd06363-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cd06364-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" and requirements for grants made under such amendments, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60504"},"text":"section 60504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
