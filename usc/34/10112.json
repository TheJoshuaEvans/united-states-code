{"tag":"section","attrib":{"id":"id4c999b96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112"},"text":null,"children":[{"tag":"num","attrib":{"value":"10112"},"text":"§ 10112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Policy Advisor on Culturally Specific Communities within the Office of Justice Programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c999b97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be a Senior Policy Advisor on Culturally Specific Communities within the Office of Justice Programs who shall, under the guidance and authority of the Assistant Attorney General of the Office of Justice Programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise on the administration of grants related to culturally specific (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":") services and contracts with culturally specific organizations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate development of Federal policy, protocols, and guidelines on matters relating to domestic violence, dating violence, sexual assault, and stalking (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/a"},"text":"section 12291(a) of this title","children":[],"tail":"), in culturally specific communities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Assistant Attorney General for the Office of Justice Programs concerning policies, legislation, implementation of laws, and other issues relating to domestic violence, dating violence, sexual assault, and stalking in culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, coordination, and support to other offices and bureaus in the Department of Justice to develop policy and to enforce Federal laws relating to domestic violence, dating violence, sexual assault, and stalking in culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that appropriate technical assistance, developed and provided by entities having expertise in culturally specific communities, is made available to grantees and potential grantees proposing to serve culturally specific communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure access to grants and technical assistance for culturally specific organizations and analyze the distribution of funding in order to identify barriers for culturally specific organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Senior Policy Advisor on Culturally Specific Communities shall be an individual with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal, lived, and work experience from a culturally specific community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999ba0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a demonstrated history of and expertise in addressing domestic violence or sexual assault in a nongovernmental agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999ba1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Assistant Attorney General of the Office of Justice Programs shall appoint an individual as Senior Policy Advisor on Culturally Specific Communities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c999ba2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXIII/s1313"},"text":"Pub. L. 117–103, div. W, title XIII, § 1313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/935"},"text":"136 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c999ba3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c999ba4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c999ba5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Violence Against Women Act Reauthorization Act of 2022, and also as part of the Consolidated Appropriations Act, 2022, and not as part of title I of the Omnibus Crime Control and Safe Streets Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4c999ba6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4c999ba7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
