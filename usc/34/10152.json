{"tag":"section","attrib":{"id":"id4c9e5658-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152"},"text":null,"children":[{"tag":"num","attrib":{"value":"10152"},"text":"§ 10152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c9e5659-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c9e565a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts made available to carry out this part, the Attorney General may, in accordance with the formula established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10156"},"text":"section 10156 of this title","children":[],"tail":", make grants to States and units of local government, for use by the State or unit of local government to provide additional personnel, equipment, supplies, contractual support, training, technical assistance, and information systems for criminal justice or civil proceedings, including for any one or more of the following programs:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4c9e565b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Law enforcement programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e565c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prosecution and court programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e565d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prevention and education programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e565e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corrections and community corrections programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e565f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Drug treatment and enforcement programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e5660-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning, evaluation, and technology improvement programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e5661-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crime victim and witness programs (other than compensation).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e5662-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mental health programs and related law enforcement and corrections programs, including behavioral programs and crisis intervention teams.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e5663-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Implementation of State crisis intervention court proceedings and related programs or initiatives, including but not limited to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4c9e5664-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4c9e5665-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drug courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4c9e5666-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4c9e5667-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" extreme risk protection order programs, which must include, at a minimum—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4c9e5668-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-deprivation and post-deprivation due process rights that prevent any violation or infringement of the Constitution of the United States, including but not limited to the Bill of Rights, and the substantive or procedural due process rights guaranteed under the Fifth and Fourteenth Amendments to the Constitution of the United States, as applied to the States, and as interpreted by State courts and United States courts (including the Supreme Court of the United States). Such programs must include, at the appropriate phase to prevent any violation of constitutional rights, at minimum, notice, the right to an in-person hearing, an unbiased adjudicator, the right to know opposing evidence, the right to present evidence, and the right to confront adverse witnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4c9e5669-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to be represented by counsel at no expense to the government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4c9e566a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pre-deprivation and post-deprivation heightened evidentiary standards and proof which mean not less than the protections afforded to a similarly situated litigant in Federal court or promulgated by the State’s evidentiary body, and sufficient to ensure the full protections of the Constitution of the United States, including but not limited to the Bill of Rights, and the substantive and procedural due process rights guaranteed under the Fifth and Fourteenth Amendments to the Constitution of the United States, as applied to the States, and as interpreted by State courts and United States courts (including the Supreme Court of the United States). The heightened evidentiary standards and proof under such programs must, at all appropriate phases to prevent any violation of any constitutional right, at minimum, prevent reliance upon evidence that is unsworn or unaffirmed, irrelevant, based on inadmissible hearsay, unreliable, vague, speculative, and lacking a foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4c9e566b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/I/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" penalties for abuse of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e566c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs to purchase and operate unmanned aircraft systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44801"},"text":"section 44801 of title 49","children":[],"tail":") to benefit public safety."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c9e566d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Programs to purchase and operate counter-UAS systems (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44801"},"text":"section 44801 of title 49","children":[],"tail":") included on the list of technologies established by subsection (d)(2)(A)(iii) "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s124n/d/2/A/iii"},"text":"section 124n(d)(2)(A)(iii) of title 6","children":[],"tail":" to exercise the authority granted under subsection (a)(2) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e566e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall be construed to ensure that a grant under that paragraph may be used for any purpose for which a grant was authorized to be used under either or both of the programs specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10151/b"},"text":"section 10151(b) of this title","children":[],"tail":", as those programs were in effect immediately before "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c76f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and subawards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or unit of local government may, in using a grant under this part for purposes authorized by subsection (a), use all or a portion of that grant to contract with or make one or more subawards to one or more—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c770-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neighborhood or community-based organizations that are private and nonprofit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c771-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c772-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program assessment component; waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c773-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each program funded under this part shall contain a program assessment component, developed pursuant to guidelines established by the Attorney General, in coordination with the National Institute of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c774-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may waive the requirement of paragraph (1) with respect to a program if, in the opinion of the Attorney General, the program is not of sufficient size to justify a full program assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c775-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this Act, no funds provided under this part may be used, directly or indirectly, to provide any of the following matters:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c776-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any security enhancements or any equipment to any nongovernmental entity that is not engaged in criminal justice or public safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c777-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless the Attorney General certifies that extraordinary and exigent circumstances exist that make the use of such funds to provide such matters essential to the maintenance of public safety and good order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca0c778-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicles (excluding police cruisers), vessels (excluding police boats), or aircraft (excluding police helicopters);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c779-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" luxury items;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c77a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c77b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction projects (other than penal or correctional institutions); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca0c77c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any similar matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c77d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of a grant made under this part may be used for costs incurred to administer such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c77e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period of a grant made under this part shall be four years, except that renewals and extensions beyond that period may be granted at the discretion of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c77f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (d)(1) shall not be construed to prohibit the use, directly or indirectly, of funds provided under this part to provide security at a public event, such as a political convention or major sports event, so long as such security is provided under applicable laws and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca0c780-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on crisis intervention programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall publish an annual report with respect to grants awarded for crisis intervention programs or initiatives under subsection (a)(1)(I) that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca0c781-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the grants awarded and the crisis intervention programs or initiatives funded by the grants, broken down by grant recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c782-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of the crisis intervention programs or initiatives in preventing violence and suicide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c783-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures that have been taken by each grant recipient to safeguard the constitutional rights of an individual subject to a crisis intervention program or initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca0c784-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10152/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts that the Attorney General is making, in coordination with the grant recipients, to protect the constitutional rights of individuals subject to the crisis intervention programs or initiatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca0c785-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s501"},"text":"Pub. L. 90–351, title I, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1111/a/2/C"},"text":"Pub. L. 109–162, title XI, § 1111(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/