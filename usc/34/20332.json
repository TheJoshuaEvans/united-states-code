{"tag":"section","attrib":{"id":"id4d2b069c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20332"},"text":null,"children":[{"tag":"num","attrib":{"value":"20332"},"text":"§ 20332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for juvenile and family court personnel","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to improve the judicial system’s handling of child abuse and neglect cases, the Administrator of the Office of Juvenile Justice and Delinquency Prevention shall make grants for the purpose of providing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2b069d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance and training to judicial personnel and attorneys, particularly personnel and practitioners in juvenile and family courts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2b069e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative reform in juvenile and family courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2b069f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s222"},"text":"Pub. L. 101–647, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4797"},"text":"104 Stat. 4797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2b06a0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2b06a1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2b06a2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13022"},"text":"section 13022 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
