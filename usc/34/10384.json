{"tag":"section","attrib":{"id":"id4cbd4fe5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384"},"text":null,"children":[{"tag":"num","attrib":{"value":"10384"},"text":"§ 10384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd4fe6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsupplanting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this subchapter to States or units of local government shall not be used to supplant State or local funds, or, in the case of Indian tribal governments, funds supplied by the Bureau of Indian Affairs, but shall be used to increase the amount of funds that would, in the absence of Federal funds received under this subchapter, be made available from State or local sources, or in the case of Indian tribal governments, from funds supplied by the Bureau of Indian Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fe7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd4fe8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States and units of local government may use assets received through the Assets Forfeiture equitable sharing program to provide the non-Federal share of the cost of programs, projects, and activities funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fe9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribal governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated by the Congress for the activities of any agency of an Indian tribal government or the Bureau of Indian Affairs performing law enforcement functions on any Indian lands may be used to provide the non-Federal share of the cost of programs or projects funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4fea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding provided under this subchapter for hiring or rehiring a career law enforcement officer may not exceed $75,000, unless the Attorney General grants a waiver from this limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd4feb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance for understaffed law enforcement agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd4fec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd4fed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered applicant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered applicant” means an applicant for a hiring grant under this subchapter seeking funding for a law enforcement agency operating below the budgeted strength of the law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd4fee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgeted strength","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “budgeted strength” means the employment of the maximum number of sworn law enforcement officers the budget of a law enforcement agency allows the agency to employ.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4fef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-05-24"},"text":"May 24, 2024","children":[],"tail":", the Attorney General shall establish consistent procedures for covered applicants, including guidance that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd4ff0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clarifies that covered applicants remain eligible for funding under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd4ff1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enables covered applicants to attest that the funding from a grant awarded under this subchapter is not being used by the law enforcement agency to supplant State or local funds, as described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd4ff2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10384/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paperwork reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the procedures and guidance under paragraph (2), the Attorney General shall take measures to reduce paperwork requirements for grants to covered applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd4ff3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1704"},"text":"Pub. L. 90–351, title I, § 1704","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tI/s10003/a/3"},"text":"Pub. L. 103–322, title I, § 10003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1812"},"text":"108 Stat. 1812","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/64/s5"},"text":"Pub. L. 118–64, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-24"},"text":"May 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1436"},"text":"138 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd4ff4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd4ff5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd4ff6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796dd–3"},"text":"section 3796dd–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbd4ff7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/64"},"text":"Pub. L. 118–64","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
