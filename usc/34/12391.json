{"tag":"section","attrib":{"id":"id4d0751e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391"},"text":null,"children":[{"tag":"num","attrib":{"value":"12391"},"text":"§ 12391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cost of testing for sexually transmitted diseases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0751ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0751eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited testing of defendants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0751ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The victim of an offense of the type referred to in subsection (a) ","children":[{"tag":"ref","attrib":{"idref":"fn002118"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002118"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":" may obtain an order in the district court of the United States for the district in which charges are brought against the defendant charged with the offense, after notice to the defendant and an opportunity to be heard, requiring that the defendant be tested for the presence of the etiologic agent for acquired immune deficiency syndrome, and that the results of the test be communicated to the victim and the defendant. Any test result of the defendant given to the victim or the defendant must be accompanied by appropriate counseling."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Showing required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To obtain an order under paragraph (1), the victim must demonstrate that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0751ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant has been charged with the offense in a State or Federal court, and if the defendant has been arrested without a warrant, a probable cause determination has been made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0751ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the test for the etiologic agent for acquired immune deficiency syndrome is requested by the victim after appropriate counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0751f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the test would provide information necessary for the health of the victim of the alleged offense and the court determines that the alleged conduct of the defendant created a risk of transmission, as determined by the Centers for Disease Control, of the etiologic agent for acquired immune deficiency syndrome to the victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Follow-up testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may order follow-up tests and counseling under paragraph (1) if the initial test was negative. Such follow-up tests and counseling shall be performed at the request of the victim on dates that occur six months and twelve months following the initial test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of testing requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order for follow-up testing under paragraph (3) shall be terminated if the person obtains an acquittal on, or dismissal of, all charges of the type referred to in subsection (a).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of test","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of any test ordered under this subsection shall be disclosed only to the victim or, where the court deems appropriate, to the parent or legal guardian of the victim, and to the person tested. The victim may disclose the test results only to any medical professional, counselor, family member or sexual partner(s) the victim may have had since the attack. Any such individual to whom the test results are disclosed by the victim shall maintain the confidentiality of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of test results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall issue an order to prohibit the disclosure by the victim of the results of any test performed under this subsection to anyone other than those mentioned in paragraph (5). The contents of the court proceedings and test results pursuant to this section shall be sealed. The results of such test performed on the defendant under this section shall not be used as evidence in any criminal trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0751f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt for disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who discloses the results of a test in violation of this subsection may be held in contempt of court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0751f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12391/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for intentional transmission of HIV","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the United States Sentencing Commission shall conduct a study and prepare and submit to the committees "},{"tag":"ref","attrib":{"idref":"fn002119"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" on the Judiciary of the Senate and the House of Representatives a report concerning recommendations for the revision of sentencing guidelines that relate to offenses in which an HIV infected individual engages in sexual activity if the individual knows that he or she is infected with HIV and intends, through such sexual activity, to expose another to HIV."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0751f7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40503"},"text":"Pub. L. 103–322, title IV, § 40503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1946"},"text":"108 Stat. 1946","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/1"},"text":"Pub. L. 104–294, title VI, § 604(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3506"},"text":"110 Stat. 3506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0751f8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0751f9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0751fa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14011"},"text":"section 14011 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s40503"},"text":"section 40503 of Pub. L. 103–322","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s40503"},"text":"section 40503 of Pub. L. 103–322","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20141"},"text":"section 20141 of this title","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s40503"},"text":"section 40503 of Pub. L. 103–322","children":[],"tail":" also enacted provisions listed in a table relating to sentencing guidelines set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d0751fb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" substituted “paragraph (1)” for “paragraph (b)(1)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d0751fc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id4d0751fd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Centers for Disease Control changed to Centers for Disease Control and Prevention by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312"},"text":"Pub. L. 102–531, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3504"},"text":"106 Stat. 3504","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d0751fe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
