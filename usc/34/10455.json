{"tag":"section","attrib":{"id":"id4cc6ecff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455"},"text":null,"children":[{"tag":"num","attrib":{"value":"10455"},"text":"§ 10455.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Policy Advisor for Culturally Specific Communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc6ed00-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Office on Violence Against Women a Senior Policy Advisor for Culturally Specific Communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc6ed01-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Senior Policy Advisor for Culturally Specific Communities, under the guidance and authority of the Director, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc6ed02-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise on the administration of grants related to culturally specific services and contracts with culturally specific organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed03-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate development of Federal policy, protocols, and guidelines on matters relating to domestic violence, dating violence, sexual assault, and stalking in culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed04-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Director on policies, legislation, implementation of laws, and other issues relating to domestic violence, dating violence, sexual assault, and stalking in culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed05-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, coordination, and support to other offices and bureaus in the Department of Justice to develop policy and to enforce Federal laws relating to domestic violence, dating violence, sexual assault, and stalking in culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed06-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that appropriate technical assistance, developed and provided by entities with expertise in culturally specific communities, is made available to grantees and potential grantees proposing to serve culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed07-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure access to grants and technical assistance for culturally specific organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc6ed08-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze the distribution of grant funding in order to identify barriers for culturally specific organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc6ed09-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10455/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Director shall hire for the position established under subsection (a) an individual with personal, lived, and work experience from a culturally specific community, and a demonstrated history and expertise addressing domestic violence or sexual assault in a nongovernmental agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc6ed0a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2018"},"text":"Pub. L. 90–351, title I, § 2018","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tIX/s902"},"text":"Pub. L. 117–103, div. W, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/911"},"text":"136 Stat. 911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc6ed0b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cc6ed0c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4cc6ed0d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
