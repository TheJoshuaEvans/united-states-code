{"tag":"section","attrib":{"id":"id4cf688f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12101"},"text":null,"children":[{"tag":"num","attrib":{"value":"12101"},"text":"§ 12101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless otherwise provided, for purposes of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf688f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “indeterminate sentencing” means a system by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf688f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12101/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court may impose a sentence of a range defined by statute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf688f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12101/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative agency, generally the parole board, or the court, controls release within the statutory range;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf688f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “part 1 violent crime” means murder and nonnegligent manslaughter, forcible rape, robbery, and aggravated assault as reported to the Federal Bureau of Investigation for purposes of the Uniform Crime Reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf688f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf688fa-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20101"},"text":"Pub. L. 103–322, title II, § 20101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–15; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf688fb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf688fc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf688fd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13701"},"text":"section 13701 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cf688fe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s20101"},"text":"section 20101 of Pub. L. 103–322","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1815"},"text":"108 Stat. 1815","children":[],"tail":", related to grants for correctional facilities prior to the general amendment of subtitle A of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
