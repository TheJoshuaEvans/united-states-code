{"tag":"section","attrib":{"id":"id4d539cd4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40744"},"text":null,"children":[{"tag":"num","attrib":{"value":"40744"},"text":"§ 40744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offset of funds appropriated","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any funds appropriated to carry out this subchapter, not to exceed $10,000,000 for each of fiscal years 2013 through 2015, shall be derived from amounts appropriated pursuant to subsection (j) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40701"},"text":"section 40701 of this title","children":[],"tail":" in each such fiscal year for grants under such section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d539cd5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/253/s5"},"text":"Pub. L. 112–253, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2409"},"text":"126 Stat. 2409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d539cd6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d539cd7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d539cd8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/253"},"text":"Pub. L. 112–253","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2407"},"text":"126 Stat. 2407","children":[],"tail":", known as the Katie Sepich Enhanced DNA Collection Act of 2012, which is classified principally to this subchapter. For complete classification of this Act to the Code, see Short Title of 2013 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d539cd9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14137c"},"text":"section 14137c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
