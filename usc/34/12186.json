{"tag":"section","attrib":{"id":"id4cfdb4ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12186"},"text":null,"children":[{"tag":"num","attrib":{"value":"12186"},"text":"§ 12186.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program priority for special emphasis programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb4f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12186/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give priority in providing lines of credit under this subpart to community development corporations that propose to undertake economic development activities in distressed communities that target women, Native Americans, at risk youth, farmworkers, population-losing communities, very low-income communities, single mothers, veterans, and refugees; or that expand employee ownership of private enterprises and small businesses, and to programs providing loans of not more than $35,000 to very small business enterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb4f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12186/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 5 percent of the amounts made available under section 31112(a)(2)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002097"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002097"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" may be reserved to carry out the activities described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb4f2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31116"},"text":"Pub. L. 103–322, title III, § 31116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1885"},"text":"108 Stat. 1885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb4f3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb4f4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfdb4f5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 31112(a)(2)(A), referred to in subsec. (b), probably should be a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s31132/b/1"},"text":"section 31132(b)(1) of Pub. L. 103–322","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1888"},"text":"108 Stat. 1888","children":[],"tail":", which authorized appropriations under this part and was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13852"},"text":"section 13852 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to being omitted from the Code as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb4f6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13826"},"text":"section 13826 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
