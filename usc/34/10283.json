{"tag":"section","attrib":{"id":"id4cb62466-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10283"},"text":null,"children":[{"tag":"num","attrib":{"value":"10283"},"text":"§ 10283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National programs for families of public safety officers who have sustained fatal or catastrophic injury in the line of duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director is authorized to use no less than $150,000 of the funds appropriated for this subchapter to maintain and enhance national peer support and counseling programs to assist families of public safety officers who have sustained fatal or catastrophic injury in the line of duty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cb62467-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1203"},"text":"Pub. L. 90–351, title I, § 1203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6106/a/2"},"text":"Pub. L. 100–690, title VI, § 6106(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4341"},"text":"102 Stat. 4341","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/180/s2/a"},"text":"Pub. L. 105–180, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-16"},"text":"June 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/511"},"text":"112 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1086/b/1/D"},"text":"Pub. L. 112–239, div. A, title X, § 1086(b)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1966