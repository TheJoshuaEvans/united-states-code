{"tag":"section","attrib":{"id":"id4cbb060d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361"},"text":null,"children":[{"tag":"num","attrib":{"value":"10361"},"text":"§ 10361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbb060e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Assistance may make grants under this subchapter to States, for the use by States, and local entities in the States to develop, implement, and enforce criminal interstate child support legislation and coordinate criminal interstate child support enforcement efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbb060f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds distributed under this subchapter shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbb0610-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a comprehensive assessment of existing criminal interstate child support enforcement efforts, including the identification of gaps in, and barriers to, the enforcement of such efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0611-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan and implement comprehensive long-range strategies for criminal interstate child support enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0612-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reach an agreement within the State regarding the priorities of such State in the enforcement of criminal interstate child support legislation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0613-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a plan to implement such priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0614-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10361/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate criminal interstate child support enforcement efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbb0615-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1601"},"text":"Pub. L. 90–351, title I, § 1601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/521/s4/a/3"},"text":"Pub. L. 102–521, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3404"},"text":"106 Stat. 3404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbb0616-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbb0617-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbb0618-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796cc"},"text":"section 3796cc of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1601"},"text":"section 1601 of Pub. L. 90–351","children":[],"tail":", title XI, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/239"},"text":"82 Stat. 239","children":[],"tail":", is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbb0619-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1601"},"text":"section 1601 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2601 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10541"},"t