{"tag":"section","attrib":{"id":"id4d5d13f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50331"},"text":null,"children":[{"tag":"num","attrib":{"value":"50331"},"text":"§ 50331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Badge of Bravery Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d13f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Justice a Congressional Badge of Bravery Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d13f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d13f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive nominations from Federal agency heads on behalf of the Federal Board and deliver such nominations to the Federal Board at Federal Board meetings described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50313/d/2"},"text":"section 50313(d)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d13f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children"