{"tag":"section","attrib":{"id":"id4ce85833-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161"},"text":null,"children":[{"tag":"num","attrib":{"value":"11161"},"text":"§ 11161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and evaluation; statistical analyses; information dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ce85834-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce85835-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ce85836-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually publish a plan to identify the purposes and goals of all agreements carried out with funds provided under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85837-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct research or evaluation in juvenile justice matters, for the purpose of providing research and evaluation relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ce85838-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention, reduction, and control of juvenile delinquency and serious crime committed by juveniles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85839-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the link between juvenile delinquency and the incarceration of members of the families of juveniles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8583a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful efforts to prevent status offenders and first-time minor offenders from subsequent involvement with the juvenile justice and criminal justice systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8583b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful efforts to prevent recidivism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8583c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the juvenile justice system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8583d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juvenile violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8583e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevalence and duration of behavioral health needs (including mental health, substance abuse, and co-occurring disorders) among juveniles pre-placement and post-placement in the juvenile justice system, including an examination of the effects of secure detention in a correctional facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8583f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the proportion of juveniles detained or confined in secure detention facilities, secure correctional facilities, jails, and lockups who are members of minority groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85840-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training efforts and reforms that have produced reductions in or elimination of the use of dangerous practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85841-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to improve the recruitment, selection, training, and retention of professional personnel who are focused on the prevention, identification, and treatment of delinquency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85842-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to improve the identification and response to victims of domestic child sex trafficking within the juvenile justice system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85843-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying positive outcome measures, such as attainment of employment and educational degrees, that States and units of local government should use to evaluate the success of programs aimed at reducing recidivism of youth who have come in contact with the juvenile justice system or criminal justice system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85844-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the impact and outcomes of the prosecution and sentencing of juveniles as adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85845-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful and cost-effective efforts by States and units of local government to reduce recidivism through policies that provide for consideration of appropriate alternative sanctions to incarceration of youth facing nonviolent charges, while ensuring that public safety is preserved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85846-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xvi"},"text":"(xvi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no cl. (xv)."}],"tail":" evaluating services, treatment, and aftercare placement of juveniles who were under the care of the State child protection system before their placement in the juvenile justice system;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce85847-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xvii"},"text":"(xvii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determining—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4ce85848-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency, seriousness, and incidence of drug use by youth in schools and communities in the States using, if appropriate, data submitted by the States pursuant to this subparagraph and subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4ce85849-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the frequency, degree of harm, and morbidity of violent incidents, particularly firearm-related injuries and fatalities, by youth in schools and communities in the States, including information with respect to—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id4ce8584a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship between victims and perpetrators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4ce8584b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demographic characteristics of victims and perpetrators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4ce8584c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xvii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of weapons used in incidents, as classified in the Uniform Crime Reports of the Federal Bureau of Investigation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ce8584d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/1/B/xviii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xviii"},"text":"(xviii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other purposes consistent with the purposes of this subchapter and subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce8584e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall ensure that an equitable amount of funds available to carry out paragraph (1)(B) is used for research and evaluation relating to the prevention of juvenile delinquency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce8584f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to permit the development of a national database of personally identifiable information on individuals involved in studies, or in data-collection efforts, carried out under paragraph (1)(B)(x).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce85850-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", the Administrator shall conduct a study with respect to juveniles who, prior to placement in the juvenile justice system, were under the care or custody of the State child welfare system, and to juveniles who are unable to return to their family after completing their disposition in the juvenile justice system and who remain wards of the State in accordance with applicable confidentiality requirements. Such study shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ce85851-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of juveniles in each category;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85852-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which State juvenile justice systems and child welfare systems are coordinating services and treatment for such juveniles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85853-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal and local sources of funds used for placements and post-placement services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85854-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barriers faced by State ","children":[{"tag":"ref","attrib":{"idref":"fn002068"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “States”."}],"tail":" and Indian Tribes in providing services to these juveniles;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85855-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of post-placement services used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85856-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of case plans and case plan reviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85857-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which case plans identify and address permanency and placement barriers and treatment plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85858-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the best practices in discharge planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce85859-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/a/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of living arrangements for juveniles who, upon release from confinement in a State correctional facility, cannot return to the residence they occupied prior to such confinement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce8585a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical analyses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce8585b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan and identify the purposes and goals of all agreements carried out with funds provided under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce8585c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake statistical work in juvenile justice matters, for the purpose of providing for the collection, analysis, and dissemination of statistical data and information relating to juvenile delinquency and serious crimes committed by juveniles, to the juvenile justice system, to juvenile violence, and to other purposes consistent with the purposes of this subchapter and subchapter I.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce8585d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority and competitive selection process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants and enter into contracts with public or private agencies, organizations, or individuals and shall use a competitive process, established by rule by the Administrator, to carry out subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce8585e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency that makes an agreement under subsections (a)(1)(B) and (b)(2) with the Administrator may carry out such agreement directly or by making grants to or contracts with public and private agencies, institutions, and organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce8585f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information dissemination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce85860-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review reports and data relating to the juvenile justice system in the United States and in foreign nations (as appropriate), collect data and information from studies and research into all aspects of juvenile delinquency (including the causes, prevention, and treatment of juvenile delinquency) and serious crimes committed by juveniles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce85861-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and operate, directly or by contract, a clearinghouse and information center for the preparation, publication, and dissemination of information relating to juvenile delinquency, including State and local prevention and treatment programs, plans, resources, and training and technical assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce85862-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants and contracts with public and private agencies, institutions, and organizations, for the purpose of disseminating information to representatives and personnel of public and private agencies, including practitioners in juvenile justice, law enforcement, the courts, corrections, schools, and related services, in the establishment, implementation, and operation of projects and activities for which financial assistance is provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce85863-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National recidivism measure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in accordance with applicable confidentiality requirements and in consultation with experts in the field of juvenile justice research, recidivism, and data collection, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce85864-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a uniform method of data collection and technology that States may use to evaluate data on juvenile recidivism on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce85865-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a common national juvenile recidivism measurement system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce85866-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11161/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make cumulative juvenile recidivism data that is collected from States available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ce85867-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tII/s251"},"text":"Pub. L. 93–415, title II, § 251","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12211"},"text":"Pub. L. 107–273, div. C, title II, § 12211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1888"},"text":"116 Stat. 1888","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/385/tII/s207"},"text":"Pub. L. 115–385, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5140"},"text":"132 Stat. 5140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ce85868-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ce85869-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ce8586a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5661"},"text":"section 5661 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ce8586b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s207/1/A/i"},"text":"Pub. L. 115–385, § 207(1)(A)(i)","children":[],"tail":", substituted “shall” for “may” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s207/1/A/ii"},"text":"Pub. L. 115–385, § 207(1)(A)(ii)","children":[],"tail":", substituted “annually publish a plan to identify” for “plan and identify”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s207/1/A/iii/I"},"text":"Pub. L. 115–385, § 207(1)(A)(iii)(I)","children":[],"tail":", added cl. (iii) and struck out former cl. (iii) which read as follows: “successful efforts to prevent first-time minor offenders from committing subsequent involvement in serious crime;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(vii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s207/1/A/iii/II"},"text":"Pub. L. 115–385, § 207(1)(A)(iii)(II)","children":[],"tail":", added cl. (vii) and struck out former cl. (vii) which read as follows: “appropriate mental health services for juveniles and youth at risk of participating in delinquent activities;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(ix) to (xviii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s207/1/A/iii/III"},"text":