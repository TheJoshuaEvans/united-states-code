{"tag":"section","attrib":{"id":"id4d099c15-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464"},"text":null,"children":[{"tag":"num","attrib":{"value":"12464"},"text":"§ 12464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to support families in the justice system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d099c16-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may make grants to States, units of local government, courts (including juvenile courts), Indian tribal governments, nonprofit organizations, legal services providers, and victim services providers to improve the response of all aspects of the civil and criminal justice system to families with a history of domestic violence, dating violence, sexual assault, or stalking, or in cases involving allegations of child sexual abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d099c17-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099c18-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide supervised visitation and safe visitation exchange of children and youth by and between parents in situations involving domestic violence, dating violence, child sexual abuse, sexual assault, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c19-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and promote State, local, and tribal legislation, policies, and best practices for improving civil and criminal court functions, responses, practices, and procedures in cases involving a history of domestic violence or sexual assault, or in cases involving allegations of child sexual abuse, including cases in which the victim proceeds pro se;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c1a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate court-based and court-related personnel and court-appointed personnel (including custody evaluators and guardians ad litem) and child protective services workers on the dynamics of domestic violence, dating violence, sexual assault, and stalking, including information on perpetrator behavior, evidence-based risk factors for domestic and dating violence homicide, and on issues relating to the needs of victims, including safety, security, privacy, and confidentiality, including cases in which the victim proceeds pro se;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c1b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate resources in juvenile court matters to respond to dating violence, domestic violence, sexual assault (including child sexual abuse), and stalking and ensure necessary services dealing with the health and mental health of victims are available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c1c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enable courts or court-based or court-related programs to develop or enhance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d099c1d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" court infrastructure (such as specialized courts, consolidated courts, dockets, intake centers, or interpreter services);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c1e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based initiatives within the court system (such as court watch programs, victim assistants, pro se victim assistance programs, or community-based supplementary services);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c1f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offender management, monitoring, and accountability programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c20-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safe and confidential information-storage and information-sharing databases within and between court systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c21-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and outreach programs to improve community access, including enhanced access for underserved populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c22-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other projects likely to improve court responses to domestic violence, dating violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c23-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide civil legal assistance and advocacy services, including legal information and resources in cases in which the victim proceeds pro se, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d099c24-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victims of domestic violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c25-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nonoffending parents in matters—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d099c26-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that involve allegations of child sexual abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d099c27-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that relate to family matters, including civil protection orders, custody, and divorce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d099c28-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the other parent is represented by counsel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c29-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect data and provide training and technical assistance, including developing State, local, and tribal model codes and policies, to improve the capacity of grantees and communities to address the civil justice needs of victims of domestic violence, dating violence, sexual assault, and stalking who have legal representation, who are proceeding pro se, or who are proceeding with the assistance of a legal advocate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c2a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve training and education to assist judges, judicial personnel, attorneys, child welfare personnel, and legal advocates in the civil justice system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d099c2b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099c2c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants for purposes described in paragraphs (1) through (7) of subsection (b), the Attorney General shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d099c2d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of families to be served by the proposed programs and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c2e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the proposed programs and services serve underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c2f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant demonstrates cooperation and collaboration with nonprofit, nongovernmental entities in the local community with demonstrated histories of effective work on domestic violence, dating violence, sexual assault, or stalking, including State or tribal domestic violence coalitions, State or tribal sexual assault coalitions, local shelters, and programs for domestic violence and sexual assault victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c30-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant demonstrates coordination and collaboration with State, tribal, and local court systems, including mechanisms for communication and referral.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c31-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under subsection (b)(8) the Attorney General shall take into account the extent to which the grantee has expertise addressing the judicial system’s handling of family violence, child custody, child abuse and neglect, adoption, foster care, supervised visitation, divorce, and parentage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d099c32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicant requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make a grant under this section to an applicant that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099c33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates expertise in the areas of domestic violence, dating violence, sexual assault, stalking, or child sexual abuse, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that any fees charged to individuals for use of supervised visitation programs and services are based on the income of those individuals, unless otherwise provided by court order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a court-based program, certifies that victims of domestic violence, dating violence, sexual assault, or stalking are not charged fees or any other costs related to the filing, petitioning, modifying, issuance, registration, enforcement, withdrawal, or dismissal of matters relating to the domestic violence, dating violence, sexual assault, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that adequate security measures, including adequate facilities, procedures, and personnel capable of preventing violence, and adequate standards are, or will be, in place (including the development of protocols or policies to ensure that confidential information is not shared with courts, law enforcement agencies, or child welfare agencies unless necessary to ensure the safety of any child or adult using the services of a program funded under this section), if the applicant proposes to operate supervised visitation programs and services or safe visitation exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that the organizational policies of the applicant do not require mediation or counseling involving offenders and victims being physically present in the same place, in cases where domestic violence, dating violence, sexual assault, or stalking is alleged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that any person providing legal assistance through a program funded under this section has completed or will complete training on domestic violence, dating violence, sexual assault, and stalking, including child sexual abuse, and related legal issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifies that any person providing custody evaluation or guardian ad litem services through a program funded under this section has completed or will complete training developed with input from and in collaboration with a tribal, State, territorial, or local domestic violence, dating violence, sexual assault, or stalking victim service provider or coalition on the dynamics of domestic violence and sexual assault, including child sexual abuse, that includes training on how to review evidence of past abuse and the use of evidenced-based theories to make recommendations on custody and visitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d099c3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $22,000,000 for each of fiscal years 2023 through 2027. Amounts appropriated pursuant to this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d099c3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment for Indian tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099c3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 percent of the total amount available under this section for each fiscal year shall be available for grants under the program authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10452"},"text":"section 10452 of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of part ","children":[{"tag":"ref","attrib":{"idref":"fn002124"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002124"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “section”."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall not apply to funds allocated for the program described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d099c3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12464/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cultural relevance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any services provided pursuant to a grant funded under this section shall be provided in a culturally relevant manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d099c3f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tIII/s1301"},"text":"Pub. L. 106–386, div. B, title III, § 1301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tI/s104/a"},"text":"Pub. L. 113–4, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/73"},"text":"127 Stat. 73","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tI/s104"},"text":"Pub. L. 117–103, div. W, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/851"},"text":"136 Stat. 851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d099c40-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d099c41-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d099c42-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10452"},"text":"Section 10452 of this title","children":[],"tail":", referred to in subsec. (f)(1), was in the original “"},{"tag":"ref","attrib":{"href":"/us/usc/t3