{"tag":"section","attrib":{"id":"id4cbd502a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401"},"text":null,"children":[{"tag":"num","attrib":{"value":"10401"},"text":"§ 10401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd502b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to provide grants to States, for use by States and units of local government, and in certain cases directly to specially qualified units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd502c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts paid to a State or a unit of local government under this subchapter shall be used by the State or unit of local government for the purpose of strengthening the juvenile justice system, which includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd502d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, implementing, and administering graduated sanctions for juvenile offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd502e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building, expanding, renovating, or operating temporary or permanent juvenile correction, detention, or community corrections facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd502f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring juvenile court judges, probation officers, and court-appointed defenders and special advocates, and funding pretrial services (including mental health screening and assessment) for juvenile offenders, to promote the effective and expeditious administration of the juvenile justice system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5030-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring additional prosecutors, so that more cases involving violent juvenile offenders can be prosecuted and case backlogs reduced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5031-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing funding to enable prosecutors to address drug, gang, and youth violence problems more effectively and for technology, equipment, and training to assist prosecutors in identifying and expediting the prosecution of violent juvenile offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5032-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining training programs for law enforcement and other court personnel with respect to preventing and controlling juvenile crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5033-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing juvenile gun courts for the prosecution and adjudication of juvenile firearms offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5034-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing drug court programs for juvenile offenders that provide continuing judicial supervision over juvenile offenders with substance abuse problems and the integrated administration of other sanctions and services for such offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5035-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining a system of juvenile records designed to promote public safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5036-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining interagency information-sharing programs that enable the juvenile and criminal justice systems, schools, and social services agencies to make more informed decisions regarding the early identification, control, supervision, and treatment of juveniles who repeatedly commit serious delinquent or criminal acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5037-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining accountability-based programs designed to reduce recidivism among juveniles who are referred by law enforcement personnel or agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5038-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining programs to conduct risk and need assessments of juvenile offenders that facilitate the effective early intervention and the provision of comprehensive services, including mental health screening and treatment and substance abuse testing and treatment to such offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5039-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining accountability-based programs that are designed to enhance school safety, which programs may include research-based bullying, cyberbullying, and gang prevention programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd503a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining restorative justice programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd503b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining programs to enable juvenile courts and juvenile probation officers to be more effective and efficient in holding juvenile offenders accountable and reducing recidivism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd503c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring detention and corrections personnel, and establishing and maintaining training programs for such personnel to improve facility practices and programming; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd503d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing, improving, and coordinating pre-release and post-release systems and programs to facilitate the successful reentry of juvenile offenders from State or local custody in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd503e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section the term “restorative justice program” means a program that emphasizes the moral accountability of an offender toward the victim and the affected community and may include community reparations boards, restitution (in the form of monetary payment or service to the victim or, where no victim can be identified, service to the affected community), and mediation between victim and offender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd503f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1801"},"text":"Pub. L. 90–351, title I, § 1801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1859"},"text":"116 Stat. 1859","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI"},"text":"Pub. L. 109–162, title XI","children":[],"tail":", §§ 1165, 1186, "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3121"},"text":"119 Stat. 3121","children":[],"tail":", 3127.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd5040-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd5041-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd5042-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee"},"text":"section 3796ee of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbd5043-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1801"},"text":"section 1801 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20201/a/3"},"text":"Pub. L. 103–322, title II, § 20201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1819"},"text":"108 Stat. 1819","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s405/d/34"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 405(d)(34), (f)(26)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–426, 2681–433, authorized grants for the purpose of developing alternative methods of punishment for young offenders, prior to the general amendment of part R of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1801"},"text":"section 1801 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2601 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10541"},"text":"section 10541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbd5044-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1186"},"text":"Pub. L. 109–162, § 1186","children":[],"tail":", amended par. (13) generally. Prior to amendment, par. (13) read as follows: “establishing and maintaining accountability-based programs that are designed to enhance school safety;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1165"},"text":"Pub. L. 109–162, § 1165","children":[],"tail":", added par. (17)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cbd5045-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4cbd5046-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/b"},"text":"Pub. L. 107–273, div. C, title II, § 12102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1869"},"text":"116 Stat. 1869","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/273/dC/tII/s12102/b"},"text":"“The amendments made by subsection (a) [enacting this subchapter] shall take effect on the first day of the first fiscal year that begins after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
