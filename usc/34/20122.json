{"tag":"section","attrib":{"id":"id4d1f1ff6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122"},"text":null,"children":[{"tag":"num","attrib":{"value":"20122"},"text":"§ 20122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education, training, and enhanced services to end violence against and abuse of individuals with disabilities and Deaf people","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1ff7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Secretary of Health and Human Services, may award grants to eligible entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1ff8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training, consultation, and information on domestic violence, dating violence, stalking, sexual assault, and abuse by caregivers against individuals with disabilities (as defined in section 3 of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102"},"text":"42 U.S.C. 12102","children":[],"tail":")) and Deaf people; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1ff9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance direct services to such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1ffa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1ffb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide personnel, training, technical assistance, advocacy, intervention, risk reduction (including using evidence-based indicators to assess the risk of domestic and dating violence homicide) and prevention of domestic violence, dating violence, stalking, and sexual assault against individuals with disabilities and Deaf people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1ffc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct outreach activities to ensure that individuals with disabilities and Deaf people who are victims of domestic violence, dating violence, stalking, or sexual assault receive appropriate assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1ffd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct cross-training for victim service organizations, governmental agencies, courts, law enforcement and other first responders, and nonprofit, nongovernmental organizations serving individuals with disabilities about risk reduction, intervention, prevention and the nature of domestic violence, dating violence, stalking, and sexual assault for individuals with disabilities and Deaf people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1ffe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to assist with modifications to existing policies, protocols, and procedures to ensure equal access to the services, programs, and activities of victim service providers for individuals with disabilities and Deaf people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1fff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide training and technical assistance on the requirements of shelters and victim service providers under Federal antidiscrimination laws, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1f2000-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Americans with Disabilities Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f2001-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of title 29","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f2002-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modify facilities, purchase equipment, and provide personnel so that shelters and victim service organizations can accommodate the needs of individuals with disabilities and Deaf people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f2003-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide advocacy and intervention services for individuals with disabilities and Deaf people who are victims of domestic violence, dating violence, stalking, or sexual assault; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f2004-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop model programs to enhance the capacity of organizations serving individuals with disabilities and Deaf people who are victims of domestic violence, dating violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f2005-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f2006-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall be eligible to receive a grant under this section if the entity is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1f2007-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f2008-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f2009-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribal government or tribal organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f200a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider, such as a State or tribal domestic violence or sexual assault coalition or a nonprofit, nongovernmental organization serving individuals with disabilities and Deaf people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f200b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded for the purpose described in subsection (b)(8) shall only be awarded to an eligible agency (as defined in section 796f–5 ","children":[{"tag":"ref","attrib":{"idref":"fn002156"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002156"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 29)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f200c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Director shall ensure that the needs of underserved populations are being addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f200d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $15,000,000 for each of fiscal years 2023 through 2027 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f200e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tIV/s1402"},"text":"Pub. L. 106–386, div. B, title IV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1513"},"text":"114 Stat. 1513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tII/s204/a"},"text":"Pub. L. 109–162, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3000"},"text":"119 Stat. 3000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tII/s203"},"text":"Pub. L. 113–4, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/82"},"text":"127 Stat. 82","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tII/s203"},"text":"Pub. L. 117–103, div. W, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/857"},"text":"136 Stat. 857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f200f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1f2010-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d1f2011-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Americans with Disabilities Act of 1990, referred to in subsec. (b)(5)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/336"},"text":"Pub. L. 101–336","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-26"},"text":"July 26, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/327"},"text":"104 Stat. 327","children":[],"tail":", which is classified principally to chapter 126 (§ 12101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"section 12101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–5"},"text":"Section 796f–5 of title 29","children":[],"tail":", referred to in subsec. (c)(2), was in the original “section 410 of the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s796f–5"},"text":"29 U.S.C. 796f–5","children":[],"tail":")” and was translated as meaning section 726 of the Rehabilitation Act of 1973, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1f2012-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–7"},"text":"section 3796gg–7 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d1f2013-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/1"},"text":"Pub. L. 117–103, § 203(1)","children":[],"tail":", substituted “individuals with disabilities and Deaf people” for “women with disabilities” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/2"},"text":"Pub. L. 117–103, § 203(2)","children":[],"tail":", substituted “sexual assault, and abuse by caregivers” for “and sexual assault” and inserted “and Deaf people” after “with disabilities (as defined in section 3 of the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102"},"text":"42 U.S.C. 12102","children":[],"tail":"))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/3/A"},"text":"Pub. L. 117–103, § 203(3)(A)","children":[],"tail":", substituted “individuals with disabilities and Deaf people” for “disabled individuals” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/3/B"},"text":"Pub. L. 117–103, § 203(3)(B)","children":[],"tail":", inserted “and other first responders” after “law enforcement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/3/C"},"text":"Pub. L. 117–103, § 203(3)(C)","children":[],"tail":", substituted “to enhance the capacity of” for “providing advocacy and intervention services within”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/4"},"text":"Pub. L. 117–103, § 203(4)","children":[],"tail":", substituted “individuals with disabilities and Deaf people” for “disabled individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s203/5"},"text":"Pub. L. 117–103, § 203(5)","children":[],"tail":", substituted “$15,000,000” for “$9,000,000” and “2023 through 2027” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s203/1/A"},"text":"Pub. L. 113–4, § 203(1)(A)","children":[],"tail":", inserted “(including using evidence-based indicators to assess the risk of domestic and dating violence homicide)” after “risk reduction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s203/1/B"},"text":"Pub. L. 113–4, § 203(1)(B)","children":[],"tail":", substituted “victim service providers” for “victim service organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s203/1/C"},"text":"Pub. L. 113–4, § 203(1)(C)","children":[],"tail":", substituted “victim service providers” for “victim services organizations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s203/2"},"text":"Pub. L. 113–4, § 203(2)","children":[],"tail":", substituted “victim service provider, such as a State or tribal” for “nonprofit and nongovernmental victim services organization, such as a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s203/3"},"text":"Pub. L. 113–4, § 203(3)","children":[],"tail":", substituted “$9,000,000 for each of fiscal years 2014 through 2018” for “$10,000,000 for each of the fiscal years 2007 through 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" substituted “Education, training, and enhanced services to end violence against and abuse of women with disabilities” for “Education and training to end violence against and abuse of women with disabilities” in section catchline and amended text generally. Prior to amendment, text consisted of subsecs. (a) to (d) relating to award of grants to provide education and technical assistance for the purpose of providing training, consultation, and information on domestic violence, stalking, and sexual assault against women who are individuals with disabilities and authorized appropriations for fiscal years 2001 through 2005."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d1f2014-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d1f2015-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d1f2016-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d1f2017-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" not effective until the beginning of fiscal year 2007, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s4"},"text":"section 4 of Pub. L. 109–162","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10261"},"text":"section 10261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d1f2018-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1002"},"text":"section 1002 of Pub. L. 106–386","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10447"},"text":"section 10447 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
