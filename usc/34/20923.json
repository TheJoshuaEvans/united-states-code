{"tag":"section","attrib":{"id":"id4d34a47a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923"},"text":null,"children":[{"tag":"num","attrib":{"value":"20923"},"text":"§ 20923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Megan Nicole Kanka and Alexandra Nicole Zapp Community Notification Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d34a47b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Megan Nicole Kanka and Alexandra Nicole Zapp Community Notification Program (hereinafter in this section referred to as the “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a47c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), immediately after a sex offender registers or updates a registration, an appropriate official in the jurisdiction shall provide the information in the registry (other than information exempted from disclosure by the Attorney General) about that offender to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d34a47d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General, who shall include that information in the National Sex Offender Registry or other appropriate databases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a47e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate law enforcement agencies (including probation agencies, if appropriate), and each school and public housing agency, in each area in which the individual resides, is an employee or is a student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a47f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each jurisdiction where the sex offender resides, is an employee, or is a student, and each jurisdiction from or to which a change of residence, employment, or student status occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a480-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any agency responsible for conducting employment-related background checks under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40102"},"text":"section 40102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a481-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Social service entities responsible for protecting minors in the child welfare system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ed72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Volunteer organizations in which contact with minors or other vulnerable individuals might occur.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ed73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any organization, company, or individual who requests such notification pursuant to procedures established by the jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ed74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (b), an organization or individual described in subsection (b)(6) or (b)(7) may opt to receive the notification described in that subsection no less frequently than once every five business days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36ed75-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s121"},"text":"Pub. L. 109–248, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/597"},"text":"120 Stat. 597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36ed76-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36ed77-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36ed78-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16921"},"text":"section 16921 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
