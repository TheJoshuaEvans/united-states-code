{"tag":"section","attrib":{"id":"id4d2b0611-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305"},"text":null,"children":[{"tag":"num","attrib":{"value":"20305"},"text":"§ 20305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for specialized technical assistance and training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d2b0612-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make grants to national organizations to provide technical assistance and training to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2b0613-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecutors and other attorneys and allied professionals instrumental to the criminal prosecution of child abuse cases in State or Federal courts, for the purpose of improving the quality of criminal prosecution of such cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2b0614-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" child abuse professionals instrumental to the protection of children, intervention in child abuse cases, and treatment of victims of child abuse, for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2b0615-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the quality of such protection, intervention, and treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b0616-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the effective delivery of the evidence-informed Children’s Advocacy Center Model and the multidisciplinary response to child abuse, including best practices in programmatic evaluation and financial oversight of Federal funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2b0617-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2b0618-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prosecutors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization to which a grant is made for specific training and technical assistance for prosecutors under subsection (a)(1) shall be one that has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2b0619-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant connection to prosecutors who handle child abuse cases in State courts, such as a membership organization or support service providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b061a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated experience in providing training and technical assistance for prosecutors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2b061b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child abuse professionals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An organization to which a grant is made for specific training and technical assistance for child abuse professionals under subsection (a)(2) shall be one that has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d2b061c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a diverse portfolio of training and technical resources for the diverse professionals responding to child abuse, including a digital library to promote evidence-informed practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d2b061d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated experience in providing training and technical assistance for child abuse professionals, especially law enforcement officers, child protective service workers, prosecutors, forensic interviewers, medical professionals, victim advocates, and mental health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2b061e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2b061f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall establish the criteria to be used for evaluating applications for grants under this section, consistent with sections 11183 and 11186 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2b0620-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The grant criteria established pursuant to paragraph (1) shall require, in the case of a grant made under subsection (a)(1), that a program provide training and technical assistance that includes information regarding improved child interview techniques, thorough investigative methods, interagency coordination and effective presentation of evidence in court, including the use of alternative courtroom procedures described in this title.","children":[{"tag":"ref","attrib":{"idref":"fn002171"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002171"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2b0621-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s214A"},"text":"Pub. L. 101–647, title II, § 214A","children":[],"tail":", formerly § 213, "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4793"},"text":"104 Stat. 4793","children":[],"tail":"; renumbered § 214A and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s6/b/1"},"text":"Pub. L. 102–586, § 6(b)(1)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5029"},"text":"106 Stat. 5029","children":[],"tail":", 5034; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12221/b/1/B"},"text":"Pub. L. 107–273, div. C, title II, § 12221(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1894"},"text":"116 Stat. 1894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/e"},"text":"Pub. L. 115–424, § 2(e)","children":[],"tail":", (h)(3), "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5469"},"text":"132 Stat. 5469","children":[],"tail":", 5470; "},{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/5"},"text":"Pub. L. 117–354, § 3(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6276"},"text":"136 Stat. 6276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2b0622-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2b0623-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d2b0624-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c)(2), means title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", known as the Victims of Child Abuse Act of 1990, which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title of 1990 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2b0625-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13003"},"text":"section 13003 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d2b0626-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/5/A/i"},"text":"Pub. L. 117–354, § 3(5)(A)(i)","children":[],"tail":", substituted “prosecutors and other attorneys and allied” for “attorneys and other allied”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/5/A/ii"},"text":"Pub. L. 117–354, § 3(5)(A)(ii)","children":[],"tail":", inserted “Center” after “Advocacy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/5/B"},"text":"Pub. L. 117–354, § 3(5)(B)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “a broad representation of attorneys who prosecute criminal cases in State courts; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/e/1"},"text":"Pub. L. 115–424, § 2(e)(1)","children":[],"tail":", substituted “to—” and pars. (1) and (2) for “to attorneys and others instrumental to the criminal prosecution of child abuse cases in State or Federal courts, for the purpose of improving the quality of criminal prosecution of such cases.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/e/2"},"text":"Pub. L. 115–424, § 2(e)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “An organization to which a grant is made pursuant to subsection (a) shall be one that has, or is affiliated with one that has, broad membership among attorneys who prosecute criminal cases in State courts and has demonstrated experience in providing training and technical assistance for prosecutors.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/h/3"},"text":"Pub. L. 115–424, § 2(h)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to sections 11183 and 11186 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/e/3"},"text":"Pub. L. 115–424, § 2(e)(3)","children":[],"tail":", inserted “, in the case of a grant made under subsection (a)(1),” after “shall require”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “sections 5673 and 5676 of this title” for “sections 5665a, 5673, and 5676 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsecs. (a), (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s6/d"},"text":"Pub. L. 102–586, § 6(d)","children":[],"tail":", substituted “Administrator” for “Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d2b0627-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d2b0628-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" effective on the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", and applicable only with respect to fiscal years beginning on or after the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s12223"},"text":"section 12223 of Pub. L. 107–273","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
