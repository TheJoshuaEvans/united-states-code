{"tag":"section","attrib":{"id":"id4d133903-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12551"},"text":null,"children":[{"tag":"num","attrib":{"value":"12551"},"text":"§ 12551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this part are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d133904-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12551/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address violent crime by increasing the number of police with advanced education and training on community patrol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133905-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12551/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide educational assistance to law enforcement personnel and to students who possess a sincere interest in public service in the form of law enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d133906-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200102"},"text":"Pub. L. 103–322, title XX, § 200102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2049"},"text":"108 Stat. 2049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d133907-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d133908-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr