{"tag":"section","attrib":{"id":"id4cce19bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10553"},"text":null,"children":[{"tag":"num","attrib":{"value":"10553"},"text":"§ 10553.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress; grant accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cce19c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10553/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than November 30th of each year, the COPS Director and the BJA Director shall each submit a report to the Congress regarding the activities carried out under this subchapter. Each such report shall include, for the preceding fiscal year, the number of grants funded under this subchapter, the amount of funds provided under those grants, and the activities for which those funds were used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cce19c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10553/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant accountability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10706"},"text":"Section 10706 of this title","children":[],"tail":" (relating to grant accountability) shall apply to grants awarded by the COPS Director and the BJA Director under this subchapter. For purposes of the preceding sentence, any references in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10706"},"text":"section 10706 of this title","children":[],"tail":" to the Attorney General shall be considered references to the COPS Director or the BJA Director, as appropriate, and any references in that section to subchapter XXXVIII shall be considered references to this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cce19c2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2703"},"text":"Pub. L. 90–351, title I, § 2703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI/s1108/b"},"text":"Pub. L. 106–386, div. B, title I, § 1108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1502"},"text":"114 Stat. 1502","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/j/2"},"text":"Pub. L. 109–271, § 8(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/767"},"text":"120 Stat. 767","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tV/s502/3"},"text":"Pub. L. 115–141, div. S, title V, § 502(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1130"},"text":"132 Stat. 1130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cce19c3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cce19c4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cce19c5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797c"},"text":"section 3797c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cce19c6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/3/A"},"text":"Pub. L. 115–141, § 502(3)(A)","children":[],"tail":", inserted “; grant accountability” after “Congress” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s502/3/B"},"text":"Pub. L. 115–141, § 502(3)(B)","children":[],"tail":"–(D), designated existing provisions as subsec. (a), inserted heading, substituted “COPS Director and the BJA Director shall each” for “Director shall”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":" substituted “Director” for “Attorney General”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
