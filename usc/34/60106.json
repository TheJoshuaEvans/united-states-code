{"tag":"section","attrib":{"id":"id4d61f52c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106"},"text":null,"children":[{"tag":"num","attrib":{"value":"60106"},"text":"§ 60106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d61f52d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General is authorized to make grants to States that have in effect a law that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f52e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes it a criminal offense for any person acting under color of law of the State to knowingly engage in a sexual act with an individual who is under arrest, in detention, or otherwise in the actual custody of any law enforcement officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f52f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibits a person charged with an offense described in paragraph (1) from asserting the consent of the other individual as a defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f530-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives a grant under this section shall submit to the Attorney General, on an annual basis, information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f531-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of reports made to law enforcement agencies in that State regarding persons engaging in a sexual act while acting under color of law during the previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f532-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of each case in which sexual misconduct by a person acting under color of law was reported during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f533-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State seeking a grant under this section shall submit an application to the Attorney General at such time, in such manner, and containing such information as the Attorney General may reasonably require, including information about the law described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f534-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant to a State under this section shall be in an amount that is not greater than 10 percent of the average of the total amount of funding of the 3 most recent awards that the State received under the following grant programs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f535-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part T of title I of the Omnibus Crime Control and Safe Streets Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10441"},"text":"34 U.S.C. 10441","children":[],"tail":" et seq.) (commonly referred to as the “STOP Violence Against Women Formula Grant Program”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f536-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12511"},"text":"Section 12511 of this title","children":[],"tail":" (commonly referred to as the “Sexual Assault Services Program”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f537-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f538-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide an increase in the amount provided to a State under the grant programs described in subsection (d) for a 2-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f539-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this section may submit an application for a renewal of such grant at such time, in such manner, and containing such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f53a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not receive a grant under this section for more than 4 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f53b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives a grant under this section shall use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f53c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of such funds for any of the permissible uses of funds under the grant program described in paragraph (1) of subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f53d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of such funds for any of the permissible uses of funds under the grant program described in paragraph (2) of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f53e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f53f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60106/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “State” means each of the several States and the District of Columbia, Indian Tribes, and the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f540-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1203"},"text":"Pub. L. 117–103, div. W, title XII, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/925"},"text":"136 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f541-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f542-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d61f543-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Omnibus Crime Control and Safe Streets Act of 1968, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/197"},"text":"82 Stat. 197","children":[],"tail":". Part T of title I of the Act is classified principally to subchapter XIX (§ 10441 et seq.) of chapter 101 of this title. For complete classification of this Act to the Code, see Short Title of 1968 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d61f544-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d61f545-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d61f546-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1204"},"text":"Pub. L. 117–103, div. W, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/926"},"text":"136 Stat. 926","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dW/tXII/s1204"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report by Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":"], and each year thereafter, the Attorney General shall submit to Congress and make publicly available on the Department of Justice website a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be reported to the Attorney General under section 1203(b) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60106/b"},"text":"34 U.S.C. 60106(b)","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of reports made, during the previous year, to Federal law enforcement agencies regarding persons engaging in a sexual act while acting under color of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of each case in which sexual misconduct by a person acting under color of law was reported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report by GAO","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act, and each year thereafter, the Comptroller General of the United States shall submit to Congress a report on any violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2243/c"},"text":"section 2243(c) of title 18","children":[],"tail":", United States Code, as amended by section 1302, committed during the 1-year period covered by the report."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report by Attorney General on Conflicts Between State’s Marriage-age and Age-based Sex Offenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act, and each year thereafter, the Attorney General shall submit to Congress a report that examines inconsistencies between State laws on marriage-age and State laws on age-based sex offenses and, in particular, States with laws that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an exception to definitions of age-based sex offenses (including statutory rape), or a defense to prosecution for such offenses, based on the marriage of the perpetrator to the victim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow marriages between parties at ages, or with age differences between them, such that sexual acts between those parties outside of marriage would constitute an age-based sex offense (including statutory rape).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s1204"},"text":"section 1204 of div. W of Pub. L. 117–103","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":", as made applicable by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s2/b"},"text":"section 2(b) of div. W of Pub. L. 117–103","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1205"},"text":"section 1205 of Pub. L. 117–103","children":[],"tail":", set out below.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d61f547-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXII/s1205"},"text":"Pub. L. 117–103, div. W, title XII, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/927"},"text":"136 Stat. 927","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/103/dW/tXII/s1205"},"text":"“In this title [see Short Title of 2022 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of Title 18","children":[],"tail":", Crimes and Criminal Procedure], the term ‘sexual act’ has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2246"},"text":"section 2246 of title 18","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of other terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":", as made applicable by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s2/b"},"text":"section 2(b) of div. W of Pub. L. 117–103","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
