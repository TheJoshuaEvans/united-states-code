{"tag":"section","attrib":{"id":"id4cb89537-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302"},"text":null,"children":[{"tag":"num","attrib":{"value":"10302"},"text":"§ 10302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cb89538-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb89539-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Attorney General shall provide financial assistance to a person who attends a program of education and is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cb8953a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the child of any eligible public safety officer under part A; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cb8953b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the spouse of an officer described in subparagraph (A) at the time of the officer’s death or on the date of a totally and permanently disabling injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb8953c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), financial assistance under this part shall consist of direct payments to an eligible person and shall be computed on the basis set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3532"},"text":"section 3532 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb8953d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The financial assistance referred to in paragraph (2) shall be reduced by the amount, if any, determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10304/b"},"text":"section 10304(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb8953e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall receive assistance under this part for a period in excess of forty-five months of full-time education or training or a proportional period of time for a part-time program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb8953f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age limitation for children","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb89540-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), no child shall be eligible for assistance under this part after the child’s 27th birthday absent a finding by the Attorney General of extraordinary circumstances precluding the child from pursuing a program of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89541-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delayed approvals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cb89542-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Educational assistance application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a claim for assistance under this part is approved more than 1 year after the date on which the application for such assistance is filed with the Attorney General, the age limitation under this subsection shall be extended by the length of the period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cb89543-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the day after the date that is 1 year after the date on which the application is filed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cb89544-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date on which the application is approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cb89545-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim for benefits for death or permanent and total disability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to an extension under subparagraph (A), if any, for an application for assistance under this part that relates to a claim for benefits under part A that was approved more than 1 year after the date on which the claim was filed with the Attorney General, the age limitation under this subsection shall be extended by the length of the period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cb89546-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the day after the date that is 1 year after the date on which the claim for benefits is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cb89547-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10302/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the date on which the claim for benefits is approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cb89548-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1212"},"text":"Pub. L. 90–351, title I, § 1212","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/238/s2/2"},"text":"Pub. L. 104–238, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3114"},"text":"110 Stat. 3114","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/390/s2/3"},"text":"Pub. L. 105–390, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3495"},"text":"112 Stat. 3495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1086/b/1/G"},"text":"Pub. L. 112–239, div. A, title X, § 1086(b)(1)(G)","children":[],"tail":", (H), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1968"},"text":"126 Stat. 1968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/36/s3"},"text":"Pub. L. 115–36, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-02"},"text":"June 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/851"},"text":"131 Stat. 851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb89549-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb8954a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb8954b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796d–1"},"text":"section 3796d–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cb8954c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/36"},"text":"Pub. L. 115–36","children":[],"tail":" designated existing provisions as par. (1) and inserted heading, substituted “Subject to paragraph (2), no child” for “No child”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/G"},"text":"Pub. L. 112–239, § 1086(b)(1)(G)","children":[],"tail":", substituted “person” for “dependent” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/H/i/I"},"text":"Pub. L. 112–239, § 1086(b)(1)(H)(i)(I)","children":[],"tail":", substituted “The” for “Subject to the availability of appropriations, the” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/H/i/II"},"text":"Pub. L. 112–239, § 1086(b)(1)(H)(i)(II)","children":[],"tail":", substituted “reduced by the amount” for “reduced by the sum of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the amount of educational assistance benefits from other Federal, State, or local governmental sources to which the eligible dependent would otherwise be entitled to receive; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the amount”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/G"},"text":"Pub. L. 112–239, § 1086(b)(1)(G)","children":[],"tail":", substituted “person” for “dependent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/H/ii"},"text":"Pub. L. 112–239, § 1086(b)(1)(H)(ii)","children":[],"tail":", struck out “dependent” before “children” in heading and before “child shall” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/390/s2/3/A"},"text":"Pub. L. 105–390, § 2(3)(A)","children":[],"tail":", substituted “public safety” for “Federal law enforcement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/390/s2/3/B"},"text":"Pub. L. 105–390, § 2(3)(B)","children":[],"tail":", substituted “Except as provided in paragraph (3), financial” for “Financial”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/390/s2/3/C"},"text":"Pub. L. 105–390, § 2(3)(C)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cb8954d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cb8954e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/36"},"text":"Pub. L. 115–36","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2017-06-02"},"text":"June 2, 2017","children":[],"tail":", and applicable to any benefit claim or application under this subchapter pending before the Bureau of Justice Assistance on such date or received by the Bureau on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/36/s6"},"text":"section 6 of Pub. L. 115–36","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10282"},"text":"section 10282 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cb8954f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", and applicable to matters pending on "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", or filed or accruing after that date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/d"},"text":"section 1086(d) of Pub. L. 112–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10251"},"text":"section 10251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
