{"tag":"section","attrib":{"id":"id4d643f15-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505"},"text":null,"children":[{"tag":"num","attrib":{"value":"60505"},"text":"§ 60505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit and accountability of grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d643f16-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f17-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered grant program” means grants awarded under section 60511, 60521, or 60531 of this title, as amended by this title; ","children":[{"tag":"ref","attrib":{"idref":"fn002233"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002233"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f18-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered grantee” means a recipient of a grant from a covered grant program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f19-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “nonprofit”, when used with respect to an organization, means an organization that is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":", and is exempt from taxation under section 501(a) of such title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f1a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unresolved audit finding” means an audit report finding in a final audit report of the Inspector General of the Department of Justice that a covered grantee has used grant funds awarded to that grantee under a covered grant program for an unauthorized expenditure or otherwise unallowable cost that is not closed or resolved during a 12-month period prior to the date on which the final audit report is issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f1b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning in fiscal year 2019, and annually thereafter, the Inspector General of the Department of Justice shall conduct audits of covered grantees to prevent waste, fraud, and abuse of funds awarded under covered grant programs. The Inspector General shall determine the appropriate number of covered grantees to be audited each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f1c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee that is found to have an unresolved audit finding under an audit conducted under subsection (b) may not receive grant funds under a covered grant program in the fiscal year following the fiscal year to which the finding relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f1d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a covered grantee is awarded funds under the covered grant program from which it received a grant award during the 1-fiscal-year period during which the covered grantee is ineligible for an allocation of grant funds under subsection (c), the Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f1e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit into the General Fund of the Treasury an amount that is equal to the amount of the grant funds that were improperly awarded to the covered grantee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f1f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to recoup the costs of the repayment to the Fund from the covered grantee that was improperly awarded the grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f20-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of grant awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in awarding grants under a covered grant program shall give priority to eligible entities that during the 2-year period preceding the application for a grant have not been found to have an unresolved audit finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f21-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f22-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A nonprofit organization that holds money in offshore accounts for the purpose of avoiding the tax described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s511/a"},"text":"section 511(a) of title 26","children":[],"tail":", shall not be eligible to receive, directly or indirectly, any funds from a covered grant program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f23-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each nonprofit organization that is a covered grantee shall disclose in its application for such a grant, as a condition of receipt of such a grant, the compensation of its officers, directors, and trustees. Such disclosure shall include a description of the criteria relied on to determine such compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f24-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on lobbying activity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f25-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available under a covered grant program may not be used by any covered grantee to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643f26-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobby any representative of the Department of Justice regarding the award of grant funding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f27-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobby any representative of the Federal Government or a State, local, or tribal government regarding the award of grant funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f28-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Attorney General determines that a covered grantee has violated paragraph (1), the Attorney General shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643f29-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the covered grantee to repay the grant in full; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f2a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60505/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the covered grantee from receiving a grant under the covered grant program from which it received a grant award during at least the 5-year period beginning on the date of such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f2b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s503"},"text":"Pub. L. 115–391, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5232"},"text":"132 Stat. 5232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f2c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f2d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d643f2e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"As amended by this title, referred to in subsec. (a)(1), means as amended by title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
