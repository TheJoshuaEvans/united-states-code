{"tag":"section","attrib":{"id":"id4d395dc3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981"},"text":null,"children":[{"tag":"num","attrib":{"value":"20981"},"text":"§ 20981.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program for monitoring sexual offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395dc4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sex offender monitoring program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395dc5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395dc6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General is authorized to award grants (referred to as “Jessica Lunsford and Sarah Lunde Grants”) to States, local governments, and Indian tribal governments to assist in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395dc7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out programs to outfit sex offenders with electronic monitoring units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395dc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of law enforcement officials necessary to carry out such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395dc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants under this section for a period not to exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395dca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The electronic monitoring units used in the pilot program shall at a minimum—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395dcb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a tracking device for each offender that contains a central processing unit with global positioning system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395dcc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit continuous monitoring of offenders 24 hours a day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dcd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395dce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State, local government, or Indian tribal government desiring a grant under this section shall submit an application to the Attorney General at such time, in such manner, and accompanied by such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395dcf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted pursuant to subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395dd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the activities for which assistance under this section is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395dd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such additional assurances as the Attorney General determines to be essential to ensure compliance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395dd2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Attorney General shall ensure that different approaches to monitoring are funded to allow an assessment of effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395dd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395dd4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for each of the fiscal years 2007 through 2009 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dd5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-09-01"},"text":"September 1, 2010","children":[],"tail":", the Attorney General shall report to Congress—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395dd6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the effectiveness and value of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395dd7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparing the cost effectiveness of the electronic monitoring to reduce sex offenses compared to other alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395dd8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20981/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations for continuing funding and the appropriate levels for such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395dd9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s621"},"text":"Pub. L. 109–248, title VI, § 621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/633"},"text":"120 Stat. 633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/400/s4/a"},"text":"Pub. L. 110–400, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4227"},"text":"122 Stat. 4227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395dda-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395ddb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395ddc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16981"},"text":"section 16981 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d395ddd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/400/s4/a"},"text":"Pub. L. 110–400, § 4(a)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) set minimum standards for electronic monitoring units used in the pilot program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d395dde-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d395ddf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/400/s4/b"},"text":"Pub. L. 110–400, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4228"},"text":"122 Stat. 4228","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/400/s4/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply to grants provided on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
