{"tag":"section","attrib":{"id":"id4d23da2c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131"},"text":null,"children":[{"tag":"num","attrib":{"value":"20131"},"text":"§ 20131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Media campaign","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23da2d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da2e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office on Violence Against Women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da2f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National media campaign","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national media campaign” means the national “Choose Respect” media campaign described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da30-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Media campaign","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, to the extent feasible and appropriate, conduct a national “Choose Respect” media campaign in accordance with this section for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da31-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing and discouraging violence against women, including domestic violence, dating violence, sexual assault, and stalking by targeting the attitudes, perceptions, and beliefs of individuals who have or are likely to commit such crimes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging victims of the crimes described in subparagraph (A) to seek help through the means determined to be most effective by the most current evidence available, including seeking legal representation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing the public about the help available to victims of the crimes described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts made available to carry out this section for the national media campaign may only be used for the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23da36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purchase of media time and space, including the strategic planning for, tracking, and accounting of, such purchases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creative and talent costs, consistent with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advertising production costs, which may include television, radio, internet, social media, and other commercial marketing venues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Testing and evaluation of advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation of the effectiveness of the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs of contracts to carry out activities authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Partnerships with professional and civic groups, community-based organizations, including faith-based organizations and culturally specific organizations, and government organizations related to the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Entertainment industry outreach, interactive outreach, media projects and activities, public information, news media outreach, corporate sponsorship and participation, and professional sports associations and military branch participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational and management expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da3f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23da40-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creative services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In using amounts for creative and talent costs under subparagraph (A), the Director shall use creative services donated at no cost to the Government wherever feasible and may only procure creative services for advertising—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d23da41-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responding to high-priority or emergent campaign needs that cannot timely be obtained at no cost; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da42-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intended to reach a minority, ethnic, or other special audience that cannot reasonably be obtained at no cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da43-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing and evaluation of advertising","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In using amounts for testing and evaluation of advertising under subparagraph (A)(iv), the Director shall test all advertisements prior to use in the national media campaign to ensure that the advertisements are effective with the target audience and meet industry-accepted standards. The Director may waive this requirement for advertisements using not more than 10 percent of the purchase of advertising time purchased under this section in a fiscal year and not more than 10 percent of the advertising space purchased under this section in a fiscal year, if the advertisements respond to emergent and time-sensitive campaign needs or the advertisements will not be widely utilized in the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da44-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the planning of the campaign under paragraph (2), the Director may consult with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d23da45-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office for Victims of Crime, the Administration on Children, Youth and Families, and other related Federal Government entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and Indian Tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of domestic violence, dating violence, sexual assault, or stalking, including national and local non-profits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of effectiveness of national media campaign","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In using amounts for the evaluation of the effectiveness of the national media campaign under subparagraph (A)(v), the Attorney General shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d23da4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an independent entity to evaluate by April 20 of each year the effectiveness of the national media campaign based on data from any relevant studies or publications, as determined by the Attorney General, including tracking and evaluation data collected according to marketing and advertising industry standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da4b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the effectiveness of the national media campaign is evaluated in a manner that enables consideration of whether the national media campaign has contributed to changes in attitude or behaviors among the target audience with respect to violence against women and such other measures of evaluation as the Attorney General determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da4c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertising","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subsection, the Director shall ensure that sufficient funds are allocated to meet the stated goals of the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities and functions under the program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall determine the overall purposes and strategy of the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23da50-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall approve—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d23da51-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategy of the national media campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da52-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all advertising and promotional material used in the national media campaign; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan for the purchase of advertising time and space for the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall be responsible for implementing a focused national media campaign to meet the purposes described in paragraph (2) and shall ensure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d23da55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information disseminated through the campaign is accurate and scientifically valid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d23da56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the campaign is designed using strategies demonstrated to be the most effective at achieving the goals and requirements of paragraph (2), which may include—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id4d23da57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a media campaign, as described in paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d23da58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local, regional, or population specific messaging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d23da59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of websites to publicize and disseminate information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d23da5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting outreach and providing educational resources for women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d23da5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborating with law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d23da5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/5/B/ii/II/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing support for school-based public health education classes to improve teen knowledge about the effects of violence against women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"None of the amounts made available under paragraph (3) may be obligated or expended for any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To supplant current antiviolence against women campaigns by community-based coalitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To supplant pro bono public service time donated by national and local broadcasting networks for other public service campaigns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For partisan political purposes, or to express advocacy in support of or to defeat any clearly identified candidate, clearly identified ballot initiative, or clearly identified legislative or regulatory proposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To fund advertising that features any elected officials, persons seeking elected office, cabinet level officials, or other Federal officials employed pursuant to schedule C of subpart C of title 5, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To fund advertising that does not contain a primary message intended to reduce or prevent violence against women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To fund advertising containing a primary message intended to promote support for the national media campaign or private sector contributions to the national media campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and performance accountability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall cause to be performed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" audits and reviews of costs of the national media campaign pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s4706"},"text":"section 4706 of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an audit to determine whether the costs of the national media campaign are allowable under chapter 43 of title 41.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit on an annual basis a report to Congress that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategy of the national media campaign and whether specific objectives of the national media campaign were accomplished;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to ensure that the national media campaign operates in an effective and efficient manner consistent with the overall strategy and focus of the national media campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans to purchase advertising time and space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and practices implemented to ensure that Federal funds are used responsibly to purchase advertising time and space and eliminate the potential for waste, fraud, and abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all contracts entered into with a corporation, partnership, or individual working on behalf of the national media campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of any financial audit of the national media campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any evidence used to develop the national media campaign;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific policies and steps implemented to ensure compliance with this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed accounting of the amount of funds obligated during the previous fiscal year for carrying out the national media campaign, including each recipient of funds, the purpose of each expenditure, the amount of each expenditure, any available outcome information, and any other information necessary to provide a complete accounting of the funds expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/8/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review and evaluation of the effectiveness of the national media campaign strategy for the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20131/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director to carry out this section $5,000,000 for each of fiscal years 2023 through 2027, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d23da73-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXIII/s1310/c"},"text":"Pub. L. 117–103, div. W, title XIII, § 1310(c)","chi