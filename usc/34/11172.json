{"tag":"section","attrib":{"id":"id4ce858a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11172"},"text":null,"children":[{"tag":"num","attrib":{"value":"11172"},"text":"§ 11172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants to and contracts with public and private agencies, organizations, and individuals to provide technical assistance to States, units of general local government, Indian tribal governments, local private entities or agencies, or any combination thereof, to carry out the projects for which grants are made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11171"},"text":"section 11171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ce858a4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tII/s262"},"text":"Pub. L. 93–415, title II, § 262","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12212"},"text":"Pub. L. 107–273, div. C, title II, § 12212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1891"},"text":"116 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ce858a5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ce858a6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ce858a7-5dcd-11f1-b11b-9e551e93f87d"},"text":nul