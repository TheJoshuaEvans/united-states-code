{"tag":"section","attrib":{"id":"id4ced134b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11271"},"text":null,"children":[{"tag":"num","attrib":{"value":"11271"},"text":"§ 11271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to potential grantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide informational assistance to potential grantees interested in establishing runaway and homeless youth centers and transitional living youth projects.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ced134c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s380"},"text":"Pub. L. 93–415, title III, § 380","children":[],"tail":", formerly § 315, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s655/2"},"text":"Pub. L. 98–473, title II, § 655(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2124"},"text":"98 Stat. 2124","children":[],"tail":"; renumbered § 341 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7273/a"},"text":"Pub. L. 100–690, title VII, § 7273(a)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4454"},"text":"102 Stat. 4454","children":[],"tail":", 4455; renumbered § 371, "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/B/ii"},"text":"Pub. L. 102–586, § 3(g)(1)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5022"},"text":"106 Stat. 5022","children":[],"tail":"; renumbered § 380 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/j"},"text":"Pub. L. 106–71, § 3(j)","children":[],"tail":", (q), "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1038"},"text":"113 Stat. 1038","children":[],"tail":", 1042.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced134d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced134e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced134f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714a"},"text":"section 5714a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced1350-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/j"},"text":"Pub. L. 106–71, § 3(j)","children":[],"tail":", struck out at end: “Such assistance shall consist of information on—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) steps necessary to establish a runaway and homeless youth center or transitional living youth project, including information on securing space for such center or such project, obtaining insurance, staffing, and establishing operating procedures;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) securing local private or public financial support for the operation of such center or such project, including information on procedures utilized by grantees under this subchapter; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the need for the establishment of additional runaway and homeless youth centers in the geographical area identified by the potential grantee involved.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7273/a/1"},"text":"Pub. L. 100–690, § 7273(a)(1)","children":[],"tail":", inserted “and transitional living youth projects” after “homeless youth centers” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7273/a/2"},"text":"Pub. L. 100–690, § 7273(a)(2)","children":[],"tail":", (3), inserted “or transitional living youth project” after “homeless youth center” and “or such project” after “such center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7273/a/3"},"text":"Pub. L. 100–690, § 7273(a)(3)","children":[],"tail":", inserted “such project” after “such center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7273/a/4"},"text":"Pub. L. 100–690, § 7273(a)(4)","children":[],"tail":", inserted “and homeless” after “runaway”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ced1351-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ced1352-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text