{"tag":"section","attrib":{"id":"id4d4ee224-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506"},"text":null,"children":[{"tag":"num","attrib":{"value":"40506"},"text":"§ 40506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of the National Missing and Unidentified Persons System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4ee225-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General,","children":[{"tag":"ref","attrib":{"idref":"fn002216"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002216"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall maintain the “National Missing and Unidentified Persons System” or “NamUs”, consistent with the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4ee226-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The NamUs shall be a national information clearinghouse and resource center for missing, unidentified, and unclaimed person cases across the United States administered by the National Institute of Justice and managed through an agreement with an eligible entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee227-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The NamUs shall coordinate or provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4ee228-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" online database technology which serves as a national information clearinghouse to help expedite case associations and resolutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee229-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" various free-of-charge forensic services to aid in the identification of missing persons and unidentified remains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee22a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigative support for criminal justice efforts to help missing and unidentified person case resolutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee22b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance for family members of missing persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee22c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance and training by coordinating State and local service providers in order to support individuals and families impacted by the loss or disappearance of a loved one; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee22d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and outreach from NamUs subject matter experts, including assistance with planning and facilitating Missing Person Day events across the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4ee22e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4ee22f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The permissible use of funds awarded under this section for the implementation and maintenance of the agreement created in subparagraph (a)(1) include the use of funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4ee230-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire additional personnel to provide case support and perform other core NamUs functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee231-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new technologies to facilitate timely data entry into the relevant data bases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee232-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct contracting activities relevant to core NamUs services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee233-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide forensic analyses to support the identification of missing and unidentified persons, to include, but not limited to DNA typing, forensic odontology, fingerprint examination, and forensic anthropology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee234-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train State, local, and Tribal law enforcement personnel and forensic medicine service providers to use NamUs resources and best practices for the investigation of missing and unidentified person cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee235-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist States in providing information to the NCIC database, the NamUs database, or any future database system for missing, unidentified, and unclaimed person cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee236-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report to law enforcement authorities in the jurisdiction in which the remains were found information on every deceased, unidentified person, regardless of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee237-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in Missing Person Days and other events to directly support family members of the missing with NamUs case entries and DNA collections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee238-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance and training by coordinating State and local service providers in order to support individuals and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee239-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct data analytics and research projects for the purpose of enhancing knowledge, best practices, and training related to missing and unidentified person cases, as well as developing NamUs system enhancements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee23a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create and maintain a secure, online, nationwide critical incident response tool for professionals that will connect law enforcement, medico-legal and emergency management professionals, as well as victims and families during a critical incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4ee23b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other purposes consistent with the goals of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4ee23c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to the Crime Control Act of 1990 to require reports of missing children to NamUs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4ee23d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (2) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee23e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40506/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amendments made by this subsection shall apply with respect to reports made before, on, or after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4ee23f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2"},"text":"Pub. L. 117–327, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4454"},"text":"136 Stat. 4454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4ee240-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4ee241-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d4ee242-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the amendments made by this subsection, referred to in subsec. (c)(3), see Codification note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4ee243-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2"},"text":"section 2 of Pub. L. 117–327","children":[],"tail":". Subsec. (c)(1) and (2) of "},{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2"},"text":"section 2 of Pub. L. 117–327","children":[],"tail":" amended sections 41307 and 41308 of this title, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Billy’s Law, also known as the Help Find the Missing Act, and not as part of Jennifer’s Law which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d4ee244-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d4ee245-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“In this Act [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327/s1"},"text":"section 1 of Pub. L. 117–327","children":[],"tail":", set out as a Short Title of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"]:"},{"tag":"quotedContent","attrib":{},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘authorized agency’ means a Government agency with an originating agency identification (ORI) number and that is a criminal justice agency, as defined in section 20.3 of title 28, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FBI","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘FBI’ means the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forensic medicine service provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘forensic medicine service provider’ means a State or unit of local government forensic medicine service provider having not fewer than 1 part-time or full-time employed forensic pathologist, or forensic pathologist under contract, who conducts medicolegal death investigations, including examinations of human remains, and who provides reports or opinion testimony with respect to such activity in courts of law within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forensic science service provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘forensic science service provider’ means a State or unit of local government agency having not fewer than 1 full-time analyst who examines physical evidence in criminal or investigative matters and provides reports or opinion testimony with respect to such evidence in courts in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Namus databases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘NamUs databases’ means the National Missing and Unidentified Persons System Missing Persons database and National Missing and Unidentified Persons System Unidentified Decedents database maintained by the National Institute of Justice of the Department of Justice, which serves as a clearinghouse and resource center for missing, unidentified, and unclaimed person cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"NCIC database","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘NCIC database’ means the National Crime Information Center Missing Person File and National Crime Information Center Unidentified Person File of the National Crime Information Center database of the FBI, established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying law enforcement agency defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘qualifying law enforcement agency’ means a State, local, or Tribal law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
