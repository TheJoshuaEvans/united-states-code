{"tag":"section","attrib":{"id":"id4d2d7753-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504"},"text":null,"children":[{"tag":"num","attrib":{"value":"20504"},"text":"§ 20504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program for support of AMBER Alert communications plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d2d7754-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall carry out a program to provide grants to States and Indian tribes for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d7755-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development or enhancement of programs and activities for the support of AMBER Alert communications plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7756-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of tribal AMBER Alert systems into State AMBER Alert systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7757-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities funded by grants under the program under subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d7758-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and implementation of education and training programs, and associated materials, relating to AMBER Alert communications plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7759-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and implementation of law enforcement programs, and associated equipment, relating to AMBER Alert communications plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d775a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and implementation of new technologies to improve AMBER Alert communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d775b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of State or regional AMBER Alert communication plans with a territorial government or an Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d775c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities as the Attorney General considers appropriate for supporting the AMBER Alert communications program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d775d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d775e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Federal share of the cost of any activities funded by a grant under this section may not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d775f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General determines that American Samoa, Guam, the Northern Mariana Islands, Puerto Rico, the Virgin Islands of the United States, or an Indian tribe is unable to comply with the requirement under paragraph (1), the Attorney General shall waive such requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7760-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grant amounts on geographic basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall, to the maximum extent practicable, ensure the distribution of grants under the program under subsection (a) on an equitable basis throughout the various regions of the United States, including territories of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7761-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall prescribe requirements, including application requirements, and standards to improve accountability and transparency for grants awarded under the program under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7762-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Indian tribe” means a federally recognized Indian tribe or a Native village, Regional Corporation, or Village Corporation (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2d7763-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2d7764-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated for the Department of Justice $5,000,000 for fiscal year 2019 to carry out this section and, in addition, $5,000,000 for fiscal year 2019 to carry out paragraphs (3) and (4) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2d7765-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20504/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated pursuant to the authorization of appropriations in paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2d7766-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/tIII/s304"},"text":"Pub. L. 108–21, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/663"},"text":"117 Stat. 663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2"},"text":"Pub. L. 115–166, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-13"},"text":"Apr. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1274"},"text":"132 Stat. 1274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tC/s10001/c"},"text":"Pub. L. 116–283, div. H, title C, § 10001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4862"},"text":"134 Stat. 4862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2d7767-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2d7768-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2d7769-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5791c"},"text":"section 5791c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d2d776a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/c/1"},"text":"Pub. L. 116–283, § 10001(c)(1)","children":[],"tail":", inserted “a territorial government or” after “with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/c/2"},"text":"Pub. L. 116–283, § 10001(c)(2)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as provided in paragraph (2), the Federal share of the cost of any activities funded by a grant under the program under subsection (a) may not exceed 50 percent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Federal share","children":[],"tail":".—If the Attorney General determines that an Indian tribe does not have sufficient funds available to comply with the Federal share requirement under paragraph (1) for the cost of activities funded by a grant for the purpose described in subsection (b)(4), the Attorney General may increase the Federal share of the costs for such activities to the extent the Attorney General determines necessary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s10001/c/3"},"text":"Pub. L. 116–283, § 10001(c)(3)","children":[],"tail":", inserted “, including territories of the United States” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2/1"},"text":"Pub. L. 115–166, § 2(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Attorney General shall carry out a program to provide grants to States for the development or enhancement of programs and activities for the support of AMBER Alert communications plans.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2/2"},"text":"Pub. L. 115–166, § 2(2)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2/3"},"text":"Pub. L. 115–166, § 2(3)","children":[],"tail":", designated existing provisions as par. (1) and inserted heading, substituted “Except as provided in paragraph (2), the Federal” for “The Federal”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2/4"},"text":"Pub. L. 115–166, § 2(4)","children":[],"tail":", substituted “and standards to improve accountability and transparency for grants awarded under” for “for grants under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2/6"},"text":"Pub. L. 115–166, § 2(6)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/166/s2/5"},"text":"Pub. L. 115–166, § 2(5)","children":[],"tail":", (7), redesignated subsec. (f) as (g) and, in par. (1), substituted “2019” for “2004” in two places and “paragraphs (3) and (4) of subsection (b)” for “subsection (b)(3)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
