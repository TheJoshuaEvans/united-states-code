{"tag":"section","attrib":{"id":"id4d10c763-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514"},"text":null,"children":[{"tag":"num","attrib":{"value":"12514"},"text":"§ 12514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program on restorative practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d10c764-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d10c765-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Office on Violence Against Women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c766-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d10c767-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c768-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c769-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c76a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c76b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c76c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c76d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a private or public nonprofit organization, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c76e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal nonprofit organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c76f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a faith-based nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c770-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restorative practice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “restorative practice” means a practice relating to a specific harm that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d10c771-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is community-based and unaffiliated with any civil or criminal legal process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c772-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is initiated by a victim of the harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c773-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" involves, on a voluntary basis and without any evidence of coercion or intimidation of any victim of the harm by any individual who committed the harm or anyone associated with any such individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c774-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more individuals who committed the harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c775-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more victims of the harm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c776-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community affected by the harm through 1 or more representatives of the community;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c777-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include and has the goal of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c778-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collectively seeking accountability from 1 or more individuals who committed the harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c779-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a written process whereby 1 or more individuals who committed the harm will take responsibility for the actions that caused harm to 1 or more victims of the harm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c77a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing a written course of action plan—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d10c77b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/D/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is responsive to the needs of 1 or more victims of the harm; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d10c77c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/D/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon which 1 or more victims, 1 or more individuals who committed the harm, and the community can agree; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c77d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conducted in a victim services framework that protects the safety and supports the autonomy of 1 or more victims of the harm and the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c77e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall award grants to eligible entities to develop and implement a program, or to assess best practices, for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d10c77f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restorative practices to prevent or address domestic violence, dating violence, sexual assault, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c780-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training by eligible entities, or for eligible entities, courts, or prosecutors, on restorative practices and program implementation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c781-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluations of a restorative practice described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c782-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under subsection (b), the Director shall give priority to eligible entities that submit proposals that meaningfully address the needs of culturally specific or underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c783-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an eligible entity shall demonstrate a history of comprehensive training and experience in working with victims of domestic violence, dating violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c784-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d10c785-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity or a subgrantee of an eligible entity that offers a restorative practices program with funds awarded under this section shall ensure that such program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d10c786-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes set practices and procedures for screening the suitability of any individual who committed a harm based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c787-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the history of civil and criminal complaints against the individual involving domestic violence, sexual assault, dating violence, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c788-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parole or probation violations of the individual or whether active parole or probation supervision of the individual is being conducted for prior offenses involving domestic violence, sexual assault, dating violence, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c789-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk to the safety of any victim of the harm based on an evidence-based risk assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c78a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk to public safety, including an evidence-based risk assessment of the danger to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c78b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" past participation of any individual who committed the harm in restorative practice programing; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c78c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" denies eligibility to participate in the program for any individual who committed a harm against whom there is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c78d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pending felony or misdemeanor prosecution for an offense against any victim of the harm or a dependent of any such victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c78e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a restraining order or a protection order (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2266"},"text":"section 2266 of title 18","children":[],"tail":") that protects any victim of the harm or a dependent of any such victim, unless there is an exception in the restraining order or protective order allowing for participation in a restorative practices program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d13388f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pending criminal charge involving or relating to sexual assault, including rape, human trafficking, or child abuse, including child sexual abuse; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d133890-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conviction for child sexual abuse against the victim or a sibling of the victim if the victim or sibling of the victim is currently a minor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133891-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a risk assessment described in paragraph (1)(A)(iii) for which an eligible entity or a subgrantee of an eligible entity determines that a victim or a dependent of a victim are at significant risk of subsequent serious injury, sexual assault, or death, the eligible entity or subgrantee shall refer the victim or dependent to other victim services, instead of restorative practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d133892-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of confidential or private information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/b/2"},"text":"section 12291(b)(2) of this title","children":[],"tail":", an individual described in subsection (a)(3)(C) shall be considered a person receiving services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d133893-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to criminal justice intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Restorative practices performed with funds awarded under this section are not intended to function as a replacement for criminal justice intervention for a specific harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d133894-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d133895-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a part of the report required to be submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291/b/6"},"text":"section 12291(b)(6) of this title","children":[],"tail":", an eligible entity that receives a grant under this section shall annually submit to the Director information relating to the effectiveness of the restorative practices carried out with amounts from the grant, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d133896-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals for whom the eligible entity supported a restorative practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d133897-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if applicable, the number of individuals who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d133898-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sought restorative practices from the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d133899-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity could not serve;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13389a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if applicable, the number of individuals—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d13389b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who sought restorative practice training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d13389c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who received restorative practice training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d13389d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who provided restorative practice training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d13389e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to whom the eligible entity could not provide restorative practice training;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13389f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim evaluation component that is documented through survey or interview, including the satisfaction of victims of a harm with the restorative practice services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1338a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if applicable, the number of individuals who committed a harm and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d1338a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successfully completed and executed a written course of action plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1338a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to successfully complete and execute a written course of action plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d1338a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" were involved in a criminal or civil complaint involving domestic violence, dating violence, sexual assault, or stalking against the victims ","children":[{"tag":"ref","attrib":{"idref":"fn002129"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002129"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" or victims during the course of the restorative practice process; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1338a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other qualitative or quantitative information determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1338a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", and biennially thereafter, the Director shall submit to Congress a report that summarizes the reports received by the Director under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1338a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12514/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Director such sums as may be necessary for each of fiscal years 2023 through 2027 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1338a7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41801"},"text":"Pub. L. 103–322, title IV, § 41801","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tI/s109/a"},"text":"Pub. L. 117–103, div. W, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/852"},"text":"136 Stat. 852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1338a8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d1338a9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d1338aa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
