{"tag":"section","attrib":{"id":"id4ca0c7f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157"},"text":null,"children":[{"tag":"num","attrib":{"value":"10157"},"text":"§ 10157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reserved funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca0c7fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the total amount made available to carry out this part for a fiscal year, the Attorney General shall reserve not more than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca311eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000, for use by the National Institute of Justice in assisting units of local government to identify, select, develop, modernize, and purchase new technologies for use by law enforcement, of which $1,000,000 shall be for use by the Bureau of Justice Statistics to collect data necessary for carrying out this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca311ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000, to be granted by the Attorney General to States and units of local government to develop and implement antiterrorism training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca311ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the total amount made available to carry out this part for a fiscal year, the Attorney General may reserve not more than 5 percent, to be granted to 1 or more States or units of local government, for 1 or more of the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10152"},"text":"section 10152 of this title","children":[],"tail":", pursuant to his determination that the same is necessary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca311ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to combat, address, or otherwise respond to precipitous or extraordinary increases in crime, or in a type or types of crime; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca311ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10157/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent, compensate for, or mitigate significant programmatic harm resulting from operation of the formula established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10156"},"text":"section 10156 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca311f0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s506"},"text":"Pub. L. 90–351, title I, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1111/a/2/C"},"text":"Pub. L. 109–162, title XI, § 1111(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3100"},"text":"119 Stat. 3100","child