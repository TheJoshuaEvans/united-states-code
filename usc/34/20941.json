{"tag":"section","attrib":{"id":"id4d36eddb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20941"},"text":null,"children":[{"tag":"num","attrib":{"value":"20941"},"text":"§ 20941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal assistance with respect to violations of registration requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36eddc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20941/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall use the resources of Federal law enforcement, including the United States Marshals Service, to assist jurisdictions in locating and apprehending sex offenders who violate sex offender registration requirements. For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s566/e/1/B"},"text":"section 566(e)(1)(B) of title 28","children":[],"tail":", a sex offender who violates a sex offender registration requirement shall be deemed a fugitive."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36eddd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20941/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal years 2007 through 2009 to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36edde-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s142"},"text":"Pub. L. 109–248, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/604"},"text":"120 Stat. 604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36eddf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36ede0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36ede1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16941"},"text":"section 16941 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
