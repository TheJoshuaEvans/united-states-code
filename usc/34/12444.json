{"tag":"section","attrib":{"id":"id4d0752a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12444"},"text":null,"children":[{"tag":"num","attrib":{"value":"12444"},"text":"§ 12444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Applicants described in paragraph (1) and paragraphs (3) through (6) shall demonstrate that they have entered into a significant partnership with a State, tribal, territorial, or local victim service or advocacy organization or condition in order to develop safe, confidential, and effective protocols, procedures, policies, and systems for protecting personally identifying information of victims.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d0752a1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41104"},"text":"Pub. L. 103–322, title IV, § 41104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s107"},"text":"Pub. L. 109–162, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2984"},"text":"119 Stat. 2984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0752a2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0752a3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d0752a4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (1) and paragraphs (3) through (6), referred to in text, probably mean paragraphs (1) and (3) through (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12443"},"text":"section 12443 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0752a5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043b–3"},"text":"section 14043b–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
