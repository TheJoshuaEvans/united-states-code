{"tag":"section","attrib":{"id":"id4cd063d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614"},"text":null,"children":[{"tag":"num","attrib":{"value":"10614"},"text":"§ 10614.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd063d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall consult with the Secretary of Health and Human Services and any other appropriate officials in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd063d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may utilize any component or components of the Department of Justice in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd063d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may issue regulations and guidelines necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd063d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other requirements that may be specified by the Attorney General, an application for a grant under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd063da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a long-term strategy and detailed implementation plan that shall provide for the consultation and coordination with appropriate State and local prosecutors, particularly when program participants fail to comply with program requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the applicant’s inability to fund the program adequately without Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the Federal support provided will be used to supplement, and not supplant, State, Indian tribal, and local sources of funding that would otherwise be available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify related governmental or community initiatives which complement or will be coordinated with the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that there has been appropriate consultation with all affected agencies and that there will be appropriate coordination with all affected agencies in the implementation of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that participating offenders will be supervised by 1 or more designated judges with responsibility for the drug court program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify plans for obtaining necessary support and continuing the proposed program following the conclusion of Federal support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10614/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the methodology that will be used in evaluating the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd063e2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2954"},"text":"Pub. L. 90–351, title I, § 2954","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2301/a"},"text":"Pub. L. 107–273, div. B, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1796"},"text":"116 Stat. 1796","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd063e3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd063e4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd063e5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u–3"},"text":"section 3797u–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
