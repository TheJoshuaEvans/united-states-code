9","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", and applicable to matters pending on "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", or filed or accruing after that date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/d"},"text":"section 1086(d) of Pub. L. 112–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10251"},"text":"section 10251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
