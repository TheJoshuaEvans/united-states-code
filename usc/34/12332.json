{"tag":"section","attrib":{"id":"id4d04e105-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12332"},"text":null,"children":[{"tag":"num","attrib":{"value":"12332"},"text":"§ 12332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State databases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d04e106-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall study and report to the States and to Congress on how the States may collect centralized databases on the incidence of sexual and domestic violence offenses within a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e107-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting its study, the Attorney General shall consult persons expert in the collection of criminal justice data, State statistical administrators, law enforcement personnel, and nonprofit nongovernmental agencies that provide direct services to victims of domestic violence. The final report shall set forth the views of the persons consulted on the recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e108-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure that no later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the study required under subsection (a) is completed and a report describing the findings made is submitted to the Committees on the Judiciary of the Senate and the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e109-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $200,000 for fiscal year 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d04e10a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40292"},"text":"Pub. L. 103–322, title IV, § 40292","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1939"},"text":"108 Stat. 1939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d04e10b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d04e10c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d04e10d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13962"},"text":"section 13962 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
