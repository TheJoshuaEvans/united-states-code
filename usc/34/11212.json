{"tag":"section","attrib":{"id":"id4ceaa25b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212"},"text":null,"children":[{"tag":"num","attrib":{"value":"11212"},"text":"§ 11212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; plan requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ceaa25c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Runaway and homeless youth center; project providing temporary shelter; counseling services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a"},"text":"section 11211(a) of this title","children":[],"tail":", an applicant shall propose to establish, strengthen, or fund an existing or proposed runaway and homeless youth center, a locally controlled project (including a host family home) that provides temporary shelter, and counseling services to youth who have left home without permission of their parents or guardians or to other homeless youth."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ceaa25d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to qualify for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a"},"text":"section 11211(a) of this title","children":[],"tail":", an applicant shall submit a plan to the Secretary including assurances that the applicant—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ceaa25e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall operate a runaway and homeless youth center located in an area which is demonstrably frequented by or easily reachable by runaway and homeless youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa25f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall use such assistance to establish, to strengthen, or to fund a runaway and homeless youth center, or a locally controlled facility providing temporary shelter, that has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ceaa260-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a maximum capacity of not more than 20 youth, except where the applicant assures that the State where the center or locally controlled facility is located has a State or local law or regulation that requires a higher maximum to comply with licensure requirements for child and youth serving facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa261-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a ratio of staff to youth that is sufficient to ensure adequate supervision and treatment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa262-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop adequate plans for contacting the parents or other relatives of the youth and ensuring the safe return of the youth according to the best interests of the youth, for contacting local government officials pursuant to informal arrangements established with such officials by the runaway and homeless youth center and for providing for other appropriate alternative living arrangements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa263-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall develop an adequate plan for ensuring—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ceaa264-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper relations with law enforcement personnel, health and mental health care personnel, social service personnel, school system personnel, and welfare personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa265-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with McKinney-Vento school district liaisons, designated under section 722(g)(1)(J)(ii) of the McKinney-Vento Homeless Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11432/g/1/J/ii"},"text":"42 U.S.C. 11432(g)(1)(J)(ii)","children":[],"tail":"), to assure that runaway and homeless youth are provided information about the educational services available to such youth under subtitle B of title VII of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11431"},"text":"42 U.S.C. 11431","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa266-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return of runaway and homeless youth from correctional institutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa267-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop an adequate plan for providing counseling and aftercare services to such youth, for encouraging the involvement of their parents or legal guardians in counseling, and for ensuring, as possible, that aftercare services will be provided to those youth who are returned beyond the State in which the runaway and homeless youth center is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa268-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop an adequate plan for establishing or coordinating with outreach programs designed to attract persons (including, where applicable, persons who are members of a cultural minority and persons with limited ability to speak English) who are eligible to receive services for which a grant under subsection (a) may be expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa269-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall keep adequate statistical records profiling the youth and family members whom it serves (including youth who are not referred to out-of-home shelter services), except that records maintained on individual runaway and homeless youth shall not be disclosed without the consent of the individual youth and parent or legal guardian to anyone other than another agency compiling statistical records or a government agency involved in the disposition of criminal charges against an individual runaway and homeless youth, and reports or other documents based on such statistical rec­ords shall not disclose the identity of individual runaway and homeless youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa26a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit annual reports to the Secretary detailing how the center has been able to meet the goals of its plans and reporting the statistical summaries required by paragraph (7);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa26b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall demonstrate its ability to operate under accounting procedures and fiscal control devices as required by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa26c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit a budget estimate with respect to the plan submitted by such center under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa26d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall supply such other information as the Secretary reasonably deems necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa26e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall submit to the Secretary an annual report that includes, with respect to the year for which the report is submitted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ceaa26f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the activities carried out under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa270-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the achievements of the project under this part carried out by the applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa271-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" statistical summaries describing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ceaa272-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/12/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and the characteristics of the runaway and homeless youth, and youth at risk of family separation, who participate in the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ceaa273-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/12/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services provided to such youth by the project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa274-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall develop an adequate emergency preparedness and management plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ceaa275-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicants providing street-based services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to use assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a/2/C/i"},"text":"section 11211(a)(2)(C)(i) of this title","children":[],"tail":" to provide street-based services, the applicant shall include in the plan required by subsection (b) assurances that in providing such services the applicant will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ceaa276-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide qualified supervision of staff, including on-street supervision by appropriately trained staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa277-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide backup personnel for on-street staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa278-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide initial and periodic training of staff who provide such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa279-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach activities for runaway and homeless youth, and street youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ceaa27a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicants providing home-based services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to use assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a"},"text":"section 11211(a) of this title","children":[],"tail":" to provide home-based services described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a/2/C/ii"},"text":"section 11211(a)(2)(C)(ii) of this title","children":[],"tail":", an applicant shall include in the plan required by subsection (b) assurances that in providing such services the applicant will—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ceaa27b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide counseling and information to youth and the families (including unrelated individuals in the family households) of such youth, including services relating to basic life skills, interpersonal skill building, educational advancement, job attainment skills, mental and physical health care, parenting skills, financial planning, and referral to sources of other needed services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa27c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide directly, or through an arrangement made by the applicant, 24-hour service to respond to family crises (including immediate access to temporary shelter for runaway and homeless youth, and youth at risk of separation from the family);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa27d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, in partnership with the families of runaway and homeless youth, and youth at risk of separation from the family, objectives and measures of success to be achieved as a result of receiving home-based services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa27e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide initial and periodic training of staff who provide home-based services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa27f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ceaa280-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caseloads will remain sufficiently low to allow for intensive (5 to 20 hours per week) involvement with each family receiving such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa281-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff providing such services will receive qualified supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ceaa282-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicants providing drug abuse education and prevention services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to use assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11211/a/2/C/iii"},"text":"section 11211(a)(2)(C)(iii) of this title","children":[],"tail":" to provide drug abuse education and prevention services, an applicant shall include in the plan required by subsection (b)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ceaa283-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ceaa284-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of such services that the applicant proposes to provide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa285-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the objectives of such services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ceaa286-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of information and training to be provided to individuals providing such services to runaway and homeless youth; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa287-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11212/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that in providing such services the applicant shall conduct outreach activities for runaway and homeless youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ceaa288-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s312"},"text":"Pub. L. 93–415, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1130"},"text":"88 Stat. 1130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/115/s7/a/2"},"text":"Pub. L. 95–115, § 7(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1058"},"text":"91 Stat. 1058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/509/s18/d"},"text":"Pub. L. 96–509, § 18(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-08"},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2762"},"text":"94 Stat. 2762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s652"},"text":"Pub. L. 98–473, title II, § 652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2123"},"text":"98 Stat. 2123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7271/c/1"},"text":"Pub. L. 100–690, title VII, § 7271(c)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4453"},"text":"102 Stat. 4453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c"},"text":"Pub. L. 102–586, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5019"},"text":"106 Stat. 5019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/c"},"text":"Pub. L. 106–71, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1036"},"text":"113 Stat. 1036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI"},"text":"Pub. L. 108–96, title I","children":[],"tail":", §§ 105, 106, 109, "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1168"},"text":"117 Stat. 1168","children":[],"tail":", 1169; "},{"tag":"ref","attrib":{"href":"/us/pl/110/378/s3/b"},"text":"Pub. L. 110–378, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4069"},"text":"122 Stat. 4069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ceaa289-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ceaa28a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ceaa28b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The McKinney-Vento Homeless Assistance Act, referred to in subsec. (b)(4)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77"},"text":"Pub. L. 100–77","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/482"},"text":"101 Stat. 482","children":[],"tail":". Subtitle B of title VII of the Act is classified generally to part B (§ 11431 et seq.) of subchapter VI of chapter 119 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11301"},"text":"section 11301 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ceaa28c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5712"},"text":"section 5712 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ceaa28d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378"},"text":"Pub. L. 110–378","children":[],"tail":" added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96/s105"},"text":"Pub. L. 108–96, § 105","children":[],"tail":", substituted “services to youth” for “services to juveniles” and “homeless youth” for “homeless juveniles”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96/s106"},"text":"Pub. L. 108–96, § 106","children":[],"tail":", inserted “, except where the applicant assures that the State where the center or locally controlled facility is located has a State or local law or regulation that requires a higher maximum to comply with licensure requirements for child and youth serving facilities” after “youth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96/s109"},"text":"Pub. L. 108–96, § 109","children":[],"tail":", substituted “McKinney-Vento school district liaisons, designated under section 722(g)(1)(J)(ii) of the McKinney-Vento Homeless Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11432/g/1/J/ii"},"text":"42 U.S.C. 11432(g)(1)(J)(ii)","children":[],"tail":"), to assure that runaway and homeless youth are provided information about the educational services available to such youth under subtitle B of title VII of that Act;” for “personnel of the schools to which runaway and homeless youth will return, to assist such youth to stay current with the curricula of those schools;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/c/1/A"},"text":"Pub. L. 106–71, § 3(c)(1)(A)","children":[],"tail":", substituted “paragraph (7)” for “paragraph (6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/c/1/B"},"text":"Pub. L. 106–71, § 3(c)(1)(B)","children":[],"tail":"–(D), added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/c/2"},"text":"Pub. L. 106–71, § 3(c)(2)","children":[],"tail":", added heading and text of subsecs. (c) to (e) and struck out former subsecs. (c) and (d) which related to street-based service projects and home-based service projects, respectively, but which specified more detailed lists of services applicants were to provide in order to qualify for assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/1"},"text":"Pub. L. 102–586, § 3(c)(1)","children":[],"tail":", substituted “project (including a host family home) that provides” for “facility providing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/A"},"text":"Pub. L. 102–586, § 3(c)(2)(A)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “shall have a maximum capacity of no more than twenty children, with a ratio of staff to children of sufficient proportion to assure adequate supervision and treatment;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/B"},"text":"Pub. L. 102–586, § 3(c)(2)(B)","children":[],"tail":", substituted “parents or other relatives of the youth and ensuring” for “child’s parents or relatives and assuring” and “youth” for “child” after “the” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/C"},"text":"Pub. L. 102–586, § 3(c)(2)(C)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “shall develop an adequate plan for assuring proper relations with law enforcement personnel, social service personnel, school system personnel, and welfare personnel, and the return of runaway and homeless youth from correctional institutions;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/D"},"text":"Pub. L. 102–586, § 3(c)(2)(D)","children":[],"tail":", substituted “providing counseling and aftercare services to such youth, for encouraging the involvement of their parents or legal guardians in counseling, and for ensuring” for “aftercare counseling involving runaway and homeless youth and their families within the State in which the runaway and homeless youth center is located and for assuring” and “youth” for “children” after “those”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/G"},"text":"Pub. L. 102–586, § 3(c)(2)(G)","children":[],"tail":", added par. (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s2/c/2/E"},"text":"Pub. L. 102–586, § 2(c)(2)(E)","children":[],"tail":", (F), redesignated par. (6) as (7) and substituted “youth and family members whom it serves (including youth who are not referred to out-of-home shelter services)” for “children and family members which it serves”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/F"},"text":"Pub. L. 102–586, § 3(c)(2)(F)","children":[],"tail":", redesignated pars. (7) to (10) as (8) to (11), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/c/2/H"},"text":"Pub. L. 102–586, § 3(c)(2)(H)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/1"},"text":"Pub. L. 100–690, § 7271(c)(1)","children":[],"tail":", (2), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5711/a"},"text":"section 5711(a) of this title","children":[],"tail":"” for “this part” and “runaway and homeless youth center” for “runaway center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/1"},"text":"Pub. L. 100–690, § 7271(c)(1)","children":[],"tail":", (3)(A), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5711/a"},"text":"section 5711(a) of this title","children":[],"tail":"” for “this part” and “including assurances that the applicant” for “meeting the following requirements and including the following information. Each center” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/3/B"},"text":"Pub. L. 100–690, § 7271(c)(3)(B)","children":[],"tail":", substituted “shall operate a runaway and homeless youth center” for “shall be” and “runaway and homeless youth” for “runaway youth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/3/C"},"text":"Pub. L. 100–690, § 7271(c)(3)(C)","children":[],"tail":", substituted “runaway and homeless youth center” for “runaway center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/3/D"},"text":"Pub. L. 100–690, § 7271(c)(3)(D)","children":[],"tail":", substituted “runaway and homeless youth” for “runaway youths”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/3/C"},"text":"Pub. L. 100–690, § 7271(c)(3)(C)","children":[],"tail":", (E), substituted “runaway and homeless youth” for “runaway youth” and substituted “runaway and homeless youth center” for “runaway center” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7271/c/3/D"},"text":"Pub. L. 100–690, § 7271(c)(3)(D)","children":[],"tail":", (E), substituted “individual runaway and homeless youth” for “individual runaway youths” in two places and “against an individual runaway and homeless youth” for “against an individual runaway youth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s652/1"},"text":"Pub. L. 98–473, § 652(1)","children":[],"tail":", substituted “proportion” for “portion”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s652/2"},"text":"Pub. L. 98–473, § 652(2)","children":[],"tail":", struck out “(if such action is required by State law)” before “and assuring”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s652/3"},"text":"Pub. L. 98–473, § 652(3)","children":[],"tail":", inserted “school system personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s652/4"},"text":"Pub. L. 98–473, § 652(4)","children":[],"tail":", substituted “families” for “parents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s652/5"},"text":"Pub. L. 98–473, § 652(5)","children":[],"tail":", substituted “family members” for “parents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/509/s18/d/1"},"text":"Pub. L. 96–509, § 18(d)(1)","children":[],"tail":", substituted “center” for “house” and inserted “or to other homeless juveniles” after “parents or guardians”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/509/s18/d/2"},"text":"Pub. L. 96–509, § 18(d)(2)","children":[],"tail":", substituted “center” for “house” wherever appearing, and in par. (4) inserted reference to social service personnel and welfare personnel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/115"},"text":"Pub. L. 95–115","children":[],"tail":" substituted “aftercare services” for “aftercase services” in par. (5), and “the consent of the individual youth and parent or legal guardian” for “parental consent” in par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ceaa28e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ceaa28f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7296/a"},"text":"section 7296(a) of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ced1290-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s670/a"},"text":"section 670(a) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":