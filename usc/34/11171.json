{"tag":"section","attrib":{"id":"id4ce85899-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11171"},"text":null,"children":[{"tag":"num","attrib":{"value":"11171"},"text":"§ 11171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ce8589a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants to and contracts with States, units of general local government, Indian tribal governments, public and private agencies, organizations, and individuals, or combinations thereof, to carry out projects for the development, testing, and demonstration of promising initiatives and programs for the prevention, control, or reduction of juvenile delinquency. The Administrator shall ensure that, to the extent reasonable and practicable, such grants are made to achieve an equitable geographical distribution of such projects throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce8589b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under subsection (a) may be used to pay all or part of the cost of the project for which such grant is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ce8589c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref"