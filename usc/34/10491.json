"href":"/us/pl/116/32/s2/2/B"},"text":"Pub. L. 116–32, § 2(2)(B)","children":[],"tail":", inserted “, psychological services, suicide prevention,” after “stress reduction”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
