{"tag":"section","attrib":{"id":"id4ccba86e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491"},"text":null,"children":[{"tag":"num","attrib":{"value":"10491"},"text":"§ 10491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba86f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish guidelines and oversee the implementation of family-friendly policies within law enforcement-related offices and divisions in the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba870-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study the effects of stress on law enforcement personnel and family well-being and disseminate the findings of such studies to Federal, State, and local law enforcement agencies, related organizations, and other interested parties, including any research and reports developed under the Law Enforcement Mental Health and Wellness Act of 2017 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/113"},"text":"Public Law 115–113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/131/2276"},"text":"131 Stat. 2276","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba871-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and evaluate model programs that provide support services to law enforcement personnel and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba872-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and training programs to develop stress reduction, psychological services, suicide prevention, and family support to State and local law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba873-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate information regarding family support, stress reduction, and psychological services to Federal, State, and local law enforcement agencies, law enforcement-related organizations, and other interested entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba874-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10491/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine issues to be researched by the Department of Justice and by grant recipients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba875-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2301"},"text":"Pub. L. 90–351, title I, § 2301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210201/a/3"},"text":"Pub. L. 103–322, title XXI, § 210201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2062"},"text":"108 Stat. 2062","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/32/s2/2"},"text":"Pub. L. 116–32, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-25"},"text":"July 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1036"},"text":"133 Stat. 1036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba876-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba877-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ccba878-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Law Enforcement Mental Health and Wellness Act of 2017, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/113"},"text":"Pub. L. 115–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-10"},"text":"Jan. 10, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2276"},"text":"131 Stat. 2276","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10381"},"text":"section 10381 of this title","children":[],"tail":" and enacted provisions set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s50101"},"text":"section 50101 of this title","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/113/s1"},"text":"section 1 of Pub. L. 115–113","children":[],"tail":", set out as a Short Title of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"tex