{"tag":"section","attrib":{"id":"id4d643ef2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502"},"text":null,"children":[{"tag":"num","attrib":{"value":"60502"},"text":"§ 60502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643ef3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “exoneree” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643ef4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a Federal, tribal, or State offense that is punishable by a term of imprisonment of more than 1 year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643ef5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served a term of imprisonment for not less than 6 months in a Federal, tribal, or State prison or correctional facility as a result of the conviction described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643ef6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been determined to be factually innocent of the offense described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643ef7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian tribe” has the meaning given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10251"},"text":"section 10251 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643ef8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “offender” includes an exoneree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643ef9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Transitional Jobs strategy” means an employment strategy for youth and adults who are chronically unemployed or those that have barriers to employment that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643efa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conducted by State, tribal, and local governments, State, tribal, and local workforce boards, and nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643efb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides time-limited employment using individual placements, team placements, and social enterprise placements, without displacing existing employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643efc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pays wages in accordance with applicable law, but in no event less than the higher of the rate specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"section 206(a)(1) of title 29","children":[],"tail":" or the applicable State or local minimum wage law, which are subsidized, in whole or in part, by public funds;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643efd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combines time-limited employment with activities that promote skill development, remove barriers to employment, and lead to unsubsidized employment such as a thorough orientation and individual assessment, job readiness and life skills training, case management and supportive services, adult education and training, child support-related services, job retention support and incentives, and other similar activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643efe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places participants into unsubsidized employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643eff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60502/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides job retention, re-employment services, and continuing and vocational education to ensure continuing participation in unsubsidized employment and identification of opportunities for advancement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f00-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/s4"},"text":"Pub. L. 110–199, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/660"},"text":"122 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/g/1"},"text":"Pub. L. 115–391, title V, § 502(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5231"},"text":"132 Stat. 5231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f01-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f02-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d643f03-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/657"},"text":"122 Stat. 657","children":[],"tail":", known as the Second Chance Act of 2007: Community Safety Through Recidivism Prevention and also as the Second Chance Act of 2007. For complete classification of this Act to the Code, see Short Title of 2008 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d643f04-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17502"},"text":"section 17502 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d643f05-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “In this Act, the term ‘Indian Tribe’ has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10251"},"text":"section 10251 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
