{"tag":"section","attrib":{"id":"id4d0e7e32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513"},"text":null,"children":[{"tag":"num","attrib":{"value":"12513"},"text":"§ 12513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program on trauma-informed, victim-centered training for law enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0e7e33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7e34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Attorney General” means the Attorney General, acting through the Director of the Office on Violence Against Women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered individual” means an individual who interfaces with victims of domestic violence, dating violence, sexual assault, and stalking, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual working for or on behalf of an eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrator or personnel of a school, university, or other educational program or activity (including a campus police officer or a school resource officer); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency services or medical employee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “demonstration site”, with respect to an eligible entity that receives a grant under this section, means the area over which the eligible entity has jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible entity” means a State, local, territorial, or Tribal law enforcement agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “mandatory partner” means a national, regional, or local victim services organization or agency working in collaboration with a law enforcement agency described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7e3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7e3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall award grants on a competitive basis to eligible entities to collaborate with their mandatory partners to carry out the demonstration program under this section by implementing evidence-based or promising investigative policies and practices to incorporate trauma-informed, victim-centered techniques designed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent re-traumatization of the victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e3f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that covered individuals use evidence-based practices to respond to and investigate cases of domestic violence, dating violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e40-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve communication between victims and law enforcement officers in an effort to increase the likelihood of the successful investigation and prosecution of the reported crime in a manner that protects the victim to the greatest extent possible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e41-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase collaboration among stakeholders who are part of the coordinated community response to domestic violence, dating violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e42-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the effectiveness of the training process and content.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e43-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall award grants under this section to multiple eligible entities for use in a variety of settings and communities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e44-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urban, suburban, Tribal, remote, and rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e45-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" college campuses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traditionally underserved communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7e47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall use the grant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7e48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" train covered individuals within the demonstration site of the eligible entity to use evidence-based, trauma-informed, and victim-centered techniques and knowledge of crime victims’ rights throughout an investigation into domestic violence, dating violence, sexual assault, or stalking, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conducting victim interviews in a manner that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d0e7e4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elicits valuable information about the domestic violence, dating violence, sexual assault, or stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7e4b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoids re-traumatization of the victim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c73c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting field investigations that mirror best and promising practices available at the time of the investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c73d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" customizing investigative approaches to ensure a culturally and linguistically appropriate approach to the community being served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c73e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" becoming proficient in understanding and responding to complex cases, including cases of domestic violence, dating violence, sexual assault, or stalking—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c73f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitated by alcohol or drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c740-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving strangulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c741-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed by a non-stranger;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c742-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed by an individual of the same sex as the victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c743-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving a victim with a disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c744-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving a male victim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c745-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving a lesbian, gay, bisexual, or transgender (commonly referred to as “LGBT”) victim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c746-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing collaborative relationships between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c747-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement officers and other members of the response team; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c748-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community being served; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c749-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing an understanding of how to define, identify, and correctly classify a report of domestic violence, dating violence, sexual assault, or stalking; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c74a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the efforts of the eligible entity to improve the response of covered individuals to domestic violence, dating violence, sexual assault, and stalking through various communication channels, such as the website of the eligible entity, social media, print materials, and community meetings, in order to ensure that all covered individuals within the demonstration site of the eligible entity are aware of those efforts and included in trainings, to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c74b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program trainings on trauma-informed, victim-centered approaches","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d10c74c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of existing trainings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d10c74d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall identify trainings for law enforcement officers, in existence as of the date on which the Attorney General begins to solicit applications for grants under this section, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d10c74e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ a trauma-informed, victim-centered approach to domestic violence, dating violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d10c74f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focus on the fundamentals of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d10c750-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trauma responses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d10c751-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of trauma on victims of domestic violence, dating violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d10c752-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" techniques for effectively investigating domestic violence, dating violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c753-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under this section shall select one or more of the approaches employed by a training identified under subparagraph (A) to test within the demonstration site of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c754-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Attorney General shall consult with the Director of the Office for Victims of Crime in order to seek input from and cultivate consensus among outside practitioners and other stakeholders through facilitated discussions and focus groups on best practices in the field of trauma-informed, victim-centered care for victims of domestic violence, dating violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c755-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Director of the National Institute of Justice, shall require each eligible entity that receives a grant under this section to identify a research partner, preferably a local research partner, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d10c756-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design a system for generating and collecting the appropriate data to facilitate an independent process or impact evaluation of the use of the grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c757-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically conduct an evaluation described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d10c758-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodically make publicly available, during the grant period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d10c759-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary results of the evaluations conducted under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d10c75a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for improving the use of the grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c75b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Attorney General $5,000,000 for each of fiscal years 2023 through 2027 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d10c75c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12513/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to interfere with the due process rights of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d10c75d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41701"},"text":"Pub. L. 103–322, title IV, § 41701","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tII/s205/b"},"text":"Pub. L. 117–103, div. W, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/859"},"text":"136 Stat. 859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d10c75e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d10c75f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d10c760-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id4d10c761-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s205"},"text":"section 205 of Pub. L. 117–103","children":[],"tail":", which enacted this part, as the “Abby Honold Act”, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/s205/a"},"text":"section 205(a) of Pub. L. 117–103","children":[],"tail":", set out as a Short Title of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
