{"tag":"section","attrib":{"id":"id4c9e5632-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142"},"text":null,"children":[{"tag":"num","attrib":{"value":"10142"},"text":"§ 10142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and functions of Director","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall have the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c9e5633-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing funds to eligible States, units of local government, and nonprofit organizations pursuant to subchapters V and XIII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e5634-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing programs in accordance with part B of subchapter V and, following public announcement of such programs, awarding and allocating funds and technical assistance in accordance with the criteria of part B of subchapter V, and on terms and conditions determined by the Director to be consistent with part B of subchapter V.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e5635-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperating with and providing technical assistance to States, units of local government, and other public and private organizations or international agencies involved in criminal justice activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e5636-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing for the development of technical assistance and training programs for State and local criminal justice agencies and fostering local participation in such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e5637-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Encouraging the targeting of State and local resources on efforts to reduce the incidence of drug abuse and crime and on programs relating to the apprehension and prosecution of drug offenders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e5638-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing and carrying on a specific and continuing program of cooperation with the States and units of local government designed to encourage and promote consultation and coordination concerning decisions made by the Bureau affecting State and local drug control and criminal justice priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e5639-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preparing recommendations on the State and local drug enforcement component of the National Drug Control Strategy which shall be submitted to the Associate Director of the Office on National Drug Control Policy. In making such recommendations, the Director shall review the statewide strategies submitted by such States under subchapter V, and shall obtain input from State and local drug enforcement officials. The recommendations made under this paragraph shall be provided at such time and in such form as the Director of National Drug Control Policy shall require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c9e563a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10142/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exercising such other powers and functions as may be vested in the Director pursuant to this chapter or by delegation of the Attorney General or Assistant Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c9e563b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s402"},"text":"Pub. L. 90–351, title I, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6091/a"},"text":"Pub. L. 100–690, title VI, § 6091(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4328"},"text":"102 Stat. 4328","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s241/b/1"},"text":"Pub. L. 101–647, title II, § 241(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4813"},"text":"104 Stat. 4813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c9e563c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c9e563d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"chil