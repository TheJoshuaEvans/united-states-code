{"tag":"section","attrib":{"id":"id4d34a472-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20922"},"text":null,"children":[{"tag":"num","attrib":{"value":"20922"},"text":"§ 20922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dru Sjodin National Sex Offender Public Website","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d34a473-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Dru Sjodin National Sex Offender Public Website (hereinafter in this section referred to as the “Website”), which the Attorney General shall maintain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a474-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be provided","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Website shall include relevant information for each sex offender and other person listed on a jurisdiction’s Internet site. The Website shall allow the public to obtain relevant information for each sex offender by a single query for any given zip code or geographical radius set by the user in a form and with such limitations as may be established by the Attorney General and shall have such other field search capabilities as the Attorney General may provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d34a475-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s120"},"text":"Pub. L. 109–248, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/597"},"text":"120 Stat. 597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a476-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d34a477-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d34a478-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Dru Sjodin National Sex Offender Public Website, referred to in text, is located at https://www.nsopw.gov.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d34a479-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16920"},"text":"section 16920 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
