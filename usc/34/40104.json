{"tag":"section","attrib":{"id":"id4d4a0035-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104"},"text":null,"children":[{"tag":"num","attrib":{"value":"40104"},"text":"§ 40104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4a0036-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “authorized agency” means a division or office of a State designated by a State to report, receive, or disseminate information under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a0037-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “child” means a person who is a child for purposes of the criminal child abuse law of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a0038-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “child abuse crime” means a crime committed under any law of a State that involves the physical or mental injury, sexual abuse or exploitation, negligent treatment, or maltreatment of a child by any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a0039-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “child abuse crime information” means the following facts concerning a person who has been arrested for, or has been convicted of, a child abuse crime: full name, race, sex, date of birth, height, weight, fingerprints, a brief description of the child abuse crime or offenses for which the person has been arrested or has been convicted, the disposition of the charge, and any other information that the Attorney General determines may be useful in identifying persons arrested for, or convicted of, a child abuse crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a003a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “care” means the provision of care, treatment, education, training, instruction, supervision, or recreation to children, the elderly, or individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a003b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “identifiable child abuse crime case” means a case that can be identified by the authorized criminal justice agency of the State as involving a child abuse crime by reference to the statutory citation or descriptive label of the crime as it appears in the criminal history record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a003c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “individuals with disabilities” means persons with a mental or physical impairment who require assistance to perform one or more daily living tasks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a003d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “national criminal history background check system” means the criminal history record system maintained by the Federal Bureau of Investigation based on fingerprint identification or any other method of positive identification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a003e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered individual” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4a003f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has, seeks to have, or may have access to children, the elderly, or individuals with disabilities, served by a qualified entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4a0040-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d4a0041-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by or volunteers with, or seeks to be employed by or volunteer with, a qualified entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d4a0042-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or operates, or seeks to own or operate, a qualified entity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a0043-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified entity” means a business or organization, whether public, private, for-profit, not-for-profit, or voluntary, that provides care or care placement services, including a business or organization that licenses or certifies others to provide care or care placement services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a0044-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, the Virgin Islands, Guam, and the Trust Territories of the Pacific; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4a0045-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40104/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “designated entity” means an entity designated by the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40102/f/2/A"},"text":"section 40102(f)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4a0046-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/209/s5"},"text":"Pub. L. 103–209, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2493"},"text":"107 Stat. 2493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320928/a/3"},"text":"Pub. L. 103–322, title XXXII, § 320928(a)(3)","children":[],"tail":", (j), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2132"},"text":"108 Stat. 2132","children":[],"tail":", 2133; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1075"},"text":"Pub. L. 107–110, title X, § 1075","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2090"},"text":"115 Stat. 2090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tI/s101/a/2"},"text":"Pub. L. 115–141, div. S, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1126"},"text":"132 Stat. 1126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4a0047-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4a0048-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4a0049-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5119c"},"text":"section 5119c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d4a004a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s101/a/2/A"},"text":"Pub. L. 115–141, § 101(a)(2)(A)","children":[],"tail":", amended par. (9) generally. Prior to amendment, par. (9) defined the term “provider”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s101/a/2/B"},"text":"Pub. L. 115–141, § 101(a)(2)(B)","children":[],"tail":"–(D), added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (9)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1075/1"},"text":"Pub. L. 107–110, § 1075(1)","children":[],"tail":", inserted before semicolon at end “(including an individual who is employed by a school in any capacity, including as a child care provider, a teacher, or another member of school personnel)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110/s1075/2"},"text":"Pub. L. 107–110, § 1075(2)","children":[],"tail":", inserted before semicolon at end “(including an individual who seeks to be employed by a school in any capacity, including as a child care provider, a teacher, or another member of school personnel)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320928/a/3/A"},"text":"Pub. L. 103–322, § 320928(a)(3)(A)","children":[],"tail":", amended par. (5) generally. Prior to amendment, par. (5) read as follows: “the term ‘child care’ means the provision of care, treatment, education, training, instruction, supervision, or recreation to children by persons having unsupervised access to a child;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320928/j/2"},"text":"Pub. L. 103–322, § 320928(j)(2)","children":[],"tail":", added pars. (6) and (7). Former pars. (6) and (7) redesignated (8) and (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320928/j/1"},"text":"Pub. L. 103–322, § 320928(j)(1)","children":[],"tail":", redesignated par. (6) as (8). Former par. (8) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320928/a/3/B"},"text":"Pub. L. 103–322, § 320928(a)(3)(B)","children":[],"tail":", substituted “care” for “child care” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s320928/j/1"},"text":"Pub. L. 103–322, § 320928(j)(1)","children":[],"tail":", redesignated pars. (7) to (9) as (9) to (11), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d4a004b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d4a004c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/110"},"text":"Pub. L. 107–110","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/s5"},"text":"section 5 of Pub. L. 107–110","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id4d4a004d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d4a004e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
