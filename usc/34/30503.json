{"tag":"section","attrib":{"id":"id4d47b639-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503"},"text":null,"children":[{"tag":"num","attrib":{"value":"30503"},"text":"§ 30503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for criminal investigations and prosecutions by State, local, and tribal law enforcement officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d47b63a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance other than financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d47b63b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of a State, local, or tribal law enforcement agency, the Attorney General may provide technical, forensic, prosecutorial, or any other form of assistance in the criminal investigation or prosecution of any crime that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d47b63c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes a crime of violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d47b63d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes a felony under the State, local, or tribal laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d47b63e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is motivated by prejudice based on the actual or perceived race, color, religion, national origin, gender, sexual orientation, gender identity, or disability of the victim, or is a violation of the State, local, or tribal hate crime laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b63f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under paragraph (1), the Attorney General shall give priority to crimes committed by offenders who have committed crimes in more than one State and to rural jurisdictions that have difficulty covering the extraordinary expenses relating to the investigation or prosecution of the crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d47b640-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d47b641-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award grants to State, local, and tribal law enforcement agencies for extraordinary expenses associated with the investigation and prosecution of hate crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b642-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Justice Programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing the grant program under this subsection, the Office of Justice Programs shall work closely with grantees to ensure that the concerns and needs of all affected parties, including community groups and schools, colleges, and universities, are addressed through the local infrastructure developed under the grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b643-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d47b644-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State, local, and tribal law enforcement agency that desires a grant under this subsection shall submit an application to the Attorney General at such time, in such manner, and accompanied by or containing such information as the Attorney General shall reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d47b645-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date for submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications submitted pursuant to subparagraph (A) shall be submitted during the 60-day period beginning on a date that the Attorney General shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d47b646-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, local, and tribal law enforcement agency applying for a grant under this subsection shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d47b647-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the extraordinary purposes for which the grant is needed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d47b648-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the State, local government, or Indian tribe lacks the resources necessary to investigate or prosecute the hate crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d47b649-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that, in developing a plan to implement the grant, the State, local, and tribal law enforcement agency has consulted and coordinated with nonprofit, nongovernmental victim services programs that have experience in providing services to victims of hate crimes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d47b64a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that any Federal funds received under this subsection will be used to supplement, not supplant, non-Federal funds that would otherwise be available for activities funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b64b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this subsection shall be approved or denied by the Attorney General not later than 180 business days after the date on which the Attorney General receives the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b64c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this subsection shall not exceed $100,000 for any single jurisdiction in any 1-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b64d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2011-12-31"},"text":"December 31, 2011","children":[],"tail":", the Attorney General shall submit to Congress a report describing the applications submitted for grants under this subsection, the award of such grants, and the purposes for which the grant amounts were expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d47b64e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30503/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $5,000,000 for each of fiscal years 2010, 2011, and 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d47b64f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dE/s4704"},"text":"Pub. L. 111–84, div. E, § 4704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2837"},"text":"123 Stat. 2837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d47b650-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d47b651-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d47b652-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3716"},"text":"section 3716 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
