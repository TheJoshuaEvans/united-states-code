{"tag":"section","attrib":{"id":"id4ced1354-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272"},"text":null,"children":[{"tag":"num","attrib":{"value":"11272"},"text":"§ 11272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease of surplus Federal facilities for use as runaway and homeless youth centers or as transitional living youth shelter facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced1355-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of lease arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into cooperative lease arrangements with States, localities, and nonprofit private agencies to provide for the use of appropriate surplus Federal facilities transferred by the General Services Administration to the Department of Health and Human Services for use as runaway and homeless youth centers or as transitional living youth shelter facilities if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1356-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant involved has suitable financial support necessary to operate a runaway and homeless youth center or transitional living youth project, as the case may be, under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1357-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is able to demonstrate the program expertise required to operate such center in compliance with this subchapter, whether or not the applicant is receiving a grant under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1358-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant has consulted with and obtained the approval of the chief executive officer of the unit of local government in which the facility is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1359-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability; rent-free use; structural changes: Federal ownership and consent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced135a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each facility made available under this section shall be made available for a period of not less than 2 years, and no rent or fee shall be charged to the applicant in connection with use of such facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced135b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any structural modifications or additions to facilities made available under this section shall become the property of the United States. All such modifications or additions may be made only after receiving the prior written consent of the Secretary or other appropriate officer of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced135c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s381"},"text":"Pub. L. 93–415, title III, § 381","children":[],"tail":", formerly § 316, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s655/2"},"text":"Pub. L. 98–473, title II, § 655(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2124"},"text":"98 Stat. 2124","children":[],"tail":"; renumbered § 342 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7273/b"},"text":"Pub. L. 100–690, title VII, § 7273(b)","children":[],"tail":", (e)(2), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4454"},"text":"102 Stat. 4454","children":[],"tail":", 4455; renumbered § 372, "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/B/ii"},"text":"Pub. L. 102–586, § 3(g)(1)(B)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5022"},"text":"106 Stat. 5022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/b/tI/s129/a/2/E"},"text":"Pub. L. 105–277, div. A, § 101(b) [title I, § 129(a)(2)(E)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-50"},"text":"112 Stat. 2681–50","children":[],"tail":", 2681–76; renumbered § 381, "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/q"},"text":"Pub. L. 106–71, § 3(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"te