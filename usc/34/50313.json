{"tag":"section","attrib":{"id":"id4d5d136b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313"},"text":null,"children":[{"tag":"num","attrib":{"value":"50313"},"text":"§ 50313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Law Enforcement Congressional Badge of Bravery Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d136c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Justice a Federal Law Enforcement Congressional Badge of Bravery Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d136d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Board shall do the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d136e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Design the Federal Law Enforcement Badge with appropriate ribbons and appurtenances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d136f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Select an engraver to produce each Federal Law Enforcement Badge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1370-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommend recipients of the Federal Law Enforcement Badge from among those nominations timely submitted to the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1371-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annually present to the Attorney General the names of Federal law enforcement officers who the Federal Board recommends as Federal Law Enforcement Badge recipients in accordance with the criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50312/a"},"text":"section 50312(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1372-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After approval by the Attorney General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1373-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the Federal Law Enforcement Badges from the engraver selected under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1374-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" send a letter announcing the award of each Federal Law Enforcement Badge to the Federal agency head who nominated the recipient of such Federal Law Enforcement Badge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1375-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" send a letter to each Member of Congress representing the congressional district where the recipient of each Federal Law Enforcement Badge resides to offer such Member an opportunity to present such Federal Law Enforcement Badge; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1376-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make or facilitate arrangements for presenting each Federal Law Enforcement Badge in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50314"},"text":"section 50314 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1377-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Set an annual timetable for fulfilling the duties described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1378-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d1379-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Board shall be composed of 7 members appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d137a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member jointly appointed by the majority leader and minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d137b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member jointly appointed by the Speaker and minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d137c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member from the Department of Justice appointed by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d137d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members of the Federal Law Enforcement Officers Association appointed by the Executive Board of the Federal Law Enforcement Officers Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d137e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two members of the Fraternal Order of Police appointed by the Executive Board of the Fraternal Order of Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d137f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1380-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Federal Board members may be members of the Federal Law Enforcement Officers Association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1381-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Federal Board members may be members of the Fraternal Order of Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1382-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal Board members shall be individuals with knowledge or expertise, whether by experience or training, in the field of Federal law enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1383-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal Board member shall be appointed for 2 years and may be reappointed. A vacancy in the Federal Board shall not affect the powers of the Federal Board and shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1384-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d1385-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairperson of the Federal Board shall be a Federal Board member elected by a majority of the Federal Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1386-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Board shall conduct its first meeting not later than 90 days after the appointment of a majority of Federal Board members. Thereafter, the Federal Board shall meet at the call of the Chairperson, or in the case of a vacancy of the position of Chairperson, at the call of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1387-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting and rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of Federal Board members shall constitute a quorum to conduct business, but the Federal Board may establish a lesser quorum for conducting hearings scheduled by the Federal Board. The Federal Board may establish by majority vote any other rules for the conduct of the business of the Federal Board, if such rules are not inconsistent with this subchapter or other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1388-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d1389-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d138a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Board may hold hearings, sit and act at times and places, take testimony, and receive evidence as the Federal Board considers appropriate to carry out the duties of the Federal Board under this subchapter. The Federal Board may administer oaths or affirmations to witnesses appearing before it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d138b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Witnesses requested to appear before the Federal Board may be paid the same fees as are paid to witnesses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1821"},"text":"section 1821 of title 28","children":[],"tail":". The per diem and mileage allowances for witnesses shall be paid from funds appropriated to the Federal Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d138c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to sections 552, 552a, and 552b of title 5—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d138d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Board may secure directly from any Federal department or agency information necessary to enable it to carry out this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d138e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request of the Federal Board, the head of that department or agency shall furnish the information to the Federal Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d138f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be kept confidential","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Board shall not disclose any information which may compromise an ongoing law enforcement investigation or is otherwise required by law to be kept confidential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1390-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d1391-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), each Federal Board member shall be compensated at a rate equal to the daily equivalent of the annual rate of basic pay prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":" for each day (including travel time) during which such Federal Board member is engaged in the performance of the duties of the Federal Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1392-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of compensation for government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal Board members who serve as officers or employees of the Federal Government or a State or a local government may not receive additional pay, allowances, or benefits by reason of their service on the Federal Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1393-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50313/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal Board member shall receive travel expenses, including per diem in lieu of subsistence, in accordance with applicable provisions under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d1394-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/298/tI/s103"},"text":"Pub. L. 110–298, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-31"},"text":"July 31, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2987"},"text":"122 Stat. 2987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d1395-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d1396-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d1397-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15243"},"text":"section 15243 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
