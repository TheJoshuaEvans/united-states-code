{"tag":"section","attrib":{"id":"id4d539cbd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742"},"text":null,"children":[{"tag":"num","attrib":{"value":"40742"},"text":"§ 40742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States to implement DNA arrestee collection processes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d539cbe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall, subject to amounts made available pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40744"},"text":"section 40744 of this title","children":[],"tail":", carry out a grant program for the purpose of assisting States with the costs associated with the implementation of DNA arrestee collection processes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d539cbf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d539cc0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, in addition to any other requirements specified by the Attorney General, a State shall submit to the Attorney General an application that demonstrates that it has statutory authorization for the implementation of a DNA arrestee collection process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d539cc1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-supplanting funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted under paragraph (1) by a State shall include assurances that the amounts received under the grant under this section shall be used to supplement, not supplant, State funds that would otherwise be available for the purpose described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d539cc2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall require a State seeking a grant under this section to document how such State will use the grant to meet expenses associated with a State’s implementation or planned implementation of a DNA arrestee collection process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d539cc3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d539cc4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount available to a State under this section shall be based on the projected costs that will be incurred by the State to implement a DNA arrestee collection process. Subject to paragraph (2), the Attorney General shall retain discretion to determine the amount of each such grant awarded to an eligible State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d539cc5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum grant allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a State seeking a grant under this section with respect to the implementation of a DNA arrestee collection process, such State shall be eligible for a grant under this section that is equal to no more than 100 percent of the first year costs to the State of implementing such process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d539cc6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a grant under this section, a State shall have a procedure in place to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d539cc7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide written notification of expungement provisions and instructions for requesting expungement to all persons who submit a DNA profile or DNA data for inclusion in the index;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d539cc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the eligibility criteria for expungement and instructions for requesting expungement on an appropriate public Web site; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d539cc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40742/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a determination on all expungement requests not later than 90 days after receipt and provide a written response of the determination to the requesting party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d539cca-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/253/s3"},"text":"Pub. L. 112–253, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2408"},"text":"126 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d539ccb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d539ccc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d539ccd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14137a"},"text":"section 14137a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
