{"tag":"section","attrib":{"id":"id4d133926-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555"},"text":null,"children":[{"tag":"num","attrib":{"value":"12555"},"text":"§ 12555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d133927-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d133928-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may award scholarships to participants who agree to work in a State or local police force in accordance with agreements entered into pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133929-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d13392a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), each scholarship payment made under this section for each academic year shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d13392b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d13392c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the educational expenses related to attending an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13392d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a participant who is pursuing a course of educational study during substantially an entire calendar year, the amount of scholarship payments made during such year shall not exceed $13,333.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13392e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of scholarship assistance received by any one student under this section shall not exceed $40,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d13392f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recipients of scholarship assistance under this section shall continue to receive such scholarship payments only during such periods as the Director finds that the recipient is maintaining satisfactory progress as determined by the institution of higher education the recipient is attending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133930-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d133931-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall make scholarship payments under this section directly to the institution of higher education that the student is attending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d133932-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each institution of higher education receiving a payment on behalf of a participant pursuant to subparagraph (A) shall remit to such student any funds in excess of the costs of tuition, fees, and room and board payable to the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d133933-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d133934-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may make payments to a participant to reimburse such participant for the costs of educational expenses if the student agrees to work in a State or local police force in accordance with the agreement entered into pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133935-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d133936-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each payment made pursuant to paragraph (1) for each academic year of study shall not exceed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d133937-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d133938-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of educational expenses related to attending an institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d133939-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a participant who is pursuing a course of educational study during substantially an entire calendar year, the amount of scholarship payments made during such year shall not exceed $13,333.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13393a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of payments made pursuant to subparagraph (A) to any 1 student shall not exceed $40,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d13393b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of scholarship","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Scholarships awarded under this subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002133"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002133"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" shall only be used to attend a 4-year institution of higher education, except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d13393c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scholarships may be used for graduate and professional study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d13393d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a participant has enrolled in the program upon or after transfer to a 4-year institution of higher education, the Director may reimburse the participant for the participant’s prior educational expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d13393e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d13393f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d133940-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each participant receiving a scholarship or a payment under this section shall enter into an agreement with the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d133941-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agreement under subparagraph (A) shall contain assurances that the participant shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d133942-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after successful completion of a baccalaureate program and training as prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12557"},"text":"section 12557 of this title","children":[],"tail":", work for 4 years in a State or local police force without there having arisen sufficient cause for the participant’s dismissal under the rules applicable to members of the police force of which the participant is a member;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d133943-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" complete satisfactorily—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d133944-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an educational course of study and receipt of a baccalaureate degree (in the case of undergraduate study) or the reward of credit to the participant for having completed one or more graduate courses (in the case of graduate study); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d133945-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Police Corps training and certification by the Director that the participant has met such performance standards as may be established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12557"},"text":"section 12557 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d133946-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repay all of the scholarship or payment received plus interest at the rate of 10 percent if the conditions of clauses (i) and (ii) are not complied with.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133947-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d133948-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A recipient of a scholarship or payment under this section shall not be considered to be in violation of the agreement entered into pursuant to paragraph (1) if the recipient—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d133949-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d13394a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes permanently and totally disabled as established by the sworn affidavit of a qualified physician.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13394b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a scholarship recipient is unable to comply with the repayment provision set forth in paragraph (1)(B)(ii) ","children":[{"tag":"ref","attrib":{"idref":"fn002134"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002134"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be paragraph “(1)(B)(iii)”."}],"tail":" because of a physical or emotional disability or for good cause as determined by the Director, the Director may substitute community service in a form prescribed by the Director for the required repayment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d13394c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall expeditiously seek repayment from a participant who violates an agreement described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d13394d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dependent child","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A dependent child of a law enforcement officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d13394e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a member of a State or local police force or is a Federal criminal investigator or uniformed police officer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d13394f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not a participant in the Police Corps program, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133950-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who serves in a State for which the Director has approved a Police Corps plan, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133951-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is killed in the course of performing police duties,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be entitled to the scholarship assistance authorized in this section for any course of study in any accredited institution of higher education. Such dependent child shall not incur any repayment obligation in exchange for the scholarship assistance provided in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d133952-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12555/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each participant desiring a scholarship or payment under this section shall submit an application as prescribed by the Director in such manner and accompanied by such information as the Director may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d133953-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200106"},"text":"Pub. L. 103–322, title XX, § 200106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2050"},"text":"108 Stat. 2050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11006/1"},"text":"Pub. L. 107–273, div. C, title I, § 11006(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1817"},"text":"116 Stat. 1817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d133954-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d133955-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d133956-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14095"},"text":"section 14095 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d133957-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (a)(2), (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “$10,000” for “$7,500” in subpar. (A)(i), “$13,333” for “$10,000” in subpar. (B), and “$40,000” for “$30,000” in subpar. (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
