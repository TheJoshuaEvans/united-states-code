{"tag":"section","attrib":{"id":"id4ccba8a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10495"},"text":null,"children":[{"tag":"num","attrib":{"value":"10495"},"text":"§ 10495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of grants; limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ccba8a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10495/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In approving grants under this subchapter, the Attorney General shall assure an equitable distribution of assistance among the States, among urban and rural areas of the United States, and among urban and rural areas of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba8a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10495/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award a grant each fiscal year, not to exceed $100,000 to a State or local law enforcement agency or $250,000 to a law enforcement organization for a period not to exceed 5 years. In any application from a State or local law enforcement agency or organization for a grant to continue a program for the second, third, fourth, or fifth fiscal year following the first fiscal year in which a grant was awarded to such agency, the Attorney General shall review the progress made toward meeting the objectives of the program. The Attorney General may refuse to award a grant if the Attorney General finds sufficient progress has not been made toward meeting such objectives, but only after affording the applicant notice and an opportunity for reconsideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba8a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10495/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of grant funds received by a State or a local law enforcement agency or organization may be used for administrative purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba8a9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2305"},"text":"Pub. L. 90–351, title I, § 2305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210201/a/3"},"text":"Pub. L. 103–322, title XXI, § 210201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2063"},"text":"108 Stat. 2063","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba8aa-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba8ab-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba8ac-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796jj–4"},"text":"section 3796jj–4 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
