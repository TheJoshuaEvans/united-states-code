":"p","attrib":{},"text":"The term “Federal Board members” means the members of the Federal Board appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50313/c"},"text":"section 50313(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1334-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Law Enforcement Badge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal Law Enforcement Badge” means the Federal Law Enforcement Congressional Badge of Bravery described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50311"},"text":"section 50311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1335-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal law enforcement officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal law enforcement officer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1336-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50301/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a Federal employee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d1337-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50301/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has statutory authority to make arrests or ap