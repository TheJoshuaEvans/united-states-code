{"tag":"section","attrib":{"id":"id4d17f3e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623"},"text":null,"children":[{"tag":"num","attrib":{"value":"12623"},"text":"§ 12623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and best practices for use of non-invasive and non-permanent tracking devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d17f3e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f3e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-03-23"},"text":"March 23, 2018","children":[],"tail":", the Attorney General, in consultation with the Secretary of Health and Human Services and leading research, advocacy, self-advocacy, and service organizations, shall establish standards and best practices relating to the use of non-invasive and non-permanent tracking technology, where a guardian or parent has determined that a non-invasive and non-permanent tracking device is the least restrictive alternative, to locate individuals as described in subsection (a)(2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12621"},"text":"section 12621 of this title","children":[],"tail":", as added by this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f3e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the standards and best practices required under paragraph (1), the Attorney General shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f3e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d17f3e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria used to determine which individuals would benefit from the use of a tracking device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria used to determine who should have direct access to the tracking system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which non-invasive and non-permanent types of tracking devices can be used in compliance with the standards and best practices; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f3ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish standards and best practices the Attorney General determines are necessary to the administration of a tracking system, including procedures to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d17f3eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" safeguard the privacy of the data used by the tracking device such that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d17f3ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to the data is restricted to law enforcement and health agencies determined necessary by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d17f3ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection, use, and retention of the data is solely for the purpose of preventing injury to or death of the individual wearing the tracking device;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria to determine whether use of the tracking device is the least restrictive alternative in order to prevent risk of injury or death before issuing the tracking device, including the previous consideration of less restrictive alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training for law enforcement agencies to recognize signs of abuse during interactions with applicants for tracking devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the civil rights and liberties of the individuals who use tracking devices, including their rights under the Fourth Amendment to the Constitution of the United States and title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a complaint and investigation process to address—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d17f3f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of noncompliance by recipients of grants under subsection (a)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12621"},"text":"section 12621 of this title","children":[],"tail":", as added by this Act, with the best practices established by the Attorney General or other applicable law; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d17f3f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of a tracking device over the objection of an individual; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f3f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the role that State agencies should have in the administration of a tracking system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f3f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards and best practices established pursuant to paragraph (1) shall take effect 90 days after publication of such standards and practices by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f3f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f3f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity that receives a grant under subsection (a)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12621"},"text":"section 12621 of this title","children":[],"tail":", as added by this Act, shall comply with any standards and best practices relating to the use of tracking devices established by the Attorney General in accordance with subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f3f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with the Secretary of Health and Human Services, shall determine whether an entity that receives a grant under subsection (a)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12621"},"text":"section 12621 of this title","children":[],"tail":", as added by this Act, acts in compliance with the standards and best practices described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f3f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of standards and best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards and best practices established by the Attorney General under subsection (a) shall apply only to the grant programs authorized under subsection (a)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12621"},"text":"section 12621 of this title","children":[],"tail":", as added by this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f3fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f3fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any tracking data provided by tracking devices issued under this program may not be used by a Federal entity to create a database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f3fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12623/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act may be construed to require that a parent or guardian use a tracking device to monitor the location of a child or adult under that parent or guardian’s supervision if the parent or guardian does not believe that the use of such device is necessary or in the interest of the child or adult under supervision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d17f3fd-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dQ/tIII/s302"},"text":"Pub. L. 115–141, div. Q, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1121"},"text":"132 Stat. 1121","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d17f3fe-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d17f3ff-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d17f400-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, means div. Q of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141"},"text":"Pub. L. 115–141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1115"},"text":"132 Stat. 1115","children":[],"tail":", known as Kevin and Avonte’s Law of 2018. For complete classification of div. Q to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dQ/s1"},"text":"section 1 of div. Q of Pub. L. 115–141","children":[],"tail":", set out as a Short Title of 2018 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (a)(2)(B)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":". Title VII of the Act is classified generally to subchapter VI (§ 2000e et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d17f401-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Kevin and Avonte’s Law of 2018, and also as part of the Consolidated Appropriations Act, 2018, and not as part of the Violent Crime Control and Law Enforcement Act of 1994 which enacted this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d17f402-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d17f403-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dQ/tIII/s301"},"text":"Pub. L. 115–141, div. Q, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1120"},"text":"132 Stat. 1120","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/141/dQ/tIII/s301"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section]:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Child","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘child’ means an individual who is less than 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Indian tribe’ has the meaning given that term in section 4(e) of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"25 U.S.C. 5304(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Law enforcement agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘law enforcement agency’ means an agency of a State, unit of local government, or Indian tribe that is authorized by law or by a government agency to engage in or supervise the prevention, detection, investigation, or prosecution of any violation of criminal law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-invasive and non-permanent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘non-invasive and non-permanent’ means, with regard to any technology or device, that the procedure to install the technology or device does not create an external or internal marker or implant a device, such as a microchip, or other trackable items.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means each of the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unit of local government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘unit of local government’ means a county, municipality, town, township, village, parish, borough, or other unit of general government below the State level.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
