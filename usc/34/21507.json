{"tag":"section","attrib":{"id":"id4d3e196d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21507"},"text":null,"children":[{"tag":"num","attrib":{"value":"21507"},"text":"§ 21507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3e196e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-08"},"text":"February 8, 2016","children":[],"tail":", the Secretary of Homeland Security, the Secretary of State, and the Attorney General shall develop a process by which to implement "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s21503/e/5"},"text":"section 21503(e)(5) of this title","children":[],"tail":" and the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s212b"},"text":"section 212b of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e196f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-08"},"text":"February 8, 2016","children":[],"tail":", the Secretary of Homeland Security, the Secretary of State, and the Attorney General shall jointly submit a report to, and shall consult with, the appropriate congressional committees on the process developed under subsection (a