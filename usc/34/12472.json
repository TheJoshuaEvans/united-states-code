{"tag":"section","attrib":{"id":"id4d099c5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12472"},"text":null,"children":[{"tag":"num","attrib":{"value":"12472"},"text":"§ 12472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this subpart is to reduce domestic violence, dating violence, sexual assault, and stalking, and to prevent homelessness by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d099c5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12472/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting the safety of victims of domestic violence, dating violence, sexual assault, and stalking who reside in homeless shelters, public housing, assisted housing, tribally designated housing, or other emergency, transitional, permanent, or affordable housing, and ensuring that such victims have meaningful access to the criminal justice system without jeopardizing such housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12472/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating long-term housing solutions that develop communities and provide sustainable living solutions for victims of domestic violence, dating violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12472/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building collaborations among victim service providers, homeless service providers, housing providers, and housing agencies to provide appropriate services, interventions, and training to address the housing needs of victims of domestic violence, dating violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12472/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enabling public and assisted housing agencies, tribally designated housing entities, private landlords, property management companies, and other housing providers and agencies to respond appropriately to domestic violence, dating violence, sexual assault, and stalking, while maintaining a safe environment for all housing residents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d099c62-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41402"},"text":"Pub. L. 103–322, title IV, § 41402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tVI/s601"},"text":"Pub. L. 109–162, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3031"},"text":"119 Stat. 3031","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tVI/s601/a/2"},"text":"Pub. L. 113–4, title VI, § 601(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/102"},"text":"127 Stat. 102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d099c63-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d099c64-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d099c65-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043e–1"},"text":"section 14043e–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d099c66-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" substituted “subpart” for “part” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
