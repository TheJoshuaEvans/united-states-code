{"tag":"section","attrib":{"id":"id4d395e41-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988"},"text":null,"children":[{"tag":"num","attrib":{"value":"20988"},"text":"§ 20988.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jessica Lunsford Address Verification Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395e42-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Jessica Lunsford Address Verification Grant Program (hereinafter in this section referred to as the “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e43-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the Program, the Attorney General is authorized to award grants to State,","children":[{"tag":"ref","attrib":{"idref":"fn002193"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002193"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “States,”."}],"tail":" local governments, and Indian tribal governments to assist in carrying out programs requiring an appropriate official to verify, at appropriate intervals, the residence of all or some registered sex offenders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e44-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e45-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State or local government seeking a grant under this section shall submit an application to the Attorney General at such time, in such manner, and accompanied by such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted pursuant to paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395e47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the activities for which assistance under this section is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such additional assurances as the Attorney General determines to be essential to ensure compliance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Attorney General shall ensure that different approaches to address verification are funded to allow an assessment of effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e4b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each of the fiscal years 2007 through 2009 such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e4c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-04-01"},"text":"April 1, 2009","children":[],"tail":", the Attorney General shall report to Congress—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395e4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the effectiveness and value of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comparing the cost effectiveness of address verification to reduce sex offenses compared to other alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395e4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20988/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making recommendations for continuing funding and the appropriate levels for such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395e50-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s631"},"text":"Pub. L. 109–248, title VI, § 631","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/641"},"text":"120 Stat. 641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395e51-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395e52-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395e53-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16988"},"text":"section 16988 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
