{"tag":"section","attrib":{"id":"id4cc232b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443"},"text":null,"children":[{"tag":"num","attrib":{"value":"10443"},"text":"§ 10443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Office on Violence Against Women","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc232b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, by and with the advice and consent of the Senate, shall appoint a Director for the Office on Violence Against Women (in this subchapter referred to as the “Director”) to be responsible, under the general authority of the Attorney General, for the administration, coordination, and implementation of the programs and activities of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc232b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other employment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc232b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in any employment other than that of serving as Director; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold any office in, or act in any capacity for, any organization, agency, or institution with which the Office makes any contract or other agreement under the Violence Against Women Act of 1994 (title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":"), the Violence Against Women Act of 2000 (division B of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Public Law 106–386","children":[],"tail":"), the Violence Against Women and Department of Justice Reauthorization Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Public Law 109–162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/119/2960"},"text":"119 Stat. 2960","children":[],"tail":"), the Violence Against Women Reauthorization Act of 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Public Law 113–4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/127/54"},"text":"127 Stat. 54","children":[],"tail":"), or the Violence Against Women Act Reauthorization Act of 2022."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc232b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a vacancy, the President may designate an officer or employee who shall act as Director during the vacancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc232b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10443/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be compensated at a rate of pay not to exceed the rate payable for level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc232b7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2003"},"text":"Pub. L. 90–351, title I, § 2003","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIV/s402/3"},"text":"Pub. L. 107–273, div. A, title IV, § 402(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1789"},"text":"116 Stat. 1789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tIX/s901/b"},"text":"Pub. L. 117–103, div. W, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/910"},"text":"136 Stat. 910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc232b8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc232b9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cc232ba-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 1994, referred to in subsec. (b)(2), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 2000, referred to in (b)(2), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1491"},"text":"114 Stat. 1491","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2000 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women and Department of Justice Reauthorization Act of 2005, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2960"},"text":"119 Stat. 2960","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1"},"text":"section 1 of Pub. L. 109–162","children":[],"tail":", set out as a Short Title of 2006 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Reauthorization Act of 2013, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/54"},"text":"127 Stat. 54","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s1"},"text":"section 1 of Pub. L. 113–4","children":[],"tail":", set out as a Short Title of 2013 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act Reauthorization Act of 2022, referred to in subsec. (b)(2), is div. W of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/840"},"text":"136 Stat. 840","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s1"},"text":"section 1 of div. W of Pub. L. 117–103","children":[],"tail":", set out as a Short Title of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc232bb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–0a"},"text":"section 3796gg–0a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cc232bc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s2003"},"text":"section 2003 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2008 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10447"},"text":"section 10447 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc232bd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s901/b/1"},"text":"Pub. L. 117–103, § 901(b)(1)","children":[],"tail":", substituted “Office on Violence Against Women” for “Violence Against Women Office” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s901/b/2"},"text":"Pub. L. 117–103, § 901(b)(2)","children":[],"tail":", substituted “the Office on Violence Against Women” for “the Violence Against Women Office” and made technical amendment to reference in original act which appears in text as reference to this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s901/b/3"},"text":"Pub. L. 117–103, § 901(b)(3)","children":[],"tail":", substituted “103–322), the Violence” for “103–322) or the Violence” and i