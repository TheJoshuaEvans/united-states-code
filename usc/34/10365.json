{"tag":"section","attrib":{"id":"id4cbb0640-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10365"},"text":null,"children":[{"tag":"num","attrib":{"value":"10365"},"text":"§ 10365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal share of a grant made under this subchapter may not exceed 75 percent of the total costs of the project described in the application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10362/a"},"text":"section 10362(a) of this title","children":[],"tail":" for the fiscal year for which the project receives assistance under this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cbb0641-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1605"},"text":"Pub. L. 90–351, title I, § 1605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/521/s4/a/3"},"text":"Pub. L. 102–521, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3405"},"text":"106 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbb0642-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbb0643-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbb0644-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Se