{"tag":"section","attrib":{"id":"id4d4c70fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40503"},"text":null,"children":[{"tag":"num","attrib":{"value":"40503"},"text":"§ 40503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An applicant receiving a grant award under this chapter may use such funds to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c70ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay for the costs incurred during or after fiscal year 2017 for the transportation, processing, identification, and reporting of missing persons and unidentified remains, including migrants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee200-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and expand programs developed to improve the reporting of unidentified persons in accordance with the assurances provided in the application submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40502/b"},"text":"section 40502(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee201-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40503/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hire and maintain additional DNA case analysts and technicians, fingerprint examiners, forensic odontologists, and forensic anthropologists, needed to support such identification programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4ee202-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40503/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure and maintain state of the art multi-modal, multi-purpose forensic and DNA-typing and analytical equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4ee203-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/177/tII/s205"},"text":"Pub. L. 106–177, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/3"},"text":"Pub. L. 116–277, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3369"},"text":"134 Stat. 3369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4ee204-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4ee205-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4d4ee206-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 40503, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/177/tII/s204"},"text":"Pub. L. 106–177, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/36"},"text":"114 Stat. 36","children":[],"tail":", related to uses of funds that a State received to establish or expand programs developed to improve the reporting of unidentified persons, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/3"},"text":"Pub. L. 116–277, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3369"},"text":"134 Stat. 3369","children":[],"tail":". Such section was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14663"},"text":"section 14663 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as section 40503."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
