{"tag":"section","attrib":{"id":"id4d512c71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40724"},"text":null,"children":[{"tag":"num","attrib":{"value":"40724"},"text":"§ 40724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DNA research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512c72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving DNA technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make grants for research and development to improve forensic DNA technology, including increasing the identification accuracy and efficiency of DNA analysis, decreasing time and expense, and increasing portability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make grants to appropriate entities under which research is carried out through demonstration projects involving coordinated training and commitment of resources to law enforcement agencies and key criminal justice participants to demonstrate and evaluate the use of forensic DNA technology in conjunction with other forensic tools. The demonstration projects shall include scientific evaluation of the public safety benefits, improvements to law enforcement operations, and cost-effectiveness of increased collection and use of DNA evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for each of fiscal years 2017 through 2021 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512c75-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s305"},"text":"Pub. L. 108–405, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2273"},"text":"118 Stat. 2273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s8/a"},"text":"Pub. L. 114–324, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1954"},"text":"130 Stat. 1954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512c76-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512c77-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512c78-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14136b"},"text":"section 14136b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d512c79-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":" substituted “$5,000,000 for each of fiscal years 2017 through 2021” for “$15,000,000 for each of fiscal years 2005 through 2009”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
