{"tag":"section","attrib":{"id":"id4cbd5000-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10386"},"text":null,"children":[{"tag":"num","attrib":{"value":"10386"},"text":"§ 10386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation or suspension of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the Attorney General determines, as a result of the reviews required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10385"},"text":"section 10385 of this title","children":[],"tail":", or otherwise, that a grant recipient under this subchapter is not in substantial compliance with the terms and requirements of an approved grant application submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10382"},"text":"section 10382 of this title","children":[],"tail":", the Attorney General may revoke or suspend funding of that grant, in whole or in part."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cbd5001-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1706"},"text":"Pub. L. 90–351, title I, § 1706","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tI/s10003/a/3"},"text":"Pub. L. 103–322, title I, § 10003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1813"},"text":"108 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd5002-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd5003-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail"