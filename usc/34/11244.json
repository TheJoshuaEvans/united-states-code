{"tag":"section","attrib":{"id":"id4ced130e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244"},"text":null,"children":[{"tag":"num","attrib":{"value":"11244"},"text":"§ 11244.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects to provide services to youth in rural areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced130f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1310-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may make grants on a competitive basis to States, localities, and private entities (and combinations of such entities) to provide services (including transportation) authorized to be provided under part A, to runaway and homeless youth in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1311-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced1312-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each grant made under paragraph (1) may not exceed $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1313-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In each fiscal year for which funds are appropriated to carry out this section, grants shall be made under paragraph (1) to eligible applicants to carry out projects in not fewer than 10 States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1314-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 2 grants may be made under paragraph (1) in each fiscal year to carry out projects in a particular State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1315-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each eligible applicant that receives a grant for a fiscal year to carry out a project under this section shall have priority to receive a grant for the subsequent fiscal year to carry out a project under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1316-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible to receive a grant under subsection (a), an applicant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1317-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application in such form and containing such information and assurances as the Secretary may require by rule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1318-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to carry out such project in a geographical area that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced1319-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a population under 20,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced131a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located outside a Standard Metropolitan Statistical Area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced131b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agree to provide to the Secretary an annual report identifying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4ced131c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of runaway and homeless youth who receive services under the project carried out by the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ced131d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of services authorized under part A that were needed by, but not provided to, such youth in the geographical area served by the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ced131e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons the services identified under clause (ii) were not provided by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4ced131f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11244/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced1320-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s344"},"text":"Pub. L. 93–415, title III, § 344","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/C"},"text":"Pub. L. 102–586, § 3(g)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5024"},"text":"106 Stat. 5024","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/r/2"},"text":"Pub. L. 106–71, § 3(r)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1043"},"text":"113 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI/s114"},"text":"Pub. L. 108–96, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1170"},"text":"117 Stat. 1170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced1321-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced1322-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced1323-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–24"},"text":"section 5714–24 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced1324-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96"},"text":"Pub. L. 108–96","children":[],"tail":" substituted “Demonstration” for “Temporary demonstration” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71"},"text":"Pub. L. 106–71","children":[],"tail":" substituted “The Secretary” for “With funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5751/c"},"text":"section 5751(c) of this title","children":[],"tail":", the Secretary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
