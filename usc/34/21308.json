{"tag":"section","attrib":{"id":"id4d3bcfd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21308"},"text":null,"children":[{"tag":"num","attrib":{"value":"21308"},"text":"§ 21308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this chapter $5,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d3bcfd4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tIV/s409"},"text":"Pub. L. 114–22, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/258"},"text":"129 Stat. 258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tI/s107"},"text":"Pub. L. 117–103, div. W, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/851"},"text":"136 Stat. 851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d3bcfd5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d3bcfd6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d3bcfd7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ",