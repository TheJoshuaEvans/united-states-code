01/a/3"},"text":"Pub. L. 113–4, title VI, § 601(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/102"},"text":"127 Stat. 102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0c0c84-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0c0c85-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d0c0c86-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Cranston-Gonzalez National Affordable Housing Act, referred to in par. (1)(E), (F), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4079"},"text":"104 Stat. 4079","children":[],"tail":". Title II of the Act, known as the HOME Investment Partnerships Act, is classified principally to subchapter II (§ 12721 et seq.) of chapter 130 of Title 42, The Public Health and Welfare. Subtitle D of title VIII of the Act, known as the AIDS Housing Opportunity Act, is classified generally to chapter 131 (§ 12901 et seq.) of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12701"},"text":"section 12701 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Housing and Community Development Act of 1974, referred to in