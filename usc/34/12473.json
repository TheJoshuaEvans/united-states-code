(","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12901"},"text":"42 U.S.C. 12901","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under title I of the Housing and Community Development Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5301"},"text":"42 U.S.C. 5301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “continuum of care” means a community plan developed to organize and deliver housing and services to meet the specific needs of people who are homeless as they move to stable housing and achieve maximum self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “low-income housing assistance voucher” means housing assistance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public housing” means housing described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/1"},"text":"section 1437a(b)(1) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public housing agency” means an agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437a/b/6"},"text":"section 1437a(b)(6) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c75-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the terms “homeless”, “homeless individual”, and “homeless person”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d099c76-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mean an individual who lacks a fixed, regular, and adequate nighttime residence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d099c77-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d099c78-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d099c79-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is sharing the housing of other persons due to loss of housing, economic hardship, or a similar reason;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d099c7a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is living in a motel, hotel, trailer park, or campground due to the lack of alternative adequate accommodations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d099c7b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is living in an emergency or transitional shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d099c7c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is abandoned in a hospital; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d099c7d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is awaiting foster care placement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d099c7e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who has a primary nighttime residence that is a public or private place not designed for or ordinarily used as a regular sleeping accommodation for human beings; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d099c7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" migratory children (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s6399"},"text":"section 6399 of title 20","children":[],"tail":") who qualify as homeless under this section because the children are living in circumstances described in this paragraph;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d099c80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12473/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “homeless service provider” means a nonprofit, nongovernmental homeless service provider, such as a homeless shelter, a homeless service or advocacy program, a tribal organization serving homeless individuals, or coalition or other nonprofit, nongovernmental organization carrying out a community-based homeless or housing program that has a documented history of effective work concerning homelessness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"i