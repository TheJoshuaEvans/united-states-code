{"tag":"section","attrib":{"id":"id4d643f8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60534"},"text":null,"children":[{"tag":"num","attrib":{"value":"60534"},"text":"§ 60534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Prisons policy on chapel library materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d643f8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60534/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2008-04-09"},"text":"April 9, 2008","children":[],"tail":", the Director of the Bureau of Prisons shall discontinue the Standardized Chapel Library project, or any other project by whatever designation that seeks to compile, list, or otherwise restrict prisoners’ access to reading materials, audiotapes, videotapes, or any other materials made available in a chapel library, except that the Bureau of Prisons may restrict access to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60534/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any materials in a chapel library that seek to incite, promote, or otherwise suggest the commission of violence or criminal activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60534/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other materials prohibited by any other law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60534/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to impact policies of the Bureau of Prisons related to access by specific prisoners to materials for security, safety, sanitation, or disciplinary reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f90-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s214"},"text":"Pub. L. 110–199, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/683"},"text":"122 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f91-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f92-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d643f93-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17534"},"text":"section 17534 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
