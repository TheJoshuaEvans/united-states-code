{"tag":"section","attrib":{"id":"id4cbfc233-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424"},"text":null,"children":[{"tag":"num","attrib":{"value":"10424"},"text":"§ 10424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and distribution of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbfc234-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount appropriated under this subchapter in any fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc235-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.4 percent shall be allocated to each of the participating States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc236-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the total funds remaining after the allocation under paragraph (1), there shall be allocated to each of the participating States an amount which bears the same ratio to the amount of remaining funds described in this paragraph as the State prison population of such State bears to the total prison population of all the participating States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc237-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of a grant made under this subchapter may not exceed 75 percent of the total costs of the projects described in the application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10422"},"text":"section 10422 of this title","children":[],"tail":" for the fiscal year for which the projects receive assistance under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc238-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least 10 percent of the total amount made available to a State under subsection (a) for any fiscal year shall be used by the State to make grants to local correctional and detention facilities in the State (provided such facilities exist therein), for the purpose of assisting jail-based substance abuse treatment programs that are effective and science-based established by those local correctional facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc239-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential substance abuse treatment program defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “residential substance abuse treatment program” means a course of comprehensive individual and group substance abuse treatment services, lasting a period of at least 6 months, in residential treatment facilities set apart from the general population of a prison or jail (which may include the use of pharmacological treatment, where appropriate, that may extend beyond such period).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc23a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1904"},"text":"Pub. L. 90–351, title I, § 1904","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s32101/a/3"},"text":"Pub. L. 103–322, title III, § 32101(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1900"},"text":"108 Stat. 1900","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2102/3"},"text":"Pub. L. 107–273, div. B, title II, § 2102(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1792"},"text":"116 Stat. 1792","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1144"},"text":"Pub. L. 109–162, title XI, § 1144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3111"},"text":"119 Stat. 3111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s102/b"},"text":"Pub. L. 110–199, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/668"},"text":"122 Stat. 668","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc23b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc23c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc23d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ff–3"},"text":"section 3796ff–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbfc23e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, subsec. (d) defined “residential substance abuse treatment program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cbfc23f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cbfc240-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1147"},"text":"section 1147 of Pub. L. 109–162","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10422"},"text":"section 10422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cbfc241-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" and requirements for grants made under such amendments, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60504"},"text":"section 60504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
