{"tag":"section","attrib":{"id":"id4d3e19f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21741"},"text":null,"children":[{"tag":"num","attrib":{"value":"21741"},"text":"§ 21741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance for States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Secretary of Health and Human Services and in coordination with the Elder Justice Coordinating Council (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397k"},"text":"section 1397k of title 42","children":[],"tail":"), shall create, compile, evaluate, and disseminate materials and information, and provide the necessary training and technical assistance, to assist States and units of local government in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3e19f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21741/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" investigating, prosecuting, pursuing, preventing, understanding, and mitigating the impact of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3e19f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21741/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical, sexual, and psychological abuse of elders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21741/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploitation of elders, including financial abuse and scams targeting elders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3e19f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21741/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neglect of elders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21741/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing, addressing, and mitigating the physical and psychological trauma to victims of elder abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3e19f9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tIV/s403"},"text":"Pub. L. 115–70, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1214"},"text":"131 Stat. 1214","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
