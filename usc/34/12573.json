{"tag":"section","attrib":{"id":"id4d15a9bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573"},"text":null,"children":[{"tag":"num","attrib":{"value":"12573"},"text":"§ 12573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d15a9be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of allotment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d15a9bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that receives an allotment pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12572"},"text":"section 12572 of this title","children":[],"tail":" shall use the allotment to pay the Federal share of the costs of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15a9c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awarding scholarships to in-service law enforcement personnel to enable such personnel to seek further education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a9c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d15a9c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time employment in summer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d15a9c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part-time (not to exceed 20 hours per week) employment for a period not to exceed 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The employment described in paragraph (1)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15a9c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided by State and local law enforcement agencies for students who are juniors or seniors in high school or are enrolled in an institution of higher education and who demonstrate an interest in undertaking a career in law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a9c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be in a law enforcement position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a9c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consist of performing meaningful tasks that inform students of the nature of the tasks performed by law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15a9c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments; Federal share; non-Federal share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d15a9c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Director shall pay to each State that receives an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12572"},"text":"section 12572 of this title","children":[],"tail":" the Federal share of the cost of the activities described in the application submitted pursuant to section 12576 "},{"tag":"ref","attrib":{"idref":"fn002138"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002138"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share shall not exceed 60 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of scholarships and student employment provided under this part shall be supplied from sources other than the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15a9cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be responsible for the administration of the programs conducted pursuant to this part and shall, in consultation with the Assistant Secretary for Postsecondary Education, issue rules to implement this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15a9cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12572"},"text":"section 12572 of this title","children":[],"tail":" may reserve not more than 8 percent of the allotment for administrative expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15a9ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12572"},"text":"section 12572 of this title","children":[],"tail":" shall ensure that each scholarship recipient under this part be compensated at the same rate of pay and benefits and enjoy the same rights under applicable agreements with labor organizations and under State and local law as other law enforcement personnel of the same rank and tenure in the office of which the scholarship recipient is a member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15a9cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12573/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplementation of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds received under this part shall only be used to supplement, and not to supplant, Federal, State, or local efforts for recruitment and education of law enforcement personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d15a9d0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200204"},"text":"Pub. L. 103–322, title XX, § 200204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2058"},"text":"108 Stat. 2058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d15a9d1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d15a9d2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d15a9d3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12576"},"text":"Section 12576 of this title","children":[],"tail":", referred to in subsec. (b)(1), was in the original “section 200203”, and was translated as reading “section 200207”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s200207"},"text":"section 200207 of Pub. L. 103–322","children":[],"tail":", to reflect the probable intent of Congress, because "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/s200203"},"text":"section 200203 of Pub. L. 103–322","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12572"},"text":"section 12572 of this title","children":[],"tail":", does not provide for submission of applications, and section 12576 does so provide."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d15a9d4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14113"},"text":"section 14113 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
