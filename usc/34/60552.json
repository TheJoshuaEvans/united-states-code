{"tag":"section","attrib":{"id":"id4d66aff5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552"},"text":null,"children":[{"tag":"num","attrib":{"value":"60552"},"text":"§ 60552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to study parole or post-incarceration supervision violations and revocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66aff6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this section, the Attorney General may make grants to States to study and to improve the collection of data with respect to individuals whose parole or post-incarceration supervision is revoked, and which such individuals represent the greatest risk to victims and community safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66aff7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a grant under this section, a State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d66aff8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certify that the State has, or intends to establish, a program that collects comprehensive and reliable data with respect to individuals described in subsection (a), including data on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d66aff9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of parole or post-incarceration supervision violations that occur with the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66affa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for parole or post-incarceration supervision revocation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66affb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the underlying behavior that led to the revocation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d66affc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of imprisonment or other penalty that is imposed for the violation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d66affd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the data described in paragraph (1) to the Bureau of Justice Statistics, in a form prescribed by the Bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66affe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60552/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any statistical analysis of population data under this section shall be conducted in accordance with the Federal Register Notice dated ","children":[{"tag":"date","attrib":{"date":"1997-10-30"},"text":"October 30, 1997","children":[],"tail":", relating to classification standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66afff-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s242"},"text":"Pub. L. 110–199, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/690"},"text":"122 Stat. 690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d66b000-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d66b001-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d66b002-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17552"},"text":"section 17552 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
