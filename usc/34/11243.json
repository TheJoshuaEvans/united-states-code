{"tag":"section","attrib":{"id":"id4ced12f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243"},"text":null,"children":[{"tag":"num","attrib":{"value":"11243"},"text":"§ 11243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants for research, evaluation, demonstration, and service projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced12f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization; purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to States, localities, and private entities (and combinations of such entities) to carry out research, evaluation, demonstration, and service projects regarding activities under this subchapter designed to increase knowledge concerning, and to improve services for, runaway youth and homeless youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced12f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection factors; priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting among applications for grants under subsection (a), the Secretary shall give priority to proposed projects relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced12f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" youth who repeatedly leave and remain away from their homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of runaway youth and homeless youth in connection with services authorized to be provided under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the special needs of runaway youth and homeless youth programs in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the special needs of programs that place runaway youth and homeless youth in host family homes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" staff training in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced12fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the behavioral and emotional effects of sexual abuse and assault, severe forms of trafficking in persons (as defined in section 7102(9) ","children":[{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 22), and sex trafficking (as defined in section 7102(10) "},{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":" of title 22);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced12fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responding to youth who are showing effects of sexual abuse and assault, severe forms of trafficking in persons (as defined in section 7102(9) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 22), or sex trafficking (as defined in section 7102(10) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 22); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced12fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency-wide strategies for working with runaway and homeless youth who have been sexually victimized, including such youth who are victims of trafficking (as defined in section 7102(15) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 22);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative methods of developing resources that enhance the establishment or operation of runaway and homeless youth centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced12ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for runaway youth and homeless youth, and staff training, related to preventing and obtaining treatment for infection by the human immunodeficiency virus (HIV);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1300-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing access to quality health care (including behavioral health care) for runaway youth and homeless youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1301-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing access to education for runaway youth and homeless youth, including access to educational and workforce programs to achieve outcomes such as decreasing secondary school dropout rates, increasing rates of attaining a secondary school diploma or its recognized equivalent, or increasing placement and retention in postsecondary education or advanced workforce training programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1302-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing programs, including innovative programs, that assist youth in obtaining and maintaining safe and stable housing, and which may include programs with supportive services that continue after the youth complete the remainder of the programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ced1303-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicant experience and diversity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting among applicants for grants under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1304-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to applicants who have experience working with runaway or homeless youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced1305-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that the applicants selected—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced1306-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent diverse geographic regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1307-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11243/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out projects that serve diverse populations of runaway or homeless youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ced1308-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s343"},"text":"Pub. L. 93–415, title III, § 343","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/C"},"text":"Pub. L. 102–586, § 3(g)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5023"},"text":"106 Stat. 5023","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/h"},"text":"Pub. L. 106–71, § 3(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1038"},"text":"113 Stat. 1038","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/96/tI/s113"},"text":"Pub. L. 108–96, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-10"},"text":"Oct. 10, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1170"},"text":"117 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/378/s5"},"text":"Pub. L. 110–378, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4069"},"text":"122 Stat. 4069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tII/s201/1"},"text":"Pub. L. 114–22, title II, § 201(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/248"},"text":"129 Stat. 248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced1309-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced130a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ced130b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7102(9), (10), and (15) of title 22, referred to in subsec. (b)(5), was redesignated section 7102(11), (12), and (17), respectively, of title 22 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced130c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–23"},"text":"section 5714–23 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced130d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s201/1/A"},"text":"Pub. L. 114–22, § 201(1)(A)","children":[],"tail":", inserted “, severe forms of trafficking in persons (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/9"},"text":"section 7102(9) of title 22","children":[],"tail":"), and sex trafficking (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/10"},"text":"section 7102(10) of title 22","children":[],"tail":")” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s201/1/B"},"text":"Pub. L. 114–22, § 201(1)(B)","children":[],"tail":", inserted “, severe forms of trafficking in persons (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/9"},"text":"section 7102(9) of title 22","children":[],"tail":"), or sex trafficking (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/10"},"text":"section 7102(10) of title 22","children":[],"tail":")” before “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/s201/1/C"},"text":"Pub. L. 114–22, § 201(1)(C)","children":[],"tail":", inserted “, including such youth who are victims of trafficking (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/15"},"text":"section 7102(15) of title 22","children":[],"tail":")” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s5/1/A"},"text":"Pub. L. 110–378, § 5(1)(A)","children":[],"tail":", substituted “priority” for “special consideration” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s5/1/B"},"text":"Pub. L. 110–378, § 5(1)(B)","children":[],"tail":", substituted “to quality health” for “to health” and “behavioral health care” for “mental health care” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s5/1/C"},"text":"Pub. L. 110–378, § 5(1)(C)","children":[],"tail":", substituted “, including access to educational and workforce programs to achieve outcomes such as decreasing secondary school dropout rates, increasing rates of attaining a secondary school diploma or its recognized equivalent, or increasing placement and retention in postsecondary education or advanced workforce training programs; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s5/1/D"},"text":"Pub. L. 110–378, § 5(1)(D)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/378/s5/2"},"text":"Pub. L. 110–378, § 5(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “In selecting among applicants for grants under subsection (a) of this section, the Secretary shall give priority to applicants who have experience working with runaway youth or homeless youth.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/96"},"text":"Pub. L. 108–96","children":[],"tail":" inserted “regarding activities under this subchapter” after “service projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/h/1"},"text":"Pub. L. 106–71, § 3(h)(1)","children":[],"tail":", inserted “evaluation,” after “research,” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/h/2"},"text":"Pub. L. 106–71, § 3(h)(2)","children":[],"tail":", inserted “evaluation,” after “research,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/h/3"},"text":"Pub. L. 106–71, § 3(h)(3)","children":[],"tail":", redesignated pars. (3) to (10) as (2) to (9), respectively, and struck out former par. (2) which read as follows: “home-based and street-based services for, and outreach to, runaway youth and homeless youth;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
