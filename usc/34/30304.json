{"tag":"section","attrib":{"id":"id4d42fc0a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304"},"text":null,"children":[{"tag":"num","attrib":{"value":"30304"},"text":"§ 30304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prison rape prevention and prosecution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d42fc0b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d42fc0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National clearinghouse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the National Institute of Corrections a national clearinghouse for the provision of information and assistance to Federal, State, and local authorities responsible for the prevention, investigation, and punishment of instances of prison rape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fc0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Institute of Corrections shall conduct periodic training and education programs for Federal, State, and local authorities responsible for the prevention, investigation, and punishment of instances of prison rape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d42fc0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d42fc0f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than September 30 of each year, the National Institute of Corrections shall submit a report to Congress and the Secretary of Health and Human Services. This report shall be available to the Director of the Bureau of Justice Statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fc10-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall summarize the activities of the Department of Justice regarding prison rape abatement for the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d42fc11-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for each of fiscal years 2004 through 2010 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d42fc12-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/79/s5"},"text":"Pub. L. 108–79, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-04"},"text":"Sept. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/978"},"text":"117 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d42fc13-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d42fc14-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d42fc15-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15604"},"text":"section 15604 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
