{"tag":"section","attrib":{"id":"id4ccba8b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10497"},"text":null,"children":[{"tag":"num","attrib":{"value":"10497"},"text":"§ 10497.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State or local law enforcement agency or organization that receives a grant under this subchapter shall submit to the Attorney General an annual report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba8b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10497/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program descriptions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba8b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10497/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of staff employed to administer programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba8b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10497/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals who participated in programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba8b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10497/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of grant programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba8b7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","at