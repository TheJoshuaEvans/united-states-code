{"tag":"section","attrib":{"id":"id4d5d12f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50104"},"text":null,"children":[{"tag":"num","attrib":{"value":"50104"},"text":"§ 50104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of discrimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d12f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federally assisted emergency assistance activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person in any State shall, on the ground of race, color, religion, national origin, or sex, be excluded from participation in, be denied the benefits of, be subjected to discrimination under, or be denied employment in connection with any activity for which Federal law enforcement assistance is provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d12f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of section 10228(c)(3) and (4) of this title applicable to violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (3) and paragraph (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10228/c"},"text":"section 10228(c) of this title","children":[],"tail":" shall apply with respect to a violation of subsection (a), except that the terms “this section” and “paragraph (1)”, as such terms appear in such paragraphs, shall be deemed to be references to subsection (a) of this section, and a reference to the Office of Justice Programs in such paragraphs shall be deemed to be a reference to the Attorney General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d12f5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609P"},"text":"Pub. L. 98–473, title II, § 609P","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2105"},"text":"98 Stat. 2105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d12f6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d12f7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d12f8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10504"},"text":"section 10504 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
