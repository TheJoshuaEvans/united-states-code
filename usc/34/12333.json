{"tag":"section","attrib":{"id":"id4d04e10e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12333"},"text":null,"children":[{"tag":"num","attrib":{"value":"12333"},"text":"§ 12333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number and cost of injuries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d04e10f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Centers for Disease Control Injury Control Division, shall conduct a study to obtain a national projection of the incidence of injuries resulting from domestic violence, the cost of injuries to health care facilities, and recommend health care strategies for reducing the incidence and cost of such injuries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e110-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section—$100,000 for fiscal year 1996.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d04e111-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40293"},"text":"Pub. L. 103–322, title IV, § 40293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","at