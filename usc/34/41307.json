{"tag":"section","attrib":{"id":"id4d5858d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41307"},"text":null,"children":[{"tag":"num","attrib":{"value":"41307"},"text":"§ 41307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement for missing children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5858d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal, State, and local law enforcement agency shall report each case of a missing child under the age of 21 reported to such agency to the National Crime Information Center of the Department of Justice and, consistent with section 40507 (including rules promulgated pursuant to section 40507(c)) of this title, shall also report such case, either directly or through authorization described in such section to transmit, enter, or share information on such case, to the NamUs databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5858d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may establish guidelines for the collection of such reports including procedures for carrying out the purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s41308"},"text":"section 41308 of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002220"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002220"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5858d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual summary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall publish an annual statistical summary of the reports received under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s41308"},"text":"section 41308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5858d4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVII/s3701"},"text":"Pub. L. 101–647, title XXXVII, § 3701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4966"},"text":"104 Stat. 4966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tII/s204"},"text":"Pub. L. 108–21, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/660"},"text":"117 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/327/s2/c/1"},"text":"Pub. L. 117–327, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4455"},"text":"136 Stat. 4455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5858d5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5858d6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d5858d7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s41308"},"text":"section 41308 of this title","children":[],"tail":", referred to in subsec. (b), was in the original “this Act”, and was translated as reading “this title”, meaning title XXXVII of "},{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41308"},"text":"section 41308 of this title","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5858d8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5779"},"text":"section 5779 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d5858d9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327"},"text":"Pub. L. 117–327","children":[],"tail":" inserted before period at end “and, consistent with section 40507 (including rules promulgated pursuant to section 40507(c)) of this title, shall also report such case, either directly or through authorization described in such section to transmit, enter, or share information on such case, to the NamUs databases”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21"},"text":"Pub. L. 108–21","children":[],"tail":" substituted “age of 21” for “age of 18”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d5858da-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d5858db-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/327"},"text":"Pub. L. 117–327","children":[],"tail":" applicable with respect to reports made before, on, or after "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40506/c/3"},"text":"section 40506(c)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
