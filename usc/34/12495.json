{"tag":"section","attrib":{"id":"id4d0e7d8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495"},"text":null,"children":[{"tag":"num","attrib":{"value":"12495"},"text":"§ 12495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to report crime and emergencies from one’s home","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0e7d8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered governmental entity” means any municipal, county, or State government that receives funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5306"},"text":"section 5306 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7d8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7d90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Landlords, homeowners, tenants, residents, occupants, and guests of, and applicants for, housing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7d91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have the right to seek law enforcement or emergency assistance on their own behalf or on behalf of another person in need of assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7d92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be penalized based on their requests for assistance or based on criminal activity of which they are a victim or otherwise not at fault under statutes, ordinances, regulations, or policies adopted or enforced by covered governmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7d93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Penalties that are prohibited under paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7d94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual or threatened assessment of monetary or criminal penalties, fines, or fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7d95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual or threatened eviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7d96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual or threatened refusal to rent or renew tenancy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7d97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual or threatened refusal to issue an occupancy permit or landlord permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7d98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual or threatened closure of the property, or designation of the property as a nuisance or a similarly negative designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7d99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5304/b"},"text":"section 5304(b) of title 42","children":[],"tail":", covered governmental entities shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7d9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report any of their laws or policies, or, as applicable, the laws or policies adopted by subgrantees, that impose penalties on landlords, homeowners, tenants, residents, occupants, guests, or housing applicants based on requests for law enforcement or emergency assistance or based on criminal activity that occurred at a property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7d9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that they are in compliance with the protections under this part or describe the steps the covered governmental entities will take within 180 days to come into compliance, or to ensure compliance among subgrantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7d9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Housing and Urban Development and the Attorney General shall implement and enforce this subpart consistent with, and in a manner that provides, the same rights and remedies as those provided for in title VIII of the Civil Rights Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7d9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12495/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For those covered governmental entities that distribute funds to subgrantees, compliance with subsection (c)(1) includes inquiring about the existence of laws and policies adopted by subgrantees that impose penalties on landlords, homeowners, tenants, residents, occupants, guests, or housing applicants based on requests for law enforcement or emergency assistance or based on criminal activity that occurred at a property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0e7d9e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41415"},"text":"Pub. L. 103–322, title IV, § 41415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s603"},"text":"Pub. L. 117–103, div. W, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/885"},"text":"136 Stat. 885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0e7d9f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0e7da0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d0e7da1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1968, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/73"},"text":"82 Stat. 73","children":[],"tail":". Title VIII of the Act, known as the Fair Housing Act, is classified principally to subchapter I (§ 3601 et seq.) of chapter 45 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0e7da2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s603"},"text":"Pub. L. 117–103, div. W, title VI, § 603","children":[],"tail":", which directed the addition of this section to chapter 2 of subtitle N of title IV of the Violence Against Women Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491"},"text":"34 U.S.C. 12491","children":[],"tail":" et seq.), was executed by adding this section to chapter 2 of subtitle N of title IV of the Violent Crime Control and Law Enforcement Act of 1994 to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d0e7da3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d0e7da4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
