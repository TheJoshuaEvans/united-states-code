{"tag":"section","attrib":{"id":"id4c999b60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109"},"text":null,"children":[{"tag":"num","attrib":{"value":"10109"},"text":"§ 10109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Audit, Assessment, and Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c999b61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office an Office of Audit, Assessment, and Management, headed by a Director appointed by the Attorney General. In carrying out the functions of the Office, the Director shall be subject to the authority, direction, and control of the Attorney General. Such authority, direction, and control may be delegated only to the Assistant Attorney General, without redelegation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Office shall be to carry out and coordinate program assessments of, take actions to ensure compliance with the terms of, and manage information with respect to, grants under programs covered by subsection (b). The Director shall take special conditions of the grant into account and consult with the office that issued those conditions to ensure appropriate compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be the exclusive element of the Department of Justice, other than the Inspector General, performing functions and activities for the purpose specified in paragraph (2). There are hereby transferred to the Office all functions and activities, other than functions and activities of the Inspector General, for such purpose performed immediately before ","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":", by any other element of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program under subchapter XVI of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any grant program carried out by the Office of Justice Programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other grant program carried out by the Department of Justice that the Attorney General considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program assessments required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall select grants awarded under the programs covered by subsection (b) and carry out program assessments on such grants. In selecting such grants, the Director shall ensure that the aggregate amount awarded under the grants so selected represent not less than 10 percent of the aggregate amount of money awarded under all such grant programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to NIJ evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection does not affect the authority or duty of the Director of the National Institute of Justice to carry out overall evaluations of programs covered by subsection (b), except that such Director shall consult with the Director of the Office in carrying out such evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of program assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program assessment required by paragraph (1) of a grant selected under paragraph (1) shall be carried out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4c999b6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than the end of the grant period, if the grant period is not more than 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4c999b6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of each year of the grant period, if the grant period is more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance actions required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall take such actions to ensure compliance with the terms of a grant as the Director considers appropriate with respect to each grant that the Director determines (in consultation with the head of the element of the Department of Justice concerned), through a program assessment under subsection (a) or other means, is not in compliance with such terms. In the case of a misuse of more than 1 percent of the grant amount concerned, the Director shall, in addition to any other action to ensure compliance that the Director considers appropriate, ensure that the entity responsible for such misuse ceases to receive any funds under any program covered by subsection (b) until such entity repays to the Attorney General an amount equal to the amounts misused. The Director may, in unusual circumstances, grant relief from this requirement to ensure that an innocent party is not punished.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant management system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish and maintain, in consultation with the chief information officer of the Office, a modern, automated system for managing all information relating to the grants made under the programs covered by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 3 percent of all funding made available for a fiscal year for the programs covered by subsection (b) shall be reserved for the Office of Audit, Assessment and Management for the activities authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c999b72-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s109"},"text":"Pub. L. 90–351, title I, § 109","children":[],"tail":", formerly § 105, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1158/a"},"text":"Pub. L. 109–162, title XI, § 1158(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3114"},"text":"119 Stat. 3114","children":[],"tail":"; renumbered § 109, "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/e"},"text":"Pub. L. 109–271, § 8(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/766"},"text":"120 Stat. 766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c999b73-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c999b74-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4c999b75-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":", referred to in subsec. (a)(3), was in the original “the date of the enactment of this Act” and was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c999b76-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712h"},"text":"section 3712h of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was also formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712d"},"text":"section 3712d of Title 42","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":" and transfer to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712h"},"text":"section 3712h of Title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4c999b77-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4c999b78-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1158/b"},"text":"Pub. L. 109–162, title XI, § 1158(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3116"},"text":"119 Stat. 3116","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/n/3"},"text":"Pub. L. 109–271, § 8(n)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/768"},"text":"120 Stat. 768","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/271/s8/n/3"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), section 109 of the Omnibus Crime Control and Safe Streets Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712d"},"text":"42 U.S.C. 3712d","children":[],"tail":" [3712h]) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10109"},"text":"34 U.S.C. 10109","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2006-04-05"},"text":"April 5, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (c), (d), and (e) of section 109 of the Omnibus Crime Control and Safe Streets Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712d"},"text":"42 U.S.C. 3712d","children":[],"tail":" [3712h]) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10109"},"text":"34 U.S.C. 10109","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
