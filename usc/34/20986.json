{"tag":"section","attrib":{"id":"id4d395e2f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20986"},"text":null,"children":[{"tag":"num","attrib":{"value":"20986"},"text":"§ 20986.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Children’s safety online awareness campaigns","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395e30-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20986/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awareness campaign for children’s safety online","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395e31-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20986/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with the National Center for Missing and Exploited Children, is authorized to develop and carry out a public awareness campaign to demonstrate, explain, and encourage children, parents, and community leaders to better protect children when such children are on the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395e32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20986/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The public awareness campaign described under paragraph (1) shall include components that compliment ","children":[{"tag":"ref","attrib":{"idref":"fn002192"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002192"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “complement”."}],"tail":" and reinforce the campaign message in a variety of media, including the Internet, television, radio, and billboards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20986/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awareness campaign regarding the accessibility and utilization of sex offender registries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with the National Center for Missing and Exploited Children, is authorized to develop and carry out a public awareness campaign to demonstrate, explain, and encourage parents and community leaders to better access and utilize the Federal and State sex offender registries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20986/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for fiscal years 2007 through 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395e35-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s629"},"text":"Pub. L. 109–248, title VI, § 629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/640"},"text":"120 Stat. 640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395e36-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395e37-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395e38-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16986"},"text":"section 16986 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
