{"tag":"section","attrib":{"id":"id4d42fb9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30111"},"text":null,"children":[{"tag":"num","attrib":{"value":"30111"},"text":"§ 30111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance for States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Secretary of Homeland Security, the Director of the United States Secret Service, the Executive Associate Director of Homeland Security Investigations, and nongovernmental and survivor stakeholders, shall create, compile, evaluate, and disseminate materials and information, and provide the necessary training and technical assistance, to assist States and units of local government in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d42fb9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" investigating, prosecuting, pursuing, preventing, understanding, and mitigating the impact of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d42fb9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30111/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical, sexual, and psychological abuse of cybercrime victims, including victims of human trafficking that is facilitated by interactive computer services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d42fb9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30111/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploitation of cybercrime victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d42fb9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30111/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deprioritization of cybercrime; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fb9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing, addressing, and mitigating the physical and psychological trauma to victims of cybercrime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d42fba0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/tIII/s324"},"text":"Pub. L. 117–347, title III, § 324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6207"},"text":"136 Stat. 6207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d42fba1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d42fba2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id4d42fba3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “computer” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/s3"},"text":"section 3 of Pub. L. 117–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20145"},"text":"section 20145 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
