{"tag":"section","attrib":{"id":"id4d1338f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542"},"text":null,"children":[{"tag":"num","attrib":{"value":"12542"},"text":"§ 12542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural drug enforcement training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1338f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialized training for rural officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Federal Law Enforcement Training Center shall develop a specialized course of instruction devoted to training law enforcement officers from rural agencies in the investigation of drug trafficking and related crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1338f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1338f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1338f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1997;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1338f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1998;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1338f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1999; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1338fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12542/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1338fb-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXVIII/s180103"},"text":"Pub. L. 103–322, title XVIII, § 180103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2046"},"text":"108 Stat. 2046","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1338fc-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1338fd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topi