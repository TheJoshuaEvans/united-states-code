{"tag":"section","attrib":{"id":"id4d0751ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12392"},"text":null,"children":[{"tag":"num","attrib":{"value":"12392"},"text":"§ 12392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of statutory rape laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d075200-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12392/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Senate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Senate that States and local jurisdictions should aggressively enforce statutory rape laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d075201-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12392/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Justice Department program on statutory rape","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", the Attorney General shall establish and implement a program that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d075202-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12392/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies the linkage between statutory rape and teenage pregnancy, particularly by predatory older men committing repeat offenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d075203-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12392/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educates State and local criminal law enforcement officials on the prevention and prosecution of statutory rape, focusing in particular on the commission of statutory rape by predatory older men committing repeat offenses, and any links to teenage pregnancy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d075204-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12392/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violence against women initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure that the Department of Justice’s Violence Against Women initiative addresses the issue of statutory rape, particularly the commission of statutory rape by predatory older men committing repeat offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d075205-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIX/s906"},"text":"Pub. L. 104–193, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2349"},"text":"110 Stat. 2349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d075206-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075207-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d075208-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14016"},"text":"section 14016 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, and not as part of the Violent Crime Control and Law Enforcement Act of 1994 which enacted this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
