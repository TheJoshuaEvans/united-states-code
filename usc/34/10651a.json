{"tag":"section","attrib":{"id":"id4cd545fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10651a"},"text":"§ 10651a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran Treatment Court Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd545ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, in coordination with the Secretary of Veterans Affairs, the Attorney General shall establish and carry out a Veteran Treatment Court Program to provide grants and technical assistance to court systems that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd54600-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have adopted a Veterans Treatment Court Program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd54601-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have filed a notice of intent to establish a Veterans Treatment Court Program with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd54602-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Veterans Treatment Court Program established under subsection (a) is to ensure the Department of Justice has a single office to coordinate the provision of grants, training, and technical assistance to help State, local, and Tribal governments to develop and maintain veteran treatment courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd54603-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs included","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Veterans Treatment Court Program established under subsection (a) shall include the grant programs relating to veterans treatment courts carried out by the Attorney General pursuant to sections 10651 and 10701 of this title or any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd54604-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10651a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd54605-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/153/s3"},"text":"Pub. L. 116–153, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-08-08"},"text":"Aug. 8, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/688"},"text":"134 Stat. 688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd54606-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd54607-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd54608-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Veteran Treatment Court Coordination Act of 2019, and not as part of the Omnibus Crime Control and Safe Streets Act of 1968 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
