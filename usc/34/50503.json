{"tag":"section","attrib":{"id":"id4d5d1415-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503"},"text":null,"children":[{"tag":"num","attrib":{"value":"50503"},"text":"§ 50503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blue Alert Coordinator; guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d1416-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination within Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall assign an existing officer of the Department of Justice to act as the national coordinator of the Blue Alert communications network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1417-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Coordinator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d1418-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to States and units of local government that are using Blue Alert plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1419-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish voluntary guidelines for States and units of local government to use in developing Blue Alert plans that will promote compatible and integrated Blue Alert plans throughout the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d141a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the resources necessary to establish a Blue Alert plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d141b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for evaluating whether a situation warrants issuing a Blue Alert;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d141c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines to protect the privacy, dignity, independence, and autonomy of any law enforcement officer who may be the subject of a Blue Alert and the family of the law enforcement officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d141d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidelines that a Blue Alert should only be issued with respect to a law enforcement officer if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d141e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the law enforcement agency involved—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d5d141f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" confirms—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id4d5d1420-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the death or serious injury of the law enforcement officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id4d5d1421-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the attack on the law enforcement officer and that there is an indication of the death or serious injury of the officer; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d5d1422-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concludes that the law enforcement officer is missing in connection with the officer’s official duties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1423-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an indication of serious injury to or death of the law enforcement officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1424-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspect involved has not been apprehended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1425-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is sufficient descriptive information of the suspect involved and any relevant vehicle and tag numbers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1426-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidelines that a Blue Alert should only be issued with respect to a threat to cause death or serious injury to a law enforcement officer if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d1427-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement agency involved confirms that the threat is imminent and credible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1428-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of receipt of the threat, the suspect is wanted by a law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1429-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspect involved has not been apprehended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d142a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is sufficient descriptive information of the suspect involved and any relevant vehicle and tag numbers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d142b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidelines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d142c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that information should be provided to the National Crime Information Center database operated by the Federal Bureau of Investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of title 28","children":[],"tail":", and any relevant crime information repository of the State involved, relating to—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id4d5d142d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer who is seriously injured or killed in the line of duty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d5d142e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an imminent and credible threat to cause the serious injury or death of a law enforcement officer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d142f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a Blue Alert should, to the maximum extent practicable (as determined by the Coordinator in consultation with law enforcement agencies of States and units of local governments), be limited to the geographic areas most likely to facilitate the apprehension of the suspect involved or which the suspect could reasonably reach, which should not be limited to State lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1430-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for law enforcement agencies of States or units of local government to develop plans to communicate information to neighboring States to provide for seamless communication of a Blue Alert; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1431-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that a Blue Alert should be suspended when the suspect involved is apprehended or when the law enforcement agency involved determines that the Blue Alert is no longer effective; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1432-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" guidelines for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d1433-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of Blue Alerts through the network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1434-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the dissemination of alerts issued through the network;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1435-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop protocols for efforts to apprehend suspects that address activities during the period beginning at the time of the initial notification of a law enforcement agency that a suspect has not been apprehended and ending at the time of apprehension of a suspect or when the law enforcement agency involved determines that the Blue Alert is no longer effective, including protocols regulating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1436-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of public safety communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1437-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" command center operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1438-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incident review, evaluation, debriefing, and public information procedures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1439-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with States to ensure appropriate regional coordination of various elements of the network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d143a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish an advisory group to assist States, units of local government, law enforcement agencies, and other entities involved in the network with initiating, facilitating, and promoting Blue Alert plans, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d143b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, representation from the various geographic regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d143c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" members who are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d143d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of a law enforcement organization representing rank-and-file officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d143e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of other law enforcement agencies and public safety communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d143f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broadcasters, first responders, dispatchers, and radio station personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1440-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of any other individuals or organizations that the Coordinator determines are necessary to the success of the network;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1441-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" act as the nationwide point of contact for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1442-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of the network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1443-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional coordination of Blue Alerts through the network; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1444-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1445-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" what procedures and practices are in use for notifying law enforcement and the public when—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5d1446-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer is killed or seriously injured in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1447-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer is missing in connection with the officer’s official duties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5d1448-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an imminent and credible threat to kill or seriously injure a law enforcement officer is received; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1449-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which of the procedures and practices are effective and that do not require the expenditure of additional resources to implement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d144a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d144b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines established under subsection (b)(2), protocols developed under subsection (b)(3), and other programs established under subsection (b), shall not be mandatory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d144c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The guidelines established under subsection (b)(2) shall, to the maximum extent practicable (as determined by the Coordinator in consultation with law enforcement agencies of States and units of local government), provide that appropriate information relating to a Blue Alert is disseminated to the appropriate officials of law enforcement agencies, public health agencies, and other agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f834d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy and civil liberties protections","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines established under subsection (b) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5f834e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide mechanisms that ensure that Blue Alerts comply with all applicable Federal, State, and local privacy laws and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5f834f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include standards that specifically provide for the protection of the civil liberties, including the privacy, of law enforcement officers who are seriously injured or killed in the line of duty, is missing in connection with the officer’s official duties, or who are threatened with death or serious injury, and the families of the officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5f8350-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Coordinator shall cooperate with the Secretary of Homeland Security, the Secretary of Transportation, the Chairman of the Federal Communications Commission, and appropriate offices of the Department of Justice in carrying out activities under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5f8351-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on Coordinator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinator may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5f8352-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform any official travel for the sole purpose of carrying out the duties of the Coordinator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f8353-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobby any officer of a State regarding the funding or implementation of a Blue Alert plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f8354-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" host a conference focused solely on the Blue Alert program that requires the expenditure of Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5f8355-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-05-19"},"text":"May 19, 2015","children":[],"tail":", and annually thereafter, the Coordinator shall submit to Congress a report on the activities of the Coordinator and the effectiveness and status of the Blue Alert plans that are in effect or being developed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5f8356-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/12/s4"},"text":"Pub. L. 114–12, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-19"},"text":"May 19, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/193"},"text":"129 Stat. 193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5f8357-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5f8358-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5f8359-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14165b"},"text":"section 14165b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
