{"tag":"section","attrib":{"id":"id4ced12a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11214"},"text":null,"children":[{"tag":"num","attrib":{"value":"11214"},"text":"§ 11214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to private entities; staffing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to deny grants to private entities which are fully controlled by private boards or persons but which in other respects meet the requirements of this subchapter and agree to be legally responsible for the operation of the runaway and homeless youth center and the programs, projects, and activities they carry out under this subchapter. Nothing in this subchapter shall give the Federal Government control over the staffing and personnel decisions of facilities receiving Federal funds under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ced12a4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s314"},"text":"Pub. L. 93–415, title III, § 314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1131"},"text":"88 Stat. 1131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s654"},"text":"Pub. L. 98–473, title II, § 654","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2123"},"text":"98 Stat. 2123","children":[],"tail":"; renumbered § 317 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII"},"text":"Pub. L. 100–690, title VII","children":[],"tail":", §§ 7271(c)(4), 7275(a), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":