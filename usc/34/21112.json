{"tag":"section","attrib":{"id":"id4d395ed0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112"},"text":null,"children":[{"tag":"num","attrib":{"value":"21112"},"text":"§ 21112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of National ICAC Task Force Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395ed1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395ed2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Justice, under the general authority of the Attorney General, a National Internet Crimes Against Children Task Force Program (hereinafter in this subchapter referred to as the “ICAC Task Force Program”), which shall consist of a national program of State, Tribal, military, and local law enforcement task forces dedicated to developing effective responses to online enticement of children by sexual predators, child exploitation, child obscenity and pornography cases, and the identification of child victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ed3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intent of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose and intent of Congress that the ICAC Task Force Program established under paragraph (1) is intended to continue the ICAC Task Force Program authorized under title I of the Departments of Commerce, Justice, and State, the Judiciary, and Related Agencies Appropriations Act, 1998, and funded under title IV of the Juvenile Justice and Delinquency Prevention Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11291"},"text":"34 U.S.C. 11291","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395ed4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395ed5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ICAC Task Force Program established under subsection (a) shall include at least 1 ICAC task force in each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ed6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity and continuity of investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to maintain established capacity and continuity of investigations and prosecutions of child exploitation cases, the Attorney General, shall, in establishing the ICAC Task Force Program under subsection (a), evaluate the task forces funded under the ICAC Task Force Program to determine if those task forces are operating in an effective manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ed7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ongoing review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ed8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic reviews of the effectiveness of each ICAC task force established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ed9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the discretion to establish a new or continue an existing task force if the Attorney General determines that such decision will enhance the effectiveness of combating child exploitation provided that the Attorney General notifies Congress in advance of any such decision and that each State maintains at least 1 ICAC task force at all times.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395eda-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395edb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish national training programs to support the mission of the ICAC task forces, including the effective use of the National Internet Crimes Against Children Data System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395edc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395edd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic reviews of the effectiveness of each training session authorized by this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395ede-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider outside reports related to the effective use of Federal funding in making future grant awards for training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395edf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited liability for ICAC Task Forces","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395ee0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a civil claim or criminal charge against an ICAC task force established pursuant to this section and sections 21113 and 21114 of this title, including any law enforcement agency that participates on such a task force or a director, officer, employee, or agent of such a law enforcement agency, arising from the prioritization decisions with respect to leads related to Internet crimes against children described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21114/8"},"text":"section 21114(8) of this title","children":[],"tail":", may not be brought in any Federal or State court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ee1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intentional, reckless, or other misconduct","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to a claim if the ICAC task force or law enforcement agency, or a director, officer, employee, or agent of that law enforcement agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ee2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in intentional misconduct; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395ee3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acted, or failed to act—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395ee4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with actual malice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395ee5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with gross negligence or reckless disregard to a substantial risk of causing physical injury without legal justification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395ee6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a purpose unrelated to the performance of any responsibility or function under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s21114/8"},"text":"section 21114(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395ee7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d395ee8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" create any independent basis of liability on behalf of, or any cause of action against—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d395ee9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ICAC task force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d395eea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement agency or a director, officer, employee, or agent of the law enforcement agency; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d395eeb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21112/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand any liability otherwise imposed, or limit any defense to that liability, otherwise available under Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395eec-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/401/tI/s102"},"text":"Pub. L. 110–401, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4233"},"text":"122 Stat. 4233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/206/s5"},"text":"Pub. L. 112–206, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-07"},"text":"Dec. 7, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1493"},"text":"126 Stat. 1493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXII/s8202/b"},"text":"Pub. L. 119–60, div. H, title LXXXII, § 8202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1841"},"text":"139 Stat. 1841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395eed-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395eee-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d395eef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title I of the Departments of Commerce, Justice, and State, the Judiciary, and Related Agencies Appropriations Act, 1998, referred to in subsec. (a)(2), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/119"},"text":"Pub. L. 105–119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2440"},"text":"111 Stat. 2440","children":[],"tail":". For complete classification of title I to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Juvenile Justice and Delinquency Prevention Act of 1974, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415"},"text":"Pub. L. 93–415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1109"},"text":"88 Stat. 1109","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 11291 et seq.) of chapter 111 of this title. For complete classification of this Act to the Code, see Short Title of 1974 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395ef0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17612"},"text":"section 17612 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d395ef1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/b/1"},"text":"Pub. L. 119–60, § 8202(b)(1)","children":[],"tail":", inserted “, Tribal, military,” after “State” and substituted “child obscenity and pornography cases, and the identification of child victims” for “and child obscenity and pornography cases”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/b/2/A"},"text":"Pub. L. 119–60, § 8202(b)(2)(A)","children":[],"tail":", substituted “, evaluate the task forces funded under the ICAC Task Force Program to determine if those task forces are operating in an effective manner.” for “consult with and consider all 59 task forces in existence on "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"October 13, 2008","children":[],"tail":". The Attorney General shall include all existing ICAC task forces in the ICAC Task Force Program, unless the Attorney General makes a determination that an existing ICAC does not have a proven track record of success.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/b/2/B"},"text":"Pub. L. 119–60, § 8202(b)(2)(B)","children":[],"tail":", substituted “establish a new or continue an existing task force” for “establish a new task force” and “State” for “state”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/b/2/C/i"},"text":"Pub. L. 119–60, § 8202(b)(2)(C)(i)","children":[],"tail":", substituted “shall establish” for “may establish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/b/2/C/ii"},"text":"Pub. L. 119–60, § 8202(b)(2)(C)(ii)","children":[],"tail":", (iii), redesignated subpar. (C) as (B) and struck out former subpar. (B). Text read as follows: “In establishing training courses under this paragraph, the Attorney General may not award any one entity other than a law enforcement agency more than $4,000,000 annually to establish and conduct training courses for ICAC task force members and other law enforcement officials.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8202/b/3"},"text":"Pub. L. 119–60, § 8202(b)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/206"},"text":"Pub. L. 112–206","children":[],"tail":" substituted “$4,000,000” for “$2,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
