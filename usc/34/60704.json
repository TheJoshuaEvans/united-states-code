{"tag":"section","attrib":{"id":"id4d66b031-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60704"},"text":null,"children":[{"tag":"num","attrib":{"value":"60704"},"text":"§ 60704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d66b032-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall issue guidance to create, carry out, and administer the Program in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b033-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds to be directed to local control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available as grants under the Program shall be, to the greatest extent practicable, locally controlled to address problems that are identified locally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b034-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Task Forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Thirty percent of the amounts made available as grants under the Program each fiscal year shall be granted to Gang Task Forces in regions experiencing a significant or increased presence of criminal or transnational organizations engaging in high levels of violent crime, firearms offenses, human trafficking, and drug trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d66b035-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available as grants under the Program shall be used to prioritize the investigation and prosecution of individuals who have an aggravating or leadership role in a criminal or transnational organization described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d66b036-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/185/s5"},"text":"Pub. L. 115–185, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-06-18"},"text":"June 18, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1486"},"text":"132 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
