{"tag":"section","attrib":{"id":"id4cfdb50c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202"},"text":null,"children":[{"tag":"num","attrib":{"value":"12202"},"text":"§ 12202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emerging community development corporation revolving loan funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb50d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to emerging community development corporations to enable such corporations to establish, maintain or expand revolving loan funds, to make or guarantee loans, or to make capital investments in new or expanding local businesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb50e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb50f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a community development corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb510-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have completed not less than one nor more than two community economic development projects or related projects that improve or provide job and employment opportunities to low-income individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb511-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a strategic investment plan that identifies and describes the economic characteristics of the target area to be served, the types of business to be assisted using amounts received under the grant and the impact of such assistance on low-income individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb512-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have secured one or more commitments from local sources for contributions (either in cash or in kind, letters of credit, or letters of commitment) in an amount that is equal to at least 10 percent of the amounts requested in the application submitted under paragraph (2).","children":[{"tag":"ref","attrib":{"idref":"fn002099"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be paragraph “(3)”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb513-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of revolving loan fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb514-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A revolving loan fund established or maintained with amounts received under this section may be utilized to provide financial and technical assistance, loans, loan guarantees or investments to private business enterprises to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfdb515-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finance projects intended to provide business and employment opportunities for low-income individuals and to improve the quality of life in urban and rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfdb516-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build and expand the capacity of emerging community development corporations and serve the economic needs of local residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb517-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage emerging community development corporations that receive grants under this section to seek technical assistance from established community development corporations, with expertise in the planning, development and management of economic development projects and shall facilitate the receipt of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb518-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 10 percent of the amounts received under this section by a grantee shall be used for training, technical assistance and administrative purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb519-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of proceeds from investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proceeds derived from investments made with amounts provided under this section may be utilized only for the purposes described in this part and shall be reinvested in the community in which they were generated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb51a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts provided under this section to a community development corporation shall not exceed $500,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb51b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31122"},"text":"Pub. L. 103–322, title III, § 31122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1886"},"text":"108 Stat. 1886","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb51c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb51d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb51e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13842"},"text":"section 13842 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
