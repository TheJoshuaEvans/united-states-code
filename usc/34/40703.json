{"tag":"section","attrib":{"id":"id4d512bd7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703"},"text":null,"children":[{"tag":"num","attrib":{"value":"40703"},"text":"§ 40703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection and use of DNA identification information from certain District of Columbia offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512bd8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of DNA samples","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512bd9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From individuals in custody","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Prisons shall collect a DNA sample from each individual in the custody of the Bureau of Prisons who is, or has been, convicted of a qualifying District of Columbia offense (as determined under subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512bda-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" From individuals on release, parole, or probation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Court Services and Offender Supervision Agency for the District of Columbia shall collect a DNA sample from each individual under the supervision of the Agency who is on supervised release, parole, or probation who is, or has been, convicted of a qualifying District of Columbia offense (as determined under subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512bdb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals already in CODIS","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each individual described in paragraph (1) or (2), if the Combined DNA Index System (in this section referred to as “CODIS”) of the Federal Bureau of Investigation contains a DNA analysis with respect to that individual, the Director of the Bureau of Prisons or Agency (as applicable) may (but need not) collect a DNA sample from that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512bdc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512bdd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Bureau of Prisons or Agency (as applicable) may use or authorize the use of such means as are reasonably necessary to detain, restrain, and collect a DNA sample from an individual who refuses to cooperate in the collection of the sample.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512bde-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Bureau of Prisons or Agency, as appropriate, may enter into agreements with units of State or local government or with private entities to provide for the collection of the samples described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512bdf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual from whom the collection of a DNA sample is authorized under this subsection who fails to cooperate in the collection of that sample shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512be0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guilty of a class A misdemeanor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512be1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" punished in accordance with title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512be2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis and use of samples","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Prisons or Agency (as applicable) shall furnish each DNA sample collected under subsection (a) to the Director of the Federal Bureau of Investigation, who shall carry out a DNA analysis on each such DNA sample and include the results in CODIS. The Director of the Federal Bureau of Investigation may waive the requirements under this subsection if DNA samples are analyzed by means of Rapid DNA instruments and the results are included in CODIS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512be3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512be4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “DNA sample” means a tissue, fluid, or other bodily sample of an individual on which a DNA analysis can be carried out.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512be5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “DNA analysis” means analysis of the deoxyribonucleic acid (DNA) identification information in a bodily sample.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512be6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Rapid DNA instruments” means instrumentation that carries out a fully automated process to derive a DNA analysis from a DNA sample.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512be7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying District of Columbia offenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The government of the District of Columbia may determine those offenses under the District of Columbia Code that shall be treated for purposes of this section as qualifying District of Columbia offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512be8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Collection of DNA samples under subsection (a) shall, subject to the availability of appropriations, commence not later than the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2000-12-19"},"text":"December 19, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512be9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Court Services and Offender Supervision Agency for the District of Columbia to carry out this section such sums as may be necessary for each of fiscal years 2001 through 2005.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512bea-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s4"},"text":"Pub. L. 106–546, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2730"},"text":"114 Stat. 2730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/50/s3/b"},"text":"Pub. L. 115–50, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-18"},"text":"Aug. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1002"},"text":"131 Stat. 1002","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512beb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512bec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512bed-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14135b"},"text":"section 14135b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d512bee-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/50/s3/b/1"},"text":"Pub. L. 115–50, § 3(b)(1)","children":[],"tail":", inserted at end “The Director of the Federal Bureau of Investigation may waive the requirements under this subsection if DNA samples are analyzed by means of Rapid DNA instruments and the results are included in CODIS.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/50/s3/b/2"},"text":"Pub. L. 115–50, § 3(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
