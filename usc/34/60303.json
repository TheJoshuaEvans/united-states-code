{"tag":"section","attrib":{"id":"id4d61f582-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303"},"text":null,"children":[{"tag":"num","attrib":{"value":"60303"},"text":"§ 60303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d61f583-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish a process through which a State may apply for a grant under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f584-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f585-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State desiring a grant under this chapter shall submit an application to the Attorney General at such time, in such manner, and containing such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f586-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f587-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification by an appropriate officer of the State that the State authorizes capital punishment under its laws and conducts, or will conduct, prosecutions in which capital punishment is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f588-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the communities to be served by the grant, including the nature of existing capital defender services and capital prosecution programs within such communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f589-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a long-term statewide strategy and detailed implementation plan that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d61f58a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects consultation with the judiciary, the organized bar, and State and local prosecutor and defender organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f58b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes as a priority improvement in the quality of trial-level representation of indigents charged with capital crimes and trial-level prosecution of capital crimes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f58c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State that employs a statutory procedure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/C"},"text":"section 60301(e)(1)(C) of this title","children":[],"tail":", a certification by an appropriate officer of the State that the State is in substantial compliance with the requirements of the applicable State statute; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f58d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that Federal funds received under this chapter shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d61f58e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to supplement and not supplant non-Federal funds that would otherwise be available for activities funded under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f58f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60303/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allocated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60306/b"},"text":"section 60306(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f590-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s423"},"text":"Pub. L. 108–405, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2288"},"text":"118 Stat. 2288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f591-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f592-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d61f593-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14163b"},"text":"section 14163b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
