{"tag":"section","attrib":{"id":"id4d34a353-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20714"},"text":null,"children":[{"tag":"num","attrib":{"value":"20714"},"text":"§ 20714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training of tribal law enforcement and prosecutorial personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General, in consultation with the Director of the Office of Tribal Justice, shall carry out a program under which tribal law enforcement officials may receive technical assistance and training to pursue a victim-centered approach to investigating and prosecuting severe forms of trafficking in persons (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d34a354-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/tII/s214"},"text":"Pub. L. 109–164, title II, § 214","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tV/s504"},"text":"Pub. L. 115–393, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5277"},"text":"132 Stat. 5277","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/164/s214"},"text":"§ 214 of Pub. L. 109–164","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tI/s106/b/3"},"text":"Pub. L. 117–347, title I, § 106(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6205"},"text":"136 Stat. 6205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a355-