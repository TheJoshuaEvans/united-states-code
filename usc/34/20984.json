{"tag":"section","attrib":{"id":"id4d395df5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984"},"text":null,"children":[{"tag":"num","attrib":{"value":"20984"},"text":"§ 20984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for fingerprinting programs for children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d395df6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish and implement a program under which the Attorney General may make grants to States, units of local government, and Indian tribal governments in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395df7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant made to a State, unit of local government, or Indian tribal government under subsection (a) shall be distributed to law enforcement agencies within the jurisdiction of such State, unit, or tribal government to be used for any of the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395df8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish a voluntary fingerprinting program for children, which may include the taking of palm prints of children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395df9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To hire additional law enforcement personnel, or train existing law enforcement personnel, to take fingerprints of children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dfa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide information within the community involved about the existence of such a fingerprinting program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dfb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide for computer hardware, computer software, or other materials necessary to carry out such a fingerprinting program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395dfc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fingerprints of a child derived from a program funded under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d395dfd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be released only to a parent or guardian of the child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d395dfe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be copied or retained by any Federal, State, local, or tribal law enforcement officer unless written permission is given by the parent or guardian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395dff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who uses the fingerprints of a child derived from a program funded under this section for any purpose other than the purpose described in subsection (c)(1) shall be subject to imprisonment for not more than 1 year, a fine under title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d395e00-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20984/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $20,000,000 to carry out this section for the 5-year period beginning on the first day of fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d395e01-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s627"},"text":"Pub. L. 109–248, title VI, § 627","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/637"},"text":"120 Stat. 637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d395e02-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d395e03-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d395e04-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16984"},"text":"section 16984 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
