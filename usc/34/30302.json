{"tag":"section","attrib":{"id":"id4d42fbc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302"},"text":null,"children":[{"tag":"num","attrib":{"value":"30302"},"text":"§ 30302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d42fbc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a zero-tolerance standard for the incidence of prison rape in prisons in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the prevention of prison rape a top priority in each prison system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbcb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement national standards for the detection, prevention, reduction, and punishment of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbcc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the available data and information on the incidence of prison rape, consequently improving the management and administration of correctional facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbcd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standardize the definitions used for collecting data on the incidence of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the accountability of prison officials who fail to detect, prevent, reduce, and punish prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbcf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the Eighth Amendment rights of Federal, State, and local prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the efficiency and effectiveness of Federal expenditures through grant programs such as those dealing with health care; mental health care; disease prevention; crime prevention, investigation, and prosecution; prison construction, maintenance, and operation; race relations; poverty; unemployment; and homelessness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d42fbd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the costs that prison rape imposes on interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d42fbd2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/79/s3"},"text":"Pub. L. 108–79, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-04"},"text":"Sept. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/974"},"text":"117 Stat. 974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d42fbd3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d42fbd4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d42fbd5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15602"},"text":"section 15602 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
