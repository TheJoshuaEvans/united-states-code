{"tag":"section","attrib":{"id":"id4ced12ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11242"},"text":null,"children":[{"tag":"num","attrib":{"value":"11242"},"text":"§ 11242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for technical assistance and training","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to statewide and regional nonprofit organizations (and combinations of such organizations) to provide technical assistance and training to public and private entities (and combinations of such entities) that are eligible to receive grants under this subchapter, for the purpose of carrying out the programs, projects, or activities for which such grants are made.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ced12ee-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s342"},"text":"Pub. L. 93–415, title III, § 342","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/C"},"text":"Pub. L. 102–586, § 3(g)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5023"},"text":"106 Stat. 5023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced12ef-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced12f0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced12f1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–22"},"text":"section 5714–22 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ced12f2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s342"},"text":"section 342 of Pub. L. 93–415","children":[],"tail":" was renumbered section 381 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11272"},"text":"section 11272 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
