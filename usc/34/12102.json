{"tag":"section","attrib":{"id":"id4cf688ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102"},"text":null,"children":[{"tag":"num","attrib":{"value":"12102"},"text":"§ 12102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf68900-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall provide Violent Offender Incarceration grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12103"},"text":"section 12103 of this title","children":[],"tail":" and Truth-in-Sentencing Incentive grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12104"},"text":"section 12104 of this title","children":[],"tail":" to eligible States—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf68901-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build or expand correctional facilities to increase the bed capacity for the confinement of persons convicted of a part 1 violent crime or adjudicated delinquent for an act which if committed by an adult, would be a part 1 violent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68902-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build or expand temporary or permanent correctional facilities, including facilities on military bases, prison barges, and boot camps, for the confinement of convicted nonviolent offenders and criminal aliens, for the purpose of freeing suitable existing prison space for the confinement of persons convicted of a part 1 violent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68903-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build or expand jails; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68904-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out any activity referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10631/b"},"text":"section 10631(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf68905-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional compacts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf68906-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), States may enter into regional compacts to carry out this part. Such compacts shall be treated as States under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68907-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be recognized as a regional compact for eligibility for a grant under section 12103 or 12104 of this title, each member State must be eligible individually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68908-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on receipt of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State may receive a grant under this part both individually and as part of a compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf68909-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the eligibility requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12104"},"text":"section 12104 of this title","children":[],"tail":", a State that certifies to the Attorney General that, as of "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"April 26, 1996","children":[],"tail":", such State has enacted legislation in reliance on this part, as enacted on "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", and would in fact qualify under those provisions, shall be eligible to receive a grant for fiscal year 1996 as though such State qualifies under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12104"},"text":"section 12104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf6890a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20102"},"text":"Pub. L. 103–322, title II, § 20102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–15; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s104/a"},"text":"Pub. L. 110–199, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/669"},"text":"122 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf6890b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf6890c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf6890d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"childr