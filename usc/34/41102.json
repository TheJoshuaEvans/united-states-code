{"tag":"section","attrib":{"id":"id4d560e15-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41102"},"text":null,"children":[{"tag":"num","attrib":{"value":"41102"},"text":"§ 41102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parimutuel licensing simplification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d560e16-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An association of State officials regulating parimutuel wagering, designated for the purpose of this section by the Attorney General, may submit fingerprints to the Attorney General on behalf of any applicant for State license to participate in parimutuel wagering. In response to such a submission, the Attorney General may, to the extent provided by law, exchange, for licensing and employment purposes, identification and criminal history records with the State governmental bodies to which such applicant has applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d585807-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d585808-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/413/s2"},"text":"Pub. L. 100–413, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-22"},"text":"Aug. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1101"},"text":"102 Stat. 1101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d585809-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d58580a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d58580b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d58580c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/413/s3"},"text":"Pub. L. 100–413, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-22"},"text":"Aug. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1101"},"text":"102 Stat. 1101","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/413/s3"},"text":"“This Act [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1989-07-01"},"text":"July 1, 1989","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
