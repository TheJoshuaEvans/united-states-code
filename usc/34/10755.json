{"tag":"section","attrib":{"id":"id4cda00c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10755"},"text":null,"children":[{"tag":"num","attrib":{"value":"10755"},"text":"§ 10755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, for purposes of carrying out this subchapter, the Attorney General is authorized to award not more than $10,000,000 of funds appropriated to the Department of Justice for these purposes for each of fiscal years 2021 through 2025.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cda00c6-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3055"},"text":"Pub. L. 90–351, title I, § 3055","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/281/s2/a"},"text":"Pub. L. 116–281, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3385"},"text":"134 Stat. 3385","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
