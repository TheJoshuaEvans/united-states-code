{"tag":"section","attrib":{"id":"id4d643f34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511"},"text":null,"children":[{"tag":"num","attrib":{"value":"60511"},"text":"§ 60511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Careers training demonstration grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d643f35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this section, the Attorney General shall make grants to States, units of local government, territories, nonprofit organizations, and Indian Tribes to provide career training, including subsidized employment, when part of a training program, to prisoners and reentering youth and adults.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under subsection (a) may be used for establishing a program to train prisoners for jobs and careers during the 3-year period before release from prison, jail, or a juvenile facility, as well as upon transition and reentry into the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Priority consideration shall be given to any application under this section that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides assessment of local demand for employees in the geographic areas to which offenders are likely to return;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts individualized reentry career planning upon the start of incarceration or post-release employment planning for each offender served under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates connections to employers within the local community; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracks and monitors employment outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Control of Internet access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives a grant under subsection (a) shall restrict access to the Internet by prisoners, as appropriate, to ensure public safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the last day of each fiscal year, an entity that receives a grant under subsection (a) during the preceding fiscal year shall submit to the Attorney General a report that describes and assesses the uses of such grant during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60511/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019, 2020, 2021, 2022, and 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f3f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s115"},"text":"Pub. L. 110–199, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/677"},"text":"122 Stat. 677","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/d"},"text":"Pub. L. 115–391, title V, § 502(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5229"},"text":"132 Stat. 5229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f40-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f41-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d643f42-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17511"},"text":"section 17511 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d643f43-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/1"},"text":"Pub. L. 115–391, § 502(d)(1)","children":[],"tail":", substituted “Careers” for “Technology careers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/2"},"text":"Pub. L. 115–391, § 502(d)(2)","children":[],"tail":", substituted “nonprofit organizations, and Indian Tribes to provide career training, including subsidized employment, when part of a training program, to prisoners and reentering youth and adults” for “and Indian Tribes to provide technology career training to prisoners”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/3"},"text":"Pub. L. 115–391, § 502(d)(3)","children":[],"tail":", struck out “technology careers training” before “program” and “technology-based” before “jobs” and inserted “, as well as upon transition and reentry into the community” after “facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/6"},"text":"Pub. L. 115–391, § 502(d)(6)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/5"},"text":"Pub. L. 115–391, § 502(d)(5)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/4"},"text":"Pub. L. 115–391, § 502(d)(4)","children":[],"tail":", (5), redesignated subsec. (d) as (e) and struck out former subsec. (e). Prior to amendment, text of subsec. (e) read as follows: “There are authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2009 and 2010.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/d/7"},"text":"Pub. L. 115–391, § 502(d)(7)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
