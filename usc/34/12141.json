{"tag":"section","attrib":{"id":"id4cfb6a4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141"},"text":null,"children":[{"tag":"num","attrib":{"value":"12141"},"text":"§ 12141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfb6a4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may award grants to not more than 15 chronic high intensive crime areas to develop comprehensive model crime prevention programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfb6a50-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve and utilize a broad spectrum of community resources, including nonprofit community organizations, law enforcement organizations, and appropriate State and Federal agencies, including the State educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a51-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempt to relieve conditions that encourage crime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6a52-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide meaningful and lasting alternatives to involvement in crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with the Ounce of Prevention Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may consult with the Ounce of Prevention Council in awarding grants under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6a54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a), the Attorney General shall give priority to proposals that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6a55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are innovative in approach to the prevention of crime in a specific area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vary in approach to ensure that comparisons of different models may be made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6a57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate crime prevention programs funded under this program with other existing Federal programs to address the overall needs of communities that benefit from grants received under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfb6a58-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s30301"},"text":"Pub. L. 103–322, title III, § 30301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1844"},"text":"108 Stat. 1844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfb6a59-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfb6a5a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfb6a5b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b)(3), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1836"},"text":"108 Stat. 1836","children":[],"tail":". For complete classification of title III to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfb6a5c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13771"},"text":"section 13771 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
