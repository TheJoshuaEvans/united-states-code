{"tag":"section","attrib":{"id":"id4d5ac967-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41503"},"text":null,"children":[{"tag":"num","attrib":{"value":"41503"},"text":"§ 41503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fugitive Apprehension Task Forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5ac968-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall, upon consultation with appropriate Department of Justice and Department of the Treasury law enforcement components, establish permanent Fugitive Apprehension Task Forces consisting of Federal, State, and local law enforcement authorities in designated regions of the United States, to be directed and coordinated by the United States Marshals Service, for the purpose of locating and apprehending fugitives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac969-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Attorney General for the United States Marshals Service to carry out the provisions of this section $30,000,000 for the fiscal year 2001, $5,000,000 for fiscal year 2002, $5,000,000 for fiscal year 2003, and $10,000,000 for each of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac96a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other existing applicable law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit any existing authority under any other provision of Federal or State law for law enforcement agencies to locate or apprehend fugitives through task forces or any other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5ac96b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/544/s6"},"text":"Pub. L. 106–544, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2718"},"text":"114 Stat. 2718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tV/s507"},"text":"Pub. L. 110–177, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2543"},"text":"121 Stat. 2543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5ac96c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5ac96d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5ac96e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s566"},"text":"section 566 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d5ac96f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177"},"text":"Pub. L. 110–177","children":[],"tail":" struck out “and” after “fiscal year 2002,” and inserted before period at end “, and $10,000,000 for each of fiscal years 2008 through 2012”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
