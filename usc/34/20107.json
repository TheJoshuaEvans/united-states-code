{"tag":"section","attrib":{"id":"id4d1f1f7e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20107"},"text":null,"children":[{"tag":"num","attrib":{"value":"20107"},"text":"§ 20107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime victims legal assistance grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1f7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may make grants as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20103/c/1/A"},"text":"section 20103(c)(1)(A) of this title","children":[],"tail":" to State, tribal, and local prosecutors’ offices, law enforcement agencies, courts, jails, and correctional institutions, and to qualified public and private entities, to develop, establish, and maintain programs for the enforcement of crime victims’ rights as provided in law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant amounts under this section may not be used to bring a cause of action for damages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False Claims Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, amounts collected pursuant to sections 3729 through 3731 of title 31 (commonly known as the “False Claims Act”) may be used for grants under this section, subject to appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f1f82-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1404D"},"text":"Pub. L. 98–473, title II, § 1404D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tI/s103/a"},"text":"Pub. L. 108–405, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2264"},"text":"118 Stat. 2264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f1f83-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1f1f84-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1f1f85-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10603d"},"text":"section 10603d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
