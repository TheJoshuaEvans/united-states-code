{"tag":"section","attrib":{"id":"id4cb89550-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303"},"text":null,"children":[{"tag":"num","attrib":{"value":"10303"},"text":"§ 10303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications; approval","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cb89551-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person seeking assistance under this part shall submit an application to the Attorney General in such form and containing such information as the Attorney General reasonably may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89552-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall approve an application for assistance under this part unless the Attorney General finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb89553-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is not eligible for, is no longer eligible for, or is not entitled to the assistance for which application is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89554-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person’s selected educational institution fails to meet a requirement under this part for eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89555-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person’s enrollment in or pursuit of the educational program selected would fail to meet the criteria established in this part for programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89556-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person already is qualified by previous education or training for the educational, professional, or vocational objective for which the educational program is offered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89557-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall notify a person applying for assistance under this part of approval or disapproval of the application in writing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cb89558-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1213"},"text":"Pub. L. 90–351, title I, § 1213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/238/s2/2"},"text":"Pub. L. 104–238, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3115"},"text":"110 Stat. 3115","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1086/b/1/G"},"text":"Pub. L. 112–239, div. A, title X, § 1086(b)(1)(G)","children":[],"tail":", (I), "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1968"},"text":"126 Stat. 1968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb89559-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb8955a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb8955b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796d–2"},"text":"section 3796d–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cb8955c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “person” for “dependent” in pars. (1) and (4) and “person’s” for “dependent’s” in pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/b/1/G"},"text":"Pub. L. 112–239, § 1086(b)(1)(G)","children":[],"tail":", substituted “person” for “dependent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cb8955d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cb8955e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", and applicable to matters pending on "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", or filed or accruing after that date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1086/d"},"text":"section 1086(d) of Pub. L. 112–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10251"},"text":"section 10251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
