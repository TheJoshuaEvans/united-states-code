{"tag":"section","attrib":{"id":"id4d17f405-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631"},"text":null,"children":[{"tag":"num","attrib":{"value":"12631"},"text":"§ 12631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of Violent Crime Reduction Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d17f406-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violent Crime Reduction Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a separate account in the Treasury, known as the “Violent Crime Reduction Trust Fund” (referred to in this section as the “Fund”) into which shall be transferred, in accordance with subsection (b), savings realized from implementation of section 5 of the Federal Workforce Restructuring Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"5 U.S.C. 3101","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Public Law 103–226","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f407-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers into Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the first day of the following fiscal years (or as soon thereafter as possible for fiscal year 1995), the following amounts shall be transferred from the general fund to the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f408-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1995, $2,423,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f409-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1996, $4,287,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f40a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1997, $5,000,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f40b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1998, $5,500,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f40c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 1999, $6,500,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f40d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2000, $6,500,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f40e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations from Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f40f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund may be appropriated exclusively for the purposes authorized in this Act and for those expenses authorized by any Act enacted before this Act that are expressly qualified for expenditure from the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f410-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12631/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated under paragraph (1) and outlays flowing from such appropriations shall not be taken into account for purposes of any budget enforcement procedures under the Balanced Budget and Emergency Deficit Control Act of 1985 except section 251A ","children":[{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of that Act as added by subsection (g), or for purposes of section 665d(b) "},{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":" of title 2. Amounts of new budget authority and outlays under paragraph (1) that are included in concurrent resolutions on the budget shall not be taken into account for purposes of sections 665(b), 665e(b), and 665e(c) of title 2,"},{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":" or for purposes of section 24 of House Concurrent Resolution 218 (One Hundred Third Congress)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d17f411-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXI/s310001/a"},"text":"Pub. L. 103–322, title XXXI, § 310001(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2102"},"text":"108 Stat. 2102","children":[],"tail":", 2103.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d17f412-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d17f413-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d17f414-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s310001"},"text":"section 310001 of Pub. L. 103–322","children":[],"tail":", which enacted this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s901a"},"text":"section 901a of Title 2","children":[],"tail":", The Congress, and amended sections 665a and 904 of Title 2 and sections 1105 and 1321 of Title 31, Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1796"},"text":"108 Stat. 1796","children":[],"tail":", known as the Violent Crime Control and Law Enforcement Act of 1994. For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (c)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1038"},"text":"99 Stat. 1038","children":[],"tail":", which enacted chapter 20 (§ 900 et seq.) and sections 654 to 656 of Title 2, The Congress, amended sections 602, 622, 631 to 642, and 651 to 653 of Title 2, sections 1104 to 1106, and 1109 of Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", The Public Health and Welfare, repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"section 661 of Title 2","children":[],"tail":", enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s911"},"text":"section 911 of Title 42","children":[],"tail":", and amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":". Section 251A of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s901a"},"text":"section 901a of Title 2","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10204/a/1"},"text":"Pub. L. 105–33, title X, § 10204(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/702"},"text":"111 Stat. 702","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 665, 665d, and 665e of title 2, referred to in subsec. (c)(2), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10118/a"},"text":"Pub. L. 105–33, title X, § 10118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/695"},"text":"111 Stat. 695","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"House Concurrent Resolution 218, referred to in subsec. (c)(2), is H. Con. Res. 218, ","children":[{"tag":"date","attrib":{"date":"1994-05-12"},"text":"May 12, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/5075"},"text":"108 Stat. 5075","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d17f415-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14211"},"text":"section 14211 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
