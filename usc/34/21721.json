{"tag":"section","attrib":{"id":"id4d3e19ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21721"},"text":null,"children":[{"tag":"num","attrib":{"value":"21721"},"text":"§ 21721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of best practices for local, State, and Federal data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3e19cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with Federal, State, and local law enforcement agencies, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3e19d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish best practices for data collection to focus on elder abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3e19d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to State, local, and tribal governments in adopting the best practices established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2017-10-18"},"text":"October 18, 2017","children":[],"tail":", the Attorney General shall publish the best practices established under subsection (a)(1) on the website of the Department of Justice in a publicly accessible manner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3e19d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require or obligate compliance with the best practices established under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d3e19d4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/70/tII/s201"},"text":"Pub. L. 115–70, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-18"},"text":"Oct. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1211"},"text":"131 Stat. 1211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
