{"tag":"section","attrib":{"id":"id4d23daab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142"},"text":null,"children":[{"tag":"num","attrib":{"value":"20142"},"text":"§ 20142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed circuit televised court proceedings for victims of crime","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d23daac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of the Federal Rules of Criminal Procedure to the contrary, in order to permit victims of crime to watch criminal trial proceedings in cases where the venue of the trial is changed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23daad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out of the State in which the case was initially brought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23daae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 350 miles from the location in which those proceedings originally would have taken place;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the trial court shall order closed circuit televising of the proceedings to that location, for viewing by such persons the court determines have a compelling interest in doing so and are otherwise unable to do so by reason of the inconvenience and expense caused by the change of venue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23daaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23dab0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No other person, other than official court and security personnel, or other persons specifically designated by the court, shall be permitted to view the closed circuit televising of the proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dab1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall not designate a person under paragraph (1) if the presiding judge at the trial determines that testimony by that person would be materially affected if that person heard other testimony at the trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dab2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23dab3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The signal transmitted pursuant to subsection (a) shall be under the control of the court at all times and shall only be transmitted subject to the terms and conditions imposed by the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dab4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No public broadcast or dissemination shall be made of the signal transmitted pursuant to subsection (a). In the event any tapes are produced in carrying out subsection (a), such tapes shall be the property of the court and kept under seal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23dab5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any violations of this subsection, or any rule or order made pursuant to this section, shall be punishable as contempt of court as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s402"},"text":"section 402 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dab6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrative Office of the United States Courts may accept donations to enable the courts to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dab7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23dab8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002167"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002167"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" Nothing in this section shall be construed—"}],"tail":null},{"tag":"clause","attrib":{"id":"id4d23dab9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/e/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create in favor of any person a cause of action against the United States or any officer or employees thereof, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23daba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/e/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide any person with a defense in any action in which application of this section is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dabb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “State” means any State, the District of Columbia, or any possession or territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dabc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Judicial Conference of the United States, pursuant to its rule making authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s331"},"text":"section 331 of title 28","children":[],"tail":", may promulgate and issue rules, or amend existing rules, to effectuate the policy addressed by this section. Upon the implementation of such rules, this section shall cease to be effective."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23dabd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20142/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall only apply to cases filed after ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d23dabe-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tII/s235"},"text":"Pub. L. 104–132, title II, § 235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1246"},"text":"110 Stat. 1246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d23dabf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d23dac0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d23dac1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Criminal Procedure, referred to in subsec. (a), are set out in the Appendix to Title 18, Crimes and Criminal Procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d23dac2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10608"},"text":"section 10608 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
