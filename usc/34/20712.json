{"tag":"section","attrib":{"id":"id4d323338-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20712"},"text":null,"children":[{"tag":"num","attrib":{"value":"20712"},"text":"§ 20712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holistic training for Federal law enforcement officers and prosecutors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"All training required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20709"},"text":"section 20709 of this title","children":[],"tail":" and section 7105(c)(4) "},{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 22 shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d323339-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20712/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasize that an individual who knowingly solicits or patronizes a commercial sex act from a person who was a minor (consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1591/c"},"text":"section 1591(c) of title 18","children":[],"tail":") or was subject to force, fraud, or coercion is guilty of an offense under chapter 77 of title 18 and is a party to a human trafficking offense;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d32333a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20712/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop specific curriculum for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d32333b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20712/2/A"},"text":nul