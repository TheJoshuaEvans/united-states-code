2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6204"},"text":"136 Stat. 6204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d32333f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d323340-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d323341-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7105/c/4"},"text":"Section 7105(c)(4) of title 22","children":[],"tail":", referred to in text, was in the original “section 105(c)(4) of the Trafficking Victims Protection Act of 2000” and was translated as if it read “section 107(c)(4)” of the Act to reflect the probable intent of Congress. There is no section 105(c)(4) of the Trafficking Victims Protection Act of 2000 and section 107(c)(4) relates to the training of Government personnel."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d323342-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20709a"},"text":"section 20709a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/117/347"},"text":"Pub. L. 117–347","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
