{"tag":"section","attrib":{"id":"id4d32330e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20710"},"text":null,"children":[{"tag":"num","attrib":{"value":"20710"},"text":"§ 20710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach to trafficking survivors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall make available, on the website of the Office of Juvenile Justice and Delinquency Prevention, a database for trafficking victim advocates, crisis hotline personnel, foster parents, law enforcement personnel, and crime survivors that contains information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d32330f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20710/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling and hotline resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d323310-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20710/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" housing resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d323311-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20710/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d323312-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20710/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services for trafficking survivors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id