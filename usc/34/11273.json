9","children":[],"tail":", 1042.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cef8378-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cef8379-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cef837a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5715"},"text":"section 5715 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cef837b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/s382"},"text":"section 382 of Pub. L. 93–415","children":[],"tail":" was renumbered section 383 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11274"},"text":"section 11274 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cef837c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71"},"text":"Pub. L. 106–71","children":[],"tail":" amended section generally, making reporting requirements biennial rather than annual and adding subsec. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/h"},"text":"Pub. L. 102–586, § 3(h)","children":[],"tail":", which directed the amendment of section “361 of the Juvenile Justice and Delinquency Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5715"},"text":"42 U.S.C. 5715","children":[],"tail":")” by amending it generally and adding subsec. (b), was executed to this section, which is section 381 of the Juvenile Justice and Delinquency Prevention Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/415"},"text":"Pub. L. 93–415","children":[],"tail":"), to reflect the probable intent of Congress and the intervening renumbering of "},{"tag":"ref","attrib":{"href":"/us/pl/93/415/s361"},"text":"section 361 of Pub. L. 93–415","children":[],"tail":" as section 381 by "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/A/ii"},"text":"section 3(g)(1)(A)(ii) of Pub. L. 102–586","children":[],"tail":". Prior to amendment, this section consisted of subsecs. (a) and (b) which required annual reports to Congress on the status and accomplishments of the runaway and homeless youth centers funded under part A of this subchapter and of the transitional living youth projects funded under part B of this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204/s1003/1"},"text":"Pub. L. 101–204, § 1003(1)","children":[],"tail":", substituted “submit a report to the Committee on Education and Labor of the House of Representatives and the Committee on the Judiciary of the Senate” for “report to the Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/204/s1003/2"},"text":"Pub. L. 101–204, § 1003(2)","children":[],"tail":", substituted “Not later than 180 days after the end of each fiscal year, the Secretary shall submit a report to the Committee on Education and Labor of the House of Representatives and the Committee on the Judiciary of the Senate” for “The Secretary shall annually report to the Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", §§ 7271(c)(5), 7273(c)(1), (2), 7274, designated existing provisions as subsec. (a), in introductory provisions substituted “Not later than 180 days after the end of each fiscal year, the Secretary shall” for “The Secretary shall annually”, “runaway and homeless youth centers” for “runaway centers”, and “part A of this subchapter” for “this part”, and in par. (1) substituted “runaway and homeless youth” for “runaway youth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7273/c/3"},"text":"Pub. L. 100–690, § 7273(c)(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/509"},"text":"Pub. L. 96–509","children":[],"tail":" substituted “centers” for “houses”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cef837d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cef837e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", with the report required by this section with respect to fiscal year 1988 to be submitted not later than "},{"tag":"date","attrib":{"date":"1989-08-01"},"text":"Aug. 1, 1989","children":[],"tail":", notwithstanding the 180-day period provided in this section, see section 7296(a), (b)(3) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
