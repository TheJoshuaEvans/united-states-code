{"tag":"section","attrib":{"id":"id4ced1365-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273"},"text":null,"children":[{"tag":"num","attrib":{"value":"11273"},"text":"§ 11273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ced1366-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2000-04-01"},"text":"April 1, 2000","children":[],"tail":", and biennially thereafter, the Secretary shall submit, to the Committee on Education and the Workforce of the House of Representatives and the Committee on the Judiciary of the Senate, a report on the status, activities, and accomplishments of entities that receive grants under parts A, B, C, D, and E, with particular attention to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ced1367-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of centers funded under part A, the ability or effectiveness of such centers in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced1368-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleviating the problems of runaway and homeless youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1369-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable or appropriate, reuniting such youth with their families and encouraging the resolution of intrafamily problems through counseling and other services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced136a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening family relationships and encouraging stable living conditions for such youth; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced136b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting such youth to decide upon a future course of action; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ced136c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of projects funded under part B—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ced136d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and characteristics of homeless youth served by such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced136e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of activities carried out by such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced136f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such projects in alleviating the problems of homeless youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1370-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such projects in preparing homeless youth for self-sufficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1371-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of such projects in assisting homeless youth to decide upon future education, employment, and independent living;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1372-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of such projects to encourage the resolution of intrafamily problems through counseling and development of self-sufficient living skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ced1373-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities and programs planned by such projects for the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cef8374-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in each report submitted under subsection (a), summaries of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cef8375-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluations performed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11277"},"text":"section 11277 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef8376-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptions of the qualifications of, and training provided to, individuals involved in carrying out such evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cef8377-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s382"},"text":"Pub. L. 93–415, title III, § 382","children":[],"tail":", formerly § 315, "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1131"},"text":"88 Stat. 1131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/509/s18/f"},"t