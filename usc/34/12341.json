{"tag":"section","attrib":{"id":"id4d04e118-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341"},"text":null,"children":[{"tag":"num","attrib":{"value":"12341"},"text":"§ 12341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural domestic violence, dating violence, sexual assault, stalking, and child abuse enforcement assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d04e119-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d04e11a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify, assess, and appropriately respond to child, youth, and adult victims of domestic violence, sexual assault, dating violence, and stalking in rural communities, by encouraging collaboration among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d04e11b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic violence, dating violence, sexual assault, and stalking victim service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e11c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e11d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecutors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e11e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e11f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other criminal justice service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e120-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human and community service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e121-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e122-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers, including sexual assault forensic examiners;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e123-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish and expand nonprofit, nongovernmental, State, tribal, territorial, and local government victim services in rural communities to child, youth, and adult victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e124-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to increase the safety and well-being of women and children in rural communities, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d04e125-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dealing directly and immediately with domestic violence, sexual assault, dating violence, and stalking occurring in rural communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e126-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating and implementing strategies to increase awareness and prevent domestic violence, sexual assault, dating violence, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e127-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop, expand, implement, and improve the quality of sexual assault forensic medical examination or sexual assault nurse examiner programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e128-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, acting through the Director of the Office on Violence Against Women (referred to in this section as the “Director”), may award grants to States, Indian tribes, local governments, and nonprofit, public or private entities, including tribal nonprofit organizations, to carry out programs serving rural areas or rural communities that address domestic violence, dating violence, sexual assault, and stalking by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d04e129-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing, expanding, and establishing cooperative efforts and projects among law enforcement officers, prosecutors, victim service providers, and other related parties to investigate and prosecute incidents of domestic violence, dating violence, sexual assault, and stalking, including developing multidisciplinary teams focusing on high risk cases with the goal of preventing domestic and dating violence homicides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e12a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing treatment, counseling, advocacy, legal assistance, and other long-term and short-term victim and population specific services to adult and minor victims of domestic violence, dating violence, sexual assault, and stalking in rural communities, including assistance in immigration matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e12b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working in cooperation with the community to develop education and prevention strategies directed toward such issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e12c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, enlarging, or strengthening programs addressing sexual assault, including sexual assault forensic examiner programs, Sexual Assault Response Teams, law enforcement training, and programs addressing rape kit backlogs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e12d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing programs and strategies that focus on the specific needs of victims of domestic violence, dating violence, sexual assault, and stalking who reside in remote rural and geographically isolated areas, including addressing the challenges posed by the lack of access to quality forensic sexual assault examinations by trained health care providers, shelters, and victims services, and limited law enforcement resources and training, and providing training and resources to Community Health Aides involved in the delivery of Indian Health Service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e12e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated pursuant to this section shall be used only for specific programs and activities expressly described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e12f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments and priorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d04e130-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment for Indian tribes","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d04e131-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 percent of the total amount available under this section for each fiscal year shall be available for grants under the program authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10452"},"text":"section 10452 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e132-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of part ","children":[{"tag":"ref","attrib":{"idref":"fn002108"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002108"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of this section shall not apply to funds allocated for the program described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e133-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment for sexual assault","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d04e134-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 25 percent of the total amount appropriated in a fiscal year under this section shall fund services that meaningfully address sexual assault in rural communities, however at such time as the amounts appropriated reach the amount of $45,000,000, the percentage allocated shall rise to 30 percent of the total amount appropriated, at such time as the amounts appropriated reach the amount of $50,000,000, the percentage allocated shall rise to 35 percent of the total amount appropriated, and at such time as the amounts appropriated reach the amount of $55,000,000, the percentage allocated shall rise to 40 percent of the amounts appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d04e135-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple purpose applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall prohibit any applicant from applying for funding to address sexual assault, domestic violence, stalking, or dating violence in the same application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e136-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotment for technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated for each fiscal year to carry out this section, not more than 8 percent may be used by the Director for technical assistance costs. Of the amounts appropriated in this subsection, no less than 25 percent of such amounts shall be available to a nonprofit, nongovernmental organization or organizations whose focus and expertise is in addressing sexual assault to provide technical assistance to sexual assault grantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e137-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Director shall give priority to the needs of underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e138-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds for rural States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 75 percent of the total amount made available for each fiscal year to carry out this section shall be allocated to eligible entities located in rural States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d04e139-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d04e13a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $100,000,000 for each of fiscal years 2023 through 2027 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d04e13b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12341/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds received through a grant under subsection (b), a law enforcement agency may use funds received through a grant under part Q of title I of the Omnibus Crime Control and Safe Streets Act of 1968 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796dd"},"text":"42 U.S.C. 3796dd","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002109"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" to accomplish the objectives of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d04e13c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40295"},"text":"Pub. L. 103–322, title IV, § 40295","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1940"},"text":"108 Stat. 1940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/386/dB/tI"},"text":"Pub. L. 106–386, div. B, title I","children":[],"tail":", §§ 1105, 1109(d), title V, § 1512(c), "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1497"},"text":"114 Stat. 1497","children":[],"tail":", 1503, 1533; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tII/s203"},"text":"Pub. L. 109–162, title II, § 203","children":[],"tail":", title IX, § 906(d), "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2998"},"text":"119 Stat. 2998","children":[],"tail":", 3081; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s7/b/1"},"text":"Pub. L. 109–271, § 7(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/764"},"text":"120 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tII/s202"},"text":"Pub. L. 113–4, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/81"},"text":"127 Stat. 81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tII/s202"},"text":"Pub. L. 117–103, div. W, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/856"},"text":"136 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d04e13d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d04e13e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d04e13f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Omnibus Crime Control and Safe Streets Act of 1968, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/197"},"text":"82 Stat. 197","children":[],"tail":". Part Q of title I of the Act was classified generally to subchapter XII–E (§ 3796dd et seq.) of chapter 46 of Title 42, The Public Health and Welfare, prior to editorial reclassification as subchapter XVI (§ 10381 et seq.) of chapter 101 of this title. For complete classification of this Act to the Code, see Short Title of 1968 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d04e140-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13971"},"text":"section 13971 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d04e141-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s202/1"},"text":"Pub. L. 117–103, § 202(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s202/2/A"},"text":"Pub. L. 117–103, § 202(2)(A)","children":[],"tail":", substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s202/2/B"},"text":"Pub. L. 117–103, § 202(2)(B)","children":[],"tail":", inserted “quality forensic sexual assault examinations by trained health care providers,” after “by the lack of access to” and substituted “shelters, and” for “shelters and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s202/3"},"text":"Pub. L. 117–103, § 202(3)","children":[],"tail":", substituted “$100,000,000 for each of fiscal years 2023 through 2027” for “$50,000,000 for each of fiscal years 2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s202/1"},"text":"Pub. L. 113–4, § 202(1)","children":[],"tail":", inserted “, including sexual assault forensic examiners” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s202/2/A"},"text":"Pub. L. 113–4, § 202(2)(A)","children":[],"tail":", substituted “victim service providers” for “victim advocacy groups” and inserted “, including developing multidisciplinary teams focusing on high risk cases with the goal of preventing domestic and dating violence homicides” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s202/2/B/i"},"text":"Pub. L. 113–4, § 202(2)(B)(i)","children":[],"tail":", substituted “legal assistance, and other long-term and short-term victim and population specific services” for “and other long- and short-term assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s202/2/B/ii"},"text":"Pub. L. 113–4, § 202(2)(B)(ii)","children":[],"tail":", (C), (D), added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s202/3"},"text":"Pub. L. 113–4, § 202(3)","children":[],"tail":", substituted “$50,000,000 for each of fiscal years 2014 through 2018” for “$55,000,000 for each of the fiscal years 2007 through 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s203"},"text":"Pub. L. 109–162, § 203","children":[],"tail":", amended section generally, substituting provisions relating to rural domestic violence, dating violence, sexual assault, stalking, and child abuse enforcement assistance for provisions relating to rural domestic violence and child abuse enforcement assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s906/d"},"text":"Pub. L. 109–162, § 906(d)","children":[],"tail":", which directed the amendment of subsec. (c) by striking par. (3) and inserting a new par. (3) which read “Not less than 10 percent of the total amount available under this section for each fiscal year shall be available for grants under the program authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3796gg–10"},"text":"section 3796gg–10 of this title","children":[],"tail":". The requirements of this paragraph shall not apply to funds allocated for such program.”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s7/b/2/A"},"text":"Pub. L. 109–271, § 7(b)(2)(A)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271/s7/b/1"},"text":"Pub. L. 109–271, § 7(b)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “Not less than 10 percent of the total amount made available for each fiscal year to carry out this section shall be allocated for grants to Indian tribes or tribal organizations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1109/d/1"},"text":"Pub. L. 106–386, § 1109(d)(1)","children":[],"tail":", inserted “and dating violence (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3796gg–2"},"text":"section 3796gg–2 of this title","children":[],"tail":")” after “domestic violence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1512/c"},"text":"Pub. L. 106–386, § 1512(c)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “to provide treatment and counseling to victims of domestic violence and dating violence (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3796gg–2"},"text":"section 3796gg–2 of this title","children":[],"tail":") and child abuse; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1109/d/2"},"text":"Pub. L. 106–386, § 1109(d)(2)","children":[],"tail":", inserted “and dating violence (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3796gg–2"},"text":"section 3796gg–2 of this title","children":[],"tail":")” after “domestic violence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1105/1"},"text":"Pub. L. 106–386, § 1105(1)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “There are authorized to be appropriated to carry out this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $7,000,000 for fiscal year 1996;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $8,000,000 for fiscal year 1997; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $15,000,000 for fiscal year 1998.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/s1105/2"},"text":"Pub. L. 106–386, § 1105(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d04e142-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d04e143-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d04e144-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},