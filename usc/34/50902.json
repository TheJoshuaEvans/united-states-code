{"tag":"section","attrib":{"id":"id4d5f83a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902"},"text":null,"children":[{"tag":"num","attrib":{"value":"50902"},"text":"§ 50902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5f83a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5f83a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First responder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first responder” has the meaning given the term “public safety officer” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10284"},"text":"section 10284 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First responder agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first responder agency” means a Federal, State, local, or Tribal agency that employs or otherwise engages the services of a first responder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer support counseling program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “peer support counseling program” means a program provided by a first responder agency that provides counseling services from a peer support specialist to a first responder of the first responder agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer support participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “peer support participant” means a first responder who receives counseling services from a peer support specialist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer support specialist","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “peer support specialist” means a first responder who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5f83a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has received training in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d5f83aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peer support counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d5f83ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing emotional and moral support to first responders who have been involved in or exposed to an emotionally traumatic experience in the course of the duties of those first responders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5f83ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated by a first responder agency to provide the services described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5f83ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-18"},"text":"November 18, 2021","children":[],"tail":", the Attorney General, in coordination with the Secretary of Health and Human Services, shall develop a report on best practices and professional standards for peer support counseling programs for first responder agencies that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5f83ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advice on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5f83af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and operating peer support counseling programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5f83b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and certifying peer support specialists;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a code of ethics for peer support specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for continuing education for peer support specialists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advice on disclosing to first responders any confidentiality rights of peer support participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5f83b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the different types of peer support counseling programs in use by first responder agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5f83b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any differences in peer support counseling programs offered across categories of first responders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5f83b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the important role senior first responders play in supporting access to mental health resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5f83b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall support and encourage the implementation of peer support counseling programs in first responder agencies by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5f83b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making the report developed under subsection (b) publicly available on the website of the Department of Justice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5f83ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a list of peer support specialist training programs on the website of the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5f83bb-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/60/s3"},"text":"Pub. L. 117–60, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-18"},"text":"Nov. 18, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1472"},"text":"135 Stat. 1472","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
