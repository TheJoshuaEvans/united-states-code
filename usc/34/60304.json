{"tag":"section","attrib":{"id":"id4d61f594-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304"},"text":null,"children":[{"tag":"num","attrib":{"value":"60304"},"text":"§ 60304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d61f595-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State receiving funds under this chapter shall submit an annual report to the Attorney General that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f596-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the activities carried out with such funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f597-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains how each activity complies with the terms and conditions of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f598-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital representation improvement grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301"},"text":"section 60301 of this title","children":[],"tail":", a report under subsection (a) shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f599-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting of all amounts expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f59a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an explanation of the means by which the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f59b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invests the responsibility for identifying and appointing qualified attorneys to represent indigents in capital cases in a program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/A"},"text":"section 60301(e)(1)(A) of this title","children":[],"tail":", an entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/B"},"text":"section 60301(e)(1)(B) of this title","children":[],"tail":", or a selection committee or similar entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/C"},"text":"section 60301(e)(1)(C) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f59c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requires such program, entity, or selection committee or similar entity, or other appropriate entity designated pursuant to the statutory procedure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/C"},"text":"section 60301(e)(1)(C) of this title","children":[],"tail":", to—"}],"tail":null},{"tag":"clause","attrib":{"id":"id4d61f59d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish qualifications for attorneys who may be appointed to represent indigents in capital cases in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/2/A"},"text":"section 60301(e)(2)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f59e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a roster of qualified attorneys in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/2/B"},"text":"section 60301(e)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f59f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign attorneys from the roster in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/2/C"},"text":"section 60301(e)(2)(C) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f5a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, sponsor, or approve specialized training programs for attorneys representing defendants in capital cases in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/2/D"},"text":"section 60301(e)(2)(D) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f5a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the performance and training program attendance of appointed attorneys, and remove from the roster attorneys who fail to deliver effective representation or fail to comply with such requirements as such program, entity, or selection committee or similar entity may establish regarding participation in training programs, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/2/E"},"text":"section 60301(e)(2)(E) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f5a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure funding for the cost of competent legal representation by the defense team and outside experts selected by counsel, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/2/F"},"text":"section 60301(e)(2)(F) of this title","children":[],"tail":", including a statement setting forth—"}],"tail":null},{"tag":"subclause","attrib":{"id":"id4d61f5a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State employs a public defender program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/A"},"text":"section 60301(e)(1)(A) of this title","children":[],"tail":", the salaries received by the attorneys employed by such program and the salaries received by attorneys in the prosecutor’s office in the jurisdiction;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f5a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State employs appointed attorneys under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/B"},"text":"section 60301(e)(1)(B) of this title","children":[],"tail":", the hourly fees received by such attorneys for actual time and service and the basis on which the hourly rate was calculated;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f5a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts paid to non-attorney members of the defense team, and the basis on which such amounts were determined; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f5a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/2/B/vi/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts for which attorney and non-attorney members of the defense team were reimbursed for reasonable incidental expenses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f5a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State that employs a statutory procedure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60301/e/1/C"},"text":"section 60301(e)(1)(C) of this title","children":[],"tail":", an assessment of the extent to which the State is in compliance with the requirements of the applicable State statute; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f5a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement confirming that the funds have not been used to fund representation in specific capital cases or to supplant non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f5a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital prosecution improvement grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the funds provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60302"},"text":"section 60302 of this title","children":[],"tail":", a report under subsection (a) shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f5aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting of all amounts expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f5ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the means by which the State has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f5ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed and established training programs for State and local prosecutors to ensure effective representation in State capital cases in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60302/b/1/A"},"text":"section 60302(b)(1)(A) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f5ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developed and implemented appropriate standards and qualifications for State and local prosecutors who litigate State capital cases in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60302/b/1/B"},"text":"section 60302(b)(1)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f5ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessed the performance of State and local prosecutors who litigate State capital cases in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60302/b/1/C"},"text":"section 60302(b)(1)(C) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f5af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified and implemented any potential legal reforms that may be appropriate to minimize the potential for error in the trial of capital cases in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60302/b/1/D"},"text":"section 60302(b)(1)(D) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f5b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established a program under which State and local prosecutors conduct a systematic review of cases in which a death sentence was imposed in order to identify cases in which post-conviction DNA testing may be appropriate in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60302/b/1/E"},"text":"section 60302(b)(1)(E) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f5b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided support and assistance to the families of murder victims; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f5b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement confirming that the funds have not been used to fund the prosecution of specific capital cases or to supplant non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f5b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure of annual State reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual reports to the Attorney General submitted by any State under this section shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f5b4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s424"},"text":"Pub. L. 108–405, title IV, § 424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2289"},"text":"118 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f5b5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f5b6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d61f5b7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14163c"},"text":"section 14163c of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
