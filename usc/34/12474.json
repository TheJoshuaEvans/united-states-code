{"tag":"section","attrib":{"id":"id4d0c0c89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474"},"text":null,"children":[{"tag":"num","attrib":{"value":"12474"},"text":"§ 12474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative grants to increase the long-term stability of victims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0c0c8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0c8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Administration for Children and Families, in partnership with the Secretary of Housing and Urban Development, shall award grants, contracts, or cooperative agreements for a period of not less than 2 years to eligible entities to develop long-term sustainability and self-sufficiency options for adult and youth victims of domestic violence, dating violence, sexual assault, and stalking who are currently homeless or at risk for becoming homeless.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall award funds in amounts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0c8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $25,000 per year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0c8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $1,000,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0c8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive funds under this section, an entity shall demonstrate that it is a coalition or partnership, applying jointly, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0c90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a domestic violence victim service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0c92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a homeless service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0c93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit, nongovernmental community housing development organization or a Department of Agriculture rural housing service program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0c94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of a homeless service provider on tribal lands or nonprofit, nongovernmental community housing development organization on tribal lands, a tribally designated housing entity or tribal housing consortium;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a dating violence, sexual assault, or stalking victim service provider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include housing developers, housing corporations, State housing finance agencies, other housing agencies, and associations representing landlords;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a public housing agency or tribally designated housing entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include tenant organizations in public or tribally designated housing, as well as nonprofit, nongovernmental tenant organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include other nonprofit, nongovernmental organizations participating in the Department of Housing and Urban Development’s Continuum of Care process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a State, tribal, territorial, or local government or government agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0c9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include any other agencies or nonprofit, nongovernmental organizations with the capacity to provide effective help to adult and youth victims of domestic violence, dating violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0c9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity seeking funds under this section shall submit an application to the Secretary of Health and Human Services at such time, in such manner, and containing such information as the Secretary of Health and Human Services may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0c9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded to eligible entities under subsection (a) shall be used to design or replicate and implement new activities, services, and programs to increase the stability and self-sufficiency of, and create partnerships to develop long-term housing options for adult and youth victims of domestic violence, dating violence, sexual assault, or stalking, and their dependents, who are currently homeless or at risk of becoming homeless. Such activities, services, or programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0c9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall develop sustainable long-term living solutions in the community by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0c9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating efforts and resources among the various groups and organizations comprised in the entity to access existing private and public funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0ca0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting with the placement of individuals and families in long-term housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0ca1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing services to help individuals or families find and maintain long-term housing, including financial assistance and support services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0ca2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may develop partnerships with individuals, organizations, corporations, or other entities that provide capital costs for the purchase, preconstruction, construction, renovation, repair, or conversion of affordable housing units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0ca3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use funds for the administrative expenses related to the continuing operation, upkeep, maintenance, and use of housing described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0ca4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide to the community information about housing and housing programs, and the process to locate and obtain long-term housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0ca5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a) shall not be used for construction, modernization or renovation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0ca6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations and priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary of Health and Human Services shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0ca7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to linguistically and culturally specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0ca8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to applications from entities that include a sexual assault service provider as described in subsection (b)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0ca9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award a minimum of 15 percent of the funds appropriated under this section in any fiscal year to tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0caa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0cab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affordable housing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “affordable housing” means housing that complies with the conditions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12745"},"text":"section 12745 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0cac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term housing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “long-term housing” means housing that is sustainable, accessible, affordable, and safe for the foreseeable future and is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0cad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rented or owned by the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0cae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsidized by a voucher or other program which is not time-limited and is available for as long as the individual meets the eligibility requirements for the voucher or program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0caf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided directly by a program, agency, or organization and is not time-limited and is available for as long as the individual meets the eligibility requirements for the program, agency, or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0cb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation, monitoring, administration, and technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0cb1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 5 percent of the funds appropriated under subsection (i) for each fiscal year may be used by the Secretary of Health and Human Services for evaluation, monitoring, and administration costs under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0cb2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up to 8 percent of the funds appropriated under subsection (i) for each fiscal year may be used to provide technical assistance to grantees under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0cb3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12474/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $4,000,000 for each of fiscal years 2023 through 2027 to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0c0cb4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41404"},"text":"Pub. L. 103–322, title IV, § 41404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tVI/s601"},"text":"Pub. L. 109–162, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3033"},"text":"119 Stat. 3033","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s5/a"},"text":"Pub. L. 109–271, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/759"},"text":"120 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tVI/s603/1"},"text":"Pub. L. 113–4, title VI, § 603(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/110"},"text":"127 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s605/b"},"text":"Pub. L. 117–103, div. W, title VI, § 605(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/886"},"text":"136 Stat. 886","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0c0cb5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0c0cb6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail