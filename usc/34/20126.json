{"tag":"section","attrib":{"id":"id4d2190a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126"},"text":null,"children":[{"tag":"num","attrib":{"value":"20126"},"text":"§ 20126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d2190a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall conduct annual consultations with Indian tribal governments concerning the Federal administration of tribal funds and programs established under this Act, the Violence Against Women Act of 1994 (title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":"), the Violence Against Women Act of 2000 (division B of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Public Law 106–386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/1491"},"text":"114 Stat. 1491","children":[],"tail":"), and the Violence Against Women Reauthorization Act of 2013."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2190a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During consultations under subsection (a), the Secretary of Health and Human Services, the Secretary of the Interior, and the Attorney General shall solicit recommendations from Indian tribes concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2190a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering tribal funds and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the safety of Indian women from domestic violence, dating violence, sexual assault, homicide, stalking, and sex trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the Federal response to such violent crimes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving access to local, regional, State, and Federal crime information databases and criminal justice information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2190ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall submit to Congress an annual report on the annual consultations required under subsection (a) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d2190ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the recommendations made under subsection (b) by Indian tribes during the year covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes actions taken during the year covered by the report to respond to recommendations made under subsection (b) during the year or a previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d2190ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how the Attorney General will work in coordination and collaboration with Indian tribes, the Secretary of Health and Human Services, and the Secretary of the Interior to address the recommendations made under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d2190af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20126/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days before the date of a consultation under subsection (a), the Attorney General shall notify tribal leaders of the date, time, and location of the consultation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d2190b0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIX/s903"},"text":"Pub. L. 109–162, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3078"},"text":"119 Stat. 3078","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tIX/s903"},"text":"Pub. L. 113–4, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/120"},"text":"127 Stat. 120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/165/s4/b/3"},"text":"Pub. L. 116–165, § 4(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-10"},"text":"Oct. 10, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/761"},"text":"134 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d2190b1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d2190b2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d2190b3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2960"},"text":"119 Stat. 2960","children":[],"tail":", known as the Violence Against Women and Department of Justice Reauthorization Act of 2005. For complete classification of this Act to the Code, see Short Title of 2006 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 1994, referred to in subsec. (a), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 2000, referred to in subsec. (a), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Pub. L. 106–386","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1491"},"text":"114 Stat. 1491","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2000 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Reauthorization Act of 2013, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/54"},"text":"127 Stat. 54","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2013 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d2190b4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14045d"},"text":"section 14045d of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d2190b5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s4/b/3/A"},"text":"Pub. L. 116–165, § 4(b)(3)(A)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “enhancing the safety of Indian women from domestic violence, dating violence, sexual assault, stalking, and sex trafficking; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/165/s4/b/3/B"},"text":"Pub. L. 116–165, § 4(b)(3)(B)","children":[],"tail":", (C), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s903/1"},"text":"Pub. L. 113–4, § 903(1)","children":[],"tail":", substituted “, the Violence Against Women Act of 2000” for “and the Violence Against Women Act of 2000” and inserted “, and the Violence Against Women Reauthorization Act of 2013” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s903/2/A"},"text":"Pub. L. 113–4, § 903(2)(A)","children":[],"tail":", substituted “Secretary of Health and Human Services, the Secretary of the Interior,” for “Secretary of the Department of Health and Human Services” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s903/2/B"},"text":"Pub. L. 113–4, § 903(2)(B)","children":[],"tail":", substituted “stalking, and sex trafficking” for “and stalking”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s903/3"},"text":"Pub. L. 113–4, § 903(3)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
