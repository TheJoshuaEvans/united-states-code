{"tag":"section","attrib":{"id":"id4cef83a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11278"},"text":null,"children":[{"tag":"num","attrib":{"value":"11278"},"text":"§ 11278.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cef83aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11278/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of performance standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-10-08"},"text":"October 8, 2008","children":[],"tail":", the Secretary shall issue rules that specify performance standards for public and nonprofit private entities and agencies that receive grants under sections 11211, 11221, and 11261 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cef83ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11278/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with representatives of public and nonprofit private entities and agencies that receive grants under this subchapter, including statewide and regional nonprofit organizations (including combinations of such organizations) that receive grants under this subchapter, and national nonprofit organizations concerned with youth homelessness, in developing the performance standards required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cef83ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11278/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of performance standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall integrate the performance standards into the processes of the Department of Health and Human Services for grantmaking, monitoring, and evaluation for programs under sections 11211, 11221, and 11261 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cef83ad-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s386A"},"text":"Pub. L. 93–415, title III, § 386A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/378/s8"},"text":"Pub. L. 110–378, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4071"},"text":"122 Stat. 4071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cef83ae-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cef83af-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cef83b0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5732–1"},"text":"section 5732–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
