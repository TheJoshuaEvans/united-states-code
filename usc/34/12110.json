{"tag":"section","attrib":{"id":"id4cf8f99b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12110"},"text":null,"children":[{"tag":"num","attrib":{"value":"12110"},"text":"§ 12110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to eligible States for incarceration of criminal aliens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf8f99c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make a payment to each State which is eligible under section 1252(j) ","children":[{"tag":"ref","attrib":{"idref":"fn002089"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002089"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 8 in such amount as is determined under section 1252(j) "},{"tag":"ref","attrib":{"idref":"fn002089"},"text":"1","children":[],"tail":" of title 8, and for which payment is not made to such State for such fiscal year under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f99d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, there are authorized to be appropriated to carry out this section from amounts authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12108"},"text":"section 12108 of this title","children":[],"tail":", an amount which when added to amounts appropriated to carry out section 1252(j) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 8 for fiscal year 1996 equals $500,000,000 and for each of the fiscal years 1997 through 2000 does not exceed $650,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f99e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amounts appropriated to carry out this section shall be reserved from the total amount appropriated for each fiscal year and shall be added to the other funds appropriated to carry out section 1252(j) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 8 and administered under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f99f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1999-05-15"},"text":"May 15, 1999","children":[],"tail":", the Attorney General shall submit a report to the Congress which contains the recommendation of the Attorney General concerning the extension of the program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf8f9a0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20110"},"text":"Pub. L. 103–322, title II, § 20110","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–21; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf8f9a1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf8f9a2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cf8f9a3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1252/j"},"text":"Section 1252(j) of title 8","children":[],"tail":", referred to in subsecs. (a) to (c), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1231/i"},"text":"section 1231(i) of title 8","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s306/a/1"},"text":"Pub. L. 104–208, div. C, title III, § 306(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-607"},"text":"110 Stat. 3009–607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf8f9a4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13710"},"text":"section 13710 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
