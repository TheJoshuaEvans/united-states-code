ed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20925"},"text":"section 20925 of this title","children":[],"tail":", referred to in subsec. (a)(2), became available on "},{"tag":"date","attrib":{"date":"2008-07-25"},"text":"July 25, 2008","children":[],"tail":". See Office of Justice Progs., U.S. Dep’t of Justice, Annual Report to Congress 26 (Fiscal Year 2008)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36ed94-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16924"},"text":"section 16924 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
