{"tag":"section","attrib":{"id":"id4d34a46b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20921"},"text":null,"children":[{"tag":"num","attrib":{"value":"20921"},"text":"§ 20921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Sex Offender Registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d34a46c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internet","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall maintain a national database at the Federal Bureau of Investigation for each sex offender and any other person required to register in a jurisdiction’s sex offender registry. The database shall be known as the National Sex Offender Registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a46d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic forwarding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure (through the National Sex Offender Registry or otherwise) that updated information about a sex offender is immediately transmitted by electronic forwarding to all relevant jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d34a46e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s119"},"text":"Pub. L. 109–248, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/596"},"text":"120 Stat. 596","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a46f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d34a470-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d34a471-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16919"},"text":"section 16919 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
