{"tag":"section","attrib":{"id":"id4cfb6aea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184"},"text":null,"children":[{"tag":"num","attrib":{"value":"12184"},"text":"§ 12184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of lines of credit and use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfb6aeb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide a community development corporation that has an application approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12183"},"text":"section 12183 of this title","children":[],"tail":" with a line of credit in an amount determined appropriate by the Secretary, subject to the limitations contained in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6aec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on availability of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6aed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide in excess of $2,000,000 in lines of credit under this subpart to a single applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A line of credit provided under this subpart shall remain available over a period of time established by the Secretary, but in no event shall any such period of time be in excess of 3 years from the date on which such line of credit is made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6aef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), if a recipient of a line of credit under this subpart has made full and productive use of such line of credit, can demonstrate the need and demand for additional assistance, and can meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12182/b/2"},"text":"section 12182(b)(2) of this title","children":[],"tail":", the amount of such line of credit may be increased by not more than $1,500,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6af0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts drawn from line of credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts drawn from each line of credit under this subpart shall be used solely for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12181"},"text":"section 12181 of this title","children":[],"tail":" and shall only be drawn down as needed to provide loans, investments, or to defray administrative costs related to the establishment of a revolving loan fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6af1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12184/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of revolving loan funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Revolving loan funds established with lines of credit provided under this subpart may be used to provide technical assistance to private business enterprises and to provide financial assistance in the form of loans, loan guarantees, interest reduction assistance, equity shares, and other such forms of assistance to business enterprises in target areas and who are in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12183/a/4"},"text":"section 12183(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfb6af2-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31114"},"text":"Pub. L. 103–322, title III, § 31114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1884"},"text":"108 Stat. 1884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfb6af3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfb6af4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfb6af5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13824"},"text":"section 13824 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
