{"tag":"section","attrib":{"id":"id4ccba8bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10498"},"text":null,"children":[{"tag":"num","attrib":{"value":"10498"},"text":"§ 10498.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba8bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10498/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “family-friendly policy” means a policy to promote or improve the morale and well being of law enforcement personnel and their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba8bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10498/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “law enforcement personnel” means individuals employed by Federal, State, and local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba8be-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2308"},"text":"Pub. L. 90–351, title I, § 2308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXI/s210201/a/3"},"text":"Pub. L. 103–322, title XXI, § 210201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2064"},"text":"108 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba8bf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba8c0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba8c1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796jj–7"},"text":"section 3796jj–7 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
