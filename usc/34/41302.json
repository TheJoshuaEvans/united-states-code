{"tag":"section","attrib":{"id":"id4d58587e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302"},"text":null,"children":[{"tag":"num","attrib":{"value":"41302"},"text":"§ 41302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of statistical data on child abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d58587f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data acquisition for 1987 and 1988","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall acquire from criminal justice agencies statistical data, for the calendar years 1987 and 1988, about the incidence of child abuse, including child sexual abuse, and shall publish annually a summary of such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d585880-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of uniform crime reporting program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d585881-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable, but in no case later than ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", the Attorney General shall modify the uniform crime reporting program in the Federal Bureau of Investigation to include data on the age of the victim of the offense and the relationship, if any, of the victim to the offender, for types of offenses that may involve child abuse, including child sexual abuse."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585882-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The modification, once made, shall remain in effect until the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d585883-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 years after the date it is made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d585884-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such ending date as may be set by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d585885-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/401/tI/s105"},"text":"Pub. L. 99–401, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/906"},"text":"100 Stat. 906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d585886-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d585887-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d585888-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5101"},"text":"section 5101 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
