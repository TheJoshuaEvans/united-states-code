{"tag":"section","attrib":{"id":"id4ced12dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11231"},"text":null,"children":[{"tag":"num","attrib":{"value":"11231"},"text":"§ 11231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants for a national communication system to assist runaway and homeless youth in communicating with their families and with service providers. The Secretary shall give priority to grant applicants that have experience in providing telephone services to runaway and homeless youth.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ced12dd-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tIII/s331"},"text":"Pub. L. 93–415, title III, § 331","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s3/g/1/C"},"text":"Pub. L. 102–586, § 3(g)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5022"},"text":"106 Stat. 5022","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/71/s3/r/1"},"text":"Pub. L. 106–71, § 3(r)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-12"},"text":"Oct. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1043"},"text":"113 Stat. 1043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ced12de-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ced12df-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ced12e0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5714–11"},"text":"section 5714–11 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ced12e1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/71"},"text":"Pub. L. 106–71","children":[],"tail":" substituted “The Secretary” for “With funds reserved under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5751/a/3"},"text":"section 5751(a)(3) of this title","children":[],"tail":", the Secretary” in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
