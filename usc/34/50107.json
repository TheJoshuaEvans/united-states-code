{"tag":"section","attrib":{"id":"id4d5d1306-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50107"},"text":null,"children":[{"tag":"num","attrib":{"value":"50107"},"text":"§ 50107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d1307-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of conditions; amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If Federal law enforcement assistance provided under this chapter is used by the recipient of such assistance in violation of section 50104 ","children":[{"tag":"ref","attrib":{"idref":"fn002225"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002225"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title or for any purpose other than the purpose for which it is provided, then such recipient shall promptly repay to the Attorney General an amount equal to the value of such assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1308-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may bring a civil action in an appropriate United States district court to recover any amount required to be repaid under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d1309-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609S"},"text":"Pub. L. 98–473, title II, § 609S","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2106"},"text":"98 Stat. 2106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d130a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d130b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d5d130c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50104"},"text":"Section 50104 of this title","children":[],"tail":", referred to in subsec. (a), was in the original a reference to “section 554”, and was translated as if it had been a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s609P"},"text":"section 609P of Pub. L. 98–473","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s50104"},"text":"section 50104 of this title","children":[],"tail":" to reflect the probable intent of Congress as manifested in earlier versions of Emergency Federal Law Enforcement Assistance provisions introduced in the Congress. "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" does not contain a section 554."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d130d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10507"},"text":"section 10507 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
