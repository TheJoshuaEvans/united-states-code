{"tag":"section","attrib":{"id":"id4d36ee66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944"},"text":null,"children":[{"tag":"num","attrib":{"value":"20944"},"text":"§ 20944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of training and technology efforts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36ee67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand training efforts with Federal, State, and local law enforcement officers and prosecutors to effectively respond to the threat to children and the public posed by sex offenders who use the Internet and technology to solicit or otherwise exploit children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate meetings involving corporations that sell computer hardware and software or provide services to the general public related to use of the Internet, to identify problems associated with the use of technology for the purpose of exploiting children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" host national conferences to train Federal, State, and local law enforcement officers, probation and parole officers, and prosecutors regarding pro-active approaches to monitoring sex offender activity on the Internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and distribute, for personnel listed in paragraph (3), information regarding multidisciplinary approaches to holding offenders accountable to the terms of their probation, parole, and sex offender registration laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with other agencies to improve the coordination of joint investigations among agencies to effectively combat online solicitation of children by sex offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploy, to all Internet Crimes Against Children Task Forces and their partner agencies, technology modeled after the Canadian Child Exploitation Tracking System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct training in the use of that technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2007-07-01"},"text":"July 1, 2007","children":[],"tail":", the Attorney General,"},{"tag":"ref","attrib":{"idref":"fn002190"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002190"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" shall submit to Congress a report on the activities carried out under this section. The report shall include any recommendations that the Attorney General considers appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Attorney General, for fiscal year 2007—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 to carry out subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20944/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36ee74-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s145"},"text":"Pub. L. 109–248, title I, § 145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/606"},"text":"120 Stat. 606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36ee75-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36ee76-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36ee77-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16944"},"text":"section 16944 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
