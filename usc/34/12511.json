{"tag":"section","attrib":{"id":"id4d0e7dcc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511"},"text":null,"children":[{"tag":"num","attrib":{"value":"12511"},"text":"§ 12511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault services program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0e7dcd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7dce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist States, Indian tribes, and territories in providing intervention, advocacy, accompaniment, support services, and related assistance for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7dcf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adult, youth, and child victims of sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family and household members of such victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those collaterally affected by the victimization, except for the perpetrator of such victimization; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7dd2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide for technical assistance and training relating to sexual assault to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, tribal, territorial and local governments, law enforcement agencies, and courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professionals working in legal, social service, and health care settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" faith-based organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dd7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other individuals and organizations seeking such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7dd8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States and territories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7dd9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants to States and territories to support the establishment, maintenance, and expansion of rape crisis centers and other nongovernmental or tribal programs and projects to assist individuals who have been victimized by sexual assault, without regard to the age of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7dda-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7ddb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the grant funds received by a State or territory governmental agency under this subsection for any fiscal year may be used for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7ddc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received by a State or territory under this subsection that are not used for administrative costs shall be used to provide grants to rape crisis centers and other nonprofit, nongovernmental organizations or tribal programs and activities for programs and activities within such State or territory that provide direct intervention and related assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7ddd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intervention and related assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Intervention and related assistance under subparagraph (B) may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d0e7dde-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 24-hour hotline services providing crisis intervention services and referral;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7ddf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accompaniment and advocacy through medical, criminal justice, and social support systems, including medical facilities, police, and court proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7de0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crisis intervention, short-term individual and group support services, direct payments, and comprehensive service coordination and supervision to assist sexual assault victims and family or household members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7de1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and referral to assist the sexual assault victim and family or household members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7de2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based, culturally specific services and support mechanisms, including outreach activities for underserved communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7de3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and distribution of materials on issues related to the services described in clauses (i) through (v).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7de4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7de5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity desiring a grant under this subsection shall submit an application to the Attorney General at such time and in such manner as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7de6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d0e7de7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth procedures designed to ensure meaningful involvement of the State or territorial sexual assault coalition and representatives from underserved communities in the development of the application and the implementation of the plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7de8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth procedures designed to ensure an equitable distribution of grants and grant funds within the State or territory and between urban and rural areas within such State or territory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7de9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the State or territorial agency that is responsible for the administration of programs and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0e7dea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet other such requirements as the Attorney General reasonably determines are necessary to carry out the purposes and provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7deb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall allocate to each State (including the District of Columbia and Puerto Rico) not less than 1.50 percent of the total amount appropriated in a fiscal year for grants under this section, except that the United States Virgin Islands, American Samoa, Guam, and the Commonwealth of the Northern Mariana Islands shall each be allocated 0.5 percent of the total appropriations. The remaining funds shall be allotted to each State and each territory in an amount that bears the same ratio to such remaining funds as the population of such State and such territory bears to the population of all the States and the territories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7dec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for culturally specific programs addressing sexual assault","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7ded-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants to eligible entities to support the establishment, maintenance, and expansion of culturally specific intervention and related assistance for victims of sexual assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7dee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7def-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a private nonprofit organization that focuses primarily on culturally specific communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7df0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have documented organizational experience in the area of sexual assault intervention or have entered into a partnership with an organization having such expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7df1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have expertise in the development of community-based, linguistically and culturally specific outreach and intervention services relevant for the specific communities to whom assistance would be provided or have the capacity to link to existing services in the community tailored to the needs of culturally specific populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7df2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an advisory board or steering committee and staffing which is reflective of the targeted culturally specific community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7df3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants under this section on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7df4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall not use more than 2.5 percent of funds appropriated under this subsection in any year for administration, monitoring, and evaluation of grants made available under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7df5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make grants under this section for a period of no less than 2 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7df6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide technical assistance to recipients of grants under this subsection by entering into a cooperative agreement or contract with a national, nonprofit, nongovernmental organization or organizations whose primary focus and expertise is in addressing sexual assault within culturally specific communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7df7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity receiving a grant under this subsection shall submit a report to the Attorney General that describes the activities carried out with such grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7df8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to State, territorial, and tribal sexual assault coalitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7df9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7dfa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants to State, territorial, and tribal sexual assault coalitions to assist in supporting the establishment, maintenance, and expansion of such coalitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dfb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 10 percent of the total amount appropriated to carry out this section shall be used for grants under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dfc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each of the State, territorial, and tribal sexual assault coalitions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7dfd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant funds received under this subsection may be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7dfe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with local sexual assault programs and other providers of direct services to encourage appropriate responses to sexual assault within the State, territory, or tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7dff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with judicial and law enforcement agencies to encourage appropriate responses to sexual assault cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e00-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with courts, child protective services agencies, and children’s advocates to develop appropriate responses to child custody and visitation issues when sexual assault has been determined to be a factor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e01-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design and conduct public education campaigns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e02-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan and monitor the distribution of grants and grant funds to their State, territory, or tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e03-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with and inform Federal, State, or local public officials and agencies to develop and implement policies to reduce or eliminate sexual assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e04-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts appropriated for grants under this subsection for each fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e05-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 percent of the funds shall be available for grants to tribal sexual assault coalitions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e06-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining funds shall be available for grants to State and territorial coalitions, and the Attorney General shall allocate an amount equal to ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"56","children":[],"tail":" of the amounts so appropriated to each of those State and territorial coalitions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e07-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity desiring a grant under this subsection shall submit an application to the Attorney General at such time, in such manner, and containing such information as the Attorney General determines to be essential to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e08-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First-time applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No entity shall be prohibited from submitting an application under this subsection during any fiscal year for which funds are available under this subsection because such entity has not previously applied or received funding under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7e09-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to tribes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7e0a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award grants to Indian tribes, tribal organizations, and nonprofit tribal organizations for the operation of sexual assault programs or projects in Indian tribal lands and Alaska Native villages to support the establishment, maintenance, and expansion of programs and projects to assist those victimized by sexual assault.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e0b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the grant funds received by an Indian tribe, tribal organization, and nonprofit tribal organization under this subsection for any fiscal year may be used for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds received under this subsection that are not used for administrative costs shall be used to provide grants to tribal organizations and nonprofit tribal organizations for programs and activities within Indian country and Alaskan native villages that provide direct intervention and related assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0e7e0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0e7e0f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $100,000,000 to remain available until expended for each of fiscal years 2023 through 2027 to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0e7e10-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amounts appropriated for each fiscal year to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0e7e11-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 2.5 percent shall be used by the Attorney General for evaluation, monitoring, and other administrative costs under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e12-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 8 percent shall be used for the provision of technical assistance to grantees and subgrantees under this section of which not less than 20 percent shall be available for technical assistance to recipients and potential recipients of grants under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e13-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 65 percent shall be used for grants to States and territories under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e14-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 percent shall be used for making grants to State, territorial, and tribal sexual assault coalitions under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e15-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 percent shall be used for grants to tribes under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0e7e16-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12511/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 percent shall be used for grants for culturally specific programs addressing sexual assault under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0e7e17-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41601"},"text":"Pub. L. 103–322, title IV, § 41601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s3/b"},"text":"Pub. L. 109–271, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/754"},"text":"120 Stat. 754","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tII/s201"},"text":"Pub. L. 113–4, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/80"},"text":"127 Stat. 80","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tII/s201"},"text":"Pub. L. 117–103, div. W, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/856"},"text":"136 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0e7e18-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0e7e19-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0e7e1a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043g"},"text":"section 14043g of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d0e7e1b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(C)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s201/1/A"},"text":"Pub. L. 117–103, § 201(1)(A)","children":[],"tail":", inserted “direct payments,” before “and comprehensive”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s201/1/B"},"text":"Pub. L. 117–103, § 201(1)(B)","children":[],"tail":", substituted “0.5 percent” for “0.25 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s201/2/A"},"text":"Pub. L. 117–103, § 201(2)(A)","children":[],"tail":", struck out subpar. (A) designation before “The Attorney General” and struck out subpar. (B) which read as follows: “Up to 5 percent of funds appropriated under this subsection in any year shall be available for technical assistance by a national, nonprofit, nongovernmental organization or organizations whose primary focus and expertise is in addressing sexual assault within underserved culturally specific populations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s201/2/B"},"text":"Pub. L. 117–103, § 201(2)(B)","children":[],"tail":", (C), added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s201/3/A"},"text":"Pub. L. 117–103, § 201(3)(A)","children":[],"tail":", substituted “$100,000,000 to remain available until expended for each of fiscal years 2023 through 2027” for “$40,000,000 to remain available until expended for each of fiscal years 2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s201/3/B"},"text":"Pub. L. 117–103, § 201(3)(B)","children":[],"tail":", substituted “8 percent” for “2.5 percent” and “of which not less than 20 percent shall be available for technical assistance to recipients and potential recipients of grants under subsection (c);” for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s201/a/1"},"text":"Pub. L. 113–4, § 201(a)(1)","children":[],"tail":", substituted “other nongovernmental or tribal programs and projects to assist individuals who have been victimized by sexual assault, without regard to the age of the individual.” for “other programs and projects to assist those victimized by sexual assault.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s201/a/2/A"},"text":"Pub. L. 113–4, § 201(a)(2)(A)","children":[],"tail":", inserted “or tribal programs and activities” after “nongovernmental organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s201/a/2/B"},"text":"Pub. L. 113–4, § 201(a)(2)(B)","children":[],"tail":", struck out “linguistically and” before “culturally”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s201/a/3/B"},"text":"Pub. L. 113–4, § 201(a)(3)(B)","children":[],"tail":", which directed striking out “the District of Columbia, Puerto Rico,” after “Guam”, was executed by striking out such phrase after “Guam,” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s201/a/3/A"},"text":"Pub. L. 113–4, § 201(a)(3)(A)","children":[],"tail":", (C), (D), inserted “(including the District of Columbia and Puerto Rico)” after “The Attorney General shall allocate to each State”, substituted “0.25 percent” for “0.125 percent”, and struck out at end “The District of Columbia shall be treated as a territory for purposes of calculating its allocation under the preceding formula.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4/s201/b"},"text":"Pub. L. 113–4, § 201(b)","children":[],"tail":", substituted “$40,000,000 to remain available until expended for each of fiscal years 2014 through 2018” for “$50,000,000 to remain available until expended for each of the fiscal years 2007 through 2011”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d0e7e1c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d0e7e1d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"sec