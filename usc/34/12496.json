{"tag":"section","attrib":{"id":"id4d0e7da5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12496"},"text":null,"children":[{"tag":"num","attrib":{"value":"12496"},"text":"§ 12496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of Housing and Urban Development such sums as may be necessary for fiscal years 2023 through 2027 to be used for training and technical assistance to support the implementation of this subpart, including technical assistance agreements with entities whose primary purpose and expertise is assisting survivors of sexual assault and domestic violence or providing culturally specific services to victims of domestic violence, dating violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d0e7da6-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41416"},"text":"Pub. L. 103–322, title IV, § 41416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s605/d"},"text":"Pub. L. 117–103, div. W, title VI, § 605(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/887"},"text":"136 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0e7da7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0e7da8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0e7da9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s605/d"},"text":"Pub. L. 117–103, div. W, title VI, § 605(d)","children":[],"tail":", which directed the addition of this section to chapter 2 of subtitle N of title IV of the Violence Against Women Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491"},"text":"34 U.S.C. 12491","children":[],"tail":" et seq.), was executed by adding this section to chapter 2 of subtitle N of title IV of the Violent Crime Control and Law Enforcement Act of 1994 to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d0e7daa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4d0e7dab-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
