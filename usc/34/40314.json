{"tag":"section","attrib":{"id":"id4d4c70b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314"},"text":null,"children":[{"tag":"num","attrib":{"value":"40314"},"text":"§ 40314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4c70ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy Act of 1974","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in the Compact shall affect the obligations and responsibilities of the FBI under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly known as the “Privacy Act of 1974”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4c70bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to certain records not affected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in the Compact shall interfere in any manner with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c70bc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" access, direct or otherwise, to records pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4c70bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9101"},"text":"section 9101 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Child Protection Act ","children":[{"tag":"ref","attrib":{"idref":"fn002213"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002213"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40101"},"text":"34 U.S.C. 40101","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Brady Handgun Violence Prevention Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/159"},"text":"Public Law 103–159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/107/1536"},"text":"107 Stat. 1536","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Violent Crime Control and Law Enforcement Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/108/2074"},"text":"108 Stat. 2074","children":[],"tail":") or any amendment made by that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Housing Act of 1937 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"42 U.S.C. 1437","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Native American Housing Assistance and Self-Determination Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"25 U.S.C. 4101","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any direct access to Federal criminal history records authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4c70c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of FBI under Departments of State, Justice, and Commerce, the Judiciary, and Related Agencies Appropriation Act, 1973","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in the Compact shall be construed to affect the authority of the FBI under the Departments of State, Justice, and Commerce, the Judiciary, and Related Agencies Appropriation Act, 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/544"},"text":"Public Law 92–544","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/86/1115"},"text":"86 Stat. 1115","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4c70c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall not be considered to be a Federal advisory committee for purposes of chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4c70c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members of Council not Federal officers or employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Council (other than a member from the FBI or any at-large member who may be a Federal official or employee) shall not, by virtue of such membership, be deemed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c70c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be, for any purpose other than to effect the Compact, officers or employees of the United States (as defined in sections 2104 and 2105 of title 5); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40314/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to become entitled by reason of Council membership to any compensation or benefit payable or made available by the Federal Government to its officers or employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4c70c9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/251/tII/s215"},"text":"Pub. L. 105–251, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-09"},"text":"Oct. 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1875"},"text":"112 Stat. 1875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/213"},"text":"Pub. L. 117–286, § 4(a)(213)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4329"},"text":"136 Stat. 4329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4c70ca-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4c70cb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d4c70cc-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Privacy Act of 1974, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/579"},"text":"Pub. L. 93–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1896"},"text":"88 Stat. 1896","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Child Protection Act, referred to in subsec. (b)(1)(B), probably means the National Child Protection Act of 1993, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/209"},"text":"Pub. L. 103–209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2490"},"text":"107 Stat. 2490","children":[],"tail":", which is classified principally to chapter 401 (§ 40101 et seq.) of this title. For complete classification of this Act to the Code, see Short Title of 1993 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Brady Handgun Violence Prevention Act, referred to in subsec. (b)(1)(C), is title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/159"},"text":"Pub. L. 103–159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1536"},"text":"107 Stat. 1536","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s925A"},"text":"section 925A of Title 18","children":[],"tail":", Crimes and Criminal Procedure, amended sections 921, 922, and 924 of Title 18 and former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3759"},"text":"section 3759 of Title 42","children":[],"tail":", The Public Health and Welfare, and enacted provisions set out as notes under sections 921 and 922 of Title 18. For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of Title 18","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violent Crime Control and Law Enforcement Act of 1994, referred to in subsec. (b)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1796"},"text":"108 Stat. 1796","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States Housing Act of 1937, referred to in subsec. (b)(1)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"act Sept. 1, 1937, ch. 896","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tII/s201/a"},"text":"Pub. L. 93–383, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/653"},"text":"88 Stat. 653","children":[],"tail":", which is classified generally to chapter 8 (§ 1437 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437"},"text":"section 1437 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Native American Housing Assistance and Self-Determination Act of 1996, referred to in subsec. (b)(1)(F), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4016"},"text":"110 Stat. 4016","children":[],"tail":", which is classified principally to chapter 43 (§ 4101 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Departments of State, Justice, and Commerce, the Judiciary, and Related Agencies Appropriation Act, 1973, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/544"},"text":"Pub. L. 92–544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1109"},"text":"86 Stat. 1109","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4c70cd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14614"},"text":"section 14614 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d4c70ce-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5.” for “the Federal Advisory Committee Act (5 U.S.C. App.).” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
