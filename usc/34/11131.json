 of local government” for “units of general local government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s2/f/1/A"},"text":"Pub. L. 102–586, § 2(f)(1)(A)","children":[],"tail":", which directed the substitution of “experience” for “existence”, could not be executed because “existence” did not appear in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/586/s2/f/1/B"},"text":"Pub. L. 102–586, § 2(f)(1)(B)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5671"},"text":"section 5671 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted “and contracts” after “grants” in section catchline, designated existing provisions as subsec. (a), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" amended section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/115"},"text":"Pub. L. 95–115","children":[],"tail":" inserted “grants and” before “contracts” and substituted “units of general local government or combinations thereof” for “local governments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ce12c0e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"i