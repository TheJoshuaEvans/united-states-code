{"tag":"section","attrib":{"id":"id4c972b46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10107"},"text":null,"children":[{"tag":"num","attrib":{"value":"10107"},"text":"§ 10107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division of Applied Law Enforcement Technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c972b47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of Science and Technology, the Division of Applied Law Enforcement Technology, headed by an individual appointed by the Attorney General. The purpose of the Division shall be to provide leadership and focus to those grants of the Department of Justice that are made for the purpose of using or improving law enforcement computer systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c999b48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the purpose of the Division, the head of the Division shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c999b49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish clear minimum standards for computer systems that can be purchased using amounts awarded under such grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c999b4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that recipients of such grants use such systems to participate in crime reporting programs administered by the Department, such as Uniform Crime Reports or the National Incident-Based Reporting System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c999b4b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s107"},"text":"Pub. L. 90–351, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1160/a"},"text":"Pub. L. 109–162, title XI, § 1160(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3117"},"text":"119 Stat. 3117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c999b4c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c999b4d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c999b4e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712f"},"text":"section 3712f of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4c999b4f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4c999b50-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1160/b"},"text":"Pub. L. 109–162, title XI, § 1160(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3117"},"text":"119 Stat. 3117","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/n/4/A"},"text":"Pub. L. 109–271, § 8(n)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/768"},"text":"120 Stat. 768","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/271/s8/n/4/A"},"text":"“This section [enacting this section] and the amendment made by this section take effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
