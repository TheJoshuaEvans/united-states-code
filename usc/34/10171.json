{"tag":"section","attrib":{"id":"id4ca31270-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171"},"text":null,"children":[{"tag":"num","attrib":{"value":"10171"},"text":"§ 10171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correctional options grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ca31271-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director, in consultation with the Director of the National Institute of Corrections, may make—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca31272-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 grants in each fiscal year, in various geographical areas throughout the United States, to public agencies for correctional options (including the cost of construction) that provide alternatives to traditional modes of incarceration and offender release programs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca31273-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide more appropriate intervention for youthful offenders who are not career criminals, but who, without such intervention, are likely to become career criminals or more serious offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca31274-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a degree of security and discipline appropriate for the offender involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca31275-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide diagnosis, and treatment and services (including counseling, substance abuse treatment, education, job training and placement assistance while under correctional supervision, and linkage to similar outside services), to increase the success rate of offenders who decide to pursue a course of lawful and productive conduct after release from legal restraint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca31276-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce criminal recidivism by offenders who receive punishment through such alternatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca31277-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the cost of correctional services and facilities by reducing criminal recidivism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca31278-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide work that promotes development of industrial and service skills in connection with a correctional option;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca31279-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" grants to private nonprofit organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ca3127a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any of the purposes specified in subparagraphs (A) through (F) of paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca3127b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undertake educational and training programs for criminal justice personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca3127c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to States and local units of government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ca3127d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out demonstration projects which, in view of previous research or experience, are likely to be a success in more than one jurisdiction;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in connection with a correctional option (excluding the cost of construction);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca3127e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants to public agencies to establish, operate, and support boot camp prisons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca3127f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants to State courts to improve security for State and local court systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca31280-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of grantees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The selection of applicants to receive grants under paragraphs (1) and (2) of subsection (a) shall be based on their potential for developing or testing various innovative alternatives to traditional modes of incarceration and offender release programs. In selecting the applicants to receive grants under subsection (a)(3), the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ca31281-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the overall quality of an applicant’s shock incarceration program, including the existence of substance abuse treatment, drug testing, counseling literacy education, vocational education, and job training programs during incarceration or after release; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ca31282-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to public agencies that clearly demonstrate that the capacity of their correctional facilities is inadequate to accommodate the number of individuals who are convicted of offenses punishable by a term of imprisonment exceeding 1 year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Priority shall be given to State court applicants under subsection (a)(4) that have the greatest demonstrated need to provide security in order to administer justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ca31283-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall consult with the Commission on Alternative Utilization of Military Facilities created by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Public Law 100–456","children":[],"tail":" in order to identify military facilities that may be used as sites for correctional programs receiving assistance under this subpart."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ca31284-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s515"},"text":"Pub. L. 90–351, title I, § 515","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXVIII/s1801/a/7"},"text":"Pub. L. 101–647, title XVIII, § 1801(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4847"},"text":"104 Stat. 4847","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXIII/s330001/b/1"},"text":"Pub. L. 103–322, title XXXIII, § 330001(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2138"},"text":"108 Stat. 2138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/177/tIII/s302/a"},"text":"Pub. L. 110–177, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2539"},"text":"121 Stat. 2539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ca31285-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ca31286-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ca31287-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commission on Alternative Utilization of Military Facilities, referred to in subsec. (c), was created by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456/s2819"},"text":"section 2819 of Pub. L. 100–456","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2391"},"text":"section 2391 of Title 10","children":[],"tail":", Armed Forces, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1031/b"},"text":"Pub. L. 105–261, div. A, title X, § 1031(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2123"},"text":"112 Stat. 2123","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ca31288-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3762a"},"text":"section 3762a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ca31289-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s515"},"text":"section 515 of Pub. L. 90–351","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/207"},"text":"82 Stat. 207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/644/tI/s7/4"},"text":"Pub. L. 91–644, title I, § 7(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-02"},"text":"Jan. 2, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1887"},"text":"84 Stat. 1887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/83/s2"},"text":"Pub. L. 93–83, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-06"},"text":"Aug. 6, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/213"},"text":"87 Stat. 213","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/503/tI/s124"},"text":"Pub. L. 94–503, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-15"},"text":"Oct. 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2421"},"text":"90 Stat. 2421","children":[],"tail":", provided for functions, powers, and duties of Law Enforcement Assistance Administration, prior to the general amendment of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/96/157"},"text":"Pub. L. 96–157","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ca3128a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s302/a/1"},"text":"Pub. L. 110–177, § 302(a)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/s302/a/2"},"text":"Pub. L. 110–177, § 302(a)(2)","children":[],"tail":", inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", in introductory provisions substituted “paragraphs (1) and (2) of subsection (a)” for “subsection (a)(1) and (2)”, and in par. (2) substituted “public agencies” for “States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ca3128b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id4ca3128c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2000-08-01"},"text":"Aug. 1, 2000","children":[],"tail":", all functions of Director of Bureau of Justice Assistance, other than those enumerated in section 10142(3) to (6) of this title, transferred to Assistant Attorney General for Office of Justice Programs, see section 1000(a)(1) [title I, § 108(b)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10141"},"text":"section 10141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
