{"tag":"section","attrib":{"id":"id4cbb0635-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364"},"text":null,"children":[{"tag":"num","attrib":{"value":"10364"},"text":"§ 10364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbb0636-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbb0637-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To request funds under this subchapter from a State, the chief executive of a local entity shall submit an application to the office designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10362/b"},"text":"section 10362(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0638-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An application under paragraph (1) shall be considered approved, in whole or in part, by the State not later than 45 days after such application is first received unless the State informs the applicant in writing of specific reasons for disapproval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0639-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State shall not disapprove any application submitted to the State without first affording the applicant reasonable notice and an opportunity for reconsideration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb063a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an application under paragraph (1) is approved, the local entity is eligible to receive funds under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbb063b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10364/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution to local entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10361"},"text":"section 10361 of this title","children":[],"tail":" in a fiscal year shall make such funds available to a local entity with an approved application within 45 days after the Bureau has approved the application submitted by the State and has made funds available to the State. The Director may waive the 45-day requirement in this section upon a finding that the State is unable to satisfy the requirement of the preceding sentence under State statutes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbb063c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1604"},"text":"Pub. L. 90–351, title I, § 1604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/521/s4/a/3"},"text":"Pub. L. 102–521, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3405"},"text":"106 Stat. 3405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbb063d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbb063e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbb063f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796cc–3"},"text":"section 3796cc–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
