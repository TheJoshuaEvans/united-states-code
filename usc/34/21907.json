{"tag":"section","attrib":{"id":"id4d408a68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s21907"},"text":null,"children":[{"tag":"num","attrib":{"value":"21907"},"text":"§ 21907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Attorney General $3,000,000 to carry out the Ashanti Alert communications network as authorized under this chapter for each of fiscal years 2019 through 2022.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d408a69-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/468/tII/s207"},"text":"Pub. L. 106–468, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/401/s2/5"},"text":"Pub. L. 115–401, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-31"},"text":"Dec. 31, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5341"},"text":"132 Stat. 5341","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
