{"tag":"section","attrib":{"id":"id4d61f54a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301"},"text":null,"children":[{"tag":"num","attrib":{"value":"60301"},"text":"§ 60301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital representation improvement grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d61f54b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants to States for the purpose of improving the quality of legal representation provided to indigent defendants in State capital cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f54c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “legal representation” means legal counsel and investigative, expert, and other services necessary for competent representation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f54d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f54e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be used to establish, implement, or improve an effective system for providing competent legal representation to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f54f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indigents charged with an offense subject to capital punishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f550-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indigents who have been sentenced to death and who seek appellate or collateral relief in State court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f551-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indigents who have been sentenced to death and who seek review in the Supreme Court of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f552-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be used to fund, directly or indirectly, representation in specific capital cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f553-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f554-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds awarded under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f555-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 75 percent shall be used to carry out the purpose described in subsection (c)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f556-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 25 percent shall be used to carry out the purpose described in subsection (c)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f557-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may waive the requirement under this subsection for good cause shown.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f558-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in subsection (c)(1), an effective system for providing competent legal representation is a system that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f559-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" invests the responsibility for appointing qualified attorneys to represent indigents in capital cases—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f55a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a public defender program that relies on staff attorneys, members of the private bar, or both, to provide representation in capital cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f55b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an entity established by statute or by the highest State court with jurisdiction in criminal cases, which is composed of individuals with demonstrated knowledge and expertise in capital cases, except for individuals currently employed as prosecutors; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f55c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to a statutory procedure enacted before ","children":[{"tag":"date","attrib":{"date":"2004-10-30"},"text":"October 30, 2004","children":[],"tail":", under which the trial judge is required to appoint qualified attorneys from a roster maintained by a State or regional selection committee or similar entity; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f55d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" requires the program described in paragraph (1)(A), the entity described in paragraph (1)(B), or an appropriate entity designated pursuant to the statutory procedure described in paragraph (1)(C), as applicable, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f55e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish qualifications for attorneys who may be appointed to represent indigents in capital cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f55f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a roster of qualified attorneys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f560-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in the case of a selection committee or similar entity described in paragraph (1)(C), assign 2 attorneys from the roster to represent an indigent in a capital case, or provide the trial judge a list of not more than 2 pairs of attorneys from the roster, from which 1 pair shall be assigned, provided that, in any case in which the State elects not to seek the death penalty, a court may find, subject to any requirement of State law, that a second attorney need not remain assigned to represent the indigent to ensure competent representation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f561-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, sponsor, or approve specialized training programs for attorneys representing defendants in capital cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f562-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d61f563-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the performance of attorneys who are appointed and their attendance at training programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f564-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remove from the roster attorneys who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d61f565-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to deliver effective representation or engage in unethical conduct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f566-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with such requirements as such program, entity, or selection committee or similar entity may establish regarding participation in training programs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f567-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/E/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the past 5 years, have been sanctioned by a bar association or court for ethical misconduct relating to the attorney’s conduct as defense counsel in a criminal case in Federal or State court; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f568-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure funding for the cost of competent legal representation by the defense team and outside experts selected by counsel, who shall be compensated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d61f569-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State that employs a statutory procedure described in paragraph (1)(C), in accordance with the requirements of that statutory procedure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d61f56a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in all other cases, as follows:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d61f56b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attorneys employed by a public defender program shall be compensated according to a salary scale that is commensurate with the salary scale of the prosecutor’s office in the jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f56c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointed attorneys shall be compensated for actual time and service, computed on an hourly basis and at a reasonable hourly rate in light of the qualifications and experience of the attorney and the local market for legal representation in cases reflecting the complexity and responsibility of capital cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f56d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-attorney members of the defense team, including investigators, mitigation specialists, and experts, shall be compensated at a rate that reflects the specialized skills needed by those who assist counsel with the litigation of death penalty cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d61f56e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60301/e/2/F/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attorney and non-attorney members of the defense team shall be reimbursed for reasonable incidental expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f56f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s421"},"text":"Pub. L. 108–405, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2286"},"text":"118 Stat. 2286","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f570-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f571-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d61f572-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14163"},"text":"section 14163 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
