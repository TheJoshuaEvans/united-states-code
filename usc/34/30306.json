text":"Pub. L. 110–199","children":[],"tail":" substituted “5 years” for “3 years” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" made amendment identical to that made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/108"},"text":"Pub. L. 109–108","children":[],"tail":". See 2005 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/108"},"text":"Pub. L. 109–108","children":[],"tail":" substituted “3 years” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “Elimination” for “Reduction” in section catchline and in text of subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d454594-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d454595-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" and requirements for grants made under such amendments, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60504"},"text":"section 60504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
