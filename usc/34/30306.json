{"tag":"section","attrib":{"id":"id4d454532-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306"},"text":null,"children":[{"tag":"num","attrib":{"value":"30306"},"text":"§ 30306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Prison Rape Elimination Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d454533-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a commission to be known as the National Prison Rape Elimination Commission (in this section referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454534-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454535-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall be composed of 9 members, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d454536-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 shall be appointed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454537-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed by the Speaker of the House of Representatives, unless the Speaker is of the same party as the President, in which case 1 shall be appointed by the Speaker of the House of Representatives and 1 shall be appointed by the minority leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454538-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the minority leader of the House of Representatives (in addition to any appointment made under subparagraph (B));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454539-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed by the majority leader of the Senate, unless the majority leader is of the same party as the President, in which case 1 shall be appointed by the majority leader of the Senate and 1 shall be appointed by the minority leader of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45453a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed by the minority leader of the Senate (in addition to any appointment made under subparagraph (D)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45453b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Commission shall be an individual who has knowledge or expertise in matters to be studied by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45453c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, the Speaker and minority leader of the House of Representatives, and the majority leader and minority leader of the Senate shall consult with one another prior to the appointment of the members of the Commission to achieve, to the maximum extent possible, fair and equitable representation of various points of view with respect to the matters to be studied by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45453d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member shall be appointed for the life of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45453e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for initial appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointment of the members shall be made not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2003-09-04"},"text":"September 4, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45453f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Commission shall be filled in the manner in which the original appointment was made, and shall be made not later than 60 days after the date on which the vacancy occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454540-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454541-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 15 days after appointments of all the members are made, the President shall appoint a chairperson for the Commission from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454542-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall meet at the call of the chairperson. The initial meeting of the Commission shall take place not later than 30 days after the initial appointment of the members is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454543-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Commission shall constitute a quorum to conduct business, but the Commission may establish a lesser quorum for conducting hearings scheduled by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454544-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may establish by majority vote any other rules for the conduct of Commission business, if such rules are not inconsistent with this chapter or other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454545-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive study of the impacts of prison rape","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454546-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall carry out a comprehensive legal and factual study of the penalogical, physical, mental, medical, social, and economic impacts of prison rape in the United States on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d454547-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454548-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communities and social institutions generally, including individuals, families, and businesses within such communities and social institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454549-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d45454a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of existing Federal, State, and local government policies and practices with respect to the prevention, detection, and punishment of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45454b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the relationship between prison rape and prison conditions, and of existing monitoring, regulatory, and enforcement practices that are intended to address any such relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45454c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of pathological or social causes of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45454d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent to which the incidence of prison rape contributes to the spread of sexually transmitted diseases and to the transmission of HIV;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45454e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the characteristics of inmates most likely to commit prison rape and the effectiveness of various types of treatment or programs to reduce such likelihood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45454f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the characteristics of inmates most likely to be victims of prison rape and the effectiveness of various types of treatment or programs to reduce such likelihood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454550-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impacts of prison rape on individuals, families, social institutions and the economy generally, including an assessment of the extent to which the incidence of prison rape contributes to recidivism and to increased incidence of sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454551-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination of the feasibility and cost of conducting surveillance, undercover activities, or both, to reduce the incidence of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454552-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the safety and security of prison facilities and the relationship of prison facility construction and design to the incidence of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454553-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the feasibility and cost of any particular proposals for prison reform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454554-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the need for additional scientific and social science research on the prevalence of prison rape in Federal, State, and local prisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454555-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the general relationship between prison rape and prison violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454556-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the relationship between prison rape and levels of training, supervision, and discipline of prison staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454557-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of existing Federal and State systems for reporting incidents of prison rape, including an assessment of whether existing systems provide an adequate assurance of confidentiality, impartiality and the absence of reprisal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454558-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d454559-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the date of the initial meeting of the Commission, the Commission shall submit a report on the study carried out under this subsection to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d45455a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d45455b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d45455c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d45455d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d45455e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Federal Bureau of Prisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d45455f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief executive of each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d454560-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the department of corrections of each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454561-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d454562-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings and conclusions of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d454563-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended national standards for reducing prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d454564-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended protocols for preserving evidence and treating victims of prison rape; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d454565-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/d/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the materials relied on by the Commission in the preparation of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454566-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454567-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conjunction with the report submitted under subsection (d)(3), the Commission shall provide the Attorney General and the Secretary of Health and Human Services with recommended national standards for enhancing the detection, prevention, reduction, and punishment of prison rape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454568-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters included","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information provided under paragraph (1) shall include recommended national standards relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d454569-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the classification and assignment of prisoners, using proven standardized instruments and protocols, in a manner that limits the occurrence of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45456a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation and resolution of rape complaints by responsible prison authorities, local and State police, and Federal and State prosecution authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45456b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of physical and testimonial evidence for use in an investigation of the circumstances relating to the rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45456c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" acute-term trauma care for rape victims, including standards relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d45456d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner and extent of physical examination and treatment to be provided to any rape victim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d45456e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner and extent of any psychological examination, psychiatric care, medication, and mental health counseling to be provided to any rape victim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45456f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referrals for long-term continuity of care for rape victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454570-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational and medical testing measures for reducing the incidence of HIV transmission due to prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454571-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post-rape prophylactic medical measures for reducing the incidence of transmission of sexual diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454572-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of correctional staff sufficient to ensure that they understand and appreciate the significance of prison rape and the necessity of its eradication;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454573-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely and comprehensive investigation of staff sexual misconduct involving rape or other sexual assault on inmates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454574-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the confidentiality of prison rape complaints and protecting inmates who make complaints of prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454575-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a system for reporting incidents of prison rape that will ensure the confidentiality of prison rape complaints, protect inmates who make prison rape complaints from retaliation, and assure the impartial resolution of prison rape complaints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d454576-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" data collection and reporting of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d454577-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/L/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prison rape;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d454578-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/L/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prison staff sexual misconduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d454579-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/L/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resolution of prison rape complaints by prison officials and Federal, State, and local investigation and prosecution authorities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d45457a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as may reasonably be related to the detection, prevention, reduction, and punishment of prison rape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45457b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall not propose a recommended standard that would impose substantial additional costs compared to the costs presently expended by Federal, State, and local prison authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d45457c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with accreditation organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing recommended national standards for enhancing the detection, prevention, reduction, and punishment of prison rape, the Commission shall consider any standards that have already been developed, or are being developed simultaneously to the deliberations of the Commission. The Commission shall consult with accreditation organizations responsible for the accreditation of Federal, State, local or private prisons, that have developed or are currently developing standards related to prison rape. The Commission will also consult with national associations representing the corrections profession that have developed or are currently developing standards related to prison rape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d45457d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d45457e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall hold public hearings. The Commission may hold such hearings, sit and act at such times and places, take such testimony, and receive such evidence as the Commission considers advisable to carry out its duties under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45457f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Witnesses requested to appear before the Commission shall be paid the same fees as are paid to witnesses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1821"},"text":"section 1821 of title 28","children":[],"tail":". The per diem and mileage allowances for witnesses shall be paid from funds appropriated to the Commission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454580-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal or State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may secure directly from any Federal department or agency such information as the Commission considers necessary to carry out its duties under this section. The Commission may request the head of any State or local department or agency to furnish such information to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454581-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel matters","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454582-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Commission shall be allowed travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 while away from their homes or regular places of business in the performance of service for the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454583-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the affirmative vote of ⅔ of the Commission, any Federal Government employee, with the approval of the head of the appropriate Federal agency, may be detailed to the Commission without reimbursement, and such detail shall be without interruption or loss of civil service status, benefits, or privileges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454584-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of temporary and intermittent services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Commission, the Attorney General shall provide reasonable and appropriate office space, supplies, and administrative assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454585-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts for research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454586-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Institute of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With a ⅔ affirmative vote, the Commission may select nongovernmental researchers and experts to assist the Commission in carrying out its duties under this chapter. The National Institute of Justice shall contract with the researchers and experts selected by the Commission to provide funding in exchange for their services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d454587-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to limit the ability of the Commission to enter into contracts with other entities or organizations for research necessary to carry out the duties of the Commission under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d454588-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d454589-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may issue subpoenas for the attendance of witnesses and the production of written or other matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45458a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of contumacy or refusal to obey a subpoena, the Attorney General may in a Federal court of appropriate jurisdiction obtain an appropriate order to enforce the subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d45458b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of documentary evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Documents provided to the Commission pursuant to a subpoena issued under this subsection shall not be released publicly without the affirmative vote of ⅔ of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d45458c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d45458d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall terminate on the date that is 60 days after the date on which the Commission submits the reports required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d45458e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s30306/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall be exempt from chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d45458f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/79/s7"},"text":"Pub. L. 108–79, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-04"},"text":"Sept. 4, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/980"},"text":"117 Stat. 980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dB/tI/s123/1"},"text":"Pub. L. 108–447, div. B, title I, § 123(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2871"},"text":"118 Stat. 2871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/108/tI/s113/b"},"text":"Pub. L. 109–108, title I, § 113(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-22"},"text":"Nov. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2305"},"text":"119 Stat. 2305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1181"},"text":"Pub. L. 109–162, title XI, § 1181","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3126"},"text":"119 Stat. 3126","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s261"},"text":"Pub. L. 110–199, title II, § 261","children":[],"tail":", "},{"tag":"date","attr