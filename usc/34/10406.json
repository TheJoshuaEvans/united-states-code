{"tag":"section","attrib":{"id":"id4cbfc1ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406"},"text":null,"children":[{"tag":"num","attrib":{"value":"10406"},"text":"§ 10406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbfc1af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall pay to each State or specifically ","children":[{"tag":"ref","attrib":{"idref":"fn002028"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002028"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “specially”."}],"tail":" qualified unit of local government that receives funds under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10404"},"text":"section 10404 of this title","children":[],"tail":" that has submitted an application under this subchapter the amount awarded to such State or unit of local government not later than the later of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 180 days after the date that the amount is available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day of the payment period if the State has provided the Attorney General with the assurances required by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc1b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of unexpended amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts awarded under this subchapter, a State or specially qualified unit shall repay to the Attorney General, before the expiration of the 36-month period beginning on the date of the award, any amount that is not expended by such State or unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may adopt policies and procedures providing for a one-time extension, by not more than 12 months, of the period referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1b5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failure to repay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the amount required to be repaid is not repaid, the Attorney General shall reduce payment in future payment periods accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1b6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of amounts repaid","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received by the Attorney General as repayments under this subsection shall be deposited in a designated fund for future payments to States and specially qualified units.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc1b7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or unit of local government that receives funds under this subchapter may use not more than 5 percent of such funds to pay for administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc1b8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsupplanting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this subchapter to States and units of local government shall not be used to supplant State or local funds as the case may be, but shall be used to increase the amount of funds that would, in the absence of funds made available under this subchapter, be made available from State or local sources, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc1b9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc1ba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of a grant received under this subchapter may not exceed 90 percent of the total program costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc1bb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10406/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), with respect to the cost of constructing juvenile detention or correctional facilities, the Federal share of a grant received under this subchapter may not exceed 50 percent of approved cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc1bc-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1805"},"text":"Pub. L. 90–351, title I, § 1805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1865"},"text":"116 Stat. 1865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc1bd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc1be-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc1bf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–5"},"text":"section 3796ee–5 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbfc1c0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1805"},"text":"section 1805 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20201/a/3"},"text":"Pub. L. 103–322, title II, § 20201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1821"},"text":"108 Stat. 1821","children":[],"tail":", and classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–4"},"text":"section 3796ee–4 of Title 42","children":[],"tail":", The Public Health and Welfare, related to allocation and distribution of funds, prior to the general amendment of part R of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
