{"tag":"section","attrib":{"id":"id4d61f573-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302"},"text":null,"children":[{"tag":"num","attrib":{"value":"60302"},"text":"§ 60302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital prosecution improvement grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d61f574-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall award grants to States for the purpose of enhancing the ability of prosecutors to effectively represent the public in State capital cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d61f575-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f576-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under subsection (a) shall be used for one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d61f577-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To design and implement training programs for State and local prosecutors to ensure effective representation in State capital cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f578-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop and implement appropriate standards and qualifications for State and local prosecutors who litigate State capital cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f579-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assess the performance of State and local prosecutors who litigate State capital cases, provided that such assessment shall not include participation by the assessor in the trial of any specific capital case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f57a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify and implement any potential legal reforms that may be appropriate to minimize the potential for error in the trial of capital cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f57b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish a program under which State and local prosecutors conduct a systematic review of cases in which a death sentence was imposed in order to identify cases in which post-conviction DNA testing may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d61f57c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide support and assistance to the families of murder victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f57d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under subsection (a) shall not be used to fund, directly or indirectly, the prosecution of specific capital cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f57e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIV/s422"},"text":"Pub. L. 108–405, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2288"},"text":"118 Stat. 2288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f57f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f580-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d61f581-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14163a"},"text":"section 14163a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
