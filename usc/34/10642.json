{"tag":"section","attrib":{"id":"id4cd2d4d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10642"},"text":null,"children":[{"tag":"num","attrib":{"value":"10642"},"text":"§ 10642.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd2d4d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10642/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A capacity building grant shall be used to develop a statewide strategic plan as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10643"},"text":"section 10643 of this title","children":[],"tail":" to prevent and reduce crime, violence, and substance abuse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10642/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rural State may also use its grant to provide training and technical assistance to communities and promote innovation in the development of policies, technologies, and programs to prevent and reduce crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd2d4d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10642/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rural State may use up to 5 percent of the grant to assist grant recipients in collecting statewide data related to the costs of crime, violence, and substance abuse for purposes of supporting the statewide strategic plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd2d4d5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2986"},"text":"Pub. L. 90–351, title I, § 2986","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11027/b"},"text":"Pub. L. 107–273, div. C, title I, § 11027(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1834"},"text":"116 Stat. 1834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd2d4d6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd2d4d7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd2d4d8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797y–1"},"text":"section 3797y–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
