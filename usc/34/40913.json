{"tag":"section","attrib":{"id":"id4d560da1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913"},"text":null,"children":[{"tag":"num","attrib":{"value":"40913"},"text":"§ 40913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation assistance to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d560da2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d560da3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this section and subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40912/b/1/B"},"text":"section 40912(b)(1)(B) of this title","children":[],"tail":", the Attorney General shall make grants to States and Indian tribal governments, in a manner consistent with the National Criminal History Improvement Program, which shall be used by the States and Indian tribal governments, in conjunction with units of local government and State and local courts, to establish or upgrade information and identification technologies for firearms eligibility determinations. Not less than 3 percent, and no more than 10 percent of each grant under this paragraph shall be used to maintain the relief from disabilities program in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40915"},"text":"section 40915 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560da4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Up to 5 percent of the grant funding available under this section may be reserved for Indian tribal governments, including tribal judicial systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560da5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded to States or Indian tribes under this section may only be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d560da6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create electronic systems, which provide accurate and up-to-date information which is directly related to checks under the National Instant Criminal Background Check System (referred to in this section as “NICS”), including court disposition and corrections records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560da7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist States in establishing or enhancing their own capacities to perform NICS background checks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560da8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply accurate and timely information to the Attorney General concerning final dispositions of criminal records to databases accessed by NICS, including through increased efforts to pre-validate the contents of those records to expedite eligibility determinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560da9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply accurate and timely information to the Attorney General concerning the identity of persons who are prohibited from obtaining a firearm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922/g/4"},"text":"section 922(g)(4) of title 18","children":[],"tail":" to be used by the Federal Bureau of Investigation solely to conduct NICS background checks;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560daa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply accurate and timely court orders and records of misdemeanor crimes of domestic violence for inclusion in Federal and State law enforcement databases used to conduct NICS background checks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560dab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and analyze data needed to demonstrate levels of State compliance with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560dac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the relief from disabilities program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40915"},"text":"section 40915 of this title","children":[],"tail":", but not less than 3 percent, and no more than 10 percent of each grant shall be used for this purpose."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560dad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for a grant under this section, a State shall certify, to the satisfaction of the Attorney General, that the State has implemented a relief from disabilities program in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40915"},"text":"section 40915 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560dae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a grant under this section, a State shall specify the projects for which grant amounts will be used, and shall use such amounts only as specified. A State that violates this subsection shall be liable to the Attorney General for the full amount of the grant received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560daf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d560db0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $125,000,000 for fiscal year 2009, $250,000,000 for fiscal year 2010, $250,000,000 for fiscal year 2011, $125,000,000 for fiscal year 2012, $125,000,000 for fiscal year 2013, and $125,000,000 for each of fiscal years 2018 through 2022.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560db1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic Abuse and Violence Prevention Initiative","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d560db2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2018 through 2022, the Attorney General shall create a priority area under the NICS Act Record Improvement Program (commonly known as “NARIP”) for a Domestic Abuse and Violence Prevention Initiative that emphasizes the need for grantees to identify and upload all felony conviction records and domestic violence records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d560db3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d560db4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use not more than 50 percent of the amounts made available under this subsection for each of fiscal years 2018 through 2022 to carry out the initiative described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d560db5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall give a funding preference under NARIP to States that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d560db6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have established an implementation plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40917"},"text":"section 40917 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d560db7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will use amounts made available under this subparagraph to improve efforts to identify and upload all felony conviction records and domestic violence records described in clauses (i), (v), and (vi) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40912/b/1/C"},"text":"section 40912(b)(1)(C) of this title","children":[],"tail":" by not later than "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560db8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Bureau of Investigation shall not charge a user fee for background checks pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922/t"},"text":"section 922(t) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560db9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall direct the Office of Justice Programs, the Bureau of Alcohol, Tobacco, Firearms, and Explosives, and the Federal Bureau of Investigation to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d560dba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist States that are not currently eligible for grants under this section to achieve compliance with all eligibility requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d560dbb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40913/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and training services to grantees under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d560dbc-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/180/tI/s103"},"text":"Pub. L. 110–180, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-08"},"text":"Jan. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2567"},"text":"121 Stat. 2567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tVI/s603/b"},"text":"Pub. L. 115–141, div. S, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1135"},"text":"132 Stat. 1135","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d560dbd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d560dbe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d560dbf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d560dc0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s603/b/1"},"text":"Pub. L. 115–141, § 603(b)(1)","children":[],"tail":", inserted before semicolon at end “, including through increased efforts to pre-validate the contents of those records to expedite eligibility determinations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s603/b/2/A"},"text":"Pub. L. 115–141, § 603(b)(2)(A)","children":[],"tail":", struck out “and” after “2012,” and inserted before period at end “, and $125,000,000 for each of fiscal years 2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s603/b/2/B"},"text":"Pub. L. 115–141, § 603(b)(2)(B)","children":[],"tail":", added par. (2) and struck out former par. (2) which related to allocations for fiscal years 2009 to 2013."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/s603/b/3"},"text":"Pub. L. 115–141, § 603(b)(3)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
