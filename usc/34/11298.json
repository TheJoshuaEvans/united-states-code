{"tag":"section","attrib":{"id":"id4cf43eec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298"},"text":null,"children":[{"tag":"num","attrib":{"value":"11298"},"text":"§ 11298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Inspectors General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf43eed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Inspector General appointed under section 403 or 415 of title 5 may authorize staff to assist the National Center for Missing and Exploited Children—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf43eee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by conducting reviews of inactive case files to develop recommendations for further investigations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf43eef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by engaging in similar activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf43ef0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf43ef1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Inspector General may not permit staff to engage in activities described in subsection (a) if such activities will interfere with the duties of the Inspector General under chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf43ef2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11298/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No additional funds are authorized to be appropriated to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf43ef3-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVII/s3703"},"text":"Pub. L. 101–647, title XXXVII, § 3703","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/344/s9"},"text":"Pub. L. 110–344, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-07"},"text":"Oct. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3936"},"text":"122 Stat. 3936","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/59"},"text":"Pub. L. 117–286, § 4(b)(59)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4349"},"text":"136 Stat. 4349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf43ef4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf43ef5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf43ef6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5780a"},"text":"section 5780a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Crime Control Act of 1990, and not as part of the Missing Children’s Assistance Act which comprises this subchapter, nor as part of the Juvenile Justice and Delinquency Prevention Act of 1974 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cf43ef7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/59/A"},"text":"Pub. L. 117–286, § 4(b)(59)(A)","children":[],"tail":", substituted “section 403 or 415 of title 5” for “section 3 or 8G of the Inspector General Act of 1978 (5 U.S.C. App.)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/59/B"},"text":"Pub. L. 117–286, § 4(b)(59)(B)","children":[],"tail":", substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
