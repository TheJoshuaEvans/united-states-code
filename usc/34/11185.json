{"tag":"section","attrib":{"id":"id4ceaa1e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11185"},"text":null,"children":[{"tag":"num","attrib":{"value":"11185"},"text":"§ 11185.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ceaa1e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11185/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this subchapter, pursuant to a grant or contract, may be made (after necessary adjustment, in the case of grants, on account of previously made overpayments or underpayments) in advance or by way of reimbursement, in such installments and on such conditions as the Administrator may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ceaa1e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11185/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Percentage of approved costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11132/c"},"text":"section 11132(c) of this title","children":[],"tail":", financial assistance extended under this subchapter shall be 100 per centum of the approved costs of the program or activity involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ceaa1e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11185/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase of grants to Indian tribes; waiver of liability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ceaa1e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11185/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a grant under this subchapter to an Indian tribe, if the Administrator determines that the tribe does not have sufficient funds available to meet the local share of the cost of any program or activity to be funded under the grant, the Administrator may increase the Federal share of the cost thereof to the extent the Administrator deems necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ceaa1e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11185/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a State does not have an adequate forum to enforce grant provisions imposing any liability on Indian tribes, the Administrator may waive State liability attributable to the liability of such tribes and may pursue such legal remedies as are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ceaa1e9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tII/s299D"},"text":"Pub. L. 93–415, title II, § 299D","children":[],"tail":", formerly § 295, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7266/4"},"text":"Pub. L. 100–690, title VII, § 7266(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4450"},"text":"102 Stat. 4450","children":[],"tail":"; renumbered § 299D, "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s2/i/1/B"},"text":"Pub. L. 102–586, § 2(i)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5006"},"text":"106 Stat. 5006","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12221/a/3"},"text":"Pub. L. 107–273, div. C, title II, § 12221(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1894"},"text":"116 Stat. 1894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ceaa1ea-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ceaa1eb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ceaa1ec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5675"},"text":"section 5675 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ceaa1ed-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" struck out subsec. (d) which read as follows: “If the Administrator determines, on the basis of information available to the Administrator during any fiscal year, that a portion of the funds granted to an applicant under part C of this subchapter for such fiscal year will not be required by the applicant or will become available by virtue of the application of the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s3783"},"text":"section 3783 of this title","children":[],"tail":", as amended from time to time, that portion shall be available for reallocation in an equitable manner to States which comply with the requirements in paragraphs (12)(A) and (13) of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5633/a"},"text":"section 5633(a) of this title","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s5665/b/6"},"text":"section 5665(b)(6) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ceaa1ee-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ceaa1ef-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" effective on the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", and applicable only with respect to fiscal years beginning on or after the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s12223"},"text":"section 12223 of Pub. L. 107–273","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4ceaa1f0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7296/a"},"text":"section 7296(a) of Pub. L. 100–690","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
