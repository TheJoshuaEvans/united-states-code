{"tag":"section","attrib":{"id":"id4d5858f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309"},"text":null,"children":[{"tag":"num","attrib":{"value":"41309"},"text":"§ 41309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on human trafficking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5858f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking offense classification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Federal Bureau of Investigation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5858f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classify the offense of human trafficking as a Part I crime in the Uniform Crime Reports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent feasible, establish subcategories for State sex crimes that involve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5858f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who is younger than 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of force, fraud or coercion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither of the elements described in subparagraphs (A) and (B); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classify the offense of human trafficking as a Group A offense for purpose of the National Incident-Based Reporting System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5858f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Federal Bureau of Investigation shall revise the Uniform Crime Reporting System ","children":[{"tag":"ref","attrib":{"idref":"fn002221"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002221"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Program”."}],"tail":" and the National Incident-Based Reporting System to distinguish between reports of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5858fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" incidents of assisting or promoting prostitution, which shall include crimes committed by persons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5858fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not directly engage in commercial sex acts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5858fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct, manage, or profit from such acts, such as State pimping and pandering crimes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of purchasing prostitution, which shall include crimes committed by persons who purchase or attempt to purchase or trade anything of value for commercial sex acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of prostitution, which shall include crimes committed by persons providing or attempting to provide commercial sex acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5858ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of assisting or promoting prostitution, child labor that is a violation of law, or forced labor of an individual under the age of 18 as described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d585900-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41309/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidents of purchasing or soliciting commercial sex acts, child labor that is a violation of law, or forced labor with an individual under the age of 18 as described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d585901-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s237/a"},"text":"Pub. L. 110–457, title II, § 237(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5083"},"text":"122 Stat. 5083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/392/s17"},"text":"Pub. L. 115–392, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5257"},"text":"132 Stat. 5257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d585902-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d585903-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d585904-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsecs. (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/s237"},"text":"section 237 of Pub. L. 110–457","children":[],"tail":". Subsec. (c) of section 237 is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d585905-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/392"},"text":"Pub. L. 115–392","children":[],"tail":" added pars. (4) and (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d585906-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d585907-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cumulative Biennial Report on Data Collection and Statistics","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/tIV/s405"},"text":"Pub. L. 117–347, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6209"},"text":"136 Stat. 6209","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/347/tIV/s405"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 280 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":"], and every 2 years thereafter, the Attorney General and the Secretary of Health and Human Services shall each submit to the Committee on the Judiciary and the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on the Judiciary and the Committee on Energy and Commerce of the House of Representatives the status of the required data collection and reporting requirements of the Attorney General and the Secretary, respectively, related to trafficking, which shall include the status of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the study required under section 201(a)(1)(B)(ii) of the Trafficking Victims Protection Reauthorization Act of 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20701/a/1/B/ii"},"text":"34 U.S.C. 20701(a)(1)(B)(ii)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State reports required under section 237(b) of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s41309/b"},"text":"34 U.S.C. 41309(b)","children":[],"tail":") to be included in the Uniform Crime Reporting Program and the National Incident-Based Reporting System;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report required under section 237(c)(1)(A) of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Public Law 110–457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/5084"},"text":"122 Stat. 5084","children":[],"tail":" [5083]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report required under section 237(c)(1)(B) of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Public Law 110–457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/5084"},"text":"122 Stat. 5084","children":[],"tail":" [5083]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report required under section 237(c)(1)(C) of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Public Law 110–457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/5084"},"text":"122 Stat. 5084","children":[],"tail":" [5083]); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive study required under section 237(c)(2) of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Public Law 110–457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/122/5085"},"text":"122 Stat. 5085","children":[],"tail":" [5084]).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
