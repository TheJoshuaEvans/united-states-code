{"tag":"section","attrib":{"id":"id4ccba882-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493"},"text":null,"children":[{"tag":"num","attrib":{"value":"10493"},"text":"§ 10493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ccba883-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or local law enforcement agency or organization that receives a grant under this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn002047"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002047"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall use amounts provided under the grant to establish or improve training and support programs for law enforcement personnel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba884-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A law enforcement agency or organization that receives funds under this subchapter shall provide at least one of the following services:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba885-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling for law enforcement officers and family members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba886-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Child care on a 24-hour basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba887-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marital and adolescent support groups.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba888-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evidence-based programs to reduce stress, prevent suicide, and promote mental health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba889-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stress education for law enforcement recruits and families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba88a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical assistance and training programs to support any or all of the services described in paragraphs (1), (2), (3), (4), and (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ccba88b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A law enforcement agency or organization that receives funds under this subchapter may provide the following services:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba88c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Post-shooting debriefing for officers and their spouses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba88d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Group therapy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba88e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hypertension clinics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba88f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical incident response on a 24-hour basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba890-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Law enforcement family crisis, mental health crisis, and suicide prevention telephone services on a 24-hour basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba891-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling for law enforcement personnel exposed to infectious disease.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba892-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling for peers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba893-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Counseling for families of personnel killed, injured, or permanently disabled in the line of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba894-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seminars regarding alcohol, drug use, gambling, and overeating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba895-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10493/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specialized training for identifying, reporting, and responding to officer mental health crises and suicide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"i