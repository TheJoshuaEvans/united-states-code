{"tag":"section","attrib":{"id":"id4d560ddb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40916"},"text":null,"children":[{"tag":"num","attrib":{"value":"40916"},"text":"§ 40916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Illegal immigrant gun purchase notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d560ddc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law or of this chapter, all records obtained by the National Instant Criminal Background Check system relevant to whether an individual is prohibited from possessing a firearm because such person is an alien illegally or unlawfully in the United States shall be made available to U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d560ddd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, at his or her discretion, shall promulgate guidelines relevant to what records relevant to illegal aliens shall be provided pursuant to the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d560dde-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/180/tI/s106"},"text":"Pub. L. 110–180, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-08"},"text":"Jan. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2570"},"text":"121 Stat. 2570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d560ddf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d560de0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d560de1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s922"},"text":"section 922 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
