{"tag":"section","attrib":{"id":"id4cbb061c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362"},"text":null,"children":[{"tag":"num","attrib":{"value":"10362"},"text":"§ 10362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbb061d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbb061e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To request a grant under this subchapter, the chief executive of a State shall submit an application to the Director in such form and containing such information as the Director may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb061f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An application under paragraph (1) shall include assurances that Federal funds received under this subchapter shall be used to supplement, not supplant, non-Federal funds that would otherwise be available for activities funded under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbb0620-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State office","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The office responsible for the trust fund required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10158"},"text":"section 10158 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbb0621-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare the application required under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbb0622-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall administer grant funds received under this subchapter, including, review of spending, processing, progress, financial reporting, technical assistance, grant adjustments, accounting, auditing, and fund disbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbb0623-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1602"},"text":"Pub. L. 90–351, title I, § 1602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/521/s4/a/3"},"text":"Pub. L. 102–521, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-25"},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3404"},"text":"106 Stat. 3404","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1111/c/2/H"},"text":"Pub. L. 109–162, title XI, § 1111(c)(2)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3102"},"text":"119 Stat. 3102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type"