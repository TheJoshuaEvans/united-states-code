{"tag":"section","attrib":{"id":"id4ca7f3bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10229"},"text":null,"children":[{"tag":"num","attrib":{"value":"10229"},"text":"§ 10229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to President and Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than April 1 of each year, the Assistant Attorney General, the Director of the Bureau of Justice Assistance, the Director of the Bureau of Justice Statistics, and the Director of the National Institute of Justice shall each submit a report to the President and to the Speaker of the House of Representatives and the President of the Senate, on their activities under this chapter during the fiscal year next preceding such date.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4ca7f3c0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s810"},"text":"Pub. L. 90–351, title I, § 810","children":[],"tail":", formerly § 816, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1209"},"text":"93 Stat. 1209","children":[],"tail":"; renumbered § 810 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609B/f"},"text":"Pub. L. 98–473, title II, § 609B(f)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2093"},"text":"98 Stat. 2093","children":[],"tail":", 2095.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ca7f3c1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ca7f3c2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ca7f3c3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3789e"},"text":"section 3789e of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4ca7f3c4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s810"},"text":"section 810 of Pub. L. 90–351","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3788"},"text":"section 3788 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s609B/e"},"text":"section 609B(e) of Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ca7f3c5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s609B/i"},"text":"Pub. L. 98–473, § 609B(i)","children":[],"tail":", substituted requirement of individual reports by certain officials of listed agencies to the President and the Speaker of the House and President of the Senate for former subsec. (a) through (e) provisions which included requirement of an annual report on or before March 31 of each year to the President and Committees on the Judiciary of the Senate and the House, including description of scope of coverage; report covering receipt and compilation of evaluations, statistics, and performance reports, comprehensive statistics, analyses, and findings respecting attainment of described objectives; plan for collection, analysis, and evaluation of data for measurement of progress in prescribed and additional areas, definition of “comprehensive statistics” and “reasonably expected contribution”; attainment of reasonably expected contribution in prescribed and added areas; and data collection, including minimum duplication."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4caa3db6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4caa3db7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s609B/i"},"text":"section 609B(i) of Pub. L. 98–473","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s609AA/a"},"text":"section 609AA(a) of Pub. L. 98–473","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id4caa3db8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2000-08-01"},"text":"Aug. 1, 2000","children":[],"tail":", all functions of Director of Bureau of Justice Assistance, other than those enumerated in section 10142(3) to (6) of this title, transferred to Assistant Attorney General for Office of Justice Programs, see section 1000(a)(1) [title I, § 108(b)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10141"},"text":"section 10141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
