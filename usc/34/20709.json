{"tag":"section","attrib":{"id":"id4d3232d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709"},"text":null,"children":[{"tag":"num","attrib":{"value":"20709"},"text":"§ 20709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Combat Human Trafficking Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d3232d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Combat Human Trafficking Act of 2015”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial sex act; severe forms of trafficking in persons; state; task force","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “commercial sex act”, “severe forms of trafficking in persons”, “State”, and “Task Force” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered offender","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered offender” means an individual who obtains, patronizes, or solicits a commercial sex act involving a person subject to severe forms of trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered offense” means the provision, obtaining, patronizing, or soliciting of a commercial sex act involving a person subject to severe forms of trafficking in persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal law enforcement officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal law enforcement officer” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s115"},"text":"section 115 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local law enforcement officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “local law enforcement officer” means any officer, agent, or employee of a unit of local government authorized by law or by a local government agency to engage in or supervise the prevention, detection, investigation, or prosecution of any violation of criminal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law enforcement officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State law enforcement officer” means any officer, agent, or employee of a State authorized by law or by a State government agency to engage in or supervise the prevention, detection, investigation, or prosecution of any violation of criminal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Justice training and policy for law enforcement officers, prosecutors, and judges","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3232e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement officers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall ensure that each anti-human trafficking program operated by the Department of Justice, including each anti-human trafficking training program for Federal, State, or local law enforcement officers, includes technical training on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d3232e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective methods for investigating and prosecuting covered offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d3232e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the provision of physical and mental health services by health care providers to persons subject to severe forms of trafficking in persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d3232e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individually screening all adults and children who are suspected of engaging in commercial sex acts or who are subject to labor exploitation that may be in violation of child labor laws to determine whether each individual screened is a victim of human trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d3232e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" how—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d3232e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victims of sex or labor trafficking often engage in criminal acts as a direct result of severe trafficking in persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d3232e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such individuals are victims of a crime and affirmative measures should be taken to avoid arresting, charging, or prosecuting such individuals for any offense that is the direct result of their victimization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232e8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal prosecutors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure that each anti-human trafficking program operated by the Department of Justice for United States attorneys or other Federal prosecutors includes training on seeking restitution for offenses under chapter 77 of title 18 to ensure that each United States attorney or other Federal prosecutor, upon obtaining a conviction for such an offense, requests a specific amount of restitution for each victim of the offense without regard to whether the victim requests restitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232e9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Judicial Center shall provide training to judges relating to the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1593"},"text":"section 1593 of title 18","children":[],"tail":" with respect to ordering restitution for victims of offenses under chapter 77 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232ea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy for Federal law enforcement officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall ensure that Federal law enforcement officers are engaged in activities, programs, or operations involving the detection, investigation, and prosecution of covered offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232eb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232ec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Justice Statistics report on State enforcement of human trafficking prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Justice Statistics shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232ed-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare an annual report on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3232ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d3232ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrests of individuals by State law enforcement officers for a covered offense, noting the number of covered offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d3232f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecutions (including specific charges) of individuals in State court systems for a covered offense, noting the number of covered offenders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d3232f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convictions of individuals in State court systems for a covered offense, noting the number of covered offenders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sentences imposed on individuals convicted in State court systems for a covered offense; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit the annual report prepared under paragraph (1) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3232f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Senior Policy Operating Group established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7103/g"},"text":"section 7103(g) of title 22","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d3232f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Justice victim screening protocol","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d3232fa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", the Attorney General shall issue a screening protocol for use during all anti-trafficking law enforcement operations in which the Department of Justice is involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d3232fb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The protocol required to be issued under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d3232fc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the individual screening of all adults and children who are suspected of engaging in commercial sex acts or who are subject to labor exploitation that may be in violation of child labor laws to determine whether each individual screened is a victim of human trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232fd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require affirmative measures to avoid arresting, charging, or prosecuting human trafficking victims for any offense that is the direct result of their victimization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232fe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require all Federal law enforcement officers and relevant department personnel who participate in human trafficking investigations to receive training on enforcement of the protocol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d3232ff-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed in consultation with State and local law enforcement agencies, the Department of Health and Human Services, survivors of human trafficking, and nongovernmental organizations that specialize in the identification, prevention, and restoration of victims of human trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d323300-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d323301-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures and practices to ensure that the screening process minimizes trauma or revictimization of the person being screened; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d323302-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20709/f/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines on assisting victims of human trafficking in identifying and receiving victim services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d323303-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/tII/s209"},"text":"Pub. L. 109–164, title II, § 209","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s114"},"text":"Pub. L. 114–22, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/241"},"text":"129 Stat. 241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/393/tV/s502"},"text":"Pub. L. 115–393, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5276"},"text":"132 Stat. 5276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/425/tI/s121/b"},"text":"Pub. L. 115–425, title I, § 121(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5478"},"text":"132 Stat. 5478","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/109/164/s209"},"text":"§ 209 of Pub. L. 109–164","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tI/s106/b/1"},"text":"Pub. L. 117–347, title I, § 106(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6204"},"text":"136 Stat. 6204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d323304-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d323305-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d323306-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/164/s209"},"text":"section 209 of Pub. L. 109–164","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/164/s209"},"text":"section 209 of Pub. L. 109–164","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3583/k"},"text":"section 3583(k) of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14044g"},"text":"section 14044g of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d323307-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s121/b/1"},"text":"Pub. L. 115–425, § 121(b)(1)","children":[],"tail":", (2), substituted “number” for “rates” in introductory provisions and inserted “, noting the number of covered offenders” after “covered offense” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s121/b/3"},"text":"Pub. L. 115–425, § 121(b)(3)","children":[],"tail":", substituted “arrests” for “arrest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s121/b/4"},"text":"Pub. L. 115–425, § 121(b)(4)","children":[],"tail":", substituted “prosecutions” for “prosecution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s121/b/5"},"text":"Pub. L. 115–425, § 121(b)(5)","children":[],"tail":", substituted “convictions” for “conviction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1)(A)(iii), (iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/393/s502/1"},"text":"Pub. L. 115–393, § 502(1)","children":[],"tail":", added cls. (iii) and (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/393/s502/2"},"text":"Pub. L. 115–393, § 502(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d323308-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d323309-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Using Existing Task Forces and Components To Target Offenders Who Exploit Children","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s110"},"text":"Pub. L. 114–22, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/239"},"text":"129 Stat. 239","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/22/tI/s110"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":"], the Attorney General shall ensure that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all task forces and working groups within the Innocence Lost National Initiative engage in activities, programs, or operations to increase the investigative capabilities of State and local law enforcement officers in the detection, investigation, and prosecution of persons who patronize, or solicit children for sex; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all components and task forces with jurisdiction to detect, investigate, and prosecute cases of child labor trafficking engage in activities, programs, or operations to increase the capacity of such components to deter and punish child labor trafficking.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
