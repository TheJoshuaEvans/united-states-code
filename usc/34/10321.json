{"tag":"section","attrib":{"id":"id4cb8958f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321"},"text":null,"children":[{"tag":"num","attrib":{"value":"10321"},"text":"§ 10321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional information sharing systems grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cb89590-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Justice Assistance is authorized to make grants and enter into contracts with State, tribal, and local criminal justice agencies and nonprofit organizations for the purposes of identifying, targeting, and removing criminal conspiracies and activities and terrorist conspiracies and activities spanning jurisdictional boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89591-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants and contracts awarded under this subchapter shall be made for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cb89592-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining and operating regional information sharing systems that are responsive to the needs of participating enforcement agencies in addressing multijurisdictional offenses and conspiracies, and that are capable of providing controlling input, dissemination, rapid retrieval, and systematized updating of information to authorized agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89593-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and operating an analytical component to assist participating agencies and projects in the compilation, interpretation, and presentation of information provided to a project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89594-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining a secure telecommunications system for regional information sharing between Federal, State, tribal, and local law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89595-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and operating secure information sharing systems to enhance the investigation and prosecution abilities of participating enforcement agencies in addressing multi-jurisdictional terrorist conspiracies and activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cb89596-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs designated by the Director that are designed to further the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89597-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is authorized to promulgate such rules and regulations as are necessary to carry out the purposes of this section, including rules and regulations for submitting and reviewing applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cb89598-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation to the Bureau of Justice Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Bureau of Justice Assistance to carry out this section $50,000,000 for fiscal year 2002 and $100,000,000 for fiscal year 2003.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cb89599-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1301"},"text":"Pub. L. 90–351, title I, § 1301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6101/a"},"text":"Pub. L. 100–690, title VI, § 6101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4340"},"text":"102 Stat. 4340","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVII/s701"},"text":"Pub. L. 107–56, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/374"},"text":"115 Stat. 374","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1114"},"text":"Pub. L. 109–162, title XI, § 1114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3103"},"text":"119 Stat. 3103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s252/a"},"text":"Pub. L. 111–211, title II, § 252(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2299"},"text":"124 Stat. 2299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cb8959a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cb8959b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cb8959c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796h"},"text":"section 3796h of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1301"},"text":"section 1301 of Pub. L. 90–351","children":[],"tail":", title VIII, "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/237"},"text":"82 Stat. 237","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3731"},"text":"section 3731 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cb8959d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1301"},"text":"section 1301 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1552/a/3"},"text":"Pub. L. 99–570, title I, § 1552(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-41"},"text":"100 Stat. 3207–41","children":[],"tail":", authorized Director to provide grants for drug law enforcement programs to eligible States and units of local government, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6101/a"},"text":"Pub. L. 100–690, title VI, § 6101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4340"},"text":"102 Stat. 4340","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s1301"},"text":"section 1301 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2601 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10541"},"text":"section 10541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cb8959e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211"},"text":"Pub. L. 111–211","children":[],"tail":" inserted “, tribal,” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1114/1"},"text":"Pub. L. 109–162, § 1114(1)","children":[],"tail":", inserted “regional” before “information sharing systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1114/2"},"text":"Pub. L. 109–162, § 1114(2)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “establishing and maintaining a telecommunication of the information sharing and analytical programs in clauses (1) and (2);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1114/3"},"text":"Pub. L. 109–162, § 1114(3)","children":[],"tail":", struck out “(5)” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s701/1"},"text":"Pub. L. 107–56, § 701(1)","children":[],"tail":", inserted “and terrorist conspiracies and activities” after “criminal conspiracies and activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s701/2"},"text":"Pub. L. 107–56, § 701(2)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s701/3"},"text":"Pub. L. 107–56, § 701(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cb8959f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cb895a0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s252/b"},"text":"Pub. L. 111–211, title II, § 252(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2299"},"text":"124 Stat. 2299","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/211/tII/s252/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this section [amending this section] or any amendment made by this section—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows the grant to be made to, or used by, an entity for law enforcement activities that the entity lacks jurisdiction to perform; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has any effect other than to authorize, award, or deny a grant of funds to a federally recognized Indian tribe for the purposes described in the relevant grant program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “Indian tribe” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s252/b"},"text":"section 252(b) of Pub. L. 111–211","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/s203/a"},"text":"section 203(a) of Pub. L. 111–211","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2801"},"text":"section 2801 of Title 25","children":[],"tail":", Indians.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id4cb895a1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"2000-08-01"},"text":"Aug. 1, 2000","children":[],"tail":", all functions of Director of Bureau of Justice Assistance, other than those enumerated in section 10142(3) to (6) of this title, transferred to Assistant Attorney General for Office of Justice Programs, see section 1000(a)(1) [title I, § 108(b)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10141"},"text":"section 10141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
