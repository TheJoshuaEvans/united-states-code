{"tag":"section","attrib":{"id":"id4d5ac9ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508"},"text":null,"children":[{"tag":"num","attrib":{"value":"41508"},"text":"§ 41508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States for threat assessment databases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5ac9ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General, through the Office of Justice Programs, shall make grants under this section to the highest State courts in States participating in the program, for the purpose of enabling such courts to establish and maintain a threat assessment database described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac9ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), a threat assessment database is a database through which a State can—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5ac9af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze trends and patterns in domestic terrorism and crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac9b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project the probabilities that specific acts of domestic terrorism or crime will occur; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac9b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop measures and procedures that can effectively reduce the probabilities that those acts will occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac9b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall define a core set of data elements to be used by each database funded by this section so that the information in the database can be effectively shared with other States and with the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac9b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2008 through 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5ac9b4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/177/tIII/s303"},"text":"Pub. L. 110–177, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-07"},"text":"Jan. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2540"},"text":"121 Stat. 2540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5ac9b5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5ac9b6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5ac9b7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3714a"},"text":"section 3714a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
