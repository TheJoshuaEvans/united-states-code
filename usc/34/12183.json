{"tag":"section","attrib":{"id":"id4cfb6ace-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183"},"text":null,"children":[{"tag":"num","attrib":{"value":"12183"},"text":"§ 12183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfb6acf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12182/b/2/B"},"text":"section 12182(b)(2)(B) of this title","children":[],"tail":", the Secretary shall ensure that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6ad0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the residents of the target area to be served (as identified under the strategic development plan) would have an income that is less than the median income for the area (as determined by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ad1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant community development corporation possesses the technical and managerial capability necessary to administer a revolving loan fund and has past experience in the development and management of housing, community and economic development programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ad2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant community development corporation has provided sufficient evidence of the existence of good working relationships with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfb6ad3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local businesses and financial institutions, as well as with the community the corporation proposes to serve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6ad4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local and regional job training programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ad5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicant community development corporation will target job opportunities that arise from revolving loan fund investments under this subpart so that 75 percent of the jobs retained or created under such investments are provided to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfb6ad6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cfb6ad7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incomes that do not exceed the Federal poverty line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cfb6ad8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incomes that do not exceed 80 percent of the median income of the area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6ad9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are unemployed or underemployed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6ada-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are participating or have participated in job training programs authorized under title I of the Workforce Innovation and Opportunity Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s3111"},"text":"29 U.S.C. 3111","children":[],"tail":" et seq.] or the Family Support Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Public Law 100–485","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6adb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals whose jobs may be retained as a result of the provision of financing available under this subpart; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfb6adc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who have historically been underrepresented in the local economy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6add-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative cross section of applicants are approved, including large and small community development corporations, urban and rural community development corporations and community development corporations representing diverse populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfb6ade-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which application to approve under this subpart the Secretary shall give priority to those applicants proposing to serve a target area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfb6adf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a median income that does not exceed 80 percent of the median for the area (as determined by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfb6ae0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a high rate of unemployment, as determined by the Secretary or in which the population loss is at least 7 percent from ","children":[{"tag":"date","attrib":{"date":"1980-04-01"},"text":"April 1, 1980","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1990-04-01"},"text":"April 1, 1990","children":[],"tail":", as reported by the Bureau of the Census."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfb6ae1-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31113"},"text":"Pub. L. 103–322, title III, § 31113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1883"},"text":"108 Stat. 1883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s405/d/44"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 405(d)(44), (f)(35)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–428, 2681–434; "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/tV/s512/jj"},"text":"Pub. L. 113–128, title V, § 512(jj)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1722"},"text":"128 Stat. 1722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfb6ae2-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfb6ae3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cfb6ae4-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Workforce Innovation and Opportunity Act, referred to in subsec. (a)(4)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1425"},"text":"128 Stat. 1425","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 3111 et seq.) of chapter 32 of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Family Support Act of 1988, referred to in subsec. (a)(4)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Pub. L. 100–485","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-13"},"text":"Oct. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2343"},"text":"102 Stat. 2343","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1988 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":", The Public Health and Welfare, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfb6ae5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13823"},"text":"section 13823 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cfb6ae6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" substituted “job training programs authorized under title I of the Workforce Innovation and Opportunity Act or the Family Support Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Public Law 100–485","children":[],"tail":")” for “job training programs authorized under title I of the Workforce Investment Act of 1998 or the Family Support Act of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/485"},"text":"Public Law 100–485","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/f/35"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(f)(35)]","children":[],"tail":", struck out “the Job Training Partnership Act or” after “authorized under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/f/tVIII/s405/d/44"},"text":"Pub. L. 105–277, § 101(f) [title VIII, § 405(d)(44)]","children":[],"tail":", substituted “authorized under the Job Training Partnership Act or title I of the Workforce Investment Act of 1998” for “authorized under the Job Training Partnership Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1501"},"text":"29 U.S.C. 1501","children":[],"tail":" et seq.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cfb6ae7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cfb6ae8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/128"},"text":"Pub. L. 113–128","children":[],"tail":" effective on the first day of the first full program year after "},{"tag":"date","attrib":{"date":"2014-07-22"},"text":"July 22, 2014","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2015-07-01"},"text":"July 1, 2015","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/113/128/s506"},"text":"section 506 of Pub. L. 113–128","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s3101"},"text":"section 3101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cfb6ae9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 101(f) [title VIII, § 405(d)(44)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and amendment by section 101(f) [title VIII, § 405(f)(35)] of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-07-01"},"text":"July 1, 2000","children":[],"tail":", see section 101(f) [title VIII, § 405(g)(1), (2)(B)] of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3502"},"text":"section 3502 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
