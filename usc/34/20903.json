{"tag":"section","attrib":{"id":"id4d34a378-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20903"},"text":null,"children":[{"tag":"num","attrib":{"value":"20903"},"text":"§ 20903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal registry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d34a379-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall contract with any interested Indian tribe, tribal organization, or tribal nonprofit organization to develop and maintain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d34a37a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20903/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national tribal sex offender registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d34a37b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20903/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal protection order registry containing civil and criminal orders of protection issued by Indian tribes and participating jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a37c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000 for each of fiscal years 2014 through 2018, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d34a37d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tIX/s905/b"},"text":"Pub. L. 109–162, title IX, § 905(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3080"},"text":"119 Stat. 3080","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tIX/s907/b"},"text":"Pub. L. 113–4, title IX, § 907(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/125"},"text":"127 Stat. 125","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a37e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d34a37f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d34a380-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of subsec. (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/s905"},"text":"section 905 of Pub. L. 109–162","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s905"},"text":"section 905 of Pub. L. 109–162","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Violence Against Women and Department of Justice Reauthorization Act of 2005, and not as part of the Sex Offender Registration and Notification Act which comprises this subchapter, or as part of the Adam Walsh Child Protection and Safety Act of 2006 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d34a381-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" substituted “fiscal years 2014 through 2018” for “fiscal years 2007 through 2011”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
