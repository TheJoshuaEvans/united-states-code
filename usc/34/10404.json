{"tag":"section","attrib":{"id":"id4cbd5079-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404"},"text":null,"children":[{"tag":"num","attrib":{"value":"10404"},"text":"§ 10404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation and distribution of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd507a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd507b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with regulations promulgated pursuant to this subchapter and except as provided in paragraph (3), the Attorney General shall allocate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd507c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.50 percent for each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd507d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the total funds remaining after the allocation under subparagraph (A), to each State, an amount which bears the same ratio to the amount of remaining funds described in this subparagraph as the population of people under the age of 18 living in such State for the most recent calendar year in which such data is available bears to the population of people under the age of 18 of all the States for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd507e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds allocated to a State under this subsection or received by a State for distribution under subsection (b) may be distributed by the Attorney General or by the State involved for any program other than a program contained in an approved application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd507f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local distribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5080-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), each State which receives funds under subsection (a)(1) in a fiscal year shall distribute among units of local government, for the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10401"},"text":"section 10401 of this title","children":[],"tail":", not less than 75 percent of such amounts received."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5081-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State submits to the Attorney General an application for waiver that demonstrates and certifies to the Attorney General that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5082-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State’s juvenile justice expenditures in the fiscal year preceding the date in which an application is submitted under this subchapter (the “State percentage”) is more than 25 percent of the aggregate amount of juvenile justice expenditures by the State and its eligible units of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd5083-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has consulted with as many units of local government in such State, or organizations representing such units, as practicable regarding the State’s calculation of expenditures under subparagraph (A), the State’s application for waiver under this paragraph, and the State’s proposed uses of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5084-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making the distribution under paragraph (1), the State shall allocate to such units of local government an amount which bears the same ratio to the aggregate amount of such funds as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5085-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cbd5086-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4cbd5087-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three-quarters; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cbd5088-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average juvenile justice expenditure for such unit of local government for the 3 most recent calendar years for which such data is available; plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cbd5089-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4cbd508a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-quarter; multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4cbd508b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average annual number of part 1 violent crimes in such unit of local government for the 3 most recent calendar years for which such data is available, bears to—","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd508c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the products determined under subparagraph (A) for all such units of local government in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd508d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allocation any unit of local government shall receive under paragraph (3) for a payment period shall not exceed 100 percent of juvenile justice expenditures of the unit for such payment period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd508e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any unit of local government’s allocation that is not available to such unit by operation of paragraph (4) shall be available to other units of local government that are not affected by such operation in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd508f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unavailability of data for units of local government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the State has reason to believe that the reported rate of part 1 violent crimes or juvenile justice expenditures for a unit of local government is insufficient or inaccurate, the State shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5090-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate the methodology used by the unit to determine the accuracy of the submitted data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5091-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if necessary, use the best available comparable data regarding the number of violent crimes or juvenile justice expenditures for the relevant years for the unit of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd5092-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government with allocations less than $10,000","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If under this section a unit of local government is allocated less than $10,000 for a payment period, the amount allotted shall be expended by the State on services to units of local government whose allotment is less than such amount in a manner consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd5093-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct grants to specially qualified units","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5094-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State does not qualify or apply for funds reserved for allocation under subsection (a) by the application deadline established by the Attorney General, the Attorney General shall reserve not more than 75 percent of the allocation that the State would have received under subsection (a) for such fiscal year to provide grants to specially qualified units which meet the requirements for funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10403"},"text":"section 10403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5095-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10404/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the qualification requirements for direct grants for specially qualified units the Attorney General may use the average amount allocated by the States to units of local government as a basis for awarding grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd5096-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1803"},"text":"Pub. L. 90–351, title I, § 1803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12102/a"},"text":"Pub. L. 107–273, div. C, title II, § 12102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1863"},"text":"116 Stat. 1863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd5097-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd5098-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd5099-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–3"},"text":"section 3796ee–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cbd509a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1803"},"text":"section 1803 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20201/a/3"},"text":"Pub. L. 103–322, title II, § 20201(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1820"},"text":"108 Stat. 1820","children":[],"tail":", and classified to former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ee–2"},"text":"section 3796ee–2 of Title 42","children":[],"tail":", The Public Health and Welfare, related to review of State applications, prior to the general amendment of part R of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/90/351"},"text":"Pub. L. 90–351","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
