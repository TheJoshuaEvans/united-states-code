{"tag":"section","attrib":{"id":"id4d512bfa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40706"},"text":null,"children":[{"tag":"num","attrib":{"value":"40706"},"text":"§ 40706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protection standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512bfb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), any sample collected under, or any result of any analysis carried out under, section 40701, 40702, or 40703 of this title may be used only for a purpose specified in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512bfc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sample or result described in subsection (a) may be disclosed under the circumstances under which disclosure of information included in the Combined DNA Index System is allowed, as specified in subparagraphs (A) through (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12592/b/3"},"text":"section 12592(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512bfd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who knowingly discloses a sample or result described in subsection (a) in any manner to any person not authorized to receive it, or obtains or uses, without authorization, such sample or result, shall be fined not more than $250,000, or imprisoned for a period of not more than one year. Each instance of disclosure, obtaining, or use shall constitute a separate offense under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512bfe-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/546/s10"},"text":"Pub. L. 106–546, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-19"},"text":"Dec. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2735"},"text":"114 Stat. 2735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tII/s203/e/2"},"text":"Pub. L. 108–405, title II, § 203(e)(2)","children":[],"tail":", title III, § 309, "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2271"},"text":"118 Stat. 2271","children":[],"tail":", 2275.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512bff-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512c00-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512c01-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14135e"},"text":"section 14135e of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d512c02-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/s309"},"text":"Pub. L. 108–405, § 309","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “A person who knowingly—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) discloses a sample or result described in subsection (a) of this section in any manner to any person not authorized to receive it; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) obtains, without authorization, a sample or result described in subsection (a) of this section,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"shall be fined not more than $250,000, or imprisoned for a period of not more than one year, or both.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/s203/e/2"},"text":"Pub. L. 108–405, § 203(e)(2)","children":[],"tail":", substituted “$250,000, or imprisoned for a period of not more than one year, or both” for “$100,000” in concluding provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
