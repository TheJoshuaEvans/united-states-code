{"tag":"section","attrib":{"id":"id4d0c0d53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492"},"text":null,"children":[{"tag":"num","attrib":{"value":"12492"},"text":"§ 12492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d0c0d54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular compliance reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0d55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each appropriate agency shall establish a process by which to review compliance with the requirements of this part, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0d56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where possible, be incorporated into other existing compliance review processes of the appropriate agency, in consultation with the Gender-based Violence Prevention Office and Violence Against Women Act Director described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12493"},"text":"section 12493 of this title","children":[],"tail":" and any other relevant officials of the appropriate agency; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0d57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" examine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d0c0d58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with requirements prohibiting the denial of assistance, tenancy, or occupancy rights on the basis of domestic violence, dating violence, sexual assault, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0c0d59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with confidentiality provisions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491/c/4"},"text":"section 12491(c)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0c0d5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the notification requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491/d/2"},"text":"section 12491(d)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0c0d5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the provisions for accepting documentation set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491/c"},"text":"section 12491(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0c0d5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with emergency transfer requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12491/e"},"text":"section 12491(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d0c0d5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the prohibition on retaliation set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12494"},"text":"section 12494 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0d5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each appropriate agency shall conduct the review described in paragraph (1) on a regular basis, as determined by the appropriate agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0d5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0d60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", each appropriate agency shall issue regulations in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":" to implement subsection (a) of this section, which shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0d61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define standards of compliance under covered housing programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0d62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include detailed reporting requirements, including the number of emergency transfers requested and granted, as well as the length of time needed to process emergency transfers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0d63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include standards for corrective action plans where compliance standards have not been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0d64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the regulations under paragraph (1), an appropriate agency shall engage in additional consultation with appropriate stakeholders including, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d0c0d65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals and organizations with expertise in the housing needs and experiences of victims of domestic violence, dating violence, sexual assault and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d0c0d66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals and organizations with expertise in the administration or management of covered housing programs, including industry stakeholders and public housing agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d0c0d67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each appropriate agency shall ensure that an agency-level assessment of the information collected during the compliance review process completed pursuant to this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d0c0d68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an evaluation of each topic identified in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d0c0d69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12492/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d0c0d6a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41412"},"text":"Pub. L. 103–322, title IV, § 41412","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s602"},"text":"Pub. L. 117–103, div. W, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/882"},"text":"136 Stat. 882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0c0d6b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0c0d6c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0c0d6d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tVI/s602"},"text":"Pub. L. 117–103, div. W, title VI, § 602","children":[],"tail":", which directed the addition of this section to chapter 2 of subtitle N 