{"tag":"section","attrib":{"id":"id4caa3de5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10234"},"text":null,"children":[{"tag":"num","attrib":{"value":"10234"},"text":"§ 10234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of Central Intelligence Agency services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, no use will be made of services, facilities, or personnel of the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4caa3de6-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s815"},"text":"Pub. L. 90–351, title I, § 815","children":[],"tail":", formerly § 822, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/157/s2"},"text":"Pub. L. 96–157, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-27"},"text":"Dec. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1214"},"text":"93 Stat. 1214","children":[],"tail":"; renumbered § 815, "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609B/f"},"text":"Pub. L. 98–473, title II, § 609B(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2093"},"text":"98 Stat. 2093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4caa3de7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4caa3de8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4caa3de9-5d