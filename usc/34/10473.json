{"tag":"section","attrib":{"id":"id4cc95f03-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473"},"text":null,"children":[{"tag":"num","attrib":{"value":"10473"},"text":"§ 10473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc95f04-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall consult with the Secretary of Health and Human Services and any other appropriate officials in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f05-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may utilize any component or components of the Department of Justice in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f06-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall issue regulations and guidelines necessary to carry out this subchapter which include, but are not limited to, the methodologies and outcome measures proposed for evaluating each applicant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95f07-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other requirements that may be specified by the Attorney General, an application for a grant under this subchapter shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95f08-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a long-term strategy and detailed implementation plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f09-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the applicant’s inability to fund the program adequately without Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f0a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the Federal support provided will be used to supplement, and not supplant, State, Indian tribal, and local sources of funding that would otherwise be available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f0b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify related governmental or community initiatives which complement or will be coordinated with the proposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that there has been appropriate consultation with all affected agencies and that there will be appropriate coordination with all affected agencies in the implementation of the program, including the State mental health authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that participating offenders will be supervised by one or more designated judges with responsibility for the mental health court program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify plans for obtaining necessary support and continuing the proposed program following the conclusion of Federal support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f0f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the methodology and outcome measures that will be used in evaluating the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95f10-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10473/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that participating first time offenders without a history of a mental illness will receive a mental health evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc95f11-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2203"},"text":"Pub. L. 90–351, title I, § 2203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/515/s3/a"},"text":"Pub. L. 106–515, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2400"},"text":"114 Stat. 2400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc95f12-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc95f13-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc95f14-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ii–2"},"text":"section 3796ii–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cc95f15-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2203"},"text":"section 2203 of title I of Pub. L. 90–351","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tV/s50001/a/3"},"text":"Pub. L. 103–322, title V, § 50001(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1956"},"text":"108 Stat. 1956","children":[],"tail":", defined “violent offender”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(b)(1)(A)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–21; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
