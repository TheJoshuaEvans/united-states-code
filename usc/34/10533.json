{"tag":"section","attrib":{"id":"id4ccba931-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533"},"text":null,"children":[{"tag":"num","attrib":{"value":"10533"},"text":"§ 10533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ccba932-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “armor vest” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ccba933-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" body armor, no less than Type I, which has been tested through the voluntary compliance testing program operated by the National Law Enforcement and Corrections Technology Center of the National Institute of Justice (NIJ), and found to meet or exceed the requirements of NIJ Standard 0101.03, or any subsequent revision of such standard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ccba934-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" body armor that has been tested through the voluntary compliance testing program, and found to meet or exceed the requirements of NIJ Standard 0115.00, or any revision of such standard;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba935-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “body armor” means any product sold or offered for sale as personal protective body covering intended to protect against gunfire, stabbing, or other physical harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba936-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means each of the 50 States, the District of Columbia, the Commonwealth of Puerto Rico, the United States Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba937-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unit of local government” means a county, municipality, town, township, village, parish, borough, or other unit of general government below the State level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba938-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Indian tribe” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ccba939-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10533/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “law enforcement officer” means any officer, agent, or employee of a State, unit of local government, or Indian tribe authorized by law or by a government agency to engage in or supervise the prevention, detection, or investigation of any violation of criminal law, or authorized by law to supervise sentenced criminal offenders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ccba93a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2503"},"text":"Pub. L. 90–351, title I, § 2503","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/181/s3/a/3"},"text":"Pub. L. 105–181, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-16"},"text":"June 16, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/514"},"text":"112 Stat. 514","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/517/s3/d"},"text":"Pub. L. 106–517, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2408"},"text":"114 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ccba93b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ccba93c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ccba93d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 3796","children":[{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"–2 of Title 42, The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ccba93e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/517"},"text":"Pub. L. 106–517","children":[],"tail":" designated provisions after “ ‘armor vest’ means” as subpar. (A) and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ccba93f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4ccba940-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interim Definition of Armor Vest","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/517/s3/e"},"text":"Pub. L. 106–517, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2408"},"text":"114 Stat. 2408","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/517/s3/e"},"text":"“For purposes of part Y of title I of the Omnibus Crime Control and Safe Streets Act of 1968 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10531"},"text":"34 U.S.C. 10531","children":[],"tail":" et seq.], as amended by this Act, the meaning of the term ‘armor vest’ (as defined in section 2503 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796"},"text":"42 U.S.C. 3796","children":[],"tail":null},{"tag":"i","attrib":{},"text":"ll","children":[],"tail":"–2) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10533"},"text":"34 U.S.C. 10533","children":[],"tail":"]) shall, until the date on which a final NIJ Standard 0115.00 is first fully approved and implemented, also include body armor which has been found to meet or exceed the requirements for protection against stabbing established by the State in which the grantee is located.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
