{"tag":"section","attrib":{"id":"id4d1f2019-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123"},"text":null,"children":[{"tag":"num","attrib":{"value":"20123"},"text":"§ 20123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for outreach and services to underserved populations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f201a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f201b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated under the grant programs identified in paragraph (2), the Attorney General shall take 2 percent of such appropriated amounts and combine them to award grants to eligible entities described in subsection (b) of this section to develop and implement outreach strategies targeted at adult or youth victims of domestic violence, dating violence, sexual assault, or stalking in underserved populations and to provide victim services to meet the needs of adult and youth victims of domestic violence, dating violence, sexual assault, and stalking in underserved populations. The requirements of the grant programs identified in paragraph (2) shall not apply to this grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f201c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The programs covered by paragraph (1) are the programs carried out under the following provisions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d1f201d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10441"},"text":"Section 10441 of this title","children":[],"tail":" (Grants to Combat Violent Crimes Against Women)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d1f201e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10461"},"text":"Section 10461 of this title","children":[],"tail":" (Grants to Encourage Arrest Policies and Enforcement of Protection Orders Program)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f201f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible entities under this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f2020-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" population specific organizations that have demonstrated experience and expertise in providing population specific services in the relevant underserved communities, or population specific organizations working in partnership with a victim service provider or domestic violence or sexual assault coalition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f2021-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victim service providers offering population specific services for a specific underserved population; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f2022-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victim service providers working in partnership with a national, State, tribal, Native Hawaiian, or local organization that has demonstrated experience and expertise in providing population specific services in the relevant underserved population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d219023-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may use up to 25 percent of funds available under this section to make one-time planning grants to eligible entities to support the planning and development of specially designed and targeted programs for adult and youth victims in one or more underserved populations, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d219024-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, building and strengthening partnerships with potential collaborators within underserved populations, Federal, State, tribal, territorial or local government entities, and public and private organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d219025-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a needs assessment of the community and the targeted underserved population or populations to determine what the barriers are to service access and what factors contribute to those barriers, using input from the targeted underserved population or populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d219026-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying promising prevention, outreach and intervention strategies for victims from a targeted underserved population or populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d219027-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a plan, with the input of the targeted underserved population or populations, for implementing prevention, outreach and intervention strategies to address the barriers to accessing services, promoting community engagement in the prevention of domestic violence, dating violence, sexual assault, and stalking within the targeted underserved populations, and evaluating the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d219028-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall make grants to eligible entities for the purpose of providing or enhancing population specific outreach and services to adult and youth victims in one or more underserved populations, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d219029-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with Federal, State, tribal, territorial and local governments, agencies, and organizations to develop or enhance population specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d21902a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the capacity of underserved populations to provide population specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d21902b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the capacity of traditional victim service providers to provide population specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d21902c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the response of criminal and civil justice interventions by providing population-specific training for law enforcement, prosecutors, judges and other court personnel on domestic violence, dating violence, sexual assault, or stalking in underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d21902d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working in cooperation with an underserved population to develop and implement outreach, education, prevention, and intervention strategies that highlight available resources and the specific issues faced by victims of domestic violence, dating violence, sexual assault, or stalking from underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d21902e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing, enlarging, or strengthening culturally specific programs and projects to provide culturally specific services regarding responses to, and prevention of, female genital mutilation and cutting; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d21902f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the response of social and human services by providing population-specific training for service providers on domestic violence, dating violence, sexual assault, or stalking in underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d219030-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity desiring a grant under this section shall submit an application to the Director of the Office on Violence Against Women at such time, in such form, and in such manner as the Director may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d219031-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity receiving a grant under this section shall submit to the Director of the Office on Violence Against Women a report that describes the activities carried out with grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d219032-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the funds identified in subsection (a)(1), there are authorized to be appropriated to carry out this section $6,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d219033-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20123/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and grant conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section the definitions and grant conditions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d219034-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s120"},"text":"Pub. L. 109–162, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2990"},"text":"119 Stat. 2990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/271"},"text":"Pub. L. 109–271","children":[],"tail":", §§ 1(c)(2), 2(h), "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/750"},"text":"120 Stat. 750","children":[],"tail":", 752; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tI/s108"},"text":"Pub. L. 113–4, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/78"},"text":"127 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tI/s105"},"text":"Pub. L. 117–103, div. W, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/851"},"text":"136 Stat. 851","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d219035-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d219036-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d219037-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14045"},"text":"section 14045 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d219038-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s105/1"},"text":"Pub. L. 117–103, § 105(1)","children":[],"tail":", inserted “Native Hawaiian,” before “or local organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s105/2/A/i"},"text":"Pub. L. 117–103, § 105(2)(A)(i)","children":[],"tail":", (ii), substituted “response” for “effectiveness” and inserted “population-specific” before “training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s105/2/A/iii"},"text":"Pub. L. 117–103, § 105(2)(A)(iii)","children":[],"tail":", (B), (C), added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s105/3"},"text":"Pub. L. 117–103, § 105(3)","children":[],"tail":", substituted “$6,000,000” for “$2,000,000” and “2023 through 2027” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" amended section generally. Prior to amendment, section related to grants for outreach to underserved populations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271/s2/h"},"text":"Pub. L. 109–271, § 2(h)","children":[],"tail":", struck out “, every 18 months,” after “Office of Violence Against Women”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/271/s1/c/2"},"text":"Pub. L. 109–271, § 1(c)(2)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d219039-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d21903a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d21903b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Pub. L. 113–4","children":[],"tail":" not effective until the beginning of the fiscal year following "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/s4"},"text":"section 4 of Pub. L. 113–4","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2261"},"text":"section 2261 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
