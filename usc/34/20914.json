{"tag":"section","attrib":{"id":"id4d34a3d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914"},"text":null,"children":[{"tag":"num","attrib":{"value":"20914"},"text":"§ 20914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required in registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d34a3d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provided by the offender","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sex offender shall provide the following information to the appropriate official for inclusion in the sex offender registry:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d34a3d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the sex offender (including any alias used by the individual).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Social Security number of the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The address of each residence at which the sex offender resides or will reside.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of any place where the sex offender is an employee or will be an employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3da-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of any place where the sex offender is a student or will be a student.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3db-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The license plate number and a description of any vehicle owned or operated by the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3dc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information relating to intended travel of the sex offender outside the United States, including any anticipated dates and places of departure, arrival, or return, carrier and flight numbers for air travel, destination country and address or other contact information therein, means and purpose of travel, and any other itinerary or other travel-related information required by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information required by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a3de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provided by the jurisdiction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The jurisdiction in which the sex offender registers shall ensure that the following information is included in the registry for that sex offender:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d34a3df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A physical description of the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The text of the provision of law defining the criminal offense for which the sex offender is registered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The criminal history of the sex offender, including the date of all arrests and convictions; the status of parole, probation, or supervised release; registration status; and the existence of any outstanding arrest warrants for the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A current photograph of the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A set of fingerprints and palm prints of the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A DNA sample of the sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A photocopy of a valid driver’s license or identification card issued to the sex offender by a jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a3e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information required by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d34a3e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time and manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sex offender shall provide and update information required under subsection (a), including information relating to intended travel outside the United States required under paragraph (7) of that subsection, in conformity with any time and manner requirements prescribed by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d34a3e8-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s114"},"text":"Pub. L. 109–248, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/594"},"text":"120 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/119/s6/a"},"text":"Pub. L. 114–119, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/22"},"text":"130 Stat. 22","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a3e9-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d34a3ea-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d34a3eb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16914"},"text":"section 16914 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d34a3ec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/119/s6/a/1"},"text":"Pub. L. 114–119, § 6(a)(1)","children":[],"tail":", added par. (7) and redesignated former par. (7) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/119/s6/a/2"},"text":"Pub. L. 114–119, § 6(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
