{"tag":"section","attrib":{"id":"id4d5d1400-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501"},"text":null,"children":[{"tag":"num","attrib":{"value":"50501"},"text":"§ 50501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5d1401-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Coordinator” means the Blue Alert Coordinator of the Department of Justice designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50503/a"},"text":"section 50503(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1402-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blue Alert","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Blue Alert” means information sent through the network relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d5d1403-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the serious injury or death of a law enforcement officer in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1404-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer who is missing in connection with the officer’s official duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d5d1405-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an imminent and credible threat that an individual intends to cause the serious injury or death of a law enforcement officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1406-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blue Alert plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Blue Alert plan” means the plan of a State, unit of local government, or Federal agency participating in the network for the dissemination of information received as a Blue Alert.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1407-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “law enforcement officer” shall have the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10284"},"text":"section 10284 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1408-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “network” means the Blue Alert communications network established by the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s50502"},"text":"section 50502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5d1409-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States, the District of Columbia, Puerto Rico, the United States Virgin Islands, Guam, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d140a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/12/s2"},"text":"Pub. L. 114–12, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-19"},"text":"May 19, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/192"},"text":"129 Stat. 192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d140b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d140c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d140d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14165"},"text":"section 14165 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d5d140e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id4d5d140f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/12"},"text":"Pub. L. 114–12","children":[],"tail":", which is classified to this chapter, as the “Rafael Ramos and Wenjian Liu National Blue Alert Act of 2015”, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/12/s1"},"text":"section 1 of Pub. L. 114–12","children":[],"tail":", set out as a Short Title of 2015 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
