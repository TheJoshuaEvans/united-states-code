"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":", and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act Reauthorization Act of 2022, referred to in par. (5), is div. W of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/840"},"text":"136 Stat. 840","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s1"},"text":"section 1 of div. W of Pub. L. 117–103","children":[],"tail":", set out as a Short Title of 2022 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cc232d4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796gg–0b"},"text":"section 3796gg–0b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cc232d5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/s2004"},"text":"section 2004 of Pub. L. 90–351","children":[],"tail":" was renumbered section 2009 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10448"},"text":"section 10448 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cc232d6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s901/c/1"},"text":"Pub. L. 117–103, § 901(c)(1)","children":[],"tail":", substituted “Office on Violence Against Women” for “Violence Against Women Office” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s901/c/2"},"text":"Pub. L. 117–103, § 901(c)(2)","children":[],"tail":", in introductory provisions, substituted “103–322), the Violence” for “103–322) and the Violence” and “, the Violence Against Women and Department of Justice Reauthorization Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Public Law 109–162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/119/2960"},"text":"119 Stat. 2960","children":[],"tail":"), the Violence Against Women Reauthorization Act of 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Public Law 113–4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/127/54"},"text":"127 Stat. 54","children":[],"tail":"), and the Violence Against Women Act Reauthorization Act of 2022, including with” for “, including with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s901/c/3"},"text":"Pub. L. 117–103, § 901(c)(3)","children":[],"tail":", inserted “synchronize Federal definitions and protocols,” before “and improve coordination”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cc232d7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cc232d8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4cc232d9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s403"},"text":"section 403 of Pub. L. 107–273","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10442"},"text":"section 10442 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
