{"tag":"section","attrib":{"id":"id4cc232c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444"},"text":null,"children":[{"tag":"num","attrib":{"value":"10444"},"text":"§ 10444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and functions of Director of Office on Violence Against Women","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall have the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc232c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintaining liaison with the judicial branches of the Federal and State Governments on matters relating to violence against women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing information to the President, the Congress, the judiciary, State, local, and tribal governments, and the general public on matters relating to violence against women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serving, at the request of the Attorney General, as the representative of the Department of Justice on domestic task forces, committees, or commissions addressing policy or issues relating to violence against women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serving, at the request of the President, acting through the Attorney General, as the representative of the United States Government on human rights and economic justice matters related to violence against women in international fora, including, but not limited to, the United Nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Carrying out the functions of the Department of Justice under the Violence Against Women Act of 1994 (title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":"), the Violence Against Women Act of 2000 (division B of "},{"tag":"ref","attrib":{"href":"/us/pl/106/386"},"text":"Public Law 106–386","children":[],"tail":"), the Violence Against Women and Department of Justice Reauthorization Act of 2005 ("},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Public Law 109–162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/119/2960"},"text":"119 Stat. 2960","children":[],"tail":"), the Violence Against Women Reauthorization Act of 2013 ("},{"tag":"ref","attrib":{"href":"/us/pl/113/4"},"text":"Public Law 113–4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/127/54"},"text":"127 Stat. 54","children":[],"tail":"), and the Violence Against Women Act Reauthorization Act of 2022, including with respect to those functions—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc232c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of policy, protocols, and guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc232c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and management of grant programs and other programs, and the provision of technical assistance under such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc232c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award and termination of grants, cooperative agreements, and contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Providing technical assistance, coordination, and support to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc232cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other components of the Department of Justice, in efforts to develop policy and to enforce Federal laws relating to violence against women, including the litigation of civil and criminal actions relating to enforcing such laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc232cc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal, State, local, and tribal agencies, in efforts to develop policy, provide technical assistance, synchronize Federal definitions and protocols, and improve coordination among agencies carrying out efforts to eliminate violence against women, including Indian or indigenous women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc232cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grantees, in efforts to combat violence against women and to provide support and assistance to victims of such violence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exercising such other powers and functions as may be vested in the Director pursuant to this subchapter or by delegation of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc232cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10444/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing such rules, regulations, guidelines, and procedures as are necessary to carry out any function of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cc232d0-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2004"},"text":"Pub. L. 90–351, title I, § 2004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tIV/s402/3"},"text":"Pub. L. 107–273, div. A, title IV, § 402(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1790"},"text":"116 Stat. 1790","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tIX/s901/c"},"text":"Pub. L. 117–103, div. W, title IX, § 901(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/910"},"text":"136 Stat. 910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cc232d1-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cc232d2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cc232d3-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 1994, referred to in par. (5), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1994 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Violence Against Women Act of 2000, referred to in par. (5), is div. B of ","children":[{"tag":