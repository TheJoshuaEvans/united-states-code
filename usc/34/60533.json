{"tag":"section","attrib":{"id":"id4d643f84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60533"},"text":null,"children":[{"tag":"num","attrib":{"value":"60533"},"text":"§ 60533.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Prisons policy on mentoring contacts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d643f85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60533/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2008-04-09"},"text":"April 9, 2008","children":[],"tail":", the Director of the Bureau of Prisons shall, in order to promote stability and continued assistance to offenders after release from prison, adopt and implement a policy to ensure that any person who provides mentoring services to an incarcerated offender is permitted to continue such services after that offender is released from prison. That policy shall permit the continuation of mentoring services unless the Director demonstrates that such services would be a significant security risk to the released offender, incarcerated offenders, persons who provide such services, or any other person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60533/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":", the Director of the Bureau of Prisons shall submit to Congress a report on the extent to which the policy described in subsection (a) has been implemented and followed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f87-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s213"},"text":"Pub. L. 110–199, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/683"},"text":"122 Stat. 683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f88-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f89-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d643f8a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17533"},"text":"section 17533 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
