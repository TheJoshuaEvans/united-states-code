{"tag":"section","attrib":{"id":"id4cd06394-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611"},"text":null,"children":[{"tag":"num","attrib":{"value":"10611"},"text":"§ 10611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd06395-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make grants to States, State courts, local courts, units of local government, and Indian tribal governments, acting directly or through agreements with other public or private entities, for adult drug courts, juvenile drug courts, family drug courts, and tribal drug courts that involve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd06396-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing judicial supervision over offenders, and other individuals under the jurisdiction of the court, with substance abuse problems, including co-occurring substance abuse and mental health problems, who are not violent offenders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06397-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with the appropriate State or local prosecutor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06398-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the integrated administration of other sanctions and services, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd06399-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mandatory periodic testing for the use of controlled substances or other addictive substances during any period of supervised release or probation for each participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd0639a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance abuse treatment for each participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd0639b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diversion, probation, or other supervised release involving the possibility of prosecution, confinement, or incarceration based on noncompliance with program requirements or failure to show satisfactory progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd0639c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offender management, and aftercare services such as relapse prevention, health care, education, vocational training, job placement, housing placement, and child care or other family support services for each participant who requires such services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd0639d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment, in whole or part, by the offender of treatment costs, to the extent practicable, such as costs for urinalysis or counseling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd0639e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment, in whole or part, by the offender of restitution, to the extent practicable, to either a victim of the offender’s offense or to a restitution or similar victim support fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd0639f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Economic sanctions imposed on an offender pursuant to this section shall not be at a level that would interfere with the offender’s rehabilitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd063a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory drug testing and mandatory sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd063a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory testing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grant amounts under this subchapter may be used for a drug court only if the drug court has mandatory periodic testing as described in subsection (a)(3)(A). The Attorney General shall, by prescribing guidelines or regulations, specify standards for the timing and manner of complying with such requirements. The standards—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd063a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cd063a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each participant is tested for every controlled substance that the participant has been known to abuse, and for any other controlled substance the Attorney General or the court may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd063a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing is accurate and practicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require approval of the drug testing regime to ensure that adequate testing occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd063a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall, by prescribing guidelines or regulations, specify that grant amounts under this subchapter may be used for a drug court only if the drug court imposes graduated sanctions that increase punitive measures, therapeutic measures, or both whenever a participant fails a drug test. Such sanctions and measures may include, but are not limited to, one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd063a7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incarceration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063a8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detoxification treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063a9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Residential treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063aa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased time in program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063ab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Termination from the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063ac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased drug screening requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063ad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased court appearances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063ae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063af-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased supervision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063b0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic monitoring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063b1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In-home restriction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063b2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Community service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063b3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family counseling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd063b4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10611/c/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Anger management classes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd063b5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2951"},"text":"Pub. L. 90–351, title I, § 2951","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2301/a"},"text":"Pub. L. 107–273, div. B, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1794"},"text":"116 Stat. 1794","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1143"},"text":"Pub. L. 109–162, title XI, § 1143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3111"},"text":"119 Stat. 3111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tVII/s751"},"text":"Pub. L. 109–177, title VII, § 751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/273"},"text":"120 Stat. 273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14007/1"},"text":"Pub. L. 114–255, div. B, title XIV, § 14007(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1296"},"text":"130 Stat. 1296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd063b6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd063b7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd063b8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u"},"text":"section 3797u of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cd063b9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" inserted “, including co-occurring substance abuse and mental health problems,” after “abuse problems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" substituted “offenders, and other individuals under the jurisdiction of the court, with substance abuse problems” for “offenders with substance abuse problems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
