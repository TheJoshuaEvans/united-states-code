{"tag":"section","attrib":{"id":"id4cbd5005-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10387"},"text":null,"children":[{"tag":"num","attrib":{"value":"10387"},"text":"§ 10387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbd5006-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10387/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall have access for the purpose of audit and examination to any pertinent books, documents, papers, or records of a grant recipient under this subchapter and to the pertinent books, documents, papers, or records of State and local governments, persons, businesses, and other entities that are involved in programs, projects, or activities for which assistance is provided under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbd5007-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10387/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply with respect to audits and examinations conducted by the Comptroller General of the United States or by an authorized representative of the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd5008-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1707"},"text":"Pub. L. 90–351, title I, § 1707","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tI/s10003/a/3"},"text":"Pub. L. 103–322, title I, § 10003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1813"},"text":"108 Stat. 1813","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd5009-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd500a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd500b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796dd–6"},"text":"section 3796dd–6 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
