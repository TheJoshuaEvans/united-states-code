{"tag":"section","attrib":{"id":"id4cef8419-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11292"},"text":null,"children":[{"tag":"num","attrib":{"value":"11292"},"text":"§ 11292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cef841a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11292/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “missing child” means any individual less than 18 years of age whose whereabouts are unknown to such individual’s parent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef841b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11292/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Office of Juvenile Justice and Delinquency Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef841c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11292/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Center” means the National Center for Missing and Exploited Children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cef841d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11292/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “parent” includes a legal guardian or other individual who may lawfully exercise parental rights with respect to the child; and","children":[],"tai