{"tag":"section","attrib":{"id":"id4c972b2e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106"},"text":null,"children":[{"tag":"num","attrib":{"value":"10106"},"text":"§ 10106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Capacity Development Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4c972b2f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c972b30-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office a Community Capacity Development Office, headed by a Director appointed by the Attorney General. In carrying out the functions of the Office, the Director shall be subject to the authority, direction, and control of the Attorney General. Such authority, direction, and control may be delegated only to the Assistant Attorney General, without redelegation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b31-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Office shall be to provide training to actual and prospective participants under programs covered by section 10103(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text Note below."}],"tail":" of this title to assist such participants in understanding the substantive and procedural requirements for participating in such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be the exclusive element of the Department of Justice performing functions and activities for the purpose specified in paragraph (2). There are hereby transferred to the Office all functions and activities for such purpose performed immediately before ","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":", by any other element of the Department. This does not preclude a grant-making office from providing specialized training and technical assistance in its area of expertise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c972b33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Means","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall, in coordination with the heads of the other elements of the Department, carry out the purpose of the Office through the following means:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c972b34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting coordination of public and private efforts and resources within or available to States, units of local government, and neighborhood and community-based organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing information, training, and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing support for inter- and intra-agency task forces and other agreements and for assessment of the effectiveness of programs, projects, approaches, or practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing in the assessment of the effectiveness of neighborhood and community-based law enforcement and crime prevention strategies and techniques, in coordination with the National Institute of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other similar means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c972b39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Training referred to in subsection (a) shall be provided on a regional basis to groups of such participants. In a case in which remedial training is appropriate, as recommended by the Director or the head of any element of the Department, such training may be provided on a local basis to a single such participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c972b3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4c972b3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify grants under which clearly beneficial outcomes were obtained, and the characteristics of those grants that were responsible for obtaining those outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4c972b3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate those characteristics into the training provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4c972b3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"not ","children":[{"tag":"ref","attrib":{"idref":"fn002001"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002001"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" to exceed 3 percent of all funding made available for a fiscal year for the programs covered by section 10103(b) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title shall be reserved for the Community Capacity Development Office for the activities authorized by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4c972b3e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s106"},"text":"Pub. L. 90–351, title I, § 106","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1159/a"},"text":"Pub. L. 109–162, title XI, § 1159(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3116"},"text":"119 Stat. 3116","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/271/s8/f"},"text":"Pub. L. 109–271, § 8(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-08-12"},"text":"Aug. 12, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/766"},"text":"120 Stat. 766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4c972b3f-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4c972b40-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4c972b41-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10103/b"},"text":"Section 10103(b) of this title","children":[],"tail":", referred to in subsecs. (a)(2) and (e), probably should be a reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10109/b"},"text":"section 10109(b) of this title","children":[],"tail":" because section 10103(b) relates to Director assistance and section 10109(b) specifically sets out covered programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"January 5, 2006","children":[],"tail":", referred to in subsec. (a)(3), was in the original “the date of the enactment of this Act” and was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4c972b42-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3712e"},"text":"section 3712e of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4c972b43-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (a)(2), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/217"},"text":"Pub. L. 109–217","children":[],"tail":" substituted “section 3712a(b)” for “section 3712d(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4c972b44-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id4c972b45-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1159/b"},"text":"Pub. L. 109–162, title XI, § 1159(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3117"},"text":"119 Stat. 3117","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/162/tXI/s1159/b"},"text":"“This section [enacting this section] and the amendment made by this section take effect 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
