{"tag":"section","attrib":{"id":"id4cd06341-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10592"},"text":null,"children":[{"tag":"num","attrib":{"value":"10592"},"text":"§ 10592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Grants made to an entity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10591"},"text":"section 10591 of this title","children":[],"tail":" for a program described in such section may be used for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd06342-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10592/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, implementation, and expansion of prison-based family treatment programs in correctional facilities for incarcerated parents with minor children (except for any such parent who there is reasonable evidence to believe engaged in domestic violence or child abuse);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06343-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10592/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development, implementation, and expansion of residential substance abuse treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06344-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10592/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination between appropriate correctional facility representatives and the appropriate governmental agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06345-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10592/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments to public and nonprofit private entities to provide substance abuse treatment to nonviolent parent drug offenders participating in that program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06346-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10592/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries, personnel costs, facility costs, and other costs directly related to the operation of that program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd06347-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2922"},"text":"Pub. L. 90–351, title I, § 2922","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s113"},"text":"Pub. L. 110–199, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/675"},"text":"122 Stat. 675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd06348-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd06349-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd0634a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797s–1"},"text":"section 3797s–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cd0634b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cd0634c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" and requirements for grants made under such amendments, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60504"},"text":"section 60504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
