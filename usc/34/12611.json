{"tag":"section","attrib":{"id":"id4d17f379-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611"},"text":null,"children":[{"tag":"num","attrib":{"value":"12611"},"text":"§ 12611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicle theft prevention program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d17f37a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"September 13, 1994","children":[],"tail":", the Attorney General shall develop, in cooperation with the States, a national voluntary motor vehicle theft prevention program (in this section referred to as the “program”) under which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f37b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the owner of a motor vehicle may voluntarily sign a consent form with a participating State or locality in which the motor vehicle owner—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f37c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states that the vehicle is not normally operated under certain specified conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f37d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agrees to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d17f37e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" display program decals or devices on the owner’s vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d17f37f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit law enforcement officials in any State to stop the motor vehicle and take reasonable steps to determine whether the vehicle is being operated by or with the permission of the owner, if the vehicle is being operated under the specified conditions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f380-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating States and localities authorize law enforcement officials in the State or locality to stop motor vehicles displaying program decals or devices under specified conditions and take reasonable steps to determine whether the vehicle is being operated by or with the permission of the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f381-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uniform decal or device designs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f382-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The motor vehicle theft prevention program developed pursuant to this section shall include a uniform design or designs for decals or other devices to be displayed by motor vehicles participating in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f383-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of design","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The uniform design shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f384-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be highly visible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f385-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explicitly state that the motor vehicle to which it is affixed may be stopped under the specified conditions without additional grounds for establishing a reasonable suspicion that the vehicle is being operated unlawfully.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f386-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary consent form","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voluntary consent form used to enroll in the program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f387-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly state that participation in the program is voluntary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f388-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly explain that participation in the program means that, if the participating vehicle is being operated under the specified conditions, law enforcement officials may stop the vehicle and take reasonable steps to determine whether it is being operated by or with the consent of the owner, even if the law enforcement officials have no other basis for believing that the vehicle is being operated unlawfully;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f389-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an express statement that the vehicle is not normally operated under the specified conditions and that the operation of the vehicle under those conditions would provide sufficient grounds for a prudent law enforcement officer to reasonably believe that the vehicle was not being operated by or with the consent of the owner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f38a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include any additional information that the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f38b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified conditions under which stops may be authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f38c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall promulgate rules establishing the conditions under which participating motor vehicles may be authorized to be stopped under this section. These conditions may not be based on race, creed, color, national origin, gender, or age. These conditions may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f38d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of the vehicle during certain hours of the day; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f38e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of the vehicle under other circumstances that would provide a sufficient basis for establishing a reasonable suspicion that the vehicle was not being operated by the owner, or with the consent of the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f38f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" More than one set of conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may establish more than one set of conditions under which participating motor vehicles may be stopped. If more than one set of conditions is established, a separate consent form and a separate design for program decals or devices shall be established for each set of conditions. The Attorney General may choose to satisfy the requirement of a separate design for program decals or devices under this paragraph by the use of a design color that is clearly distinguishable from other design colors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f390-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No new conditions without consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the program has begun, the conditions under which a vehicle may be stopped if affixed with a certain decal or device design may not be expanded without the consent of the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f391-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited participation by States and localities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or locality need not authorize the stopping of motor vehicles under all sets of conditions specified under the program in order to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f392-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicles for hire","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f393-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to lessees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who is in the business of renting or leasing motor vehicles and who rents or leases a motor vehicle on which a program decal or device is affixed shall, prior to transferring possession of the vehicle, notify the person to whom the motor vehicle is rented or leased about the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f394-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required by this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d17f395-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f396-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in a prominent format to be determined by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d17f397-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the possibility that if the motor vehicle is operated under the specified conditions, the vehicle may be stopped by law enforcement officials even if the officials have no other basis for believing that the vehicle is being operated unlawfully.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f398-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine for failure to provide notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Failure to provide proper notice under this subsection shall be punishable by a fine not to exceed $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f399-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of police","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of participating in the program, a State or locality must agree to take reasonable steps to ensure that law enforcement officials throughout the State or locality are familiar with the program, and with the conditions under which motor vehicles may be stopped under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f39a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall promulgate regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d17f39b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to carry out this section.","children":[{"tag":"ref","attrib":{"idref":"fn002142"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a dash."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d17f39c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f39d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,700,000 for fiscal year 1997; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d17f39e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12611/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,800,000 for fiscal year 1998.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d17f39f-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXII/s220002"},"text":"Pub. L. 103–322, title XXII, § 220002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2074"},"text":"108 Stat. 2074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d17f3a0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d17f3a1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d17f3a2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14171"},"text":"section 14171 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
