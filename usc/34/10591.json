{"tag":"section","attrib":{"id":"id4cd06337-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10591"},"text":null,"children":[{"tag":"num","attrib":{"value":"10591"},"text":"§ 10591.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make grants to States, units of local government, territories, nonprofit organizations, and Indian Tribes to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd06338-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10591/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, implement, and expand comprehensive and clinically-appropriate family-based substance abuse treatment programs as alternatives to incarceration for nonviolent parent drug offenders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd06339-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10591/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" provide prison-based family treatment programs for incarcerated parents of minor children or pregnant women."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd0633a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2921"},"text":"Pub. L. 90–351, title I, § 2921","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s113"},"text":"Pub. L. 110–199, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/674"},"text":"122 Stat. 674","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tII/s201/c/1"},"text":"Pub. L. 114–198, title II, § 201(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/714"},"text":"130 Stat. 714","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/b/1"},"text":"Pub. L. 115–391, title V, § 502(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5228"},"text":"132 Stat. 5228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd0633b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd0633c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd0633d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797s"},"text":"section 3797s of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cd0633e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"te