{"tag":"section","attrib":{"id":"id4cbd5011-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389"},"text":null,"children":[{"tag":"num","attrib":{"value":"10389"},"text":"§ 10389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbd5012-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “career law enforcement officer” means a person hired on a permanent basis who is authorized by law or by a State or local public agency to engage in or supervise the prevention, detection, or investigation of violations of criminal laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5013-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “citizens’ police academy” means a program by local law enforcement agencies or private nonprofit organizations in which citizens, especially those who participate in neighborhood watch programs, are trained in ways of facilitating communication between the community and local law enforcement in the prevention of crime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5014-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” means a tribe, band, pueblo, nation, or other organized group or community of Indians, including an Alaska Native village (as defined in or established under the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"43 U.S.C. 1601","children":[],"tail":" et seq.)), that is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd5015-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “school resource officer” means a career law enforcement officer, with sworn authority, deployed in community-oriented policing, and assigned by the employing police department or agency to work in collaboration with schools and community-based organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cbd5016-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address crime and disorder problems, gangs, and drug activities affecting or occurring in or around an elementary or secondary school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd5017-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or expand crime prevention efforts for students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd5018-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate likely school-age victims in crime prevention and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd5019-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or expand community justice initiatives for students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd501a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train students in conflict resolution, restorative justice, and crime awareness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd501b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the identification of physical changes in the environment that may reduce crime in or around the school; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cbd501c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in developing school policy that addresses crime and to recommend procedural changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd501d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “commercial sex act” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd501e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “minor” means an individual who has not attained the age of 18 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbd501f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10389/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “severe form of trafficking in persons” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbd5020-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1709"},"text":"Pub. L. 90–351, title I, § 1709","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tI/s10003/a/3"},"text":"Pub. L. 103–322, title I, § 10003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1813"},"text":"108 Stat. 1813","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/302/s1/2"},"text":"Pub. L. 105–302, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2841"},"text":"112 Stat. 2841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tVI/s601/2"},"text":"Pub. L. 114–22, title VI, § 601(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/259"},"text":"129 Stat. 259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbd5021-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbd5022-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4cbd5023-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203/s2"},"text":"Pub. L. 92–203, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbd5024-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796dd–8"},"text":"section 3796dd–8 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbd5025-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22"},"text":"Pub. L. 114–22","children":[],"tail":" added pars. (5) to (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/302"},"text":"Pub. L. 105–302","children":[],"tail":" designated first three undesignated paragraphs as pars. (1) to (3), respectively, and added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
