{"tag":"section","attrib":{"id":"id4cf1cdac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a"},"text":null,"children":[{"tag":"num","attrib":{"value":"11295a"},"text":"§ 11295a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf1cdad-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293/b"},"text":"section 11293(b) of this title","children":[],"tail":", the grant recipient shall, based solely on reports received by the grantee and not involving any data collection by the grantee other than those reports, annually provide to the Administrator and make available to the general public, as appropriate—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf1cdae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children nationwide who are reported to the grantee as missing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children nationwide who are reported to the grantee as victims of non-family abductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children nationwide who are reported to the grantee as victims of family abductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of missing children recovered nationwide whose recovery was reported to the grantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children nationwide who are reported to the grantee as missing from State-sponsored care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children nationwide who are reported to the grantee as missing from State-sponsored care whose recovery was reported to the grantee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of children nationwide who are reported to the grantee as missing from State-sponsored care and are likely victims of child sex trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf1cdb5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incidence of attempted child abductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s11293/b"},"text":"section 11293(b) of this title","children":[],"tail":", the grant recipient shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf1cdb6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track the incidence of attempted child abductions in order to identify links and patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such information to law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf1cdb8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such information available to the general public, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf1cdb9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11295a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for forensic partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p