{"tag":"section","attrib":{"id":"id4d5d130e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50108"},"text":null,"children":[{"tag":"num","attrib":{"value":"50108"},"text":"§ 50108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5d130f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each recipient of Federal law enforcement assistance provided under this chapter shall keep such records as the Attorney General may prescribe to facilitate an effective audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5d1310-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s50108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General and the Comptroller General of the United States shall have access, for the purpose of audit and examination, to any books, documents, and records of recipients of Federal law enforcement assistance provided under this chapter which, in the opinion of the Attorney General or the Comptroller General, are related to the receipt or use of such assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5d1311-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s609T"},"text":"Pub. L. 98–473, title II, § 609T","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2106"},"text":"98 Stat. 2106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5d1312-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5d1313-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5d1314-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10508"},"text":"section 10508 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
