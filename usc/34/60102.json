{"tag":"section","attrib":{"id":"id4d61f4f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60102"},"text":null,"children":[{"tag":"num","attrib":{"value":"60102"},"text":"§ 60102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In sections 60101 to 60104 of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d61f4f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime of violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “crime of violence” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s924/c/3"},"text":"section 924(c)(3) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f4f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private prisoner transport company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private prisoner transport company” means any entity, other than the United States, a State, or an inferior political subdivision of a State, which engages in the business of the transporting for compensation, individuals committed to the custody of any State or of an inferior political subdivision of a State, or any attempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d61f4f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violent prisoner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “violent prisoner” means any individual in the custody of a State or an inferior political subdivision of a State who has previously been convicted of or is currently charged with a crime of violence or any similar statute of a State or the inferior political subdivisions of a State, or any attempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d61f4f4-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/560/s3"},"text":"Pub. L. 106–560, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2784"},"text":"114 Stat. 2784","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d61f4f5-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d61f4f6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d61f4f7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13726a"},"text":"section 13726a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
