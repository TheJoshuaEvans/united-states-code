{"tag":"section","attrib":{"id":"id4d66b06d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60908"},"text":null,"children":[{"tag":"num","attrib":{"value":"60908"},"text":"§ 60908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall require an agency to provide information that would endanger the safety of any person, unreasonably impede an ongoing investigation, violate a court order, or violate legal obligations regarding privacy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d66b06e-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/164/s9"},"text":"Pub. L. 117–164, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-03"},"text":"Aug. 3, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1360"},"text":"136 Stat. 1360","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
