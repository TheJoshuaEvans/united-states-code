{"tag":"section","attrib":{"id":"id4d23da7b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141"},"text":null,"children":[{"tag":"num","attrib":{"value":"20141"},"text":"§ 20141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services to victims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d23da7c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of responsible officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each department and agency of the United States engaged in the detection, investigation, or prosecution of crime shall designate by names and office titles the persons who will be responsible for identifying the victims of crime and performing the services described in subsection (c) at each stage of a criminal case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23da7d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of victims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the earliest opportunity after the detection of a crime at which it may be done without interfering with an investigation, a responsible official shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23da7e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the victim or victims of a crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the victims of their right to receive, on request, the services described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform each victim of the name, title, and business address and telephone number of the responsible official to whom the victim should address a request for each of the services described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23da81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23da82-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A responsible official shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da83-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform a victim of the place where the victim may receive emergency medical and social services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform a victim of any restitution or other relief to which the victim may be entitled under this or any other law and ","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “the”."}],"tail":" manner in which such relief may be obtained;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform a victim of public and private programs that are available to provide counseling, treatment, and other support to the victim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist a victim in contacting the persons who are responsible for providing the services and relief described in subparagraphs (A), (B), and (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A responsible official shall arrange for a victim to receive reasonable protection from a suspected offender and persons acting in concert with or at the behest of the suspected offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During the investigation and prosecution of a crime, a responsible official shall provide a victim the earliest possible notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the investigation of the crime, to the extent it is appropriate to inform the victim and to the extent that it will not interfere with the investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arrest of a suspected offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the filing of charges against a suspected offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduling of each court proceeding that the witness is either required to attend or, under section 10606(b)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002166"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002166"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 42, is entitled to attend;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the release or detention status of an offender or suspected offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance of a plea of guilty or nolo contendere or the rendering of a verdict after trial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sentence imposed on an offender, including the date on which the offender will be eligible for parole.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During court proceedings, a responsible official shall ensure that a victim is provided a waiting area removed from and out of the sight and hearing of the defendant and defense witnesses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After trial, a responsible official shall provide a victim the earliest possible notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduling of a parole hearing for the offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the escape, work release, furlough, or any other form of release from custody of the offender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the death of the offender, if the offender dies while in custody.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At all times, a responsible official shall ensure that any property of a victim that is being held for evidentiary purposes be maintained in good condition and returned to the victim as soon as it is no longer needed for evidentiary purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General or the head of another department or agency that conducts an investigation of a sexual assault shall pay, either directly or by reimbursement of payment by the victim, the cost of a physical examination of the victim which an investigating officer determines was necessary or useful for evidentiary purposes. The Attorney General shall provide for the payment of the cost of up to 2 anonymous and confidential tests of the victim for sexually transmitted diseases, including HIV, gonorrhea, herpes, chlamydia, and syphilis, during the 12 months following sexual assaults that pose a risk of transmission, and the cost of a counseling session by a medically trained professional on the accuracy of such tests and the risk of transmission of sexually transmitted diseases to the victim as the result of the assault. A victim may waive anonymity and confidentiality of any tests paid for under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A responsible official shall provide the victim with general information regarding the corrections process, including information about work release, furlough, probation, and eligibility for each.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23da98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cause of action or defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not create a cause of action or defense in favor of any person arising out of the failure of a responsible person to provide information as required by subsection (b) or (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d23da99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d23da9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “responsible official” means a person designated pursuant to subsection (a) to perform the functions of a responsible official under that section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d23da9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “victim” means a person that has suffered direct physical, emotional, or pecuniary harm as a result of the commission of a crime, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d23da9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a victim that is an institutional entity, an authorized representative of the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d23da9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a victim who is under 18 years of age, incompetent, incapacitated, or deceased, one of the following (in order of preference):","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d23da9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a spouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23da9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legal guardian;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23daa0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23daa1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23daa2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sibling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23daa3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another family member; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d23daa4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20141/e/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another person designated by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d23daa5-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tV/s503"},"text":"Pub. L. 101–647, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4820"},"text":"104 Stat. 4820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40503/a"},"text":"Pub. L. 103–322, title IV, § 40503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1946"},"text":"108 Stat. 1946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d23daa6-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d23daa7-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d23daa8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10606/b/4"},"text":"Section 10606(b)(4) of title 42","children":[],"tail":", referred to in subsec. (c)(3)(D), was in the original “section 1102(b)(4)”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s1102/b/4"},"text":"section 1102(b)(4) of Pub. L. 101–647","children":[],"tail":", which has been translated as reading "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s502/b/4"},"text":"section 502(b)(4) of Pub. L. 101–647","children":[],"tail":" to reflect the probable intent of Congress because "},{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":" does not contain a section 1102 and section 502(b)(4) relates to the right of crime victims to be present at public court proceedings. "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10606"},"text":"Section 10606 of Title 42","children":[],"tail":", The Public Health and Welfare, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tI/s102/c"},"text":"Pub. L. 108–405, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2264"},"text":"118 Stat. 2264","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d23daa9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10607"},"text":"section 10607 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d23daaa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" inserted at end “The Attorney General shall provide for the payment of the cost of up to 2 anonymous and confidential tests of the victim for sexually transmitted diseases, including HIV, gonorrhea, herpes, chlamydia, and syphilis, during the 12 months following sexual assaults that pose a risk of transmission, and the cost of a counseling session by a medically trained professional on the accuracy of such tests and the risk of transmission of sexually transmitted diseases to the victim as the result of the assault. A victim may waive anonymity and confidentiality of any tests paid for under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
