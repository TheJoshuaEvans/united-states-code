{"tag":"section","attrib":{"id":"id4d5ac991-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507"},"text":null,"children":[{"tag":"num","attrib":{"value":"41507"},"text":"§ 41507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Gang Intelligence Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5ac992-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall establish a National Gang Intelligence Center and gang information database to be housed at and administered by the Federal Bureau of Investigation to collect, analyze, and disseminate gang activity information from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5ac993-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac994-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Alcohol, Tobacco, Firearms, and Explosives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac995-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Drug Enforcement Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac996-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Prisons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac997-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Marshals Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac998-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Directorate of Border and Transportation Security of the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac999-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Housing and Urban Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac99a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Justice Services of the Bureau of Indian Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac99b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal, State, and local law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac99c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, tribal, State, and local prosecutors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac99d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, tribal, State, and local probation and parole offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac99e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, tribal, State, and local prisons and jails; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac99f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac9a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center established under subsection (a) shall make available the information referred to in subsection (a) to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d5ac9a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, tribal, State, and local law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac9a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, tribal, State, and local corrections agencies and penal institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac9a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, tribal, State, and local prosecutorial agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d5ac9a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac9a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center established under subsection (a) shall annually submit to Congress a report on gang activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac9a6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for fiscal year 2006 and for each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5ac9a7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1107"},"text":"Pub. L. 109–162, title XI, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3093"},"text":"119 Stat. 3093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/211/tII/s251/a"},"text":"Pub. L. 111–211, title II, § 251(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-29"},"text":"July 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2297"},"text":"124 Stat. 2297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5ac9a8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5ac9a9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5ac9aa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d5ac9ab-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s251/a/1/A"},"text":"Pub. L. 111–211, § 251(a)(1)(A)","children":[],"tail":", (B), added par. (8) and redesignated former par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s251/a/1/A"},"text":"Pub. L. 111–211, § 251(a)(1)(A)","children":[],"tail":", (C), redesignated par. (8) as (9) and substituted “tribal, State,” for “State”. Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s251/a/1/A"},"text":"Pub. L. 111–211, § 251(a)(1)(A)","children":[],"tail":", (D), redesignated pars. (9) to (11) as (10) to (12), respectively, and inserted “tribal,” before “State,” wherever appearing. Former par. (12) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s251/a/1/A"},"text":"Pub. L. 111–211, § 251(a)(1)(A)","children":[],"tail":", redesignated par. (12) as (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/211/s251/a/2"},"text":"Pub. L. 111–211, § 251(a)(2)","children":[],"tail":", inserted “tribal,” before “State,” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
