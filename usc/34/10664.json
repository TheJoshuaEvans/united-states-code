{"tag":"section","attrib":{"id":"id4cd78f57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664"},"text":null,"children":[{"tag":"num","attrib":{"value":"10664"},"text":"§ 10664.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to award competitive grants to address methamphetamine use by pregnant and parenting women offenders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd78f58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and program authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award competitive grants to address the use of methamphetamine among pregnant and parenting women offenders to promote public safety, public health, family permanence and well being.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes and program authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this section shall be used to facilitate or enhance and ","children":[{"tag":"ref","attrib":{"idref":"fn002055"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002055"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":" collaboration between the criminal justice, child welfare, and State, territorial, or Tribal substance abuse systems in order to carry out programs to address the use of methamphetamine drugs by pregnant and parenting women offenders."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child welfare agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child welfare agency” means the State, territorial, or Tribal agency responsible for child or family services and welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal justice agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “criminal justice agency” means an agency of the State, territory, Indian tribe, or local government or its contracted agency that is responsible for detection, arrest, enforcement, prosecution, defense, adjudication, incarceration, probation, or parole relating to the violation of the criminal laws of that State, territory, Indian tribe, or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/b/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002056"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002056"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be par. “(3)”."}],"tail":" Indian tribe"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10554"},"text":"section 10554 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant may be awarded under this section unless an application has been submitted to, and approved by, the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant under this section shall be submitted in such form, and contain such information, as the Attorney General,","children":[{"tag":"ref","attrib":{"idref":"fn002057"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" may prescribe by regulation or guidelines."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make grants to States, territories, and Indian tribes. Applicants must demonstrate extensive collaboration with the State criminal justice agency and child welfare agency in the planning and implementation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with the regulations or guidelines established by the Attorney General in consultation with the Secretary of Health and Human Services, each application for a grant under this section shall contain a plan to expand the services for pregnant and parenting women offenders who are pregnant women or women with dependent children for the use of methamphetamine or methamphetamine and other drugs and include the following in the plan:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cd78f64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of how the applicant will work jointly with the criminal justice and child welfare agencies needs ","children":[{"tag":"ref","attrib":{"idref":"fn002058"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002058"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. The word “needs” probably should not appear."}],"tail":" associated with the use of methamphetamine or methamphetamine and other drugs by pregnant and parenting women offenders to promote family stability and permanence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the nature and the extent of the problem of methamphetamine use by pregnant and parenting women offenders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification that the State has involved counties, Indian tribes, and other units of local government, when appropriate, in the development, expansion, modification, operation or improvement of proposed programs to address the use, manufacture, or sale of methamphetamine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification that funds received under this section will be used to supplement, not supplant, other Federal, State, Tribal, and local funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cd78f68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of clinically appropriate practices and procedures to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cd78f69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screen and assess pregnant and parenting women offenders for addiction to methamphetamine and other drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when clinically appropriate for both the women and children, provide family treatment for pregnant and parenting women offenders, with clinically appropriate services in the same location to promote family permanence and self sufficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cd78f6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/c/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a process to enhance or ensure the abilities of the child welfare agency, criminal justice agency and State substance agency to work together to re-unite families when appropriate in the case where family treatment is not provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grant shall be a three-year grant. Successful applicants may reapply for only one additional three-year funding cycle and the Attorney General may approve such applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance accountability; reports and evaluations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78f6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Successful applicants shall submit to the Attorney General a report on the activities carried out under the grant at the end of each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78f6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months at ","children":[{"tag":"ref","attrib":{"idref":"fn002059"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. Probably should be “after”."}],"tail":" the end of the 3 year funding cycle under this section, the Attorney General shall submit a report to the appropriate committees of jurisdiction that summarizes the results of the evaluations conducted by recipients and recommendations for further legislative action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78f70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10664/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd78f71-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tVII/s756"},"text":"Pub. L. 109–177, title VII, § 756","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/275"},"text":"120 Stat. 275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dB/tII/s220/c"},"text":"Pub. L. 110–161, div. B, title II, § 220(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1916"},"text":"121 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd78f72-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd78f73-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd78f74-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Combat Methamphetamine Epidemic Act of 2005, and also as part of the USA PATRIOT Improvement and Reauthorization Act of 2005, and not as part of title I of the Omnibus Crime Control and Safe Streets Act of 1968 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797cc–3"},"text":"section 3797cc–3 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cd78f75-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/1"},"text":"Pub. L. 110–161, § 220(c)(1)","children":[],"tail":", inserted “, territorial, or Tribal” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/2/A"},"text":"Pub. L. 110–161, § 220(c)(2)(A)","children":[],"tail":", inserted “, territorial, or Tribal” after “State” and substituted “or” for “and/or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/2/B"},"text":"Pub. L. 110–161, § 220(c)(2)(B)","children":[],"tail":", inserted “, territory, Indian tribe,” after “agency of the State” and after “criminal laws of that State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/2/C"},"text":"Pub. L. 110–161, § 220(c)(2)(C)","children":[],"tail":", added par. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/3/A"},"text":"Pub. L. 110–161, § 220(c)(3)(A)","children":[],"tail":", substituted “Indian tribes” for “Indian Tribes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/3/B/i"},"text":"Pub. L. 110–161, § 220(c)(3)(B)(i)","children":[],"tail":", struck out “State’s” after “expand the” and substituted “women or” for “women and/or” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/3/B/ii"},"text":"Pub. L. 110–161, § 220(c)(3)(B)(ii)","children":[],"tail":", struck out “State” after “with the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/3/B/iii"},"text":"Pub. L. 110–161, § 220(c)(3)(B)(iii)","children":[],"tail":", inserted “, Indian tribes,” after “involved counties”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s220/c/3/B/iv"},"text":"Pub. L. 110–161, § 220(c)(3)(B)(iv)","children":[],"tail":", inserted “, Tribal” after “Federal, State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
