{"tag":"section","attrib":{"id":"id4d34a444-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20918"},"text":null,"children":[{"tag":"num","attrib":{"value":"20918"},"text":"§ 20918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic in person verification","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A sex offender shall appear in person, allow the jurisdiction to take a current photograph, and verify the information in each registry in which that offender is required to be registered not less frequently than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d34a445-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20918/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each year, if the offender is a tier I sex offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a446-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20918/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every 6 months, if the offender is a tier II sex offender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d34a447-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20918/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every 3 months, if the offender is a tier III sex offender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d34a448-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s116"},"text":"Pub. L. 109–248, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/595"},"text":"120 Stat. 595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d34a449-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d34a44a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d34a44b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16916"},"text":"section 16916 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
