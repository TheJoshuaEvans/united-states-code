{"tag":"section","attrib":{"id":"id4d66b014-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60555"},"text":null,"children":[{"tag":"num","attrib":{"value":"60555"},"text":"§ 60555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Attorney General to carry out sections 60551, 60552, and 60553 of this title, $5,000,000 for each of the fiscal years 2019, 2020, 2021, 2022, and 2023.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d66b015-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s245"},"text":"Pub. L. 110–199, title II, § 245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/692"},"text":"122 Stat. 692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s504/e"},"text":"Pub. L. 115–391, title V, § 504(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5233"},"text":"132 Stat. 5233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d66b016-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d66b017-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d66b018-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17555"},"text":"section 17555 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d66b019-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":" substituted “and 60553 of this title, $5,000,000 for each of the fiscal years 2019, 2020, 2021, 2022, and 2023” for “60553, and 60554 of this title, $10,000,000 for each of the fiscal years 2009 and 2010”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
