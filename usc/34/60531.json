{"tag":"section","attrib":{"id":"id4d643f68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531"},"text":null,"children":[{"tag":"num","attrib":{"value":"60531"},"text":"§ 60531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based mentoring and transitional service grants to nonprofit organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d643f69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this section, the Attorney General shall make grants to nonprofit organizations and Indian Tribes for the purpose of providing transitional services essential to reintegrating offenders into the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f6a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under subsection (a) may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f6b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentoring adult and juvenile offenders during incarceration, through transition back to the community, and post-release;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f6c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transitional services to assist in the reintegration of offenders into the community, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643f6d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational, literacy, and vocational, services and the Transitional Jobs strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f6e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance abuse treatment and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f6f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated supervision and services for offenders, including physical health care and comprehensive housing and mental health care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f70-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f71-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validated assessment tools to assess the risk factors of returning inmates; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f72-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training regarding offender and victims issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f73-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; priority consideration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a nonprofit organization or Indian Tribe shall submit an application to the Attorney General at such time, in such manner, and accompanied by such information as the Attorney General may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f75-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Priority consideration shall be given to any application under this section that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643f76-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a plan to implement activities that have been demonstrated effective in facilitating the successful reentry of offenders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f77-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for an independent evaluation that includes, to the maximum extent feasible, random assignment of offenders to program delivery and control groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f78-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic performance outcomes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall require each applicant under this section to identify specific performance outcomes related to the long-term goal of stabilizing communities by reducing recidivism (using a measure that is consistent with the research undertaken by the Bureau of Justice Statistics under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s60551/b/6"},"text":"section 60551(b)(6) of this title","children":[],"tail":"), and reintegrating offenders into the community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f79-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that receives a grant under subsection (a) during a fiscal year shall, not later than the last day of the following fiscal year, submit to the Attorney General a report that describes and assesses the uses of that grant during that fiscal year and that identifies the progress of the grantee toward achieving its strategic performance outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f7a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60531/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Attorney General to carry out this section $15,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f7b-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s211"},"text":"Pub. L. 110–199, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/679"},"text":"122 Stat. 679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tXIV/s14009/b"},"text":"Pub. L. 114–255, div. B, title XIV, § 14009(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1297"},"text":"130 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/f/1"},"text":"Pub. L. 115–391, title V, § 502(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5230"},"text":"132 Stat. 5230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f7c-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f7d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d643f7e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17531"},"text":"section 17531 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d643f7f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/f/1/A"},"text":"Pub. L. 115–391, § 502(f)(1)(A)","children":[],"tail":", substituted “Community-based mentoring and transitional service grants to nonprofit organizations” for “Mentoring grants to nonprofit organizations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/f/1/B"},"text":"Pub. L. 115–391, § 502(f)(1)(B)","children":[],"tail":", struck out “mentoring and other” before “transitional services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/f/1/C"},"text":"Pub. L. 115–391, § 502(f)(1)(C)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “transitional services to assist in the reintegration of offenders into the community, including mental health care; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391/s502/f/1/D"},"text":"Pub. L. 115–391, § 502(f)(1)(D)","children":[],"tail":", substituted “this section $15,000,000 for each of fiscal years 2019 through 2023.” for “this section $15,000,000 for each of fiscal years 2009 and 2010.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" inserted “, including mental health care” after “community”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
