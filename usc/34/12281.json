{"tag":"section","attrib":{"id":"id4cfdb5cd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281"},"text":null,"children":[{"tag":"num","attrib":{"value":"12281"},"text":"§ 12281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gang Resistance Education and Training projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cfdb5ce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb5cf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish not less than 50 Gang Resistance Education and Training (GREAT) projects, to be located in communities across the country, in addition to the number of projects currently funded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5d0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Communities identified for such GREAT projects shall be selected by the Attorney General on the basis of gang-related activity in that particular community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5d1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of assistance per project; allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall make available not less than $800,000 per project, subject to the availability of appropriations, and such funds shall be allocated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cfdb5d2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent to the affected State and local law enforcement and prevention organizations participating in such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cfdb5d3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent to the Bureau of Alcohol, Tobacco, Firearms, and Explosives, Department of Justice for salaries, expenses, and associated administrative costs for operating and overseeing such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cfdb5d4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb5d5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5d6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5d7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5d8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb5d9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12281/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb5da-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s32401"},"text":"Pub. L. 103–322, title III, § 32401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1902"},"text":"108 Stat. 1902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXI/s1112/p"},"text":"Pub. L. 107–296, title XI, § 1112(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2278"},"text":"116 Stat. 2278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1188"},"text":"Pub. L. 109–162, title XI, § 1188","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3128"},"text":"119 Stat. 3128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb5db-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb5dc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb5dd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13921"},"text":"section 13921 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cfdb5de-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", which directed the amendment of section 32401(b) of the Violent Crime Control Act of 1994 by adding pars. (1) to (5) and striking out former pars. (1) to (6), was executed by making the amendments to this section, which is section 32401(b) of the Violent Crime Control and Law Enforcement Act of 1994, to reflect the probable intent of Congress. Former pars. (1) to (6) authorized appropriations for fiscal years 1995 through 2000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1112/p/1"},"text":"Pub. L. 107–296, § 1112(p)(1)","children":[],"tail":", substituted “Attorney General” for “Secretary of the Treasury” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1112/p/2"},"text":"Pub. L. 107–296, § 1112(p)(2)","children":[],"tail":", substituted “Bureau of Alcohol, Tobacco, Firearms, and Explosives, Department of Justice” for “Bureau of Alcohol, Tobacco and Firearms”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cfdb5df-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cfdb5e0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
