{"tag":"section","attrib":{"id":"id4d0296f9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12313"},"text":null,"children":[{"tag":"num","attrib":{"value":"12313"},"text":"§ 12313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General shall compile information regarding sex offender treatment programs and ensure that information regarding community treatment programs in the community into which a convicted sex offender is released is made available to each person serving a sentence of imprisonment in a Federal penal or correctional institution for a commission of an offense under chapter 109A of title 18 or for the commission of a similar offense, including halfway houses and psychiatric institutions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d0296fa-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40154"},"text":"Pub. L. 103–322, title IV, § 40154","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1922"},"text":"108 Stat. 1922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d0296fb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d0296fc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d0296fd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13943"},"text":"section 13943 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
