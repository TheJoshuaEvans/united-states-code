{"tag":"section","attrib":{"id":"id4cbfc224-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423"},"text":null,"children":[{"tag":"num","attrib":{"value":"10423"},"text":"§ 10423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of State applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cbfc225-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10421"},"text":"section 10421 of this title","children":[],"tail":" to carry out the projects described in the application submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10422"},"text":"section 10422 of this title","children":[],"tail":" upon determining that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cbfc226-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application is consistent with the requirements of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cbfc227-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the approval of the application the Attorney General has made an affirmative finding in writing that the proposed project has been reviewed in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc228-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each application submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10422"},"text":"section 10422 of this title","children":[],"tail":" shall be considered approved, in whole or in part, by the Attorney General not later than 90 days after first received unless the Attorney General informs the applicant of specific reasons for disapproval."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc229-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds received under this subchapter shall not be used for land acquisition or construction projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc22a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval notice and reconsideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall not disapprove any application without first affording the applicant reasonable notice and an opportunity for reconsideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cbfc22b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10423/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for partnerships with community-based drug treatment programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In considering an application submitted by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10422"},"text":"section 10422 of this title","children":[],"tail":", the Attorney General shall give priority to an application that involves a partnership between the State and a community-based drug treatment program within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cbfc22c-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s1903"},"text":"Pub. L. 90–351, title I, § 1903","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s32101/a/3"},"text":"Pub. L. 103–322, title III, § 32101(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1899"},"text":"108 Stat. 1899","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1145/c"},"text":"Pub. L. 109–162, title XI, § 1145(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3112"},"text":"119 Stat. 3112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cbfc22d-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cbfc22e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cbfc22f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3796ff–2"},"text":"section 3796ff–2 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cbfc230-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cbfc231-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4cbfc232-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"Oct. 1, 2006","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1147"},"text":"section 1147 of Pub. L. 109–162","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10422"},"text":"section 10422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
