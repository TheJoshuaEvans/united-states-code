{"tag":"section","attrib":{"id":"id4cf6887e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314"},"text":null,"children":[{"tag":"num","attrib":{"value":"11314"},"text":"§ 11314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for tribal delinquency prevention and response programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf6887f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make grants under this section, on a competitive basis, to eligible Indian Tribes (or consortia of Indian Tribes) as described in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf68880-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to support and enhance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf68881-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tribal juvenile delinquency prevention services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf68882-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of Indian Tribes to respond to, and care for, at-risk or delinquent youth upon release; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68883-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage accountability of Indian tribal governments with respect to preventing juvenile delinquency, and responding to, and caring for, juvenile offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf68884-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible Indian Tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, an Indian Tribe or consortium of Indian Tribes shall submit to the Administrator an application in such form as the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf68885-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants under this section, the Administrator shall take into consideration, with respect to the Indian Tribe to be served, the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf68886-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" juvenile delinquency rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68887-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" school dropout rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf68888-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" number of youth at risk of delinquency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf68889-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount available for a fiscal year to carry out this subchapter, 11 percent shall be available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf6888a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tV/s505"},"text":"Pub. L. 93–415, title V, § 505","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/385/tIII/s305"},"text":"Pub. L. 115–385, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5150"},"text":"132 Stat. 5150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf6888b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf6888c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"