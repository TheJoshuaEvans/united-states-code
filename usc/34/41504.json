{"tag":"section","attrib":{"id":"id4d5ac970-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41504"},"text":null,"children":[{"tag":"num","attrib":{"value":"41504"},"text":"§ 41504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project Safe Neighborhoods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d5ac971-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall establish a program for each United States Attorney to provide for coordination with State and local law enforcement officials in the identification and prosecution of violations of Federal firearms laws including school gun violence and juvenile gun offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d5ac972-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s41504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for hiring 94 additional Assistant United States Attorneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $9,000,000 for fiscal year 2002 to hire an additional Assistant United States Attorney in each United States Attorney Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d5ac973-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tI/s104"},"text":"Pub. L. 107–273, div. A, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1766"},"text":"116 Stat. 1766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d5ac974-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d5ac975-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d5ac976-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s509"},"text":"section 509 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
