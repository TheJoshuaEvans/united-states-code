{"tag":"section","attrib":{"id":"id4d28bcb3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303"},"text":null,"children":[{"tag":"num","attrib":{"value":"20303"},"text":"§ 20303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional children’s advocacy centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d28bcb4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and maintenance of regional children’s advocacy program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish and maintain a children’s advocacy program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d28bcb5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus attention on child victims by assisting communities in developing child-focused, community-oriented, facility-based programs designed to improve the resources available to children and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcb6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance coordination among community agencies and professionals involved in the intervention, prevention, prosecution, and investigation systems that respond to child abuse cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcb7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train physicians and other health care and mental health care professionals, law enforcement officers, child protective service workers, forensic interviewers, prosecutors, victim advocates, multidisciplinary team leadership, and children’s advocacy center staff, in the multidisciplinary approach to child abuse so that trained personnel will be available to provide support to community agencies and professionals involved in the intervention, prevention, prosecution, and investigation systems that respond to child abuse cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcb8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, training, coordination, and organizational capacity support for State chapters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcb9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collaborate with State chapters to provide training, technical assistance, coordination, organizational capacity support, and oversight of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bcba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local children’s advocacy centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcbb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communities that want to develop local children’s advocacy centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d28bcbc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of regional children’s advocacy program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d28bcbd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bcbe-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain regional children’s advocacy program centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcbf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund existing regional centers with expertise in multidisciplinary team investigation, trauma-informed interventions, and evidence-informed treatment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for the purpose of enabling grant recipients to provide information, services, training and technical assistance to aid communities in establishing and maintaining multidisciplinary programs that respond to child abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcc0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bcc1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist communities, local children’s advocacy centers, multidisciplinary teams, and State chapters—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d28bcc2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing and expanding a comprehensive, multidisciplinary response to child abuse that is designed to meet the needs of child victims and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcc3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in promoting the effective delivery of the evidence-informed Children’s Advocacy Center Model and the multidisciplinary response to child abuse, including best practices in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d28bcc4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizational support and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d28bcc5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programmatic evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d28bcc6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial oversight of Federal funding;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcc7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in establishing child-friendly facilities for the investigation and intervention in child abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in preventing or reducing trauma to children caused by duplicative contacts with community professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in providing families with needed services and assisting them in regaining maximum functioning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in maintaining open communication and case coordination among community professionals and agencies involved in child protection efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bccb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordinating and tracking investigative, preventive, prosecutorial, and treatment efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bccc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in obtaining information useful for criminal and civil proceedings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bccd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in holding offenders accountable through improved prosecution of child abuse cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcce-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in enhancing professional skills necessary to effectively respond to cases of child abuse through training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bccf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in enhancing community understanding of child abuse; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcd0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training and technical assistance to local children’s advocacy centers, interested communities, and chapters in its census region that are grant recipients under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20304"},"text":"section 20304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d28bcd1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of regional children’s advocacy program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d28bcd2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of proposals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1992-11-04"},"text":"November 4, 1992","children":[],"tail":", the Administrator shall solicit proposals for assistance under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcd3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order for a proposal to be selected, the Administrator may require an applicant to have in existence, at the time the proposal is submitted, 1 or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bcd4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A proven record in conducting activities of the kinds described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcd5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A facility where children who are victims of sexual or physical abuse and their nonoffending family members can go for the purpose of investigation and intervention in child abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcd6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Multidisciplinary staff experienced in providing evidence-informed services for children and families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcd7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Experience in serving as a center for training and education and as a resource facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcd8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National expertise in providing technical assistance to communities with respect to the multidisciplinary response to child abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcd9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bcda-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal submitted in response to the solicitation under paragraph (1) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d28bcdb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a single or multiyear management plan that outlines how the applicant will provide information, services, and technical assistance to communities and chapters so that communities can establish and maintain multidisciplinary programs that respond to child abuse and chapters can establish and maintain children’s advocacy centers in their State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcdc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the ability of the applicant to operate successfully a children’s advocacy center or provide training to allow others to do so; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcdd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the annual cost of the proposal and a breakdown of those costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcde-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A management plan described in paragraph (3)(A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d28bcdf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outline the basic activities expected to be performed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bce0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the entities that will conduct the basic activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bce1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the period of time over which the basic activities will take place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bce2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" define the overall program management and direction by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id4d28bce3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying managerial, organizational, and administrative procedures and responsibilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d28bce4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating how implementation and monitoring of the progress of the children’s advocacy program after receipt of funding will be achieved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id4d28bce5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/3/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing sufficient rationale to support the costs of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bce6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of proposals","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bce7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proposals shall be selected under this section on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bce8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall select proposals for funding that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d28bce9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best result in developing and establishing multidisciplinary programs that respond to child abuse by assisting, training, and teaching community agencies and professionals called upon to respond to child abuse cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcea-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in resolving problems that may occur during the development, operation, and implementation of a multidisciplinary program that responds to child abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bceb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the greatest extent possible and subject to available appropriations, ensure that at least 1 applicant is selected from each of the 4 census regions of the country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bcec-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best result in supporting chapters in each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d28bced-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise best carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available in separate appropriation Acts, the Administrator shall provide to each grant recipient the financial and technical assistance and other incentives that are necessary and appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out activities that are in the best interests of abused and neglected children, a grant recipient shall consult with other grant recipients under this Act on a regular basis to exchange ideas, share information, and review children’s advocacy program activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d28bcf0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d28bcf1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of regional children’s advocacy program activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall regularly monitor and evaluate the activities of grant recipients and shall determine whether each grant recipient has complied with the original proposal and any modifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcf2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient shall provide an annual report to the Administrator that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d28bcf3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the progress made in satisfying the purpose of the children’s advocacy program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d28bcf4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states whether changes are needed and are being made to carry out the purpose of the children’s advocacy program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d28bcf5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20303/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuation of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon discontinuation of funding of a grant recipient under this section, the Administrator shall solicit new proposals in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d28bcf6-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tII/s213"},"text":"Pub. L. 101–647, title II, § 213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s6/b/2"},"text":"Pub. L. 102–586, § 6(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5030"},"text":"106 Stat. 5030","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/21/tIII/s381/a"},"text":"Pub. L. 108–21, title III, § 381(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-30"},"text":"Apr. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/667"},"text":"117 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c"},"text":"Pub. L. 115–424, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-07"},"text":"Jan. 7, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5466"},"text":"132 Stat. 5466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3"},"text":"Pub. L. 117–354, § 3(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6274"},"text":"136 Stat. 6274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d28bcf7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d28bcf8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d28bcf9-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(6), probably means the Victims of Child Abuse Act of 1990, title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647"},"text":"Pub. L. 101–647","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4792"},"text":"104 Stat. 4792","children":[],"tail":", which is classified principally to this chapter. For complete classification of title II to the Code, see Short Title of 1990 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d28bcfa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13001b"},"text":"section 13001b of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4d28bcfb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/s213"},"text":"section 213 of Pub. L. 101–647","children":[],"tail":" was renumbered section 214A and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s20305"},"text":"section 20305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d28bcfc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/A/i"},"text":"Pub. L. 117–354, § 3(3)(A)(i)","children":[],"tail":", (ii), in heading, inserted “and maintenance” after “Establishment” and, in introductory provisions, struck out “, in coordination with the Director of the Office of Victims of Crime,” after “Administrator” and inserted “and maintain” after “establish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/A/iii"},"text":"Pub. L. 117–354, § 3(3)(A)(iii)","children":[],"tail":", substituted “victim advocates, multidisciplinary team leadership, and children’s advocacy center staff” for “and victim advocates” and struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/A/v"},"text":"Pub. L. 117–354, § 3(3)(A)(v)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/A/iv"},"text":"Pub. L. 117–354, § 3(3)(A)(iv)","children":[],"tail":", (vi), redesignated par. (4) as (5) and substituted “organizational capacity support, and oversight of” for “and oversight to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/B/i/II"},"text":"Pub. L. 117–354, § 3(3)(B)(i)(II)","children":[],"tail":", substituted “training and technical assistance to aid communities in establishing and maintaining” for “and technical assistance to aid communities in establishing” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/B/i/I"},"text":"Pub. L. 117–354, § 3(3)(B)(i)(I)","children":[],"tail":", inserted “and maintain” after “establish”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/B/ii/I/aa"},"text":"Pub. L. 117–354, § 3(3)(B)(ii)(I)(aa)","children":[],"tail":", inserted “Center” after “Advocacy” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/B/ii/I/bb"},"text":"Pub. L. 117–354, § 3(3)(B)(ii)(I)(bb)","children":[],"tail":", substituted “and intervention in child” for “of, assessment of, and intervention in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/B/ii/II"},"text":"Pub. L. 117–354, § 3(3)(B)(ii)(II)","children":[],"tail":", substituted “centers, interested communities, and chapters” for “centers and interested communities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/C/i/I"},"text":"Pub. L. 117–354, § 3(3)(C)(i)(I)","children":[],"tail":", substituted “investigation and intervention in child abuse” for “evaluation, intervention, evidence gathering, and counseling”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/C/i/II"},"text":"Pub. L. 117–354, § 3(3)(C)(i)(II)","children":[],"tail":", substituted “multidisciplinary response to child abuse” for “judicial handling of child abuse and neglect”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/C/ii"},"text":"Pub. L. 117–354, § 3(3)(C)(ii)","children":[],"tail":", substituted “and chapters so that communities can establish and maintain multidisciplinary programs that respond to child abuse and chapters can establish and maintain children’s advocacy centers in their State” for “so that communities can establish multidisciplinary programs that respond to child abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B)(iv), (v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/C/iii"},"text":"Pub. L. 117–354, § 3(3)(C)(iii)","children":[],"tail":", added cl. (iv) and redesignated former cl. (iv) as (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s3/3/C/iv"},"text":"Pub. L. 117–354, § 3(3)(C)(iv)","children":[],"tail":", inserted “under this Act” after “recipients”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/1/A"},"text":"Pub. L. 115–424, § 2(c)(1)(A)","children":[],"tail":", struck out “with the Director and” after “coordination” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/1/B"},"text":"Pub. L. 115–424, § 2(c)(1)(B)","children":[],"tail":"–(F), redesignated pars. (3) and (4) as (2) and (3), respectively, in par. (3) as redesignated, inserted “, law enforcement officers, child protective service workers, forensic interviewers, prosecutors, and victim advocates,” after “health care professionals” and struck out “medical” before “personnel” and “support”, added par. (4), and struck out former par. (2) which read as follows; “provide support for nonoffending family members;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/A/i"},"text":"Pub. L. 115–424, § 2(c)(2)(A)(i)","children":[],"tail":", struck out “, in coordination with the Director,” after “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/A/iii"},"text":"Pub. L. 115–424, § 2(c)(2)(A)(iii)","children":[],"tail":", substituted “multidisciplinary team investigation, trauma-informed interventions, and evidence-informed treatment,” for “the prevention, judicial handling, and treatment of child abuse and neglect; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/A/ii"},"text":"Pub. L. 115–424, § 2(c)(2)(A)(ii)","children":[],"tail":", (iv), struck out subpar. (C) which read as follows: “fund the establishment of freestanding facilities in multidisciplinary programs within communities that have yet to establish such facilities,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/i/I"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(i)(I)","children":[],"tail":", substituted “communities, local children’s advocacy centers, multidisciplinary teams, and State chapters” for “communities” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/i/II"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(i)(II)","children":[],"tail":", inserted “and expanding” after “developing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/i/IV"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(i)(IV)","children":[],"tail":", added cl. (ii). Former cl. (ii) redesignated (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/i/III"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(i)(III)","children":[],"tail":", (V), redesignated cl. (ii) as (iii) and substituted “child-friendly facilities for the investigation of, assessment of, and intervention in abuse” for “a freestanding facility where interviews of and services for abused children can be provided”. Former cl. (iii) redesignated (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/i/III"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(i)(III)","children":[],"tail":", (VI), redesignated cl. (iii) as (iv) and substituted “duplicative” for “multiple”. Former cl. (iv) redesignated (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A)(v) to (xi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/i/III"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(i)(III)","children":[],"tail":", redesignated cls. (iv) to (x) as (v) to (xi), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/2/B/ii"},"text":"Pub. L. 115–424, § 2(c)(2)(B)(ii)","children":[],"tail":", inserted “and interested communities” after “advocacy centers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/3/A"},"text":"Pub. L. 115–424, § 2(c)(3)(A)","children":[],"tail":", substituted “evidence-informed services for” for “remedial counseling to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/3/B"},"text":"Pub. L. 115–424, § 2(c)(3)(B)","children":[],"tail":", substituted “children’s advocacy center” for “multidisciplinary child abuse program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/3/C/i"},"text":"Pub. L. 115–424, § 2(c)(3)(C)(i)","children":[],"tail":", struck out “, in coordination with the Director,” after “Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B)(iii) to (v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/3/C/ii"},"text":"Pub. L. 115–424, § 2(c)(3)(C)(ii)","children":[],"tail":", (iii), redesignated cls. (iv) and (v) as (iii) and (iv), respectively, and struck out former cl. (iii) which read as follows: “carry out the objectives developed by the board under subsection (e)(2)(A);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/4/A"},"text":"Pub. L. 115–424, § 2(c)(4)(A)","children":[],"tail":", struck out “, in coordination with the Director,” after “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/4/B"},"text":"Pub. L. 115–424, § 2(c)(4)(B)","children":[],"tail":", struck out “and the Director” after “Administrator” in intoductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/4/C"},"text":"Pub. L. 115–424, § 2(c)(4)(C)","children":[],"tail":", struck out subpar. (B) designation and heading before “Upon discontinuation” and struck out subpar. (A). Prior to amendment, text of subpar. (A) read as follows: “If a grant recipient under this section substantially fails in the implementation of the program activities, the Administrator shall not discontinue funding until reasonable notice and an opportunity for reconsideration is given.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/424/s2/c/5"},"text":"Pub. L. 115–424, § 2(c)(5)","children":[],"tail":", struck out subsecs. (e) and (f) which related to the children’s advocacy advisory board and annual report on the progress of regional children’s advocacy program activities, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s381/a/1"},"text":"Pub. L. 108–21, § 381(a)(1)","children":[],"tail":", struck out “and” at end of cl. (ii) of subpar. (B), substituted “board” for “Board” in cl. (iii) of subpar. (B), and redesignated subpars. (C) and (D) as cls. (iv) and (v), respectively, of subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B)(ii), (2)(A), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/21/s381/a/2"},"text":"Pub. L. 108–21, § 381(a)(2)","children":[],"tail":", substituted “board” for “Board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d28bcfd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4d28bcfe-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a board established by the President or an officer of the Federal Government, such board is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a board established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
