{"tag":"section","attrib":{"id":"id4d4c70ee-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502"},"text":null,"children":[{"tag":"num","attrib":{"value":"40502"},"text":"§ 40502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4c70ef-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant award under this chapter, an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40501"},"text":"section 40501 of this title","children":[],"tail":" shall submit an application at such time and in such form as the Attorney General may reasonably require."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4c70f0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each such application shall include assurances that the applicant shall, to the greatest extent possible—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c70f1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the National Crime Information Center and, when possible, to law enforcement authorities throughout the applicant’s jurisdiction regarding every deceased unidentified person, regardless of age, found in the applicant’s jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70f2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter a complete profile of such unidentified person in compliance with the guidelines established by the Department of Justice for the National Crime Information Center Missing and Unidentified Persons File, including dental records, DNA records, x-rays, and fingerprints, if available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70f3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter the National Crime Information Center number or other appropriate number assigned to the unidentified person on the death certificate of each such unidentified person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70f4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain all such records pertaining to unidentified persons until a person is identified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70f5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and report information to the National Missing and Unidentified Persons System (NamUs) regarding missing persons and unidentified remains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d4c70f6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protections for biological family reference samples","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c70f7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any suspected biological family DNA reference samples received from citizens of the United States or foreign nationals and uploaded into the Combined DNA Index System (commonly referred to as “CODIS”) by an accredited, publicly funded CODIS forensic laboratory awarded a grant under this section may be used only for identifying missing persons and unidentified remains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70f8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any biological family DNA reference samples from citizens of the United States or foreign nationals entered into CODIS for purposes of identifying missing persons and unidentified remains may not be disclosed to a Federal or State law enforcement agency for law enforcement purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4c70f9-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/177/tII/s203"},"text":"Pub. L. 106–177, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/36"},"text":"114 Stat. 36","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/2"},"text":"Pub. L. 116–277, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3369"},"text":"134 Stat. 3369","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4c70fa-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4c70fb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d4c70fc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14662"},"text":"section 14662 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d4c70fd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/2/A"},"text":"Pub. L. 116–277, § 2(a)(2)(A)","children":[],"tail":", substituted “an entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40501"},"text":"section 40501 of this title","children":[],"tail":"” for “a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/2/B/i"},"text":"Pub. L. 116–277, § 2(a)(2)(B)(i)","children":[],"tail":", substituted “applicant” for “State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/2/B/ii"},"text":"Pub. L. 116–277, § 2(a)(2)(B)(ii)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “report to the National Crime Information Center and when possible, to law enforcement authorities throughout the State regarding every deceased unidentified person, regardless of age, found in the State’s jurisdiction;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/2/B/iii"},"text":"Pub. L. 116–277, § 2(a)(2)(B)(iii)","children":[],"tail":"–(v), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/2/C"},"text":"Pub. L. 116–277, § 2(a)(2)(C)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
