{"tag":"section","attrib":{"id":"id4cfdb55e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12225"},"text":null,"children":[{"tag":"num","attrib":{"value":"12225"},"text":"§ 12225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall consider the following facts in awarding grants:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cfdb55f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12225/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Demonstrated need and evidence of the ability to provide the services described in the plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12223"},"text":"section 12223 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cfdb560-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12225/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall attempt, to the extent practicable, to achieve an equitable geographic distribution of grant awards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cfdb561-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31705"},"text":"Pub. L. 103–322, title III, § 31705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1891"},"text":"108 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cfdb562-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cfdb563-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cfdb564-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13865"},"text":"section 13865 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
