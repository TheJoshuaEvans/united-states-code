{"tag":"section","attrib":{"id":"id4cda0000-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702"},"text":null,"children":[{"tag":"num","attrib":{"value":"10702"},"text":"§ 10702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To request a grant under this subchapter, the chief executive officer of a State, unit of local government, or Indian tribe shall submit an application to the Attorney General at such time and in such form as the Attorney General may require. Such application shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cda0001-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification that Federal funds made available under this subchapter will not be used to supplant State, local, or tribal funds, but will be used to increase the amounts of such funds that would, in the absence of Federal funds, be made available for the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10701/a"},"text":"section 10701(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0002-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance that, for each fiscal year covered by an application, the applicant shall maintain and report such data, records, and information (programmatic and financial) as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0003-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A certification, made in a form acceptable to the Attorney General and executed by the chief executive officer of the applicant (or by another officer of the applicant, if qualified under regulations promulgated by the Attorney General), that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cda0004-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities or services to be funded by the grant meet all the requirements of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0005-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all the information contained in the application is correct;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0006-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been appropriate coordination with affected agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cda0007-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant will comply with all provisions of this subchapter and all other applicable Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cda0008-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assurance that the applicant will work with the Drug Enforcement Administration to develop an integrated and comprehensive strategy to address opioid abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cda0009-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3022"},"text":"Pub. L. 90–351, title I, § 3022","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/198/tII/s201/a/1"},"text":"Pub. L. 114–198, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-22"},"text":"July 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/712"},"text":"130 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cda000a-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cda000b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cda000c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797ff–1"},"text":"section 3797ff–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
