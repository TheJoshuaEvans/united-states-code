{"tag":"section","attrib":{"id":"id4cd06377-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10595a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10595a"},"text":"§ 10595a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd06378-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10595a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this subchapter $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd06379-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10595a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount made available to carry out this subchapter in any fiscal year, not less than 5 percent shall be used for grants to Indian Tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd0637a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2926"},"text":"Pub. L. 90–351, title I, § 2926","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s113"},"text":"Pub. L. 110–199, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/676"},"text":"122 Stat. 676","children":[],"tail"