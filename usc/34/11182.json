{"tag":"section","attrib":{"id":"id4ce858bd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182"},"text":null,"children":[{"tag":"num","attrib":{"value":"11182"},"text":"§ 11182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4ce858be-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be administered by the Administrator under the general authority of the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce858bf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain crime control provisions applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 10228(c), 10230(a), 10230(b), 10230(c), 10231(a), 10231(b), and 10231(d) of this title, shall apply with respect to the administration of and compliance with this chapter, except that for purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce858c0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the Office of Justice Programs in such sections shall be deemed to be a reference to the Assistant Attorney General who heads the Office of Justice Programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce858c1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “this chapter” as it appears in such sections shall be deemed to be a reference to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce858c2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain other crime control provisions applicable","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 10221(a), 10221(c), and 10225 of this title shall apply with respect to the administration of and compliance with this chapter, except that for purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce858c3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the Attorney General, the Assistant Attorney General who heads the Office of Justice Programs, the Director of the National Institute of Justice, the Director of the Bureau of Justice Statistics, or the Director of the Bureau of Justice Assistance shall be deemed to be a reference to the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce858c4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reference to the Office of Justice Programs, the Bureau of Justice Assistance, the National Institute of Justice, or the Bureau of Justice Statistics shall be deemed to be a reference to the Office of Juvenile Justice and Delinquency Prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce858c5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “this chapter” as it appears in such sections shall be deemed to be a reference to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce858c6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules, regulations, and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4ce858c7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator is authorized to establish such rules, regulations, guidance, and procedures as are necessary for the exercise of the functions of the Office and only to the extent necessary to ensure that there is compliance with the specific requirements of this subchapter or to respond to requests for clarification and guidance relating to such compliance. In developing guidance and procedures, the Administrator shall consult with representatives of States and units of local government, including those individuals responsible for administration of this chapter and compliance with the core requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4ce858c8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4ce858c9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting, compliance reporting, State plan requirements, and other similar documentation as may be required from States is requested in a manner that respects confidentiality, encourages efficiency and reduces the duplication of reporting efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4ce858ca-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States meeting all the core requirements are encouraged to experiment with offering innovative, data-driven programs designed to further improve the juvenile justice system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4ce858cb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s11182/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of State compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State requires by law compliance with the core requirements, then for the period such law is in effect in such State such State shall be rebuttably presumed to satisfy such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4ce858cc-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415/tII/s299A"},"text":"Pub. L. 93–415, title II, § 299A","children":[],"tail":", formerly § 262, "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1129"},"text":"88 Stat. 1129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/115/s6/c"},"text":"Pub. L. 95–115, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1058"},"text":"91 Stat. 1058","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/509/s16"},"text":"Pub. L. 96–509, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-08"},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2761"},"text":"94 Stat. 2761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s641"},"text":"Pub. L. 98–473, title II, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2122"},"text":"98 Stat. 2122","children":[],"tail":"; renumbered § 292, "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7266/3"},"text":"Pub. L. 100–690, title VII, § 7266(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4449"},"text":"102 Stat. 4449","children":[],"tail":"; renumbered § 299A, "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s2/i/1/B"},"text":"Pub. L. 102–586, § 2(i)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5006"},"text":"106 Stat. 5006","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tII/s12214"},"text":"Pub. L. 107–273, div. C, title II, § 12214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1892"},"text":"116 Stat. 1892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/385/tII/s209"},"text":"Pub. L. 115–385, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5144"},"text":"132 Stat. 5144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4ce858cd-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4ce858ce-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4ce858cf-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b), (c), and (d)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/415"},"text":"Pub. L. 93–415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1109"},"text":"88 Stat. 1109","children":[],"tail":", known as the Juvenile Justice and Delinquency Prevention Act of 1974, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title of 1974 Act note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4ce858d0-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5672"},"text":"section 5672 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4ce858d1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s209/1"},"text":"Pub. L. 115–385, § 209(1)","children":[],"tail":", designated existing provisions as par. (1), struck out “, after appropriate consultation with representatives of States and units of local government,” after “Administrator is authorized”, inserted “guidance,” after “regulations,” and “In developing guidance and procedures, the Administrator shall consult with representatives of States and units of local government, including those individuals responsible for administration of this chapter and compliance with the core requirements.” at end, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385/s209/2"},"text":"Pub. L. 115–385, § 209(2)","children":[],"tail":", substituted “core requirements” for “requirements described in paragraphs (11), (12), and (13) of "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11133/a"},"text":"section 11133(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s12214/1"},"text":"Pub. L. 107–273, § 12214(1)","children":[],"tail":", substituted “only to the extent necessary to ensure that there is compliance with the specific requirements of this subchapter or to respond to requests for clarification and guidance relating to such compliance” for “as are consistent with the purpose of this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/s12214/2"},"text":"Pub. L. 107–273, § 12214(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", in amending subsec. (a) generally, substituted provisions setting forth the administrative authority of the Office for former provisions which incorporated other administrative provisions into this chapter as well as construing certain references as authorizing the Administrator of the Office of Juvenile Justice and Delinquency Prevention to perform the same actions as other officials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", in amending subsec. (b) generally, substituted provisions relating to the applicability of other provisions to this chapter as well as defining certain references therein for former provisions which directed the Office of Justice Assistance, Research and Statistics to provide staff support and coordinate the activities of the Office of Juvenile Justice and Delinquency Prevention."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", in amending section generally, added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/509"},"text":"Pub. L. 96–509","children":[],"tail":" brought relevant applicable administrative provisions of the Omnibus Crime Control and Safe Streets Act of 1968 into conformance subsequent to the Justice System Improvement Amendments of 1979 and provided that the Office of Justice Assistance, Research, and Statistics provide staff support to, and coordinate the activities of the Office in the same manner as it does for the Law Enforcement Assistance Administration, National Institute of Justice, and Bureau of Justice Statistics pursuant to former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3781/b"},"text":"section 3781(b) of title 42","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/115"},"text":"Pub. L. 95–115","children":[],"tail":" substituted provisions setting forth applicability of specified statutory requirements, for provisions setting forth prohibitions against discrimination and required terms in grants, contracts, and agreements and enforcement procedures thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4ceaa1c2-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ceaa1c3-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/385"},"text":"Pub. L. 115–385","children":[],"tail":" not applicable with respect to funds appropriated for any fiscal year that begins before "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/385/s3"},"text":"section 3 of Pub. L. 115–385","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11102"},"text":"section 11102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ceaa1c4-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" effective on the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", and applicable only with respect to fiscal years beginning on or after the first day of the first fiscal year that begins after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s12223"},"text":"section 12223 of Pub. L. 107–273","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ceaa1c5-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s670/a"},"text":"section 670(a) of Pub. L. 98–473","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4ceaa1c6-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/115"},"text":"Pub. L. 95–115","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/415/s263/c"},"text":"section 263(c) of Pub. L. 93–415","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/95/115/s6/d/2"},"text":"section 6(d)(2) of Pub. L. 95–115","children":[],"tail":" and repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7266/2"},"text":"Pub. L. 100–690, title VII, § 7266(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4449"},"text":"102 Stat. 4449","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s11101"},"text":"section 11101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
