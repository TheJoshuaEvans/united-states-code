{"tag":"section","attrib":{"id":"id4d4c70dd-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501"},"text":null,"children":[{"tag":"num","attrib":{"value":"40501"},"text":"§ 40501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d4c70de-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d4c70df-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award grants to eligible entities described in paragraph (2) to enable the eligible entities to improve the transportation, processing, identification, and reporting of missing persons and unidentified remains, including migrants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d4c70e0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible entities described in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d4c70e1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States and units of local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70e2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accredited, publicly funded, Combined DNA Index System (commonly known as “CODIS”) forensic laboratories, which demonstrate the grant funds will be used for DNA typing and uploading biological family DNA reference samples, including samples from foreign nationals, into CODIS, subject to the protocols for inclusion of such forensic DNA profiles into CODIS, and the privacy protections required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40502/c"},"text":"section 40502(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70e3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Medical examiners offices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70e4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accredited, publicly funded toxicology laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70e5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accredited, publicly funded crime laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publicly funded university forensic anthropology laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d4c70e7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40501/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nonprofit organizations that have working collaborative agreements with State and county forensic offices, including medical examiners, coroners, and justices of the peace, for entry of data into CODIS or the National Missing and Unidentified Persons System (commonly known as “NamUs”), or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d4c70e8-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/177/tII/s202"},"text":"Pub. L. 106–177, title II, § 202","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/1"},"text":"Pub. L. 116–277, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3368"},"text":"134 Stat. 3368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d4c70e9-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d4c70ea-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4d4c70eb-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 40501, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/177/tII/s202"},"text":"Pub. L. 106–177, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-03-10"},"text":"Mar. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/36"},"text":"114 Stat. 36","children":[],"tail":", authorized Attorney General to provide grant awards to States to enable States to improve the reporting of unidentified and missing persons, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/277/s2/a/1"},"text":"Pub. L. 116–277, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3368"},"text":"134 Stat. 3368","children":[],"tail":". Such section was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14661"},"text":"section 14661 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as section 40501."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d4c70ec-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id4d4c70ed-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/177"},"text":"Pub. L. 106–177","children":[],"tail":", which is classified to this chapter, as “Jennifer’s Law”, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/177/s201"},"text":"section 201 of Pub. L. 106–177","children":[],"tail":", set out as a Short Title of 2000 Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s10101"},"text":"section 10101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
