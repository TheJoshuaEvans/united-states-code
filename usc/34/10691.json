{"tag":"section","attrib":{"id":"id4cd78fc5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10691"},"text":null,"children":[{"tag":"num","attrib":{"value":"10691"},"text":"§ 10691.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sex offender apprehension grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cd78fc6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10691/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to make sex offender apprehension grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cd78fc7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10691/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this subchapter, the Attorney General may make grants to States, units of local government, Indian tribal governments, other public and private entities, and multi-jurisdictional or regional consortia thereof for activities specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cd78fc8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10691/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An activity referred to in paragraph (1) is any program, project, or other activity to assist a State in enforcing sex offender registration requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cd78fc9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10691/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary for fiscal years 2007 through 2009 to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cd78fca-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3011"},"text":"Pub. L. 90–351, title I, § 3011","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/248/tVI/s623"},"text":"Pub. L. 109–248, title VI, § 623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/635"},"text":"120 Stat. 635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd78fcb-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd78fcc-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd78fcd-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797ee"},"text":"section 3797ee of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
