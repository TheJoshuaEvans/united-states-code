{"tag":"section","attrib":{"id":"id4d133919-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554"},"text":null,"children":[{"tag":"num","attrib":{"value":"12554"},"text":"§ 12554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of lead agency and submission of State plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d13391a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State that desires to participate in the Police Corps program under this part shall designate a lead agency that will be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d13391b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting to the Director a State plan described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d13391c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering the program in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d13391d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d13391e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the lead agency shall work in cooperation with the local law enforcement liaisons, representatives of police labor organizations and police management organizations, and other appropriate State and local agencies to develop and implement interagency agreements designed to carry out the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d13391f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the State shall advertise the assistance available under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133920-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain assurances that the State shall screen and select law enforcement personnel for participation in the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d133921-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12554/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12559"},"text":"section 12559 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d133922-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200105"},"text":"Pub. L. 103–322, title XX, § 200105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2050"},"text":"108 Stat. 2050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d133923-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d133924-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d133925-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14094"},"text":"section 14094 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
