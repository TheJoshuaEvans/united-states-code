{"tag":"section","attrib":{"id":"id4cf8f961-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108"},"text":null,"children":[{"tag":"num","attrib":{"value":"12108"},"text":"§ 12108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cf8f962-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8f963-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8f964-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $997,500,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f965-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,330,000,000 for fiscal year 1997;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f966-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,527,000,000 for fiscal year 1998;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f967-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,660,000,000 for fiscal year 1999; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f968-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,753,100,000 for fiscal year 2000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f969-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8f96a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts remaining after the allocation of funds for the purposes set forth under sections 12110, 12111, and 12109 of this title, the Attorney General shall, from amounts authorized to be appropriated under paragraph (1) for each fiscal year, distribute 50 percent for incarceration grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12103"},"text":"section 12103 of this title","children":[],"tail":", and 50 percent for incentive grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12104"},"text":"section 12104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f96b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of minimum amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall distribute minimum amounts allocated for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12103/a"},"text":"section 12103(a) of this title","children":[],"tail":" to an eligible State not later than 30 days after receiving an application that demonstrates that such State qualifies for a Violent Offender Incarceration grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12103"},"text":"section 12103 of this title","children":[],"tail":" or a Truth-in-Sentencing Incentive grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12104"},"text":"section 12104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cf8f96c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cf8f96d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in section ","children":[{"tag":"ref","attrib":{"idref":"fn002086"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002086"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “sections”."}],"tail":" 12110 and 12111 of this title, funds made available pursuant to this section shall be used only to carry out the purposes described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12102/a"},"text":"section 12102(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f96e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonsupplanting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available pursuant to this section shall not be used to supplant State funds, but shall be used to increase the amount of funds that would, in the absence of Federal funds, be made available from State sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f96f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than 3 percent of the funds that remain available after carrying out sections 12109, 12110, and 12111 of this title shall be available to the Attorney General for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cf8f970-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f971-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and evaluation, including assessment of the effect on public safety and other effects of the expansion of correctional capacity and sentencing reforms implemented pursuant to this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f972-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance relating to the use of grant funds, and development and implementation of sentencing reforms implemented pursuant to this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cf8f973-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data collection and improvement of information systems relating to the confinement of violent offenders and other sentencing and correctional matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f974-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carryover of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated pursuant to this section during any fiscal year shall remain available until expended. Funds obligated, but subsequently unspent and deobligated, may remain available, to the extent as may ","children":[{"tag":"ref","attrib":{"idref":"fn002087"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002087"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “be”."}],"tail":" provided in appropriations Acts, for the purpose described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12102/a/4"},"text":"section 12102(a)(4) of this title","children":[],"tail":" for any subsequent fiscal year. The further obligation of such funds by an official for such purpose shall not be delayed, directly or indirectly, in any manner by any officer or employee in the executive branch."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cf8f975-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12108/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of a grant received under this part may not exceed 90 percent of the costs of a proposal as described in an application approved under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4cf8f976-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tII/s20108"},"text":"Pub. L. 103–322, title II, § 20108","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title I, § 114(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–19; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/199/tI/s104/b"},"text":"Pub. L. 110–199, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/669"},"text":"122 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cf8f977-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cf8f978-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cf8f979-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13708"},"text":"section 13708 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section. Some section numbers or references in amendment notes below reflect the classification of such sections or references prior to editorial reclassification."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id4cf8f97a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s20108"},"text":"section 20108 of Pub. L. 103–322","children":[],"tail":", title II, "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1818"},"text":"108 Stat. 1818","children":[],"tail":", defined terms prior to the general amendment of subtitle A of title II of "},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4cf8f97b-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" inserted at end “Funds obligated, but subsequently unspent and deobligated, may remain available, to the extent as may provided in appropriations Acts, for the purpose described in "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s13702/a/4"},"text":"section 13702(a)(4) of this title","children":[],"tail":" for any subsequent fiscal year. The further obligation of such funds by an official for such purpose shall not be delayed, directly or indirectly, in any manner by any officer or employee in the executive branch.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4cf8f97c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id4cf8f97d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199"},"text":"Pub. L. 110–199","children":[],"tail":" and requirements for grants made under such amendments, see "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s60504"},"text":"section 60504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
