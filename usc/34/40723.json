{"tag":"section","attrib":{"id":"id4d512c17-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723"},"text":null,"children":[{"tag":"num","attrib":{"value":"40723"},"text":"§ 40723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault forensic exam program grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d512c18-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512c19-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c1a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, Tribal, or local government or hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c1b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a sexual assault examination program, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d512c1c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a SANE program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d512c1d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a SAFE program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d512c1e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a SART program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d512c1f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical personnel, including a doctor or nurse, involved in treating victims of sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d512c20-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider involved in treating victims of sexual assault;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c21-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State sexual assault coalition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c22-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health care facility, including a hospital that provides sexual assault forensic examinations by a qualified or certified SANE or SAFE;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c23-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sexual assault examination program that provides SANE or SAFE training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c24-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a community-based program that provides sexual assault forensic examinations, including pediatric forensic exams in a multidisciplinary setting, by a qualified or certified SANE or SAFE outside of a traditional health care setting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c25-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health care facility” means any State, local, Tribal, community, free, nonprofit, academic, or private medical facility, including a hospital, that provides emergency medical care to patients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c26-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical forensic examination; MFE","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “medical forensic examination” or “MFE” means an examination of a sexual assault patient by a health care provider, who has specialized education and clinical experience in the collection of forensic evidence and treatment of these patients, which includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c27-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering information from the patient for the medical forensic history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c28-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c29-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating treatment of injuries, documentation of biological and physical findings, and collection of evidence from the patient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c2a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c2b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information, treatment, and referrals for sexually transmitted infections, pregnancy, suicidal ideation, alcohol and substance abuse, and other non-acute medical concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c2c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing follow-up as needed to provide additional healing, treatment, or collection of evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c2d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric SANE and SAFE","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pediatric SANE and SAFE” means a SANE or SAFE who is trained to conduct sexual assault forensic examinations on children and youth between the ages of 0 and 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c2e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified personnel” includes a registered or advanced practice nurse, physician, doctor of osteopathy, or physician assistant who has specialized training conducting medical forensic examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c2f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified SANE and SAFE training program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified SANE and SAFE training program” means a program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c30-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified to prepare current and future sexual assault nurse examiners to be profession-ready and meet the applicable State and National certification and licensure requirements, through didactic, clinical, preceptor, or capstone programs that include longer-term training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c31-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that preparation under a health care model that uses trauma-informed techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c32-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved as meeting the most recent National Training Standards for Sexual Assault Medical Forensic Examiners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c33-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural area” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c34-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c35-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual assault” means any nonconsensual sexual act or sexual contact proscribed by Federal, Tribal, or State law, including when the individual lacks capacity to consent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c36-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault forensic examiner; SAFE","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual assault forensic examiner” or “SAFE” means an individual who has specialized forensic training in treating sexual assault survivors and conducting medical forensic examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c37-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault forensic examination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sexual assault forensic examination” means an examination of a sexual assault patient by a health care provider, who has specialized education and clinical experience in the collection of forensic evidence and treatment of these patients, which includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c38-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gathering information from the patient for the medical forensic history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c39-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c3a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating treatment of injuries, documentation of biological and physical findings, and collection of evidence from the patient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c3b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c3c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information, treatment, and referrals for sexually transmitted infections, pregnancy, suicidal ideation, alcohol and substance abuse, and other non-acute medical concerns; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c3d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/11/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing follow-up as needed to provide additional healing, treatment, or collection of evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c3e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault nurse examiner; SANE","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual assault nurse examiner” or “SANE” means a registered or advanced practice nurse who has specialized training conducting medical forensic examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c3f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault response team; SART","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sexual assault response team” or “SART” means a multidisciplinary team that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c40-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a specialized and immediate response to survivors of sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c41-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include health care personnel, law enforcement representatives, community-based survivor advocates, prosecutors, and forensic scientists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c42-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c43-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trauma-informed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “trauma-informed” means, with respect to services or training, services or training that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c44-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a patient-centered approach to providing services or care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c45-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the dignity, strength, and empowerment of patients who have experienced trauma; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate evidence-based practices based on knowledge about the impact of trauma on patients’ lives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underserved populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “underserved populations” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault nurse examiner training program grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512c49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General, in consultation with the Secretary, shall make grants to eligible entities for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To establish qualified regional SANE training programs—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d512c4b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide clinical education for SANE students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d512c4c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide salaries for full and part-time SANE instructors, including those specializing in pediatrics and working in a multidisciplinary team setting, to help with the clinical training of SANEs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d512c4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide access to simulation laboratories and other resources necessary for clinical education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide full and part time salaries for SANEs and SAFEs, including pediatric SANEs and SAFEs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase access to SANEs and SAFEs by otherwise providing training, education, or technical assistance relating to the collection, preservation, analysis, and use of DNA samples and DNA evidence by SANEs, SAFEs, and other qualified personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c50-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reviewing applications for grants under this section, the Attorney General shall give preference to any eligible entity that certifies in the grant application that the entity will coordinate with a rape crisis center or the State sexual assault coalition to facilitate sexual assault advocacy to support sexual assault survivors and use the grant funds to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c51-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish qualified SANE training programs in localities with a high volume of forensic trauma cases, including adult and child sexual assault, domestic violence, elder abuse, sex trafficking, and strangulation cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c52-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the local and regional availability of full and part time sexual assault nurse examiners in a rural area, Tribal area, an area with a health professional shortage, or for an underserved population, including efforts to provide culturally competent services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish or sustain sexual assault mobile teams or units or otherwise enhance SANE and SAFE access through telehealth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directive to the Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512c55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the beginning of fiscal year 2022, the Attorney General shall coordinate with the Secretary to inform health care facilities, including Federally qualified health centers and hospitals, colleges and universities, and other appropriate health-related entities about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of grant funding under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of sexual assault nurse examiners, both adult and pediatric, and available resources of the Department of Justice and the Department of Health and Human Services to train or employ sexual assault nurses examiners to address the needs of communities dealing with sexual assault, domestic violence, sex trafficking, elder abuse, strangulation, and, in particular, the need for pediatric SANEs, including such nurse examiners working in the multidisciplinary setting, in responding to abuse of both children and adolescents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Attorney General shall collaborate with nongovernmental organizations representing SANEs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information on access to sexual assault forensic examinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d512c5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Attorney General, in consultation with the Secretary, shall establish, and update annually, a public website on the access to forensic nurse examiners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The website required under paragraph (1) shall with specificity describe, by State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding opportunities for SANE training and continuing education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of sexual assault advocates at locations providing sexual assault forensic exams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d512c5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", the Attorney General, in consultation with the Secretary, shall submit to the Committee on the Judiciary of the Senate, the Committee on Health, Education, Labor, and Pensions of the Senate, the Committee on the Judiciary of the House of Representatives, and the Committee on Energy and Commerce of the House of Representatives a report on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d512c5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of, and patient access to, trained SANEs and other providers who perform MFEs or sexual assault forensic examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the health care facilities, including hospitals or clinics, that offer SANEs and sexual assault forensic examinations and whether each health care facility, including a hospital or clinic, has full-time, part-time, or on-call coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional, provider, or other barriers to access for SANE care and services, including MFEs and sexual assault forensic examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c62-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State requirements, minimum standards, and protocols for training SANEs, including trauma-informed and culturally competent training standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c63-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State requirements, minimum standards, and protocols for training emergency services personnel involved in MFEs and sexual assault forensic examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c64-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of sexual assault nurse examiner training, frequency of when training is convened, the providers of such training, the State’s role in such training, and what process or procedures are in place for continuing education of such examiners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c65-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dedicated Federal and State funding to support SANE training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c66-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding opportunities for SANE training and continuing education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c67-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of sexual assault advocates at locations providing MFEs and sexual assault forensic exams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d512c68-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/d/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total annual cost of conducting sexual assault forensic exams described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10449/b"},"text":"section 10449(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d512c69-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s40723/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $30,000,000 for each of fiscal years 2023 through 2027 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d512c6a-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/405/tIII/s304"},"text":"Pub. L. 108–405, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2273"},"text":"118 Stat. 2273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/360/s4"},"text":"Pub. L. 110–360, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4009"},"text":"122 Stat. 4009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/182/s4"},"text":"Pub. L. 113–182, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-29"},"text":"Sept. 29, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1918"},"text":"128 Stat. 1918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/324/s4"},"text":"Pub. L. 114–324, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1950"},"text":"130 Stat. 1950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/107/s2"},"text":"Pub. L. 115–107, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Jan. 8, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2266"},"text":"131 Stat. 2266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/104/s4"},"text":"Pub. L. 116–104, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3273"},"text":"133 Stat. 3273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tXIII/s1318/b"},"text":"Pub. L. 117–103, div. W, title XIII, § 1318(b)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/940-945"},"text":"136 Stat. 940–945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d512c6b-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d512c6c-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d512c6d-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14136a"},"text":"section 14136a of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d512c6e-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1318/b"},"text":"Pub. L. 117–103, § 1318(b)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The Attorney General shall make grants to eligible entities to provide training, technical assistance, education, equipment, and information relating to the identification, collection, preservation, analysis, and use of DNA samples and DNA evidence by medical personnel and other personnel, including doctors, medical examiners, coroners, nurses, victim service providers, and other professionals involved in treating victims of sexual assault and sexual assault examination programs, including SANE (Sexual Assault Nurse Examiner), SAFE (Sexual Assault Forensic Examiner), and SART (Sexual Assault Response Team).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1318/b"},"text":"Pub. L. 117–103, § 1318(b)","children":[],"tail":", (c), added subsec. (b) and struck out former subsec. (b) which defined “eligible entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1318/b"},"text":"Pub. L. 117–103, § 1318(b)","children":[],"tail":", (d)(2), added subsec. (c) and struck out former subsec. (c) which related to preference given to certain eligible entities for grants and promoting the role and employment of forensic nurses."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1318/d/2"},"text":"Pub. L. 117–103, § 1318(d)(2)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/s1318/d/2"},"text":"Pub. L. 117–103, § 1318(d)(2)","children":[],"tail":", (e), redesignated subsec. (d) as (e) and amended it generally. Prior to amendment, subsec. authorized appropriation of $30,000,000 for each of fiscal years 2019 through 2024 to carry out this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/104"},"text":"Pub. L. 116–104","children":[],"tail":" substituted “2019 through 2024” for “2015 through 2019”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/107"},"text":"Pub. L. 115–107","children":[],"tail":" inserted “, both adult and pediatric,” after “role of forensic nurses” and substituted “elder abuse, and, in particular, the need for pediatric sexual assault nurse examiners, including such nurse examiners working in the multidisciplinary setting, in responding to abuse of both children and adolescents” for “and elder abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/324"},"text":"Pub. L. 114–324","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/182"},"text":"Pub. L. 113–182","children":[],"tail":" substituted “2015 through 2019” for “2009 through 2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/360"},"text":"Pub. L. 110–360","children":[],"tail":" substituted “2009 through 2014” for “2005 through 2009”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id4d512c6f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id4d512c70-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" not effective until Oct. 1 of the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
