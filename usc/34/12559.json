{"tag":"section","attrib":{"id":"id4d15a995-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559"},"text":null,"children":[{"tag":"num","attrib":{"value":"12559"},"text":"§ 12559.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State Police Corps plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d15a996-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the screening and selection of participants in accordance with the criteria set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12556"},"text":"section 12556 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a997-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state procedures governing the assignment of participants in the Police Corps program to State and local police forces (except with permission of the Director, no more than 25 percent of all the participants assigned in each year by each State to be assigned to a statewide police force or forces);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a998-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that participants shall be assigned to those geographic areas in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15a999-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is the greatest need for additional law enforcement personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a99a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participants will be used most effectively;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a99b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that to the extent consistent with paragraph (3), a participant shall be assigned to an area near the participant’s home or such other place as the participant may request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a99c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that to the extent feasible, a participant’s assignment shall be made at the time the participant is accepted into the program, subject to change—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15a99d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to commencement of a participant’s fourth year of undergraduate study, under such circumstances as the plan may specify; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a99e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from commencement of a participant’s fourth year of undergraduate study until completion of 4 years of police service by participant, only for compelling reasons or to meet the needs of the State Police Corps program and only with the consent of the participant;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a99f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that no participant shall be assigned to serve with a local police force—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15a9a0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose size has declined by more than 5 percent since ","children":[{"tag":"date","attrib":{"date":"1989-06-21"},"text":"June 21, 1989","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15a9a1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has members who have been laid off but not retired;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9a2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that participants shall be placed and to the extent feasible kept on community and preventive patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9a3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that participants will receive effective training and leadership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9a4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that the State may decline to offer a participant an appointment following completion of Federal training, or may remove a participant from the Police Corps program at any time, only for good cause (including failure to make satisfactory progress in a course of educational study) and after following reasonable review procedures stated in the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15a9a5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12559/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that a participant shall, while serving as a member of a police force, be compensated at the same rate of pay and benefits and enjoy the same rights under applicable agreements with labor organizations and under State and local law as other police officers of the same rank and tenure in the police force of which the participant is a member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d15a9a6-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200110"},"text":"Pub. L. 103–322, title XX, § 200110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2056"},"text":"108 Stat. 2056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11006/3"},"text":"Pub. L. 107–273, div. C, title I, § 11006(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1817"},"text":"116 Stat. 1817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d15a9a7-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d15a9a8-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d15a9a9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14099"},"text":"section 14099 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d15a9aa-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “except with permission of the Director, no more than 25 percent” for “no more than 10 percent”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
