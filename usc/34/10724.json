{"tag":"section","attrib":{"id":"id4cda0080-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10724"},"text":null,"children":[{"tag":"num","attrib":{"value":"10724"},"text":"§ 10724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To be eligible for an award of a grant or cooperative agreement under this subchapter, an entity shall submit to the Director of the Bureau of Justice Assistance an application in such form and manner, and containing such information, as required by the Director of the Bureau of Justice Assistance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cda0081-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s3034"},"text":"Pub. L. 90–351, title I, § 3034","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/76/s3/a"},"text":"Pub. L. 115–76, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-11-02"},"text":"Nov. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1249"},"text":"131 Stat. 1249","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
