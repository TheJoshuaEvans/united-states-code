{"tag":"section","attrib":{"id":"id4cc95e74-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a"},"text":null,"children":[{"tag":"num","attrib":{"value":"10462a"},"text":"§ 10462a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to State and Tribal courts to implement protection order pilot programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4cc95e75-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means a State or Tribal court that is part of a multidisciplinary partnership that includes, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95e76-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, Tribal, or local law enforcement agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e77-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, Tribal, or local prosecutor’s office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e78-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a victim service provider or State or Tribal domestic violence coalition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e79-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a provider of culturally specific services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e7a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit program or government agency with demonstrated experience in providing legal assistance or legal advice to victims of domestic violence and sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e7b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bar association of the applicable State or Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e7c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or Tribal association of court clerks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e7d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, Tribal, or local association of criminal defense attorneys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e7e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 2 individuals with expertise in the design and management of court case management systems and systems of integration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e7f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not fewer than 2 State or Tribal court judges with experience in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95e80-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the field of domestic violence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e81-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing protective orders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e82-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judge assigned to the criminal docket of the State or Tribal court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95e83-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95e84-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make grants to eligible entities to carry out the activities described in subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e85-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may award not more than 10 grants under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant awarded under paragraph (1) may be not more than $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95e87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95e88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall use the grant funds, in consultation with the partners of the eligible entity described in subsection (a), to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95e89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and implement a program for properly and legally serving protection orders through electronic communication methods to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95e8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modernize the service process and make the process more effective and efficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95e8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for improved safety of victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95e8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make protection orders enforceable as quickly as possible;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e8d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop best practices relating to the service of protection orders through electronic communication methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e8e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the program developed under subparagraph (A) complies with due process requirements and any other procedures required by law or by a court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e8f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement any technology necessary to carry out the program developed under subparagraph (A), such as technology to verify and track the receipt of a protection order by the intended party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e90-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95e91-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the program required under paragraph (1)(A) not later than 2 years after the date on which the eligible entity receives the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e92-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the program required under paragraph (1)(A) for not fewer than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95e93-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity of recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall award grants under this section to eligible entities in a variety of areas and situations, including, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95e94-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State court that serves a population of not fewer than 1,000,000 individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e95-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State court that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95e96-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves a State that is among the 7 States with the lowest population density in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e97-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a relatively low rate of successful service with respect to protection orders, as determined by the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e98-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State court that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95e99-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves a State that is among the 7 States with the highest population density in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95e9a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a relatively low rate of successful service with respect to protection orders, as determined by the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e9b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court that uses an integrated, statewide case management system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e9c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court that uses a standalone case management system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e9d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95e9e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court that primarily serves a culturally specific and underserved population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95e9f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95ea0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity desiring a grant under this section shall submit to the Attorney General an application that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95ea1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the process that the eligible entity uses for service of protection orders at the time of submission of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ea2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable, statistics relating to protection orders during the 3 calendar years preceding the date of submission of the application, including rates of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95ea3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" successful service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95ea4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ea5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial list of the entities serving as the partners of the eligible entity described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95ea6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95ea7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No other application required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity shall not be required to submit an application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10462"},"text":"section 10462 of this title","children":[],"tail":" to receive a grant under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95ea8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4cc95ea9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which an eligible entity receives a grant under this section, the eligible entity shall submit to the Attorney General a report that details the plan of the eligible entity for implementation of the program under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4cc95eaa-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4cc95eab-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which an eligible entity implements a program under subsection (c), and not later than 2 years thereafter, the eligible entity shall submit to the Attorney General a report that describes the program, including, with respect to the program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95eac-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the viability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95ead-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eae-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the technology used to fulfill the goals of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eb1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of any legal or due process issues resulting from the electronic service method described in subsection (c)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eb2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for implementing such a program in other similarly situated locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4cc95eb3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of final report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall include in the second report submitted under subparagraph (A) recommendations for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4cc95eb4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" future nationwide implementation of the program implemented by the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4cc95eb5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" usage of electronic service, similar to the service used by the eligible entity, for other commonly used court orders, including with respect to viability and cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95eb6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No regulations or guidelines required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s10464"},"text":"section 10464 of this title","children":[],"tail":", the Attorney General shall not be required to publish regulations or guidelines implementing this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4cc95eb7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10462a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"s