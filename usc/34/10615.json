{"tag":"section","attrib":{"id":"id4cd063e6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s10615"},"text":null,"children":[{"tag":"num","attrib":{"value":"10615"},"text":"§ 10615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To request funds under this subchapter, the chief executive or the chief justice of a State or the chief executive or judge of a unit of local government or Indian tribal government, or the chief judge of a State court or the judge of a local court or Indian tribal court shall submit an application to the Attorney General in such form and containing such information as the Attorney General may reasonably require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4cd063e7-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tI/s2955"},"text":"Pub. L. 90–351, title I, § 2955","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tII/s2301/a"},"text":"Pub. L. 107–273, div. B, title II, § 2301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1797"},"text":"116 Stat. 1797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4cd063e8-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4cd063e9-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4cd063ea-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3797u–4"},"text":"section 3797u–4 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
