{"tag":"section","attrib":{"id":"id4d1f1f86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108"},"text":null,"children":[{"tag":"num","attrib":{"value":"20108"},"text":"§ 20108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime victims notification grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d1f1f87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may make grants as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20103/c/1/A"},"text":"section 20103(c)(1)(A) of this title","children":[],"tail":" to State, tribal, and local prosecutors’ offices, law enforcement agencies, courts, jails, and correctional institutions, and to qualified public or private entities, to develop and implement state-of-the-art systems for notifying victims of crime of important dates and developments relating to the criminal proceedings at issue in a timely and efficient manner, provided that the jurisdiction has laws substantially equivalent to the provisions of chapter 237 of title 18."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Systems developed and implemented under this section may be integrated with existing case management systems operated by the recipient of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20101/d"},"text":"section 20101(d) of this title","children":[],"tail":", there are authorized to be appropriated to carry out this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d1f1f8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2005; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d1f1f8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of the fiscal years 2006, 2007, 2008, and 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d1f1f8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False Claims Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, amounts collected pursuant to sections 3729 through 3731 of title 31 (commonly known as the “False Claims Act”) may be used for grants under this section, subject to appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d1f1f8d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s1404E"},"text":"Pub. L. 98–473, title II, § 1404E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/405/tI/s103/c"},"text":"Pub. L. 108–405, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2265"},"text":"118 Stat. 2265","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d1f1f8e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d1f1f8f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d1f1f90-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10603e"},"text":"section 10603e of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
