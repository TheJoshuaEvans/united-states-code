{"tag":"section","attrib":{"id":"id4d643f46-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521"},"text":null,"children":[{"tag":"num","attrib":{"value":"60521"},"text":"§ 60521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offender reentry substance abuse and criminal justice collaboration program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d643f47-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may make competitive grants to States, units of local government, territories, and Indian Tribes, in accordance with this section, for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f48-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the provision of drug treatment to offenders in prisons, jails, and juvenile facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f49-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the use of alcohol and other drugs by long-term substance abusers during the period in which each such long-term substance abuser is in prison, jail, or a juvenile facility, and through the completion of parole or court supervision of such long-term substance abuser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f4a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant made under subsection (a) may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f4b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for continuing and improving drug treatment programs provided at a prison, jail, or juvenile facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f4c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and implement programs for supervised long-term substance abusers that include alcohol and drug abuse assessments, coordinated and continuous delivery of drug treatment, and case management services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f4d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen rehabilitation efforts for offenders by providing addiction recovery support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f4e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish pharmacological drug treatment services as part of any drug treatment program offered by a grantee to offenders who are in a prison or jail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f4f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f50-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity described in subsection (a) desiring a grant under that subsection shall submit to the Attorney General an application in such form and manner and at such time as the Attorney General requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f51-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a grant under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643f52-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any agency, organization, or researcher that will be involved in administering a drug treatment program carried out with a grant under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f53-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that such drug treatment program has been developed in consultation with the Single State Authority for Substance Abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f54-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certify that such drug treatment program shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id4d643f55-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be clinically-appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id4d643f56-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide comprehensive treatment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f57-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how evidence-based strategies have been incorporated into such drug treatment program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f58-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how data will be collected and analyzed to determine the effectiveness of such drug treatment program and describe how randomized trials will be used where practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f59-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f5a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"September 30, 2009","children":[],"tail":", the Attorney General shall submit to Congress a report that identifies the best practices relating to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d643f5b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance abuse treatment in prisons, jails, and juvenile facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d643f5c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive and coordinated treatment of long-term substance abusers, including the best practices identified through the activities funded under subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f5d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":", the Attorney General shall submit to Congress a report on the drug treatment programs funded under this section, including on the matters specified in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f5e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Single State Authority for Substance Abuse","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Single State Authority for Substance Abuse” means an entity designated by the Governor or chief executive officer of a State as the single State administrative authority responsible for the planning, development, implementation, monitoring, regulation, and evaluation of substance abuse services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d643f5f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d643f60-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d643f61-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s60521/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution of grant amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount made available to carry out this section in any fiscal year, the Attorney General shall ensure that grants awarded under this section are equitably distributed among geographical regions and between urban and rural populations, including Indian Tribes, consistent with the objective of reducing recidivism among criminal offenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d643f62-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/199/tII/s201"},"text":"Pub. L. 110–199, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-09"},"text":"Apr. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/678"},"text":"122 Stat. 678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/391/tV/s502/e"},"text":"Pub. L. 115–391, title V, § 502(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5230"},"text":"132 Stat. 5230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d643f63-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d643f64-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d643f65-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17521"},"text":"section 17521 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id4d643f66-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/391"},"text":"Pub. L. 115–391","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “There are authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2009 and 2010.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
