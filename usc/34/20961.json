{"tag":"section","attrib":{"id":"id4d36ee86-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961"},"text":null,"children":[{"tag":"num","attrib":{"value":"20961"},"text":"§ 20961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to national crime information databases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36ee87-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Attorney General shall ensure access to the national crime information databases (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s534"},"text":"section 534 of title 28","children":[],"tail":") by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee88-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Missing and Exploited Children, to be used only within the scope of the Center’s duties and responsibilities under Federal law to assist or support law enforcement agencies in administration of criminal justice functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee89-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governmental social service agencies with child protection responsibilities, to be used by such agencies only in investigating or responding to reports of child abuse, neglect, or exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36ee8a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions of access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The access provided under this section, and associated rules of dissemination, shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36ee8b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defined by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36ee8c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20961/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limited to personnel of the Center or such agencies that have met all requirements set by the Attorney General, including training, certification, and background screening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36ee8d-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s151"},"text":"Pub. L. 109–248, title I, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/608"},"text":"120 Stat. 608","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36ee8e-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36ee8f-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36ee90-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16961"},"text":"section 16961 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
