{"tag":"section","attrib":{"id":"id4d07528b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12442"},"text":null,"children":[{"tag":"num","attrib":{"value":"12442"},"text":"§ 12442.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose areas","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Grants made under this part may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d07528c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12442/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or improve protocols, procedures, and policies for the purpose of preventing the release of personally identifying information of victims (such as developing alternative identifiers);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07528d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12442/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defray the costs of modifying or improving existing databases, registries, and victim notification systems to ensure that personally identifying information of victims is protected from release, unauthorized information sharing and disclosure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07528e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12442/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop confidential opt out systems that will enable victims of violence to make a single request to keep personally identifying information out of multiple databases, victim notification systems, and registries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d07528f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12442/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop safe uses of technology (such as notice requirements regarding electronic surveillance by government entities), to protect against abuses of technology (such as electronic or GPS stalking), or providing training for law enforcement on high tech electronic crimes of domestic violence, dating violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d075290-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s41102"},"text":"Pub. L. 103–322, title IV, § 41102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tI/s107"},"text":"Pub. L. 109–162, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2983"},"text":"119 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d075291-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075292-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d075293-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14043b–1"},"text":"section 14043b–1 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
