{"tag":"section","attrib":{"id":"id4d15aa04-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578"},"text":null,"children":[{"tag":"num","attrib":{"value":"12578"},"text":"§ 12578.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d15aa05-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person who receives a scholarship under this part shall enter into an agreement with the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15aa06-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement described in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d15aa07-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assurances that the scholarship recipient will work in a law enforcement position in the State that awarded the scholarship in accordance with the service obligation described in subsection (c) after completion of the scholarship recipient’s academic courses leading to an associate, bachelor, or graduate degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15aa08-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide assurances that the scholarship recipient will repay the entire scholarship in accordance with such terms and conditions as the Director shall prescribe if the requirements of the agreement are not complied with, unless the scholarship recipient—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d15aa09-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15aa0a-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes physically or emotionally disabled, as established by the sworn affidavit of a qualified physician; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d15aa0b-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been discharged in bankruptcy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15aa0c-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the terms and conditions under which the scholarship recipient may seek employment in the field of law enforcement in a State other than the State that awarded the scholarship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d15aa0d-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service obligation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d15aa0e-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a person who receives a scholarship under this part shall work in a law enforcement position in the State that awarded the scholarship for a period of 1 month for each credit hour for which funds are received under the scholarship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d15aa0f-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12578/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of satisfying the requirement of paragraph (1), a scholarship recipient shall work in a law enforcement position in the State that awarded the scholarship for not less than 6 months but shall not be required to work in such a position for more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d15aa10-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXX/s200209"},"text":"Pub. L. 103–322, title XX, § 200209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2060"},"text":"108 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d15aa11-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d15aa12-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d15aa13-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14118"},"text":"section 14118 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
