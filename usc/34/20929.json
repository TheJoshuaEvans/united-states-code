{"tag":"section","attrib":{"id":"id4d36edaf-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929"},"text":null,"children":[{"tag":"num","attrib":{"value":"20929"},"text":"§ 20929.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election by Indian tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id4d36edb0-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36edb1-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A federally recognized Indian tribe may, by resolution or other enactment of the tribal council or comparable governmental body—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d36edb2-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to carry out this part as a jurisdiction subject to its provisions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d36edb3-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to delegate its functions under this part to another jurisdiction or jurisdictions within which the territory of the tribe is located and to provide access to its territory and such other cooperation and assistance as may be needed to enable such other jurisdiction or jurisdictions to carry out and enforce the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36edb4-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imputed election in certain cases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribe shall be treated as if it had made the election described in paragraph (1)(B) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d36edb5-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is a tribe subject to the law enforcement jurisdiction of a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1162"},"text":"section 1162 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d36edb6-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tribe does not make an election under paragraph (1) within 1 year of ","children":[{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":" or rescinds an election under paragraph (1)(A); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d36edb7-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General determines that the tribe has not substantially implemented the requirements of this part and is not likely to become capable of doing so within a reasonable amount of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id4d36edb8-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation between tribal authorities and other jurisdictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id4d36edb9-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A tribe subject to this part is not required to duplicate functions under this part which are fully carried out by another jurisdiction or jurisdictions within which the territory of the tribe is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id4d36edba-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribe may, through cooperative agreements with such a jurisdiction or jurisdictions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id4d36edbb-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for the tribe to carry out any function of such a jurisdiction under this part with respect to sex offenders subject to the tribe’s jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id4d36edbc-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s20929/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for such a jurisdiction to carry out any function of the tribe under this part with respect to sex offenders subject to the tribe’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id4d36edbd-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248/tI/s127"},"text":"Pub. L. 109–248, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/599"},"text":"120 Stat. 599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d36edbe-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d36edbf-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id4d36edc0-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in text, was in the original “this subtitle”, meaning subtitle A (§§ 111–131) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/248"},"text":"Pub. L. 109–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-27"},"text":"July 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/591"},"text":"120 Stat. 591","children":[],"tail":", which is classified principally to this part. For complete classification of subtitle A to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d36edc1-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16927"},"text":"section 16927 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
