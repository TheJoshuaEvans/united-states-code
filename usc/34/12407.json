{"tag":"section","attrib":{"id":"id4d075236-5dcd-11f1-b11b-9e551e93f87d","identifier":"/us/usc/t34/s12407"},"text":null,"children":[{"tag":"num","attrib":{"value":"12407"},"text":"§ 12407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations on intrastate communication","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The State Justice Institute, after consultation with nationally recognized nonprofit associations with expertise in data sharing among criminal justice agencies and familiarity with the issues raised in stalking and domestic violence cases, shall recommend proposals regarding how State courts may increase intrastate communication between civil and criminal courts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id4d075237-5dcd-11f1-b11b-9e551e93f87d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40608"},"text":"Pub. L. 103–322, title IV, § 40608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1952"},"text":"108 Stat. 1952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id4d075238-5dcd-11f1-b11b-9e551e93f87d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id4d075239-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id4d07523a-5dcd-11f1-b11b-9e551e93f87d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14037"},"text":"section 14037 of Title 42","children":[],"tail":", The Public Health and Welfare, prior to editorial reclassification and renumbering as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
