{"tag":"section","attrib":{"id":"id52a24400-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1342"},"text":null,"children":[{"tag":"num","attrib":{"value":"1342"},"text":"§ 1342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rate orders of State agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The district courts shall not enjoin, suspend or restrain the operation of, or compliance with, any order affecting rates chargeable by a public utility and made by a State administrative agency or a rate-making body of a State political subdivision, where:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a24401-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1342/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Jurisdiction is based solely on diversity of citizenship or repugnance of the order to the Federal Constitution; and,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a24402-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1342/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The order does not interfere with interstate commerce; and,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a24403-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1342/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The order has been made after reasonable notice and hearing; and,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a24404-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1342/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plain, speedy and efficient remedy may be had in the courts of such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a24405-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/932"},"text":"62 Stat. 932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a24406-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a24407-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(1) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 1, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1091"},"text":"36 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-14/ch283/s1"},"text":"May 14, 1934, ch. 283, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/775"},"text":"48 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-08-21/ch726/s1"},"text":"Aug. 21, 1937, ch. 726, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/738"},"text":"50 Stat. 738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-04-20/ch117"},"text":"Apr. 20, 1940, ch. 117","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/143"},"text":"54 Stat. 143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section rearranges and restates the fourth sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/1"},"text":"section 41(1) of title 28","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/1"},"text":"section 41(1) of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 1331, 1332, 1341, 1345, 1354, and 1359 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “at law or in equity” before “in the courts of such State” were omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suit,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “operation” was substituted for “enforcement, operation or execution” for the same reason.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
