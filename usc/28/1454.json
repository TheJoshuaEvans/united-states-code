{"tag":"section","attrib":{"id":"id52abe194-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454"},"text":null,"children":[{"tag":"num","attrib":{"value":"1454"},"text":"§ 1454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patent, plant variety protection, and copyright cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52abe195-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action in which any party asserts a claim for relief arising under any Act of Congress relating to patents, plant variety protection, or copyrights may be removed to the district court of the United States for the district and division embracing the place where the action is pending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe196-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rules","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The removal of an action under this section shall be made in accordance with section 1446, except that if the removal is based solely on this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52abe197-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action may be removed by any party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe198-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time limitations contained in section 1446(b) may be extended at any time for cause shown.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe199-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification of Jurisdiction in Certain Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court to which a civil action is removed under this section is not precluded from hearing and determining any claim in the civil action because the State court from which the civil action is removed did not have jurisdiction over that claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe19a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remand","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a civil action is removed solely under this section, the district court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52abe19b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remand all claims that are neither a basis for removal under subsection (a) nor within the original or supplemental jurisdiction of the district court under any Act of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe19c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1454/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, under the circumstances specified in section 1367(c), remand any claims within the supplemental jurisdiction of the district court under section 1367.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52abe19d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/29/s19/c/1"},"text":"Pub. L. 112–29, § 19(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/332"},"text":"125 Stat. 332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52abe19e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52abe19f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52abe1a0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any civil action commenced on or after ","children":[{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/29/s19/e"},"text":"section 19(e) of Pub. L. 112–29","children":[],"tail":", set out as an Effective Date of 2011 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1295"},"text":"section 1295 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
