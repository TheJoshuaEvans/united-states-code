{"tag":"section","attrib":{"id":"id52ee9086-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perishable personal property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ee9087-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Sell","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If at any time during any action or proceeding under this chapter the court determines on its own initiative or upon motion of any party, that any seized or detained personal property is likely to perish, waste, or be destroyed, or otherwise substantially depreciate in value during the pendency of the proceeding, the court shall order a commercially reasonable sale of such property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9088-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of Sale Proceeds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 5 days after such sale, the proceeds shall be deposited with the clerk of the court, accompanied by a statement in writing and signed by the United States marshal, to be filed in the action or proceeding, stating the time and place of sale, the name of the purchaser, the amount received, and an itemized account of expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9089-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of liability on the part of the United States, there shall be a presumption that the price paid at a sale under subsection (a) is the fair market value of the property or portion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee908a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4937"},"text":"104 Stat. 4937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee908b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee908c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee908d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
