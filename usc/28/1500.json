{"tag":"section","attrib":{"id":"id52ae2b21-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1500"},"text":null,"children":[{"tag":"num","attrib":{"value":"1500"},"text":"§ 1500.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pendency of claims in other courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Court of Federal Claims shall not have jurisdiction of any claim for or in respect to which the plaintiff or his assignee has pending in any other court any suit or process against the United States or any person who, at the time when the cause of action alleged in such suit or process arose, was, in respect thereto, acting or professing to act, directly or indirectly under the authority of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ae2b22-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/942"},"text":"62 Stat. 942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s133/e/1"},"text":"Pub. L. 97–164, title I, § 133(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/40"},"text":"96 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ae2b23-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ae2b24-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 260 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s154"},"text":"Mar. 3, 1911, ch. 231, § 154","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1138"},"text":"36 Stat. 1138","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or in the Supreme Court on appeal therefrom” were omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ae2b25-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ae2b26-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “United States Claims Court” for “Court of Claims”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ae2b27-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related