{"tag":"section","attrib":{"id":"id52e9d486-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2634"},"text":null,"children":[{"tag":"num","attrib":{"value":"2634"},"text":"§ 2634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Reasonable notice of the time and place of trial or hearing before the Court of International Trade shall be given to all parties to any civil action, as prescribed by the rules of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52e9d487-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s301"},"text":"Pub. L. 96–417, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1733"},"text":"94 Stat. 1733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e9d488-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e9d489-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52e9d48a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2634, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/981"},"text":"62 Stat. 981","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-06-02"},"text"