{"tag":"section","attrib":{"id":"id524556f3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s293"},"text":null,"children":[{"tag":"num","attrib":{"value":"293"},"text":"§ 293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judges of the Court of International Trade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524556f4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s293/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" The Chief Justice of the United States may designate and assign temporarily any judge of the Court of International Trade to perform judicial duties in any circuit, either in a court of appeals or district court, upon presentation of a certificate of necessity by the chief judge or circuit justice of the circuit in which the need arises."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524556f5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/901"},"text":"62 Stat. 901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-14/ch589/s3/a"},"text":"July 14, 1956, ch. 589, § 3(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/532"},"text":"70 Stat. 532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/755/s4"},"text":"Pub. L. 85–755, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-25"},"text":"Aug. 25, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/848"},"text":"72 Stat. 848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s205"},"text":"Pub. L. 95–598, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2660"},"text":"92 Stat. 2660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tI/s102"},"text":"Pub. L. 96–417, title I, § 102","children":[],"tail":", title V, § 501(8), "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1727"},"text":"94 Stat. 1727","children":[],"tail":", 1742; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s110/a"},"text":"Pub. L. 97–164, title I, § 110(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/29"},"text":"96 Stat. 29","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id524556f6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id524556f7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 301 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s188"},"text":"Mar. 3, 1911, ch. 231, § 188","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1143"},"text":"36 Stat. 1143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-03-02/ch488/s1"},"text":"Mar. 2, 1929, ch. 488, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1475"},"text":"45 Stat. 1475","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section simplifies last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s301"},"text":"section 301 of title 28","children":[],"tail":", U.S.C., 1940 ed., and is in conformity with other designation and assignment provisions of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s301"},"text":"section 301 of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 211–213, 215, and 296 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section transfers from the President to the Chief Justice of the United States the authority to designate and assign which is in conformity with sections 201 and 292 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “he is willing to undertake” were added to make clear that such service is voluntary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The term “chief judge” was substituted for “presiding judge.” (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s136"},"text":"section 136 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id524556f8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id524556f9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s110/b"},"text":"Pub. L. 97–164, § 110(b)","children":[],"tail":", substituted “the Court of International Trade” for “other courts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s110/a/1"},"text":"Pub. L. 97–164, § 110(a)(1)","children":[],"tail":", (2), redesignated subsec. (b) as (a). Former subsec. (a), which authorized the Chief Justice to designate and assign judges of the Court of Claims or the Court of Customs and Patent Appeals to serve temporarily on the other of these two courts or in a court of appeals or district court of any circuit in times of necessity, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s110/a/2"},"text":"Pub. L. 97–164, § 110(a)(2)","children":[],"tail":", (3), redesignated subsec. (e), as that subsec. was to have become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", as subsec. (b). Former subsec. (b) redesignated (a). See 1978 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s110/a/1"},"text":"Pub. L. 97–164, § 110(a)(1)","children":[],"tail":", struck out subsecs. (c) and (d) which related, respectively, to the authority of the chief judge of the Court of Customs and Patent Appeals to designate and assign temporarily any judge of the Court of Customs and Patent Appeals to serve as a judge of the Court of International Trade and to the authority of the chief judge of the Court of International Trade to designate and assign temporarily any judge of the Court of International Trade to serve as a judge of the Court of Customs and Patent Appeals or the Court of Claims."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s110/a/3"},"text":"Pub. L. 97–164, § 110(a)(3)","children":[],"tail":", redesignated subsec. (e), as that subsec. was to have become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":", as subsec. (b). See 1978 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/s102/a"},"text":"Pub. L. 96–417, § 102(a)","children":[],"tail":", redesignated the Customs Court as the Court of International Trade and authorized performance of judicial functions in a court of appeals."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/s501/8"},"text":"Pub. L. 96–417, § 501(8)","children":[],"tail":", redesignated the Customs Court as the Court of International Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/s102/b"},"text":"Pub. L. 96–417, § 102(b)","children":[],"tail":", redesignated the Customs Court as the Court of International Trade and authorized temporary assignments to the Court of Claims of judges of the Court of International Trade upon presentation of a certificate of necessity by the chief judge of the Court of Claims."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" directed the amendment of this section by adding subsec. (e) relating to temporary assignments of bankruptcy judges, which amendment did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/b"},"text":"section 402(b) of Pub. L. 95–598","children":[],"tail":", as amended, set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" substituted “Judges of other courts” for “Circuit or district judges to court of customs and patent appeals” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" added subsec. (a). It incorporates provisions of former sections 291(a), (b) and 292(e) of this title respecting assignment of any judge of the Court of Claims to serve as circuit judge in any circuit, assignment of judges of the Court of Customs and Patent Appeals to serve as judges of the Court of Appeals or the District Court of Appeals or the District Court for the District of Columbia, and assignment of judges of the Court of Claims to district courts, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" designated existing second par. as subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-14"},"text":"July 14, 1956","children":[],"tail":", authorized the Chief Justice of the United States to designate and assign temporarily a judge of the Customs Court to perform judicial duties in a district court in any circuit."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5247a0ea-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5247a0eb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5247a0ec-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", and applicable with respect to civil actions pending on or commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/a"},"text":"section 701(a) of Pub. L. 96–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5247a0ed-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Jurisdiction of United States Court of Customs and Patent Appeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" not limiting or altering the jurisdiction of the United States Court of Customs and Patent Appeals [now United States Court of Appeals for the Federal Circuit], see "},{"tag":"ref","attrib":{"href":"/us/pl/85/755/s7"},"text":"section 7 of Pub. L. 85–755","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s291"},"text":"section 291 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5247a0ee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation or Alteration of Jurisdiction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by act ","children":[{"tag":"date","attrib":{"date":"1956-07-14"},"text":"July 14, 1956","children":[],"tail":", not to be construed as limiting or altering the jurisdiction heretofore conferred upon the Customs Court [now United States Court of International Trade], see section 4 of act "},{"tag":"date","attrib":{"date":"1956-07-14"},"text":"July 14, 1956","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
