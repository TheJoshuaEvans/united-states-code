{"tag":"section","attrib":{"id":"id5293eb9d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s714"},"text":null,"children":[{"tag":"num","attrib":{"value":"714"},"text":"§ 714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criers and messengers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5293eb9e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each court of appeals may appoint a crier who shall be subject to removal by the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5293eb9f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The crier, with the approval of the court, may appoint necessary messengers in such number as the Director of the Administrative Office of the United States Courts may approve. The crier may remove such messengers with the approval of the court. The crier shall also perform the duties of bailiff and messenger.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5293eba0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s120/c/1"},"text":"Pub. L. 97–164, title I, § 120(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/33"},"text":"96 Stat. 33","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5293eba1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5293eba2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5293eba3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as an Effective Date of 1982 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5293eba4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of This Section to Court of Appeals for District of Columbia During Continued Service of Marshal for Court in Office on ","children":[{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a) of this section not applicable to the Court of Appeals for the District of Columbia during the continued service as Marshal for such Court of any individual who was serving in such office under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s713/c"},"text":"section 713(c) of this title","children":[],"tail":" as of "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s415"},"text":"section 415 of Pub. L. 98–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s713"},"text":"section 713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}]