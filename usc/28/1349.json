{"tag":"section","attrib":{"id":"id52a24449-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1349"},"text":null,"children":[{"tag":"num","attrib":{"value":"1349"},"text":"§ 1349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporation organized under federal law as party","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall not have jurisdiction of any civil action by or against any corporation upon the ground that it was incorporated by or under an Act of Congress, unless the United States is the owner of more than one-half of its capital stock.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a2444a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/934"},"text":"62 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a2444b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a2444c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 42 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1925-02-13/ch229/s12"},"text":"Feb. 13, 1925, ch. 229, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/941"},"text":"43 Stat. 941","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “action or suit,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
