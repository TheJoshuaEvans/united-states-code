{"tag":"section","attrib":{"id":"id52f0ffc6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3015"},"text":null,"children":[{"tag":"num","attrib":{"value":"3015"},"text":"§ 3015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery as to debtor’s financial condition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f0ffc7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), in an action or proceeding under subchapter B or C, the United States may have discovery regarding the financial condition of the debtor in the manner in which discovery is authorized by the Federal Rules of Civil Procedure in an action on a claim for a debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f0ffc8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply with respect to an action or proceeding under subchapter B unless there is a reasonable likelihood that the debt involved exceeds $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f0ffc9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4939"},"text":"104 Stat. 4939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f0ffca-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52f0ffcb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52f0ffcc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (a), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f0ffcd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f0ffce-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
