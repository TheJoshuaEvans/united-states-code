{"tag":"section","attrib":{"id":"id52e51989-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2504"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504"},"text":"§ 2504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plaintiff’s testimony","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Court of Federal Claims may, at the instance of the Attorney General, order any plaintiff to appear, upon reasonable notice, before any judge of the court and be examined on oath as to all matters pertaining to his claim. Such examination shall be reduced to writing by the judge, and shall be returned to and filed in the court, and may, at the discretion of the attorneys for the United States, be read and used as evidence on the trial. If any plaintiff, after such order is made and due and reasonable notice thereof is given to him, fails to appear, or refuses to testify or answer fully as to all material matters within his knowledge, the court may order that the case shall not be tried until he fully complies with such order.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52e5198a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/976"},"text":"62 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s139/c"},"text":"Pub. L. 97–164, title I, § 139(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/42"},"text":"96 Stat. 42","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e5198b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52e5198c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 274 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s166"},"text":"Mar. 3, 1911, ch. 231, § 166","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1140"},"text":"36 Stat. 1140","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Attorney General” were substituted for “attorney or solicitor appearing in behalf of the United States,” in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s309"},"text":"section 309 of title 5","children":[],"tail":", U.S.C., 1940 ed., Executive Departments and Government Officers and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e5198d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e5198e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “United States Claims Court” for “Court of Claims”, and “judge” for “commissioner” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e5198f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e51990-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e51991-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub