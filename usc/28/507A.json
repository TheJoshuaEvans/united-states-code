{"tag":"section","attrib":{"id":"id525d24d9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507A"},"text":null,"children":[{"tag":"num","attrib":{"value":"507A"},"text":"§ 507A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Attorney General for National Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525d24da-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the Assistant Attorneys General appointed under section 506, one shall serve, upon the designation of the President, as the Assistant Attorney General for National Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525d24db-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Assistant Attorney General for National Security shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525d24dc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the head of the National Security Division of the Department of Justice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s509A"},"text":"section 509A of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525d24dd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as primary liaison to the Director of National Intelligence for the Department of Justice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525d24de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as the Attorney General may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525d24df-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s506/a/1"},"text":"Pub. L. 109–177, title V, § 506(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/247"},"text":"120 Stat. 247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
