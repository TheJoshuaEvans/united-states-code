{"tag":"section","attrib":{"id":"id52cf9601-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2251"},"text":null,"children":[{"tag":"num","attrib":{"value":"2251"},"text":"§ 2251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stay of State court proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52cf9602-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52cf9603-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending matters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A justice or judge of the United States before whom a habeas corpus proceeding is pending, may, before final judgment or after final judgment of discharge, or pending appeal, stay any proceeding against the person detained in any State court or by or under the authority of any State for any matter involved in the habeas corpus proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52cf9604-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matter not pending","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a habeas corpus proceeding is not pending until the application is filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52cf9605-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2251/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application for appointment of counsel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a State prisoner sentenced to death applies for appointment of counsel pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3599/a/2"},"text":"section 3599(a)(2) of title 18","children":[],"tail":" in a court that would have jurisdiction to entertain a habeas corpus application regarding that sentence, that court may stay execution of the sentence of death, but such stay shall terminate not later than 90 days after counsel is appointed or the application for appointment of counsel is withdrawn or denied."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cf9606-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Further Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the granting of such a stay, any such proceeding in any State court or by or under the authority of any State shall be void. If no stay is granted, any such proceeding shall be as valid as if no habeas corpus proceedings or appeal were pending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52cf9607-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/966"},"text":"62 Stat. 966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s507/f"},"text":"Pub. L. 109–177, title V, § 507(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/251"},"text":"120 Stat. 251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cf9608-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cf9609-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 465 (R.S. § 766; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-03/ch226"},"text":"Mar. 3, 1893, ch. 226","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/751"},"text":"27 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-13/ch229/s8/c"},"text":"Feb. 13, 1925, ch. 229, § 8(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/940"},"text":"43 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-19/ch673"},"text":"June 19, 1934, ch. 673","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1177"},"text":"48 Stat. 1177","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions relating to proceedings pending in 1934 were deleted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision requiring an appeal to be taken within 3 months was omitted as covered by sections 2101 and 2107 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52cf960a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52cf960b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" designated first par. of existing provisions as subsec. (a)(1) and inserted headings, added pars. (2) and (3), and designated second par. of existing provisions as subsec. (b) and inserted heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52cf960c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cf960d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s507/d"},"text":"Pub. L. 109–177, title V, § 507(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/251"},"text":"120 Stat. 251","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/177/tV/s507/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2265"},"text":"section 2265 of this title","children":[],"tail":", amending this section and sections 2261 and 2266 of this title, and repealing former "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2265"},"text":"section 2265 of this title","children":[],"tail":"] and the amendments made by this section shall apply to cases pending on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time limits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case pending on the date of enactment of this Act, if the amendments made by this section establish a time limit for taking certain action, the period of which began on the date of an event that occurred prior to the date of enactment of this Act, the period of such time limit shall instead begin on the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
