{"tag":"section","attrib":{"id":"id5270372a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535"},"text":null,"children":[{"tag":"num","attrib":{"value":"535"},"text":"§ 535.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of crimes involving Government officers and employees; limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5270372b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Attorney General and the Federal Bureau of Investigation may investigate any violation of Federal criminal law involving Government officers and employees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5270372c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270372d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without limiting the authority to investigate any matter which is conferred on them or on a department or agency of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270372e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any information, allegation, matter, or complaint witnessed, discovered, or received in a department or agency of the executive branch of the Government relating to violations of Federal criminal law involving Government officers and employees shall be expeditiously reported to the Attorney General by the head of the department or agency, or the witness, discoverer, or recipient, as appropriate, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5270372f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibility to perform an investigation with respect thereto is specifically assigned otherwise by another provision of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703730-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to any department or agency of the Government, the Attorney General directs otherwise with respect to a specified class of information, allegation, or complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52703731-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not limit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52703732-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the military departments to investigate persons or offenses over which the armed forces have jurisdiction under the Uniform Code of Military Justice (chapter 47 of title 10); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703733-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s535/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the primary authority of the Postmaster General to investigate postal offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52703734-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/616"},"text":"80 Stat. 616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tII/s206"},"text":"Pub. L. 107–273, div. A, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1779"},"text":"116 Stat. 1779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52703735-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52703736-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id52703737-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s311a"},"text":"5 U.S.C. 311a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-08-31/ch1143/s1"},"text":"Aug. 31, 1954, ch. 1143, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/998"},"text":"68 Stat. 998","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is reorganized for clarity and continuity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “may” is substituted for “shall have authority”. The word “is” is substituted for “may have been or may hereafter be”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “This section does not limit” are substituted for “that the provisions of this section shall not limit, in any way”. The words “(chapter 47 of title 10)” are added after “Uniform Code of Military Justice” to reflect the codification of that Code in title 10, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52703738-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52703739-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" substituted “Federal criminal law” for “title 18” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", in introductory provisions, substituted “matter, or complaint witnessed, discovered, or” for “or complaint” and “Federal criminal law” for “title 18” and inserted “or the witness, discoverer, or recipient, as appropriate,” after “agency,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5270373a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id5270373b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Postmaster General of Post Office Department abolished and all functions, powers, and duties of Postmaster General transferred to United States Postal Service by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375/s4/a"},"text":"Pub. L. 91–375, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s201"},"text":"section 201 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
