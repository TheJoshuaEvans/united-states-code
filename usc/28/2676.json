{"tag":"section","attrib":{"id":"id52ec457d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2676"},"text":null,"children":[{"tag":"num","attrib":{"value":"2676"},"text":"§ 2676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgment as bar","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The judgment in an action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/b"},"text":"section 1346(b) of this title","children":[],"tail":" shall constitute a complete bar to any action by the claimant, by reason of the same subject matter, against the employee of the government whose act or omission gave rise to the claim."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ec457e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/984"},"text":"62 Stat. 984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ec457f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ec4580-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 931(b) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753/s410/b"},"text":"Aug. 2, 1946, ch. 753, § 410(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/844"},"text":"60 Stat. 844","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section constitutes the first sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s931/b"},"text":"section 931(b) of title 28","children":[],"tail":", U.S.C., 1940 ed. Other provisions of such section 931(b) are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2675"},"text":"section 2675 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52ec4581-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Revision Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was eliminated by Senate amendment. See 80th Congress Senate Report No. 1559.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
