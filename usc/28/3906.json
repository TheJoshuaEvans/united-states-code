{"tag":"section","attrib":{"id":"id52f5bbdf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3906"},"text":null,"children":[{"tag":"num","attrib":{"value":"3906"},"text":"§ 3906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A judgment, award, or compromise settlement against the United States under this chapter (including any interest and costs) shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bbe0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", if it arises out of an action commenced in a district court of the United States (or any appeal therefrom); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bbe1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" out of amounts otherwise appropriated or available to the office involved, if it arises out of an appeal from an administrative proceeding under chapter 5 of title 3.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f5bbe2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/c"},"text":"Pub. L. 104–331, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4071"},"text":"110 Stat. 4071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f5bbe3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\