{"tag":"section","attrib":{"id":"id52e51920-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466"},"text":null,"children":[{"tag":"num","attrib":{"value":"2466"},"text":"§ 2466.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fugitive disentitlement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e51921-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A judicial officer may disallow a person from using the resources of the courts of the United States in furtherance of a claim in any related civil forfeiture action or a claim in third party proceedings in any related criminal forfeiture action upon a finding that such person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52e51922-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after notice or knowledge of the fact that a warrant or process has been issued for his apprehension, in order to avoid criminal prosecution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52e51923-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purposely leaves the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52e51924-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declines to enter or reenter the United States to submit to its jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52e51925-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise evades the jurisdiction of the court in which a criminal case is pending against the person; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e51926-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not confined or held in custody in any other jurisdiction for commission of criminal conduct in that jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e51927-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2466/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) may be applied to a claim filed by a corporation if any majority shareholder, or individual filing the claim on behalf of the corporation is a person to whom subsection (a) applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e51928-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s14/a"},"text":"Pub. L. 106–185, § 14(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/219"},"text":"114 Stat. 219","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s322"},"text":"Pub. L. 107–56, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/315"},"text":"115 Stat. 315","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1171/c"},"text":"Pub. L. 109–162, title XI, § 1171(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3123"},"text":"119 Stat. 3123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tIV/s406/a/1"},"text":"Pub. L. 109–177, title IV, § 406(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/244"},"text":"120 Stat. 244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e51929-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e5192a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e5192b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" directed amendment of directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/s322"},"text":"Pub. L. 107–56, § 322","children":[],"tail":", identical to amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/s322"},"text":"Pub. L. 107–56, § 322","children":[],"tail":". See 2001 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s322"},"text":"Pub. L. 107–56, § 322","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":", designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e5192c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e5192d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1171/c"},"text":"Pub. L. 109–162, title XI, § 1171(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3123"},"text":"119 Stat. 3123","children":[],"tail":", provided in part that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/s1171/c"},"text":"section 1171(c) of Pub. L. 109–162","children":[],"tail":" is effective "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52e5192e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/185/s14/c"},"text":"Pub. L. 106–185, § 14(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/219"},"text":"114 Stat. 219","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/185/s14/c"},"text":"“The amendments made by this section [enacting this section] shall apply to any case pending on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-04-25"},"text":"Apr. 25, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
