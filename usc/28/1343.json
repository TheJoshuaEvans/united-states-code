{"tag":"section","attrib":{"id":"id52a24408-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343"},"text":null,"children":[{"tag":"num","attrib":{"value":"1343"},"text":"§ 1343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil rights and elective franchise","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a24409-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The district courts shall have original jurisdiction of any civil action authorized by law to be commenced by any person:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a2440a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recover damages for injury to his person or property, or because of the deprivation of any right or privilege of a citizen of the United States, by any act done in furtherance of any conspiracy mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1985"},"text":"section 1985 of Title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a2440b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recover damages from any person who fails to prevent or to aid in preventing any wrongs mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1985"},"text":"section 1985 of Title 42","children":[],"tail":" which he had knowledge were about to occur and power to prevent;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a2440c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To redress the deprivation, under color of any State law, statute, ordinance, regulation, custom or usage, of any right, privilege or immunity secured by the Constitution of the United States or by any Act of Congress providing for equal rights of citizens or of all persons within the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a2440d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recover damages or to secure equitable or other relief under any Act of Congress providing for the protection of civil rights, including the right to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a2440e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a2440f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia shall be considered to be a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a24410-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Act of Congress applicable exclusively to the District of Columbia shall be considered to be a statute of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a24411-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/932"},"text":"62 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s42"},"text":"Sept. 3, 1954, ch. 1263, § 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1241"},"text":"68 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/315/ptIII/s121"},"text":"Pub. L. 85–315, part III, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-09-09"},"text":"Sept. 9, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/637"},"text":"71 Stat. 637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/170/s2"},"text":"Pub. L. 96–170, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1284"},"text":"93 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a24412-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a24413-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(12), (13), and (14) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", pars. 12, 13, 14, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1092"},"text":"36 Stat. 1092","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suits,” “suits at law or in equity” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Numerous changes were made in arrangement and phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a24414-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a24415-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/170"},"text":"Pub. L. 96–170","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1957—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/315"},"text":"Pub. L. 85–315","children":[],"tail":" inserted “and elective franchise” in section catchline and added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1985"},"text":"section 1985 of Title 42","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t8/s47"},"text":"section 47 of Title 8","children":[],"tail":"” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a24416-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a24417-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/170/s3"},"text":"Pub. L. 96–170, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1284"},"text":"93 Stat. 1284","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/170/s3"},"text":"“The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1983"},"text":"section 1983 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply with respect to any deprivation of rights, privileges, or immunities secured by the Constitution and laws occurring after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
