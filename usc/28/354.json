{"tag":"section","attrib":{"id":"id524c8294-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354"},"text":null,"children":[{"tag":"num","attrib":{"value":"354"},"text":"§ 354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by judicial council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524c8295-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Upon Receipt of Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id524c8296-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The judicial council of a circuit, upon receipt of a report filed under section 353(c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524c8297-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct any additional investigation which it considers to be necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524c8298-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may dismiss the complaint; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524c8299-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the complaint is not dismissed, shall take such action as is appropriate to assure the effective and expeditious administration of the business of the courts within the circuit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524c829a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of possible actions if complaint not dismissed.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524c829b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Action by the judicial council under paragraph (1)(C) may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id524c829c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ordering that, on a temporary basis for a time certain, no further cases be assigned to the judge whose conduct is the subject of a complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id524c829d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" censuring or reprimanding such judge by means of private communication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id524c829e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" censuring or reprimanding such judge by means of public announcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524c829f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"For article iii judges","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the conduct of a judge appointed to hold office during good behavior is the subject of the complaint, action by the judicial council under paragraph (1)(C) may include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id524c82a0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifying disability of the judge pursuant to the procedures and standards provided under section 372(b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id524c82a1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting that the judge voluntarily retire, with the provision that the length of service requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s371"},"text":"section 371 of this title","children":[],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524c82a2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"For magistrate judges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the conduct of a magistrate judge is the subject of the complaint, action by the judicial council under paragraph (1)(C) may include directing the chief judge of the district of the magistrate judge to take such action as the judicial council considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524c82a3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on judicial council regarding removals.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524c82a4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Article iii judges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under no circumstances may the judicial council order removal from office of any judge appointed to hold office during good behavior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524c82a5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Magistrate and bankruptcy judges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any removal of a magistrate judge under this subsection shall be in accordance with section 631 and any removal of a bankruptcy judge shall be in accordance with section 152.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524c82a6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of action to judge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The judicial council shall immediately provide written notice to the complainant and to the judge whose conduct is the subject of the complaint of the action taken under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524c82a7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral to Judicial Conference.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id524c82a8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the authority granted under subsection (a), the judicial council may, in its discretion, refer any complaint under section 351, together with the record of any associated proceedings and its recommendations for appropriate action, to the Judicial Conference of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524c82a9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which the judicial council determines, on the basis of a complaint and an investigation under this chapter, or on the basis of information otherwise available to the judicial council, that a judge appointed to hold office during good behavior may have engaged in conduct—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524c82aa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which might constitute one or more grounds for impeachment under article II of the Constitution, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524c82ab-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, in the interest of justice, is not amenable to resolution by the judicial council,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the judicial council shall promptly certify such determination, together with any complaint and a record of any associated proceedings, to the Judicial Conference of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524c82ac-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s354/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to complainant and judge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A judicial council acting under authority of this subsection shall, unless contrary to the interests of justice, immediately submit written notice to the complainant and to the judge whose conduct is the subject of the action taken under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524c82ad-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11042/a"},"text":"Pub. L. 107–273, div. C, title I, § 11042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1850"},"text":"116 Stat. 1850","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
