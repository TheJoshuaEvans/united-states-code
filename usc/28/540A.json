{"tag":"section","attrib":{"id":"id5270374c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A"},"text":null,"children":[{"tag":"num","attrib":{"value":"540A"},"text":"§ 540A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of violent crimes against travelers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5270374d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of an appropriate law enforcement official of a State or political subdivision, the Attorney General and Director of the Federal Bureau of Investigation may assist in the investigation of a felony crime of violence in violation of the law of any State in which the victim appears to have been selected because he or she is a traveler.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270374e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Travelers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a case in which the traveler who is a victim of a crime described in subsection (a) is from a foreign nation, the Attorney General and Director of the Federal Bureau of Investigation, and, when appropriate, the Secretary of State shall assist the prosecuting and law enforcement officials of a State or political subdivision to the fullest extent possible in securing from abroad such evidence or other information as may be needed for the effective investigation and prosecution of the crime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270374f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52703750-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “felony crime of violence” means an offense punishable by more than one year in prison that has as an element the use, attempted use, or threatened use of physical force against the person of another.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703751-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703752-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540A/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “traveler” means a victim of a crime of violence who is not a resident of the State in which the crime of violence occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52703753-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320916/a"},"text":"Pub. L. 103–322, title XXXII, § 320916(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2129"},"text":"108 Stat. 2129","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/tVI/s604/b/21"},"text":"Pub. L. 104–294, title VI, § 604(b)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3507"},"text":"110 Stat. 3507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52703754-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52703755-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52703756-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" designated three undesignated pars. as pars. (1) to (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52703757-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52703758-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/294"},"text":"Pub. L. 104–294","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/294/s604/d"},"text":"section 604(d) of Pub. L. 104–294","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s13"},"text":"section 13 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
