{"tag":"section","attrib":{"id":"id52690b37-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s528"},"text":null,"children":[{"tag":"num","attrib":{"value":"528"},"text":"§ 528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification of officers and employees of the Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General shall promulgate rules and regulations which require the disqualification of any officer or employee of the Department of Justice, including a United States attorney or a member of such attorney’s staff, from participation in a particular investigation or prosecution if such participation may result in a personal, financial, or political conflict of interest, or the appearance thereof. Such rules and regulations may provide that a willful violation of any provision thereof shall result in removal from office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52690b38-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVI/s603/a"},"text":"Pub. L. 95–521, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1874"},"text":"92 Stat. 1874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52690b39-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52690b3a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52690b3b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s604"},"text":"section 604 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"section 591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
