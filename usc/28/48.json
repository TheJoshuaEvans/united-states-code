{"tag":"section","attrib":{"id":"id5223ec8c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48"},"text":null,"children":[{"tag":"num","attrib":{"value":"48"},"text":"§ 48.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5223ec8d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The courts of appeals shall hold regular sessions at the places listed below, and at such other places within the respective circuit as each court may designate by rule.","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id5223ec8e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Circuits","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Places","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"District of Columbia","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Washington.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"First","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Boston.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Second","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"New York.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Third","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Philadelphia.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Fourth","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Richmond, Asheville.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Fifth","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"New Orleans, Fort Worth, Jackson.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sixth","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Cincinnati.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Seventh","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Chicago.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Eighth","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"St. Louis, Kansas City, Omaha, St. Paul.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Ninth","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"San Francisco, Los Angeles, Portland, Seattle.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Tenth","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Denver, Wichita, Oklahoma City.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Eleventh","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Atlanta, Jacksonville, Montgomery.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Federal","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"District of Columbia, and in any other place listed above as the court by rule directs.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5223ec8f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each court of appeals may hold special sessions at any place within its circuit as the nature of the business may require, and upon such notice as the court orders. The court may transact any business at a special session which it might transact at a regular session.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5223ec90-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any court of appeals may pretermit any regular session of court at any place for insufficient business or other good cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5223ec91-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The times and places of the sessions of the Court of Appeals for the Federal Circuit shall be prescribed with a view to securing reasonable opportunity to citizens to appear before the court with as little inconvenience and expense to citizens as is practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5223ec92-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each court of appeals may hold special sessions at any place within the United States outside the circuit as the nature of the business may require and upon such notice as the court orders, upon a finding by either the chief judge of the court of appeals (or, if the chief judge is unavailable, the most senior available active judge of the court of appeals) or the judicial council of the circuit that, because of emergency conditions, no location within the circuit is reasonably available where such special sessions could be held. The court may transact any business at a special session outside the circuit which it might transact at a regular session.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52263683-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a court of appeals issues an order exercising its authority under subsection (e), the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52263684-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" through the Administrative Office of the United States Courts, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52263685-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" send notice of such order, including the reasons for the issuance of such order, to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52263686-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 180 days after the expiration of such court order submit a brief report to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives describing the impact of such order, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52263687-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the issuance of such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52263688-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52263689-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such order on litigants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5226368a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs to the judiciary resulting from such order; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5226368b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s48/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide reasonable notice to the United States Marshals Service before the commencement of any special session held pursuant to such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5226368c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/872"},"text":"62 Stat. 872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s36"},"text":"Oct. 31, 1951, ch. 655, § 36","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/723"},"text":"65 Stat. 723","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/452/s4"},"text":"Pub. L. 96–452, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1994"},"text":"94 Stat. 1994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s104"},"text":"Pub. L. 97–164, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/26"},"text":"96 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tV/s501"},"text":"Pub. L. 102–572, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4512"},"text":"106 Stat. 4512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/63/s2/a"},"text":"Pub. L. 109–63, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-09"},"text":"Sept. 9, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1993"},"text":"119 Stat. 1993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5226368d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5226368e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 223 and § 11–205 District of Columbia Code, 1940 ed. (","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-02-09/ch74/s6"},"text":"Feb. 9, 1893, ch. 74, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/435"},"text":"27 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1894-07-30/ch172/s2"},"text":"July 30, 1894, ch. 172, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/161"},"text":"28 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1901-03-03/ch854/s225"},"text":"Mar. 3, 1901, ch. 854, § 225","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/1225"},"text":"31 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s126"},"text":"Mar. 3, 1911, ch. 231, § 126","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1132"},"text":"36 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-07-17/ch246"},"text":"July 17, 1916, ch. 246","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/385"},"text":"39 Stat. 385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-01-08/ch57"},"text":"Jan. 8, 1925, ch. 57","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/729"},"text":"43 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-07-03/ch735"},"text":"July 3, 1926, ch. 735","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/809"},"text":"44 Stat. 809","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-02-28/ch363/s3"},"text":"Feb. 28, 1929, ch. 363, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1347"},"text":"45 Stat. 1347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-05-17/ch190"},"text":"May 17, 1932, ch. 190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/158"},"text":"47 Stat. 158","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s223"},"text":"section 223 of title 28","children":[],"tail":", U.S.C., 1940 ed., with part of section 11–205 of the District of Columbia Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to San Juan as a place for holding court in the First Circuit was omitted. The revised section will permit the holding of terms at San Juan when the public interest requires.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “and at such other places within the respective circuits as may be designated by rule of court” was added to enable each court of appeals to hold such additional regular terms as changing circumstances might require.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of such section 223, for furnishing suitable rooms and accommodation at Oakland City, were omitted as obsolete since the erection of a new Federal building there.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions as to fixed times for holding court in the Fifth Circuit was omitted as inconsistent with the practice in the other circuits. Words “San Francisco, Los Angeles, Portland, Seattle” were substituted for “San Francisco and two other places designated by the court” to conform with the practice in the Ninth Circuit.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5226368f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Revision Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"By Senate amendment, Jacksonville (Fla.) was added as a place for holding a regular session of the Court of Appeals for the Fifth Circuit. See 80th Congress Senate Report No. 1559.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52263690-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52263691-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/63"},"text":"Pub. L. 109–63","children":[],"tail":" added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" struck out “, with the consent of the Judicial Conference of the United States,” after “pretermit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s104/a"},"text":"Pub. L. 97–164, § 104(a)","children":[],"tail":", (b), designated introductory provisions and table of circuits as subsec. (a) and substituted provisions directing the courts of appeals to hold regular sessions at the places listed in the table and at such other places within the circuits as each court might designate by rule, for provisions which directed that terms or sessions of courts of appeals be held annually at the places listed in the table and at such other places as the courts might designate by rule and authorized each court of appeals to hold special terms at any place within its circuit, and added to the table an item for the Federal circuit, with sessions to be held in the District of Columbia and in any other place listed elsewhere in the table as the Federal circuit court might by rule direct."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s104/c"},"text":"Pub. L. 97–164, § 104(c)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s104/c"},"text":"Pub. L. 97–164, § 104(c)","children":[],"tail":", designated existing provisions following table of circuits as subsec. (c) and substituted “regular session” for “regular term or session”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s104/c"},"text":"Pub. L. 97–164, § 104(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/452"},"text":"Pub. L. 96–452","children":[],"tail":" substituted “New Orleans, Fort Worth, Jackson” for “New Orleans, Atlanta, Fort Worth, Jacksonville, Montgomery” in item relating to fifth circuit, and added item relating to eleventh circuit."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-31"},"text":"Oct. 31, 1951","children":[],"tail":", inserted last par."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52263692-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52263693-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1101/a"},"text":"section 1101(a) of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52263694-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52263695-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/452"},"text":"Pub. L. 96–452","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/452/s12"},"text":"section 12 of Pub. L. 96–452","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s41"},"text":"section 41 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52263696-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Survey of Judicial Business in Alaska","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/70/s23/a"},"text":"Pub. L. 86–70, § 23(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/147"},"text":"73 Stat. 147","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/70/s23/a"},"text":"“The Judicial Conference of the United States, with the assistance of the Administrative Office of the United States Courts, shall conduct a study, including a field survey, of the Federal judicial business arising in the State of Alaska with a view toward directing the United States Court of Appeals for the Ninth Circuit to hold such terms of court in Anchorage or such other Alaskan cities as may be necessary for the prompt and efficient administration of justice.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
