{"tag":"section","attrib":{"id":"id528a76d5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s622"},"text":null,"children":[{"tag":"num","attrib":{"value":"622"},"text":"§ 622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings; conduct of business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id528a76d6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regular meetings of the Board shall be held quarterly. Special meetings shall be held from time to time upon the call of the Chairman, acting at his own discretion or pursuant to the petition of any four members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528a76d7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member of the Board shall be entitled to one vote. A simple majority of the membership shall constitute a quorum for the conduct of business. The Board shall act upon the concurrence of a simple majority of the members present and voting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528a76d8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/665"},"text":"81 Stat. 665","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
