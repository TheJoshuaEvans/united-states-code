{"tag":"section","attrib":{"id":"id5288053f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s606"},"text":null,"children":[{"tag":"num","attrib":{"value":"606"},"text":"§ 606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Deputy Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Deputy Director shall perform the duties assigned to him by the Director, and shall act as Director during the absence or incapacity of the Director or when the Director’s office is vacant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52880540-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/915"},"text":"62 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/370/s5/a/1"},"text":"Pub. L. 86–370, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/652"},"text":"73 Stat. 652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52880541-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52880542-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 444 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s302"},"text":"Mar. 3, 1911, ch. 231, § 302","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch501/s1"},"text":"Aug. 7, 1939, ch. 501, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1223"},"text":"53 Stat. 1223","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains provisions as to duties of Assistant Director in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s444"},"text":"section 444 of title 28","children":[],"tail":", U.S.C., 1940 ed. The remainder of said section 444 is incorporated in sections 601, 603 and 608 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52880543-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52880544-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370"},"text":"Pub. L. 86–370","children":[],"tail":" substituted “Deputy Director” for “Assistant Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52880545-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52880546-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1959 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370"},"text":"Pub. L. 86–370","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/370/s7/a"},"text":"section 7(a) of Pub. L. 86–370","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52880547-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to Assistant Director Deemed Reference to Deputy Director","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in any other law to Assistant Director of the Administrative Office of the United States Courts deemed to be reference to the Deputy Director of the Administrative Office of the United States Courts, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s601"},"text":"section 601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
