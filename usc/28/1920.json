{"tag":"section","attrib":{"id":"id52c5f866-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920"},"text":null,"children":[{"tag":"num","attrib":{"value":"1920"},"text":"§ 1920.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of costs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A judge or clerk of any court of the United States may tax as costs the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52c5f867-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees of the clerk and marshal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c5f868-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees for printed or electronically recorded transcripts necessarily obtained for use in the case;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c5f869-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees and disbursements for printing and witnesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c5f86a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees for exemplification and the costs of making copies of any materials where the copies are necessarily obtained for use in the case;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c5f86b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Docket fees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1923"},"text":"section 1923 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c5f86c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1920/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation of court appointed experts, compensation of interpreters, and salaries, fees, expenses, and costs of special interpretation services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1828"},"text":"section 1828 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A bill of costs shall be filed in the case and, upon allowance, included in the judgment or decree.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c5f86d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/955"},"text":"62 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/539/s7"},"text":"Pub. L. 95–539, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-28"},"text":"Oct. 28, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2044"},"text":"92 Stat. 2044","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/406/s6"},"text":"Pub. L. 110–406, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4292"},"text":"122 Stat. 4292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c5f86e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c5f86f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 9a(a) and 830 (R.S. § 983; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s5a"},"text":"Mar. 3, 1911, ch. 231, § 5a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1944-01-20/ch3/s1"},"text":"Jan. 20, 1944, ch. 3, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/5"},"text":"58 Stat. 5","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For distribution of other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s9a"},"text":"section 9a of title 28","children":[],"tail":", U.S.C., 1940 ed., see table at end of reviser’s notes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “may” was substituted for “shall” before “tax as costs,” in view of Rule 54(d) of the Federal Rules of Civil Procedure, providing for allowance of costs to the prevailing party as of course “unless the court otherwise directs”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c5f870-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c5f871-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/406/s6/1"},"text":"Pub. L. 110–406, § 6(1)","children":[],"tail":", substituted “for printed or electronically recorded transcripts” for “of the court reporter for all or any part of the stenographic transcript”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/406/s6/2"},"text":"Pub. L. 110–406, § 6(2)","children":[],"tail":", substituted “the costs of making copies of any materials where the copies are” for “copies of papers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/539"},"text":"Pub. L. 95–539","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c5f872-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c5f873-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/539"},"text":"Pub. L. 95–539","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-28"},"text":"Oct. 28, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/539/s10/a"},"text":"section 10(a) of Pub. L. 95–539","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s602"},"text":"section 602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
