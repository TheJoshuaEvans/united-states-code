{"tag":"section","attrib":{"id":"id52b55711-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1654"},"text":null,"children":[{"tag":"num","attrib":{"value":"1654"},"text":"§ 1654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appearance personally or by counsel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all courts of the United States the parties may plead and conduct their own cases personally or by counsel as, by the rules of such courts, respectively, are permitted to manage and conduct causes therein.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b55712-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/944"},"text":"62 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s91"},"text":"May 24, 1949, ch. 139, § 91","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/103"},"text":"63 Stat. 103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b55713-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52b55714-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52b55715-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 394 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s272"},"text":"Mar. 3, 1911, ch. 231, § 272","c