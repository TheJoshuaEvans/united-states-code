{"tag":"section","attrib":{"id":"id52c3aeeb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876"},"text":null,"children":[{"tag":"num","attrib":{"value":"1876"},"text":"§ 1876.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial by jury in the Court of International Trade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c3aeec-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil action in the Court of International Trade which is to be tried before a jury, the jury shall be selected in accordance with the provisions of this chapter and under the procedures set forth in the jury selection plan of the district court for the judicial district in which the case is to be tried.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3aeed-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever the Court of International Trade conducts a jury trial—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52c3aeee-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the clerk of the district court for the judicial district in which the Court of International Trade is sitting, or an authorized deputy clerk, shall act as clerk of the Court of International Trade for the purposes of selecting and summoning the jury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c3aeef-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualifications for jurors shall be the same as those established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1865/b"},"text":"section 1865(b) of this title","children":[],"tail":" for jurors in the district courts of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c3aef0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each party shall be entitled to challenge jurors in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1870"},"text":"section 1870 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c3aef1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1876/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jurors shall be compensated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1871"},"text":"section 1871 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c3aef2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s302/a"},"text":"Pub. L. 96–417, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1739"},"text":"94 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3aef3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c3aef4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52c3aef5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to civil actions commenced on or after ","children":[{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/b/1/C"},"text":"section 701(b)(1)(C) of Pub. L. 96–417","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
