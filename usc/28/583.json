{"tag":"section","attrib":{"id":"id5279add6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s583"},"text":null,"children":[{"tag":"num","attrib":{"value":"583"},"text":"§ 583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each United States trustee and assistant United States trustee, before taking office, shall take an oath to execute faithfully his duties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5279add7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s224/a"},"text":"Pub. L. 95–598, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2663"},"text":"92 Stat. 2663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5279add8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5279add9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5279adda-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/s408/c"},"text":"Section 408(c) of Pub. L. 95–598","children":[],"tail":", as amended, which provided for the repeal of this section and the deletion of any references to United States Trustees in this title at a prospective date, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s307/b"},"text":"section 307(b) of Pub. L. 99–554","children":[],"tail":". See note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
