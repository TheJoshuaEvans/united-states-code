{"tag":"section","attrib":{"id":"id5280d97b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s598"},"text":null,"children":[{"tag":"num","attrib":{"value":"598"},"text":"§ 598.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application thereof to any person or circumstance is held invalid, the remainder of this chapter and the application of such provision to other persons not similarly situated or to other circumstances shall not be affected by such invalidation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5280d97c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVI/s601/a"},"text":"Pub. L. 95–521, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1873"},"text":"92 Stat. 1873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/409"},"text":"Pub. L. 97–409","children":[],"tail":", §§ 2(a)(1)(A), 7, "},{"tag":"date","attrib":{"date":"1983-01-03"},"text":"Jan. 3, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2039"},"text":"96 Stat. 2039","children":[],"tail":", 2042; "},{"tag":"ref","attrib":{"href":"/us/pl/100/191/s2"},"text":"Pub. L. 100–191, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1306"},"text":"101 Stat. 1306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5280d97d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5280d97e-3a70-11f1-9e0c-dcbb1364