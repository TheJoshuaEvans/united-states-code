{"tag":"section","attrib":{"id":"id52ee9099-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3010"},"text":null,"children":[{"tag":"num","attrib":{"value":"3010"},"text":"§ 3010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-owned property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ee909a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3010/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedies available to the United States under this chapter may be enforced against property which is co-owned by a debtor and any other person only to the extent allowed by the law of the State where the property is located. This section shall not be construed to limit any right or interest of a debtor or co-owner in a retirement system for Federal military or civilian personnel established by the United States or any agency thereof or in a qualified retirement arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee909b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3010/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee909c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3010/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “retirement system for Federal military or civilian personnel” means a pension or annuity system for Federal military or civilian personnel of more than one agency, or for some or all of such personnel of a single agency, established by statute or by regulation pursuant to statutory authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee909d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3010/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified retirement arrangement” means a plan qualified under section 401(a), 403(a), or 409 of the Internal Revenue Code of 1986 or a plan that is subject to the requirements of section 205 of the Employee Retirement Income Security Act of 1974.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee909e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4937"},"text":"104 Stat. 4937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee909f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee90a0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52ee90a1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 401(a), 403(a), and 409 of the Internal Revenue Code of 1986, referred to in subsec. (b)(2), are classified to sections 401(a), 403(a), and 409, respectively, of Title 26, Internal Revenue Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 205 of the Employee Retirement Income Security Act of 1974, referred to in subsec. (b)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1055"},"text":"section 1055 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee90a2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee90a3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
