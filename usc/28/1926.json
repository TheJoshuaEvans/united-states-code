{"tag":"section","attrib":{"id":"id52c5f8af-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1926"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926"},"text":"§ 1926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court of Federal Claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c5f8b0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judicial Conference of the United States shall prescribe from time to time the fees and costs to be charged and collected in the United States Court of Federal Claims.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c5f8b1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court and its officers shall collect only such fees and costs as the Judicial Conference prescribes. The court may require advance payment of fees by rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c5f8b2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/957"},"text":"62 Stat. 957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s139/p/1"},"text":"Pub. L. 97–164, title I, § 139(p)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/44"},"text":"96 Stat. 44","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b"},"text":"Pub. L. 102–572, title IX, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c5f8b3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c5f8b4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 304 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s191"},"text":"Mar. 3, 1911, ch. 231, § 191","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1144"},"text":"36 Stat. 1144","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For distribution of other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s304"},"text":"section 304 of title 28","children":[],"tail":", U.S.C., 1940 ed., see Distribution Table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c5f8b5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c5f8b6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “Court of Federal Claims” for “Claims Court” as section catchline and “United States Court of Federal Claims” for “United States Claims Court” in subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “Claims Court” for “Court of Customs and Patent Appeals” as section catchline and, in text substituted provisions directing the Judicial Conference of the United States to prescribe from time to time the fees and costs to be charged and collected in the United States Claims Court and directing the court and its officers to collect only such fees and costs as the Judicial Conference prescribes, with the court authorized to require advance payment of fees by rule for provisions which had directed that fees and costs in the Court of Customs and Patent Appeals be fixed by a table of fees adopted by such court and approved by the Supreme Court, that the fees and costs so fixed not exceed the fees and costs charged in the Supreme Court, and that the fees be accounted for and paid over to the Treasury."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c5f8b7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c5f8b8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c5f8b9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52c5f8ba-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Court Fees for Electronic Access to Information","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Judicial Conference to prescribe reasonable fees for collection by courts under this section for access to information available through automatic data processing equipment and fees to be deposited in Judiciary Automation Fund, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/140/s303"},"text":"section 303 of Pub. L. 102–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1913"},"text":"section 1913 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
