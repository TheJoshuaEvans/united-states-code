{"tag":"section","attrib":{"id":"id522b183a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s96"},"text":null,"children":[{"tag":"num","attrib":{"value":"96"},"text":"§ 96.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Kansas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Kansas constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Kansas City, Lawrence, Leavenworth, Salina, Topeka, Hutchinson, Wichita, Dodge City, and Fort Scott.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id522b183b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/880"},"text":"62 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-27/ch516"},"text":"Aug. 27, 1949, ch. 516","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/666"},"text":"63 Stat. 666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI/s141"},"text":"Pub. L. 99–554, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3096"},"text":"100 Stat. 3096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522b183c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522b183d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 157 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s82"},"text":"Mar. 3, 1911, ch. 231, § 82","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1112"},"text":"36 Stat. 1112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-09-06/ch447"},"text":"Sept. 6, 1916, ch. 447","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/725"},"text":"39 Stat. 725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch319"},"text":"June 7, 1924, ch. 319","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/607"},"text":"43 Stat. 607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-13/ch349"},"text":"June 13, 1938, ch. 349","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/673"},"text":"52 Stat. 673","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions as to the appointment and residence of deputy marshals and deputy clerks and maintenance of offices by them were omitted. See sections 541 [see 561], 542 [see 561], and 751 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision making inoperative the terms of the last paragraph of this section, whenever, upon the recommendation of the Attorney General, court accommodations should be provided in Federal buildings, was omitted as unnecessary. When such buildings become available the Director of the Administrative Office of the United States Courts will, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"section 604 of this title","children":[],"tail":", provide court accommodations therein."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision respecting court accommodations at Hutchinson was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522b183e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522b183f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" provided for holding court at Lawrence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-08-27"},"text":"Aug. 27, 1949","children":[],"tail":", abolished the three divisions which constituted the judicial district, and added Dodge City as an additional place for holding court."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id522b1840-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id522b1841-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s302/a"},"text":"section 302(a) of Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
