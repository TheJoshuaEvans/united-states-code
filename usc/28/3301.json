{"tag":"section","attrib":{"id":"id52f34af4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f34af5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Affiliate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34af6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person who directly or indirectly owns, controls, or holds with power to vote, 20 percent or more of the outstanding voting securities of the debtor, other than a person who holds the securities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52f34af7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a fiduciary or agent without sole discretionary power to vote the securities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34af8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely to secure a debt, if the person has not exercised the power to vote;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34af9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a corporation 20 percent or more of whose outstanding voting securities are directly or indirectly owned, controlled, or held with power to vote, by the debtor or a person who directly or indirectly owns, controls, or holds with power to vote, 20 percent or more of the outstanding voting securities of the debtor, other than the person who holds securities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52f34afa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a fiduciary or agent without sole power to vote the securities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34afb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely to secure a debt, if the person has not in fact exercised the power to vote;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34afc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person whose business is operated by the debtor under a lease or other agreement, or a person substantially all of whose assets are controlled by the debtor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34afd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who operates the debtor’s business under a lease or other agreement or controls substantially all of the debtor’s assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34afe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Asset” means property of a debtor, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34aff-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property to the extent it is encumbered by a valid lien;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b00-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property to the extent it is generally exempt under nonbankruptcy law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b01-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interest in real property held in tenancy by the entirety, or as part of a community estate, to extent such interest is not subject to process by the United States holding a claim against only one tenant or co-owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b02-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Claim” means a right to payment, whether or not the right is reduced to judgment, liquidated, unliquidated, fixed, contingent, matured, unmatured, disputed, undisputed, legal, equitable, secured, or unsecured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b03-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Creditor” means a person who has a claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b04-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Insider” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34b05-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the debtor is an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52f34b06-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relative of the debtor or of a general partner of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b07-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership in which the debtor is a general partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b08-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general partner in a partnership described in clause (ii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b09-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation of which the debtor is a director, officer, or person in control;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b0a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the debtor is a corporation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52f34b0b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a director of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b0c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b0d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person in control of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b0e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership in which the debtor is a general partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b0f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general partner in a partnership described in clause (iv); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b10-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relative of a general partner, director, officer, or person in control of the debtor;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b11-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the debtor is a partnership—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52f34b12-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general partner in the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b13-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relative of a general partner in, a general partner of, or a person in control of the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b14-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another partnership in which the debtor is a general partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b15-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general partner in a partnership described in clause (iii); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b16-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person in control of the debtor.","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b17-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affiliate, or an insider of an affiliate as if the affiliate were the debtor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b18-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a managing agent of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b19-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002120"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002120"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “(6)”."}],"tail":" “Lien” means a charge against or an interest in property to secure payment of a debt and includes a security interest created by agreement, a judicial lien obtained by legal or equitable process or proceedings, a common law lien, or a statutory lien."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b1a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “(7)”."}],"tail":" “Relative” means an individual related, by consanguinity or adoption, within the third degree as determined by the common law, a spouse, or an individual so related to a spouse within the third degree as so determined."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b1b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002122"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002122"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be “(8)”."}],"tail":" “Transfer” means every mode, direct or indirect, absolute or conditional, voluntary or involuntary, of disposing of or parting with an asset or an interest in an asset, and includes payment of money, release, lease, and creation of a lien or other encumbrance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b1c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"5","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"5","children":[],"tail":" So in original. Probably should be “(9)”."}],"tail":" “Valid lien” means a lien that is effective against the holder of a judicial lien subsequently obtained in legal or equitable proceeding."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f34b1d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4959"},"text":"104 Stat. 4959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f34b1e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f34b1f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f34b20-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
