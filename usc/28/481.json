{"tag":"section","attrib":{"id":"id525ab47e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481"},"text":null,"children":[{"tag":"num","attrib":{"value":"481"},"text":"§ 481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated case information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525ab47f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Administrative Office of the United States Courts shall ensure that each United States district court has the automated capability readily to retrieve information about the status of each case in such court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab480-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525ab481-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out subsection (a), the Director shall prescribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id525ab482-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information to be recorded in district court automated systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id525ab483-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for uniform categorization or characterization of judicial actions for the purpose of recording information on judicial actions in the district court automated systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525ab484-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The uniform standards prescribed under paragraph (1)(B) of this subsection shall include a definition of what constitutes a dismissal of a case and standards for measuring the period for which a motion has been pending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab485-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s481/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each United States district court shall record information as prescribed pursuant to subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525ab486-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tI/s103/a"},"text":"Pub. L. 101–650, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5095"},"text":"104 Stat. 5095","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
