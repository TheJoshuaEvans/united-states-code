{"tag":"section","attrib":{"id":"id5291a21d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s656"},"text":null,"children":[{"tag":"num","attrib":{"value":"656"},"text":"§ 656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Rule 45 of the Federal Rules of Civil Procedure (relating to subpoenas) applies to subpoenas for the attendance of witnesses and the production of documentary evidence at an arbitration hearing under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5291a21e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIX/s901/a"},"text":"Pub. L. 100–702, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4662"},"text":"102 Stat. 4662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/315/s8"},"text":"Pub. L. 105–315, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2996"},"text":"112 Stat. 2996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a21f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a220-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5291a221-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in text, are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a222-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/315"},"text":"Pub. L. 105–315","children":[],"tail":" amended section generally, substituting provisions relating to subpoenas for provisions relating to certification of arbitrators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
