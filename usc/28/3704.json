{"tag":"section","attrib":{"id":"id52f5bbaa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704"},"text":null,"children":[{"tag":"num","attrib":{"value":"3704"},"text":"§ 3704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f5bbab-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Section 3702 shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bbac-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lottery, sweepstakes, or other betting, gambling, or wagering scheme in operation in a State or other governmental entity, to the extent that the scheme was conducted by that State or other governmental entity at any time during the period beginning ","children":[{"tag":"date","attrib":{"date":"1976-01-01"},"text":"January 1, 1976","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1990-08-31"},"text":"August 31, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bbad-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a lottery, sweepstakes, or other betting, gambling, or wagering scheme in operation in a State or other governmental entity where both—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f5bbae-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such scheme was authorized by a statute as in effect on ","children":[{"tag":"date","attrib":{"date":"1991-10-02"},"text":"October 2, 1991","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f5bbaf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a scheme described in section 3702 (other than one based on parimutuel animal racing or jai-alai games) actually was conducted in that State or other governmental entity at any time during the period beginning ","children":[{"tag":"date","attrib":{"date":"1989-09-01"},"text":"September 1, 1989","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1991-10-02"},"text":"October 2, 1991","children":[],"tail":", pursuant to the law of that State or other governmental entity;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bbb0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a betting, gambling, or wagering scheme, other than a lottery described in paragraph (1), conducted exclusively in casinos located in a municipality, but only to the extent that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f5bbb1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3704/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such scheme or a similar scheme was authorized, not later than one year after the effective date of this chapter, to be operated in that municipality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f5bbb2-3a70-11f1-9e0c-dcbb1364da