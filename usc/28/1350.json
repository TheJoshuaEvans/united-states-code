{"tag":"section","attrib":{"id":"id52a2444d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1350"},"text":null,"children":[{"tag":"num","attrib":{"value":"1350"},"text":"§ 1350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alien’s action for tort","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action by an alien for a tort only, committed in violation of the law of nations or a treaty of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a2444e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/934"},"text":"62 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a2444f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a24450-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(17) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 17, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1093"},"text":"36 Stat. 1093","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suits,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a24451-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52a24452-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Torture Victim Protection","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/256"},"text":"Pub. L. 102–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-03-12"},"text":"Mar. 12, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/73"},"text":"106 Stat. 73","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/256"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Torture Victim Protection Act of 1991’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ESTABLISHMENT OF CIVIL ACTION.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who, under actual or apparent authority, or color of law, of any foreign nation—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subjects an individual to torture shall, in a civil action, be liable for damages to that individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subjects an individual to extrajudicial killing shall, in a civil action, be liable for damages to the individual’s legal representative, or to any person who may be a claimant in an action for wrongful death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exhaustion of Remedies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court shall decline to hear a claim under this section if the claimant has not exhausted adequate and available remedies in the place in which the conduct giving rise to the claim occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statute of Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No action shall be maintained under this section unless it is commenced within 10 years after the cause of action arose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extrajudicial Killing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this Act, the term ‘extrajudicial killing’ means a deliberated killing not authorized by a previous judgment pronounced by a regularly constituted court affording all the judicial guarantees which are recognized as indispensable by civilized peoples. Such term, however, does not include any such killing that, under international law, is lawfully carried out under the authority of a foreign nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Torture","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘torture’ means any act, directed against an individual in the offender’s custody or physical control, by which severe pain or suffering (other than pain or suffering arising only from or inherent in, or incidental to, lawful sanctions), whether physical or mental, is intentionally inflicted on that individual for such purposes as obtaining from that individual or a third person information or a confession, punishing that individual for an act that individual or a third person has committed or is suspected of having committed, intimidating or coercing that individual or a third person, or for any reason based on discrimination of any kind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" mental pain or suffering refers to prolonged mental harm caused by or resulting from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intentional infliction or threatened infliction of severe physical pain or suffering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration or application, or threatened administration or application, of mind altering substances or other procedures calculated to disrupt profoundly the senses or the personality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threat of imminent death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threat that another individual will imminently be subjected to death, severe physical pain or suffering, or the administration or application of mind altering substances or other procedures calculated to disrupt profoundly the senses or personality.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
