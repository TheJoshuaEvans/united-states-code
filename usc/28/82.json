{"tag":"section","attrib":{"id":"id522636c5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s82"},"text":null,"children":[{"tag":"num","attrib":{"value":"82"},"text":"§ 82.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arizona","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Arizona constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Flagstaff, Globe, Phoenix, Prescott, Tucson, and Yuma.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id522636c6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/874"},"text":"62 Stat. 874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/40/s1"},"text":"Pub. L. 116–40, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-09"},"text":"Aug. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1063"},"text":"133 Stat. 1063","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522636c7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522636c8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 143 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-06-20/ch310/s31"},"text":"June 20, 1910, ch. 310, § 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/576"},"text":"36 Stat. 576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-10-03/ch17"},"text":"Oct. 3, 1913, ch. 17","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/38/203"},"text":"38 Stat. 203","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision for transfer of causes, civil or criminal, from one place for holding court to another was omitted. Such provision, as to civil cases, is covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1404"},"text":"section 1404 of this title","children":[],"tail":", and, as to criminal cases, is rendered unnecessary because of inherent power of the court and Rules 18–20 of the Federal Rules of Criminal Procedure, relating to venue."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision for making an interlocutory order at any place designated for holding court was omitted as unnecessary in view of Federal Rules of Civil Procedure, rule 77(b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision requiring the clerk to keep his office at the State capital was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5228a6c9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5228a6ca-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/40"},"text":"Pub. L. 116–40","children":[],"tail":" substituted “Flagstaff, Globe, Phoenix, Prescott, Tucson, and Yuma” for “Globe, Phoenix, Prescott, and Tucson”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
