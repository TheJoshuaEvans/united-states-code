{"tag":"section","attrib":{"id":"id52c5f895-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1922"},"text":null,"children":[{"tag":"num","attrib":{"value":"1922"},"text":"§ 1922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Witness fees before United States magistrate judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The fees of more than four witnesses shall not be taxed against the United States, in the examination of any criminal case before a United States magistrate judge, unless their materiality and importance are first approved and certified to by the United States attorney for the district in which the examination is had.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c5f896-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/956"},"text":"62 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tIV/s402/b/2"},"text":"Pub. L. 90–578, title IV, § 402(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1118"},"text":"82 Stat. 1118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c5f897-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c5f898-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 828 (R.S. § 981; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-05-28/ch252/s19"},"text":"May 28, 1896, ch. 252, § 19","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/184"},"text":"29 Stat. 184","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Last clause of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s828"},"text":"section 828 of title 28","children":[],"tail":", U.S.C., 1940 ed., providing “and such taxation shall be subject to revision, as in other cases” was omitted as unnecessary in view of the inherent power of the court to revise costs taxed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c5f899-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id52c5f89a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States magistrate judges” substituted for “United States magistrates” in section catchline and “United States magistrate judge” substituted for “United States magistrate” in text pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of this title","children":[],"tail":". Previously, “United States magistrates” and “United States magistrate” substituted for “United States commissioners” and “United States commissioner”, respectively, pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":". See chapter 43 (§ 631 et seq.) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
