{"tag":"section","attrib":{"id":"id52e763e7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2514"},"text":null,"children":[{"tag":"num","attrib":{"value":"2514"},"text":"§ 2514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of fraudulent claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A claim against the United States shall be forfeited to the United States by any person who corruptly practices or attempts to practice any fraud against the United States in the proof, statement, establishment, or allowance thereof.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In such cases the United States Court of Federal Claims shall specifically find such fraud or attempt and render judgment of forfeiture.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52e763e8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/978"},"text":"62 Stat. 978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s139/j/2"},"text":"Pub. L. 97–164, title I, § 139(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/43"},"text":"96 Stat. 43","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e763e9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52e763ea-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 279 and 280 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 172, 173, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1141"},"text":"36 Stat. 1141","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s279"},"text":"section 279 of title 28","children":[],"tail":", U.S.C., 1940 ed., that a judgment of forfeiture shall forever bar the prosecution of the claim was omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2518"},"text":"section 2518 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s280"},"text":"section 280 of title 28","children":[],"tail":", U.S.C., 1940 ed., barring allowance by accounting officers of fraudulent claims under Act "},{"tag":"date","attrib":{"date":"1874-06-16"},"text":"June 16, 1874","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/75"},"text":"18 Stat. 75","children":[],"tail":", was omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s280"},"text":"section 280 of title 28","children":[],"tail":", U.S.C., 1940 ed., barring allowance of fraudulent claims by Congress was omitted as unnecessary and superfluous."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e763eb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e763ec-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “United States Claims Court” for “Court of Claims”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e763ed-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e763ee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e763ef-3a70-11f