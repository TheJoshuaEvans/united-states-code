{"tag":"section","attrib":{"id":"id5242e5d4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s175"},"text":null,"children":[{"tag":"num","attrib":{"value":"175"},"text":"§ 175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official duty station; residence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5242e5d5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s175/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The official duty station of each judge of the United States Court of Federal Claims is the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5242e5d6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s175/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After appointment and while in active service, each judge shall reside within fifty miles of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5242e5d7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s175/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired judges of the Court of Federal Claims are not subject to restrictions as to residence. The place where a retired judge maintains the actual abode in which such judge customarily lives shall be deemed to be the judge’s official duty station for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s456"},"text":"section 456 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5242e5d8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/425/s2"},"text":"Pub. L. 89–425, § 2","children":[],"tai