{"tag":"section","attrib":{"id":"id528cc049-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s632"},"text":null,"children":[{"tag":"num","attrib":{"value":"632"},"text":"§ 632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Character of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id528cc04a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Full-time United States magistrate judges may not engage in the practice of law, and may not engage in any other business, occupation, or employment inconsistent with the expeditious, proper, and impartial performance of their duties as judicial officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528cc04b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Part-time United States magistrate judges shall render such service as judicial officers as is required by law. While so serving they may engage in the practice of law, but may not serve as counsel in any criminal action in any court of the United States, nor act in any capacity that is, under such regulations as the conference may establish, inconsistent with the proper discharge of their office. Within such restrictions, they may engage in any other business, occupation, or employment which is not inconsistent with the expeditious, proper, and impartial performance of their duties as judicial officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528cc04c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/916"},"text":"62 Stat. 916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tI/s101"},"text":"Pub. L. 90–578, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1110"},"text":"82 Stat. 1110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528cc04d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528cc04e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528cc04f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" substituted provisions as to character of service of full-time and part-time United States magistrates for former provisions prescribing jurisdiction and powers of national park commissioners and practice and procedure before such officers. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s636"},"text":"section 636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id528cc050-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id528cc051-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States magistrate judges” substituted for “United States magistrates” wherever appearing in text pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528cc052-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", except when a later effective date is applicable, which is the earlier of date when implementation of amendment by appointment of magistrates [now United States magistrate judges] and assumption of office takes place or third anniversary of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/s403"},"text":"section 403 of Pub. L. 90–578","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of this title","children":[