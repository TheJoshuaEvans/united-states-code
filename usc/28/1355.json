{"tag":"section","attrib":{"id":"id52a2446e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355"},"text":null,"children":[{"tag":"num","attrib":{"value":"1355"},"text":"§ 1355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine, penalty or forfeiture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a2446f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district courts shall have original jurisdiction, exclusive of the courts of the States, of any action or proceeding for the recovery or enforcement of any fine, penalty, or forfeiture, pecuniary or otherwise, incurred under any Act of Congress, except matters within the jurisdiction of the Court of International Trade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1582"},"text":"section 1582 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a24470-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a24471-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A forfeiture action or proceeding may be brought in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52a24472-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district court for the district in which any of the acts or omissions giving rise to the forfeiture occurred, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52a24473-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other district where venue for the forfeiture action or proceeding is specifically provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1395"},"text":"section 1395 of this title","children":[],"tail":" or any other statute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a24474-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever property subject to forfeiture under the laws of the United States is located in a foreign country, or has been detained or seized pursuant to legal process or competent authority of a foreign government, an action or proceeding for forfeiture may be brought as provided in paragraph (1), or in the United States District court ","children":[{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" for the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a24475-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which a final order disposing of property in a civil forfeiture action or proceeding is appealed, removal of the property by the prevailing party shall not deprive the court of jurisdiction. Upon motion of the appealing party, the district court or the court of appeals shall issue any order necessary to preserve the right of the appealing party to the full value of the property at issue, including a stay of the judgment of the district court pending appeal or requiring the prevailing party to post an appeal bond.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a24476-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any court with jurisdiction over a forfeiture action pursuant to subsection (b) may issue and cause to be served in any other district such process as may be required to bring before the court the property that is the subject of the forfeiture action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a24477-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/934"},"text":"62 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tV/s507"},"text":"Pub. L. 96–417, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1743"},"text":"94 Stat. 1743","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXV/s1521"},"text":"Pub. L. 102–550, title XV, § 1521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4062"},"text":"106 Stat. 4062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a24478-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a24479-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 41(9) and 371(2) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 24, par. 9, 256, par. 2, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1092"},"text":"36 Stat. 1092","children":[],"tail":", 1160)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “fine” was inserted so that this section will apply to the many provisions in the United States Code for fines which are essentially civil. (See, also, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2461"},"text":"section 2461 of this title","children":[],"tail":" and reviser’s note thereunder.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “pecuniary or otherwise” were added to make this section expressly applicable to both pecuniary and property forfeitures. The original section was so construed in ","children":[{"tag":"i","attrib":{},"text":"Miller v. United States","children":[],"tail":", 1870, 11 Wall. 268, 20 L.Ed. 135; "},{"tag":"i","attrib":{},"text":"Tyler v. Defrees","children":[],"tail":", 1870, 11 Wall. 331, and "},{"tag":"i","attrib":{},"text":"The Rosemary","children":[],"tail":", C.C.A. 1928, 26 F.2d 354, certiorari denied 49 S.Ct. 23, 278 U.S. 619, 73 L.Ed. 542."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a4b47a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a4b47b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) to (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" inserted exception for matters within the jurisdiction of the Court of International Trade under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1582"},"text":"section 1582 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b47c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b47d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" applicable with respect to civil actions commenced on or after the 90th day after "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/c/1/B"},"text":"section 701(c)(1)(B) of Pub. L. 96–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
