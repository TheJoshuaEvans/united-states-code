{"tag":"section","attrib":{"id":"id52a4b4fa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1390"},"text":null,"children":[{"tag":"num","attrib":{"value":"1390"},"text":"§ 1390.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a4b4fb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1390/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this chapter, the term “venue” refers to the geographic specification of the proper court or courts for the litigation of a civil action that is within the subject-matter jurisdiction of the district courts in general, and does not refer to any grant or restriction of subject-matter jurisdiction providing for a civil action to be adjudicated only by the district court for a particular district or districts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b4fc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1390/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of Certain Cases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided by law, this chapter shall not govern the venue of a civil action in which the district court exercises the jurisdiction conferred by section 1333, except that such civil actions may be transferred between district courts as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b4fd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1390/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification Regarding Cases Removed From State Courts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter shall not determine the district court to which a civil action pending in a State court may be removed, but shall govern the transfer of an action so removed as between districts and divisions of the United States district courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a4b4fe-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63/tII/s201/a"},"text":"Pub. L. 112–63, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/762"},"text":"125 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b4ff-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b500-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a4b501-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63/tII/s205"},"text":"Pub. L. 112–63, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/764"},"text":"125 Stat. 764","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/63/tII/s205"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this title [enacting this section, amending sections 1391 and 1404 of this title, and repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1392"},"text":"section 1392 of this title","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect upon the expiration of the 30-day period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action that is commenced in a United States district court on or after such effective date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action that is removed from a State court to a United States district court and that had been commenced, within the meaning of State law, on or after such effective date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
