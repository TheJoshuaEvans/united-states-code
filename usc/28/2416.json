{"tag":"section","attrib":{"id":"id52e2a8dc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2416"},"text":null,"children":[{"tag":"num","attrib":{"value":"2416"},"text":"§ 2416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for commencing actions brought by the United States—Exclusions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of computing the limitations periods established in section 2415, there shall be excluded all periods during which—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e2a8dd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant or the res is outside the United States, its territories and possessions, the District of Columbia, or the Commonwealth of Puerto Rico; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e2a8de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the defendant is exempt from legal process because of infancy, mental incompetence, diplomatic immunity, or for any other reason; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e2a8df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facts material to the right of action are not known and reasonably could not be known by an official of the United States charged with the responsibility to act in the circumstances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e2a8e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2416/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States is in a state of war declared pursuant to article I, section 8, of the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e2a8e1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/505/s1"},"text":"Pub. L. 89–505, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-18"},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/305"},"text":"80 Stat. 305","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
