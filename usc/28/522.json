{"tag":"section","attrib":{"id":"id526450a4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s522"},"text":null,"children":[{"tag":"num","attrib":{"value":"522"},"text":"§ 522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of business and statistics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id526450a5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Attorney General, by April 1 of each year, shall report to Congress on the business of the Department of Justice for the last preceding fiscal year, and on any other matters pertaining to the Department that he considers proper, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52669a96-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s522/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the several appropriations which are placed under the control of the Department and the amount appropriated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52669a97-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s522/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statistics of crime under the laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52669a98-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s522/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the number of causes involving the United States, civil and criminal, pending during the preceding year in each of the several courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52669a99-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to any data, records, or other information acquired, collected, classified, preserved, or published by the Attorney General for any statistical, research, or other aggregate reporting purpose beginning not later than 1 year after the date of enactment of ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “the”."}],"tail":" 21st Century Department of Justice Appropriations Authorization Act and continuing thereafter, and notwithstanding any other provision of law, the same criteria shall be used (and shall be required to be used, as applicable) to classify or categorize offenders and victims (in the criminal context), and to classify or categorize actors and acted upon (in the noncriminal context)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52669a9a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/615"},"text":"80 Stat. 615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s19"},"text":"Pub. L. 94–273, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/379"},"text":"90 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dA/tII/s204/b"},"text":"Pub. L. 107–273, div. A, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1776"},"text":"116 Stat. 1776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52669a9b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52669a9c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id52669a9d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s333"},"text":"5 U.S.C. 333","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 384.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “The Attorney General . . . shall report” are substituted for “It shall be the duty of the Attorney General to make . . . a report”. The word “beginning” is substituted for “commencement”. The words “pertaining to the Department that he considers proper” are substituted for “appertaining thereto that he may deem proper”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and a detailed statement of the amounts used for defraying the expenses of the United States courts in each judicial district” are omitted as obsolete in view of the creation of the Administrative Office of the United States Courts by the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch501/s1"},"text":"Act of Aug. 7, 1939, ch. 501, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1223"},"text":"53 Stat. 1223","children":[],"tail":" (Chapter 41 of this title)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the words “involving the United States” are inserted for clarity. The function of reporting on all cases pending in the United States courts is now vested in the Administrative Office of the United States Courts, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"28 U.S.C. 604","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52669a9e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52669a9f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of 21st Century Department of Justice Appropriations Authorization Act, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52669aa0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “by April 1 of each year” for “at the beginning of each regular session of Congress”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52669aa1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52669aa2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Banking Law Offenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXV/s2546"},"text":"Pub. L. 101–647, title XXV, § 2546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4885"},"text":"104 Stat. 4885","children":[],"tail":", which requires the Attorney General to report to Congress quarterly, after "},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"Dec. 31, 1991","children":[],"tail":", on the nature and number of proceedings in progress with respect to banking law offenses, was editorially reclassified as "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41306"},"text":"section 41306 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52669aa3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Oversight","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/700/s6"},"text":"Pub. L. 100–700, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4634"},"text":"102 Stat. 4634","children":[],"tail":", which required the Attorney General to report annually to Congress on referrals of fraud cases and related matters, terminated, effective "},{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, page 120 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52669aa4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Robberies and Burglaries Involving Controlled Substances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/305/s4"},"text":"Pub. L. 98–305, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-31"},"text":"May 31, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/222"},"text":"98 Stat. 222","children":[],"tail":", provided that for each of the first three years after "},{"tag":"date","attrib":{"date":"1984-05-31"},"text":"May 31, 1984","children":[],"tail":", the Attorney General would submit an annual report to Congress with respect to the enforcement activities of the Attorney General relating to the offenses created by "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2118"},"text":"section 2118 of Title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52669aa5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Sexual Exploitation of Children","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/292/s9"},"text":"Pub. L. 98–292, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/206"},"text":"98 Stat. 206","children":[],"tail":", which requires the Attorney General to report to Congress annually on prosecutions, convictions, and forfeitures under chapter 110 of Title 18, Crimes and Criminal Procedure, relating to sexual exploitation and other abuse of children, was editorially reclassified as "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s41301"},"text":"section 41301 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
