{"tag":"section","attrib":{"id":"id52ec4529-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2645"},"text":null,"children":[{"tag":"num","attrib":{"value":"2645"},"text":"§ 2645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ec452a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A final decision of the Court of International Trade in a contested civil action or a decision granting or refusing a preliminary injunction shall be supported by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ec452b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2645/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of findings of fact and conclusions of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ec452c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2645/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opinion stating the reasons and facts upon which the decision is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ec452d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the Court of International Trade has rendered a judgment, the court may, upon the motion of a party or upon its own motion, amend its findings or make additional findings and may amend the decision and judgment accordingly. A motion of a party or the court shall be made not later than thirty days after the date of entry of the judgment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ec452e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2645/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision of the Court of International Trade is final and conclusive, unless a retrial or rehearing is granted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2646"},"text":"section 2646 of this title","children":[],"tail":" or an appeal is taken to the Court of Appeals for the Federal Circuit by filing a notice of appeal with the clerk of the Court of International Trade within the time and in the manner prescribed for appeals to United States courts of appeals from the United States district courts."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ec452f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s301"},"text":"Pub. L. 96–417, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1738"},"text":"94 Stat. 1738","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s141"},"text":"Pub. L. 97–164, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/45"},"text":"96 Stat. 45","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ec4530-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ec4531-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ec4532-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “is taken to the Court of Appeals for the Federal Circuit by filing a notice of appeal with the clerk of the Court of International Trade within the time and in the manner prescribed for appeals to United States courts of appeals from the United States district courts” for “is taken to the Court of Customs and Patent Appeals within the time and in the manner provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2601"},"text":"section 2601 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ec4533-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52ec4534-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
