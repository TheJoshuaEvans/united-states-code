{"tag":"section","attrib":{"id":"id52455686-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s253"},"text":null,"children":[{"tag":"num","attrib":{"value":"253"},"text":"§ 253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of chief judge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52455687-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge of the Court of International Trade, with the approval of the court, shall supervise the fiscal affairs and clerical force of the court; ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The semicolon probably should be a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52455688-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge shall promulgate dockets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52455689-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge, under rules of the court, may designate any judge or judges of the court to try any case and, when the circumstances so warrant, reassign the case to another judge or judges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5245568a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/900"},"text":"62 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/243/s3"},"text":"Pub. L. 86–243, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-09"},"text":"Sept. 9, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/474"},"text":"73 Stat. 474","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s105"},"text":"Pub. L. 91–271, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/276"},"text":"84 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tV/s501/3"},"text":"Pub. L. 96–417, title V, § 501(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1742"},"text":"94 Stat. 1742","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tV/s501/b/2"},"text":"Pub. L. 104–317, title V, § 501(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3856"},"text":"110 Stat. 3856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5245568b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5245568c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 296 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s187/a"},"text":"Mar. 3, 1911, ch. 231, § 187(a)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1940-10-10/ch843/s1"},"text":"Oct. 10, 1940, ch. 843, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1101"},"text":"54 Stat. 1101","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains a part of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s296"},"text":"section 296 of title 28","children":[],"tail":", U.S.C., 1940 ed. Other provisions of such section are incorporated in sections 251, 252, 254, 456, 1581, 2071, 2639, and 2640 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision respecting recommendations for appointment, promotions, or otherwise affecting such clerical force, was omitted as unnecessary in view of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s871"},"text":"section 871 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph is partly new and conforms with similar provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s136/e"},"text":"section 136(e) of this title","children":[],"tail":", relating to the chief judges of district courts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The term “chief judge” was substituted for “presiding judge.” (See Reviser’s Note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s136"},"text":"section 136 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5245568d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5245568e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" struck out “; precedence of judges” after “chief judge” in section catchline and struck out subsecs. (d) and (e) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) Whenever the chief judge is unable to perform the duties of his office or the office is vacant, his powers and duties shall devolve upon the judge next in precedence who is able to act, until such disability is removed or another chief judge is appointed and duly qualified.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(e) The chief judge shall have precedence and shall preside at any session which he attends. Other judges shall have precedence and shall preside according to the seniority of their commissions. Judges whose commissions bear the same date shall have precedence according to seniority in age.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" redesignated the Customs Court as the Court of International Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" reorganized existing provisions into lettered subsecs. (a) to (e) and made minor changes in phraseology."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/243"},"text":"Pub. L. 86–243","children":[],"tail":" required the chief judge to supervise the fiscal affairs and clerical force of the court, with the approval of the court."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5245568f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52455690-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", and applicable with respect to civil actions pending on or commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/a"},"text":"section 701(a) of Pub. L. 96–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52455691-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1970-10-01"},"text":"Oct. 1, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/s122"},"text":"section 122 of Pub. L. 91–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s256"},"text":"section 256 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id52455692-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/243"},"text":"Pub. L. 86–243","children":[],"tail":" not to deprive Customs Court [now Court of International Trade] officers or employees of any rights, privileges, or civil service status, see "},{"tag":"ref","attrib":{"href":"/us/pl/86/243/s4"},"text":"section 4 of Pub. L. 86–243","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s871"},"text":"section 871 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
