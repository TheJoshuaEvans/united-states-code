{"tag":"section","attrib":{"id":"id52b7c856-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1694"},"text":null,"children":[{"tag":"num","attrib":{"value":"1694"},"text":"§ 1694.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patent infringement action","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In a patent infringement action commenced in a district where the defendant is not a resident but has a regular and established place of business, service of process, summons or subpoena upon such defendant may be made upon his agent or agents conducting such business.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b7c857-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/945"},"text":"62 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b7c858-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52b7c859-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 109 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s48"},"text":"Mar. 3, 1911, ch. 231, § 48","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1100"},"text":"36 Stat. 1100","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Venue provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s109"},"text":"section 109 of title 28","children":[],"tail":", U.S.C., 1940 ed., appear in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1400"},"text":"section 1400 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
