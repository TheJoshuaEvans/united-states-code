{"tag":"section","attrib":{"id":"id52ee902b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002"},"text":null,"children":[{"tag":"num","attrib":{"value":"3002"},"text":"§ 3002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee902c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Counsel for the United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ee902d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States attorney, an assistant United States attorney designated to act on behalf of the United States attorney, or an attorney with the United States Department of Justice or with a Federal agency who has litigation authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee902e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any private attorney authorized by contract made in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3718"},"text":"section 3718 of title 31","children":[],"tail":" to conduct litigation for collection of debts on behalf of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee902f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Court” means any court created by the Congress of the United States, excluding the United States Tax Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9030-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Debt” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ee9031-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that is owing to the United States on account of a direct loan, or loan insured or guaranteed, by the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee9032-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount that is owing to the United States on account of a fee, duty, lease, rent, service, sale of real or personal property, overpayment, fine, assessment, penalty, restitution, damages, interest, tax, bail bond forfeiture, reimbursement, recovery of a cost incurred by the United States, or other source of indebtedness to the United States, but that is not owing under the terms of a contract originally entered into by only persons other than the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and includes any amount owing to the United States for the benefit of an Indian tribe or individual Indian, but excludes any amount to which the United States is entitled under section 3011(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9033-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Debtor” means a person who is liable for a debt or against whom there is a claim for a debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9034-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Disposable earnings” means that part of earnings remaining after all deductions required by law have been withheld.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9035-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Earnings” means compensation paid or payable for personal services, whether denominated as wages, salary, commission, bonus, or otherwise, and includes periodic payments pursuant to a pension or retirement program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9036-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Garnishee” means a person (other than the debtor) who has, or is reasonably thought to have, possession, custody, or control of any property in which the debtor has a substantial nonexempt interest, including any obligation due the debtor or to become due the debtor, and against whom a garnishment under section 3104 or 3205 is issued by a court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9037-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Judgment” means a judgment, order, or decree entered in favor of the United States in a court and arising from a civil or criminal proceeding regarding a debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9038-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Nonexempt disposable earnings” means 25 percent of disposable earnings, subject to section 303 of the Consumer Credit Protection Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9039-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Person” includes a natural person (including an individual Indian), a corporation, a partnership, an unincorporated association, a trust, or an estate, or any other public or private entity, including a State or local government or an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee903a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Prejudgment remedy” means the remedy of attachment, receivership, garnishment, or sequestration authorized by this chapter to be granted before judgment on the merits of a claim for a debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee903b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Property” includes any present or future interest, whether legal or equitable, in real, personal (including choses in action), or mixed property, tangible or intangible, vested or contingent, wherever located and however held (including community property and property held in trust (including spendthrift and pension trusts)), but excludes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ee903c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property held in trust by the United States for the benefit of an Indian tribe or individual Indian; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee903d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian lands subject to restrictions against alienation imposed by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee903e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Security agreement” means an agreement that creates or provides for a lien.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee903f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Marianas, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9040-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “United States” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ee9041-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee9042-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency, department, commission, board, or other entity of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee9043-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an instrumentality of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9044-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3002/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States marshal” means a United States marshal, a deputy marshal, or an official of the United States Marshals Service designated under section 564.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee9045-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4933"},"text":"104 Stat. 4933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee9046-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee9047-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52ee9048-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 303 of the Consumer Credit Protection Act, referred to in par. (9), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1673"},"text":"section 1673 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee9049-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee904a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
