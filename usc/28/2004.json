{"tag":"section","attrib":{"id":"id52c86a6c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2004"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004"},"text":"§ 2004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of personalty generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any personalty sold under any order or decree of any court of the United States shall be sold in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2001"},"text":"section 2001 of this title","children":[],"tail":", unless the court orders otherwise."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section shall not apply to sales and proceedings under Title 11 or by receivers or conservators of banks appointed by the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c86a6d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/959"},"text":"62 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c86a6e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c86a6f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 848 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1893-03-03/ch225/s2"},"text":"Mar. 3, 1893, ch. 225, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/751"},"text":"27 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-04-24/ch77/s2"},"text":"Apr. 24, 1935, ch. 77, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/160"},"text":"49 Stat. 160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-19/ch276"},"text":"June 19, 1935, ch. 276","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/390"},"text":"49 Stat. 390","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision making the section applicable to pending proceedings was deleted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
