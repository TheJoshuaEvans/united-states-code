{"tag":"section","attrib":{"id":"id52880548-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s607"},"text":null,"children":[{"tag":"num","attrib":{"value":"607"},"text":"§ 607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice of law prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An officer or employee of the Administrative Office shall not engage directly or indirectly in the practice of law in any court of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52880549-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/915"},"text":"62 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5288054a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5288054b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 445 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s303"},"text":"Mar. 3, 1911, ch. 231, § 303","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch501/s1"},"text":"Aug. 7, 1939, ch. 501, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1223"},"text":"53 Stat. 1223","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains the last paragraph of title 28, U.S.C., 1940 ed., § 445. The remainder of said section is incorporated in sections 602 and 603 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
