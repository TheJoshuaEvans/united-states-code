{"tag":"section","attrib":{"id":"id52f34b70-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307"},"text":null,"children":[{"tag":"num","attrib":{"value":"3307"},"text":"§ 3307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defenses, liability, and protection of trans­feree","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f34b71-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Good Faith Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transfer or obligation is not voidable under section 3304(b) with respect to a person who took in good faith and for a reasonably equivalent value or against any transferee or obligee subsequent to such person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bb72-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), to the extent a transfer is voidable in an action or proceeding by the United States under section 3306(a)(1), the United States may recover judgment for the value of the asset transferred, but not to exceed the judgment on a debt. The judgment may be entered against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bb73-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first transferee of the asset or the person for whose benefit the transfer was made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb74-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsequent transferee, other than a good faith transferee who took for value or any subsequent transferee of such good-faith transferee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bb75-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Value of Asset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (b), the value of the asset is the value of the asset at the time of the transfer, subject to adjustment as the equities may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bb76-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights of Good Faith Transferees and Obligees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding voidability of a transfer or an obligation under this subchapter, a good-faith transferee or obligee is entitled, to the extent of the value given the debtor for the transfer or obligation, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bb77-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lien on or a right to retain any interest in the asset transferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb78-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement of any obligation incurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb79-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction in the amount of the liability on the judgment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bb7a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transfer is not voidable under section 3304(a) or section 3304(b)(2) if the transfer results from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bb7b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" termination of a lease upon default by the debtor when the termination is pursuant to the lease and applicable law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb7c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement of a security interest in compliance with article 9 of the Uniform Commercial Code or its equivalent in effect in the State where the property is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bb7d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Voidability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A transfer is not voidable under section 3304(a)(2)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bb7e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent the insider gives new value to or for the benefit of the debtor after the transfer is made unless the new value is secured by a valid lien;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb7f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if made in the ordinary course of business or financial affairs of the debtor and the insider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb80-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3307/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if made pursuant to a good-faith effort to rehabilitate the debtor and the transfer secured both present value given for that purpose and an antecedent debt of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f5bb81-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4963"},"text":"104 Stat. 4963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f5bb82-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f5bb83-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f5bb84-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
