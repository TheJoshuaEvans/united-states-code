{"tag":"section","attrib":{"id":"id52a2441c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1345"},"text":null,"children":[{"tag":"num","attrib":{"value":"1345"},"text":"§ 1345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States as plaintiff","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by Act of Congress, the district courts shall have original jurisdiction of all civil actions, suits or proceedings commenced by the United States, or by any agency or officer thereof expressly authorized to sue by Act of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a2441d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/933"},"text":"62 Stat. 933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a2441e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a2441f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(1) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 1, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1091"},"text":"36 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-14/ch283/s1"},"text":"May 14, 1934, ch. 283, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/775"},"text":"48 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-08-21/ch726/s1"},"text":"Aug. 21, 1937, ch. 726, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/738"},"text":"50 Stat. 738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-04-20/ch117"},"text":"Apr. 20, 1940, ch. 117","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/143"},"text":"54 Stat. 143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/1"},"text":"section 41(1) of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 1331, 1332, 1341, 1342, 1354, and 1359 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil actions, suits or proceedings” were substituted for “suits of a civil nature, at common law or in equity” in view of Rules 2 and 81(a)(7) of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “agency” was inserted in order that this section shall apply to actions by agencies of the Government and to conform with special acts authorizing such actions. (See definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “Except as otherwise provided by Act of Congress,” at the beginning of the section was inserted to make clear that jurisdiction exists generally in district courts in the absence of special provisions conferring it elsewhere.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
