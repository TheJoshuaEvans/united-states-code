{"tag":"section","attrib":{"id":"id52b556ed-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1631"},"text":null,"children":[{"tag":"num","attrib":{"value":"1631"},"text":"§ 1631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to cure want of jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a civil action is filed in a court as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s610"},"text":"section 610 of this title","children":[],"tail":" or an appeal, including a petition for review of administrative action, is noticed for or filed with such a court and that court finds that there is a want of jurisdiction, the court shall, if it is in the interest of justice, transfer such action or appeal to any other such court (or, for cases within the jurisdiction of the United States Tax Court, to that court) in which the action or appeal could have been brought at the time it was filed or noticed, and the action or appeal shall proceed as if it had been filed in or noticed for the court to which it is transferred on the date upon which it was actually filed in or noticed for the court from which it is transferred."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b556ee-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tIII/s301/a"},"text":"Pub. L. 97–164, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/55"},"text":"96 Stat. 55","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/332/s2"},"text":"Pub. L. 115–332, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-19"},"text":"Dec. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4487"},"text":"132 Stat. 4487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b556ef-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52b556f0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52b556f1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/332"},"text":"Pub. L. 115–332","children":[],"tail":" inserted “(or, for cases within the jurisdiction of the United States Tax Court, to that court)” after “any other such court”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b556f2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52b556f3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as an Effective Date of 1982 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
