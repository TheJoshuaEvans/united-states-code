{"tag":"section","attrib":{"id":"id5228a6e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s85"},"text":null,"children":[{"tag":"num","attrib":{"value":"85"},"text":"§ 85.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Colorado","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Colorado constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Boulder, Colorado Springs, Denver, Durango, Grand Junction, Montrose, Pueblo, and Sterling.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5228a6e1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/875"},"text":"62 Stat. 875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s409"},"text":"Pub. L. 98–620, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3362"},"text":"98 Stat. 3362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/455/s5"},"text":"Pub. L. 108–455, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-10"},"text":"Dec. 10, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3629"},"text":"118 Stat. 3629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/482/tIII/s301"},"text":"Pub. L. 108–482, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3918"},"text":"118 Stat. 3918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5228a6e2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5228a6e3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 146 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s73"},"text":"Mar. 3, 1911, ch. 231, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1108"},"text":"36 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-06-12/ch143"},"text":"June 12, 1916, ch. 143","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/225"},"text":"39 Stat. 225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-05-29/ch209"},"text":"May 29, 1924, ch. 209","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/243"},"text":"43 Stat. 243","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision for furnishing rooms and accommodations at Sterling was omitted as obsolete upon advice from the Director of the Administrative Office of the United States Courts that Federal accommodations are now available.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision authorizing adjournment at Denver when there is not business for terms at other places, is incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s138"},"text":"section 138 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions as to clerk’s and marshal’s deputies and maintenance of offices were deleted as covered by sections 541 [see 561], 542 [see 561], and 751 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5228a6e4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5228a6e5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/455"},"text":"Pub. L. 108–455","children":[],"tail":" and 108–482 amended section identically, inserting “Colorado Springs,” after “Boulder,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" provided for holding court at Boulder."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5228a6e6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5228a6e7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s411"},"text":"Pub. L. 98–620, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3362"},"text":"98 Stat. 3362","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/620/tIV/s411"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this subtitle [subtitle B (§§ 404–411) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":", amending this section and sections 90, 93, 112, 124, and 126 of this title and enacting provisions set out as notes under sections 1, 90, 93, and 124 of this title] shall take effect on "},{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this subtitle shall not affect the composition, or preclude the service, of any grand or petit jury summoned, impaneled, or actually serving on the effective date of this subtitle [","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"Jan. 1, 1985","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
