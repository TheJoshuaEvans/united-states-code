{"tag":"section","attrib":{"id":"id52b09be3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603"},"text":null,"children":[{"tag":"num","attrib":{"value":"1603"},"text":"§ 1603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52b09be4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “foreign state”, except as used in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1608"},"text":"section 1608 of this title","children":[],"tail":", includes a political subdivision of a foreign state or an agency or instrumentality of a foreign state as defined in subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b09be5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An “agency or instrumentality of a foreign state” means any entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52b09be6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is a separate legal person, corporate or otherwise, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52b09be7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is an organ of a foreign state or political subdivision thereof, or a majority of whose shares or other ownership interest is owned by a foreign state or political subdivision thereof, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52b09be8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is neither a citizen of a State of the United States as defined in section 1332 (c) and (e) of this title, nor created under the laws of any third country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b09be9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The “United States” includes all territory and waters, continental or insular, subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b09bea-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “commercial activity” means either a regular course of commercial conduct or a particular commercial transaction or act. The commercial character of an activity shall be determined by reference to the nature of the course of conduct or particular transaction or act, rather than by reference to its purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b09beb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1603/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A “commercial activity carried on in the United States by a foreign state” means commercial activity carried on by such state and having substantial contact with the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52b09bec-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/583/s4/a"},"text":"Pub. L. 94–583, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2892"},"text":"90 Stat. 2892","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/2/s4/b/2"},"text":"Pub. L. 109–2, § 4(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/12"},"text":"119 Stat. 12","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b09bed-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52b09bee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52b09bef-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/2"},"text":"Pub. L. 109–2","children":[],"tail":" substituted “(e)” for “(d)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b09bf0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52b09bf1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/2"},"text":"Pub. L. 109–2","children":[],"tail":" applicable to any civil action commenced on or after "},{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/2/s9"},"text":"section 9 of Pub. L. 109–2","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52b09bf2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/583/s8"},"text":"section 8 of Pub. L. 94–583","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
