{"tag":"section","attrib":{"id":"id52b5570d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1653"},"text":null,"children":[{"tag":"num","attrib":{"value":"1653"},"text":"§ 1653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of pleadings to show jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Defective allegations of jurisdiction may be amended, upon terms, in the trial or appellate courts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b5570e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/944"},"text":"62 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b5570f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52b55710-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 399 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s274c"},"text":"Mar. 3, 1911, ch. 231, § 274c","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch90"},"text":"Mar. 3, 1915, ch. 90","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/956"},"text":"38 Stat. 956","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was extended to permit amendment of all jurisdictional allegations instead of merely allegations of diversity of citizenship as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s399"},"text":"section 399 of title 28","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
