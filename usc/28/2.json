{"tag":"section","attrib":{"id":"id521f310e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of court","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Supreme Court shall hold at the seat of government a term of court commencing on the first Monday in October of each year and may hold such adjourned or special terms as may be necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id521f310f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id521f3110-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id521f3111-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 338 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s230"},"text":"Mar. 3, 1911, ch. 231, § 230","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1156"},"text":"36 Stat. 1156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-09-06/ch448/s1"},"text":"Sept. 6, 1916, ch. 448, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/726"},"text":"39 Stat. 726","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
