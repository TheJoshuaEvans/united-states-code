{"tag":"section","attrib":{"id":"id52b7c848-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1691"},"text":null,"children":[{"tag":"num","attrib":{"value":"1691"},"text":"§ 1691.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seal and teste of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All writs and process issuing from a court of the United States shall be under the seal of the court and signed by the clerk thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b7c849-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/945"},"text":"62 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b7c84a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52b7c84b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 721 (R.S. § 911; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions as to teste of process issuing from the district courts were omitted as superseded by Rule 4 (b) of the Federal Rules of Civil Procedure. Provision for teste of the Chief Justice of writs and process was omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision requiring the United States to bear the expense of providing seals was omitted as unnecessary and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b7c84c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52b7c84d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Immunity From Seizure Under Judicial Process of Cultural Objects Imported for Temporary Exhibition or Display","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential determination of cultural significance of objects and exhibition or display thereof in the national interest, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2459"},"text":"section 2459 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
