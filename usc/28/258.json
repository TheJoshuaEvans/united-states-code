{"tag":"section","attrib":{"id":"id524556bd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258"},"text":null,"children":[{"tag":"num","attrib":{"value":"258"},"text":"§ 258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief judges; precedence of judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524556be-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id524556bf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The chief judge of the Court of International Trade shall be the judge of the court in regular active service who is senior in commission of those judges who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524556c0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are 64 years of age or under;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524556c1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have served for 1 year or more as a judge of the court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524556c2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not served previously as chief judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524556c3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524556c4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which no judge of the court meets the qualifications under paragraph (1), the youngest judge in regular active service who is 65 years of age or over and who has served as a judge of the court for 1 year or more shall act as the chief judge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524556c5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case under subparagraph (A) in which there is no judge of the court in regular active service who has served as a judge of the court for 1 year or more, the judge of the court in regular active service who is senior in commission and who has not served previously as chief judge shall act as the chief judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id524556c6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id524556c7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subparagraph (C), the chief judge serving under paragraph (1) shall serve for a term of 7 years and shall serve after expiration of such term until another judge is eligible under paragraph (1) to serve as chief judge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524556c8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subparagraph (C), a judge of the court acting as chief judge under subparagraph (A) or (B) of paragraph (2) shall serve until a judge meets the qualifications under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id524556c9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No judge of the court may serve or act as chief judge of the court after attaining the age of 70 years unless no other judge is qualified to serve as chief judge under paragraph (1) or is qualified to act as chief judge under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524556ca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge shall have precedence and preside at any session of the court which such judge attends. Other judges of the court shall have precedence and preside according to the seniority of their commissions. Judges whose commissions bear the same date shall have precedence according to seniority in age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524556cb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the chief judge desires to be relieved of the duties as chief judge while retaining active status as a judge of the court, the chief judge may so certify to the Chief Justice of the United States, and thereafter the chief judge of the court shall be such other judge of the court who is qualified to serve or act as chief judge under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524556cc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s258/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a chief judge is temporarily unable to perform the duties as such, such duties shall be performed by the judge of the court in active service, able and qualified to act, who is next in precedence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524556cd-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317/tV/s501/a"},"text":"Pub. L. 104–317, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3855"},"text":"110 Stat. 3855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id524556ce-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id524556cf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id524556d0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuance of Position of Chief Judge","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317/tV/s501/c"},"text":"Pub. L. 104–317, title V, § 501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3856"},"text":"110 Stat. 3856","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/317/tV/s501/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s258/a"},"text":"section 258(a) of title 28","children":[],"tail":", United States Code (as added by subsection (a) of this section), the chief judge of the United States Court of International Trade who is in office on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":"] shall continue to be such chief judge on or after such date until any one of the following events occurs:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge is relieved of his duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s258/c"},"text":"section 258(c) of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regular active status of the chief judge is terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge attains the age of 70 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge has served for a term of 7 years as chief judge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the chief judge vacates the position of chief judge under paragraph (1), the position of chief judge of the Court of International Trade shall be filled in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s258/a"},"text":"section 258(a) of title 28","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
