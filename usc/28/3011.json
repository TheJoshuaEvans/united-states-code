{"tag":"section","attrib":{"id":"id52ee90a4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3011"},"text":null,"children":[{"tag":"num","attrib":{"value":"3011"},"text":"§ 3011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of surcharge on a debt","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ee90a5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surcharge Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an action or proceeding under subchapter B or C, and subject to subsection (b), the United States is entitled to recover a surcharge of 10 percent of the amount of the debt in connection with the recovery of the debt, to cover the cost of processing and handling the litigation and enforcement under this chapter of the claim for such debt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee90a6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee90a7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States receives an attorney’s fee in connection with the enforcement of the claim; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee90a8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the law pursuant to which the action on the claim is based provides any other amount to cover such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee90a9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4937"},"text":"104 Stat. 4937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee90aa-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee90ab-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee90ac-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
