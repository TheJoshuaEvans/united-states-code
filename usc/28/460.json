{"tag":"section","attrib":{"id":"id525869df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s460"},"text":null,"children":[{"tag":"num","attrib":{"value":"460"},"text":"§ 460.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to other courts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525869e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s460/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 452 through 459 and section 462 of this chapter shall also apply to the United States Court of Federal Claims, to each court created by Act of Congress in a territory which is invested with any jurisdiction of a district court of the United States, and to the judges thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525869e1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s460/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The official duty station of each judge referred to in subsection (a) which is not otherwise established by law shall be that place where the court holds regular sessions at or near which the judge performs a substantial portion of his judicial work, which is nearest the place where he maintains his actual abode in which he customarily lives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525869e2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/908"},"text":"62 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s43/a"},"text":"Oct. 31, 1951, ch. 655, § 43(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/725"},"text":"65 Stat. 725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/508/s12/e"},"text":"Pub. L. 85–508, § 12(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/348"},"text":"72 Stat. 348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s217/a"},"text":"Pub. L. 95–598, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2661"},"text":"92 Stat. 2661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s115/b/1"},"text":"Pub. L. 97–164, title I, § 115(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/31"},"text":"96 Stat. 31","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525869e3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id525869e4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was included to make clear that the provisions of this chapter are equally applicable in Alaska, the Canal Zone and the Virgin Islands in view of definitive ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525869e5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id525869e6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “Application to other courts” for “Application to Canal Zone, Guam and Virgin Islands” in section catchline, designated existing provisions as subsec. (a), substituted “Sections 452 through 459 and section 462 of this chapter shall also apply to the United States Claims Court, to each court created by Act of Congress in a territory which is invested with any jurisdiction of a district court of the United States, and to the judges thereof” for “Sections 452–459 of this chapter shall also apply to the United States District Court for the District of the Canal Zone, the District Court of Guam and the District Court of the Virgin Islands and the judges thereof”, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" struck out “Alaska,” after “Application to” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L