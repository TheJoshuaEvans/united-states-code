{"tag":"section","attrib":{"id":"id52cd2468-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2111"},"text":null,"children":[{"tag":"num","attrib":{"value":"2111"},"text":"§ 2111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Harmless error","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On the hearing of any appeal or writ of certiorari in any case, the court shall give judgment after an examination of the record without regard to errors or defects which do not affect the substantial rights of the parties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52cd2469-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s110"},"text":"May 24, 1949, ch. 139, § 110","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/105"},"text":"63 Stat. 105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cd246a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cd246b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cd246c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Incorporates in title 28, U.S.C., as section 2111 thereof, the harmless error provisions of section 269 of the Judicial Code (now repealed), which applied to all courts of the United States and to all cases therein and therefore was superseded only in part by the Federal Procedural Rules, which apply only to the United States district courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
