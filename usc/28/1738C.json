{"tag":"section","attrib":{"id":"id52ba1230-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738C"},"text":"§ 1738C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain acts, records, and proceedings and the effect thereof","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ba1231-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person acting under color of State law may deny—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba1232-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full faith and credit to any public act, record, or judicial proceeding of any other State pertaining to a marriage between 2 individuals, on the basis of the sex, race, ethnicity, or national origin of those individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1233-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a right or claim arising from such a marriage on the basis that such marriage would not be recognized under the law of that State on the basis of the sex, race, ethnicity, or national origin of those individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1234-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement by Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may bring a civil action in the appropriate United States district court against any person who violates subsection (a) for declaratory and injunctive relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1235-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private Right of Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who is harmed by a violation of subsection (a) may bring a civil action in the appropriate United States district court against the person who violated such subsection for declaratory and injunctive relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1236-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “State” has the meaning given such term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s7"},"text":"section 7 of title 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ba1237-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/228/s4"},"text":"Pub. L. 117–228, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-13"},"text":"Dec. 13, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2305"},"text":"136 Stat. 2305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ba1238-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ba1239-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52ba123a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1738C, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/199/s2/a"},"text":"Pub. L. 104–199, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-21"},"text":"Sept. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2419"},"text":"110 Stat. 2419","children":[],"tail":", related to effect not required to be given to certain acts, records, and proceedings of another jurisdiction regarding marriage between persons of the same sex, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/117/228/s3"},"text":"Pub. L. 117–228, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-13"},"text":"Dec. 13, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2305"},"text":"136 Stat. 2305","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
