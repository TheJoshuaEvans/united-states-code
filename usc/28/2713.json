{"tag":"section","attrib":{"id":"id52ee8fe2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2713"},"text":null,"children":[{"tag":"num","attrib":{"value":"2713"},"text":"§ 2713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial of ownership of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than twenty days before the return day of a warrant issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2712"},"text":"section 2712 of this title","children":[],"tail":", the party whose property is attached, on notice to the United States Attorney, may file a plea in abatement, denying the allegations of the affidavit, or denying ownership in the defendant of the property attached. The court, upon application of either party, shall order a trial by jury of the issues. Where the parties, by consent, waive a trial by jury, the court shall decide the issues. A party claiming ownership of the property attached and seeking its return is limited to the remedy afforded by this section, but his right to an action of trespass, or other action for damages, is not impaired."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ee8fe3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/682/s9"},"text":"Pub. L. 86–682, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/707"},"text":"74 Stat. 707","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee8fe4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee8fe5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id52ee8fe6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from R.S. § 927, which was originally classified to section 740 of former Title 28. Following the general revision and enactment of Title 28 by act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", R.S. § 927 was reclassified to "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s840"},"text":"section 840 of Title 39","children":[],"tail":". R.S. § 927 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s12/c"},"text":"section 12(c) of Pub. L. 86–682","children":[],"tail":" (section 1 of which revised and enacted Title 39), and reenacted by section 9 thereof as "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2713"},"text":"section 2713 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee8fe7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee8fe8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1960-09-01"},"text":"Sept. 1, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s11"},"text":"section 11 of Pub. L. 86–682","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
