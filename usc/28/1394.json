{"tag":"section","attrib":{"id":"id52a4b52e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1394"},"text":null,"children":[{"tag":"num","attrib":{"value":"1394"},"text":"§ 1394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Banking association’s action against Comptroller of Currency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any civil action by a national banking association to enjoin the Comptroller of the Currency, under the provisions of any Act of Congress relating to such associations, may be prosecuted in the judicial district where such association is located.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a6ff1f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/935"},"text":"62 Stat. 935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ff20-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a6ff21-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 110 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s49"},"text":"Mar. 3, 1911, ch. 231, § 49","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1100"},"text":"36 Stat. 1100","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Any civil action” were substituted for “All proceedings,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id52a6ff22-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52a6ff23-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Exception as to Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested by any provision of law in the Comptroller of the Currency, referred to in this section, were not included in the transfer of functions of officers, agencies and employees of the Department of the Treasury to the Secretary of the Treasury, made by Reorg. Plan No. 26 of 1950, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", 15 F.R. 4935, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s321/c/2"},"text":"section 321(c)(2) of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
