{"tag":"section","attrib":{"id":"id52703759-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540B"},"text":null,"children":[{"tag":"num","attrib":{"value":"540B"},"text":"§ 540B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of serial killings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5270375a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General and the Director of the Federal Bureau of Investigation may investigate serial killings in violation of the laws of a State or political subdivision, if such investigation is requested by the head of a law enforcement agency with investigative or prosecutorial jurisdiction over the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270375b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5270375c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Killing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “killing” means conduct that would constitute an offense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1111"},"text":"section 1111 of title 18","children":[],"tail":", United States Code, if Federal jurisdiction existed."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270375d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Serial killings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “serial killings” means a series of three or more killings, not less than one of which was committed within the United States, having common characteristics such as to suggest the reasonable possibility that the crimes were committed by the same actor or actors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270375e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States, the District of Columbia, and any commonwealth, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5270375f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/314/tVII/s701/a"},"text":"Pub. L. 105–314, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2986"},"text":"112 Stat. 2986","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
