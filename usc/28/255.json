{"tag":"section","attrib":{"id":"id5245569f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s255"},"text":null,"children":[{"tag":"num","attrib":{"value":"255"},"text":"§ 255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Three-judge trials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524556a0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon application of any party to a civil action, or upon his own initiative, the chief judge of the Court of International Trade shall designate any three judges of the court to hear and determine any civil action which the chief judge finds: (1) raises an issue of the constitutionality of an Act of Congress, a proclamation of the President or an Executive order; or (2) has broad or significant implications in the administration or interpretation of the customs laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524556a1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of the three judges designated may hear and determine the civil action and all questions pending therein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524556a2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s108"},"text":"Pub. L. 91–271, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/277"},"text":"84 Stat. 277","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tV/s501/5"},"text":"Pub. L. 96–417, title V, § 501(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1742"},"text":"94 Stat. 1742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id524556a3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id524556a4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id524556a5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 255 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s257"},"text":"section 257 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id524556a6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" redesignated the Customs Court as the Court of International Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id524556a7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id524556a8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text