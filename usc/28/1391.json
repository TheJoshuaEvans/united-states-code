{"tag":"section","attrib":{"id":"id52a4b502-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391"},"text":null,"children":[{"tag":"num","attrib":{"value":"1391"},"text":"§ 1391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a4b503-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Section","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b504-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section shall govern the venue of all civil actions brought in district courts of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b505-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proper venue for a civil action shall be determined without regard to whether the action is local or transitory in nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b506-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue in General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action may be brought in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b507-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judicial district in which any defendant resides, if all defendants are residents of the State in which the district is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b508-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a judicial district in which a substantial part of the events or omissions giving rise to the claim occurred, or a substantial part of property that is the subject of the action is situated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b509-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no district in which an action may otherwise be brought as provided in this section, any judicial district in which any defendant is subject to the court’s personal jurisdiction with respect to such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b50a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Residency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For all venue purposes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b50b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural person, including an alien lawfully admitted for permanent residence in the United States, shall be deemed to reside in the judicial district in which that person is domiciled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b50c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity with the capacity to sue and be sued in its common name under applicable law, whether or not incorporated, shall be deemed to reside, if a defendant, in any judicial district in which such defendant is subject to the court’s personal jurisdiction with respect to the civil action in question and, if a plaintiff, only in the judicial district in which it maintains its principal place of business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b50d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a defendant not resident in the United States may be sued in any judicial district, and the joinder of such a defendant shall be disregarded in determining where the action may be brought with respect to other defendants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b50e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Residency of Corporations in States With Multiple Districts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of venue under this chapter, in a State which has more than one judicial district and in which a defendant that is a corporation is subject to personal jurisdiction at the time an action is commenced, such corporation shall be deemed to reside in any district in that State within which its contacts would be sufficient to subject it to personal jurisdiction if that district were a separate State, and, if there is no such district, the corporation shall be deemed to reside in the district within which it has the most significant contacts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b50f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Where Defendant Is Officer or Employee of the United States.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b510-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action in which a defendant is an officer or employee of the United States or any agency thereof acting in his official capacity or under color of legal authority, or an agency of the United States, or the United States, may, except as otherwise provided by law, be brought in any judicial district in which (A) a defendant in the action resides, (B) a substantial part of the events or omissions giving rise to the claim occurred, or a substantial part of property that is the subject of the action is situated, or (C) the plaintiff resides if no real property is involved in the action. Additional persons may be joined as parties to any such action in accordance with the Federal Rules of Civil Procedure and with such other venue requirements as would be applicable if the United States or one of its officers, employees, or agencies were not a party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b511-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The summons and complaint in such an action shall be served as provided by the Federal Rules of Civil Procedure except that the delivery of the summons and complaint to the officer or agency as required by the rules may be made by certified mail beyond the territorial limits of the district in which the action is brought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b512-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions Against a Foreign State","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action against a foreign state as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1603/a"},"text":"section 1603(a) of this title","children":[],"tail":" may be brought—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b513-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any judicial district in which a substantial part of the events or omissions giving rise to the claim occurred, or a substantial part of property that is the subject of the action is situated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b514-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any judicial district in which the vessel or cargo of a foreign state is situated, if the claim is asserted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1605/b"},"text":"section 1605(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b515-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any judicial district in which the agency or instrumentality is licensed to do business or is doing business, if the action is brought against an agency or instrumentality of a foreign state as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1603/b"},"text":"section 1603(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b516-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States District Court for the District of Columbia if the action is brought against a foreign state or political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b517-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1391/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiparty, Multiforum Litigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action in which jurisdiction of the district court is based upon ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1369"},"text":"section 1369 of this title","children":[],"tail":" may be brought in any district in which any defendant resides or in which a substantial part of the accident giving rise to the action took place."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a4b518-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/935"},"text":"62 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/748/s2"},"text":"Pub. L. 87–748, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-05"},"text":"Oct. 5, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/744"},"text":"76 Stat. 744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/234"},"text":"Pub. L. 88–234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-23"},"text":"Dec. 23, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/473"},"text":"77 Stat. 473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/714"},"text":"Pub. L. 89–714","children":[],"tail":", §§ 1, 2, "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1111"},"text":"80 Stat. 1111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/574/s3"},"text":"Pub. L. 94–574, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2721"},"text":"90 Stat. 2721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/583/s5"},"text":"Pub. L. 94–583, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2897"},"text":"90 Stat. 2897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tX/s1013/a"},"text":"Pub. L. 100–702, title X, § 1013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4669"},"text":"102 Stat. 4669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s311"},"text":"Pub. L. 101–650, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5114"},"text":"104 Stat. 5114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/198/s3"},"text":"Pub. L. 102–198, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1623"},"text":"105 Stat. 1623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tV/s504"},"text":"Pub. L. 102–572, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4513"},"text":"106 Stat. 4513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/34/s1"},"text":"Pub. L. 104–34, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-10-03"},"text":"Oct. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/293"},"text":"109 Stat. 293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11020/b/2"},"text":"Pub. L. 107–273, div. C, title I, § 11020(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1827"},"text":"116 Stat. 1827","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/63/tII/s202"},"text":"Pub. L. 112–63, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/763"},"text":"125 Stat. 763","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b519-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a4b51a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 111, 112 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 50, 51, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1101"},"text":"36 Stat. 1101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch345"},"text":"Sept. 19, 1922, ch. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/849"},"text":"42 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch526/s1"},"text":"Mar. 4, 1925, ch. 526, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1264"},"text":"43 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-04-16/ch230"},"text":"Apr. 16, 1936, ch. 230","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1213"},"text":"49 Stat. 1213","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s111"},"text":"section 111 of title 28","children":[],"tail":", U.S.C., 1940 ed., with part of section 112 of such title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The portion of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s112"},"text":"section 112 of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to venue generally constitutes this section and the parts relating to arrest of the defendant, venue and process in stockholders’ actions constitute sections 1401, 1693, and 1695 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s111"},"text":"section 111 of title 28","children":[],"tail":", U.S.C., 1940 ed., that a district court may proceed as to parties before it although one or more defendants do not reside in the district, and that its judgment shall be without prejudice to such absent defendants, was omitted as covered by rule 19(b) of the Federal Rules of Civil Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “action” was substituted for “suit” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “reside” was substituted for “whereof he is an inhabitant” for clarity inasmuch as “inhabitant” and “resident” are synonymous. (See ","children":[{"tag":"i","attrib":{},"text":"Ex parte Shaw","children":[],"tail":", 1892, 12 S.Ct. 935, 145 U.S. 444, 36 L.Ed. 768; "},{"tag":"i","attrib":{},"text":"Standard Stoker Co., Inc. v. Lower","children":[],"tail":", D.C., 1931, 46 F.2d 678; "},{"tag":"i","attrib":{},"text":"Edgewater Realty Co. v. Tennessee Coal, Iron & Railroad Co","children":[],"tail":"., D.C., 1943, 49 F.Supp. 807.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to “all plaintiffs” and “all defendants” were substituted for references to “the plaintiff” and “the defendant,” in view of many decisions holding that the singular terms were used in a collective sense. (See ","children":[{"tag":"i","attrib":{},"text":"Smith v. Lyon","children":[],"tail":", 1890, 10 S.Ct. 303, 133 U.S. 315, 33 L.Ed. 635; "},{"tag":"i","attrib":{},"text":"Hooe v. Jamieson","children":[],"tail":", 1897, 17 S.Ct. 596, 166 U.S. 395, 41 L.Ed. 1049; and "},{"tag":"i","attrib":{},"text":"Fetzer v. Livermore","children":[],"tail":", D.C., 1926, 15 F.2d 462.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), references to defendants “found” within a district or voluntarily appearing were omitted. The use of the word “found” made ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s111"},"text":"section 111 of title 28","children":[],"tail":", U.S.C., 1940 ed., ambiguous. The argument that an action could be brought in the district where one defendant resided and a nonresident defendant was “found,” was rejected in "},{"tag":"i","attrib":{},"text":"Camp v. Gress","children":[],"tail":", 1919, 39 S.Ct. 478, 250 U.S. 308, 63 L.Ed. 997. However, this ambiguity will be obviated in the future by the omission of such reference."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) of this section is added to give statutory recognition to the weight of authority concerning a rule of venue as to which there has been a sharp conflict of decisions. (See ","children":[{"tag":"i","attrib":{},"text":"Sandusky Foundry & Machine Co. v. DeLavand","children":[],"tail":", 1918, D.C.Ohio, 251 F. 631, 632, and cases cited. See also "},{"tag":"i","attrib":{},"text":"Keating v. Pennsylvania Co","children":[],"tail":"., 1917, D.C.Ohio, 245 F. 155 and cases cited.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a4b51b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52a4b51c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (e), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a4b51d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63/s202/1"},"text":"Pub. L. 112–63, § 202(1)","children":[],"tail":", added subsecs. (a) to (d) and struck out former subsecs. (a) to (d) which related to venue when jurisdiction is founded only on diversity of citizenship, when jurisdiction is not founded solely on diversity of citizenship, when a defendant is a corporation, and when an alien is sued, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63/s202/2"},"text":"Pub. L. 112–63, § 202(2)","children":[],"tail":", inserted subsec. heading, substituted “(A)”, “(B)”, and “(C)” for “(1)”, “(2)”, and “(3)”, respectively, in first par., designated first and second pars. as pars. (1) and (2), respectively, and inserted par. headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63/s202/3"},"text":"Pub. L. 112–63, § 202(3)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63/s202/4"},"text":"Pub. L. 112–63, § 202(4)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/34"},"text":"Pub. L. 104–34","children":[],"tail":" substituted “any defendant is” for “the defendants are”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" inserted before period at end “, if there is no district in which the action may otherwise be brought”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198"},"text":"Pub. L. 102–198","children":[],"tail":" substituted “in (1)” for “if (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s311/1"},"text":"Pub. L. 101–650, § 311(1)","children":[],"tail":", substituted cls. (1) to (3) for “the judicial district where all plaintiffs or all defendants reside, or in which the claim arose”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s311/2"},"text":"Pub. L. 101–650, § 311(2)","children":[],"tail":", substituted “may, except as otherwise provided by law, be brought only if” and cls. (1) to (3) for “may be brought only in the judicial district where all defendants reside, or in which the claim arose, except as otherwise provided by law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s311/3"},"text":"Pub. L. 101–650, § 311(3)","children":[],"tail":", substituted “(2) a substantial part of the events or omissions giving rise to the claim occurred, or a substantial part of property that is the subject of the action is situated, or (3)” for “or (2) the cause of action arose, or (3) any real property involved in the action is situated, or (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “A corporation may be sued in any judicial district in which it is incorporated or licensed to do business or is doing business, and such judicial district shall be regarded as the residence of such corporation for venue purposes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/574"},"text":"Pub. L. 94–574","children":[],"tail":" provided that, in actions against the United States, its agencies, or officers or employees in their official capacities, additional persons may be joined in accordance with the Federal Rules of Civil Procedure and with other venue requirements which would be applicable if the United States, its agencies, or one of its officers or employees were not a party."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/583"},"text":"Pub. L. 94–583","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/714/s1"},"text":"Pub. L. 89–714, § 1","children":[],"tail":", authorized a civil action to be brought in the judicial district in which the claim arose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/714/s1"},"text":"Pub. L. 89–714, § 1","children":[],"tail":", authorized a civil action to be brought in the judicial district in which the claim arose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/714/s2"},"text":"Pub. L. 89–714, § 2","children":[],"tail":", repealed subsec. (f) which permitted a civil action on a tort claim arising out of the manufacture, assembly, repair, ownership, maintenance, use, or operation of an automobile to be brought in the judicial district wherein the act or omission complained of occurred. Present provisions are now contained in subsecs. (a) and (b) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/234"},"text":"Pub. L. 88–234","children":[],"tail":" added subsec. (f)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/748"},"text":"Pub. L. 87–748","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b51e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b51f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63"},"text":"Pub. L. 112–63","children":[],"tail":" effective upon the expiration of the 30-day period beginning on "},{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":", and applicable to any action commenced in a United States district court on or after such effective date, and to any action removed from a State court to a United States district court that had been commenced, within the meaning of State law, on or after such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/63/s205"},"text":"section 205 of Pub. L. 112–63","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1390"},"text":"section 1390 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b520-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273"},"text":"Pub. L. 107–273","children":[],"tail":" applicable to a civil action if the accident giving rise to the cause of action occurred on or after the 90th day after "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/s11020/c"},"text":"section 11020(c) of Pub. L. 107–273","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1369"},"text":"section 1369 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b521-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1101/a"},"text":"section 1101(a) of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b522-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tX/s1013/b"},"text":"Pub. L. 100–702, title X, § 1013(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4669"},"text":"102 Stat. 4669","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/702/tX/s1013/b"},"text":"“The amendment made by this section [amending this section] takes effect 90 days after the date of enactment of this title [","children":[{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b523-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/583"},"text":"Pub. L. 94–583","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/583/s8"},"text":"section 8 of Pub. L. 94–583","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
