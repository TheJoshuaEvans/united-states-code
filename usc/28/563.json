{"tag":"section","attrib":{"id":"id5274f25c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s563"},"text":null,"children":[{"tag":"num","attrib":{"value":"563"},"text":"§ 563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director and each United States marshal and law enforcement officer of the Service, before taking office, shall take an oath or affirmation to faithfully execute the duties of that office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5274f25d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7608/a/1"},"text":"Pub. L. 100–690, title VII, § 7608(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4513"},"text":"102 Stat. 4513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5274f25e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5274f25f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5274f260-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 563, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/619"},"text":"80 Stat. 619","children":[],"tail":", specifically stated the oath of office to be taken, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7608/a/1"},"text":"Pub. L. 100–690, § 7608(a)(1)","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s561/h"},"text":"section 561(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
