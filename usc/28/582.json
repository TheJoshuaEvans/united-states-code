{"tag":"section","attrib":{"id":"id5279adcb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s582"},"text":null,"children":[{"tag":"num","attrib":{"value":"582"},"text":"§ 582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant United States trustees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5279adcc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may appoint one or more assistant United States trustees in any region when the public interest so requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279adcd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each assistant United States trustee is subject to removal by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5279adce-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s224/a"},"text":"Pub. L. 95–598, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2663"},"text":"92 Stat. 2663","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI/s111/d"},"text":"Pub. L. 99–554, title I, § 111(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3091"},"text":"100 Stat. 3091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5279adcf-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"ta