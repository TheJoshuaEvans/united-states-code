{"tag":"section","attrib":{"id":"id52abe17e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453"},"text":null,"children":[{"tag":"num","attrib":{"value":"1453"},"text":"§ 1453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of class actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52abe17f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “class”, “class action”, “class certification order”, and “class member” shall have the meanings given such terms under section 1332(d)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe180-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A class action may be removed to a district court of the United States in accordance with section 1446 (except that the 1-year limitation under section 1446(c)(1) shall not apply), without regard to whether any defendant is a citizen of the State in which the action is brought, except that such action may be removed by any defendant without the consent of all defendants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe181-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Remand Orders.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52abe182-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 1447 shall apply to any removal of a case under this section, except that notwithstanding section 1447(d), a court of appeals may accept an appeal from an order of a district court granting or denying a motion to remand a class action to the State court from which it was removed if application is made to the court of appeals not more than 10 days after entry of the order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe183-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time period for judgment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the court of appeals accepts an appeal under paragraph (1), the court shall complete all action on such appeal, including rendering judgment, not later than 60 days after the date on which such appeal was filed, unless an extension is granted under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe184-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of time period","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court of appeals may grant an extension of the 60-day period described in paragraph (2) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52abe185-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all parties to the proceeding agree to such extension, for any period of time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52abe186-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such extension is for good cause shown and in the interests of justice, for a period not to exceed 10 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe187-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a final judgment on the appeal under paragraph (1) is not issued before the end of the period described in paragraph (2), including any extension under paragraph (3), the appeal shall be denied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe188-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section shall not apply to any class action that solely involves—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52abe189-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim concerning a covered security as defined under section 16(f)(3) of the Securities Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78p/f/3"},"text":"15 U.S.C. 78p(f)(3)","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “77p(f)(3)”."}],"tail":") and section 28(f)(5)(E) of the Securities Exchange Act of 1934 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78bb/f/5/E"},"text":"15 U.S.C. 78bb(f)(5)(E)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe18a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim that relates to the internal affairs or governance of a corporation or other form of business enterprise and arises under or by virtue of the laws of the State in which such corporation or business enterprise is incorporated or organized; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52abe18b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1453/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim that relates to the rights, duties (including fiduciary duties), and obligations relating to or created by or pursuant to any security (as defined under section 2(a)(1) of the Securities Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77b/a/1"},"text":"15 U.S.C. 77b(a)(1)","children":[],"tail":") and the regulations issued thereunder)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52abe18c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/2/s5/a"},"text":"Pub. L. 109–2, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/12"},"text":"119 Stat. 12","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s6/2"},"text":"Pub. L. 111–16, § 6(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-07"},"text":"May 7, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1608"},"text":"123 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/63/tI/s103/d/2"},"text":"Pub. L. 112–63, title I, § 103(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/762"},"text":"125 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52abe18d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52abe18e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52abe18f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63"},"text":"Pub. L. 112–63","children":[],"tail":" substituted “1446(c)(1)” for “1446(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" substituted “not more than 10 days” for “not less than 7 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52abe190-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52abe191-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/63"},"text":"Pub. L. 112–63","children":[],"tail":" effective upon the expiration of the 30-day period beginning on "},{"tag":"date","attrib":{"date":"2011-12-07"},"text":"Dec. 7, 2011","children":[],"tail":", and applicable to any action or prosecution commenced on or after such effective date, with provisions for treatment of cases removed to Federal court, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/63/s105"},"text":"section 105 of Pub. L. 112–63","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52abe192-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/16"},"text":"Pub. L. 111–16","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-12-01"},"text":"Dec. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/16/s7"},"text":"section 7 of Pub. L. 111–16","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s109"},"text":"section 109 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52abe193-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any civil action commenced on or after ","children":[{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/2/s9"},"text":"section 9 of Pub. L. 109–2","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
