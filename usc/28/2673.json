{"tag":"section","attrib":{"id":"id52ec4560-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2673"},"text":null,"children":[{"tag":"num","attrib":{"value":"2673"},"text":"§ 2673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The head of each federal agency shall report annually to Congress all claims paid by it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of this title","children":[],"tail":", stating the name of each claimant, the amount claimed, the amount awarded, and a brief description of the claim."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ec4561-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/983"},"text":"62 Stat. 983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ec4562-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ec4563-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 922 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753/s404"},"text":"Aug. 2, 1946, ch. 753, § 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/843"},"text":"60 Stat. 843","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ec4564-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52ec4565-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/348/s1/1"},"text":"Pub. L. 89–348, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1310"},"text":"79 Stat. 1310","children":[],"tail":", repealed the requirement that an annual report to Congress be made of the administrative adjustment of tort claims of $2,500 or less, stating the name of each claimant, the amount claimed, the amount awarded, and a brief description of the claim."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
