le 40","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/581/tII/s202/b"},"text":"Pub. L. 87–581, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-13"},"text":"Aug. 13, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/360"},"text":"76 Stat. 360","children":[],"tail":", provided that the Court of Claims (now United States Court of Federal Claims) was to continue to have jurisdiction to render judgment upon certain claims for a penalty withheld from a contractor or subcontractor under section 324 of former Title 40, Public Buildings, Property, and Works, in connection with any contract subject to that section existing on the date sixty days after "},{"tag":"date","attrib":{"date":"1962-08-13"},"text":"Aug. 13, 1962","children":[],"tail":", or thereafter entered into pursuant to invitations for bids that were outstanding on "},{"tag":"date","attrib":{"date":"1962-08-13"},"text":"Aug. 13, 1962","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
