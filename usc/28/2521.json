{"tag":"section","attrib":{"id":"id52e76426-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521"},"text":null,"children":[{"tag":"num","attrib":{"value":"2521"},"text":"§ 2521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas and incidental powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e76427-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subpoenas requiring the attendance of parties or witnesses and subpoenas requiring the production of books, papers, documents or tangible things by any party or witness having custody or control thereof, may be issued for purposes of discovery or for use of the things produced as evidence in accordance with the rules and orders of the court. Such subpoenas shall be issued and served and compliance therewith shall be compelled as provided in the rules and orders of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e76428-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Court of Federal Claims shall have power to punish by fine or imprisonment, at its discretion, such contempt of its authority as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52e76429-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misbehavior of any person in its presence or so near thereto as to obstruct the administration of justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e7642a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misbehavior of any of its officers in their official transactions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e7642b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disobedience or resistance to its lawful writ, process, order, rule, decree, or command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e7642c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Court of Federal Claims shall have such assistance in the carrying out of its lawful writ, process, order, rule, decree, or command as is available to a court of the United States. The United States marshal for any district in which the Court of Federal Claims is sitting shall, when requested by the chief judge of the Court of Federal Claims, attend any session of the Court of Federal Claims in such district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e7642d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s59/a"},"text":"Sept. 3, 1954, ch. 1263, § 59(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1248"},"text":"68 Stat. 1248","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s910/a"},"text":"Pub. L. 102–572, title IX, § 910(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4519"},"text":"106 Stat. 4519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e7642e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e7642f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e76430-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" inserted “and incidental powers” in section catchline, designated existing provisions as subsec. (a), and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e76431-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e76432-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
