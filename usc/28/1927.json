{"tag":"section","attrib":{"id":"id52c5f8bb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1927"},"text":null,"children":[{"tag":"num","attrib":{"value":"1927"},"text":"§ 1927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counsel’s liability for excessive costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any attorney or other person admitted to conduct cases in any court of the United States or any Territory thereof who so multiplies the proceedings in any case unreasonably and vexatiously may be required by the court to satisfy personally the excess costs, expenses, and attorneys’ fees reasonably incurred because of such conduct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c5f8bc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/957"},"text":"62 Stat. 957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/349/s3"},"text":"Pub. L. 96–349, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1156"},"text":"94 Stat. 1156","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c5f8bd-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c5f8be-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 829 (R.S. § 982).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “personally” was inserted upon authority of ","children":[{"tag":"i","attrib":{},"text":"Motion Picture Patents Co. v. Steiner et al","children":[],"tail":"., 1912, 201 F. 63, 119 C.C.A. 401. Reference to “proctor” was omitted as covered by the revised section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See definition of “court of the United States” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c5f8bf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c5f8c0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/349"},"text":"Pub. L. 96–349","children":[],"tail":" substituted judicial authorization to require attorneys to satisfy excess costs, expenses, and attorneys’ fees reasonably incurred because of multiplication of proceedings for such prior authority to impose liability for increased costs based on multiplication of proceedings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
