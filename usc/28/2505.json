{"tag":"section","attrib":{"id":"id52e51992-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2505"},"text":null,"children":[{"tag":"num","attrib":{"value":"2505"},"text":"§ 2505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial before judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any judge of the United States Court of Federal Claims may sit at any place within the United States to take evidence and enter judgment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52e51993-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/976"},"text":"62 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s54/a"},"text":"Sept. 3, 1954, ch. 1263, § 54(a)","children":[],"tail":", (b), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1246"},"text":"68 Stat. 1246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s139/d"},"text":"Pub. L. 97–164, title I, § 139(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/42"},"text":"96 Stat. 42","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e51994-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52e51995-3a70-11f1-9e0c-dcbb1364dae6"},