{"tag":"section","attrib":{"id":"id52a243f4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1340"},"text":null,"children":[{"tag":"num","attrib":{"value":"1340"},"text":"§ 1340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal revenue; customs duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action arising under any Act of Congress providing for internal revenue, or revenue from imports or tonnage except matters within the jurisdiction of the Court of International Trade.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a243f5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/932"},"text":"62 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tV/s501/21"},"text":"Pub. L. 96–417, title V, § 501(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1742"},"text":"94 Stat. 1742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a243f6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a243f7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(5) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 5, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1092"},"text":"36 Stat. 1092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-03-02/ch488/s1"},"text":"Mar. 2, 1929, ch. 488, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1475"},"text":"45 Stat. 1475","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Customs Court” were substituted for “Court of Customs and Patent Appeals.” ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/5"},"text":"Section 41(5) of title 28","children":[],"tail":", U.S.C., 1940 ed., is based on the Judicial Code of 1911. At that time the only court, other than the district courts, having jurisdiction of customs cases, was the Court of Customs Appeals which became the Court of Customs and Patent Appeals in 1929. The Customs Court was created in 1926 as a court of original jurisdiction over customs cases. (See reviser’s note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “any civil action” were substituted for “all cases” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a243f8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a243f9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" redesignated the Customs Court as the Court of International Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a243fa-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a243fb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", and applicable with respect to civil actions pending on or commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/a"},"text":"section 701(a) of Pub. L. 96–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
