{"tag":"section","attrib":{"id":"id52e9d47e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2633"},"text":null,"children":[{"tag":"num","attrib":{"value":"2633"},"text":"§ 2633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure and fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e9d47f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A filing fee shall be payable to the clerk of the Court of International Trade upon the commencement of a civil action in such court. The amount of the fee shall be prescribed by the rules of the court, but shall be not less than $5 nor more than the filing fee for commencing a civil action in a district court of the United States. The court may fix all other fees to be charged by the clerk of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d480-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court of International Trade shall prescribe rules governing the summons, pleadings, and other papers, for their amendment, service, and filing, for consolidations, severances, suspensions of cases, and for other procedural matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d481-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All summons, pleadings, and other papers filed in the Court of International Trade shall be served on all parties in accordance with rules prescribed by the court. When the United States, its agencies, or its officers are adverse parties, service of the summons shall be made upon the Attorney General and the head of the Government agency whose action is being contested. When injunctive relief is sought, the summons, pleadings, and other papers shall also be served upon the named officials sought to be enjoined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e9d482-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s301"},"text":"Pub. L. 96–417, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1732"},"text":"94 Stat. 1732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e9d483-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e9d484-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52e9d485-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2633, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/980"},"text":"62 Stat. 980","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s114"},"text":"Pub. L. 91–271, title I, § 114","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/279"},"text":"84 Stat. 279","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tX/s1001/b/4/D"},"text":"Pub. L. 96–39, title X, § 1001(b)(4)(D)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/306"},"text":"93 Stat. 306","children":[],"tail":", related to precedence of cases, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2647"},"text":"section 2647 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
