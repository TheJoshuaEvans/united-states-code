{"tag":"section","attrib":{"id":"id52e76433-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2522"},"text":null,"children":[{"tag":"num","attrib":{"value":"2522"},"text":"§ 2522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Review of a decision of the United States Court of Federal Claims shall be obtained by filing a notice of appeal with the clerk of the Court of Federal Claims within the time and in the manner prescribed for appeals to United States courts of appeals from the United States district courts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52e76434-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s139/q/1"},"text":"Pub. L. 97–164, title I, § 139(q)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/44"},"text":"96 Stat. 44","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a"},"text":"Pub. L. 102–572, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e76435-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e76436-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e76437-3a70-11f1-9e0c-dcbb1364dae6"},"te