{"tag":"section","attrib":{"id":"id5272a8fc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s545"},"text":null,"children":[{"tag":"num","attrib":{"value":"545"},"text":"§ 545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5272a8fd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each United States attorney shall reside in the district for which he is appointed, except that these officers of the District of Columbia, the Southern District of New York, and the Eastern District of New York may reside within 20 miles thereof. Each assistant United States attorney shall reside in the district for which he or she is appointed or within 25 miles thereof. The provisions of this subsection shall not apply to any United States attorney or assistant United States attorney appointed for the Northern Mariana Islands who at the same time is serving in the same capacity in another district. Pursuant to an order from the Attorney General or his designee, a United States attorney or an assistant United States attorney may be assigned dual or additional responsibilities that exempt such officer from the residency requirement in this subsection for a specific period as established by the order and subject to renewal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a8fe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may determine the official stations of United States attorneys and assistant United States attorneys within the districts for which they are appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5272a8ff-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/618"},"text":"80 Stat. 618","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/530/s1"},"text":"Pub. L. 95–530, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-27"},"text":"Oct. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2028"},"text":"92 Stat. 2028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/91"},"text":"Pub. L. 96–91","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-25"},"text":"Oct. 25, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/700"},"text":"93 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXXII/s320932"},"text":"Pub. L. 103–322, title XXXII, § 320932","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2135"},"text":"108 Stat. 2135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s501/a"},"text":"Pub. L. 109–177, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/246"},"text":"120 Stat. 246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5272a900-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a901-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id5272a902-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1966 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t28/s505"},"text":"28 U.S.C. 505","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “shall” is substituted for “must”. The word “thereof” is substituted for “of the District”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a903-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Prior section 505.—","children":[],"tail":"Based on title 28, U.S.C., 1940 ed., § 524 ("},{"tag":"ref","attrib":{"href":"/us/act/1874-06-20/ch328/s2"},"text":"June 20, 1874, ch. 328, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/109"},"text":"18 Stat. 109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1896-05-28/ch252"},"text":"May 28, 1896, ch. 252","children":[],"tail":", §§ 8, 12, "},{"tag":"ref","attrib":{"href":"/us/stat/29/181"},"text":"29 Stat. 181","children":[],"tail":", 183; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-14/ch203"},"text":"June 14, 1941, ch. 203","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/55/251"},"text":"55 Stat. 251","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s524"},"text":"section 524 of title 28","children":[],"tail":", U.S.C., 1940 ed., that the United States attorney shall give his personal attention to the duties of his office and declaring the office of United States attorney vacant upon his removal from his district or neglect of duty, were omitted as unnecessary and inconsistent with section 507(b) [now 519] of this title, charging the Attorney General with the duty of supervising the United States attorneys in the performance of their duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision permitting the United States attorney and his assistants to reside within twenty miles of the District of Columbia was added because of the relatively small and congested area of the District, as a result of which few Federal officers are appointed from the District or reside therein. Also the residence requirement of this section has no relation to domicile or voting residence nor does it affect the citizenship or residence status of District of Columbia officeholders in the several States from which appointed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only citizens of Hawaii resident therein at least 3 years preceding appointment may be appointed as United States Attorneys for the district of Hawaii. See section 501 [now 541] of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s524"},"text":"section 524 of title 28","children":[],"tail":", U.S.C., 1940 ed., were incorporated in sections 541 [see 561] and 751 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5272a904-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5272a905-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 545, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/911"},"text":"62 Stat. 911","children":[],"tail":", related to vacancies in the office of the United States Marshal, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", and reenactment in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s565"},"text":"section 565 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"section 4(c) of Pub. L. 89–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5272a906-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" inserted at end “Pursuant to an order from the Attorney General or his designee, a United States attorney or an assistant United States attorney may be assigned dual or additional responsibilities that exempt such officer from the residency requirement in this subsection for a specific period as established by the order and subject to renewal.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" struck out “and assistant United States attorney” after “Each United States attorney” and inserted after first sentence “Each assistant United States attorney shall reside in the district for which he or she is appointed or within 25 miles thereof.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/91"},"text":"Pub. L. 96–91","children":[],"tail":" inserted provisions authorizing the United States attorney and the assistant United States attorneys for the Eastern District of New York to reside outside the district but within 20 miles thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/530"},"text":"Pub. L. 95–530","children":[],"tail":" inserted provision that this subsection not apply to any United States attorney or assistant United States attorney appointed for the Northern Mariana Islands who at the same time is serving in the same capacity in another district."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5272a907-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5272a908-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s501/b"},"text":"Pub. L. 109–177, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/246"},"text":"120 Stat. 246","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/177/tV/s501/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect as of ","children":[{"tag":"date","attrib":{"date":"2005-02-01"},"text":"February 1, 2005","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
