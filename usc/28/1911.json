{"tag":"section","attrib":{"id":"id52c3af10-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1911"},"text":null,"children":[{"tag":"num","attrib":{"value":"1911"},"text":"§ 1911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supreme Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Supreme Court may fix the fees to be charged by its clerk.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The fees of the clerk, cost of serving process, and other necessary disbursements incidental to any case before the court, may be taxed against the litigants as the court directs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c3af11-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/954"},"text":"62 Stat. 954","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3af12-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c3af13-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 330 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s223"},"text":"Mar. 3, 1911, ch. 231, § 223","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1153"},"text":"36 Stat. 1153","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The second paragraph was inserted to give statutory sanction to existing practice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
