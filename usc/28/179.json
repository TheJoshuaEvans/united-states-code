{"tag":"section","attrib":{"id":"id5242e638-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179"},"text":null,"children":[{"tag":"num","attrib":{"value":"179"},"text":"§ 179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel application and insurance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5242e639-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of construing and applying title 5, a judge of the United States Court of Federal Claims shall be deemed to be an “officer” under section 2104(a) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5242e63a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5242e63b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5242e63c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of construing and applying chapter 89 of title 5, a judge of the United States Court of Federal Claims who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5242e63d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is retired under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5242e63e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" at the time of becoming such a retired judge—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5242e63f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was enrolled in a health benefits plan under chapter 89 of title 5, but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5242e640-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not satisfy the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905/b/1"},"text":"section 8905(b)(1) of title 5","children":[],"tail":" (relating to eligibility to continue enrollment as an annuitant),"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be deemed to be an annuitant meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905/b/1"},"text":"section 8905(b)(1) of title 5","children":[],"tail":", in accordance with the succeeding provisions of this paragraph, if the judge gives timely written notification to the chief judge of the court that the judge is willing to be called upon to perform judicial duties under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s178/d"},"text":"section 178(d) of this title","children":[],"tail":" during the period of continued eligibility for enrollment, as described in subparagraph (B)(ii) or (C)(ii) (whichever applies)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5242e641-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5242e642-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to be eligible for continued enrollment under this paragraph, notification under subparagraph (A) shall be made before the first day of the open enrollment period preceding the calendar year referred to in clause (ii)(II); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5242e643-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if such notification is timely made, the retired judge shall be eligible for continued enrollment under this paragraph for the period—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5242e644-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning on the date on which eligibility would otherwise cease, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5242e645-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending on the last day of the calendar year next beginning after the end of the open enrollment period referred to in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5242e646-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of applying this paragraph for the first time in the case of any particular judge—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5242e647-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subparagraph (B)(i) shall be applied by substituting “the expiration of the term of office of the judge” for the matter following “before”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5242e648-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5242e649-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the term of office of such judge expires before the first day of the open enrollment period referred to in subparagraph (B)(i), the period of continued eligibility for enrollment shall be as described in subparagraph (B)(ii); but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5242e64a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the term of office of such judge expires on or after the first day of the open enrollment period referred to in subparagraph (B)(i), the period of continued eligibility shall not end until the last day of the calendar year next beginning after the end of the next full open enrollment period beginning after the date on which the term expires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5242e64b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the event that a retired judge remains enrolled under chapter 89 of title 5 for a period of 5 consecutive years by virtue of paragraph (1) (taking into account only periods of coverage as an active judge immediately before retirement and as a retired judge pursuant to paragraph (1)), then, effective as of the day following the last day of that 5-year period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5242e64c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 89 of title 5 shall be applied as if such judge had satisfied the requirements of section 8905(b)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “of title 5”."}],"tail":" on the last day of such period; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5242e64d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of paragraph (1) shall cease to apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5242e64e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term “open enrollment period” refers to a period described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905/g/1"},"text":"section 8905(g)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5242e64f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s179/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of construing and applying chapter 87 of title 5, including any adjustment of insurance rates by regulation or otherwise, a judge of the United States Court of Federal Claims in regular active service or who is retired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of this title","children":[],"tail":" shall be deemed to be a judge of the United States described under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8701/a/5"},"text":"section 8701(a)(5) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5242e650-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518/tIII/s309/a"},"text":"Pub. L. 106–518, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2419"},"text":"114 Stat. 2419","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
