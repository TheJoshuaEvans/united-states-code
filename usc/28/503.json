{"tag":"section","attrib":{"id":"id525d24a8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall appoint, by and with the advice and consent of the Senate, an Attorney General of the United States. The Attorney General is the head of the Department of Justice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id525d24a9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/612"},"text":"80 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525d24aa-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id525d24ab-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id525d24ac-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s291"},"text":"5 U.S.C. 291","children":[],"tail":" (last 10 words)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 346 (last 10 words).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “The President shall appoint, by and with the advice and consent of the Senate” have been added to conform the section with the Constitution. See article II, section 2, clause 2.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525d24ad-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id525d24ae-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 503, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":", related to appointment of attorneys to assist United States attorneys, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", and reenactment in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s543"},"text":"section 543 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"section 4(c) of Pub. L. 89–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id525d24af-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id525d24b0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Actions Challenging Appointment of Attorney General on Grounds of Violation of Constitutional Provisions Governing Compensation and Other Emoluments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/178/s2"},"text":"Pub. L. 93–178, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-10"},"text":"Dec. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/697"},"text":"87 Stat. 697","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/178/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person aggrieved by an action of the Attorney General may bring a civil action in the appropriate district court to contest the constitutionality of the appointment and continuance in office of the Attorney General on the ground that such appointment and continuance in office is in violation of article I, section 6, clause 2, of the Constitution. The United States district courts shall have exclusive jurisdiction, without regard to the sum or value of the matter in controversy, to determine the validity of such appointment and continuance in office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action brought under this section shall be heard and determined by a panel of three judges in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2284"},"text":"section 2284 of title 28","children":[],"tail":", United States Code. Any appeal from the action of a court convened pursuant to such section shall lie to the Supreme Court."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any judge designated to hear any action brought under this section shall cause such action to be in every way expedited.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
