{"tag":"section","attrib":{"id":"id52407579-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159"},"text":null,"children":[{"tag":"num","attrib":{"value":"159"},"text":"§ 159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bankruptcy statistics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5240757a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clerk of the district court, or the clerk of the bankruptcy court if one is certified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s156/b"},"text":"section 156(b) of this title","children":[],"tail":", shall collect statistics regarding debtors who are individuals with primarily consumer debts seeking relief under chapters 7, 11, and 13 of title 11. Those statistics shall be in a standardized format prescribed by the Director of the Administrative Office of the United States Courts (referred to in this section as the “Director”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5240757b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5240757c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile the statistics referred to in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5240757d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the statistics available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5240757e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2008-07-01"},"text":"July 1, 2008","children":[],"tail":", and annually thereafter, prepare, and submit to Congress a report concerning the information collected under subsection (a) that contains an analysis of the information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5240757f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The compilation required under subsection (b) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52407580-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be itemized, by chapter, with respect to title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52407581-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be presented in the aggregate and for each district; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52407582-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include information concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52407583-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total assets and total liabilities of the debtors described in subsection (a), and in each category of assets and liabilities, as reported in the schedules prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2075"},"text":"section 2075 of this title","children":[],"tail":" and filed by debtors;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52407584-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current monthly income, average income, and average expenses of debtors as reported on the schedules and statements that each such debtor files under sections 521 and 1322 of title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52407585-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of debt discharged in cases filed during the reporting period, determined as the difference between the total amount of debt and obligations of a debtor reported on the schedules and the amount of such debt reported in categories which are predominantly nondischargeable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52407586-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average period of time between the date of the filing of the petition and the closing of the case for cases closed during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52407587-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for cases closed during the reporting period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52407588-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which a reaffirmation agreement was filed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52407589-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5240758a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of reaffirmation agreements filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5240758b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of those cases in which a reaffirmation agreement was filed, the number of cases in which the debtor was not represented by an attorney; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id5240758c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/E/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of those cases in which a reaffirmation agreement was filed, the number of cases in which the reaffirmation agreement was approved by the court;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5240758d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to cases filed under chapter 13 of title 11, for the reporting period—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5240758e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id5240758f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which a final order was entered determining the value of property securing a claim in an amount less than the amount of the claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id52407590-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of final orders entered determining the value of property securing a claim;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52407591-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases dismissed, the number of cases dismissed for failure to make payments under the plan, the number of cases refiled after dismissal, and the number of cases in which the plan was completed, separately itemized with respect to the number of modifications made before completion of the plan, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52407592-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which the debtor filed another case during the 6-year period preceding the filing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52407593-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which creditors were fined for misconduct and any amount of punitive damages awarded by the court for creditor misconduct; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52407594-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s159/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases in which sanctions under rule 9011 of the Federal Rules of Bankruptcy Procedure were imposed against the debtor’s attorney or damages awarded under such Rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52407595-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVI/s601/a"},"text":"Pub. L. 109–8, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/119"},"text":"119 Stat. 119","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/327/s2/c/2"},"text":"Pub. L. 111–327, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3563"},"text":"124 Stat. 3563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52407596-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52407597-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52407598-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Bankruptcy Procedure, referred to in subsec. (c)(3)(H), are set out in the Appendix to Title 11, Bankruptcy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52407599-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(3)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/327"},"text":"Pub. L. 111–327","children":[],"tail":" inserted “the” after “against”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5240759a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5240759b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVI/s601/c"},"text":"Pub. L. 109–8, title VI, § 601(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/120"},"text":"119 Stat. 120","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/8/tVI/s601/c"},"text":"“The amendments made by this section [enacting this section] shall take effect 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
