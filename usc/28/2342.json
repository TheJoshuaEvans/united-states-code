{"tag":"section","attrib":{"id":"id52dded97-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342"},"text":null,"children":[{"tag":"num","attrib":{"value":"2342"},"text":"§ 2342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of court of appeals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The court of appeals (other than the United States Court of Appeals for the Federal Circuit) has exclusive jurisdiction to enjoin, set aside, suspend (in whole or in part), or to determine the validity of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52dded98-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all final orders of the Federal Communication Commission made reviewable by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s402/a"},"text":"section 402(a) of title 47","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52dded99-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all final orders of the Secretary of Agriculture made under chapters 9 and 20A of title 7, except orders issued under sections 210(e), 217a, and 499g(a) of title 7;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52dded9a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all rules, regulations, or final orders of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52dded9b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation issued pursuant to section 50501, 50502, 56101–56104, or 57109 of title 46 or pursuant to part B or C of subtitle IV, subchapter III of chapter 311, chapter 313, or chapter 315 of title 49; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52dded9c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Maritime Commission issued pursuant to section 305,","children":[{"tag":"ref","attrib":{"idref":"fn002099"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 41304, 41308, or 41309 or chapter 421 or 441 of title 46;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52dded9d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all final orders of the Atomic Energy Commission made reviewable by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2239"},"text":"section 2239 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52dded9e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2342/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all rules, regulations, or final orders of the Surface Transportation Board made reviewable by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2321"},"text":"section 2321 of this title","children":[],"tai