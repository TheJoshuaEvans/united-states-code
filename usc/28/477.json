{"tag":"section","attrib":{"id":"id525ab45b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s477"},"text":null,"children":[{"tag":"num","attrib":{"value":"477"},"text":"§ 477.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Model civil justice expense and delay reduction plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525ab45c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s477/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525ab45d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s477/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Based on the plans developed and implemented by the United States district courts designated as Early Implementation District Courts pursuant to section 103(c) of the Civil Justice Reform Act of 1990, the Judicial Conference of the United States may develop one or more model civil justice expense and delay reduction plans. Any such model plan shall be accompanied by a report explaining the manner in which the plan complies with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s473"},"text":"section 473 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525ab45e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s477/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Federal Judicial Center and the Director of the Administrative Office of the United States Courts may make recommendations to the Judicial Conference regarding the development of any model civil justice expense and delay reduction plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab45f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s477/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Administrative Office of the United States Courts shall transmit to the United States district courts and to the Committees on the Judiciary of the Senate and the House of Representatives copies of any model plan and accompanying report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525ab460-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tI/s103/a"},"text":"Pub. L. 101–650, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5094"},"text":"104 Stat. 5094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525ab461-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525ab462-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id525ab463-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 103(c) of the Civil Justice Reform Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650"},"text":"Pub. L. 101–650","children":[],"tail":"], referred to in subsec. (a)(1), is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s471"},"text":"section 471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
