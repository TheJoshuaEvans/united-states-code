{"tag":"section","attrib":{"id":"id525ab445-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474"},"text":null,"children":[{"tag":"num","attrib":{"value":"474"},"text":"§ 474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of district court action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525ab446-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525ab447-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The chief judge of each district court in a circuit and the chief judge of the circuit shall, as a committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id525ab448-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each plan and report submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s472/d"},"text":"section 472(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id525ab449-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such suggestions for additional actions or modified actions of that district court as the committee considers appropriate for reducing cost and delay in civil litigation in the district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525ab44a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge of a circuit may designate another judge of the court of appeals of that circuit, and the chief judge of a district court may designate another judge of such court, to perform that chief judge’s responsibilities under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab44b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Judicial Conference of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525ab44c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review each plan and report submitted by a district court pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s472/d"},"text":"section 472(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525ab44d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s474/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request the district court to take additional action if the Judicial Conference determines that such court has not adequately responded to the conditions relevant to the civil and criminal dockets of the court or to the recommendations of the district court’s advisory group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525ab44e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tI/s103/a"},"text":"Pub. L. 101–650, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5093"},"text":"104 Stat. 5093","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/198/s2/2"},"text":"Pub. L. 102–198, § 2(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1623"},"text":"105 Stat. 1623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525ab44f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525ab450-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id525ab451-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s2/2/A"},"text":"Pub. L. 102–198, § 2(2)(A)","children":[],"tail":", substituted “chief judge” for “chief judges” and struck out “court of appeals for such” after “judge of the” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s2/2/B"},"text":"Pub. L. 102–198, § 2(2)(B)","children":[],"tail":", substituted “circuit may designate another judge of the court of appeals of that circuit,” for “court of appeals” and “court, to perform that” for “court to perform the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
