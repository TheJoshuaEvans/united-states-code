{"tag":"section","attrib":{"id":"id5293ebeb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s756"},"text":null,"children":[{"tag":"num","attrib":{"value":"756"},"text":"§ 756.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to appoint","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a majority of the district judges of any district court cannot agree upon the appointment of any officer of such court, the chief judge shall make such appointment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5293ebec-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/923"},"text":"62 Stat. 923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5293ebed-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5293ebee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 375 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s260"},"text":"Mar. 3, 1911, ch. 231, § 260","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1161"},"text":"36 Stat. 1161","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1919-02-25"},"text":"Feb. 25, 1919","children":[],"tail":", ch.29, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/40/1157"},"text":"40 Stat. 1157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-03-01/ch419"},"text":"Mar. 1, 1929, ch. 419","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1422"},"text":"45 Stat. 1422","children":[],"tail":"; "},