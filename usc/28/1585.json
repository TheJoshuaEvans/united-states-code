{"tag":"section","attrib":{"id":"id52b09bd5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1585"},"text":null,"children":[{"tag":"num","attrib":{"value":"1585"},"text":"§ 1585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers in law and equity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Court of International Trade shall possess all the powers in law and equity of, or as conferred by statute upon, a district court of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b09bd6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tII/s201"},"text":"Pub. L. 96–417, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1730"},"text":"94 Stat. 1730","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
