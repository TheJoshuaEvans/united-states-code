{"tag":"section","attrib":{"id":"id52ec4521-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2644"},"text":null,"children":[{"tag":"num","attrib":{"value":"2644"},"text":"§ 2644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If, in a civil action in the Court of International Trade under section 515 of the Tariff Act of 1930, the plaintiff obtains monetary relief by a judgment or under a stipulation agreement, interest shall be allowed at an annual rate established under section 6621 of the Internal Revenue Code of 1986. Such interest shall be calculated from the date of the filing of the summons in such action to the date of the refund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ec4522-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s301"},"text":"Pub. L. 96–417, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1738"},"text":"94 Stat. 1738","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ec4523-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ec4524-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52ec4525-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 515 of the Tariff Act of 1930, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1515"},"text":"section 1515 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6621 of the Internal Revenue Code of 1986, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6621"},"text":"section 6621 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ec4526-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ec4527-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ec4528-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to civil actions commenced on or after ","children":[{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/b