ldren":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t28/s508"},"text":"28 U.S.C. 508","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “sections 5315–5317 of title 5” are substituted for “subsection (f) and (g) of section 303 of the Federal Executive Salary Act of 1964” to reflect the codification of those subsections in title 5. The words “GS–18 of the General Schedule set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"” are substituted for “grade 18 of the General Schedule of the Classification Act of 1949, as amended”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a92c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Prior section 508.—","children":[],"tail":"Based on "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s312"},"text":"section 312 of title 5","children":[],"tail":", U.S.C., 1940 ed., Executive Departments and Government Officers and Employees, and title 28, U.S.C., 1940 ed., §§ 579 and 580 (R.S. § 363; "},{"tag":"ref","attrib":{"href":"/us/act/1896-05-28/ch252"},"text":"May 28, 1896, ch. 252","children":[],"tail":", §§ 8, 24, "},{"tag":"ref","attrib":{"href":"/us/stat/29/181"},"text":"29 Stat. 181","children":[],"tail":", 186; "},{"tag":"ref","attrib":{"href":"/us/act/1903-03-03/ch1007/s1"},"text":"Mar. 3, 1903, ch. 1007, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/1141"},"text":"32 Stat. 1141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2918/s1"},"text":"Mar. 4, 1907, ch. 2918, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1360"},"text":"34 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1908-05-27/ch200/s1"},"text":"May 27, 1908, ch. 200, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/375"},"text":"35 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-07-19/ch24/s1"},"text":"July 19, 1919, ch. 24, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/209"},"text":"41 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-06-01/ch204"},"text":"June 1, 1922, ch. 204","children":[],"tail":", title II (part), "},{"tag":"ref","attrib":{"href":"/us/stat/42/616"},"text":"42 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-01-03/ch21"},"text":"Jan. 3, 1923, ch. 21","children":[],"tail":", title II, "},{"tag":"ref","attrib":{"href":"/us/stat/42/1083"},"text":"42 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch295"},"text":"Mar. 4, 1923, ch. 295","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1560"},"text":"42 Stat. 1560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-05-28/ch204"},"text":"May 28, 1924, ch. 204","children":[],"tail":", title II (part), "},{"tag":"ref","attrib":{"href":"/us/stat/43/220"},"text":"43 Stat. 220","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates part of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s312"},"text":"section 312 of title 5","children":[],"tail":", U.S.C., 1940 ed., and part of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s579"},"text":"section 579 of title 28","children":[],"tail":", U.S.C., 1940 ed., with "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s580"},"text":"section 580 of title 28","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 579 and 580 of title 28, U.S.C., 1940 ed., fixed specific salaries for the United States attorneys and assistants, while ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s312"},"text":"section 312 of title 5","children":[],"tail":", U.S.C., 1940 ed., provided for a contractual arrangement for compensation of special attorneys."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"According to a Department of Justice interpretation, provisions for specific salaries were superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s678"},"text":"section 678 of title 5","children":[],"tail":", which provides for adjustment of compensation by heads of departments. Hence, this section leaves the amount of compensation to the Attorney General."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s578b"},"text":"Section 578b of title 28","children":[],"tail":", U.S.C., 1940 ed., providing that United States attorneys shall be paid for their services, was omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s578c"},"text":"Section 578c of title 28","children":[],"tail":", U.S.C., 1940 ed., providing that United States attorneys shall not receive fees in addition to their salaries, was omitted as obsolete, in view of this section and current practice."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s312"},"text":"section 312 of title 5","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 503 [now 543] and 507 [now 509 and 547] of this title, and other provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s579"},"text":"section 579 of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in section 552 [see Prior Provisions note for that section] of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5272a92d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5272a92e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 548, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/912"},"text":"62 Stat. 912","children":[],"tail":", related to administration of oaths by marshals, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5272a92f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" amended section generally, substituting “rate of basic compensation provided for Executive Level IV of the Executive Schedule set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":", United States Code” for “highest rate of GS–18 of the General Schedule set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5272a930-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5272a931-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Salary Increases","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1969—Increase in the rates of pay of United States Attorneys and Assistant United States Attorneys whose annual salaries are fixed pursuant to this section, effective on the first day of the first pay period which begins on or after ","children":[{"tag":"date","attrib":{"date":"1969-12-27"},"text":"Dec. 27, 1969","children":[],"tail":", by amounts equal, as nearly as may be practicable, to the increases provided pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/91/231/s2"},"text":"section 2 of Pub. L. 91–231","children":[],"tail":", which raised corresponding rates by 6 percent, see "},{"tag":"ref","attrib":{"href":"/us/pl/91/231"},"text":"Pub. L. 91–231","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s211/a"},"text":"Pub. L. 90–206, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/633"},"text":"81 Stat. 633","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/206/tII/s211/a"},"text":"“The rates of basic pay of United States attorneys and assistant United States attorneys whose annual salaries are fixed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s548"},"text":"section 548 of title 28","children":[],"tail":", United States Code shall be increased, effective on the effective date of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s202"},"text":"section 202 of this title","children":[],"tail":" [see Effective Date of 1967 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":"] by amounts equal, as nearly as may be practicable, to the increases provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s202/a"},"text":"section 202(a) of this title","children":[],"tail":" [see "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332/a"},"text":"section 5332(a) of Title 5","children":[],"tail":"] for corresponding rates of basic pay.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/s211/a"},"text":"Section 211(a) of Pub. L. 90–206","children":[],"tail":" effective as of the beginning of the first pay period which begins on or after "},{"tag":"date","attrib":{"date":"1967-10-01"},"text":"Oct. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s220/a/2"},"text":"section 220(a)(2) of Pub. L. 90–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/504/tI/s108/a"},"text":"Pub. L. 89–504, title I, § 108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-18"},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/293"},"text":"80 Stat. 293","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/504/tI/s108/a"},"text":"“The rates of basic compensation of assistant United States attorneys whose basic salaries are fixed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s508"},"text":"section 508 of title 28","children":[],"tail":", United States Code [now this section] shall be increased, effective on the effective date of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s102"},"text":"section 102 of this title","children":[],"tail":" [first day of the first pay period beginning on or after "},{"tag":"date","attrib":{"date":"1966-07-01"},"text":"July 1, 1966","children":[],"tail":"], by amounts equal, as nearly as may be practicable, to the increases provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s102/a"},"text":"section 102(a) of this title","children":[],"tail":" [see "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332/a"},"text":"section 5332(a) of Title 5","children":[],"tail":"], for corresponding rates of compensation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision effective ","children":[{"tag":"date","attrib":{"date":"1966-07-18"},"text":"July 18, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/504/s109/1"},"text":"section 109(1) of Pub. L. 89–504","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/301/s15/a"},"text":"Pub. L. 89–301, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-29"},"text":"Oct. 29, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1122"},"text":"79 Stat. 1122","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/301/s15/a"},"text":"“The rates of basic compensation of assistant United States attorneys whose basic salaries are fixed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s508"},"text":"section 508 of title 28","children":[],"tail":", United States Code, [now this section], shall be increased by 3.6 per centum effective on the first day of the first pay period which begins on or after "},{"tag":"date","attrib":{"date":"1965-10-01"},"text":"October 1, 1965","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/793/s1003/b"},"text":"Pub. L. 87–793, § 1003(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/866"},"text":"76 Stat. 866","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/793/s1003/b"},"text":"“The rates of basic compensation of assistant United States attorneys whose basic salaries are fixed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s508"},"text":"section 508 of title 28","children":[],"tail":", United States Code, [now this section], shall be increased by 7½ per centum effective on the first day of the first pay period which begins on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5272a932-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compensation of Incumbent United States Attorneys and Assistant United States Attorneys","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426/s306/a/2"},"text":"Pub. L. 88–426, § 306(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-14"},"text":"Aug. 14, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/428"},"text":"78 Stat. 428","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/88/631/s3/c"},"text":"Pub. L. 88–631, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-06"},"text":"Oct. 6, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1008"},"text":"78 Stat. 1008","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/88/631/s3/c"},"text":"“Subject to section 303(f) and (g) of this Act [see sections 5315 to 5317 of Title 5, Government Organization and Employees], each incumbent United States attorney and assistant United States attorney shall be paid compensation at a rate equal to that of attorneys of comparable responsibility and professional qualifications, as determined by the Attorney General, whose compensation is prescribed in the General Schedule of the Classification Act of 1949, as amended [now covered by chapter 51 and subchapter III of chapter 53 of Title 5].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5272a933-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alaska, Canal Zone and Virgin Islands","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-03-02/ch9/s2/b"},"text":"Act Mar. 2, 1955, ch. 9, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/10"},"text":"69 Stat. 10","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1955-03-02/ch9/s2/b"},"text":"“The salaries of United States attorneys and assistant United States attorneys for the districts of Alaska, Canal Zone, and the Virgin Islands are subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s508"},"text":"section 508 of title 28","children":[],"tail":", United States Code [now this section.]”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5272a934-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Salary Limitations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-05/ch328"},"text":"Aug. 5, 1953, ch. 328","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/67/375"},"text":"67 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-07-02/ch456"},"text":"July 2, 1954, ch. 456","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/68/421"},"text":"68 Stat. 421","children":[],"tail":", which prescribed salary limitations, were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/657"},"text":"80 Stat. 657","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
