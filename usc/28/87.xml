<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id5228a6ee-3a70-11f1-9e0c-dcbb1364dae6" identifier="/us/usc/t28/s87"><num value="87">§ 87.</num><heading> Delaware</heading><content>
<p style="-uslm-lc:I11" class="indent0">Delaware constitutes one judicial district.</p>
<p style="-uslm-lc:I56" class="indent4 firstIndent-2">Court shall be held at Wilmington.</p>
</content><sourceCredit id="id5228a6ef-3a70-11f1-9e0c-dcbb1364dae6">(<ref href="/us/act/1948-06-25/ch646">June 25, 1948, ch. 646</ref>, <ref href="/us/stat/62/875">62 Stat. 875</ref>.)</sourceCredit>
