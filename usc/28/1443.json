{"tag":"section","attrib":{"id":"id52a97010-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1443"},"text":null,"children":[{"tag":"num","attrib":{"value":"1443"},"text":"§ 1443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil rights cases","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any of the following civil actions or criminal prosecutions, commenced in a State court may be removed by the defendant to the district court of the United States for the district and division embracing the place wherein it is pending:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a97011-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1443/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Against any person who is denied or cannot enforce in the courts of such State a right under any law providing for the equal civil rights of citizens of the United States, or of all persons within the jurisdiction thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a97012-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1443/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any act under color of authority derived from any law providing for equal rights, or for refusing to do any act on the ground that it would be inconsistent with such law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a97013-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/938"},"text":"62 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a97014-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a97015-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 74 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s31"},"text":"Mar. 3, 1911, ch. 231, § 31","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1096"},"text":"36 Stat. 1096","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s74"},"text":"section 74 of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 1446 and 1447 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or in the part of the State where such suit or prosecution is pending” after “courts of such States,” were omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
