{"tag":"section","attrib":{"id":"id52c86a8b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2041"},"text":null,"children":[{"tag":"num","attrib":{"value":"2041"},"text":"§ 2041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of moneys in pending or adjudicated cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All moneys paid into any court of the United States, or received by the officers thereof, in any case pending or adjudicated in such court, shall be forthwith deposited with the Treasurer of the United States or a designated depositary, in the name and to the credit of such court.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section shall not prevent the delivery of any such money to the rightful owners upon security, according to agreement of parties, under the direction of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52cada8c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/960"},"text":"62 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/g/4/C"},"text":"Pub. L. 97–258, § 2(g)(4)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1061"},"text":"96 Stat. 1061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cada8d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cada8e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 851 (R.S. § 995; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-05-29/ch214/s1"},"text":"May 29, 1920, ch. 214, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/654"},"text":"41 Stat. 654","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52cada8f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52cada90-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “Deposit of moneys in pending or adjudicated cases” for “Deposit” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52cada91-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52cada92-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Registry Administration Account","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/459/tIV/s400"},"text":"Pub. L. 100–459, title IV, § 400","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2211"},"text":"102 Stat. 2211","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/459/tIV/s400"},"text":"“That any funds hereafter collected by the Judiciary as a charge for services rendered in administering accounts kept in a court’s registry shall be deposited into a separate account entitled ‘Registry Administration Account’ in the Treasury of the United States. Such funds shall remain available to the Judiciary until expended to reimburse any appropriation for the amount paid out of such appropriation for expenses of the Courts of Appeals, District Courts and Other Judicial Services and the Administrative Office of the United States Courts”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
