{"tag":"section","attrib":{"id":"id5291a210-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655"},"text":null,"children":[{"tag":"num","attrib":{"value":"655"},"text":"§ 655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitrators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a211-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers of Arbitrators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An arbitrator to whom an action is referred under section 654 shall have the power, within the judicial district of the district court which referred the action to arbitration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a212-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct arbitration hearings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a213-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer oaths and affirmations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a214-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a215-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each district court that authorizes arbitration shall establish standards for the certification of arbitrators and shall certify arbitrators to perform services in accordance with such standards and this chapter. The standards shall include provisions requiring that any arbitrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a216-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take the oath or affirmation described in section 453; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a217-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to the disqualification rules under section 455.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a218-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s655/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immunity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All individuals serving as arbitrators in an alternative dispute resolution program under this chapter are performing quasi-judicial functions and are entitled to the immunities and protections that the law accords to persons serving in such capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a219-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIX/s901/a"},"text":"Pub. L. 100–702, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4661"},"text":"102 Stat. 4661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/315/s7"},"text":"Pub. L. 105–315, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2996"},"text":"112 Stat. 2996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a21a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a21b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a21c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/315"},"text":"Pub. L. 105–315","children":[],"tail":" amended section generally, substituting provisions relating to arbitrators for provisions relating to trial de novo."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
