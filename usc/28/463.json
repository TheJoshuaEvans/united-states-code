{"tag":"section","attrib":{"id":"id525ab3fe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s463"},"text":null,"children":[{"tag":"num","attrib":{"value":"463"},"text":"§ 463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a Chief Justice, justice, judge, officer, or employee of any United States court is sued in his official capacity, or is otherwise required to defend acts taken or omissions made in his official capacity, and the services of an attorney for the Government are not reasonably available pursuant to chapter 31 of this title, the Director of the Administrative Office of the United States Courts may pay the costs of his defense. The Director shall prescribe regulations for such payments subject to the approval of the Judicial Conference of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id525ab3ff-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s116/a"},"text":"Pub. L. 97–164, title I, § 116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/32"},"text":"96 Stat. 32","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525ab400-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id525ab401-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id525ab402-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as an Effective Date of 1982 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
