{"tag":"section","attrib":{"id":"id52965da7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s961"},"text":null,"children":[{"tag":"num","attrib":{"value":"961"},"text":"§ 961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office expenses of clerks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each clerk of court shall be allowed his necessary office expenses when authorized by the Director of the Administrative Office of the United States Courts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52965da8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/927"},"text":"62 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52965da9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52965daa-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 544, 563 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1891-03-03/ch517/s2"},"text":"Mar. 3, 1891, ch. 517, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/826"},"text":"26 Stat. 826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-02-26/ch49/s5"},"text":"Feb. 26, 1919, ch. 49, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1182"},"text":"40 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-03-04/ch161/s1"},"text":"Mar. 4, 1921, ch. 161, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1412"},"text":"41 Stat. 1412","children":