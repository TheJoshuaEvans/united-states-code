{"tag":"section","attrib":{"id":"id52e763fb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2516"},"text":null,"children":[{"tag":"num","attrib":{"value":"2516"},"text":"§ 2516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest on claims and judgments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e763fc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on a claim against the United States shall be allowed in a judgment of the United States Court of Federal Claims only under a contract or Act of Congress expressly providing for payment thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e763fd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest on a judgment against the United States affirmed by the Supreme Court after review on petition of the United States is paid at a rate equal to the weekly average 1-year constant maturity Treasury yield, as published by the Board of Governors of the Federal Reserve System, for the calendar week preceding the date of the judgment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e763fe-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/978"},"text":"62 Stat. 978","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s57"},"text":"Sept. 3, 1954, ch. 1263, § 57","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1248"},"text":"68 Stat. 1248","children":[],"tail":"; "},{"tag":"ref",