{"tag":"section","attrib":{"id":"id524c82c5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s359"},"text":null,"children":[{"tag":"num","attrib":{"value":"359"},"text":"§ 359.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524c82c6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s359/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on Individuals Who Are Subject of Investigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No judge whose conduct is the subject of an investigation under this chapter shall serve upon a special committee appointed under section 353, upon a judicial council, upon the Judicial Conference, or upon the standing committee established under section 331, until all proceedings under this chapter relating to such investigation have been finally terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524c82c7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s359/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amicus Curiae","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person shall be granted the right to intervene or to appear as amicus curiae in any proceeding before a judicial council or the Judicial Conference under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524c82c8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11042/a"},"text":"Pub. L. 107–273, div. C, title I, § 11042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1853"},"text":"116 Stat. 1853","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
