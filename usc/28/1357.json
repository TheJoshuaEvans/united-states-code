{"tag":"section","attrib":{"id":"id52a4b486-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1357"},"text":null,"children":[{"tag":"num","attrib":{"value":"1357"},"text":"§ 1357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injuries under Federal laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action commenced by any person to recover damages for any injury to his person or property on account of any act done by him, under any Act of Congress, for the protection or collection of any of the revenues, or to enforce the right of citizens of the United States to vote in any State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a4b487-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/934"},"text":"62 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b488-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a4b489-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(11) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 11, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1092"},"text":"36 Stat. 1092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “any civil action” were substituted for “all suits,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
