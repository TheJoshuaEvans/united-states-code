{"tag":"section","attrib":{"id":"id52c86a17-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1932"},"text":null,"children":[{"tag":"num","attrib":{"value":"1932"},"text":"§ 1932.","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 1932 is set out preceding this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of earned release credit","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any civil action brought by an adult convicted of a crime and confined in a Federal correctional facility, the court may order the revocation of such earned good time credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3624/b"},"text":"section 3624(b) of title 18","children":[],"tail":", United States Code, that has not yet vested, if, on its own motion or the motion of any party, the court finds that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52c86a18-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1932/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim was filed for a malicious purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c86a19-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1932/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claim was filed solely to harass the party against which it was filed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c86a1a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1932/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claimant testifies falsely or otherwise knowingly presents false evidence or information to the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c86a1b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title VIII, § 809(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–76; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
