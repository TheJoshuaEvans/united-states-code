{"tag":"section","attrib":{"id":"id52f5bb8c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f5bb8d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “amateur sports organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f5bb8e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person or governmental entity that sponsors, organizes, schedules, or conducts a competitive game in which one or more amateur athletes participate, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f5bb8f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a league or association of persons or governmental entities described in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb90-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “governmental entity” means a State, a political subdivision of a State, or an entity or organization, including an entity or organization described in section 4(5) of the Indian Gaming Regulatory Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/5"},"text":"25 U.S.C. 2703(5)","children":[],"tail":"), that has governmental authority within the territorial boundaries of the United States, including on lands described in section 4(4) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/4"},"text":"25 U.S.C. 2703(4)","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb91-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “professional sports organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f5bb92-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person or governmental entity that sponsors, organizes, schedules, or conducts a competitive game in which one or more professional athletes participate, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f5bb93-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a league or association of persons or governmental entities described in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb94-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f5bb95-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, Palau, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f5bb96-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/559/s2/a"},"text":"Pub. L. 102–559, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4227"},"text":"106 Stat. 4227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f5bb97-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52f5bb98-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"id52f5bb99-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of certain provisions of this chapter, see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f5bb9a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f5bb9b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/559/s3"},"text":"Pub. L. 102–559, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4229"},"text":"106 Stat. 4229","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/559/s3"},"text":"“This Act [enacting this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1"},"text":"section 1 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
