{"tag":"section","attrib":{"id":"id52396fd6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s143"},"text":null,"children":[{"tag":"num","attrib":{"value":"143"},"text":"§ 143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacant judgeship as affecting proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the office of a district judge becomes vacant, all pending process, pleadings and proceedings shall, when necessary, be continued by the clerk until a judge is appointed or designated to hold such court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52396fd7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/898"},"text":"62 Stat. 898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52396fd8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52396fd9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 26 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s22"},"text":"Mar. 3, 1911, ch. 231, § 22","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1090"},"text":"36 Stat. 1090","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last clause of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s26"},"text":"section 26 of title 28","children":[],"tail":", U.S.C., 1940, ed., prescribing the powers of a designated judge was omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s296"},"text":"section 296 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
