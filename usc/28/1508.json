{"tag":"section","attrib":{"id":"id52ae2b65-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1508"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508"},"text":"§ 1508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction for certain partnership proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Court of Federal Claims shall have jurisdiction to hear and to render judgment upon any petition under section 6226 or 6228(a) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ae2b66-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248/tIV/s402/c/18/A"},"text":"Pub. L. 97–248, title IV, § 402(c)(18)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/669"},"text":"96 Stat. 669","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/2"},"text":"Pub. L. 102–572, title IX, § 902(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ae2b67-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ae2b68-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52ae2b69-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 6226 and 6228(a) of the Internal Revenue Code of 1986, referred to in text, are classified to sections 6226 and 6228(a) of Title 26, Internal Revenue Code. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6226"},"text":"Section 6226 of Title 26","children":[],"tail":" was repealed and reenacted by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/a"},"text":"Pub. L. 114–74, title XI, § 1101(a)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":", 630, and as so reenacted no longer relates to judicial review, see "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6234"},"text":"section 6234 of Title 26","children":[],"tail":". Section 6228 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/74/tXI/s1101/a"},"text":"Pub. L. 114–74, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-02"},"text":"Nov. 2, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/625"},"text":"129 Stat. 625","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ae2b6a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “Court of Federal Claims” for “Claims Court”."}],"tail":"\n"},{"t