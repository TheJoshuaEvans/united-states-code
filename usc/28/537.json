{"tag":"section","attrib":{"id":"id52703741-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s537"},"text":null,"children":[{"tag":"num","attrib":{"value":"537"},"text":"§ 537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of unforeseen emergencies of a confidential character","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations for the Federal Bureau of Investigation are available for expenses of unforeseen emergencies of a confidential character, when so specified in the appropriation concerned, to be spent under the direction of the Attorney General. The Attorney General shall certify the amount spent that he considers advisable not to specify, and his certification is a sufficient voucher for the amount therein expressed to have been spent.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52703742-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/617"},"text":"80 Stat. 617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52703743-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52703744-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id52703745-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s341c"},"text":"5 U.S.C. 341c","children":[],"tail":" (less last sentence)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-07-28/ch503/s5"},"text":"July 28, 1950, ch. 503, § 5","children":[],"tail":" (less last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/380"},"text":"64 Stat. 380","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is revised and reorganized for clarity. The words “now or hereafter provided” are omitted as unnecessary. The words “for expenses of membership in the International Commission of Criminal Police and” are omitted as obsolete. The Act of ","children":[{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/768"},"text":"Pub. L. 85–768","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/921"},"text":"72 Stat. 921","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263a"},"text":"22 U.S.C. 263a","children":[],"tail":") authorizes the Attorney General to accept and maintain, on behalf of the United States, membership in the International Criminal Police Organization, and to designate any departments and agencies which may participate in the United States representation with that organization; and authorizes each participating department and agency to pay its pro rata share, as determined by the Attorney General, of the expenses of such membership. The word “spent” is substituted for “expended”. The words “certify the amount spent that he considers” are substituted for “make a certificate of the amount of any such expenditure as he may think it”. The words “his certification is a sufficient voucher” are substituted for “and every such certificate shall be deemed a sufficient voucher”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
