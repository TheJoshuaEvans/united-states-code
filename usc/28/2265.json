{"tag":"section","attrib":{"id":"id52db7cf3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265"},"text":null,"children":[{"tag":"num","attrib":{"value":"2265"},"text":"§ 2265.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification and judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52db7cf4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52db7cf5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If requested by an appropriate State official, the Attorney General of the United States shall determine—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52db7cf6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the State has established a mechanism for the appointment, compensation, and payment of reasonable litigation expenses of competent counsel in State postconviction proceedings brought by indigent prisoners who have been sentenced to death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52db7cf7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the mechanism described in subparagraph (A) was established; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52db7cf8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the State provides standards of competency for the appointment of counsel in proceedings described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7cf9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The date the mechanism described in paragraph (1)(A) was established shall be the effective date of the certification under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7cfa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Only express requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are no requirements for certification or for application of this chapter other than those expressly stated in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52db7cfb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall promulgate regulations to implement the certification procedure under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52db7cfc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Certification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52db7cfd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination by the Attorney General regarding whether to certify a State under this section is subject to review exclusively as provided under chapter 158 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7cfe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Court of Appeals for the District of Columbia Circuit shall have exclusive jurisdiction over matters under paragraph (1), subject to review by the Supreme Court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2350"},"text":"section 2350 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7cff-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2265/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard of review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination by the Attorney General regarding whether to certify a State under this section shall be subject to de novo review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52db7d00-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s507/c/1"},"text":"Pub. L. 109–177, title V, § 507(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/250"},"text":"120 Stat. 250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52db7d01-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52db7d02-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52db7d03-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2265, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tI/s107/a"},"text":"Pub. L. 104–132, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1223"},"text":"110 Stat. 1223","children":[],"tail":", related to the application of sections 2262, 2263, 2264, and 2266 of this title to State unitary review procedures, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s507/c/1"},"text":"Pub. L. 109–177, title V, § 507(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/250"},"text":"120 Stat. 250","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52db7d04-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52db7d05-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to cases pending on or after ","children":[{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", with special rule for certain cases pending on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s507/d"},"text":"section 507(d) of Pub. L. 109–177","children":[],"tail":", set out as an Effective Date of 2006 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2251"},"text":"section 2251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
