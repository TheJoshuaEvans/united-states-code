{"tag":"section","attrib":{"id":"id5298cdde-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s993"},"text":null,"children":[{"tag":"num","attrib":{"value":"993"},"text":"§ 993.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Chair","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Chair shall—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5298cddf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s993/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" call and preside at meetings of the Commission, which shall be held for at least two weeks in each quarter after the members of the Commission hold part-time positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5298cde0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s993/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5298cde1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s993/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of requests for appropriations for the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5298cde2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s993/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of funds made available to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5298cde3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl