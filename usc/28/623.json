{"tag":"section","attrib":{"id":"id528a76d9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623"},"text":null,"children":[{"tag":"num","attrib":{"value":"623"},"text":"§ 623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id528a76da-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In its direction and supervision of the activities of the Federal Judicial Center, the Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id528a76db-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish such policies and develop such programs for the Federal Judicial Center as will further achievement of its purpose and performance of its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76dc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate recommendations for improvements in the administration of the courts of the United States, in the training of the personnel of those courts, and in the management of their resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76dd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Judicial Conference of the United States, at least one month in advance of its annual meeting, a report of the activities of the Center and such recommendations as the Board may propose for the consideration of the Conference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present to other government departments agencies, and instrumentalities whose programs or activities relate to the administration of justice in the courts of the United States the recommendations of the Center for the improvement of such programs or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" study and determine ways in which automatic data processing and systems procedures may be applied to the administration of the courts of the United States, and include in the annual report required by paragraph (3) of this subsection details of the results of the studies and determinations made pursuant to this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider and recommend to both public and private agencies aspects of the operation of the courts of the United States deemed worthy of special study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76e1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct, coordinate, and encourage programs relating to the history of the judicial branch of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528a76e2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall transmit to Congress and to the Attorney General of the United States copies of all reports and recommendations submitted to the Judicial Conference of the United States. The Board shall also keep the Committees on the Judiciary of the United States Senate and House of Representatives fully and currently informed with respect to the activities of the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528a76e3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/665"},"text":"81 Stat. 665","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIII/s302"},"text":"Pub. L. 100–702, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4648"},"text":"102 Stat. 4648","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528a76e4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528a76e5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528a76e6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id528a76e7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id528a76e8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (b) of this section relating to requirement that the Board transmit to Congress copies of all reports and recommendations submitted to the Judicial Conference of the United States, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 12 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
