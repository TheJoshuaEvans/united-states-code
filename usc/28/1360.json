{"tag":"section","attrib":{"id":"id52a4b492-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1360"},"text":null,"children":[{"tag":"num","attrib":{"value":"1360"},"text":"§ 1360.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State civil jurisdiction in actions to which Indians are parties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a4b493-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1360/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of the States listed in the following table shall have jurisdiction over civil causes of action between Indians or to which Indians are parties which arise in the areas of Indian country listed opposite the name of the State to the same extent that such State has jurisdiction over other civil causes of action, and those civil laws of such State that are of general application to private persons or private property shall have the same force and effect within such Indian country as they have elsewhere within the State:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id52a4b494-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"State of","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Indian country affected","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Alaska","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"California","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Minnesota","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State, except the Red Lake Reservation.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nebraska","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oregon","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State, except the Warm Springs Reservation.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Wisconsin","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"All Indian country within the State.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b495-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1360/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall authorize the alienation, encumbrance, or taxation of any real or personal property, including water rights, belonging to any Indian or any Indian tribe, band, or community that is held in trust by the United States or is subject to a restriction against alienation imposed by the United States; or shall authorize regulation of the use of such property in a manner inconsistent with any Federal treaty, agreement, or statute or with any regulation made pursuant thereto; or shall confer jurisdiction upon the State to adjudicate, in probate proceedings or otherwise, the ownership or right to possession of such property or any interest therein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b496-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1360/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any tribal ordinance or custom heretofore or hereafter adopted by an Indian tribe, band, or community in the exercise of any authority which it may possess shall, if not inconsistent with any applicable civil law of the State, be given full force and effect in the determination of civil causes of action pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a4b497-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/ch505/s4"},"text":"Aug. 15, 1953, ch. 505, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/589"},"text":"67 Stat. 589","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-24/ch910/s2"},"text":"Aug. 24, 1954, ch. 910, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/795"},"text":"68 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/615/s2"},"text":"Pub. L. 85–615, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/545"},"text":"72 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s239"},"text":"Pub. L. 95–598, title II, § 239","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2668"},"text":"92 Stat. 2668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s110"},"text":"Pub. L. 98–353, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/342"},"text":"98 Stat. 342","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b498-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a4b499-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a4b49a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" struck out “or Territories” after “Each of the States”, struck out “or Territory” after “State” in 5 places, and substituted “within the State” for “within the Territory” in item relating to Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" directed the amendment of subsec. (a) by substituting in the item relating to Alaska “within the State” for “within the Territory”, which amendment did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/b"},"text":"section 402(b) of Pub. L. 95–598","children":[],"tail":", as amended, set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/615"},"text":"Pub. L. 85–615","children":[],"tail":" gave Alaska jurisdiction over civil causes of action between Indians or to which Indians are parties which arise in all Indian country within the Territory of Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-24"},"text":"Aug. 24, 1954","children":[],"tail":", brought the Menominee Tribe within the provisions of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b49b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a4b49c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s122/a"},"text":"section 122(a) of Pub. L. 98–353","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a4b49d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of State Constitutions To Remove Legal Impediment; Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/ch505/s6"},"text":"Act Aug. 15, 1953, ch. 505, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/590"},"text":"67 Stat. 590","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1953-08-15/ch505/s6"},"text":"“Notwithstanding the provisions of any Enabling Act for the admission of a State, the consent of the United States is hereby given to the people of any State to amend, where necessary, their State constitution or existing statutes, as the case may be, to remove any legal impediment to the assumption of civil and criminal jurisdiction in accordance with the provisions of this Act [adding this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1162"},"text":"section 1162 of Title 18","children":[],"tail":", Crimes and Criminal Procedure]: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the provisions of this Act shall not become effective with respect to such assumption of jurisdiction by any such State until the people thereof have appropriately amended their State constitution or statutes as the case may be.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52a4b49e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consent of United States to Other States To Assume Jurisdiction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-15/ch505/s7"},"text":"Act Aug. 15, 1953, ch. 505, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/590"},"text":"67 Stat. 590","children":[],"tail":", which gave consent of the United States to any other State not having jurisdiction with respect to criminal offenses or civil causes of action, or with respect to both, as provided for in this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1162"},"text":"section 1162 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, to assume jurisdiction at such time and in such manner as the people of the State shall, by legislative action, obligate and bind the State to assumption thereof, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/90/284/s403/b"},"text":"section 403(b) of Pub. L. 90–284","children":[],"tail":", title IV, "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/79"},"text":"82 Stat. 79","children":[],"tail":", such repeal not to affect any cession of jurisdiction made pursuant to such section prior to its repeal."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Retrocession of jurisdiction by State acquired by State pursuant to section 7 of Act ","children":[{"tag":"date","attrib":{"date":"1953-08-15"},"text":"Aug. 15, 1953","children":[],"tail":", prior to its repeal, see "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1323"},"text":"section 1323 of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id52a4b49f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52a4b4a0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Admission of Alaska as State","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Admission of Alaska into the Union was accomplished ","children":[{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", on issuance of Proc. No. 3269, "},{"tag":"date","attrib":{"date":"1959-01-03"},"text":"Jan. 3, 1959","children":[],"tail":", 24 F.R. 81, 73 Stat. c16, as required by sections 1 and 8(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/339"},"text":"72 Stat. 339","children":[],"tail":", set out as notes preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s21"},"text":"section 21 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
