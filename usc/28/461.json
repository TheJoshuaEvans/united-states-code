 of $100, to the next higher multiple of $100)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/92/s140"},"text":"section 140 of Pub. L. 97–92","children":[],"tail":" (set out below), appropriate salary increases were authorized for Federal judges and Justices of the Supreme Court pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/s702/a"},"text":"section 702(a) of Pub. L. 101–194","children":[],"tail":" which provided that effective for pay periods beginning on or after "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", the rate of basic pay for any office or position in the judicial branch of the Government shall be determined as if "},{"tag":"ref","attrib":{"href":"/us/pl/100/440/s620/b"},"text":"section 620(b) of Pub. L. 100–440","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"5 U.S.C. 5303","children":[],"tail":" note) and "},{"tag":"ref","attrib":{"href":"/us/pl/101/136/s619/b"},"text":"section 619(b) of Pub. L. 101–136","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"5 U.S.C. 5303","children":[],"tail":" note) had never been enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/s702"},"text":"section 702 of Pub. L. 101–194","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of Title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/a/tIV/s406"},"text":"Pub. L. 100–202, § 101(a) [title IV, § 406]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329"},"text":"101 Stat. 1329","children":[],"tail":", 1329–26, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/202/s101/a/tIV/s406"},"text":"“Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/92/s140"},"text":"section 140 of Public Law 97–92","children":[],"tail":" [set out below], during fiscal year 1988, justices and judges of the United States shall receive the same percentage increase in salary accorded to employees paid under the General Schedule (pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5305"},"text":"5 U.S.C. 5305","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tIV/s406"},"text":"Pub. L. 99–500, § 101(b) [title IV, § 406]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–64, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tIV/s406"},"text":"Pub. L. 99–591, § 101(b) [title IV, § 406]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–64, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/591/s101/b/tIV/s406"},"text":"“Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/92/s140"},"text":"section 140 of Public Law 97–92","children":[],"tail":" [set out below], during fiscal year 1987, justices and judges of the United States shall receive the same percentage increase in salary accorded to employees paid under the General Schedule (pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5305"},"text":"5 U.S.C. 5305","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/88/tI/s100"},"text":"Pub. L. 99–88, title I, § 100","children":[],"tail":", 