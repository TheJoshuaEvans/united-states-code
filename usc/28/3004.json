{"tag":"section","attrib":{"id":"id52ee906c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004"},"text":null,"children":[{"tag":"num","attrib":{"value":"3004"},"text":"§ 3004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process; enforcement; notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ee906d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaint, notice, writ, or other process required to be served in an action or proceeding under this chapter shall be served in accordance with the Federal Rules of Civil Procedure unless otherwise provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee906e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nationwide Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee906f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ee9070-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any writ, order, judgment, or other process, including a summons and complaint, filed under this chapter may be served in any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee9071-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such writ, order, or judgment may be enforced by the court issuing the writ, order, or process, regardless of where the person is served with the writ, order, or process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9072-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the debtor so requests, within 20 days after receiving the notice described in section 3101(d) or 3202(b), the action or proceeding in which the writ, order, or judgment was issued shall be transferred to the district court for the district in which the debtor resides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9073-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Other Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At such time as counsel for the United States considers appropriate, but not later than the time a prejudgment or postjudgment remedy is put into effect under this chapter, counsel for the United States shall exercise reasonable diligence to serve on the debtor and any person who the United States believes, after exercising due diligence, has possession, custody, or control of the property, a copy of the application for such remedy, the order granting such remedy, and the notice required by section 3101(d) or 3202(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee9074-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4936"},"text":"104 Stat. 4936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee9075-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee9076-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52ee9077-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (a), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee9078-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee9079-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
