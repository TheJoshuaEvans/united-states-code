{"tag":"section","attrib":{"id":"id52abe162-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1449"},"text":null,"children":[{"tag":"num","attrib":{"value":"1449"},"text":"§ 1449.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State court record supplied","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Where a party is entitled to copies of the rec­ords and proceedings in any suit or prosecution in a State court, to be used in any district court of the United States, and the clerk of such State court, upon demand, and the payment or tender of the legal fees, fails to deliver certified copies, the district court may, on affidavit reciting such facts, direct such record to be supplied by affidavit or otherwise. Thereupon such proceedings, trial, and judgment may be had in such district court, and all such process awarded, as if certified copies had been filed in the district court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52abe163-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/940"},"text":"62 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s85"},"text":"May 24, 1949, ch. 139, § 85","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/102"},"text":"63 Stat. 102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52abe164-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52abe165-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52abe166-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 78 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s35"},"text":"Mar. 3, 1911, ch. 231, § 35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1098"},"text":"36 Stat. 1098","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52abe167-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section corrects a typographical error by eliminating from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1449"},"text":"section 1449 of title 28","children":[],"tail":", U.S.C., the words “any attachment or sequestration of the”, which had been inadvertently included, and inserting in lieu thereof the words, “and the clerk of such State court, upon”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52abe168-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52abe169-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “and the clerk of such State court, upon” for “any attachment or sequestration of the”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
