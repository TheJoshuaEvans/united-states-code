{"tag":"section","attrib":{"id":"id524556d6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s291"},"text":null,"children":[{"tag":"num","attrib":{"value":"291"},"text":"§ 291.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Circuit judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524556d7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s291/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Justice of the United States may, in the public interest, designate and assign temporarily any circuit judge to act as circuit judge in another circuit upon request by the chief judge or circuit justice of such circuit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524556d8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s291/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge of a circuit or the circuit justice may, in the public interest, designate and assign temporarily any circuit judge within the circuit, including a judge designated and assigned to temporary duty therein, to hold a district court in any district within the circuit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524556d9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/900"},"text":"62 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-07-28/ch253/s2"},"text":"July 28, 1953, ch. 253, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/226"},"text":"67 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s39/b"},"text":"Sept. 3, 1954, ch. 1263, § 39(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1240"},"text":"68 Stat. 1240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-09/ch517/s1/a"},"text":"July 9, 1956, ch. 517, § 1(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/497"},"text":"70 Stat. 497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/755/s2"},"text":"Pub. L. 85–755, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-25"},"text":"Aug. 25, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/848"},"text":"72 Stat. 848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s202"},"text":"Pub. L. 95–598, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2660"},"text":"92 Stat. 2660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s108"},"text":"Pub. L. 97–164, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/28"},"text":"96 Stat. 28","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tI/s104"},"text":"Pub. L. 102–572, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4507"},"text":"106 Stat. 4507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id524556da-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id524556db-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 17, 22 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 13, 18, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1089"},"text":"36 Stat. 1089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-10-03/ch18"},"text":"Oct. 3, 1913, ch. 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/203"},"text":"38 Stat. 203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-14/ch306"},"text":"Sept. 14, 1922, ch. 306","children":[],"tail":", §§ 3, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/42/839"},"text":"42 Stat. 839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1929-03-02/ch488/s1"},"text":"Mar. 2, 1929, ch. 488, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1475"},"text":"45 Stat. 1475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-07/ch426"},"text":"June 7, 1934, ch. 426","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/926"},"text":"48 Stat. 926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch804"},"text":"June 25, 1936, ch. 804","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1921"},"text":"49 Stat. 1921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-08-24/ch754/s4"},"text":"Aug. 24, 1937, ch. 754, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/753"},"text":"50 Stat. 753","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-12-29/ch835/s1"},"text":"Dec. 29, 1942, ch. 835, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/1094"},"text":"56 Stat. 1094","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates all provisions of sections 17 and 22 of title 28, U.S.C., 1940 ed., relating to designation and assignment of circuit judges.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The revised section omits a reference to the Chief Justice contained in said section 22, since in exercising the powers under subsection (b), he acts as a circuit justice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (d) of said section 17, making the section applicable to the United States Court of Appeals for the District of Columbia, is omitted since such court is included in this revision because the District of Columbia is made a separate circuit. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41"},"text":"section 41 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of said sections 17 and 22 authorizing the senior Associate Justice to act in the absence of the Chief Justice of the United States were omitted as surplusage in view of specific authority to so act in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s3"},"text":"section 3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words in said section 17 “for such time as the business of such district court may require,” were omitted as inconsistent with the language of said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s22"},"text":"section 22 of title 28","children":[],"tail":", U.S.C., 1940 ed., which employed the words “the public interest requires” and “from time to time and until he shall otherwise direct.” The revised section and sections 294 and 296 of this title make clear the power to make designation and assignment without any limitation of time, to revoke such designation and assignment and to make, from time to time, new designations and assignments."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The term “chief judge” of the circuit was substituted for “senior circuit judge.” (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s136"},"text":"section 136 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References in said sections 17 and 22 to retired judges were omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s294"},"text":"section 294 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s17"},"text":"section 17 of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 292, 295 and 296 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s22"},"text":"section 22 of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s296"},"text":"section 296 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology and arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id524556dc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id524556dd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Chief Justice of the United States may designate and assign temporarily any circuit judge to act as circuit judge in another circuit upon presentation of a certificate of necessity by the chief judge or circuit justice of the circuit where the need arises.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" redesignated subsec. (c) as (b). Former subsec. (b), which authorized the Chief Justice of the United States to designate and temporarily assign any circuit judge to serve as a judge of the Court of Claims or the Court of Customs and Patent Appeals upon presentation to him of a certificate of necessity by the chief judge of the court in which the need arose, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" directed the amendment of subsec. (c) by inserting “or bankruptcy” after “to hold a district”, which amendment did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/b"},"text":"section 402(b) of Pub. L. 95–598","children":[],"tail":", as amended, set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" struck out provision for assignment of any judge of the Court of Claims to serve as circuit judge in any circuit. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s293/a"},"text":"section 293(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" redesignated subsec. (c) as (b) and incorporated in it provision for assignment of circuit judges to Court of Customs and Patent Appeals formerly contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s293"},"text":"section 293 of this title","children":[],"tail":". Former subsec. (b), which provided for assignment of judges of the Court of Customs and Patent Appeals to serve as judges of the Court of Appeals or the District Court for the District of Columbia, was struck out. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s293/a"},"text":"section 293(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755"},"text":"Pub. L. 85–755","children":[],"tail":" redesignated subsec. (d) as (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1956-07-09"},"text":"July 9, 1956","children":[],"tail":", inserted “or any judge of the Court of Claims to serve as a circuit judge in any circuit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", struck out “United States” from name of Court of Claims."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1953—Subsecs. (c), (d). Act ","children":[{"tag":"date","attrib":{"date":"1953-07-28"},"text":"July 28, 1953","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id524556de-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id524556df-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1101/a"},"text":"section 1101(a) of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id524556e0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id524556e1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Jurisdiction of United States Court of Customs and Patent Appeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/755/s7"},"text":"Pub. L. 85–755, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-25"},"text":"Aug. 25, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/850"},"text":"72 Stat. 850","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/755/s7"},"text":"“Nothing contained in this Act [amending this section and sections 211 and 292 to 295 of this title] shall be construed in any way to limit or alter the jurisdiction heretofore conferred upon the United States Court of Customs and Patent Appeals [now United States Court of Appeals for the Federal Circuit] by any provision of law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
