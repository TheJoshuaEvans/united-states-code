{"tag":"section","attrib":{"id":"id522d6283-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nebraska","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nebraska constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Lincoln, North Platte, and Omaha.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id522d6284-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/884"},"text":"62 Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch627/s1"},"text":"Aug. 9, 1955, ch. 627, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/546"},"text":"69 Stat. 546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522d6285-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522d6286-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 173 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s93"},"text":"Mar. 3, 1911, ch. 231, § 93","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1118"},"text":"36 Stat. 1118","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions for furnishing rooms and accommodations at the various places for holding court were omitted as obsolete upon advice of Director of the Administrative Office of the United States Courts that Federal accommodations are now available at such places.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision relating to the appointment and residence of deputy clerks and the places for keeping offices was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The county of Arthur in the North Platte Division was created since the enactment of the Judicial Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522d6287-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522d6288-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1955—Act ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"Aug. 9, 1955","children":[],"tail":", struck out the separate divisions of the district and reduced the number of places of holding terms."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id522d6289-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id522d628a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1955 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch627/s2"},"text":"Act Aug. 9, 1955, ch. 627, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/546"},"text":"69 Stat. 546","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1955-08-09/ch627/s2"},"text":"“The amendment made by the first section of this Act [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1955-09-01"},"text":"September 1, 1955","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
