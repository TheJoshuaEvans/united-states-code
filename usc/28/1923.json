{"tag":"section","attrib":{"id":"id52c5f89b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1923"},"text":null,"children":[{"tag":"num","attrib":{"value":"1923"},"text":"§ 1923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Docket fees and costs of briefs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c5f89c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attorney’s and proctor’s docket fees in courts of the United States may be taxed as costs as follows:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"$20 on trial or final hearing (including a default judgment whether entered by the court or by the clerk) in civil, criminal, or admiralty cases, except that in cases of admiralty and maritime jurisdiction where the libellant recovers less than $50 the proctor’s docket fee shall be $10;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"$20 in admiralty appeals involving not over $1,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"$50 in admiralty appeals involving not over $5,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"$100 in admiralty appeals involving more than $5,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"$5 on discontinuance of a civil action;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"$5 on motion for judgment and other proceedings on recognizances;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"$2.50 for each deposition admitted in evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c5f89d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The docket fees of United States attorneys and United States trustees shall be paid to the clerk of court and by him paid into the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c5f89e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In admiralty appeals the court may allow as costs for printing the briefs of the successful party not more than:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"$25 where the amount involved is not over $1,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"$50 where the amount involved is not over $5,000;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"$75 where the amount involved is over $5,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c5f89f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/956"},"text":"62 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-06-18/ch304"},"text":"June 18, 1954, ch. 304","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/253"},"text":"68 Stat. 253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s245"},"text":"Pub. L. 95–598, title II, § 245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2671"},"text":"92 Stat. 2671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c5f8a0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c5f8a1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 571, 572, and 578 (R.S. §§ 823, 824; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1896-05-28/ch252"},"text":"May 28, 1896, ch. 252","children":[],"tail":", §§ 6, 24, "},{"tag":"ref","attrib":{"href":"/us/stat/29/179"},"text":"29 Stat. 179","children":[],"tail":", 186; "},{"tag":"ref","attrib":{"href":"/us/act/1919-02-26/ch49/s1"},"text":"Feb. 26, 1919, ch. 49, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1182"},"text":"40 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-07-19/ch24/s1"},"text":"July 19, 1919, ch. 24, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/209"},"text":"41 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-02-11/ch46"},"text":"Feb. 11, 1921, ch. 46","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1099"},"text":"41 Stat. 1099","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-06/ch409"},"text":"June 6, 1930, ch. 409","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/522"},"text":"46 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-03/ch431/s1"},"text":"Aug. 3, 1935, ch. 431, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/513"},"text":"49 Stat. 513","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates sections 571, 572, and 578 of title 28, U.S.C., 1940 ed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “$20 on trial or final hearing in civil, criminal, or admiralty cases” was substituted for the following provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s572"},"text":"section 572 of title 28","children":[],"tail":", U.S.C., 1940 ed., “On trial before a jury, in civil or criminal causes or before referees, or on a final hearing in equity or admiralty, a docket fee of $20”, and the limitation of $10 in “cases at law when judgment is rendered without a jury” was omitted. This simplified restatement provides for a single docket fee in each case which reaches final hearing or trial. Since the docket fee is arbitrary, any limitation or distinction between law cases tried with or without a jury is unrealistic."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “solicitor” was omitted as obsolete and inapplicable in civil, criminal, or admiralty practice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “motion for judgment” were substituted for “scire facias” to conform to Rules 2 and 81 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c5f8a2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id52c5f8a3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/tIV/s408/c"},"text":"Pub. L. 95–598, title IV, § 408(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2687"},"text":"92 Stat. 2687","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/98/166/tII/s200"},"text":"Pub. L. 98–166, title II, § 200","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-28"},"text":"Nov. 28, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1081"},"text":"97 Stat. 1081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tIII/s323"},"text":"Pub. L. 98–353, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/358"},"text":"98 Stat. 358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/429"},"text":"Pub. L. 99–429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/985"},"text":"100 Stat. 985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tII/s200"},"text":"Pub. L. 99–500, § 101(b) [title II, § 200]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–45, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tII/s200"},"text":"Pub. L. 99–591, § 101(b) [title II, § 200]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–45; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tIII/s307/a"},"text":"Pub. L. 99–554, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3125"},"text":"100 Stat. 3125","children":[],"tail":", which provided for the deletion of any references to United States Trustees in this title at a prospective date, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tIII/s307/b"},"text":"Pub. L. 99–554, title III, § 307(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3125"},"text":"100 Stat. 3125","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c5f8a4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" inserted “and United States trustees” after “United States attorneys”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1954-06-18"},"text":"June 18, 1954","children":[],"tail":", inserted in first item “including a default judgment whether entered by the court or by the clerk” after “final hearing”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c5f8a5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c5f8a6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/c"},"text":"section 402(c) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
