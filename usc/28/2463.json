{"tag":"section","attrib":{"id":"id52e518f8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2463"},"text":null,"children":[{"tag":"num","attrib":{"value":"2463"},"text":"§ 2463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property taken under revenue law not re­pleviable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All property taken or detained under any revenue law of the United States shall not be repleviable, but shall be deemed to be in the custody of the law and subject only to the orders and decrees of the courts of the United States having jurisdiction thereof.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52e518f9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/974"},"text":"62 Stat. 974","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e518fa-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52e518fb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 747 (R.S. § 934).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
