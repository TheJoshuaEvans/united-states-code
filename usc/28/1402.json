{"tag":"section","attrib":{"id":"id52a6ff55-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402"},"text":"§ 1402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States as defendant","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a6ff56-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any civil action in a district court against the United States under subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346"},"text":"section 1346 of this title","children":[],"tail":" may be prosecuted only:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a6ff57-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), in the judicial district where the plaintiff resides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a6ff58-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a civil action by a corporation under paragraph (1) of subsection (a) of section 1346, in the judicial district in which is located the principal place of business or principal office or agency of the corporation; or if it has no principal place of business or principal office or agency in any judicial district (A) in the judicial district in which is located the office to which was made the return of the tax in respect of which the claim is made, or (B) if no return was made, in the judicial district in which lies the District of Columbia. Notwithstanding the foregoing provisions of this paragraph a district court, for the convenience of the parties and witnesses, in the interest of justice, may transfer any such action to any other district or division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ff59-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any civil action on a tort claim against the United States under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346"},"text":"section 1346 of this title","children":[],"tail":" may be prosecuted only in the judicial district where the plaintiff resides or wherein the act or omission complained of occurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ff5a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any civil action against the United States under subsection (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346"},"text":"section 1346 of this title","children":[],"tail":" may be prosecuted only in the judicial district where the property is situated at the time of levy, or if no levy is made, in the judicial district in which the event occurred which gave rise to the cause of action."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ff5b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any civil action under section 2409a to quiet title to an estate or interest in real property in which an interest is claimed by the United States shall be brought in the district court of the district where the property is located or, if located in different districts, in any of such districts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a6ff5c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/937"},"text":"62 Stat. 937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/920"},"text":"Pub. L. 85–920","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1770"},"text":"72 Stat. 1770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/tII/s202/b"},"text":"Pub. L. 89–719, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1149"},"text":"80 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/562/s2"},"text":"Pub. L. 92–562, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1176"},"text":"86 Stat. 1176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s131"},"text":"Pub. L. 97–164, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/39"},"text":"96 Stat. 39","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ff5d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a6ff5e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 762, 931(a) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch359/s5"},"text":"Mar. 3, 1887, ch. 359, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/506"},"text":"24 Stat. 506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753/s410/a"},"text":"Aug. 2, 1946, ch. 753, § 410(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/843"},"text":"60 Stat. 843","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates the venue provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s762"},"text":"section 762 of title 28","children":[],"tail":", U.S.C., 1940 ed., with the venue provisions of section 931(a) of such title, the latter provisions relating to tort claims cases. The jurisdictional provisions of such section 931(a) are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/b"},"text":"section 1346(b) of this title","children":[],"tail":". For other provisions thereof, see Distribution Table."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s762"},"text":"section 762 of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to the verification and contents of a petition filed against the United States were omitted as unnecessary. "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s265"},"text":"Section 265 of title 28","children":[],"tail":", U.S.C., 1940 ed., relative to the petition in cases filed in the Court of Claims was also omitted from the revised title. (See, also, Rule 11 of the Federal Rules of Civil Procedure.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suit” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a6ff5f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a6ff60-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" inserted “in a district court” after “civil action” in introductory provisions preceding par. (1). The phrase “civil action” also appeared in par. (2), but no change was made to reflect the probable intent of Congress as indicated on page 79 of House Report No. 97–312."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/562"},"text":"Pub. L. 92–562","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/920"},"text":"Pub. L. 85–920","children":[],"tail":" provided for venue and change of venue in tax refund suits by corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a6ff61-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a6ff62-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a6ff63-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/719"},"text":"Pub. L. 89–719","children":[],"tail":" applicable after "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/719/s203"},"text":"section 203 of Pub. L. 89–719","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346"},"text":"section 1346 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
