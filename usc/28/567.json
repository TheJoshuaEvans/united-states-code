"href":"/us/act/1930-06-06/ch409"},"text":"June 6, 1930, ch. 409","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/522"},"text":"46 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-10-13/ch431/s1"},"text":"Oct. 13, 1941, ch. 431, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/736"},"text":"55 Stat. 736","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates first sentence of section 577 with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s578a"},"text":"section 578a of title 28","children":[],"tail":", U.S.C., 1940 ed., with changes of phraseology necessary to effect consolidation. Other provisions of said section 577 are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1929"},"text":"section 1929 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The qualification that payments of witness fees or costs be made upon “order of court,” contained in said ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s577"},"text":"section 577 of title 28","children":[],"tail":", U.S.C., 1940 ed., was omitted as obsolete and suitable reference was made to sections 1825 and 1871 of this title under which payments are now made on certificates of attendance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s578a"},"text":"Section 578a of title 28","children":[],"tail":", U.S.C., 1940 ed., is rewritten in simplified terms without change of substance. The proviso of such section 578a, prohibiting the collection of fees from the United States, was omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2412"},"text":"section 2412 of this title","children":[],"tail":", providing that the United States should be liable only for fees when such liability is expressly provided by Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s578a"},"text":"section 578a of title 28","children":[],"tail":", U.S.C., 1940 ed., requiring that fees and emoluments collected by the marshal shall be deposited by him in accordance with the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s495"},"text":"section 495 of title 31","children":[],"tail":", U.S.C., 1940 ed., Money and Finance, was omitted as said section 495 governs such deposits without implementation in this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5274f28e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5274f28f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 567, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/620"},"text":"80 Stat. 620","children":[],"tail":", related to expenses of marshals, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7608/a/1"},"text":"Pub. L. 100–690, § 7608(a)(1)","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s565"},"text":"section 565 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5274f290-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","at