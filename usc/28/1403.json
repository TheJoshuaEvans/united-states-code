{"tag":"section","attrib":{"id":"id52a6ff64-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1403"},"text":null,"children":[{"tag":"num","attrib":{"value":"1403"},"text":"§ 1403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eminent domain","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Proceedings to condemn real estate for the use of the United States or its departments or agencies shall be brought in the district court of the district where the land is located or, if located in different districts in the same State, in any of such districts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a6ff65-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/937"},"text":"62 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ff66-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a6ff67-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s257"},"text":"section 257 of title 40","children":[],"tail":", U.S.C., 1940 ed., Public Buildings, Property, and Works ("},{"tag":"ref","attrib":{"href":"/us/act/1888-08-01/ch728/s1"},"text":"Aug. 1, 1888, ch. 728, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/357"},"text":"25 Stat. 357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section constitutes the first clause of the second sentence of section 257, of title 40, U.S.C., 1940 ed. The revised section is expressive of the purpose of such section 257 with necessary changes in phraseology.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The jurisdiction provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s257"},"text":"section 257 of title 40","children":[],"tail":", U.S.C., 1940 ed., is incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1358"},"text":"section 1358 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The remainder of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s257"},"text":"section 257 of title 40","children":[],"tail":", U.S.C., 1940 ed., is retained in said title 40."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision with respect to property in different districts was added to conform with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1392"},"text":"section 1392 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See, also, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1392"},"text":"section 1392 of this title","children":[],"tail":" which fixes venue of an action involving property in different districts in the same State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
