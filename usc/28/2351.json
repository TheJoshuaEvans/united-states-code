{"tag":"section","attrib":{"id":"id52ddedf3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2351"},"text":null,"children":[{"tag":"num","attrib":{"value":"2351"},"text":"§ 2351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of orders by district courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The several district courts have jurisdiction specifically to enforce, and to enjoin and restrain any person from violating any order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s193"},"text":"section 193 of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ddedf4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/e"},"text":"Pub. L. 89–554, § 4(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/624"},"text":"80 Stat. 624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ddedf5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ddedf6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id52ddedf7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s1042"},"text":"5 U.S.C. 1042","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-12-29/ch1189/s12"},"text":"Dec. 29, 1950, ch. 1189, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1132"},"text":"64 Stat. 1132","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “United States” preceding “district court” are omitted as unnecessary because the term “district court” as used in title 28 means a United States district court. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of title 28","children":[],"tail":", United States Code. The words “have jurisdiction” are substituted for “are vested with jurisdiction”. The words “heretofore or hereafter” following “order” are omitted as unnecessary and any existing rights and liabilities are preserved by technical sections 7 and 8."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
