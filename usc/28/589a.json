{"tag":"section","attrib":{"id":"id5279ae4a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a"},"text":null,"children":[{"tag":"num","attrib":{"value":"589a"},"text":"§ 589a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Trustee System Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5279ae4b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is hereby established in the Treasury of the United States a special fund to be known as the “United States Trustee System Fund” (hereinafter in this section referred to as the “Fund”). Monies in the Fund shall be available to the Attorney General without fiscal year limitation in such amounts as may be specified in appropriations Acts for the following purposes in connection with the operations of United States trustees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5279ae4c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries and related employee benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae4d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel and transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae4e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental of space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae4f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication, utilities, and miscellaneous computer charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae50-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security investigations and audits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae51-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies, books, and other materials for legal research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae52-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furniture and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae53-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" miscellaneous services, including those obtained by contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae54-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" printing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279ae55-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of recovering the cost of services of the United States Trustee System, there shall be deposited as offsetting collections to the appropriation “United States Trustee System Fund”, to remain available until expended, the following—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5279ae56-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5279ae57-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $51.49 of the fees collected in each case under section 1930(a)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5279ae58-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 28.33 percent of the fees collected under section 1930(a)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae59-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 48.89 percent of the fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1930/a/3"},"text":"section 1930(a)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae5a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of the fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1930/a/4"},"text":"section 1930(a)(4) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae5b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of the fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1930/a/5"},"text":"section 1930(a)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae5c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1930/a/6"},"text":"section 1930(a)(6) of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002033"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002033"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Deposits of Fees Under Section 1930(a)(6) of This Title for Certain Fiscal Years note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae5d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three-fourths of the fees collected under the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1930/a"},"text":"section 1930(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae5e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation of trustees received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s330/d"},"text":"section 330(d) of title 11","children":[],"tail":" by the clerks of the bankruptcy courts;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae5f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excess fees collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s586/e/2"},"text":"section 586(e)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae60-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest earned on Fund investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae61-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fines imposed under section 110(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of title 11, United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279ae62-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund which are not currently needed for the purposes specified in subsections (a) and (f) shall be kept on deposit or invested in obligations of, or guaranteed by, the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279ae63-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall transmit to the Congress, not later than 120 days after the end of each fiscal year, a detailed report on the amounts deposited in the Fund and a description of expenditures made under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279ae64-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Fund for any fiscal year such sums as may be necessary to supplement amounts deposited under subsection (b) for the purposes specified in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279ae65-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5279ae66-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During each of fiscal years 2021 through 2031 and notwithstanding subsection (b)(5), the fees collected under section 1930(a)(6), less the amount specified in paragraph (2), shall be deposited as follows, in the following order:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5279ae67-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" First, the amounts needed to offset the amount specified in the Department of Justice appropriations for that fiscal year, shall be deposited as discretionary offsetting collections to the “United States Trustee System Fund”, pursuant to subsection (a), to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5279ae68-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Second, any remaining amounts shall be deposited as discretionary offsetting collections to the “United States Trustee System Fund”, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5279ae69-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (b), for each of fiscal years 2021 through 2031, $5,400,000 of the fees collected under section 1930(a)(6) shall be deposited in the general fund of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id527c1e6a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI/s115/a"},"text":"Pub. L. 99–554, title I, § 115(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3094"},"text":"100 Stat. 3094","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/162/tIV/s406/c"},"text":"Pub. L. 101–162, title IV, § 406(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1016"},"text":"103 Stat. 1016","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/140/tI/s111/b"},"text":"Pub. L. 102–140, title I, § 111(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/795"},"text":"105 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/121/tI/s111/a/2"},"text":"Pub. L. 103–121, title I, § 111(a)(2)","children":[],"tail":", (b)(2), (3), "},{"tag":"date","attrib":{"date":"1993-10-27"},"text":"Oct. 27, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1164"},"text":"107 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/91/tI/s101/a"},"text":"Pub. L. 104–91, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/11"},"text":"110 Stat. 11","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/99/tII/s211"},"text":"Pub. L. 104–99, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-26"},"text":"Jan. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/37"},"text":"110 Stat. 37","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tI/s109/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title I, § 109(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"hre