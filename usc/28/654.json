{"tag":"section","attrib":{"id":"id5291a201-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654"},"text":null,"children":[{"tag":"num","attrib":{"value":"654"},"text":"§ 654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a202-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral of Actions to Arbitration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of law to the contrary and except as provided in subsections (a), (b), and (c) of section 652 and subsection (d) of this section, a district court may allow the referral to arbitration of any civil action (including any adversary proceeding in bankruptcy) pending before it when the parties consent, except that referral to arbitration may not be made where—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a203-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action is based on an alleged violation of a right secured by the Constitution of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a204-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jurisdiction is based in whole or in part on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1343"},"text":"section 1343 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a205-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relief sought consists of money damages in an amount greater than $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a206-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safeguards in Consent Cases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until such time as rules are adopted under chapter 131 of this title relating to procedures described in this subsection, the district court shall, by local rule adopted under section 2071(a), establish procedures to ensure that any civil action in which arbitration by consent is allowed under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a207-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consent to arbitration is freely and knowingly obtained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a208-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no party or attorney is prejudiced for refusing to participate in arbitration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a209-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a)(3), a district court may presume damages are not in excess of $150,000 unless counsel certifies that damages exceed such amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a20a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s654/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter is deemed to affect any program in which arbitration is conducted pursuant to section ","children":[{"tag":"ref","attrib":{"idref":"fn002057"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002057"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “section” probably should not appear."}],"tail":" title IX of the Judicial Improvements and Access to Justice Act ("},{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Public Law 100–702","children":[],"tail":"), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/53/s1"},"text":"section 1 of Public Law 105–53","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a20b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIX/s901/a"},"text":"Pub. L. 100–702, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4660"},"text":"102 Stat. 4660","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/315/s6"},"text":"Pub. L. 105–315, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2995"},"text":"112 Stat. 2995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a20c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a20d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5291a20e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title IX of the Judicial Improvements and Access to Justice Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Public Law 100–702","children":[],"tail":"), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/53/s1"},"text":"section 1 of Public Law 105–53","children":[],"tail":", referred to in subsec. (d), is title IX of "},{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4659"},"text":"102 Stat. 4659","children":[],"tail":", which enacted this chapter and provisions set out as notes under sections 651 and 652 of this title. "},{"tag":"ref","attrib":{"href":"/us/pl/105/53/s1"},"text":"Section 1 of Pub. L. 105–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-06"},"text":"Oct. 6, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1173"},"text":"111 Stat. 1173","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIX/s905"},"text":"section 905 of title IX of Pub. L. 100–702","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s651"},"text":"section 651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a20f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/315"},"text":"Pub. L. 105–315","children":[],"tail":" amended section generally, substituting provisions relating to arbitration for provisions relating to arbitration award and judgment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
