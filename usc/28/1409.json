{"tag":"section","attrib":{"id":"id52a6ffa2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1409"},"text":null,"children":[{"tag":"num","attrib":{"value":"1409"},"text":"§ 1409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue of proceedings arising under title 11 or arising in or related to cases under title 11","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a6ffa3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in subsections (b) and (d), a proceeding arising under title 11 or arising in or related to a case under title 11 may be commenced in the district court in which such case is pending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ffa4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (d) of this section, a trustee in a case under title 11 may commence a proceeding arising in or related to such case to recover a money judgment of or property worth less than $1,000 ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Adjustment of Dollar Amounts notes below."}],"tail":" or a consumer debt of less than $15,000,"},{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":" or a debt (excluding a consumer debt) against a noninsider of less than $25,000, only in the district court for the district in which the defendant resides."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ffa5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, a trustee in a case under title 11 may commence a proceeding arising in or related to such case as statutory successor to the debtor or creditors under section 541 or 544(b) of title 11 in the district court for the district where the State or Federal court sits in which, under applicable nonbankruptcy venue provisions, the debtor or creditors, as the case may be, may have commenced an action on which such proceeding is based if the case under title 11 had not been commenced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ffa6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1409/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A trustee may commence a proceeding arising under title 11 or arising in or related to a case under title 11 based on a claim arising after the commencement of such case from the operation of the business of the debtor only in the district court for the district where a State or Federal court sits in which, under applicable nonbankruptcy venue provisions, an action on such claim may have been brought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ffa7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1409/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A proceeding arising under title 11 or arising in or related to a case under title 11, based on a claim arising after the commencement of such case from the operation of the business of the debtor, may be commenced against the representative of the estate in such case in the district court for the district where the State or Federal court sits in which the party commencing such proceeding may, under applicable nonbankruptcy venue provisions, have brought an action on such claim, or in the district court in which such case is pending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a6ffa8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s102/a"},"text":"Pub. L. 98–353, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/334"},"text":"98 Stat. 334","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV/s410"},"text":"Pub. L. 109–8, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/106"},"text":"119 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s3/b"},"text":"Pub. L. 116–54, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1085"},"text":"133 Stat. 1085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ffa9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a6ffaa-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a6ffab-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54"},"text":"Pub. L. 116–54","children":[],"tail":" substituted “$25,000” for “$10,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" substituted “$15,000, or a debt (excluding a consumer debt) against a noninsider of less than $10,000,” for “$5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a6ffac-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a6ffad-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54"},"text":"Pub. L. 116–54","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a6ffae-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a6ffaf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s122/a"},"text":"section 122(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"courtRules","id":"id52a6ffb0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Court Rules and Judicial Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52a6ffb1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adjustment of Dollar Amounts","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The dollar amounts specified in this section were adjusted by notices of the Judicial Conference of the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s104"},"text":"section 104 of Title 11","children":[],"tail":", Bankruptcy, as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2025-01-30"},"text":"Jan. 30, 2025","children":[],"tail":", 90 F.R. 8941, effective "},{"tag":"date","attrib":{"date":"2025-04-01"},"text":"Apr. 1, 2025","children":[],"tail":", and corrected at 90 F.R. 10643, in subsec. (b), dollar amounts “1,525”, “22,700”, and “27,750” were adjusted to “1,725”, “25,700”, and “31,425”, respectively. See notice of the Judicial Conference of the United States set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s104"},"text":"section 104 of Title 11","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2022-01-31"},"text":"Jan. 31, 2022","children":[],"tail":", 87 F.R. 6625, effective "},{"tag":"date","attrib":{"date":"2022-04-01"},"text":"Apr. 1, 2022","children":[],"tail":", in subsec. (b), dollar amounts “1,375”, “20,450”, and “25,000” were adjusted to “1,525”, “22,700”, and “27,750”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2019-02-05"},"text":"Feb. 5, 2019","children":[],"tail":", 84 F.R. 3488, effective "},{"tag":"date","attrib":{"date":"2019-04-01"},"text":"Apr. 1, 2019","children":[],"tail":", in subsec. (b), dollar amounts “1,300”, “19,250”, and “12,850” were adjusted to “1,375”, “20,450”, and “13,650”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2016-02-16"},"text":"Feb. 16, 2016","children":[],"tail":", 81 F.R. 8748, effective "},{"tag":"date","attrib":{"date":"2016-04-01"},"text":"Apr. 1, 2016","children":[],"tail":", in subsec. (b), dollar amounts “1,250”, “18,675”, and “12,475” were adjusted to “1,300”, “19,250”, and “12,850”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2013-02-12"},"text":"Feb. 12, 2013","children":[],"tail":", 78 F.R. 12089, effective "},{"tag":"date","attrib":{"date":"2013-04-01"},"text":"Apr. 1, 2013","children":[],"tail":", in subsec. (b), dollar amounts “1,175”, “17,575”, and “11,725” were adjusted to “1,250”, “18,675”, and “12,475”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2010-02-19"},"text":"Feb. 19, 2010","children":[],"tail":", 75 F.R. 8747, effective "},{"tag":"date","attrib":{"date":"2010-04-01"},"text":"Apr. 1, 2010","children":[],"tail":", in subsec. (b), dollar amounts “1,100”, “16,425”, and “10,950” were adjusted to “1,175”, “17,575”, and “11,725”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By notice dated ","children":[{"tag":"date","attrib":{"date":"2007-02-07"},"text":"Feb. 7, 2007","children":[],"tail":", 72 F.R. 7082, effective "},{"tag":"date","attrib":{"date":"2007-04-01"},"text":"Apr. 1, 2007","children":[],"tail":", in subsec. (b), dollar amounts “1,000”, “15,000”, and “10,000” were adjusted to “1,100”, “16,425”, and “10,950”, respectively. "},{"tag":"ref","attrib":{"href":"/us/pl/116/54"},"text":"Pub. L. 116–54","children":[],"tail":" subsequently substituted “25,000” for “10,000”, see 2019 Amendment note above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
