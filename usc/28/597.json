{"tag":"section","attrib":{"id":"id5280d972-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s597"},"text":null,"children":[{"tag":"num","attrib":{"value":"597"},"text":"§ 597.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship with Department of Justice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5280d973-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s597/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension of Other Investigations and Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever a matter is in the prosecutorial jurisdiction of an independent counsel or has been accepted by an independent counsel under section 594(e), the Department of Justice, the Attorney General, and all other officers and employees of the Department of Justice shall suspend all investigations and proceedings regarding such matter, except to the extent required by section 594(d)(1), and except insofar as such independent counsel agrees in writing that such investigation or proceedings may be continued by the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5280d974-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s597/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation as Amicus Curiae Permitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall prevent the Attorney General or the Solicitor General from making a presentation as amicus curiae to any court as to issues of law raised by any case or proceeding in which an independent counsel participates in an official capacity or any appeal of such a case or proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5280d975-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVI/s601/a"},"text":"Pub. L. 95–521, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1872"},"text":"92 Stat. 1872","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/a/1/A"},"text":"Pub. L. 97–409, § 2(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-03"},"text":"Jan. 3, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2039"},"text":"96 Stat. 2039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/191/s2"},"text":"Pub. L. 100–191, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1306"},"text":"101 Stat. 1306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5280d976-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5280d977-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5280d978-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191"},"text":"Pub. L. 100–191","children":[],"tail":" amended section generally, substituting provisions relating to relationship with Department of Justice for substantially similar provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/a/1/A"},"text":"Pub. L. 97–409, § 2(a)(1)(A)","children":[],"tail":", substituted “independent counsel” for “special prosecutor” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5280d979-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5280d97a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191"},"text":"Pub. L. 100–191","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", and applicable to proceedings initiated and independent counsels appointed on and after "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/191/s6"},"text":"section 6 of Pub. L. 100–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"section 591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
