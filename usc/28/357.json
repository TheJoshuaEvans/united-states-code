{"tag":"section","attrib":{"id":"id524c82b8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s357"},"text":null,"children":[{"tag":"num","attrib":{"value":"357"},"text":"§ 357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of orders and actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524c82b9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s357/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Action of Judicial Council","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complainant or judge aggrieved by an action of the judicial council under section 354 may petition the Judicial Conference of the United States for review thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524c82ba-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s357/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action of Judicial Conference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Judicial Conference, or the standing committee established under section 331, may grant a petition filed by a complainant or judge under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524c82bb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s357/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as expressly provided in this section and section 352(c), all orders and determinations, including denials of petitions for review, shall be final and conclusive and shall not be judicially reviewable on appeal or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524c82bc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11042/a"},"text":"Pub. L. 107–273, div. C, title I, § 11042(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1853"},"text":"116 Stat. 1853","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
