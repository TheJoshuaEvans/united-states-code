{"tag":"section","attrib":{"id":"id52ee8fe9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2714"},"text":null,"children":[{"tag":"num","attrib":{"value":"2714"},"text":"§ 2714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of proceeds of attached property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the property attached is sold on an interlocutory order or is producing revenue, the money arising from the sale or revenue shall be invested, under the order of the court, in securities of the United States. The accretions therefrom are subject to the order of the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ee8fea-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/682/s9"},"text":"Pub. L. 86–682, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/707"},"text":"74 Stat. 707","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee8feb-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee8fec-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id52ee8fed-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from R.S. § 928, which was originally classified to section 741 of former Title 28. Following the general revision and enactment of Title 28 by act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", R.S. § 928 was reclassified to "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s841"},"text":"section 841 of Title 39","children":[],"tail":". R.S. § 928 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s12/c"},"text":"section 12(c) of Pub. L. 86–682","children":[],"tail":" (section 1 of which revised and enacted Title 39), and reenacted by section 9 thereof as "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2714"},"text":"section 2714 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee8fee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee8fef-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1960-09-01"},"text":"Sept. 1, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s11"},"text":"section 11 of Pub. L. 86–682","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
