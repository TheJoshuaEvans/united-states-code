{"tag":"section","attrib":{"id":"id5291a223-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657"},"text":null,"children":[{"tag":"num","attrib":{"value":"657"},"text":"§ 657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitration award and judgment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a224-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing and Effect of Arbitration Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An arbitration award made by an arbitrator under this chapter, along with proof of service of such award on the other party by the prevailing party or by the plaintiff, shall be filed promptly after the arbitration hearing is concluded with the clerk of the district court that referred the case to arbitration. Such award shall be entered as the judgment of the court after the time has expired for requesting a trial de novo. The judgment so entered shall be subject to the same provisions of law and shall have the same force and effect as a judgment of the court in a civil action, except that the judgment shall not be subject to review in any other court by appeal or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a225-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sealing of Arbitration Award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The district court shall provide, by local rule adopted under section 2071(a), that the contents of any arbitration award made under this chapter shall not be made known to any judge who might be assigned to the case until the district court has entered final judgment in the action or the action has otherwise terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a226-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trial de Novo of Arbitration Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a227-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for filing demand","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 30 days after the filing of an arbitration award with a district court under subsection (a), any party may file a written demand for a trial de novo in the district court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a228-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action restored to court docket","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon a demand for a trial de novo, the action shall be restored to the docket of the court and treated for all purposes as if it had not been referred to arbitration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a229-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion of evidence of arbitration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The court shall not admit at the trial de novo any evidence that there has been an arbitration proceeding, the nature or amount of any award, or any other matter concerning the conduct of the arbitration proceeding, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5291a22a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evidence would otherwise be admissible in the court under the Federal Rules of Evidence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5291a22b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s657/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties have otherwise stipulated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a22c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIX/s901/a"},"text":"Pub. L. 100–702, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4662"},"text":"102 Stat. 4662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/315/s9"},"text":"Pub. L. 105–315, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2997"},"text":"112 Stat. 2997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a22d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a22e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5291a22f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Evidence, referred to in subsec. (c)(3)(A), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a230-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/315"},"text":"Pub. L. 105–315","children":[],"tail":" amended section generally, substituting provisions relating to arbitration award and judgment for provisions relating to compensation of arbitrators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
