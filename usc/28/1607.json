{"tag":"section","attrib":{"id":"id52b5567d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1607"},"text":null,"children":[{"tag":"num","attrib":{"value":"1607"},"text":"§ 1607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterclaims","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any action brought by a foreign state, or in which a foreign state intervenes, in a court of the United States or of a State, the foreign state shall not be accorded immunity with respect to any counterclaim—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52b5567e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1607/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a foreign state would not be entitled to immunity under section 1605 or 1605A of this chapter had such claim been brought in a separate action against the foreign state; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b5567f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1607/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arising out of the transaction or occurrence that is the subject matter of the claim of the foreign state; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b55680-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1607/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the counterclaim does not seek relief exceeding in amount or differing in kind from that sought by the foreign state.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52b55681-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/583/s4/a"},"text":"Pub. L. 94–583, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2894"},"text":"90 Stat. 2894","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tX/s1083/b/2"},"text":"Pub. L. 110–181, div. A, title X, § 1083(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/341"},"text":"122 Stat. 341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b55682-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52b55683-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52b55684-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" inserted “or 1605A” after “section 1605”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b55685-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52b55686-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For applicability of amendments by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" to pending cases, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1083/c"},"text":"section 1083(c) of Pub. L. 110–181","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1605A"},"text":"section 1605A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52b55687-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/583/s8"},"text":"section 8 of Pub. L. 94–583","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
