{"tag":"section","attrib":{"id":"id52ddede8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2350"},"text":null,"children":[{"tag":"num","attrib":{"value":"2350"},"text":"§ 2350.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review in Supreme Court on certiorari or certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ddede9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2350/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An order granting or denying an interlocutory injunction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2349/b"},"text":"section 2349(b) of this title","children":[],"tail":" and a final judgment of the court of appeals in a proceeding to review under this chapter are subject to review by the Supreme Court on a writ of certiorari as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254/1"},"text":"section 1254(1) of this title","children":[],"tail":". Application for the writ shall be made within 45 days after entry of the order and within 90 days after entry of the judgment, as the case may be. The United States, the agency, or an aggrieved party may file a petition for a writ of certiorari."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ddedea-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2350/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254/2"},"text":"section 1254(2) of this title","children":[],"tail":", regarding certification, and of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2101/f"},"text":"section 2101(f) of this title","children":[],"tail":", regarding stays, also apply to proceedings under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"source