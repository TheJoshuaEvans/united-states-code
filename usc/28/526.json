{"tag":"section","attrib":{"id":"id52690b1e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s526"},"text":null,"children":[{"tag":"num","attrib":{"value":"526"},"text":"§ 526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Attorney General to investigate United States attorneys, marshals, trustees, clerks of court, and others","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52690b1f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Attorney General may investigate the official acts, records, and accounts of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52690b20-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s526/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States attorneys, marshals, trustees, including trustees in cases under title 11; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52690b21-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s526/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request and on behalf of the Director of the Administrative Office of the United States Courts, the clerks of the United States courts and of the district court of the Virgin Islands, probation officers, United States magistrate judges, and court reporters;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for which purpose all the official papers, rec­ords, dockets, and accounts of these officers, without exception, may be examined by agents of the Attorney General at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52690b22-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations for the examination of judicial officers are available for carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52690b23-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/615"},"text":"80 Stat. 615","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII"},"text":"Pub. L. 95–598, title II","children":[],"tail":", §§ 219(a), (b), 220, "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2662"},"text":"92 Stat. 2662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI/s144/c"},"text":"Pub. L. 99–554, title I, § 144(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3096"},"text":"100 Stat. 3096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dB/tIV/s4003/b/2"},"text":"Pub. L. 107–273, div. B, title IV, § 4003(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"