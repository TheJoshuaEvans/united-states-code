{"tag":"section","attrib":{"id":"id52c3af67-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1918"},"text":null,"children":[{"tag":"num","attrib":{"value":"1918"},"text":"§ 1918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District courts; fines, forfeitures and criminal proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c3af68-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs shall be included in any judgment, order, or decree rendered against any person for the violation of an Act of Congress in which a civil fine or forfeiture of property is provided for.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3af69-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever any conviction for any offense not capital is obtained in a district court, the court may order that the defendant pay the costs of prosecution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c3af6a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/955"},"text":"62 Stat. 955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3af6b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c3af6c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 822 (R.S. § 974).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
