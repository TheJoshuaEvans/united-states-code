{"tag":"section","attrib":{"id":"id52cd242b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of criminal case on appeal from State court","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Criminal cases on review from State courts shall have priority, on the docket of the Supreme Court, over all cases except cases to which the United States is a party and such other cases as the court may decide to be of public importance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52cd242c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/962"},"text":"62 Stat. 962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cd242d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cd242e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 351 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s253"},"text":"Mar. 3, 1911, ch. 231, § 253","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1160"},"text":"36 Stat. 1160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-01-31/ch14/s1"},"text":"Jan. 31, 1928, ch. 14, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/54"},"text":"45 Stat. 54","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
