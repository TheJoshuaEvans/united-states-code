{"tag":"section","attrib":{"id":"id52cadb16-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2077"},"text":null,"children":[{"tag":"num","attrib":{"value":"2077"},"text":"§ 2077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of rules; advisory committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52cadb17-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2077/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rules for the conduct of the business of each court of appeals, including the operating procedures of such court, shall be published. Each court of appeals shall print or cause to be printed necessary copies of the rules. The Judicial Conference shall prescribe the fees for sales of copies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1913"},"text":"section 1913 of this title","children":[],"tail":", but the Judicial Conference may provide for free distribution of copies to members of the bar of each court and to other interested persons."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cadb18-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2077/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each court, except the Supreme Court, that is authorized to prescribe rules of the conduct of such court’s business under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of this title","children":[],"tail":" shall appoint an advisory committee for the study of the rules of practice and internal operating procedures of such court and, in the case of an advisory committee appointed by a court of appeals, of the rules of the judicial council of the circuit. The advisory committee shall make recommendations to the court concerning such rules and procedures. Members of the committee shall serve without compensation, but the Director may pay travel and transportation expenses in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52cadb19-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tII/s208/a"},"text":"Pub. L. 97–164, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/54"},"text":"96 Stat. 54","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIV/s401/b"},"text":"Pub. L. 100–702, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4650"},"text":"102 Stat. 4650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIV/s406"},"text":"Pub. L. 101–650, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5124"},"text":"104 Stat. 5124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cadb1a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52cadb1b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52cadb1c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650"},"text":"Pub. L. 101–650","children":[],"tail":" inserted before period at end of first sentence “and, in the case of an advisory committee appointed by a court of appeals, of the rules of the judicial council of the circuit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" substituted “Each court, except the Supreme Court, that is authorized to prescribe rules of the conduct of such court’s business under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of this title","children":[],"tail":" shall appoint” for “Each court of appeals shall appoint” and “such court” for “the court of appeals”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52cadb1d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cadb1e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650"},"text":"Pub. L. 101–650","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/s407"},"text":"section 407 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s332"},"text":"section 332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cadb1f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-12-01"},"text":"Dec. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/s407"},"text":"section 407 of Pub. L. 100–702","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52cadb20-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as an Effective Date of 1982 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
