{"tag":"section","attrib":{"id":"id525869c6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458"},"text":null,"children":[{"tag":"num","attrib":{"value":"458"},"text":"§ 458.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relative of justice or judge ineligible to appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525869c7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525869c8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person shall be appointed to or employed in any office or duty in any court who is related by affinity or consanguinity within the degree of first cousin to any justice or judge of such court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525869c9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the appointment of a judge of a court exercising judicial power under article III of the United States Constitution (other than the Supreme Court), subsection (b) shall apply in lieu of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525869ca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525869cb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id525869cc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “same court” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id525869cd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a district court, the court of a single judicial district; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id525869ce-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a court of appeals, the court of appeals of a single circuit; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id525869cf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “member”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id525869d0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an active judge or a judge retired in senior status under section 371(b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id525869d1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include a retired judge, except as described under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525869d2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s458/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may be appointed to the position of judge of a court exercising judicial power under article III of the United States Constitution (other than the Supreme Court) who is related by affinity or consanguinity within the degree of first cousin to any judge who is a member of the same court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525869d3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/908"},"text":"62 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/300/s1/a"},"text":"Pub. L. 105–300, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2836"},"text":"112 Stat. 2836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525869d4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id525869d5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 126 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-03/ch373/s7"},"text":"Mar. 3, 1887, ch. 373, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/555"},"text":"24 Stat. 555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1888-08-13/ch866/s7"},"text":"Aug. 13, 1888, ch. 866, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/25/437"},"text":"25 Stat. 437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s67"},"text":"Mar. 3, 1911, ch. 231, § 67","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1105"},"text":"36 Stat. 1105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-12-21/ch4"},"text":"Dec. 21, 1911, ch. 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/46"},"text":"37 Stat. 46","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision referring to circuit court employees as of ","children":[{"tag":"date","attrib":{"date":"1911-12-21"},"text":"December 21, 1911","children":[],"tail":", was omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525869d6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id525869d7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/300"},"text":"Pub. L. 105–300","children":[],"tail":" designated existing provisions as subsec. (a)(1) and added subsecs. (a)(2) and (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id525869d8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id525869d9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/300/s1/b"},"text":"Pub. L. 105–300, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2837"},"text":"112 Stat. 2837","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/300/s1/b"},"text":"“This Act [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":"] and shall apply only to any individual whose nomination is submitted to the Senate on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
