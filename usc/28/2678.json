{"tag":"section","attrib":{"id":"id52ec458b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2678"},"text":null,"children":[{"tag":"num","attrib":{"value":"2678"},"text":"§ 2678.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney fees; penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No attorney shall charge, demand, receive, or collect for services rendered, fees in excess of 25 per centum of any judgment rendered pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/b"},"text":"section 1346(b) of this title","children":[],"tail":" or any settlement made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2677"},"text":"section 2677 of this title","children":[],"tail":", or in excess of 20 per centum of any award, compromise, or settlement made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any attorney who charges, demands, receives, or collects for services rendered in connection with such claim any amount in excess of that allowed under this section, if recovery be had, shall be fined not more than $2,000 or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ec458c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/984"},"text":"62 Stat. 984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/506/s4"},"text":"Pub. L. 89–506, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-18"},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/307"},"text":"80 Stat. 307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ec458d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ec458e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 944 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753/s422"},"text":"Aug. 2, 1946, ch. 753, § 422","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/846"},"text":"60 Stat. 846","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “shall be guilty of a misdemeanor” and “shall, upon conviction thereof”, in the second sentence, were omitted in conformity with revised title 18, U.S.C., Crimes and Criminal Procedure (H.R. 1600, 80th Cong.). See sections 1 and 2 of said revised title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52ec458f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senate Revision Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was renumbered “2677” by Senate amendment. See 80th Congress Senate Report No. 1559.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ec4590-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ec4591-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/506"},"text":"Pub. L. 89–506","children":[],"tail":" raised the limitations on allowable attorneys fees from 10 to 20 percent for administrative settlements and from 20 to 25 percent for fees in cases after suit is filed and removed the requirement of agency or court allowance of the amount of attorneys fees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ec4592-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52ec4593-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/506"},"text":"Pub. L. 89–506","children":[],"tail":" applicable to claims accruing six months or more after "},{"tag":"date","attrib":{"date":"1966-07-18"},"text":"July 18, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/506/s10"},"text":"section 10 of Pub. L. 89–506","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
