{"tag":"section","attrib":{"id":"id52b7c885-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1713"},"text":null,"children":[{"tag":"num","attrib":{"value":"1713"},"text":"§ 1713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against loss by class members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The court may approve a proposed settlement under which any class member is obligated to pay sums to class counsel that would result in a net loss to the class member only if the court makes a written finding that nonmonetary benefits to the class member substantially outweigh the monetary loss.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b7c886-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/2/s3/a"},"text":"Pub. L. 109–2, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/7"},"text":"119 Stat. 7","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b7c887-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b7c888-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52b7c889-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any civil action commenced on or after ","children":[{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/2/s9"},"text":"section 9 of Pub. L. 109–2","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
