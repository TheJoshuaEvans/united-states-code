{"tag":"section","attrib":{"id":"id528a76b3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620"},"text":null,"children":[{"tag":"num","attrib":{"value":"620"},"text":"§ 620.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Judicial Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id528a76b4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the judicial branch of the Government a Federal Judicial Center, whose purpose it shall be to further the development and adoption of improved judicial administration in the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528a76b5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Center shall have the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id528a76b6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research and study of the operation of the courts of the United States, and to stimulate and coordinate such research and study on the part of other public and private persons and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76b7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and present for consideration by the Judicial Conference of the United States recommendations for improvement of the administration and management of the courts of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76b8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate, create, develop, and conduct programs of continuing education and training for personnel of the judicial branch of the Government and other persons whose participation in such programs would improve the operation of the judicial branch, including, but not limited to, judges, United States magistrate judges, clerks of court, probation officers, and persons serving as mediators and arbitrators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76b9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insofar as may be consistent with the performance of the other functions set forth in this section, to provide staff, research, and planning assistance to the Judicial Conference of the United States and its committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76ba-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Insofar ","children":[{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" as may be consistent with the performance of the other functions set forth in this section, to cooperate with the State Justice Institute in the establishment and coordination of research and programs concerning the administration of justice; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76bb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s620/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insofar as may be consistent with the performance of the other functions set forth in this section, to cooperate with and assist agencies of the Federal Government and other appropriate organizations in providing information and advice to further improvement in the administration of justice in the courts of foreign countries and to acquire information about judicial administration in foreign countries that may contribute to performing the other functions set forth in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528a76bc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/664"},"text":"81 Stat. 664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s227"},"text":"Pub. L. 95–598, title II, § 227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2665"},"text":"92 Stat. 2665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tII/s214"},"text":"Pub. L. 98–620, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3346"},"text":"98 Stat. 3346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/336/s6/b"},"text":"Pub. L. 99–336, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/639"},"text":"100 Stat. 639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIII/s303"},"text":"Pub. L. 100–702, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4648"},"text":"102 Stat. 4648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tVI/s602/a"},"text":"Pub. L. 102–572, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4514"},"text":"106 Stat. 4514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528a76bd-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528a76be-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528a76bf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “to stimulate, create, develop, and conduct programs of continuing education and training for personnel of the judicial branch of the Government, including, but not limited to, judges, clerks of court, probation officers, and United States magistrates;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/336"},"text":"Pub. L. 99–336","children":[],"tail":" struck out “referees,” after “judges,” and substituted “magistrates” for “commissioners”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" directed the amendment of par. (3) by striking out “referees,” and by substituting “magistrates” for “commissioners”, which amendment did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/b"},"text":"section 402(b) of Pub. L. 95–598","children":[],"tail":", as amended, set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id528a76c0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id528a76c1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States magistrate judges” substituted for “United States magistrates” in subsec. (b)(3) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528a76c2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s1101/a"},"text":"section 1101(a) of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s905"},"text":"section 905 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528a76c3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/336/s6/c"},"text":"Pub. L. 99–336, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/639"},"text":"100 Stat. 639","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/336/s6/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s288d"},"text":"section 288d of Title 2","children":[],"tail":", The Congress, and redesignating sections 1364 to 1366 of this title] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528a76c4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s216"},"text":"section 216 of Pub. L. 98–620","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10701"},"text":"section 10701 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id528a76c5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Best Practices","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/153/s6"},"text":"Pub. L. 114–153, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/384"},"text":"130 Stat. 384","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/153/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-05-11"},"text":"May 11, 2016","children":[],"tail":"], the Federal Judicial Center, using existing resources, shall develop recommended best practices for—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seizure of information and media storing the information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the securing of the information and media once seized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Judicial Center shall update the recommended best practices developed under subsection (a) from time to time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Submissions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Judicial Center shall provide a copy of the recommendations developed under subsection (a), and any updates made under subsection (b), to the—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Committee on the Judiciary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Committee on the Judiciary of the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id528a76c6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Intercircuit Conflicts and Structural Alternatives for Courts of Appeals by Federal Judicial Center","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s302"},"text":"Pub. L. 101–650, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5104"},"text":"104 Stat. 5104","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tV/s502/c"},"text":"Pub. L. 102–572, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4513"},"text":"106 Stat. 4513","children":[],"tail":", directed Board of the Federal Judicial Center to conduct study and submit report to Congress by "},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"Jan. 1, 1992","children":[],"tail":", on number and frequency of conflicts among judicial circuits in interpreting law that remain unresolved because they are not heard by the Supreme Court, and further directed Board to study full range of structural alternatives for Federal Courts of Appeals and submit report on the study to Congress and Judicial Conference of the United States, no later than 2 years and 9 months after "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
