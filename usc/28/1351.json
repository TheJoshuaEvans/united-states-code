{"tag":"section","attrib":{"id":"id52a24453-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1351"},"text":null,"children":[{"tag":"num","attrib":{"value":"1351"},"text":"§ 1351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consuls, vice consuls, and members of a diplomatic mission as defendant","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The district courts shall have original jurisdiction, exclusive of the courts of the States, of all civil actions and proceedings against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a24454-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1351/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consuls or vice consuls of foreign states; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a24455-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1351/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of a mission or members of their families (as such terms are defined in section 2 of the Diplomatic Relations Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a24456-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/934"},"text":"62 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s80/c"},"text":"May 24, 1949, ch. 139, § 80(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/101"},"text":"63 Stat. 101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/393/s8/a/1"},"text":"Pub. L. 95–393, § 8(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/810"},"text":"92 Stat. 810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a24457-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a24458-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 41(18), 371(8) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 24, par. 18, 256, par. 8, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1093"},"text":"36 Stat. 1093","children":[],"tail":", 1160)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suits,” and “all suits and proceedings” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a24459-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52a2445a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2 of the Diplomatic Relations Act, referred to in par. (2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s254a"},"text":"section 254a of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a2445b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/393"},"text":"Pub. L. 95–393","children":[],"tail":" substituted “Consuls, vice consuls, and members of a diplomatic mission as defendant” for “Consuls and vice consuls as defendants” in section catchline, designated existing provisions as introductory provision preceding par. (1), and in such introductory provision as so designated, substituted “civil actions and proceedings against—” for “actions and proceedings against consuls or vice consuls of foreign states”, and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “of all actions and proceedings” for “of any civil action”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a2445c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a2445d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/393"},"text":"Pub. L. 95–393","children":[],"tail":" effective at end of ninety-day period beginning on "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/393/s9"},"text":"section 9 of Pub. L. 95–393","children":[],"t