{"tag":"section","attrib":{"id":"id52324413-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s126"},"text":null,"children":[{"tag":"num","attrib":{"value":"126"},"text":"§ 126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vermont","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Vermont constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Bennington, Brattleboro, Burlington, Montpelier, Rutland, Saint Johnsbury, and Windsor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52324414-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/893"},"text":"62 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/312"},"text":"Pub. L. 88–312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-05-28"},"text":"May 28, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/201"},"text":"78 Stat. 201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s410"},"text":"Pub. L. 98–620, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3362"},"text":"98 Stat. 3362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52324415-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52324416-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 191 (","children":[{"tag":"ref",