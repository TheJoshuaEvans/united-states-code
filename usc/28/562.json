{"tag":"section","attrib":{"id":"id5274f252-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s562"},"text":null,"children":[{"tag":"num","attrib":{"value":"562"},"text":"§ 562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5274f253-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s562/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a vacancy in the office of a United States marshal, the Attorney General may designate a person to perform the functions of and act as marshal, except that the Attorney General may not designate to act as marshal any person who was appointed by the President to that office but with respect to such appointment the Senate has refused to give its advice and consent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5274f254-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s562/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person designated by the Attorney General under subsection (a) may serve until the earliest of the following events:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5274f255-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s562/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The entry into office of a United States marshal appointed by the President, pursuant to section 561(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5274f256-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s562/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expiration of the thirtieth day following the end of the next session of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5274f257-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s562/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such designee of the Attorney General is appointed by the President pursuant to section 561(c), but the Senate refuses to give its advice and consent to the appointment, the expiration of the thirtieth day following such refusal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5274f258-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7608/a/1"},"text":"Pub. L. 100–690, title VII, § 7608(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4513"},"text":"102 Stat. 4513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5274f259-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5274f25a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5274f25b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 562, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/619"},"text":"80 Stat. 619","children":[],"tail":", related to appointment of deputy marshals and clerical assistants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s7608/a/1"},"text":"Pub. L. 100–690, § 7608(a)(1)","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s561/f"},"text":"section 561(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
