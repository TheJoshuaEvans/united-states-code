{"tag":"section","attrib":{"id":"id52a6ff99-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1408"},"text":null,"children":[{"tag":"num","attrib":{"value":"1408"},"text":"§ 1408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue of cases under title 11","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1410"},"text":"section 1410 of this title","children":[],"tail":", a case under title 11 may be commenced in the district court for the district—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a6ff9a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1408/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the domicile, residence, principal place of business in the United States, or principal assets in the United States, of the person or entity that is the subject of such case have been located for the one hundred and eighty days immediately preceding such commencement, or for a longer portion of such one-hundred-and-eighty-day period than the domicile, residence, or principal place of business, in the United States, or principal assets in the United States, of such person were located in any other district; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a6ff9b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1408/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which there is pending a case under title 11 concerning such person’s affiliate, general partner, or partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a6ff9c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s102/a"},"text":"Pub. L. 98–353,