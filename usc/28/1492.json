{"tag":"section","attrib":{"id":"id52abe1de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1492"},"text":null,"children":[{"tag":"num","attrib":{"value":"1492"},"text":"§ 1492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional reference cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any bill, except a bill for a pension, may be referred by either House of Congress to the chief judge of the United States Court of Federal Claims for a report in conformity with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2509"},"text":"section 2509 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52abe1df-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/941"},"text":"62 Stat. 941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/681/s1"},"text":"Pub. L. 89–681, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/958"},"text":"80 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s133/b"},"text":"Pub. L. 97–164, title I, § 133(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/40"},"text":"96 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52abe1e0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52abe1e1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 257 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s151"},"text":"Mar. 3, 1911, ch. 231, § 151","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1138"},"text":"36 Stat. 1138","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains only the jurisdictional provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s257"},"text":"section 257 of title 28","children":[],"tail":", U.S.C., 1940 ed. The procedural provisions are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2509"},"text":"section 2509 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ae2ad2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ae2ad3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"hre