{"tag":"section","attrib":{"id":"id52a4b4d8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1368"},"text":null,"children":[{"tag":"num","attrib":{"value":"1368"},"text":"§ 1368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterclaims in unfair practices in international trade.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action based on a counterclaim raised pursuant to section 337(c) of the Tariff Act of 1930, to the extent that it arises out of the transaction or occurrence that is the subject matter of the opposing party’s claim in the proceeding under section 337(a) of that Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a4b4d9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIII/s321/b/3/A"},"text":"Pub. L. 103–465, title III, § 321(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4946"},"text":"108 Stat. 4946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b4da-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a4b4db-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52a4b4dc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 337 of the Tariff Act of 1930, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1337"},"text":"section 1337 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b4dd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a4b4de-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to complaints filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1337"},"text":"section 1337 of Title 19","children":[],"tail":", Customs Duties, on or after the date on which the World Trade Organization Agreement enters into force with respect to the United States ["},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"], or in cases under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1337"},"text":"section 1337 of Title 19","children":[],"tail":" in which no complaint is filed, with respect to investigations initiated under such section on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s322"},"text":"section 322 of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date of 1994 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1337"},"text":"section 1337 of Title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
