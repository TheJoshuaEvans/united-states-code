{"tag":"section","attrib":{"id":"id52db7ce9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2264"},"text":null,"children":[{"tag":"num","attrib":{"value":"2264"},"text":"§ 2264.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of Federal review; district court adjudications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52db7cea-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2264/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Whenever a State prisoner under capital sentence files a petition for habeas corpus relief to which this chapter applies, the district court shall only consider a claim or claims that have been raised and decided on the merits in the State courts, unless the failure to raise the claim properly is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52db7ceb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2264/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the result of State action in violation of the Constitution or laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7cec-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2264/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the result of the Supreme Court’s recognition of a new Federal right that is made retroactively applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7ced-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2264/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on a factual predicate that could not have been discovered through the exercise of due diligence in time to present the claim for State or Federal post-conviction review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52db7cee-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2264/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Following review subject to subsections (a), (d), and (e) of section 2254, the court shall rule on the claims properly before it.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52db7cef-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tI/s107/a"},"text":"Pub. L. 104–132, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1223"},"text":"110 Stat. 1223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52db7cf0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52db7cf1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52db7cf2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to cases pending on or after ","children":[{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s107/c"},"text":"section 107(c) of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2261"},"text":"section 2261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
