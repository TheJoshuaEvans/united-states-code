{"tag":"section","attrib":{"id":"id52a4b4df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369"},"text":null,"children":[{"tag":"num","attrib":{"value":"1369"},"text":"§ 1369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiparty, multiforum jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a4b4e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action involving minimal diversity between adverse parties that arises from a single accident, where at least 75 natural persons have died in the accident at a discrete location, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b4e1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a defendant resides in a State and a substantial part of the accident took place in another State or other location, regardless of whether that defendant is also a resident of the State where a substantial part of the accident took place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4e2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any two defendants reside in different States, regardless of whether such defendants are also residents of the same State or States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4e3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial parts of the accident took place in different States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b4e4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of Jurisdiction of District Courts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The district court shall abstain from hearing any civil action described in subsection (a) in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b4e5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial majority of all plaintiffs are citizens of a single State of which the primary defendants are also citizens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4e6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the claims asserted will be governed primarily by the laws of that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b4e7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rules and Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a4b4e8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimal diversity exists between adverse parties if any party is a citizen of a State and any adverse party is a citizen of another State, a citizen or subject of a foreign state, or a foreign state as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1603/a"},"text":"section 1603(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4e9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation is deemed to be a citizen of any State, and a citizen or subject of any foreign state, in which it is incorporated or has its principal place of business, and is deemed to be a resident of any State in which it is incorporated or licensed to do business or is doing business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4ea-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “injury” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52a4b4eb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical harm to a natural person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52a4b4ec-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical damage to or destruction of tangible property, but only if physical harm described in subparagraph (A) exists;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4ed-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “accident” means a sudden accident, or a natural event culminating in an accident, that results in death incurred at a discrete location by at least 75 natural persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a4b4ee-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” includes the District of Columbia, the Commonwealth of Puerto Rico, and any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b4ef-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intervening Parties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any action in a district court which is or could have been brought, in whole or in part, under this section, any person with a claim arising from the accident described in subsection (a) shall be permitted to intervene as a party plaintiff in the action, even if that person could not have brought an action in a district court as an original matter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a4b4f0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1369/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Judicial Panel on Multidistrict Litigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A district court in which an action under this section is pending shall promptly notify the judicial panel on multidistrict litigation of the pendency of the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a4b4f1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11020/b/1/A"},"text":"Pub. L. 107–273, div. C, title I, § 11020(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1826"},"text":"116 Stat. 1826","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b4f2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b4f3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a4b4f4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11020/c"},"text":"Pub. L. 107–273, div. C, title I, § 11020(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1829"},"text":"116 Stat. 1829","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/273/dC/tI/s11020/c"},"text":"“The amendments made by subsection (b) [enacting this section and sections 1697 and 1785 of this title and amending sections 1391 and 1441 of this title] shall apply to a civil action if the accident giving rise to the cause of action occurred on or after the 90th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
