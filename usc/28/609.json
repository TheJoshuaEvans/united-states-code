{"tag":"section","attrib":{"id":"id52880550-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Courts’ appointive power unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority of the courts to appoint their own administrative or clerical personnel shall not be limited by any provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52880551-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/915"},"text":"62 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52880552-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52880553-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed. § 446 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s304"},"text":"Mar. 3, 1911, ch. 231, § 304","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch501/s1"},"text":"Aug. 7, 1939, ch. 501, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1223"},"text":"53 Stat. 1223","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains the last clause of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s446/1"},"text":"section 446(1) of title 28","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A similar provision with respect to the Attorney General’s authority over United States attorneys and their assistants, and United States marshals and their deputies was omitted as unnecessary since there is nothing in this chapter that could affect such authority of the Attorney General.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s446"},"text":"section 446 of title 28","children":[],"tail":", U.S.C., 1940 ed., see "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"section 604 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
