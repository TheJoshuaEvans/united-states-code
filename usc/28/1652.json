{"tag":"section","attrib":{"id":"id52b55709-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1652"},"text":null,"children":[{"tag":"num","attrib":{"value":"1652"},"text":"§ 1652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State laws as rules of decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The laws of the several states, except where the Constitution or treaties of the United States or Acts of Congress otherwise require or provide, shall be regarded as rules of decision in civil actions in the courts of the United States, in cases where they apply.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b5570a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/944"},"text":"62 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b5570b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52b5570c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 725 (R.S. § 721).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Civil actions” was substituted for “trials at common law” to clarify the meaning of the Rules of Decision Act in the light of the Federal Rules of Civil Procedure. Such Act has been held to apply to suits in equity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
