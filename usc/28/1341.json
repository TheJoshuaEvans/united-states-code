{"tag":"section","attrib":{"id":"id52a243fc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1341"},"text":null,"children":[{"tag":"num","attrib":{"value":"1341"},"text":"§ 1341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes by States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall not enjoin, suspend or restrain the assessment, levy or collection of any tax under State law where a plain, speedy and efficient remedy may be had in the courts of such State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a243fd-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/932"},"text":"62 Stat. 932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a243fe-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a243ff-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(1) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 1, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1091"},"text":"36 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-14/ch283/s1"},"text":"May 14, 1934, ch. 283, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/775"},"text":"48 Stat. 775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1937-08-21/ch726/s1"},"text":"Aug. 21, 1937, ch. 726, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/50/738"},"text":"50 Stat. 738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1940-04-20/ch117"},"text":"Apr. 20, 1940, ch. 117","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/143"},"text":"54 Stat. 143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section restates the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/1"},"text":"section 41(1) of title 28","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/1"},"text":"section 41(1) of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 1331, 1332, 1342, 1345, 1354, and 1359 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “at law or in equity” before “in the courts of such State” were omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suit” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “under State law” were substituted for “imposed by or pursuant to the laws of any State” for the same reason.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
