{"tag":"section","attrib":{"id":"id52a6ff76-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1405"},"text":null,"children":[{"tag":"num","attrib":{"value":"1405"},"text":"§ 1405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation or alteration of district or division","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Actions or proceedings pending at the time of the creation of a new district or division or transfer of a county or territory from one division or district to another may be tried in the district or division as it existed at the institution of the action or proceeding, or in the district or division so created or to which the county or territory is so transferred as the parties shall agree or the court direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a6ff77-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/937"},"text":"62 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ff78-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a6ff79-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 121 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s59"},"text":"Mar. 3, 1911, ch. 231, § 59","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1103"},"text":"36 Stat. 1103","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Enforcement of liens in like circumstances is provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1656"},"text":"section 1656 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Remainder of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s121"},"text":"section 121 of title 28","children":[],"tail":", U.S.C., 1940 ed., is incorporated in section 3240 of revised title 18, Crimes and Criminal Procedure (H.R. 1600, 80th Cong.)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
