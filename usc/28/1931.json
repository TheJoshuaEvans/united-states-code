o practice, as prescribed by the Judicial Conference of the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1914"},"text":"section 1914 of title 28","children":[],"tail":", United States Code, $30 of that portion of the fee exceeding $20 shall be deposited into the special fund of the Treasury established under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1931"},"text":"section 1931 of title 28","children":[],"tail":", United States Code. Any portion exceeding $5 of the fee for a duplicate certificate of admission or certificate of good standing, as prescribed by the Judicial Conference of the United States pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1914"},"text":"section 1914 of title 28","children":[],"tail":", United States Code, shall be deposited into the special fund of the Treasury established under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1931"},"text":"section 1931 of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Bankruptcy Complaint Filing Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fee collected for filing an adversary complaint in a bankruptcy proceeding, as established in Item 6 of the Bankruptcy Court Miscellaneous Fee Schedule prescribed by the Judicial Conference of the United States pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1930/b"},"text":"section 1930(b) of title 28","children":[],"tail":", United States Code, the portion of the fee exceeding $120 shall be deposited into the special fund of the Treasury established under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1931"},"text":"section 1931 of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall take effect 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52c86a14-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Collection and Deposit of Miscellaneous Bankruptcy Fees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/162/tIV/s406/b"},"text":"Pub. L. 101–162, title IV, § 406(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1016"},"text":"103 Stat. 1016","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/121/tI/s111/a/3"},"text":"Pub. L. 103–121, title I, § 111(a)(3)","children":[],"tail":", (b)(4), "},{"tag":"date","attrib":{"date":"1993-10-27"},"text":"Oct. 27, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1164"},"text":"107 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/1/tI/s113"},"text":"Pub. L. 106–113, div. B, § 1000(a)(1) [title I, § 113]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–20; "},{"tag":"ref","attrib":{"href":"/us/pl/106/518/tII