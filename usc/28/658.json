{"tag":"section","attrib":{"id":"id5291a231-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s658"},"text":null,"children":[{"tag":"num","attrib":{"value":"658"},"text":"§ 658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of arbitrators and neutrals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a232-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s658/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The district court shall, subject to regulations approved by the Judicial Conference of the United States, establish the amount of compensation, if any, that each arbitrator or neutral shall receive for services rendered in each case under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a233-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s658/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation Allowances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations prescribed by the Director of the Administrative Office of the United States Courts, a district court may reimburse arbitrators and other neutrals for actual transportation expenses necessarily incurred in the performance of duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a234-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIX/s901/a"},"text":"Pub. L. 100–702, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4662"},"text":"102 Stat. 4662","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/315/s10"},"text":"Pub. L. 105–315, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2997"},"text":"112 Stat. 2997","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a235-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a236-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a237-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/315"},"text":"Pub. L. 105–315","children":[],"tail":" amended section generally, substituting provisions relating to compensation of arbitrators and neutrals for provisions relating to district courts that may authorize arbitration."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
