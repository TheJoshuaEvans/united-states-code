{"tag":"section","attrib":{"id":"id5291a265-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s674"},"text":null,"children":[{"tag":"num","attrib":{"value":"674"},"text":"§ 674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Librarian","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a266-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Supreme Court may appoint a librarian, whose salary it shall fix, and who shall be subject to removal by the Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a267-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The librarian shall, with the approval of the Chief Justice, appoint necessary assistants and fix their compensation and make rules governing the use of the library.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a268-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s674/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" He shall select and acquire by purchase, gift, bequest, or exchange, such books, pamphlets, periodicals, microfilm and other processed copy as may be required by the Court for its official use and for the reasonable needs of its bar.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a269-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s674/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The librarian shall certify to the marshal for payment vouchers covering expenditures for the purchase of such books and other material, and for binding, rebinding and repairing the same.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a26a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/919"},"text":"62 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s206/d"},"text":"Pub. L. 92–310, title II, § 206(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/203"},"text":"86 Stat. 203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a26b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5291a26c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section gives statutory recognition to the office of librarian. For many years the Court has appointed its librarian directly through the Chief Justice, rather than through the marshal. Other members of the library staff are appointed by the librarian, with the approval of the Chief Justice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Under this section the marshal will not be required to certify to expenditures for some 2,000 books bought for the library each year but this will be the duty of the librarian.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a26d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a26e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1972—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out sentence which required the librarian to furnish a bond."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
