{"tag":"section","attrib":{"id":"id52bc82cc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1822"},"text":null,"children":[{"tag":"num","attrib":{"value":"1822"},"text":"§ 1822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competency of interested persons; share of penalties payable","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person interested in a share of any fine, penalty or forfeiture incurred under any Act of Congress, may be examined as a witness in any proceeding for the recovery of such fine, penalty or forfeiture by any party thereto. Such examination shall not deprive the witness of his share.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52bc82cd-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/950"},"text":"62 Stat. 950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52bc82ce-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52bc82cf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s644"},"text":"section 644 of title 18","children":[],"tail":", U.S.C., 1940 ed., Criminal Code and Criminal Procedure, R.S. § 5295."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
