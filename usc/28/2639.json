{"tag":"section","attrib":{"id":"id52e9d4cf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639"},"text":null,"children":[{"tag":"num","attrib":{"value":"2639"},"text":"§ 2639.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Burden of proof; evidence of value","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e9d4d0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52e9d4d1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, in any civil action commenced in the Court of International Trade under section 515, 516, or 516A of the Tariff Act of 1930, the decision of the Secretary of the Treasury, the administering authority, or the International Trade Commission is presumed to be correct. The burden of proving otherwise shall rest upon the party challenging such decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4d2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of paragraph (1) of this subsection shall not apply to any civil action commenced in the Court of International Trade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1582"},"text":"section 1582 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d4d3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil action described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1581/h"},"text":"section 1581(h) of this title","children":[],"tail":", the person commencing the action shall have the burden of making the demonstration required by such section by clear and convincing evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d4d4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Where the value of merchandise or any of its components is in issue in any civil action in the Court of International Trade—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52e9d4d5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports or depositions of consuls, customs officers, and other officers of the United States, and depositions and affidavits of other persons whose attendance cannot reasonably be had, may be admitted into evidence when served upon the opposing party as prescribed by the rules of the court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4d6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2639/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price lists and catalogs may be admitted in evidence when duly authenticated, relevant, and material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e9d4d7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s301"},"text":"Pub. L. 96–417, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1736"},"text":"94 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e9d4d8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e9d4d9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52e9d4da-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 515, 516, and 516A of the Tariff Act of 1930, referred to in subsec. (a)(1), are classified to sections 1515, 1516, and 1516a, respectively, of Title 19, Customs Duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52e9d4db-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2639, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/982"},"text":"62 Stat. 982","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s120"},"text":"Pub. L. 91–271, title I, § 120","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/281"},"text":"84 Stat. 281","children":[],"tail":", provided for retrial or rehearing, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2646"},"text":"section 2646 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e9d4dc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52e9d4dd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) of this section applicable with respect to civil actions commenced on or after the 90th day after ","children":[{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/c/1/A"},"text":"section 701(c)(1)(A) of Pub. L. 96–417","children":[],"tail":", set out as an Effective Date of 1980 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b) of this section applicable with respect to civil actions commenced on or after ","children":[{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/b/1/B"},"text":"section 701(b)(1)(B) of Pub. L. 96–417","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
