{"tag":"section","attrib":{"id":"id52965d27-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797"},"text":null,"children":[{"tag":"num","attrib":{"value":"797"},"text":"§ 797.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall of retired judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52965d28-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52965d29-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any judge of the United States Court of Federal Claims who has retired from regular active service under subchapter III of chapter 83, or chapter 84, of title 5 shall be known and designated as a senior judge and may perform duties as a judge when recalled pursuant to subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52965d2a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any judge of the Court of Federal Claims receiving an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s178/c"},"text":"section 178(c) of this title","children":[],"tail":" (pertaining to disability) who, in the estimation of the chief judge, has recovered sufficiently to render judicial service, shall be known and designated as a senior judge and may perform duties as a judge when recalled under subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965d2b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge of the Court of Federal Claims may, whenever he deems it advisable, recall any senior judge, with such judge’s consent, to perform such duties as a judge and for such period of time as the chief judge may specify.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965d2c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any senior judge performing duties pursuant to this section shall not be counted as a judge for purposes of the number of judgeships authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965d2d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s797/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any senior judge, while performing duties pursuant to this section, shall be paid the same allowances for travel and other expenses as a judge in active service. Such senior judge shall also receive from the Court of Federal Claims supplemental pay in an amount sufficient, when added to his retirement annuity, to equal the salary of a judge in active service for the same period or periods of time. Such supplemental pay shall be paid in the same manner as the salary of a judge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52965d2e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/375/s2"},"text":"Pub. L. 92–375, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-10"},"text":"Aug. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/529"},"text":"86 Stat. 529","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s121/f/1"},"text":"Pub. L. 97–164, title I, § 121(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/35"},"text":"96 Stat. 35","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/651/tII/s202/c"},"text":"Pub. L. 99–651, title II, § 202(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3648"},"text":"100 Stat. 3648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX"},"text":"Pub. L. 102–572, title IX","children":[],"tail":", §§ 902(a), 904(b), "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":", 4517; "},{"tag":"ref","attrib":{"href":"/us/pl/106/518/tIII/s308"},"text":"Pub. L. 106–518, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2419"},"text":"114 Stat. 2419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52965d2f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52965d30-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52965d31-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518"},"text":"Pub. L. 106–518","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/a/1"},"text":"Pub. L. 102–572, § 902(a)(1)","children":[],"tail":", substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/a/2"},"text":"Pub. L. 102–572, § 902(a)(2)","children":[],"tail":", substituted “Court of Federal Claims” for “Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":", §§ 902(a)(2), 904(b), substituted “Court of Federal Claims” for “Claims Court” and struck out “civil service” before “retirement annuity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/651"},"text":"Pub. L. 99–651","children":[],"tail":" inserted reference to chapter 84 of title 5."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “judges” for “commissioners” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “Any judge of the United States Claims Court who has retired from regular active service under subchapter III of chapter 83 of title 5 shall be known and designated as a senior judge and may perform duties as a judge when recalled pursuant to subsection (b) of this section” for “Any commissioner who has retired from regular active service under the Civil Service Retirement Act shall be known and designated as a senior commissioner and may perform duties as a commissioner when recalled pursuant to subsection (b) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “The chief judge of the Claims Court may, whenever he deems it advisable, recall any senior judge, with such judge’s consent, to perform such duties as a judge and for such period of time as the chief judge may specify” for “The United States Court of Claims, whenever it deems such action advisable, may recall any senior commissioner, with the latter’s acquiescence, to perform such duties as a commissioner and for such period of time as the court may specify”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “Any senior judge performing duties pursuant to this section shall not be counted as a judge for purposes of the number of judgeships authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"” for “Any senior commissioner performing duties pursuant to this section shall not be counted as a commissioner for purposes of the number of commissioner positions authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s792"},"text":"section 792 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “judge” for “commissioner” wherever appearing, “Such senior judge” for “He”, and “Claims Court” for “Court of Claims”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52965d32-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52965d33-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52965d34-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/651"},"text":"Pub. L. 99–651","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/651/s203"},"text":"section 203 of Pub. L. 99–651","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s155"},"text":"section 155 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52965d35-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"te