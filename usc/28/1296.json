{"tag":"section","attrib":{"id":"id529d893c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1296"},"text":null,"children":[{"tag":"num","attrib":{"value":"1296"},"text":"§ 1296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of certain agency actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id529d893d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1296/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the provisions of chapter 179, the United States Court of Appeals for the Federal Circuit shall have jurisdiction over a petition for review of a final decision under chapter 5 of title 3 of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id529d893e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1296/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate agency (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s454"},"text":"section 454 of title 3","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id529d893f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1296/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Labor Relations Authority made under part D of subchapter II of chapter 5 of title 3, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7123"},"text":"section 7123 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id529d8940-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1296/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor or the Occupational Safety and Health Review Commission, made under part C of subchapter II of chapter 5 of title 3.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id529d8941-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1296/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Petition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any petition for review under this section must be filed within 30 days after the date the petitioner receives notice of the final decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id529d8942-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/a/1"},"text":"Pub. L. 104–331, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4068"},"text":"110 Stat. 4068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id529d8943-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id529d8944-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id529d8945-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1296, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s127/a"},"text":"Pub. L. 97–164, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/39"},"text":"96 Stat. 39","children":[],"tail":", related to precedence of cases in United States Court of Appeals for the Federal Circuit, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/29/C"},"text":"Pub. L. 98–620, title IV, § 402(29)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3359"},"text":"98 Stat. 3359","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id529d8946-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/d"},"text":"Pub. L. 104–331, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4071"},"text":"110 Stat. 4071","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/331/s3/d"},"text":"“The amendments made by this section [enacting this section and sections 1413 and 3901 to 3908 of this title and amending sections 1346 and 2402 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
