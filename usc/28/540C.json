{"tag":"section","attrib":{"id":"id52703760-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C"},"text":null,"children":[{"tag":"num","attrib":{"value":"540C"},"text":"§ 540C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FBI police","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52703761-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52703762-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703763-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FBI ","children":[{"tag":"inline","attrib":{},"text":"buildings and grounds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52703764-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “FBI buildings and grounds” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52703765-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the whole or any part of any building or structure which is occupied under a lease or otherwise by the Federal Bureau of Investigation and is subject to supervision and control by the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703766-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land upon which there is situated any building or structure which is occupied wholly by the Federal Bureau of Investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703767-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any enclosed passageway connecting 2 or more buildings or structures occupied in whole or in part by the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52703768-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “FBI buildings and grounds” includes adjacent streets and sidewalks not to exceed 500 feet from such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703769-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FBI police","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “FBI police” means the permanent police force established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270376a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of FBI Police; Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5270376b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the supervision of the Attorney General, the Director may establish a permanent police force, to be known as the FBI police.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270376c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The FBI police shall perform such duties as the Director may prescribe in connection with the protection of persons and property within FBI buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270376d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniformed representative","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director, or designated representative duly authorized by the Attorney General, may appoint uniformed representatives of the Federal Bureau of Investigation as FBI police for duty in connection with the policing of all FBI buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270376e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5270376f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with regulations prescribed by the Director and approved by the Attorney General, the FBI police may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52703770-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" police the FBI buildings and grounds for the purpose of protecting persons and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703771-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the performance of duties necessary for carrying out subparagraph (A), make arrests and otherwise enforce the laws of the United States, including the laws of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703772-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry firearms as may be required for the performance of duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703773-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent breaches of the peace and suppress affrays and unlawful assemblies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703774-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the same powers as sheriffs and constables when policing FBI buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52703775-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority and policing powers of FBI police under this paragraph shall not include the service of civil process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703776-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay and benefits.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52703777-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rates of basic pay, salary schedule, pay provisions, and benefits for members of the FBI police shall be equivalent to the rates of basic pay, salary schedule, pay provisions, and benefits applicable to members of the United States Secret Service Uniformed Division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52703778-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pay and benefits for the FBI police under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52703779-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be established by regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5270377a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply with respect to pay periods beginning after ","children":[{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5270377b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not result in any decrease in the rates of pay or benefits of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270377c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Metropolitan Police Force","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect the authority of the Metropolitan Police Force of the District of Columbia with respect to FBI buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5270377d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11024/a"},"text":"Pub. L. 107–273, div. C, title I, § 11024(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1830"},"text":"116 Stat. 1830","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5270377e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5270377f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52703780-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Another section 540C, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s824/a"},"text":"Pub. L. 107–306, title VIII, § 824(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2428"},"text":"116 Stat. 2428","children":[],"tail":", related to annual report on activities of Federal Bureau of Investigation personnel outside the United States. "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tIII/s361/i"},"text":"Pub. L. 108–177, title III, § 361(i)","children":[],"tail":", (n), "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2625"},"text":"117 Stat. 2625","children":[],"tail":", 2626, which, under the heading “Annual Report on Activities of FBI Personnel Outside the United States”, directed the repeal of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s540C"},"text":"section 540C of title 28","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2003-12-31"},"text":"Dec. 31, 2003","children":[],"tail":", was executed by repealing the section 540C added by "},{"tag":"ref","attrib":{"href":"/us/pl/107/306"},"text":"Pub. L. 107–306","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52703781-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id52703782-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of the functions, personnel, assets, and obligations of the United States Secret Service, including the functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 381, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
