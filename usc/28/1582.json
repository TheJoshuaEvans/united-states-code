 1641(d)(2)(A), 1671c(i)(2), and 1673c(i)(2), respectively, of Title 19, Customs Duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52b09bbc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1582, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/943"},"text":"62 Stat. 943","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s110"},"text":"Pub. L. 91–271, title I, § 110","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/278"},"text":"84 Stat. 278","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1979-07-26"},"text":"July 26, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/96/39/tX/s1001/b/4/B"},"text":"Pub. L. 96–39, title X, § 1001(b)(4)(B)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/305"},"text":"93 Stat. 305","children":[],"tail":", related to the jurisdiction of the Customs Court, prior to the general revision of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52b09bbd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" inserted “593A,” after “592,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"P