{"tag":"section","attrib":{"id":"id52b09bb4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1582"},"text":null,"children":[{"tag":"num","attrib":{"value":"1582"},"text":"§ 1582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions commenced by the United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Court of International Trade shall have exclusive jurisdiction of any civil action which arises out of an import transaction and which is commenced by the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52b09bb5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1582/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recover a civil penalty under section 592, 593A, 641(b)(6), 641(d)(2)(A), 704(i)(2), or 734(i)(2) of the Tariff Act of 1930;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52b09bb6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1582/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recover upon a bond relating to the importation of merchandise required by the laws of the United States or by the Secretary of the Treasury; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52b09bb7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1582/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recover customs duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52b09bb8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tII/s201"},"text":"Pub. L. 96–417, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"dat