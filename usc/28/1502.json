{"tag":"section","attrib":{"id":"id52ae2b33-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treaty cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by Act of Congress, the United States Court of Federal Claims shall not have jurisdiction of any claim against the United States growing out of or dependent upon any treaty entered into with foreign nations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ae2b34-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/942"},"text":"62 Stat. 942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s88"},"text":"May 24, 1949, ch. 139, § 88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/102"},"text":"63 Stat. 102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s133/e/1"},"text":"Pub. L. 97–164, title I, § 133(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/40"},"text":"96 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ae2b35-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ae2b36-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ae2b37-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 259 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s153"},"text":"Mar. 3, 1911, ch. 231, § 153","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1138"},"text":"36 Stat. 1138","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Phrase “Except as otherwise provided by enactment of Congress” was inserted to cover cases where special Acts confer jurisdiction. (See ","children":[{"tag":"i","attrib":{},"text":"Sioux Tribe of Indians v. United States","children":[],"tail":", 1943, 97 Ct.Cl. 613, certiorari denied 63 S.Ct. 992, 318 U.S. 789, 87 L.Ed. 1155, and "},{"tag":"i","attrib":{},"text":"In re United States","children":[],"tail":", 1873, 17 Wall. 439, 443, 21 L.Ed. 696.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “not pending therein on ","children":[{"tag":"date","attrib":{"date":"1862-12-01"},"text":"December 1, 1862","children":[],"tail":",” were omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ae2b38-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section, in amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1502"},"text":"section 1502 of title 28","children":[],"tail":", U.S.C., conforms with the provisions of act of "},{"tag":"date","attrib":{"date":"1946-08-13"},"text":"August 13, 1946","children":[],"tail":" (ch. 959, § 25, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1056"},"text":"60 Stat. 1056","children":[],"tail":"), which affected section 153 of the Judicial Code of 1911 by striking therefrom the words “or with Indian tribes.” Such section 153 of the Judicial Code was the source of such section 1502."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ae2b39-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ae2b3a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “United States Claims Court” for “Court of Claims”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", struck out “or with Indian tribes” after “foreign nations”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ae2b3b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Relat