{"tag":"section","attrib":{"id":"id525d24ce-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507"},"text":null,"children":[{"tag":"num","attrib":{"value":"507"},"text":"§ 507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Attorney General for Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525d24cf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall appoint, with the approval of the President, an Assistant Attorney General for Administration, who shall perform such duties as the Attorney General may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525d24d0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The position of Assistant Attorney General for Administration is in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525d24d1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901"},"text":"section 901 of title 31","children":[],"tail":", United States Code, the Assistant Attorney General for Administration shall be the Chief Financial Officer of the Department of Justice."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525d24d2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/612"},"text":"80 Stat. 612","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/1/tI/s111"},"text":"Pub. L. 106–113, div. B, § 1000(a)(1) [title I, § 111]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–20.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525d24d3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id525d24d4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id525d24d5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[Uncodified].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1950 Reorg. Plan No. 2, § 5 eff. ","children":[{"tag":"html:span","attrib":{},"text":"May 24, 1950","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1261"},"text":"64 Stat. 1261","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The title of the position was changed to “Assistant Attorney General for Administration” by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1964-08-14/s307"},"text":"§ 307 of the Act of Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/432"},"text":"78 Stat. 432","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “competitive service” are substituted for “classified civil service” because the term “classified civil service” formerly used to designate the merit system established by the Civil Service Act of 1883 has become ambiguous due to the creation of the “classified” pay system. The term “competitive service” is now customarily used, and appears throughout title 5, United States Code, in place of “classified civil service”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “There shall be in the Department of Justice” are omitted as unnecessary as the title of the position and the fact of appointment by the Attorney General establish the location of the position in the Department of Justice.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last 12 words of section 5 of the Reorganization Plan are omitted on authority of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-05/ch369/s1101"},"text":"Act of June 5, 1952, ch. 369, § 1101","children":[],"tail":" (3d proviso), "},{"tag":"ref","attrib":{"href":"/us/stat/66/121"},"text":"66 Stat. 121","children":[],"tail":". The salary of the position is now fixed by "},{"tag":"ref","attrib":{"href":"/us/act/1964-08-14/s303/e"},"text":"§ 303(e) of the Act of Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/420"},"text":"78 Stat. 420","children":[],"tail":", which is codified in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525d24d6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id525d24d7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 507, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/910"},"text":"62 Stat. 910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s71"},"text":"May 24, 1949, ch. 139, § 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/100"},"text":"63 Stat. 100","children":[],"tail":", related to duties of United States attorneys, and to supervision by the Attorney General, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", and reenactment in sections 509 and 547 of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"section 4(c) of Pub. L. 89–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id525d24d8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
