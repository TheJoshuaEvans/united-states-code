{"tag":"section","attrib":{"id":"id52c3aecf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1872"},"text":null,"children":[{"tag":"num","attrib":{"value":"1872"},"text":"§ 1872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issues of fact in Supreme Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all original actions at law in the Supreme Court against citizens of the United States, issues of fact shall be tried by a jury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c3aed0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/953"},"text":"62 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3aed1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c3aed2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 343 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s235"},"text":"Mar. 3, 1911, ch. 231, § 235","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1156"},"text":"36 Stat. 1156","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
