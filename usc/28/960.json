{"tag":"section","attrib":{"id":"id52965d98-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960"},"text":null,"children":[{"tag":"num","attrib":{"value":"960"},"text":"§ 960.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52965d99-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any officers and agents conducting any business under authority of a United States court shall be subject to all Federal, State and local taxes applicable to such business to the same extent as if it were conducted by an individual or corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965d9a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A tax under subsection (a) shall be paid on or before the due date of the tax under applicable nonbankruptcy law, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52965d9b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax is a property tax secured by a lien against property that is abandoned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s554"},"text":"section 554 of title 11","children":[],"tail":", within a reasonable period of time after the lien attaches, by the trustee in a case under title 11; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52965d9c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the tax is excused under a specific provision of title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965d9d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a case pending under chapter 7 of title 11, payment of a tax may be deferred until final distribution is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s726"},"text":"section 726 of title 11","children":[],"tail":", if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52965d9e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax was not incurred by a trustee duly appointed or elected under chapter 7 of title 11; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52965d9f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s960/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the due date of the tax, an order of the court makes a finding of probable insufficiency of funds of the estate to pay in full the administrative expenses allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s503/b"},"text":"section 503(b) of title 11","children":[],"tail":" that have the same priority in distribution under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s726/b"},"text":"section 726(b) of title 11","children":[],"tail":" as the priority of that tax."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52965da0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/927"},"text":"62 Stat. 927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVII/s712/a"},"text":"Pub. L. 109–8, title VII, § 712(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/127"},"text":"119 Stat. 127","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52965da1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52965da2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 124a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch585"},"text":"June 18, 1934, ch. 585","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/993"},"text":"48 Stat. 993","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A proviso in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s124a"},"text":"section 124a of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to taxes accruing prior to the effective date of the 1934 act, was omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s124a"},"text":"section 124a of title 28","children":[],"tail":", U.S.C., 1940 ed., to specific officers was omitted as covered by the words “Any officers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Word “Federal” was added before “State” in recognition of the liability of such officers for Federal taxes under the revenue laws.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52965da3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52965da4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52965da5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52965da6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
