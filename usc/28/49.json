{"tag":"section","attrib":{"id":"id52263697-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49"},"text":null,"children":[{"tag":"num","attrib":{"value":"49"},"text":"§ 49.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of judges to division to appoint independent counsels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52263698-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning with the two-year period commencing on the date of the enactment of this section, three judges or justices shall be assigned for each successive two-year period to a division of the United States Court of Appeals for the District of Columbia to be the division of the court for the purpose of appointing independent counsels. The Clerk of the United States Court of Appeals for the District of Columbia Circuit shall serve as the clerk of such division of the court and shall provide such services as are needed by such division of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52263699-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subsection (f) of this section, assignment to such division of the court shall not be a bar to other judicial assignments during the term of such division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5226369a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In assigning judges or justices to sit on such division of the court, priority shall be given to senior circuit judges and retired justices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5226369b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Justice of the United States shall designate and assign three circuit court judges or justices, one of whom shall be a judge of the United States Court of Appeals for the District of Columbia, to such division of the court. Not more than one judge or justice or senior or retired judge or justice may be named to such division from a particular court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5226369c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy in such division of the court shall be filled only for the remainder of the two-year period in which such vacancy occurs and in the same manner as initial assignments to such division were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5226369d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s49/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in chapter 40 of this title, no member of such division of the court who participated in a function conferred on the division under chapter 40 of this title involving an independent counsel shall be eligible to participate in any judicial proceeding concerning a matter which involves such independent counsel while such independent counsel is serving in that office or which involves the exercise of such independent counsel’s official duties, regardless of whether such independent counsel is still serving in that office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5226369e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVI/s602/a"},"text":"Pub. L. 95–521, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1873"},"text":"92 Stat. 1873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/b/1"},"text":"Pub. L. 97–409, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-03"},"text":"Jan. 3, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2039"},"text":"96 Stat. 2039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI/s144/g/3"},"text":"Pub. L. 99–554, title I, § 144(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3097"},"text":"100 Stat. 3097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/191"},"text":"Pub. L. 100–191","children":[],"tail":", §§ 4, 5(a), "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1307"},"text":"101 Stat. 1307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5226369f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522636a0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id522636a1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is ","children":[{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522636a2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191/s4"},"text":"Pub. L. 100–191, § 4","children":[],"tail":", inserted at end: “The Clerk of the United States Court of Appeals for the District of Columbia Circuit shall serve as the clerk of such division of the court and shall provide such services as are needed by such division of the court.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191/s5/a"},"text":"Pub. L. 100–191, § 5(a)","children":[],"tail":", substituted “involving an independent counsel” for “involving a independent counsel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" substituted “chapter 40” for “chapter 39” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/b/1/B"},"text":"Pub. L. 97–409, § 2(b)(1)(B)","children":[],"tail":", substituted “independent counsels” for “special prosecutors” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/b/1/B"},"text":"Pub. L. 97–409, § 2(b)(1)(B)","children":[],"tail":", substituted “independent counsels” for “special prosecutors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/b/1/A"},"text":"Pub. L. 97–409, § 2(b)(1)(A)","children":[],"tail":", (C), substituted “independent counsel” for “special prosecutor” wherever appearing and “independent counsel’s” for “special prosecutor’s”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id522636a3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id522636a4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s302/a"},"text":"section 302(a) of Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id522636a5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/521/s604"},"text":"section 604 of Pub. L. 95–521","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"section 591 o