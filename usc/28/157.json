{"tag":"section","attrib":{"id":"id523e2b37-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157"},"text":null,"children":[{"tag":"num","attrib":{"value":"157"},"text":"§ 157.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id523e2b38-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each district court may provide that any or all cases under title 11 and any or all proceedings arising under title 11 or arising in or related to a case under title 11 shall be referred to the bankruptcy judges for the district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id523e2b39-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id523e2b3a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bankruptcy judges may hear and determine all cases under title 11 and all core proceedings arising under title 11, or arising in a case under title 11, referred under subsection (a) of this section, and may enter appropriate orders and judgments, subject to review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s158"},"text":"section 158 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id523e2b3b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Core proceedings include, but are not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id523e2b3c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" matters concerning the administration of the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b3d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowance or disallowance of claims against the estate or exemptions from property of the estate, and estimation of claims or interests for the purposes of confirming a plan under chapter 11, 12, or 13 of title 11 but not the liquidation or estimation of contingent or unliquidated personal injury tort or wrongful death claims against the estate for purposes of distribution in a case under title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b3e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counterclaims by the estate against persons filing claims against the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b3f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orders in respect to obtaining credit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b40-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orders to turn over property of the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b41-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceedings to determine, avoid, or recover preferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b42-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motions to terminate, annul, or modify the automatic stay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b43-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceedings to determine, avoid, or recover fraudulent conveyances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b44-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determinations as to the dischargeability of particular debts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b45-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objections to discharges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b46-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determinations of the validity, extent, or priority of liens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b47-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirmations of plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b48-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orders approving the use or lease of property, including the use of cash collateral;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b49-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" orders approving the sale of property other than property resulting from claims brought by the estate against persons who have not filed claims against the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b4a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other proceedings affecting the liquidation of the assets of the estate or the adjustment of the debtor-creditor or the equity security holder relationship, except personal injury tort or wrongful death claims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id523e2b4b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognition of foreign proceedings and other matters under chapter 15 of title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id523e2b4c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The bankruptcy judge shall determine, on the judge’s own motion or on timely motion of a party, whether a proceeding is a core proceeding under this subsection or is a proceeding that is otherwise related to a case under title 11. A determination that a proceeding is not a core proceeding shall not be made solely on the basis that its resolution may be affected by State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id523e2b4d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-core proceedings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s157/b/2/B"},"text":"section 157(b)(2)(B) of title 28","children":[],"tail":", United States Code, shall not be subject to the mandatory abstention provisions of section 1334(c)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id523e2b4e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district court shall order that personal injury tort and wrongful death claims shall be tried in the district court in which the bankruptcy case is pending, or in the district court in the district in which the claim arose, as determined by the district court in which the bankruptcy case is pending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id523e2b4f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id523e2b50-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bankruptcy judge may hear a proceeding that is not a core proceeding but that is otherwise related to a case under title 11. In such proceeding, the bankruptcy judge shall submit proposed findings of fact and conclusions of law to the district court, and any final order or judgment shall be entered by the district judge after considering the bankruptcy judge’s proposed findings and conclusions and after reviewing de novo those matters to which any party has timely and specifically objected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id523e2b51-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of paragraph (1) of this subsection, the district court, with the consent of all the parties to the proceeding, may refer a proceeding related to a case under title 11 to a bankruptcy judge to hear and determine and to enter appropriate orders and judgments, subject to review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s158"},"text":"section 158 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id523e2b52-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district court may withdraw, in whole or in part, any case or proceeding referred under this section, on its own motion or on timely motion of any party, for cause shown. The district court shall, on timely motion of a party, so withdraw a proceeding if the court determines that resolution of the proceeding requires consideration of both title 11 and other laws of the United States regulating organizations or activities affecting interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id523e2b53-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s157/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the right to a jury trial applies in a proceeding that may be heard under this section by a bankruptcy judge, the bankruptcy judge may conduct the jury trial if specially designated to exercise such jurisdiction by the district court and with the express consent of all the parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id523e2b54-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s104/a"},"text":"Pub. L. 98–353, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/340"},"text":"98 Stat. 340","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI"},"text":"Pub. L. 99–554, title I","children":[],"tail":", §§ 143, 144(b), "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3096"},"text":"100 Stat. 3096","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tI/s112"},"text":"Pub. L. 103–394, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4117"},"text":"108 Stat. 4117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s802/c/1"},"text":"Pub. L. 109–8, title VIII, § 802(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/145"},"text":"119 Stat. 145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id523e2b55-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id523e2b56-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id523e2b57-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(2)(P). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" added subpar. (P)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":", in subpar. (B) substituted “interests” for “interest” and inserted reference to chapter 12, and in subpar. (G) inserted a comma after “annul”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id523e2b58-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id523e2b59-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id523e2b5a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id523e2b5b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s302/a"},"text":"section 302(a) of Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
