{"tag":"section","attrib":{"id":"id5291a27f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677"},"text":null,"children":[{"tag":"num","attrib":{"value":"677"},"text":"§ 677.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counselor to the Chief Justice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a280-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Justice of the United States may appoint a Counselor who shall serve at the pleasure of the Chief Justice and shall perform such duties as may be assigned to him by the Chief Justice. The salary payable to the Counselor shall be fixed by the Chief Justice at a rate which shall not exceed the salary payable to the Director of the Administrative Office of the United States Courts. The Counselor may elect to bring himself within the same retirement program available to the Director of the Administrative Office of the United States Courts, as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s611"},"text":"section 611 of this title","children":[],"tail":", by filing a written election with the Chief Justice within the time and in the manner prescribed by section 611."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a281-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Counselor, with the approval of the Chief Justice, may appoint and fix the compensation of necessary employees. The Counselor and his employees shall be deemed employees of the Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a282-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a283-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Counselor, with the approval of the Chief Justice, may accept voluntary personal services to assist with public and visitor programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a284-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No person may volunteer personal services under this subsection unless the person has first agreed, in writing, to waive any claim against the United States arising out of or in connection with such services, other than a claim under chapter 81 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a285-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No person volunteering personal services under this subsection shall be considered an employee of the United States for any purpose other than for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5291a286-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 81 of title 5; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5291a287-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a288-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the administration of this subsection, the Counselor shall ensure that the acceptance of personal services shall not result in the reduction of pay or displacement of any employee of the Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a289-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s677/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Counselor, with the approval of the Chief Justice, shall establish a retention and recruitment program that is consistent with section 908 of the Emergency Supplemental Act, 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1926"},"text":"2 U.S.C. 1926","children":[],"tail":") for Supreme Court Police officers and other critical employees who agree in writing to remain employed with the Supreme Court for a period of service of not less than two years."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a28a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/238/s1"},"text":"Pub. L. 92–238, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-01"},"text":"Mar. 1, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/46"},"text":"86 Stat. 46","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/233/s1"},"text":"Pub. L. 105–233, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-13"},"text":"Aug. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1535"},"text":"112 Stat. 1535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/402/s1/b/3/A"},"text":"Pub. L. 110–402, § 1(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4254"},"text":"122 Stat. 4254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dE/tIII/s307"},"text":"Pub. L. 117–328, div. E, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4672"},"text":"136 Stat. 4672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a28b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a28c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a28d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/402/s1/b/3/A/i"},"text":"Pub. L. 110–402, § 1(b)(3)(A)(i)","children":[],"tail":", substituted “Counselor” for “Administrative Assistant” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/402/s1/b/3/A/ii"},"text":"Pub. L. 110–402, § 1(b)(3)(A)(ii)","children":[],"tail":", substituted “a Counselor” for “an Administrative Assistant” in first sentence and “Counselor” for “Administrative Assistant” in second and third sentences."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/402/s1/b/3/A/iii"},"text":"Pub. L. 110–402, § 1(b)(3)(A)(iii)","children":[],"tail":", substituted “Counselor” for “Administrative Assistant” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/233"},"text":"Pub. L. 105–233","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
