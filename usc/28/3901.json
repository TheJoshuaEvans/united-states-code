{"tag":"section","attrib":{"id":"id52f5bbbd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3901"},"text":null,"children":[{"tag":"num","attrib":{"value":"3901"},"text":"§ 3901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f5bbbe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/g"},"text":"section 1346(g) of this title","children":[],"tail":", the defendant shall be the employing office alleged to have committed the violation involved."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bbbf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jury Trial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an action described in subsection (a), any party may demand a jury trial where a jury trial would be available in an action against a private defendant under the relevant law made applicable by chapter 5 of title 3. In any case in which a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s411"},"text":"section 411 of title 3","children":[],"tail":" is alleged, the court shall not inform the jury of the maximum amount of compensatory damages available under section 411(b)(1) or 411(b)(3) of title 3."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f5bbc0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/c"},"text":"Pub. L. 104–331, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4070"},"text":"110 Stat. 4070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f5bbc1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f5bbc2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f5bbc3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/d"},"text":"section 3(d) of Pub. L. 104–331","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1296"},"text":"section 1296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
