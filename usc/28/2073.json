{"tag":"section","attrib":{"id":"id52cadad4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073"},"text":null,"children":[{"tag":"num","attrib":{"value":"2073"},"text":"§ 2073.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of procedure and evidence; method of prescribing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52cadad5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52cadad6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judicial Conference shall prescribe and publish the procedures for the consideration of proposed rules under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52cadad7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judicial Conference may authorize the appointment of committees to assist the Conference by recommending rules to be prescribed under sections 2072 and 2075 of this title. Each such committee shall consist of members of the bench and the professional bar, and trial and appellate judges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cadad8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Judicial Conference shall authorize the appointment of a standing committee on rules of practice, procedure, and evidence under subsection (a) of this section. Such standing committee shall review each recommendation of any other committees so appointed and recommend to the Judicial Conference rules of practice, procedure, and evidence and such changes in rules proposed by a committee appointed under subsection (a)(2) of this section as may be necessary to maintain consistency and otherwise promote the interest of justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cadad9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52cadada-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each meeting for the transaction of business under this chapter by any committee appointed under this section shall be open to the public, except when the committee so meeting, in open session and with a majority present, determines that it is in the public interest that all or part of the remainder of the meeting on that day shall be closed to the public, and states the reason for so closing the meeting. Minutes of each meeting for the transaction of business under this chapter shall be maintained by the committee and made available to the public, except that any portion of such minutes, relating to a closed meeting and made available to the public, may contain such deletions as may be necessary to avoid frustrating the purposes of closing the meeting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52cadadb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any meeting for the transaction of business under this chapter, by a committee appointed under this section, shall be preceded by sufficient notice to enable all interested persons to attend.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cadadc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In making a recommendation under this section or under section 2072 or 2075, the body making that recommendation shall provide a proposed rule, an explanatory note on the rule, and a written report explaining the body’s action, including any minority or other separate views.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cadadd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2073/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Failure to comply with this section does not invalidate a rule prescribed under section 2072 or 2075 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52cadade-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIV/s401/a"},"text":"Pub. L. 100–702, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4649"},"text":"102 Stat. 4649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/tI/s104/e"},"text":"Pub. L. 103–394, title I, § 104(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4110"},"text":"108 Stat. 4110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cadadf-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52cadae0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52cadae1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2073, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/961"},"text":"62 Stat. 961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s104"},"text":"May 24, 1949, ch. 139, § 104","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/104"},"text":"63 Stat. 104","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-05-10/ch174/s3"},"text":"May 10, 1950, ch. 174, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/158"},"text":"64 Stat. 158","children":[],"tail":", empowered the Supreme Court to prescribe, by general rules, the practice and procedure in admiralty and maritime cases in the district courts, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/773/s2"},"text":"Pub. L. 89–773, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-06"},"text":"Nov. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1323"},"text":"80 Stat. 1323","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52cadae2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/s104/e/1"},"text":"Pub. L. 103–394, § 104(e)(1)","children":[],"tail":", substituted “sections 2072 and 2075” for “section 2072”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394/s104/e/2"},"text":"Pub. L. 103–394, § 104(e)(2)","children":[],"tail":", inserted “or 2075” after “2072”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52cadae3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cadae4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/394"},"text":"Pub. L. 103–394","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/394/s702"},"text":"section 702 of Pub. L. 103–394","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52cadae5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-12-01"},"text":"Dec. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/s407"},"text":"section 407 of Pub. L. 100–702","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2071"},"text":"section 2071 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52cadae6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"More Complete Information Regarding Assets of the Estate","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV/s419"},"text":"Pub. L. 109–8, title IV, § 419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/109"},"text":"119 Stat. 109","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/8/tIV/s419"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Judicial Conference of the United States, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2075"},"text":"section 2075 of title 28","children":[],"tail":" of the United States Code and after consideration of the views of the Director of the Executive Office for United States Trustees, shall propose amended Federal Rules of Bankruptcy Procedure and in accordance with rule 9009 of the Federal Rules of Bankruptcy Procedure [11 U.S.C. App.] shall prescribe official bankruptcy forms directing debtors under chapter 11 of title 11 of United States Code, to disclose the information described in paragraph (2) by filing and serving periodic financial and other reports designed to provide such information."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The information referred to in paragraph (1) is the value, operations, and profitability of any closely held corporation, partnership, or of any other entity in which the debtor holds a substantial or controlling interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the rules and reports under subsection (a) shall be to assist parties in interest taking steps to ensure that the debtor’s interest in any entity referred to in subsection (a)(2) is used for the payment of allowed claims against debtor.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52cadae7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Standard Form Disclosure Statement and Plan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV/s433"},"text":"Pub. L. 109–8, title IV, § 433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/110"},"text":"119 Stat. 110","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/8/tIV/s433"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Within a reasonable period of time after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":"], the Judicial Conference of the United States shall prescribe in accordance with rule 9009 of the Federal Rules of Bankruptcy Procedure [11 U.S.C. App.] official standard form disclosure statements and plans of reorganization for small business debtors (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of title 11","children":[],"tail":", United States Code, as amended by this Act), designed to achieve a practical balance between—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable needs of the courts, the United States trustee, creditors, and other parties in interest for reasonably complete information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economy and simplicity for debtors.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52cadae8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Uniform Reporting Rules and Forms for Small Business Cases","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tIV/s435"},"text":"Pub. L. 109–8, title IV, § 435","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/111"},"text":"119 Stat. 111","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/8/tIV/s435"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposal of Rules and Forms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Judicial Conference of the United States shall propose in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2073"},"text":"section 2073 of title 28","children":[],"tail":" of the United States Code amended Federal Rules of Bankruptcy Procedure, and shall prescribe in accordance with rule 9009 of the Federal Rules of Bankruptcy Procedure [11 U.S.C. App.] official bankruptcy forms, directing small business debtors to file periodic financial and other reports containing information, including information relating to—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor’s profitability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor’s cash receipts and disbursements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the debtor is timely filing tax returns and paying taxes and other administrative expenses when due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules and forms proposed under subsection (a) shall be designed to achieve a practical balance among—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable needs of the bankruptcy court, the United States trustee, creditors, and other parties in interest for reasonably complete information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business debtor’s interest that required reports be easy and inexpensive to complete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest of all parties that the required reports help such debtor to understand such debtor’s financial condition and plan the [sic] such debtor’s future.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
