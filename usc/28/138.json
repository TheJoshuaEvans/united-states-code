{"tag":"section","attrib":{"id":"id52396fa3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s138"},"text":null,"children":[{"tag":"num","attrib":{"value":"138"},"text":"§ 138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms abolished","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district court shall not hold formal terms.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52396fa4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/897"},"text":"62 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/139/s1"},"text":"Pub. L. 88–139, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-16"},"text":"Oct. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/248"},"text":"77 Stat. 248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52396fa5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52396fa6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was substituted for a number of special provisions fixing stated times for holding terms of court in the several districts, in order to vest in the courts wider discretion and promote greater efficiency in the administration of the business of such courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52396fa7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52396fa8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/139"},"text":"Pub. L. 88–139","children":[],"tail":" substituted “The district court shall not hold formal terms” for “The times for holding regular terms of court at the places fixed by this chapter shall be determined by rule of the district court” in text, and “Terms abolished” for “Times for holding regular terms” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
