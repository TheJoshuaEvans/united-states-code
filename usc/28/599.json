{"tag":"section","attrib":{"id":"id5280d982-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s599"},"text":null,"children":[{"tag":"num","attrib":{"value":"599"},"text":"§ 599.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of effect of chapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall cease to be effective five years after the date of the enactment of the Independent Counsel Reauthorization Act of 1994, except that this chapter shall continue in effect with respect to then pending matters before an independent counsel that in the judgment of such counsel require such continuation until that independent counsel determines such matters have been completed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5280d983-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191/s2"},"text":"Pub. L. 100–191, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1306"},"text":"101 Stat. 1306","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/270/s2"},"text":"Pub. L. 103–270, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-30"},"text":"June 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/732"},"text":"108 Stat. 732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5280d984-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5280d985-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attr