{"tag":"section","attrib":{"id":"id5279ade3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s585"},"text":null,"children":[{"tag":"num","attrib":{"value":"585"},"text":"§ 585.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5279ade4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s585/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may appoint an acting United States trustee for a region in which the office of the United States trustee is vacant. The individual so appointed may serve until the date on which the vacancy is filled by appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":" or by designation under subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5279ade5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s585/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may designate a United States trustee to serve in not more than two regions for such time as the public interest requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5279ade6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s224/a"},"text":"Pub. L. 95–598, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2663"},"text":"92 Stat. 2663","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/tI/s112"},"text":"Pub. L. 99–554, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3091"},"text":"100 Stat. 3091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5279ade7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5279ade8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id5279ade9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/s408/c"},"text":"Section 408(c) of Pub. L. 95–598","children":[],"tail":", as amended, which provided for the repeal of this section and the deletion of any references to United States Trustees in this title at a prospective date, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s307/b"},"text":"section 307(b) of Pub. L. 99–554","children":[],"tail":". See note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5279adea-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The Attorney General may appoint an acting United States trustee for a district in which the office of United States trustee is vacant, or may designate a United States trustee for another judicial district to serve as trustee for the district in which such vacancy exists. The individual so appointed or designated may serve until the earlier of 90 days after such appointment or designation, as the case may be, or the date on which the vacancy is filled by appointment under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5279adeb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5279adec-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/554"},"text":"Pub. L. 99–554","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/554/s302/a"},"text":"section 302(a) of Pub. L. 99–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s581"},"text":"section 581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
