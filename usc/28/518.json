{"tag":"section","attrib":{"id":"id52645073-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s518"},"text":null,"children":[{"tag":"num","attrib":{"value":"518"},"text":"§ 518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct and argument of cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52645074-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except when the Attorney General in a particular case directs otherwise, the Attorney General and the Solicitor General shall conduct and argue suits and appeals in the Supreme Court and suits in the United States Court of Federal Claims or in the United States Court of Appeals for the Federal Circuit and in the Court of International Trade in which the United States is interested.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52645075-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Attorney General considers it in the interests of the United States, he may personally conduct and argue any case in a court of the United States in which the United States is interested, or he may direct the Solicitor General or any officer of the Department of Justice to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52645076-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/613"},"text":"80 Stat. 613","children":[],"tail":"; amended "},{"tag":"ref","at