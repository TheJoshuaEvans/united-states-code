{"tag":"section","attrib":{"id":"id52a4b4a3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1362"},"text":null,"children":[{"tag":"num","attrib":{"value":"1362"},"text":"§ 1362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of all civil actions, brought by any Indian tribe or band with a governing body duly recognized by the Secretary of the Interior, wherein the matter in controversy arises under the Constitution, laws, or treaties of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a4b4a4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/635/s1"},"text":"Pub. L. 89–635, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-10"},"text":"Oct. 10, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/880"},"text":"80 Stat. 880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
