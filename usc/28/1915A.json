{"tag":"section","attrib":{"id":"id52c3af58-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1915A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1915A"},"text":"§ 1915A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Screening","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c3af59-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1915A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Screening","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall review, before docketing, if feasible or, in any event, as soon as practicable after docketing, a complaint in a civil action in which a prisoner seeks redress from a governmental entity or officer or employee of a governmental entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3af5a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1915A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grounds for Dismissal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On review, the court shall identify cognizable claims or dismiss the complaint, or any portion of the complaint, if the complaint—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52c3af5b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1915A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is frivolous, malicious, or fails to state a claim upon which relief may be granted; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c3af5c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1915A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeks monetary relief from a defendant who is immune from such relief.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3af5d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1915A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this section, the term “prisoner” means any person incarcerated or detained in any facility who is accused of, convicted of, sentenced for, or adjudicated delinquent for, violations of criminal law or the terms and conditions of parole, probation, pretrial release, or diversionary program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c3af5e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tI/s101"},"text":"Pub. L. 104–134, title I, § 101[(a)]","children":[],"tail":" [title VIII, § 805(a)], "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321"},"text":"110 Stat. 1321","children":[],"tail":", 1321–75; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/104/140/s1/a"},"text":"Pub. L. 104–140, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-02"},"text":"May 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1327"},"text":"110 Stat. 1327","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
