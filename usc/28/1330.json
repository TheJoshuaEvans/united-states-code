{"tag":"section","attrib":{"id":"id529d894c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1330"},"text":null,"children":[{"tag":"num","attrib":{"value":"1330"},"text":"§ 1330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions against foreign states","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id529d894d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district courts shall have original jurisdiction without regard to amount in controversy of any nonjury civil action against a foreign state as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1603/a"},"text":"section 1603(a) of this title","children":[],"tail":" as to any claim for relief in personam with respect to which the foreign state is not entitled to immunity either under sections 1605–1607 of this title or under any applicable international agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id529d894e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personal jurisdiction over a foreign state shall exist as to every claim for relief over which the district courts have jurisdiction under subsection (a) where service has been made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1608"},"text":"section 1608 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id529d894f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (b), an appearance by a foreign state does not confer personal jurisdiction with respect to any claim for relief not arising out of any transaction or occurrence enumerated in sections 1605–1607 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id529d8950-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/583/s2/a"},"text":"Pub. L. 94–583, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2891"},"text":"90 Stat. 2891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id529d8951-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id529d8952-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id529d8953-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/583/s8"},"text":"section 8 of Pub. L. 94–583","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1602"},"text":"section 1602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
