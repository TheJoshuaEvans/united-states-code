{"tag":"section","attrib":{"id":"id524075b1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s172"},"text":null,"children":[{"tag":"num","attrib":{"value":"172"},"text":"§ 172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenure and salaries of judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524075b2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each judge of the United States Court of Federal Claims shall be appointed for a term of fifteen years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524075b3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each judge shall receive a salary at the rate of pay, and in the same manner, as judges of the district courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524075b4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/898"},"text":"62 Stat. 898","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s105/a"},"text":"Pub. L. 97–164, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/27"},"text":"96 Stat. 27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tX/s1023"},"text":"Pub. L. 100–702, title X, § 1023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attri