{"tag":"section","attrib":{"id":"id52c3af20-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1914"},"text":null,"children":[{"tag":"num","attrib":{"value":"1914"},"text":"§ 1914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District court; filing and miscellaneous fees; rules of court","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c3af21-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clerk of each district court shall require the parties instituting any civil action, suit or proceeding in such court, whether by original process, removal or otherwise, to pay a filing fee of $350, except that on application for a writ of habeas corpus the filing fee shall be $5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3af22-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The clerk shall collect from the parties such additional fees only as are prescribed by the Judicial Conference of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3af23-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each district court by rule or standing order may require advance payment of fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c3af24-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/954"},"text":"62 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s244"},"text":"Pub. L. 95–598, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2671"},"text":"92 Stat. 2671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/336/s4/a"},"text":"Pub. L. 99–336, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/637"},"text":"100 Stat. 637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/b/tIV/s407/a"},"text":"Pub. L. 99–500, § 101(b) [title IV, § 407(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-39"},"text":"100 Stat. 1783–39","children":[],"tail":", 1783–64, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/b/tIV/s407/a"},"text":"Pub. L. 99–591, § 101(b) [title IV, § 407(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-39"},"text":"100 Stat. 3341–39","children":[],"tail":", 3341–64; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tIV/s401/a"},"text":"Pub. L. 104–317, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3853"},"text":"110 Stat. 3853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dB/tIII/s307/a"},"text":"Pub. L. 108–447, div. B, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2895"},"text":"118 Stat. 2895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tX/s10001/a"},"text":"Pub. L. 109–171, title X, § 10001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/183"},"text":"120 Stat. 183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3af25-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c3af26-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 549, 553 and 555 (R.S. § 828; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-28/ch1301/s1"},"text":"June 28, 1902, ch. 1301, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/476"},"text":"32 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-11/ch204"},"text":"Feb. 11, 1925, ch. 204","children":[],"tail":", §§ 2, 6, 8, "},{"tag":"ref","attrib":{"href":"/us/stat/43/857"},"text":"43 Stat. 857","children":[],"tail":", 858; "},{"tag":"ref","attrib":{"href":"/us/act/1927-01-22/ch50/s2"},"text":"Jan. 22, 1927, ch. 50, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1023"},"text":"44 Stat. 1023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-01-31/ch14/s1"},"text":"Jan. 31, 1928, ch. 14, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/54"},"text":"45 Stat. 54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-03-03/ch124/s2"},"text":"Mar. 3, 1942, ch. 124, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/122"},"text":"56 Stat. 122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-09-27/ch414"},"text":"Sept. 27, 1944, ch. 414","children":[],"tail":", §§ 1, 4, 5, "},{"tag":"ref","attrib":{"href":"/us/stat/58/743"},"text":"58 Stat. 743","children":[],"tail":", 744)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates sections 549, 553, and 555 of title 28, U.S.C., 1940 ed., as amended with necessary changes of phraseology.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “filing fee” was substituted for the inconsistent and misleading words of sections 549 and 553 of title 28, U.S.C., 1940 ed., “as full payment for all services to be rendered by the clerk” etc. thus removing the necessity for including exceptions and referring to other sections containing provisions for additional fees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s549"},"text":"section 549 of title 28","children":[],"tail":", U.S.C., 1940 ed., for payment of fees by the parties instituting criminal proceedings by indictment or information, was omitted. Such proceedings are instituted only by the United States from which costs cannot be exacted."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s549"},"text":"section 549 of title 28","children":[],"tail":", U.S.C., 1940 ed., for taxation of fees as costs, was omitted as covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1920"},"text":"section 1920 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or appeal from a deportation order of a United States Commissioner” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s553"},"text":"section 553 of title 28","children":[],"tail":", U.S.C., 1940 ed., were omitted as obsolete since repeal of the Chinese Exclusion Act by "},{"tag":"ref","attrib":{"href":"/us/act/1943-12-17/ch344/s1"},"text":"act Dec. 17, 1943, ch. 344, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/600"},"text":"57 Stat. 600","children":[],"tail":". Appeal was formerly conferred by "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s282"},"text":"section 282 of title 8","children":[],"tail":", U.S.C., 1940 ed., Aliens and Nationality."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) excepting the District of Columbia, was added to preserve the existing schedule of fees prescribed by section 11–1509 of the District of Columbia Code, 1940 ed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c3af27-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id52c3af28-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" is a corrected version of "},{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c3af29-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" substituted “$350” for “$250”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “$250” for “$150”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" substituted “$150” for “$120”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Pub. L. 99–500","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Pub. L. 99–591","children":[],"tail":" substituted “$120” for “$60”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/336"},"text":"Pub. L. 99–336","children":[],"tail":" struck out subsec. (d) which provided that section was not applicable to District of Columbia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" substituted “$60” for “$15”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c3af2a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c3af2b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/tX/s10001/d"},"text":"Pub. L. 109–171, title X, § 10001(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/184"},"text":"120 Stat. 184","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/171/tX/s10001/d"},"text":"“This section [amending this sec