{"tag":"section","attrib":{"id":"id52b7c8b6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1731"},"text":null,"children":[{"tag":"num","attrib":{"value":"1731"},"text":"§ 1731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handwriting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The admitted or proved handwriting of any person shall be admissible, for purposes of comparison, to determine genuineness of other handwriting attributed to such person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b7c8b7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/945"},"text":"62 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b7c8b8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52b7c8b9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 638 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-02-26/ch79"},"text":"Feb. 26, 1913, ch. 79","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/683"},"text":"37 Stat. 683","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “as a basis for comparison by witnesses, or by the jury, court, or officer conducting such proceeding”, were omitted as superfluous.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
