{"tag":"section","attrib":{"id":"id52bef437-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1862"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862"},"text":"§ 1862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No citizen shall be excluded from service as a grand or petit juror in the district courts of the United States or in the Court of International Trade on account of race, color, religion, sex, national origin, or economic status.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52bef438-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/952"},"text":"62 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/274/s101"},"text":"Pub. L. 90–274, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-03-27"},"text":"Mar. 27, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/54"},"text":"82 Stat. 54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s302/c"},"text":"Pub. L. 96–417, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1739"},"text":"94 Stat. 1739","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52bef439-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52bef43a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section makes provision for specific exemption of classes of citizens usually excused from jury service in the interest of the public health, safety, or welfare. The inclusion in the jury list of persons so exempted usually serves only to waste the time of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52bef43b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52bef43c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" prohibited discrimination against service as juror in the Court of International Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/274"},"text":"Pub. L. 90–274","children":[],"tail":" substituted provisions prohibiting discrimination against citizens in their service as jurors because of race, color, religion, sex, national origin, or economic status for provisions identifying three groups as exempt from jury service, including members of the armed forces on active duty, members of fire or police departments, and public officers actively engaged in the performance of official duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52bef43d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52bef43e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-11-01"},"text":"Nov. 1, 1980","children":[],"tail":", and applicable with respect to civil actions pending on or commenced on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/s701/a"},"text":"section 701(a) of Pub. L. 96–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s251"},"text":"section 251 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52bef43f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/274"},"text":"Pub. L. 90–274","children":[],"tail":" effective 270 days after "},{"tag":"date","attrib":{"date":"1968-03-27"},"text":"Mar. 27, 1968","children":[],"tail":", except as to cases in which an indictment has been returned or a petit jury empaneled prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/274/s104"},"text":"section 104 of Pub. L. 90–274","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1861"},"text":"section 1861 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
