{"tag":"section","attrib":{"id":"id522fd2da-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121"},"text":null,"children":[{"tag":"num","attrib":{"value":"121"},"text":"§ 121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South Carolina","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"South Carolina constitutes one judicial district comprising eleven divisions.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id522fd2db-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Charleston Division comprises the counties of Berkeley, Charleston, Clarendon, Colleton, Dorchester, and Georgetown.","children":[{"tag":"p","attrib":{},"text":"Court for the Charleston Division shall be held at Charleston.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2dc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Columbia Division comprises the counties of Kershaw, Lee, Lexington, Richland, and Sumter.","children":[{"tag":"p","attrib":{},"text":"Court for the Columbia Division shall be held at Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2dd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Florence Division comprises the counties of Chesterfield, Darlington, Dillon, Florence, Horry, Marion, Marlboro, and Williamsburg.","children":[{"tag":"p","attrib":{},"text":"Court for the Florence Division shall be held at Florence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Aiken Division comprises the counties of Aiken, Allendale, and Barnwell.","children":[{"tag":"p","attrib":{},"text":"Court for the Aiken Division shall be held at Aiken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Orangeburg Division comprises the counties of Bamberg, Calhoun, and Orangeburg.","children":[{"tag":"p","attrib":{},"text":"Court for the Orangeburg Division shall be held at Orangeburg.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Greenville Division comprises the counties of Greenville and Laurens.","children":[{"tag":"p","attrib":{},"text":"Court for the Greenville Division shall be held at Greenville.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2e1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Rock Hill Division comprises the counties of Chester, Fairfield, Lancaster, and York.","children":[{"tag":"p","attrib":{},"text":"Court for the Rock Hill Division shall be held at Rock Hill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2e2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Greenwood Division comprises the counties of Abbeville, Edgefield, Greenwood, McCormick, Newberry, and Saluda.","children":[{"tag":"p","attrib":{},"text":"Court for the Greenwood Division shall be held at Greenwood.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2e3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Anderson Division comprises the counties of Anderson, Oconee, and Pickens.","children":[{"tag":"p","attrib":{},"text":"Court for the Anderson Division shall be held at Anderson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2e4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Spartanburg Division comprises the counties of Cherokee, Spartanburg, and Union.","children":[{"tag":"p","attrib":{},"text":"Court for the Spartanburg Division shall be held at Spartanburg.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522fd2e5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s121/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Beaufort Division comprises the counties of Beaufort, Hampton, and Jasper.","children":[{"tag":"p","attrib":{},"text":"Court for the Beaufort Division shall be held at Beaufort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id522fd2e6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/889"},"text":"62 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/242/s1/a"},"text":"Pub. L. 89–242, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-07"},"text":"Oct. 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/951"},"text":"79 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/657/s2"},"text":"Pub. L. 99–657, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3670"},"text":"100 Stat. 3670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/140/tIII/s304"},"text":"Pub. L. 102–140, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/810"},"text":"105 Stat. 810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522fd2e7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522fd2e8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 186 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s105"},"text":"Mar. 3, 1911, ch. 231, § 105","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1123"},"text":"36 Stat. 1123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-02-05/ch28"},"text":"Feb. 5, 1912, ch. 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/60"},"text":"37 Stat. 60","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1915-03-03/ch100/s5"},"text":"Mar. 3, 1915, ch. 100, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/961"},"text":"38 Stat. 961","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1916-09-01/ch434"},"text":"Sept. 1, 1916, ch. 434","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/721"},"text":"39 Stat. 721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch261"},"text":"Mar. 4, 1923, ch. 261","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1486"},"text":"42 Stat. 1486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-01-30/ch118"},"text":"Jan. 30, 1925, ch. 118","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/800"},"text":"43 Stat. 800","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-06-26/ch696"},"text":"June 26, 1926, ch. 696","children":[],"tail":", §§ 1–3, "},{"tag":"ref","attrib":{"href":"/us/stat/44/773"},"text":"44 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch637"},"text":"June 20, 1936, ch. 637","children":[],"tail":", §§ 1–3, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1558"},"text":"49 Stat. 1558","children":[],"tail":", 1559; "},{"tag":"ref","attrib":{"href":"/us/act/1940-06-12/ch335"},"text":"June 12, 1940, ch. 335","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/344"},"text":"54 Stat. 344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1943-06-28/ch173"},"text":"June 28, 1943, ch. 173","children":[],"tail":", title II, § 204, "},{"tag":"ref","attrib":{"href":"/us/stat/57/244"},"text":"57 Stat. 244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1944-12-13/ch556"},"text":"Dec. 13, 1944, ch. 556","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/801"},"text":"58 Stat. 801","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s186"},"text":"section 186 of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to trial of criminal cases in the division in which the offense was committed, was omitted as fully covered by Rules 18–22 of the Federal Rules of Criminal Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision relating to the places of the clerks’ offices was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision respecting court accommodations at Orangeburg was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522fd2e9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522fd2ea-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/140/s304/1"},"text":"Pub. L. 102–140, § 304(1)","children":[],"tail":", struck out reference to Hampton County."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/140/s304/2"},"text":"Pub. L. 102–140, § 304(2)","children":[],"tail":", inserted reference to Hampton County."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/657/s2/1"},"text":"Pub. L. 99–657, § 2(1)","children":[],"tail":", substituted “eleven divisions” for “ten divisions” in introductory text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/657/s2/2"},"text":"Pub. L. 99–657, § 2(2)","children":[],"tail":", struck out “Beaufort,” after “counties of” and substituted “and Georgetown” for “Georgetown, and Jasper”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/657/s2/3"},"text":"Pub. L. 99–657, § 2(3)","children":[],"tail":", added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/242"},"text":"Pub. L. 89–242","children":[],"tail":" consolidated into a single district the 10 divisions of the state which had formerly been divided into an Eastern and a Western District."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id522fd2eb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id522fd2ec-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/657/s4"},"text":"Pub. L. 99–657, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3670"},"text":"100 Stat. 3670","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/657/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by sections 2 and 3 [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s90"},"text":"section 90 of this title","children":[],"tail":"] take effect 90 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by section 4 [enacting this note] takes effect on the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s90"},"text":"section 90 of this title","children":[],"tail":"] shall not affect any action commenced before the effective date of such amendments and pending on such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Juries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s90"},"text":"section 90 of this title","children":[],"tail":"] shall not affect the composition, or preclude the service, of any grand or petit jury summoned, empaneled, or actually serving on the effective date of such amendments.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id522fd2ed-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/242/s6"},"text":"Pub. L. 89–242, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-07"},"text":"Oct. 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/953"},"text":"79 Stat. 953","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/242/s6"},"text":"“The provisions of this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s133"},"text":"section 133 of this title","children":[],"tail":" and enacting provisions set out as a note below] shall become effective on the first day of the month following the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1965-10-07"},"text":"Oct. 7, 1965","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id522fd2ee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consolidation of South Carolina Into a Single Judicial District","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/242"},"text":"Pub. L. 89–242","children":[],"tail":", §§ 2–5, "},{"tag":"date","attrib":{"date":"1965-10-07"},"text":"Oct. 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/952"},"text":"79 Stat. 952","children":[],"tail":", 953, provided for the consolidation, in compliance with "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s132"},"text":"section 132 of this title","children":[],"tail":", of the Eastern and Western Districts of South Carolina into a single district with continuing jurisdiction over civil cases and criminal acts pending or committed prior to "},{"tag":"date","attrib":{"date":"1965-11-01"},"text":"Nov. 1, 1965","children":[],"tail":", and appropriate provisions for the appointment or transfer of United States attorneys, marshals, and other court personnel, then serving, from the two districts to the consolidated district."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
