{"tag":"section","attrib":{"id":"id5291a24a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672"},"text":null,"children":[{"tag":"num","attrib":{"value":"672"},"text":"§ 672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marshal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5291a24b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Supreme Court may appoint a marshal, who shall be subject to removal by the Court, and may fix his compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a24c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The marshal may, with the approval of the Chief Justice of the United States, appoint and fix the compensation of necessary assistants and other employees to attend the Court, and necessary custodial employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5291a24d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The marshal shall:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5291a24e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Attend the Court at its sessions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a24f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serve and execute all process and orders issued by the Court or a member thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a250-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Take charge of all property of the United States used by the Court or its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a251-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disburse funds appropriated for work upon the Supreme Court building and grounds under the jurisdiction of the Architect of the Capitol upon certified vouchers submitted by the Architect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a252-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disburse funds appropriated for the purchase of books, pamphlets, periodicals and other publications, and for their repair, binding, and rebinding, upon vouchers certified by the librarian of the Court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a253-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pay the salaries of the Chief Justice, associate justices, and all officers and employees of the Court and disburse other funds appropriated for disbursement, under the direction of the Chief Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a254-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pay the expenses of printing briefs and travel expenses of attorneys in behalf of persons whose motions to appear in forma pauperis in the Supreme Court have been approved and when counsel have been appointed by the Supreme Court, upon vouchers certified by the clerk of the Court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5291a255-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s672/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversee the Supreme Court Police.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5291a256-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/918"},"text":"62 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/279/s2"},"text":"Pub. L. 88–279, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-03-10"},"text":"Mar. 10, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/158"},"text":"78 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/390/s2"},"text":"Pub. L. 97–390, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-29"},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1958"},"text":"96 Stat. 1958","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a257-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5291a258-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 325, 331, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s13d"},"text":"section 13d of title 40","children":[],"tail":", U.S.C., 1940 ed., Public Buildings, Property and Works ("},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 219, 224, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1152"},"text":"36 Stat. 1152","children":[],"tail":", 1153; "},{"tag":"ref","attrib":{"href":"/us/act/1928-04-11/ch358"},"text":"April 11, 1928, ch. 358","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/424"},"text":"45 Stat. 424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-05-07/ch222/s4"},"text":"May 7, 1934, ch. 222, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/668"},"text":"48 Stat. 668","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates part of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s325"},"text":"section 325 of title 28","children":[],"tail":", U.S.C., 1940 ed., with section 331 of such title and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s13d"},"text":"section 13d of title 40","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s325"},"text":"section 325 of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to appointment of clerk and reporter of the Supreme Court are incorporated in sections 671 and 673 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s331"},"text":"section 331 of title 28","children":[],"tail":", U.S.C., 1940 ed., fixing the marshal’s salary at “not to exceed $5,500 per annum” was omitted and the court given authority to fix the salary in conformity with sections 671 and 673 of this title relating to the clerk and the reporter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Part of subsection (c)(5) is new. It recognizes the propriety of certification by the Court Librarian of vouchers for expenditures for the library. (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s674"},"text":"section 674 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The marshal’s duties as superintendent of the Supreme Court building are incorporated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s13c"},"text":"section 13c of title 40","children":[],"tail":", U.S.C., 1940 ed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a259-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a25a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/390"},"text":"Pub. L. 97–390","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/279/s2/a"},"text":"Pub. L. 88–279, § 2(a)","children":[],"tail":", struck out “except the clerk, his deputies and employees,” after “employees of the Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/279/s2/b"},"text":"Pub. L. 88–279, § 2(b)","children":[],"tail":", added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5291a25b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5291a25c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1964 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/279"},"text":"Pub. L. 88–279","children":[],"tail":" effective upon appropriation and availability of funds to pay salaries and other expenses of the clerk’s office, see "},{"tag":"ref","attrib":{"href":"/us/pl/88/279/s4"},"text":"section 4 of Pub. L. 88–279","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s671"},"text":"section 671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5291a25d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Annual appropriations to carry out amendment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/279"},"text":"Pub. L. 88–279","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/88/279/s3"},"text":"section 3 of Pub. L. 88–279","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s671"},"text":"section 671 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
