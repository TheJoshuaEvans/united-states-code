{"tag":"section","attrib":{"id":"id52965dc8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992"},"text":null,"children":[{"tag":"num","attrib":{"value":"992"},"text":"§ 992.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office; compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52965dc9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The voting members of the United States Sentencing Commission shall be appointed for six-year terms, except that the initial terms of the first members of the Commission shall be staggered so that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52965dca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members, including the Chair, serve terms of six years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52965dcb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three members serve terms of four years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52965dcc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members serve terms of two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965dcd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52965dce-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52965dcf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no voting member of the Commission may serve more than two full terms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52965dd0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a voting member appointed to fill a vacancy that occurs before the expiration of the term for which a predecessor was appointed shall be appointed only for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52965dd1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A voting member of the Commission whose term has expired may continue to serve until the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52965dd2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which a successor has taken office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52965dd3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Congress adjourns sine die to end the session of Congress that commences after the date on which the member’s term expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965dd4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chair and Vice Chairs of the Commission shall hold full-time positions and shall be compensated during their terms of office at the annual rate at which judges of the United States courts of appeals are compensated. The voting members of the Commission, other than the Chair and Vice Chairs, shall hold full-time positions until the end of the first six years after the sentencing guidelines go into effect pursuant to section 235(a)(1)(B)(ii) of the Sentencing Reform Act of 1984, and shall be compensated at the annual rate at which judges of the United States courts of appeals are compensated. Thereafter, the voting members of the Commission, other than the Chair and Vice Chairs,,","children":[{"tag":"ref","attrib":{"idref":"fn002060"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002060"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" shall hold part-time positions and shall be paid at the daily rate at which judges of the United States courts of appeals are compensated. A Federal judge may serve as a member of the Commission without resigning the judge’s appointment as a Federal judge."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52965dd5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s992/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 44(c) and 134(b) of this title (relating to the residence of judges) do not apply to any judge holding a full-time position on the Commission under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52965dd6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s217/a"},"text":"Pub. L. 98–473, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2018"},"text":"98 Stat. 2018","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":", §§ 4, 6(a), "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3592"},"text":"100 Stat. 3592","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/349/s1"},"text":"Pub. L. 102–349, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/933"},"text":"106 Stat. 933","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXVIII/s280005/b"},"text":"Pub. L. 103–322, title XXVIII, § 280005(b)","children":[],"tail":", (c)(1), (3), "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2096"},"text":"108 Stat. 2096","children":[],"tail":", 2097.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52965dd7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52965dd8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5298cdd9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 235(a)(1)(B)(ii) of the Sentencing Reform Act of 1984, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1/B/ii"},"text":"section 235(a)(1)(B)(ii) of Pub. L. 98–473","children":[],"tail":", which is set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5298cdda-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s280005/c/1"},"text":"Pub. L. 103–322, § 280005(c)(1)","children":[],"tail":", substituted “Chair” for “Chairman”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/s280005/b"},"text":"Pub. L. 103–322, § 280005(b)","children":[],"tail":", (c)(3), amended first sentence generally, substituting “The Chair and Vice Chairs of the Commission shall hold full-time positions and shall be compensated during their terms” for “The Chairman of the Commission shall hold a full-time position and shall be compensated during the term”, in second sentence, substituted “Chair and Vice Chairs” for “Chairman”, in third sentence, substituted “Chair and Vice Chairs,” for “Chairman”, and in last sentence, substituted “the judge’s appointment” for “his appointment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/349"},"text":"Pub. L. 102–349","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “No voting member may serve more than two full terms. A voting member appointed to fill a vacancy that occurs before the expiration of the term for which his predecessor was appointed shall be appointed only for the remainder of such term.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s4"},"text":"Pub. L. 99–646, § 4","children":[],"tail":", substituted “section 235(a)(1)(B)(ii) of the Sentencing Reform Act of 1984” for “section 225(a)(1)(B)(ii) of the Sentencing Reform Act of 1983”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646/s6/a"},"text":"Pub. L. 99–646, § 6(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5298cddb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id5298cddc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1/B/i"},"text":"section 235(a)(1)(B)(i) of Pub. L. 98–473","children":[],"tail":", set out as an Effective Date; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id5298cddd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commencement of Terms of First Members of Commission","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions directing that, for purposes of subsec. (a) of this section, the terms of the first members of the United States Sentencing Commission shall not begin to run until the sentencing guidelines go into effect pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1/B/ii"},"text":"section 235(a)(1)(B)(ii) of Pub. L. 98–473","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/2"},"text":"section 235(a)(2) of Pub. L. 98–473","children":[],"tail":", both of which are set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
