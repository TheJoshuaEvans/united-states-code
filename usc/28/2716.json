{"tag":"section","attrib":{"id":"id52ee8ff9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2716"},"text":null,"children":[{"tag":"num","attrib":{"value":"2716"},"text":"§ 2716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After the first publication of the notice of attachment, a person indebted to, or having possession of property of a defendant and having knowledge of the notice, shall answer for the amount of his debt or the value of the property. Any disposal or attempted disposal of the property, to the injury of the United States, is unlawful. When the person indebted to, or having possession of the property of a defendant, is known to the United States attorney or marshal, the officer shall cause a personal notice of the attachment to be served upon him, but the lack of the notice does not invalidate the attachment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ee8ffa-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/682/s9"},"text":"Pub. L. 86–682, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/707"},"text":"74 Stat. 707","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee8ffb-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee8ffc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id52ee8ffd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from R.S. § 930, which was originally classified to section 743 of former Title 28. Following the general revision and enactment of Title 28 by act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", R.S. § 930 was reclassified to "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s843"},"text":"section 843 of Title 39","children":[],"tail":". R.S. § 930 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s12/c"},"text":"Pub. L. 86–682, § 12(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":", (section 1 of which revised and enacted Title 39), and reenacted by section 9 thereof as "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2716"},"text":"section 2716 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee8ffe-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee8fff-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1960-09-01"},"text":"Sept. 1, 1960","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s11"},"text":"section 11 of Pub. L. 86–682","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
