{"tag":"section","attrib":{"id":"id5280d9a0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s599B"},"text":null,"children":[{"tag":"num","attrib":{"value":"599B"},"text":"§ 599B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel Management demonstration ","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" project "},{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Personnel Management Demonstration Project established under section 102 of title I of division C of the Omnibus Consolidated and Emergency Supplemental Appropriations Act for Fiscal Year 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":"; 122 "},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “112”."}],"tail":" Stat. 2681–585) shall be transferred to the Attorney General of the United States for continued use by the Bureau of Alcohol, Tobacco, Firearms, and Explosives, Department of Justice, and the Secretary of the Treasury for continued use by the Tax and Trade Bureau."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5280d9a1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1187/b"},"text":"Pub. L. 109–162, title XI, § 1187(b)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date"