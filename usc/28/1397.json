{"tag":"section","attrib":{"id":"id52a6ff33-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1397"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397"},"text":"§ 1397.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpleader","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any civil action of interpleader or in the nature of interpleader under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1335"},"text":"section 1335 of this title","children":[],"tail":" may be brought in the judicial district in which one or more of the claimants reside."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a6ff34-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/936"},"text":"62 Stat. 936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ff35-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a6ff36-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(26) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 26, as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-01-20/ch13/s1"},"text":"Jan. 20, 1936, ch. 13, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1096"},"text":"49 Stat. 1096","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/26"},"text":"section 41(26) of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to jurisdiction are the basis of "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1335"},"text":"section 1335 of this title","children":[],"tail":" and other provisions thereof are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2361"},"text":"section 2361 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suit,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
