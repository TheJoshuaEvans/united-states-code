{"tag":"section","attrib":{"id":"id52834ab6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s601"},"text":null,"children":[{"tag":"num","attrib":{"value":"601"},"text":"§ 601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation; Director and Deputy Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrative Office of the United States Courts shall be maintained at the seat of government. It shall be supervised by a Director and a Deputy Director appointed and subject to removal by the Chief Justice of the United States, after consulting with the Judicial Conference. The Director and Deputy Director shall be deemed to be officers for purposes of title 5, United States Code.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52834ab7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/913"},"text":"62 Stat. 913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/370/s5/a/1"},"text":"Pub. L. 86–370, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/652"},"text":"73 Stat. 652","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s307"},"text":"Pub. L. 101–650, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5112"},"text":"104 Stat. 5112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tVI/s602"},"text":"Pub. L. 104–317, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3857"},"text":"110 Stat. 3857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52834ab8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52834ab9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C. 1940 ed., § 444 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s302"},"text":"Mar. 3, 1911, ch. 231, § 302","children":[],"tail":" as added "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch501/s1"},"text":"Aug. 7, 1939, ch. 501, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1223"},"text":"53 Stat. 1223","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section contains part of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s444"},"text":"section 444 of title 28","children":[],"tail":", U.S.C., 1940 ed. The remainder of said section 444 is incorporated in sections 603, 606 and 608 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52834aba-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52834abb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317"},"text":"Pub. L. 104–317","children":[],"tail":" inserted at end “The Director and Deputy Director shall be deemed to be officers for purposes of title 5, United States Code.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650"},"text":"Pub. L. 101–650","children":[],"tail":" substituted “Chief Justice of the United States, after consulting with the Judicial Conference” for “Supreme Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1959—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370"},"text":"Pub. L. 86–370","children":[],"tail":" substituted “Deputy Director” for “Assistant Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52834abc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52834abd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1959 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370"},"text":"Pub. L. 86–370","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/86/370/s7/a"},"text":"section 7(a) of Pub. L. 86–370","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52834abe-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Veterans’ Preference in Judicial Branch Appointments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/339/s4/d"},"text":"Pub. L. 105–339, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3186"},"text":"112 Stat. 3186","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/339/s4/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraphs (2) and (3), the Judicial Conference of the United States shall prescribe procedures to provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans’ preference in the consideration of applicants for employment, and in the conduct of any reductions in force, within the judicial branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redress for alleged violations of any rights provided for under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under the procedures, a preference eligible (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108"},"text":"section 2108 of title 5","children":[],"tail":", United States Code) shall be afforded preferences in a manner and to the extent consistent with preferences afforded to preference eligibles in the executive branch."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in the procedures shall apply with respect to an applicant or employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is made by the President with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is as a judicial officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is required by statute to be made by or with the approval of a court or judicial officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is to a position, the duties of which are equivalent to those of a Senior Executive Service position (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/2"},"text":"section 3132(a)(2) of title 5","children":[],"tail":", United States Code)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term ‘judicial officer’ means a justice, judge, or magistrate judge listed in subparagraph (A), (B), (F), or (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s376/a/1"},"text":"section 376(a)(1) of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to congress; effective date.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 12 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":"], the Judicial Conference of the United States shall submit a copy of the procedures prescribed under this subsection to the Committee on Government Reform and Oversight [now Committee on Oversight and Accountability] and the Committee on the Judiciary of the House of Representatives and the Committee on Governmental Affairs [now Committee on Homeland Security and Governmental Affairs] and the Committee on the Judiciary of the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures prescribed under this subsection shall take effect 13 months after the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52834abf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reference to Assistant Director Deemed Reference to Deputy Director","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/370/s5/a/4"},"text":"Pub. L. 86–370, § 5(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-23"},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/652"},"text":"73 Stat. 652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/370/s5/a/4"},"text":"“Whenever the Assistant Director of the Administrative Office of the United States Courts is referred to in any other law, such reference shall be deemed to be to the Deputy Director of the Administrative Office of the United States Courts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52834ac0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Law Existing on ","children":[{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s2/b"},"text":"Act June 25, 1948, ch. 646, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/985"},"text":"62 Stat. 985","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1948-06-25/ch646/s2/b"},"text":"“The provisions of title 28, Judiciary and Judicial Procedure, of the United States Code, set out in section 1 of this Act, with respect to the organization of each of the several courts therein provided for and of the Administrative Office of the United States Courts, shall be construed as continuations of existing law, and the tenure of the judges, officers, and employees thereof and of the United States attorneys and marshals and their deputies and assistants, in office on the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":"], shall not be affected by its enactment, but each of them shall continue to serve in the same capacity under the appropriate provisions of title 28, as set out in section 1 of this Act, pursuant to his prior appointment: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That each circuit court of appeals shall, as in said title 28 set out, hereafter be known as a United States court of appeals. No loss of rights, interruption of jurisdiction, or prejudice to matters pending in any of such courts on the effective date of this Act shall result from its enactment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
