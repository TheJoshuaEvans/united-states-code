{"tag":"section","attrib":{"id":"id52ee904b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003"},"text":null,"children":[{"tag":"num","attrib":{"value":"3003"},"text":"§ 3003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ee904c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee904d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “includes” and “including” are not limiting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee904e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “or” is not exclusive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee904f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the singular includes the plural.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9050-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Rights of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter shall not be construed to curtail or limit the right of the United States under any other Federal law or any State law—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee9051-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect taxes or to collect any other amount collectible in the same manner as a tax;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9052-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect any fine, penalty, assessment, restitution, or forfeiture arising in a criminal case;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9053-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint or seek the appointment of a receiver; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9054-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce a security agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9055-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter shall not be construed to supersede or modify the operation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee9056-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9057-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admiralty law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9058-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3713"},"text":"section 3713 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9059-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 303 of the Consumer Credit Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1673"},"text":"15 U.S.C. 1673","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee905a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statute of limitation applicable to a criminal proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee905b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the common law or statutory rights to set-off or recoupment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee905c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal law authorizing, or any inherent authority of a court to provide, injunctive relief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee905d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the authority of a court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ee905e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impose a sanction under the Federal Rules of Civil Procedure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee905f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint a receiver to effectuate its order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ee9060-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exercise the power of contempt under any Federal law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9061-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any law authorizing the United States to obtain partition, or to recover possession, of property in which the United States holds title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9062-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of any other chapter of this title, except to the extent such provision is inconsistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9063-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter shall preempt State law to the extent such law is inconsistent with a provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9064-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Rights of the United States Under Foreign and International Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter shall not be construed to curtail or limit the rights of the United States under foreign law, under a treaty or an international agreement, or otherwise under international law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ee9065-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3003/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Federal Rules of Civil Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided otherwise in this chapter, the Federal Rules of Civil Procedure shall apply with respect to actions and proceedings under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee9066-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4935"},"text":"104 Stat. 4935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee9067-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee9068-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52ee9069-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsecs. (c)(8)(A) and (f), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee906a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee906b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
