{"tag":"section","attrib":{"id":"id5272a8e8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s543"},"text":null,"children":[{"tag":"num","attrib":{"value":"543"},"text":"§ 543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special attorneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5272a8e9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may appoint attorneys to assist United States attorneys when the public interest so requires, including the appointment of qualified tribal prosecutors and other qualified attorneys to assist in prosecuting Federal offenses committed in Indian country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a8ea-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each attorney appointed under this section is subject to removal by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a8eb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian Country","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Indian country” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5272a8ec-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"hre