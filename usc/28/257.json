{"tag":"section","attrib":{"id":"id524556b4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s257"},"text":null,"children":[{"tag":"num","attrib":{"value":"257"},"text":"§ 257.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All decisions of the Court of International Trade shall be preserved and open to inspection. The court shall forward copies of each decision to the Secretary of the Treasury or his designee and to the appropriate customs officer for the district in which the case arose. The Secretary shall publish weekly such decisions as he or the court may designate and abstracts of all other decisions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id524556b5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/900"},"text":"62 Stat. 900","children":[],"tail":", § 255; renumbered § 257 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s107"},"text":"Pub. L. 91–271, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/277"},"text":"84 Stat. 277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tV/s501/6"},"text":"Pub. L. 96–417, title V, § 501(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1742"},"text":"94 Stat. 1742","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id524556b6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id524556b7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1519"},"text":"section 1519 of title 19","children":[],"tail":", U.S.C., 1940 ed., Customs Duties ("},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch497"},"text":"June 17, 1930, ch. 497","children":[],"tail":", title IV, § 519, "},{"tag":"ref","attrib":{"href":"/us/stat/46/739"},"text":"46 Stat. 739","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id524556b8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id524556b9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417"},"text":"Pub. L. 96–417","children":[],"tail":" redesignated the Customs Court as the Court of International Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/271"},"text":"Pub. L. 91–271","children":[],"tail":" inserted “or his designee” after “Secretary of the Treasury,” and substituted “to the appropriate customs officer” for “the collector”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id524556ba-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidi