{"tag":"section","attrib":{"id":"id52c13d85-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1868"},"text":null,"children":[{"tag":"num","attrib":{"value":"1868"},"text":"§ 1868.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance and inspection of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After the master jury wheel is emptied and refilled pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1863/b/4"},"text":"section 1863(b)(4) of this title","children":[],"tail":", and after all persons selected to serve as jurors before the master wheel was emptied have completed such service, all records and papers compiled and maintained by the jury commission or clerk before the master wheel was emptied shall be preserved in the custody of the clerk for four years or for such longer period as may be ordered by a court, and shall be available for public inspection for the purpose of determining the validity of the selection of any jury."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c13d86-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/953"},"text":"62 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/274/s101"},"text":"Pub. L. 90–274, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-03-27"},"text":"Mar. 27, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/60"},"text":"82 Stat. 60","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c13d87-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c13d88-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 416, 417 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 279, 280, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1165"},"text":"36 Stat. 1165","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1929-01-31/ch126"},"text":"Jan. 31, 1929, ch. 126","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1145"},"text":"45 Stat. 1145","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates parts of sections 416, 417 of title 28, U.S.C., 1940 ed., with necessary changes in phraseology.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The remaining portion of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s416"},"text":"section 416 of title 28","children":[],"tail":", U.S.C., 1940 ed., constitutes "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1867"},"text":"section 1867 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The remainder of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s417"},"text":"section 417 of title 28","children":[],"tail":", U.S.C., 1940 ed., is incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1866"},"text":"section 1866 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words, “in the opinion of the court, disqualified” were substituted for “not an indifferent person, or is interested in the event of the cause”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c13d89-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c13d8a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/274"},"text":"Pub. L. 90–274","children":[],"tail":" substituted provisions for the maintenance and inspection of records in the hands of the commission or clerk before the master wheel was emptied for provisions covering the disqualification of the United States marshal or his deputy and the appointment of a disinterested person by the court."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c13d8b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c13d8c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/274"},"text":"Pub. L. 90–274","children":[],"tail":" effective 270 days after "},{"tag":"date","attrib":{"date":"1968-03-27"},"text":"Mar. 27, 1968","children":[],"tail":", except as to cases in which an indictment has been returned or a petit jury empaneled prior to such effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/274/s104"},"text":"section 104 of Pub. L. 90–274","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1861"},"text":"section 1861 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
