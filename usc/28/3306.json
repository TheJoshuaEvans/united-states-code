{"tag":"section","attrib":{"id":"id52f34b61-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306"},"text":null,"children":[{"tag":"num","attrib":{"value":"3306"},"text":"§ 3306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f34b62-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an action or proceeding under this subchapter for relief against a transfer or obligation, the United States, subject to section 3307 and to applicable principles of equity and in accordance with the Federal Rules of Civil Procedure, may obtain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f34b63-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoidance of the transfer or obligation to the extent necessary to satisfy the debt to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b64-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a remedy under this chapter against the asset transferred or other property of the transferee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b65-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relief the circumstances may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f34b66-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim for relief with respect to a fraudulent transfer or obligation under this subchapter is extinguished unless action is brought—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f34b67-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 3304(b)(1)(A) within 6 years after the transfer was made or the obligation was incurred or, if later, within 2 years after the transfer or obligation was or could reasonably have been discovered by the claimant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b68-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (a)(1) or (b)(1)(B) of section 3304 within 6 years after the transfer was made or the obligation was incurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b69-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 3304(a)(2) within 2 years after the transfer was made or the obligation was incurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f34b6a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4963"},"text":"104 Stat. 4963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f34b6b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52f34b6c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52f34b6d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Rules of Civil Procedure, referred to in subsec. (a), are set out in the Appendix to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f34b6e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f34b6f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
