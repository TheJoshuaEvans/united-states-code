{"tag":"section","attrib":{"id":"id5291a29a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law clerks and secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Circuit judges may appoint necessary law clerks and secretaries. A law clerk appointed under this section shall be exempt from the provisions of subchapter I of chapter 63 of title 5, unless specifically included by the appointing judge or by local rule of court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5291a29b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/920"},"text":"62 Stat. 920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tX/s1003/a/3"},"text":"Pub. L. 100–702, title X, § 1003(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4665"},"text":"102 Stat. 4665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5291a29c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5291a29d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 222a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s118a"},"text":"Mar. 3, 1911, ch. 231, § 118a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1930-06-17/ch509"},"text":"June 17, 1930, ch. 509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/774"},"text":"46 Stat. 774","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s222a"},"text":"section 222a of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to compensation of law clerks is incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"section 604 of this title","children":[],"tail":". (See reviser’s note under such section.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “with the approval of the Attorney General,” were omitted to confer on circuit judges the same authority given Supreme Court justices under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s675"},"text":"section 675 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provision for appointment of secretaries is new. Existing law fixes compensation of secretaries but makes no provision for their appointment. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"section 604 of this title","children":[],"tail":" and reviser’s note thereunder.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5291a29e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5291a29f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" inserted at end “A law clerk appointed under this section shall be exempt from the provisions of subchapter I of chapter 63 of title 5, unless specifically included by the appointing judge or by local rule of court.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
