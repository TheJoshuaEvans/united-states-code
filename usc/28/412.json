{"tag":"section","attrib":{"id":"id5255f946-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s412"},"text":null,"children":[{"tag":"num","attrib":{"value":"412"},"text":"§ 412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of Supreme Court reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office, or other printer designated by the Supreme Court of the United States shall print such additional bound volumes and preliminary prints of such reports as may be required for sale to the public. Such additional copies shall be sold by the Superintendent of Documents, as provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5255f947-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/906"},"text":"62 Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-10/ch632/s5"},"text":"July 10, 1952, ch. 632, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/541"},"text":"66 Stat. 541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5255f948-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5255f949-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 335 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s228"},"text":"Mar. 3, 1911, ch. 231, § 228","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1155"},"text":"36 Stat. 1155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-07-01/ch267/s4"},"text":"July 1, 1922, ch. 267, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/818"},"text":"42 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-05-29/ch425/s2"},"text":"May 29, 1926, ch. 425, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/677"},"text":"44 Stat. 677","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority for making an appropriation to carry into effect the provisions of this section is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s336"},"text":"section 336 of title 28","children":[],"tail":", U.S.C., 1940 ed., acts "},{"tag":"ref","attrib":{"href":"/us/act/1922-07-01/ch267/s5"},"text":"July 1, 1922, ch. 267, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/818"},"text":"42 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-05-29/ch425/s3"},"text":"May 29, 1926, ch. 425, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/678"},"text":"44 Stat. 678","children":[],"tail":", which is omitted, but not repealed, as unnecessary in this revision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to digests was omitted to conform to administrative practice. (See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604/a/9"},"text":"section 604(a)(9) of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5255f94a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5255f94b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1952—Act ","children":[{"tag":"date","attrib":{"date":"1952-07-10"},"text":"July 10, 1952","children":[],"tail":", permitted Superintendent of Documents to sell reports under same terms as other Government publications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5255f94c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id5255f94d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
