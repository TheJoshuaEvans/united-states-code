{"tag":"section","attrib":{"id":"id528a76e9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s624"},"text":null,"children":[{"tag":"num","attrib":{"value":"624"},"text":"§ 624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Board","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Board is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id528a76ea-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s624/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint and fix the duties of the Director and the Deputy Director of the Federal Judicial Center, who shall serve at the pleasure of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76eb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s624/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to request from any department, agency, or independent instrumentality of the Government any information it deems necessary to the performance of the functions of the Federal Judicial Center set forth in this chapter, and each such department, agency, or instrumentality is directed to cooperate with the Board and, to the extent permitted by law, to furnish such information to the Center upon request of the Chairman or upon request of the Director when the Board has delegated this authority to him;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76ec-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s624/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contract with and compensate government and private agencies or persons for research projects and other services, without regard to section 6101(b) to (d) of title 41, and to delegate such contract authority to the Director of the Federal Judicial Center, who is hereby empowered to exercise such delegated authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528a76ed-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/666"},"text":"81 Stat. 666","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIII/s304/a"},"text":"Pub. L. 100–702, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4648"},"text":"102 Stat. 4648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/g/3"},"text":"Pub. L. 111–350, § 5(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3848"},"text":"124 Stat. 3848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528a76ee-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528a76ef-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528a76f0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “section 6101(b) to (d) of title 41” for “section 3709 of the Revised Statutes, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" inserted “and the Deputy Director” after “Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
