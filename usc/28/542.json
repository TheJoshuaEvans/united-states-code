{"tag":"section","attrib":{"id":"id5272a8de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s542"},"text":null,"children":[{"tag":"num","attrib":{"value":"542"},"text":"§ 542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant United States attorneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5272a8df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s542/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may appoint one or more assistant United States attorneys in any district when the public interest so requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a8e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s542/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each assistant United States attorney is subject to removal by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5272a8e1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/618"},"text":"80 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5272a8e2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a8e3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id5272a8e4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"childr