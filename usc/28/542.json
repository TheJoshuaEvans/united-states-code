{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t28/s502"},"text":"28 U.S.C. 502","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None].","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t28/s504/b"},"text":"28 U.S.C. 504(b)","children":[],"tail":" (2d sentence, as applicable to assistant United States attorneys)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “is” is substituted for “shall be”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a8e5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Prior section 502","children":[],"tail":".—Based on title 28, U.S.C., 1940 ed., §§ 483, 594 ("},{"tag":"ref","attrib":{"href":"/us/act/1896-05-28/ch252/s8"},"text":"May 28, 1896, ch. 252, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/29/181"},"text":"29 Stat. 181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-07-19/ch24/s1"},"text":"July 19, 1919, ch. 24, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/209"},"text":"41 Stat. 209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch295"},"text":"Mar. 4, 1923, ch. 295","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1560"},"text":"42 Stat. 1560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-25/ch804"},"text":"June 25, 1936, ch. 804","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1921"},"text":"49 Stat. 1921","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates sections 483 and 594 of title 28, U.S.C., 1940 ed., relating to appointment of assistant United States attorneys.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “United States attorneys” were substituted for “district attorneys.” (See reviser’s note under section 501 [now 541] of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The exception of Alaska from the operation of such section 483 was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s109"},"text":"section 109 of title 48","children":[],"tail":", U.S.C., 1940 ed., Territories and Insular Possessions, authorizing appointment of assistant United States attorneys in Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference in such section 483 to “District of Columbia” was omitted. (See reviser’s note under section 501 [now 541] of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of sections 483 and 594 of title 28, U.S.C., 1940 ed., requiring the judges and United States attorneys to certify or evidence in writing the necessity for assistant United States attorneys in their respective districts, and specifying that such opinion of the judge shall state to the Attorney General the facts as distinguished from conclusions, showing the necessity therefor, were omitted. The Attorney General, as chief law enforcement officer, is in a better position to determine such necessity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The salary provisions of such section 594 were omitted as covered by section 508 [now 548] of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5272a8e6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5272a8e7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 542, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/911"},"text":"62 Stat. 911","children":[],"tail":", related to appointment and tenure of deputies and assistants for United States marshals, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", and reenactment in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s562"},"text":"section 562 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"section 4(c) of Pub. L. 89–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
