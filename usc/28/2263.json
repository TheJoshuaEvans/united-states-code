{"tag":"section","attrib":{"id":"id52db7cdd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263"},"text":null,"children":[{"tag":"num","attrib":{"value":"2263"},"text":"§ 2263.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing of habeas corpus application; time requirements; tolling rules","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52db7cde-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any application under this chapter for habeas corpus relief under section 2254 must be filed in the appropriate district court not later than 180 days after final State court affirmance of the conviction and sentence on direct review or the expiration of the time for seeking such review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52db7cdf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The time requirements established by subsection (a) shall be tolled—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52db7ce0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the date that a petition for certiorari is filed in the Supreme Court until the date of final disposition of the petition if a State prisoner files the petition to secure review by the Supreme Court of the affirmance of a capital sentence on direct review by the court of last resort of the State or other final State court decision on direct review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7ce1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the date on which the first petition for post-conviction review or other collateral relief is filed until the final State court disposition of such petition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52db7ce2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during an additional period not to exceed 30 days, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52db7ce3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motion for an extension of time is filed in the Federal district court that would have jurisdiction over the case upon the filing of a habeas corpus application under section 2254; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52db7ce4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2263/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a showing of good cause is made for the failure to file the habeas corpus application within the time period established by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52db7ce5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tI/s107/a"},"text":"Pub. L. 104–132, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1223"},"text":"110 Stat. 1223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52db7ce6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52db7ce7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52db7ce8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to cases pending on or after ","children":[{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s107/c"},"text":"section 107(c) of Pub. L. 104–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2261"},"text":"section 2261 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
