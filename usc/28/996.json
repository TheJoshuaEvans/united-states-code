{"tag":"section","attrib":{"id":"id529b186a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s996"},"text":null,"children":[{"tag":"num","attrib":{"value":"996"},"text":"§ 996.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id529b186b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s996/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Staff Director shall supervise the activities of persons employed by the Commission and perform other duties assigned to the Staff Director by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id529b186c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s996/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Staff Director shall, subject to the approval of the Commission, appoint such officers and employees as are necessary in the execution of the functions of the Commission. The officers and employees of the Commission shall be exempt from the provisions of part III of title 5, except the following: chapters 45 (Incentive Awards), 63 (Leave), 81 (Compensation for Work Injuries), 83 (Retirement), 84 (Federal Employees’ Retirement System), 85 (Unemployment Compensation), 87 (Life Insurance), and 89 (Health Insurance), and subchapter VI of chapter 55 (Payment for accumulated and accrued leave).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id529b186d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s217/a"},"text":"Pub. L. 98–473, title II, § 217(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2026"},"text":"98 Stat. 2026","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVII/s7106/c"},"text":"Pub. L. 100–690, title VII, § 7106(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4418"},"text":"102 Stat. 4418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s325/b/6"},"text":"Pub. L. 101–650, title III, § 325(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5121"},"text":"104 Stat. 5121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tXXVIII/s280005/c/5"},"text":"Pub. L. 103–322, title XXVIII, § 280005(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2097"},"text":"108 Stat. 2097","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/518/tIII/s302/a"},"text":"Pub. L. 106–518, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2416"},"text":"114 Stat. 2416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dE/tIII/s308"},"text":"Pub. L. 117–328, div. E, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4672"},"text":"136 Stat. 4672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id529b186e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id529b186f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id529b1870-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “84 (Federal Employees’ Retirement System),” after “83 (Retirement),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518"},"text":"Pub. L. 106–518","children":[],"tail":" substituted “except the following: chapters 45 (Incentive Awards), 63 (Leave), 81 (Compensation for Work Injuries), 83 (Retirement), 85 (Unemployment Compensation), 87 (Life Insurance), and 89 (Health Insurance), and subchapter VI of chapter 55 (Payment for accumulated and accrued leave)” for “United States Code, except the following chapters: 45 (Incentive Awards), 81 (Compensation for Work Injuries), 83 (Retirement), 85 (Unemployment Compensation), 87 (Life Insurance), and 89 (Health Insurance)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" substituted “the Staff Director” for “him” after “assigned to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650"},"text":"Pub. L. 101–650","children":[],"tail":" substituted “and 89 (Health Insurance)” for “89 (Health Insurance), and 91 (Conflicts of Interest)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" inserted reference to chapter 45 (Incentive Awards)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id529b1871-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id529b1872-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s235/a/1/B/i"},"text":"section 235(a)(1)(B)(i) of Pub. L. 98–473","children":[],"tail":", set out as an Effective Date; Savings Provision note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3551"},"text":"section 3551 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"id529b1873-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518/tIII/s302/b"},"text":"Pub. L. 106–518, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2417"},"text":"114 Stat. 2417","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/518/tIII/s302/b"},"text":"“Any leave that an individual accrued or accumulated (or that otherwise became available to such individual) under the leave system of the United States Sentencing Commission and that remains unused as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":"] shall, on and after such date, be treated as leave accrued or accumulated (or that otherwise became available to such individual) under chapter 63 of title 5, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
