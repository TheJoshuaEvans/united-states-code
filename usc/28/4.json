{"tag":"section","attrib":{"id":"id521f3116-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"§ 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Precedence of associate justices","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Associate justices shall have precedence according to the seniority of their commissions. Justices whose commissions bear the same date shall have precedence according to seniority in age.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id521f3117-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id521f3118-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id521f3119-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 322 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s216"},"text":"Mar. 3, 1911, ch. 231, § 216","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1152"},"text":"36 Stat. 1152","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
