{"tag":"section","attrib":{"id":"id522b181a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s92"},"text":null,"children":[{"tag":"num","attrib":{"value":"92"},"text":"§ 92.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idaho","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Idaho, exclusive of Yellowstone National Park, constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Boise, Coeur d’Alene, Moscow, and Pocatello.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id522b181b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/877"},"text":"62 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/272/s5"},"text":"Pub. L. 91–272, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/297"},"text":"84 Stat. 297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522b181c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522b181d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 151 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s78"},"text":"Mar. 3, 1911, ch. 231, § 78","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1109"},"text":"36 Stat. 1109","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1939-05-11/ch121"},"text":"May 11, 1939, ch. 121","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/738"},"text":"53 Stat. 738","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"All of Yellowstone National Park is included in the judicial district of Wyoming by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s131"},"text":"section 131 of this title","children":[],"tail":". Those parts of the park lying in Idaho are accordingly excluded from the judicial district of Idaho."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision as to the places for maintenance of the clerk’s offices, and requiring that they be open at all times, was omitted as covered by sections 452–751 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522b181e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522b181f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/272"},"text":"Pub. L. 91–272","children":[],"tail":" struck out provisions which had divided the judicial district of Idaho into a Northern Division, a Central Division, a Southern Division, and an Eastern Division."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
