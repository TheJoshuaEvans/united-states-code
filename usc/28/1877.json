{"tag":"section","attrib":{"id":"id52c3aef6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1877"},"text":null,"children":[{"tag":"num","attrib":{"value":"1877"},"text":"§ 1877.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of jurors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52c3aef7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1877/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the provisions of this section and title 5 of the United States Code, subchapter 1 of chapter 81, title 5, United States Code, applies to a Federal grand or petit juror, except that entitlement to disability compensation payments does not commence until the day after the date of termination of service as a juror.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52c3aef8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1877/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In administering this section with respect to a juror covered by this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52c3aef9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1877/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a juror is deemed to receive monthly pay at the minimum rate for grade GS–2 of the General Schedule unless his actual pay as a Government employee while serving on court leave is higher, in which case monthly pay is determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8114"},"text":"section 8114 of title 5","children":[],"tail":", United States Code, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c3aefa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1877/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance of duty as a juror includes that time when a juror is (A) in attendance at court pursuant to a summons, (B) in deliberation, (C) sequestered by order of a judge, or (D) at a site, by order of the court, for the taking of a view.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c3aefb-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/463/s3/1"},"text":"Pub. L. 97–463, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2531"},"text":"96 Stat. 2531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3aefc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c3aefd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52c3aefe-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b)(1), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
