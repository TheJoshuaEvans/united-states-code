{"tag":"section","attrib":{"id":"id52e519a4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2507"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507"},"text":"§ 2507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calls and discovery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e519a5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Court of Federal Claims may call upon any department or agency of the United States or upon any party for any information or papers, not privileged, for purposes of discovery or for use as evidence. The head of any department or agency may refuse to comply with a call issued pursuant to this subsection when, in his opinion, compliance will be injurious to the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e76396-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Without limitation on account of anything contained in subsection (a) of this section, the court may, in accordance with its rules, provide additional means for the discovery of any relevant facts, books, papers, documents or tangible things, not privileged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e76397-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court of Federal Claims may use all recorded and printed reports made by the committees of the Senate or House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e76398-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/977"},"text":"62 Stat. 977","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s55/a"},"text":"Sept. 3, 1954, ch. 1263, § 55(a)","children":[],"tail":"–(c), "},{"tag":"ref","attrib":{"href":"/us/stat/68/1247"},"text":"68 Stat. 1247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s139/f"},"text":"Pub. L. 97–164, title I, § 139(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/42"},"text":"96 Stat. 42","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a"},"text":"Pub. L. 102–572, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e76399-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52e7639a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 272 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s164"},"text":"Mar. 3, 1911, ch. 231, § 164","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1140"},"text":"36 Stat. 1140","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or agency” were added. (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1345"},"text":"section 1345 of this title","children":[],"tail":".)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e7639b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e7639c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/a/1"},"text":"Pub. L. 102–572, § 902(a)(1)","children":[],"tail":", substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/a/2"},"text":"Pub. L. 102–572, § 902(a)(2)","children":[],"tail":", substituted “Court of Federal Claims” for “Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s139/f/1"},"text":"Pub. L. 97–164, § 139(f)(1)","children":[],"tail":", substituted “United States Claims Court” for “Court of Claims”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/s139/f/2"},"text":"Pub. L. 97–164, § 139(f)(2)","children":[],"tail":", substituted “Claims Court” for “Court of Claims”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “Calls and discovery” for “Calls on departments for information” in section catchline, designated existing provisions as subsec. (a), and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e7639d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e7639e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52e7639f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
