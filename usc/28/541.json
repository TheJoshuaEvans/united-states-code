{"tag":"section","attrib":{"id":"id527037d3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s541"},"text":null,"children":[{"tag":"num","attrib":{"value":"541"},"text":"§ 541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States attorneys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id527037d4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall appoint, by and with the advice and consent of the Senate, a United States attorney for each judicial district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037d5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each United States attorney shall be appointed for a term of four years. On the expiration of his term, a United States attorney shall continue to perform the duties of his office until his successor is appointed and qualifies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037d6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s541/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each United States attorney is subject to removal by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id527037d7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/617"},"text":"80 Stat. 617","children":[]