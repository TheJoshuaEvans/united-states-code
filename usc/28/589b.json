{"tag":"section","attrib":{"id":"id527c1e7c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b"},"text":null,"children":[{"tag":"num","attrib":{"value":"589b"},"text":"§ 589b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bankruptcy data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id527c1e7d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall, within a reasonable time after the effective date of this section, issue rules requiring uniform forms for (and from time to time thereafter to appropriately modify and approve)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id527c1e7e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" final reports by trustees in cases under subchapter V of chapter 11 and chapters 7, 12, and 13 of title 11; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e7f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic reports by debtors in possession or trustees in cases under chapter 11 of title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527c1e80-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report referred to in subsection (a) shall be designed (and the requirements as to place and manner of filing shall be established) so as to facilitate compilation of data and maximum possible access of the public, both by physical inspection at one or more central filing locations, and by electronic access through the Internet or other appropriate media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527c1e81-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required to be filed in the reports referred to in subsection (b) shall be that which is in the best interests of debtors and creditors, and in the public interest in reasonable and adequate information to evaluate the efficiency and practicality of the Federal bankruptcy system. In issuing rules proposing the forms referred to in subsection (a), the Attorney General shall strike the best achievable practical balance between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id527c1e82-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasonable needs of the public for information about the operational results of the Federal bankruptcy system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e83-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economy, simplicity, and lack of undue burden on persons with a duty to file reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e84-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate privacy concerns and safeguards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527c1e85-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The uniform forms for final reports required under subsection (a) for use by trustees under subchapter V of chapter 11 and chapters 7, 12, and 13 of title 11 shall, in addition to such other matters as are required by law or as the Attorney General in the discretion of the Attorney General shall propose, include with respect to a case under such title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id527c1e86-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about the length of time the case was pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e87-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assets abandoned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e88-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assets exempted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e89-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receipts and disbursements of the estate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e8a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses of administration, including for use under section 707(b), actual costs of administering cases under chapter 13 of title 11;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e8b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims asserted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e8c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims allowed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e8d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributions to claimants and claims discharged without payment,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in each case by appropriate category and, in cases under subchapter V of chapter 11 and chapters 12 and 13 of title 11, date of confirmation of the plan, each modification thereto, and defaults by the debtor in performance under the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527c1e8e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The uniform forms for periodic reports required under subsection (a) for use by trustees or debtors in possession under chapter 11 of title 11 shall, in addition to such other matters as are required by law or as the Attorney General in the discretion of the Attorney General shall propose, include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id527c1e8f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about the industry classification, published by the Department of Commerce, for the businesses conducted by the debtor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e90-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" length of time the case has been pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e91-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" number of full-time employees as of the date of the order for relief and at the end of each reporting period since the case was filed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e92-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash receipts, cash disbursements and profitability of the debtor for the most recent period and cumulatively since the date of the order for relief;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e93-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with title 11, whether or not tax returns and tax payments since the date of the order for relief have been timely filed and made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e94-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all professional fees approved by the court in the case for the most recent period and cumulatively since the date of the order for relief (separately reported, for the professional fees incurred by or on behalf of the debtor, between those that would have been incurred absent a bankruptcy case and those not); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527c1e95-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s589b/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans of reorganization filed and confirmed and, with respect thereto, by class, the recoveries of the holders, expressed in aggregate dollar values and, in the case of claims, as a percentage of total claims of the class allowed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id527c1e96-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVI/s602/a"},"text":"Pub. L. 109–8, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/120"},"text":"119 Stat. 120","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s4/b/2"},"text":"Pub. L. 116–54, § 4(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1086"},"text":"133 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id527c1e97-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id527c1e98-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id527c1e99-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this section, referred to in subsec. (a), see Effective Date note set out below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id527c1e9a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s4/b/2/A"},"text":"Pub. L. 116–54, § 4(b)(2)(A)","children":[],"tail":", inserted “subchapter V of chapter 11 and” after “cases under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54/s4/b/2/B"},"text":"Pub. L. 116–54, § 4(b)(2)(B)","children":[],"tail":", inserted “subchapter V of chapter 11 and” after “trustees under” in introductory provisions and “subchapter V of chapter 11 and” after “cases under” in concluding provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id527c1e9b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id527c1e9c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/54"},"text":"Pub. L. 116–54","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2019-08-23"},"text":"Aug. 23, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/54/s5"},"text":"section 5 of Pub. L. 116–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id527c1e9d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", and not applicable with respect to cases commenced under Title 11, Bankruptcy, before such effective date, except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/s1501"},"text":"section 1501 of Pub. L. 109–8","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
