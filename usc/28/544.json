{"tag":"section","attrib":{"id":"id5272a8f4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s544"},"text":null,"children":[{"tag":"num","attrib":{"value":"544"},"text":"§ 544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each United States attorney, assistant United States attorney, and attorney appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s543"},"text":"section 543 of this title","children":[],"tail":", before taking office, shall take an oath to execute faithfully his duties."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id5272a8f5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/618"},"text":"80 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5272a8f6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a8f7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id5272a8f8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:spa