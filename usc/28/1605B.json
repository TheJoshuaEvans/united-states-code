{"tag":"section","attrib":{"id":"id52b2e667-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1605B"},"text":"§ 1605B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of foreign states for international terrorism against the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52b2e668-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “international terrorism”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52b2e669-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331"},"text":"section 2331 of title 18","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52b2e66a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any act of war (as defined in that section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b2e66b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility of Foreign States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign state shall not be immune from the jurisdiction of the courts of the United States in any case in which money damages are sought against a foreign state for physical injury to person or property or death occurring in the United States and caused by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52b5566c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of international terrorism in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52b5566d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tortious act or acts of the foreign state, or of any official, employee, or agent of that foreign state while acting within the scope of his or her office, employment, or agency, regardless where the tortious act or acts of the foreign state occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b5566e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims by Nationals of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2337/2"},"text":"section 2337(2) of title 18","children":[],"tail":", a national of the United States may bring a claim against a foreign state in accordance with section 2333 of that title if the foreign state would not be immune under subsection (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52b5566f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1605B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A foreign state shall not be subject to the jurisdiction of the courts of the United States under subsection (b) on the basis of an omission or a tortious act or acts that constitute mere negligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52b55670-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/222/s3/a"},"text":"Pub. L. 114–222, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-28"},"text":"Sept. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/853"},"text":"130 Stat. 853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b55671-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b55672-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52b55673-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any civil action pending on, or commenced on or after, ","children":[{"tag":"date","attrib":{"date":"2016-09-28"},"text":"Sept. 28, 2016","children":[],"tail":", and arising out of an injury to a person, property, or business on or after "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"Sept. 11, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/222/s7"},"text":"section 7 of Pub. L. 114–222","children":[],"tail":", set out as an Effective Date of 2016 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2333"},"text":"section 2333 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52b55674-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Stay of Actions Pending State Negotiations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/222/s5"},"text":"Pub. L. 114–222, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-09-28"},"text":"Sept. 28, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/854"},"text":"130 Stat. 854","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/222/s5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The courts of the United States shall have exclusive jurisdiction in any action in which a foreign state is subject to the jurisdiction of a court of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1605B"},"text":"section 1605B of title 28","children":[],"tail":", United States Code, as added by section 3(a) of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intervention","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may intervene in any action in which a foreign state is subject to the jurisdiction of a court of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1605B"},"text":"section 1605B of title 28","children":[],"tail":", United States Code, as added by section 3(a) of this Act, for the purpose of seeking a stay of the civil action, in whole or in part."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stay.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court of the United States may stay a proceeding against a foreign state if the Secretary of State certifies that the United States is engaged in good faith discussions with the foreign state defendant concerning the resolution of the claims against the foreign state, or any other parties as to whom a stay of claims is sought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A stay under this section may be granted for not more than 180 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may petition the court for an extension of the stay for additional 180-day periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recertification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court shall grant an extension under clause (i) if the Secretary of State recertifies that the United States remains engaged in good faith discussions with the foreign state defendant concerning the resolution of the claims against the foreign state, or any other parties as to whom a stay of claims is sought.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
