{"tag":"section","attrib":{"id":"id52ae2ada-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1494"},"text":null,"children":[{"tag":"num","attrib":{"value":"1494"},"text":"§ 1494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts of officers, agents or contractors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The United States Court of Federal Claims shall have jurisdiction to determine the amount, if any, due to or from the United States by reason of any unsettled account of any officer or agent of, or contractor with, the United States, or a guarantor, surety or personal representative of any such officer, agent or contractor, and to render judgment thereof,","children":[{"tag":"ref","attrib":{"idref":"fn002075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “thereon,”."}],"tail":" where—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ae2adb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1494/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claimant or the person he represents has applied to the proper department of the Government for settlement of the account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ae2adc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1494/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three years have elapsed from the date of such application without settlement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ae2add-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1494/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no suit upon the same has been brought by the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ae2ade-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/941"},"text":"62 Stat. 941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1953-07-28/ch253/s9"},"text":"July 28, 1953, ch. 253, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/226"},"text":"67 Stat. 226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s44/c"},"text":"Sept. 3, 1954, ch. 1263, § 44(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1242"},"text":"68 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s133/c/1"},"text":"Pub. L. 97–164, title I, § 133(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/40"},"text":"96 Stat. 40","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/a/1"},"text":"Pub. L. 102–572, title IX, § 902(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ae2adf-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ae2ae0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title