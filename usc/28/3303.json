{"tag":"section","attrib":{"id":"id52f34b2d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value for transfer or obligation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f34b2e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transaction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Value is given for a transfer or an obligation if, in exchange for the transfer or obligation, property is transferred or an antecedent debt is secured or satisfied, but value does not include an unperformed promise made otherwise than in the ordinary course of the promisor’s business to furnish support to the debtor or another person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f34b2f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonably Equivalent Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of sections 3304 and 3307, a person gives a reasonably equivalent value if the person acquires an interest of the debtor in an asset pursuant to a regularly conducted, noncollusive foreclosure sale or execution of a power of sale for the acquisition or disposition of such interest upon default under a mortgage, deed of trust, or security agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f34b30-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Present Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transfer is made for present value if the exchange between the debtor and the transferee is intended by them to be contemporaneous and is in fact substantially contemporaneous.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f34b31-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4961"},"text":"104 Stat. 4961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f34b32-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f34b33-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f34b34-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
