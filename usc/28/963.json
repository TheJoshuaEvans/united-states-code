{"tag":"section","attrib":{"id":"id52965dae-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s963"},"text":null,"children":[{"tag":"num","attrib":{"value":"963"},"text":"§ 963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Courts defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, unless the context indicates otherwise, the words “court” and “courts” include the Supreme Court of the United States and the courts enumerated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s610"},"text":"section 610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52965daf-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/927"},"text":"62 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52965db0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52965db1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section was included to embrace the Supreme Court and all courts under the supervision of the Administrative Office of the United States Courts. See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s610"},"text":"section 610 of this title","children":[],"tail":" and reviser’s note thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
