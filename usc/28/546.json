rib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t28/s506"},"text":"28 U.S.C. 506","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[None].","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5272a914-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Prior section 506.—","children":[],"tail":"Based on title 28, U.S.C., 1940 ed., § 511 (R.S. § 793; "},{"tag":"ref","attrib":{"href":"/us/act/1898-06-24/ch495/s2"},"text":"June 24, 1898, ch. 495, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/487"},"text":"30 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s291"},"text":"Mar. 3, 1911, ch. 231, § 291","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1167"},"text":"36 Stat. 1167","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “United States attorney” were substituted for “district attorney.” (See Reviser’s Note under section 501 [now 541] of this title.)","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “The Supreme Court of the Territory, and the district court of the United States for the District of Columbia” were omitted as obsolete. This section, as revised, applies to all districts enumerated in chapter 5 of this title. There were no provisions respecting vacancies in Hawaii and Puerto Rico. Therefore this section remedies this situation and establishes a uniform method to fill interim vacancies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “and a copy shall be entered on the journal of the court” after “filed in the clerk’s office of said court”, in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s511"},"text":"section 511 of title 28","children":[],"tail":", U.S.C., 1940 ed., were omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s511"},"text":"section 511 of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to marshals, are incorporated in sections 544 and 545 [see Prior Provisions notes under those sections] of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5272a915-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id5272a916-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 546, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/911"},"text":"62 Stat. 911","children":[],"tail":", related to death of a marshal, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", and reenactment in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s566"},"text":"section 566 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"section 4(c) of Pub. L. 89–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5272a917-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/34"},"text":"Pub. L. 110–34","children":[],"tail":" added subsecs. (c) and (d) and struck out former subsec. (c) which read as follows: “A person appointed as United States attorney under this section may serve until the qualification of a United States Attorney for such district appointed by the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" added subsec. (c) and struck out former subsecs. (c) and (d) which related to length of service of a United States attorney appointed under this section and appointment of a United States attorney by a district court after expiration of a previous appointment, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/646"},"text":"Pub. L. 99–646","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The district court for a district in which the office of United States attorney is vacant may appoint a United States attorney to serve until the vacancy is filled. The order of appointment by the court shall be filed with the clerk of the court.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5272a918-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5272a919-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/34/s3"},"text":"Pub. L. 110–34, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-06-14"},"text":"June 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/224"},"text":"121 Stat. 224","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/34/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this Act [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-06-14"},"text":"June 14, 2007","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person serving as a United States attorney on the day before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-06-14"},"text":"June 14, 2007","children":[],"tail":"] who was appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s546"},"text":"section 546 of title 28","children":[],"tail":", United States Code, may serve until the earlier of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualification of a United States attorney for such district appointed by the President under section 541 of that title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 120 days after the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expired appointments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an appointment expires under paragraph (1), the district court for that district may appoint a United States attorney for that district under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s546/d"},"text":"section 546(d) of title 28","children":[],"tail":", United States Code, as added by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
