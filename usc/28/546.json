{"tag":"section","attrib":{"id":"id5272a909-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546"},"text":null,"children":[{"tag":"num","attrib":{"value":"546"},"text":"§ 546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5272a90a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), the Attorney General may appoint a United States attorney for the district in which the office of United States attorney is vacant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a90b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall not appoint as United States attorney a person to whose appointment by the President to that office the Senate refused to give advice and consent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a90c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person appointed as United States attorney under this section may serve until the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5272a90d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the qualification of a United States attorney for such district appointed by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s541"},"text":"section 541 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5272a90e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of 120 days after appointment by the Attorney General under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5272a90f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an appointment expires under subsection (c)(2), the district court for such district may appoint a United States attorney to serve until the vacancy is filled. The order of appointment by the court shall be filed with the clerk of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5272a910-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/618"},"text":"80 Stat. 618","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/646/s69"},"text":"Pub. L. 99–646, § 69","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3616"},"text":"100 Stat. 3616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s502"},"text":"Pub. L. 109–177, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/st