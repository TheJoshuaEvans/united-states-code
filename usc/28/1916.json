{"tag":"section","attrib":{"id":"id52c3af5f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1916"},"text":null,"children":[{"tag":"num","attrib":{"value":"1916"},"text":"§ 1916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seamen’s suits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In all courts of the United States, seamen may institute and prosecute suits and appeals in their own names and for their own benefit for wages or salvage or the enforcement of laws enacted for their health or safety without prepaying fees or costs or furnishing security therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52c3af60-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/955"},"text":"62 Stat. 955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c3af61-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c3af62-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 837 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-12/ch27/s1"},"text":"June 12, 1917, ch. 27, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/157"},"text":"40 Stat. 157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1918-07-01/ch113/s1"},"text":"July 1, 1918, ch. 113, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/683"},"text":"40 Stat. 683","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
