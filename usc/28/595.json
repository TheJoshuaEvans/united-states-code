{"tag":"section","attrib":{"id":"id5280d94a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595"},"text":null,"children":[{"tag":"num","attrib":{"value":"595"},"text":"§ 595.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5280d94b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight of Conduct of Independent Counsel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5280d94c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The appropriate committees of the Congress shall have oversight jurisdiction with respect to the official conduct of any independent counsel appointed under this chapter, and such independent counsel shall have the duty to cooperate with the exercise of such oversight jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5280d94d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An independent counsel appointed under this chapter shall submit to the Congress annually a report on the activities of the independent counsel, including a description of the progress of any investigation or prosecution conducted by the independent counsel. Such report may omit any matter that in the judgment of the independent counsel should be kept confidential, but shall provide information adequate to justify the expenditures that the office of the independent counsel has made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5280d94e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight of Conduct of Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 15 days after receiving an inquiry about a particular case under this chapter, which is a matter of public knowledge, from a committee of the Congress with jurisdiction over this chapter, the Attorney General shall provide the following information to that committee with respect to that case:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5280d94f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the information about the case was received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5280d950-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether a preliminary investigation is being conducted, and if so, the date it began.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5280d951-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether an application for the appointment of an independent counsel or a notification that further investigation is not warranted has been filed with the division of the court, and if so, the date of such filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5280d952-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s595/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Relating to Impeachment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An independent counsel shall advise the House of Representatives of any substantial and credible information which such independent counsel receives, in carrying out the independent counsel’s responsibilities under this chapter, that may constitute grounds for an impeachment. Nothing in this chapter or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s49"},"text":"section 49 of this title","children":[],"tail":" shall prevent the Congress or either House thereof from obtaining information in the course of an impeachment proceeding."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5280d953-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/521/tVI/s601/a"},"text":"Pub. L. 95–521, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-26"},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1871"},"text":"92 Stat. 1871","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/a/1"},"text":"Pub. L. 97–409, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-03"},"text":"Jan. 3, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2139"},"text":"96 Stat. 2139","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/191/s2"},"text":"Pub. L. 100–191, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1304"},"text":"101 Stat. 1304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/270/s3/g"},"text":"Pub. L. 103–270, § 3(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-06-30"},"text":"June 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/734"},"text":"108 Stat. 734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5280d954-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5280d955-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5280d956-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/270"},"text":"Pub. L. 103–270","children":[],"tail":" substituted “annually a report on the activities of the independent counsel, including a description of the progress of any investigation or prosecution conducted by the independent counsel. Such report may omit any matter that in the judgment of the independent counsel should be kept confidential, but shall provide information adequate to justify the expenditures that the office of the independent counsel has made” for “such statements or reports on the activities of such independent counsel as the independent counsel considers appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191"},"text":"Pub. L. 100–191","children":[],"tail":" amended section generally, substituting subsecs. (a) to (c) relating to congressional oversight for former subsecs. (a) to (e) relating to reporting and congressional oversight."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/409/s2/a/1"},"text":"Pub. L. 97–409, § 2(a)(1)","children":[],"tail":", substituted “independent counsel” for “special prosecutor” and “independent counsel’s” for “special prosecutor’s” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id5280d957-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5280d958-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment; Transition Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/270"},"text":"Pub. L. 103–270","children":[],"tail":" applicable with respect to independent counsels appointed before, on, or after "},{"tag":"date","attrib":{"date":"1994-06-30"},"text":"June 30, 1994","children":[],"tail":", with transition provision relating to reporting requirements established or modified by "},{"tag":"ref","attrib":{"href":"/us/pl/103/270"},"text":"Pub. L. 103–270","children":[],"tail":", see section 7(a), (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/270"},"text":"Pub. L. 103–270","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"section 591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id5280d959-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/191"},"text":"Pub. L. 100–191","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", and applicable to proceedings initiated and independent counsels appointed on and after "},{"tag":"date","attrib":{"date":"1987-12-15"},"text":"Dec. 15, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/191/s6"},"text":"section 6 of Pub. L. 100–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s591"},"text":"section 591 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
