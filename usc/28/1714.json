{"tag":"section","attrib":{"id":"id52b7c88a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1714"},"text":null,"children":[{"tag":"num","attrib":{"value":"1714"},"text":"§ 1714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against discrimination based on geographic location","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The court may not approve a proposed settlement that provides for the payment of greater sums to some class members than to others solely on the basis that the class members to whom the greater sums are to be paid are located in closer geographic proximity to the court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b7c88b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/2/s3/a"},"text":"Pub. L. 109–2, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/7"},"text":"119 Stat. 7","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b7c88c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52b7c88d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52b7c88e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any civil action commenced on or after ","children":[{"tag":"date","attrib":{"date":"2005-02-18"},"text":"Feb. 18, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/2/s9"},"text":"section 9 of Pub. L. 109–2","children":[],"tail":", set out as an Effective Date of 2005 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1332"},"text":"section 1332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
