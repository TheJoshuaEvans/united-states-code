{"tag":"section","attrib":{"id":"id52a4b4a5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1363"},"text":null,"children":[{"tag":"num","attrib":{"value":"1363"},"text":"§ 1363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurors’ employment rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action brought for the protection of jurors’ employment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1875"},"text":"section 1875 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a4b4a6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/572/s6/b/1"},"text":"Pub. L. 95–572, § 6(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2457"},"text":"92 Stat. 2457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b4a7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a4b4a8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52a4b4a9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1363 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1366"},"text":"section 1366 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a4b4aa-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a4b4ab-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/572/s7"},"text":"Pub. L. 95–572, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2457"},"text":"92 Stat. 2457","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/572/s7"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, the amendments made by this Act [enacting this section and section 1875, renumbering section 1363, relating to construction of references to laws of the United States or Acts of Congress, as section 1364, and amending sections 1863, 1865, 1866, 1869, and 1871 of this title] shall apply with respect to any grand or petit juror summoned for service or actually serving on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by section 5 of this Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1871"},"text":"section 1871 of this title","children":[],"tail":"] shall apply with respect to any grand or petit juror serving on or after the sixtieth day following the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
