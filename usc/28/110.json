{"tag":"section","attrib":{"id":"id522d6295-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s110"},"text":null,"children":[{"tag":"num","attrib":{"value":"110"},"text":"§ 110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Jersey","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"New Jersey constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Camden, Newark and Trenton.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id522d6296-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/885"},"text":"62 Stat. 885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522d6297-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522d6298-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 176 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s96"},"text":"Mar. 3, 1911, ch. 231, § 96","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1119"},"text":"36 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1912-08-09/ch277"},"text":"Aug. 9, 1912, ch. 277","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/265"},"text":"37 Stat. 265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-02-14/ch53"},"text":"Feb. 14, 1913, ch. 53","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/674"},"text":"37 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-05-17/ch311"},"text":"May 17, 1926, ch. 311","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/561"},"text":"44 Stat. 561","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions relating to maintenance of offices by the clerk and marshal were omitted as covered by sections 452, 541 [see 561], 542 [see 561], and 751 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
