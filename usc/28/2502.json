{"tag":"section","attrib":{"id":"id52e5196d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2502"},"text":null,"children":[{"tag":"num","attrib":{"value":"2502"},"text":"§ 2502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens’ privilege to sue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e5196e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Citizens or subjects of any foreign government which accords to citizens of the United States the right to prosecute claims against their government in its courts may sue the United States in the United States Court of Federal Claims if the subject matter of the suit is otherwise within such court’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e5196f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" See section 7422(f) of the Internal Revenue Code of 1986 for exception with respect to suits involving internal revenue taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e51970-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/976"},"text":"62 Stat. 976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/713/s3/b"},"text":"Pub. L. 89–713, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-02"},"text":"Nov. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1108"},"text":"80 Stat. 1108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI