{"tag":"section","attrib":{"id":"id529b18d4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1260"},"text":null,"children":[{"tag":"num","attrib":{"value":"1260"},"text":"§ 1260.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supreme Court of the Virgin Islands; certiorari","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Final judgments or decrees rendered by the Supreme Court of the Virgin Islands may be reviewed by the Supreme Court by writ of certiorari where the validity of a treaty or statute of the United States is drawn in question or where the validity of a statute of the Virgin Islands is drawn in question on the ground of its being repugnant to the Constitution, treaties, or laws of the United States, or where any title, right, privilege, or immunity is specially set up or claimed under the Constitution or the treaties or statutes of, or any commission held or authority exercised under, the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id529b18d5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/226/s2/a"},"text":"Pub. L. 112–226, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1606"},"text":"126 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id529b18d6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id529b18d7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id529b18d8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/226/s3"},"text":"Pub. L. 112–226, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1607"},"text":"126 Stat. 1607","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/226/s3"},"text":"“The amendments made by this Act [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1613"},"text":"section 1613 of Title 48","children":[],"tail":", Territories and Insular Possessions] apply to cases commenced on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
