{"tag":"section","attrib":{"id":"id524a1269-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s335"},"text":null,"children":[{"tag":"num","attrib":{"value":"335"},"text":"§ 335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial Conference of the Court of International Trade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id524a126a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chief judge of the Court of International Trade is authorized to summon annually the judges of such court to a judicial conference, at a time and place that such chief judge designates, for the purpose of considering the business of such court and improvements in the administration of justice in such court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id524a126b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Court of International Trade shall provide by its rules for representation and active participation at such conference by members of the bar.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id524a126c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/466/s2/a"},"text":"Pub. L. 99–466, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-14"},"text":"Oct. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1190"},"text":"100 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id524a126d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id524a126e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id524a126f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1986-10-14"},"text":"Oct. 14, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/466/s4"},"text":"section 4 of Pub. L. 99–466","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s331"},"text":"section 331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
