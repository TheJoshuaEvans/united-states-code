{"tag":"section","attrib":{"id":"id528a76fe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s626"},"text":null,"children":[{"tag":"num","attrib":{"value":"626"},"text":"§ 626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of the Director and Deputy Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The compensation of the Director of the Federal Judicial Center shall be the same as that of the Director of the Administrative Office of the United States Courts, and his appointment and salary shall not be subject to the provisions of title 5, United States Code, governing appointments in competitive service, or the provisions of chapter 51 and subchapter III of chapter 53 of such title, relating to classification and General Schedule pay rates: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any Director who is a justice or judge of the United States in active or retired status shall serve without additional compensation. The compensation of the Deputy Director of the Federal Judicial Center shall be the same as that of the Deputy Director of the Administrative Office of the United States Courts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id528a76ff-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/666"},"text":"81 Stat. 666","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIII/s304/b/1"},"text":"Pub. L. 100–702, title III, § 304(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4648"},"text":"102 Stat. 4648","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528a7700-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528a7701-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id528a7702-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in text, is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528a7703-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" inserted “and Deputy Director” in section catchline and inserted at end of text “The compensation of the Deputy Director of the Federal Judicial Center shall be the same as that of the Deputy Director of the Administrative Office of the United States Courts.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id528a7704-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528a7705-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702/tIII/s304/c"},"text":"Pub. L. 100–702, title III, § 304(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4648"},"text":"102 Stat. 4648","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/702/tIII/s304/c"},"text":"“The amendment made by subsection (b) [amending this section] shall be effective for fiscal years beginning on or after ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
