<section xmlns="http://xml.house.gov/schemas/uslm/1.0" style="-uslm-lc:I80" id="id522fd2d6-3a70-11f1-9e0c-dcbb1364dae6" identifier="/us/usc/t28/s120"><num value="120">§ 120.</num><heading> Rhode Island</heading><content>
<p style="-uslm-lc:I11" class="indent0">Rhode Island constitutes one judicial district.</p>
<p style="-uslm-lc:I56" class="indent4 firstIndent-2">Court shall be held at Providence.</p>
</content><sourceCredit id="id522fd2d7-3a70-11f1-9e0c-dcbb1364dae6">(<ref href="/us/act/1948-06-25/ch646">June 25, 1948, ch. 646</ref>, <ref href="/us/stat/62/889">62 Stat. 889</ref>.)</sourceCredit>
