{"tag":"section","attrib":{"id":"id529fd3ca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1336"},"text":null,"children":[{"tag":"num","attrib":{"value":"1336"},"text":"§ 1336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surface Transportation Board’s orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id529fd3cb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by Act of Congress, the district courts shall have jurisdiction of any civil action to enforce, in whole or in part, any order of the Surface Transportation Board, and to enjoin or suspend, in whole or in part, any order of the Surface Transportation Board for the payment of money or the collection of fines, penalties, and forfeitures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id529fd3cc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a district court or the United States Court of Federal Claims refers a question or issue to the Surface Transportation Board for determination, the court which referred the question or issue shall have exclusive jurisdiction of a civil action to enforce, enjoin, set aside, annul, or suspend, in whole or in part, any order of the Surface Transportation Board arising out of such referral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id529fd3cd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action brought under subsection (b) of this section shall be filed within 90 days from the date that the order of the Surface Transportation Board becomes final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id529fd3ce-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/931"},"text":"62 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/513/s1"},"text":"Pub. L. 88–513, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-30"},"text":"Aug. 30, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/695"},"text":"78 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/584/s1"},"text":"Pub. L. 93–584, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-02"},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1917"},"text":"88 Stat. 1917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s128"},"text":"Pub. L. 97–164, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/39"},"text":"96 Stat. 39","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s305/a/1"},"text":"Pub. L. 104–88, title III, § 305(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/944"},"text":"109 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id529fd3cf-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id529fd3d0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(27), (28) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 24(27), (28), 207, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1091"},"text":"36 Stat. 1091","children":[],"tail":", 1148; "},{"tag":"ref","attrib":{"href":"/us/act/1913-10-22/ch32"},"text":"Oct. 22, 1913, ch. 32","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/219"},"text":"38 Stat. 219","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Except as otherwise provided by enactment of Congress” were inserted because of certain similar cases of which the courts of appeals are given jurisdiction. (See, for example, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s21"},"text":"section 21 of title 15","children":[],"tail":", U.S.C., 1940 ed., Commerce and Trade.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “any civil action” were substituted for “all cases” and “cases” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id529fd3d1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id529fd3d2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “Surface Transportation Board’s” for “Interstate Commerce Commission’s” in section catchline and “Surface Transportation Board” for “Interstate Commerce Commission” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “United States Claims Court” for “Court of Claims”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/584"},"text":"Pub. L. 93–584","children":[],"tail":" substituted provisions that the district courts shall have jurisdiction of civil actions to enforce, in whole or in part, orders of the Interstate Commerce Commission, and to enjoin or suspend, in whole or in part, any order of the Interstate Commerce Commission for the payment of money or the collection of fines, penalties, and forfeitures, for provisions that the district courts shall have jurisdiction of civil actions to enforce, enjoin, set aside, annul or suspend, in whole or in part, any order of the Interstate Commerce Commission."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/513"},"text":"Pub. L. 88–513","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"sta