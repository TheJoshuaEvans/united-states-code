{"tag":"section","attrib":{"id":"id52a9701e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1445"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445"},"text":"§ 1445.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonremovable actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a9701f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1445/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action in any State court against a railroad or its receivers or trustees, arising under sections 1–4 and 5–10 of the Act of ","children":[{"tag":"date","attrib":{"date":"1908-04-22"},"text":"April 22, 1908","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s51–54"},"text":"45 U.S.C. 51–54","children":[],"tail":", 55–60), may not be removed to any district court of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a97020-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1445/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action in any State court against a carrier or its receivers or trustees to recover damages for delay, loss, or injury of shipments, arising under section 11706 or 14706 of title 49, may not be removed to any district court of the United States unless the matter in controversy exceeds $10,000, exclusive of interest and costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a97021-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1445/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action in any State court arising under the workmen’s compensation laws of such State may not be removed to any district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a97022-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1445/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action in any State court arising under section 40302 of the Violence Against Women Act of 1994 may not be removed to any district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a97023-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/939"},"text":"62 Stat. 939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/554/s5"},"text":"Pub. L. 85–554, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-25"},"text":"July 25, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/415"},"text":"72 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/473/s2/a/3/A"},"text":"Pub. L. 95–473, § 2(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1465"},"text":"92 Stat. 1465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/486/s9/b"},"text":"Pub. L. 95–486, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-20"},"text":"Oct. 20, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1634"},"text":"92 Stat. 1634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40302/e/5"},"text":"Pub. L. 103–322, title IV, § 40302(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1942"},"text":"108 Stat. 1942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s305/b"},"text":"Pub. L. 104–88, title III, § 305(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/944"},"text":"109 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s3"},"text":"Pub. L. 104–287, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3388"},"text":"110 Stat. 3388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a97024-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a97025-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 71 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s28"},"text":"Mar. 3, 1911, ch. 231, § 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1094"},"text":"36 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1914-01-20/ch11"},"text":"Jan. 20, 1914, ch. 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/278"},"text":"38 Stat. 278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-01-31/ch14/s1"},"text":"Jan. 31, 1928, ch. 14, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/54"},"text":"45 Stat. 54","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or its receivers or trustees” were inserted in both subsections to make clear that nonremovable actions against a carrier do not become removable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1442"},"text":"section 1442 of this title","children":[],"tail":" when filed against court receivers or trustees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This was the unquestioned rule prior to the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-23/ch399"},"text":"act of Aug. 23, 1916, ch. 399","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/532"},"text":"39 Stat. 532","children":[],"tail":", amending "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s76"},"text":"section 76 of title 28","children":[],"tail":", U.S.C., 1940 ed., and permitting removal of actions against officers of United States courts. The cases are in conflict as to whether under that amendment the case becomes removable when the carrier is in receivership or undergoing reorganization. The revised section resolves the conflict by denying the right of removal to receivers and trustees where it would be nonexistent if the carrier were the party defendant. Thus the subject matter rather than legalistic distinctions as to the identity of the parties is made determinative consideration."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A reference in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s71"},"text":"section 71 of title 28","children":[],"tail":", U.S.C., 1940 ed., to sections 51–59 of title 45, U.S.C., 1940 ed., Railroads, was changed to “51–60.” Such sections 51–59 embraced all of chapter 2 of said title 45 when the law on which such section 71 is based was enacted, but a new section (60) was added in 1939."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s71"},"text":"section 71 of title 28","children":[],"tail":", U.S.C., 1940 ed., appear in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1441"},"text":"section 1441 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a97026-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52a97027-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 40302 of the Violence Against Women Act of 1994, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40302"},"text":"section 40302 of title IV of Pub. L. 103–322","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12361"},"text":"section 12361 of Title 34","children":[],"tail":", Crime Control and Law Enforcement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a97028-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “sections 1–4 and 5–10 of the Act of "},{"tag":"date","attrib":{"date":"1908-04-22"},"text":"April 22, 1908","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s51–54"},"text":"45 U.S.C. 51–54","children":[],"tail":", 55–60)” for “sections 51–60 of Title 45”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “carrier” for “common carrier” and “11706 or 14706” for “11707”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Pub. L. 103–322","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/486"},"text":"Pub. L. 95–486","children":[],"tail":" substituted “$10,000” for “$3,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s11707"},"text":"section 11707 of title 49","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20"},"text":"section 20 of Title 49","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/554"},"text":"Pub. L. 85–554","children":[],"tail":" substituted “Nonremovable actions” for “Carriers; nonremovable actions” in section catchline and added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a97029-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a9702a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s8/1"},"text":"section 8(1) of Pub. L. 104–287","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5303"},"text":"section 5303 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a9702b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52a9702c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1958 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/554"},"text":"Pub. L. 85–554","children":[],"tail":" applicable only in the case of actions commenced after "},{"tag":"date","attrib":{"date":"1958-07-25"},"text":"July 25, 1958","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/85/554/s3"},"text":"section 3 of Pub. L. 85–554","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1331"},"text":"section 1331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
