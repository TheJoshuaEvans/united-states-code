{"tag":"section","attrib":{"id":"id521f3112-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"§ 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancy in office of Chief Justice; disability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever the Chief Justice is unable to perform the duties of his office or the office is vacant, his powers and duties shall devolve upon the associate justice next in precedence who is able to act, until such disability is removed or another Chief Justice is appointed and duly qualified.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id521f3113-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id521f3114-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id521f3115-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 323 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s217"},"text":"Mar. 3, 1911, ch. 231, § 217","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1152"},"text":"36 Stat. 1152","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The sentence, “This provision shall apply to every Associate Justice who succeeds to the office of Chief Justice”, was omitted as covered by last portion of revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes were made in phraseology.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For seniority of commissions, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s4"},"text":"section 4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
