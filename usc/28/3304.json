{"tag":"section","attrib":{"id":"id52f34b35-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304"},"text":null,"children":[{"tag":"num","attrib":{"value":"3304"},"text":"§ 3304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer fraudulent as to a debt to the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f34b36-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Debt Arising Before Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in section 3307, a transfer made or obligation incurred by a debtor is fraudulent as to a debt to the United States which arises before the transfer is made or the obligation is incurred if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f34b37-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34b38-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor makes the transfer or incurs the obligation without receiving a reasonably equivalent value in exchange for the transfer or obligation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b39-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor is insolvent at that time or the debtor becomes insolvent as a result of the transfer or obligation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b3a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34b3b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer was made to an insider for an antecedent debt, the debtor was insolvent at the time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b3c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the insider had reasonable cause to believe that the debtor was insolvent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f34b3d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers Without Regard to Date of Judgment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52f34b3e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in section 3307, a transfer made or obligation incurred by a debtor is fraudulent as to a debt to the United States, whether such debt arises before or after the transfer is made or the obligation is incurred, if the debtor makes the transfer or incurs the obligation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34b3f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with actual intent to hinder, delay, or defraud a creditor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b40-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without receiving a reasonably equivalent value in exchange for the transfer or obligation if the debtor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52f34b41-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was engaged or was about to engage in a business or a transaction for which the remaining assets of the debtor were unreasonably small in relation to the business or transaction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52f34b42-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intended to incur, or believed or reasonably should have believed that he would incur, debts beyond his ability to pay as they became due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52f34b43-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining actual intent under paragraph (1), consideration may be given, among other factors, to whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52f34b44-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer or obligation was to an insider;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b45-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor retained possession or control of the property transferred after the transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b46-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer or obligation was disclosed or concealed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b47-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the transfer was made or obligation was incurred, the debtor had been sued or threatened with suit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b48-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer was of substantially all the debtor’s assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b49-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor absconded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b4a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor removed or concealed assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b4b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the consideration received by the debtor was reasonably equivalent to the value of the asset transferred or the amount of the obligation incurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b4c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor was insolvent or became insolvent shortly after the transfer was made or the obligation was incurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b4d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer occurred shortly before or shortly after a substantial debt was incurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52f34b4e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3304/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor transferred the essential assets of the business to a lienor who transferred the assets to an insider of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f34b4f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4961"},"text":"104 Stat. 4961","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f34b50-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f34b51-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f34b52-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
