{"tag":"section","attrib":{"id":"id5261df37-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B"},"text":null,"children":[{"tag":"num","attrib":{"value":"509B"},"text":"§ 509B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section to enforce human rights laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5261df38-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 90 days after the date of the enactment of the Human Rights Enforcement Act of 2009, the Attorney General shall establish a section within the Criminal Division of the Department of Justice with responsibility for the enforcement of laws against suspected participants in serious human rights offenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5261df39-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The section established under subsection (a) is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5261df3a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate legal action against individuals suspected of participating in serious human rights offenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5261df3b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate any such legal action with the United States Attorney for the relevant jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5261df3c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall, as appropriate, consult with the Secretary of Homeland Security and the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5261df3d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining the appropriate legal action to take against individuals who are suspected of committing serious human rights offenses under Federal law, the section shall take into consideration the availability of criminal prosecution under the laws of the United States for such offenses or in a foreign jurisdiction that is prepared to undertake a prosecution for the conduct that forms the basis for such offenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5261df3e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “serious human rights offenses” includes violations of Federal criminal laws relating to genocide, torture, war crimes, and the use or recruitment of child soldiers under sections 1091, 2340, 2340A, 2441, and 2442 of title 18, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5261df3f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/122/s2/b"},"text":"Pub. L. 111–122, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-22"},"text":"Dec. 22, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3480"},"text":"123 Stat. 3480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5261df40-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5261df41-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id5261df42-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Human Rights Enforcement Act of 2009, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/122"},"text":"Pub. L. 111–122","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2009-12-22"},"text":"Dec. 22, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
