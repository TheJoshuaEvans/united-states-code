{"tag":"section","attrib":{"id":"id52a6ffbd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1411"},"text":null,"children":[{"tag":"num","attrib":{"value":"1411"},"text":"§ 1411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jury trials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52a6ffbe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, this chapter and title 11 do not affect any right to trial by jury that an individual has under applicable nonbankruptcy law with regard to a personal injury or wrongful death tort claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52a6ffbf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district court may order the issues arising under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s303"},"text":"section 303 of title 11","children":[],"tail":" to be tried without a jury."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a6ffc0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s102/a"},"text":"Pub. L. 98–353, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/335"},"text":"98 Stat. 335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ffc1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a6ffc2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52a6ffc3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", except that subsec. (a) not applicable with respect to cases under Title 11, Bankruptcy, that are pending on "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", or to proceedings arising in or related to such cases, see section 122(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
