{"tag":"section","attrib":{"id":"id525ab3f0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462"},"text":null,"children":[{"tag":"num","attrib":{"value":"462"},"text":"§ 462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court accommodations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525ab3f1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sessions of courts of the United States (except the Supreme Court) shall be held only at places where the Director of the Administrative Office of the United States Courts provides accommodations, or where suitable accommodations are furnished without cost to the judicial branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab3f2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Administrative Office of the United States Courts shall provide accommodations, including chambers and courtrooms, only at places where regular sessions of court are authorized by law to be held, but only if the judicial council of the appropriate circuit has approved the accommodations as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab3f3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The limitations and restrictions contained in subsection (b) of this section shall not prevent the Director from furnishing chambers to circuit judges at places within the circuit other than where regular sessions of court are authorized by law to be held, when the judicial council of the circuit approves.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab3f4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Administrative Office of the United States Courts shall provide permanent accommodations for the United States Court of Appeals for the Federal Circuit and for the United States Court of Federal Claims only at the District of Columbia. However, each such court may hold regular and special sessions at other places utilizing the accommodations which the Director provides to other courts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab3f5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Administrative Office of the United States Courts shall provide accommodations for probation officers, pretrial service officers, and Federal Public Defender Organizations at such places as may be approved by the judicial council of the appropriate circuit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab3f6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s462/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of the Director, the Administrator of General Services is authorized and directed to provide the accommodations the Director requests, and to close accommodations which the Director recommends for closure with the approval of the Judicial Conference of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525ab3f7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s115/c/1"},"text":"Pub. L. 97–164, title I, § 115(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/31"},"text":"96 Stat. 31","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/702/tX/s1015"},"text":"Pub. L. 100–702, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4669"},"text":"102 Stat. 4669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525ab3f8-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525ab3f9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id525ab3fa-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" substituted “within the circuit other than where regular sessions of court are authorized by law to be held,” for “where Federal facilities are available”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id525ab3fb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id525ab3fc-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id525ab3fd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as an Effective Date of 1982 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of this title","children":[],"tail":"."}],"tai