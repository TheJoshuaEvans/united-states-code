{"tag":"section","attrib":{"id":"id52a6ffb2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1410"},"text":null,"children":[{"tag":"num","attrib":{"value":"1410"},"text":"§ 1410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue of cases ancillary to foreign proceedings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A case under chapter 15 of title 11 may be commenced in the district court of the United States for the district—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52a6ffb3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1410/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the debtor has its principal place of business or principal assets in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a6ffb4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1410/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the debtor does not have a place of business or assets in the United States, in which there is pending against the debtor an action or proceeding in a Federal or State court; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52a6ffb5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1410/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a case other than those specified in paragraph (1) or (2), in which venue will be consistent with the interests of justice and the convenience of the parties, having regard to the relief sought by the foreign representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52a6ffb6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s102/a"},"text":"Pub. L. 98–353, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/335"},"text":"98 Stat. 335","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/8/tVIII/s802/c/4"},"text":"Pub. L. 109–8, title VIII, § 802(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-04-20"},"text":"Apr. 20, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/146"},"text":"119 Stat. 146","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a6ffb7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52a6ffb8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52a6ffb9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/8"},"text":"Pub. L. 109–8","children":[],"tail":" amended section generally. Prior to amendment, section related to venue of cases commenced under "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s304"},"text":"section 304 of title 11","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52a6ffba-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"to