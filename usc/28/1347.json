{"tag":"section","attrib":{"id":"id52a2443f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1347"},"text":null,"children":[{"tag":"num","attrib":{"value":"1347"},"text":"§ 1347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partition action where United States is joint tenant","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction of any civil action commenced by any tenant in common or joint tenant for the partition of lands where the United States is one of the tenants in common or joint tenants.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a24440-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/933"},"text":"62 Stat. 933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a24441-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a24442-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 41(25) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s24"},"text":"Mar. 3, 1911, ch. 231, § 24","children":[],"tail":", par. 25, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1094"},"text":"36 Stat. 1094","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The venue provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s41/25"},"text":"section 41(25) of title 28","children":[],"tail":", U.S.C., 1940 ed., is incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1399"},"text":"section 1399 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “civil action” were substituted for “suits in equity,” in view of Rule 2 of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"A change was made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
