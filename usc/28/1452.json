{"tag":"section","attrib":{"id":"id52abe175-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1452"},"text":null,"children":[{"tag":"num","attrib":{"value":"1452"},"text":"§ 1452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of claims related to bankruptcy cases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52abe176-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A party may remove any claim or cause of action in a civil action other than a proceeding before the United States Tax Court or a civil action by a governmental unit to enforce such governmental unit’s police or regulatory power, to the district court for the district where such civil action is pending, if such district court has jurisdiction of such claim or cause of action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1334"},"text":"section 1334 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52abe177-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court to which such claim or cause of action is removed may remand such claim or cause of action on any equitable ground. An order entered under this subsection remanding a claim or cause of action, or a decision to not remand, is not reviewable by appeal or otherwise by the court of appeals under section 158(d), 1291, or 1292 of this title or by the Supreme Court of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52abe178-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s103/a"},"text":"Pub. L. 98–353, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/335"},"text":"98 Stat. 335","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s309/c"},"text":"Pub. L. 101–650, title III, § 309(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5113"},"text":"104 Stat. 5113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52abe179-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52abe17a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52abe17b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650"},"text":"Pub. L. 101–650","children":[],"tail":" inserted before period at end “by the court of appeals under section 158(d), 1291, or 1292 of this title or by the Supreme Court of the United States under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52abe17c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52abe17d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/s122/a"},"text":"section 122(a) of Pub. L. 98–353","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s151"},"text":"section 151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
