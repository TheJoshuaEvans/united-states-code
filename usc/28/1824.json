{"tag":"section","attrib":{"id":"id52bc82d3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1824"},"text":null,"children":[{"tag":"num","attrib":{"value":"1824"},"text":"§ 1824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mileage fees under summons as both witness and juror","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No constructive or double mileage fees shall be allowed by reason of any person being summoned both as a witness and a juror.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52bc82d4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/951"},"text":"62 Stat. 951","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52bc82d5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52bc82d6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 602 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1908-05-27/ch200/s1"},"text":"May 27, 1908, ch. 200, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/377"},"text":"35 Stat. 377","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or as a witness in two or more cases pending in the same court and triable at the same term thereof” were omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1821"},"text":"section 1821 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
