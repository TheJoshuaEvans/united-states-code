{"tag":"section","attrib":{"id":"id52ee9000-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2717"},"text":null,"children":[{"tag":"num","attrib":{"value":"2717"},"text":"§ 2717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The court, or a judge thereof, upon—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ee9001-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2717/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application of the party when property has been attached and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ee9002-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2717/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execution to the United States of a penal bond, approved by a judge, in double the value of the property attached and conditioned upon the return of the property or the payment of any judgment rendered by the court","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may discharge the warrant of attachment as to the property of the applicant.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ee9003-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/682/s9"},"text":"Pub. L. 86–682, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ee9004-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ee9005-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id52ee9006-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was derived from R.S. § 931, which was originally classified to section 744 of former Title 28. Following the general revision and enactment of Title 28 by act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", R.S. § 931 was reclassified to "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s844"},"text":"section 844 of Title 39","children":[],"tail":". R.S. § 931 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/86/682/s12/c"},"text":"Pub. L. 86–682, § 12(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-02"},"text":"Sept. 2, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/708"},"text":"74 Stat. 708","children":[],"tail":", (section 1 of which revised and enacted Title 39), and reenacted by section 9 thereof as "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2717"},"text":"section 2717 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ee9007-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52ee9008-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 