{"tag":"section","attrib":{"id":"id528a7712-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s628"},"text":null,"children":[{"tag":"num","attrib":{"value":"628"},"text":"§ 628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations and accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to carry out the provisions of this chapter. The Administrative Office of the United States Courts shall provide accounting, disbursing, auditing, and other fiscal services for the Federal Judicial Center.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id528a7713-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/667"},"text":"81 Stat. 667","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
