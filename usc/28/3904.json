{"tag":"section","attrib":{"id":"id52f5bbce-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3904"},"text":null,"children":[{"tag":"num","attrib":{"value":"3904"},"text":"§ 3904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited review of certain appeals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f5bbcf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An appeal may be taken directly to the Supreme Court of the United States from any interlocutory or final judgment, decree, or order of a court upon the constitutionality of any provision of chapter 5 of title 3.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bbd0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Supreme Court shall, if it has not previously ruled on the question, accept jurisdiction over the appeal referred to in subsection (a), advance the appeal on the docket, and expedite the appeal to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f5bbd1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/c"},"text":"Pub. L. 104–331, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4070"},"text":"110 Stat. 4070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f5bbd2-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f5bbd3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f5bbd4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/d"},"text":"section 3(d) of Pub. L. 104–331","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1296"},"text":"section 1296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
