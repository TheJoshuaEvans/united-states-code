{"tag":"section","attrib":{"id":"id52324438-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s131"},"text":null,"children":[{"tag":"num","attrib":{"value":"131"},"text":"§ 131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wyoming","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Wyoming and those portions of Yellowstone National Park situated in Montana and Idaho constitute one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Casper, Cheyenne, Evanston, Lander, Jackson, and Sheridan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52324439-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/895"},"text":"62 Stat. 895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/353/tII/s203/a"},"text":"Pub. L. 98–353, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/350"},"text":"98 Stat. 350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5232443a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id5232443b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s27"},"text":"section 27 of title 16","children":[],"tail":", U.S.C., 1940 ed., Conservation, and title 28, U.S.C., 1940 ed., § 196 ("},{"tag":"ref","attrib":{"href":"/us/act/1894-05-07/ch72/s5"},"text":"May 7, 1894, ch. 72, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/74"},"text":"28 Stat. 74","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231"},"text":"Mar. 3, 1911, ch. 231","children":[],"tail":", §§ 115, 291, "},{"tag":"ref","attrib":{"href":"/us/stat/36/1130"},"text":"36 Stat. 1130","children":[],"tail":", 1167; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-05/ch260"},"text":"June 5, 1924, ch. 260","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/388"},"text":"43 Stat. 388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-28/ch778/s1"},"text":"June 28, 1938, ch. 778, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1213"},"text":"52 Stat. 1213","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s196"},"text":"section 196 of title 28","children":[],"tail":", U.S.C., 1940 ed., with a portion of "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s27"},"text":"section 27 of title 16","children":[],"tail":", U.S.C., 1940 ed., with necessary changes in arrangement and phraseology. Reference to parts of Yellowstone National Park in Montana and Idaho is derived from said section 27. Other provisions of said section are incorporated in sections 631 and 632 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s196"},"text":"section 196 of title 28","children":[],"tail":", U.S.C., 1940 ed., for furnishing rooms and accommodations at Casper was omitted as obsolete, upon advice of the Director of the Administrative Office of the United States Courts that Federal accommodations are now available there."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s196"},"text":"section 196 of title 28","children":[],"tail":", U.S.C., 1940 ed., for appointment of deputies and maintenance of offices by the clerk and marshal were omitted as covered by sections 541 [see 561], 542 [see 561], and 751 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id5232443c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id5232443d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353"},"text":"Pub. L. 98–353","children":[],"tail":" provided for holding court at Jackson."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
