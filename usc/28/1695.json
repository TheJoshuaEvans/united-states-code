{"tag":"section","attrib":{"id":"id52b7c85a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1695"},"text":null,"children":[{"tag":"num","attrib":{"value":"1695"},"text":"§ 1695.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockholder’s derivative action","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Process in a stockholder’s action in behalf of his corporation may be served upon such corporation in any district where it is organized or licensed to do business or is doing business.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52b7c85b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/945"},"text":"62 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52b7c85c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52b7c85d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 112 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s51"},"text":"Mar. 3, 1911, ch. 231, § 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1101"},"text":"36 Stat. 1101","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1922-09-19/ch345"},"text":"Sept. 19, 1922, ch. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/849"},"text":"42 Stat. 849","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch526/s1"},"text":"Mar. 4, 1925, ch. 526, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1264"},"text":"43 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-04-16/ch230"},"text":"Apr. 16, 1936, ch. 230","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1213"},"text":"49 Stat. 1213","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “is organized or licensed to do business or is doing business” was substituted for the words “resides or is found,” as more specific and to conform to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391"},"text":"section 1391 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Venue provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s112"},"text":"section 112 of title 28","children":[],"tail":", U.S.C., 1940 ed., appear in section 1391 and 1401 of this title. Other provisions are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1693"},"text":"section 1693 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
