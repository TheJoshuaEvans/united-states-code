{"tag":"section","attrib":{"id":"id52f0ffb2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3013"},"text":null,"children":[{"tag":"num","attrib":{"value":"3013"},"text":"§ 3013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification or protective order; supervision of enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The court may at any time on its own initiative or the motion of any interested person, and after such notice as it may require, make an order denying, limiting, conditioning, regulating, extending, or modifying the use of any enforcement procedure under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52f0ffb3-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/647/tXXXVI/s3611"},"text":"Pub. L. 101–647, title XXXVI, § 3611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4938"},"text":"104 Stat. 4938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f0ffb4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f0ffb5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f0ffb6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", and applicable with respect to certain actions for debts owed the United States pending in court on that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/647/s3631"},"text":"section 3631 of Pub. L. 101–647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
