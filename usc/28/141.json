{"tag":"section","attrib":{"id":"id52396fb7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141"},"text":null,"children":[{"tag":"num","attrib":{"value":"141"},"text":"§ 141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special sessions; places; notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52396fb8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52396fb9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special sessions of the district court may be held at such places in the district as the nature of the business may require, and upon such notice as the court orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52396fba-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any business may be transacted at a special session which might be transacted at a regular session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52396fbb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52396fbc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special sessions of the district court may be held at such places within the United States outside the district as the nature of the business may require and upon such notice as the court orders, upon a finding by either the chief judge of the district court (or, if the chief judge is unavailable, the most senior available active judge of the district court) or the judicial council of the circuit that, because of emergency conditions, no location within the district is reasonably available where such special sessions could be held.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52396fbd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pursuant to this subsection, any business which may be transacted at a regular session of a district court may be transacted at a special session conducted outside the district, except that a criminal trial may not be conducted at a special session outside the State in which the crime has been committed unless the defendant consents to such a criminal trial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52396fbe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, in any case in which special sessions are conducted pursuant to this section, the district court may summon jurors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52396fbf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in civil proceedings, from any part of the district in which the court ordinarily conducts business or the district in which it is holding a special session; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52396fc0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in criminal trials, from any part of the district in which the crime has been committed and, if the defendant so consents, from any district in which the court is conducting business pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52396fc1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a district court issues an order exercising its authority under paragraph (1), the court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52396fc2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" through the Administrative Office of the United States Courts, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52396fc3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" send notice of such order, including the reasons for the issuance of such order, to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52396fc4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 180 days after the expiration of such court order submit a brief report to the Committee on the Judiciary of the Senate and the Committee on the Judiciary of the House of Representatives describing the impact of such order, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id52396fc5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the issuance of such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id52396fc6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration of such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id52396fc7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such order on litigants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id52396fc8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs to the judiciary resulting from such order; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52396fc9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide reasonable notice to the United States Marshals Service before the commencement of any special session held pursuant to such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52396fca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s141/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a district court issues an order exercising its authority under paragraph (1), the court shall direct the United States marshal of the district where the court is meeting to furnish transportation and subsistence to the same extent as that provided in sections 4282 and 4285 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52396fcb-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/897"},"text":"62 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/139/s1"},"text":"Pub. L. 88–139, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-10-16"},"text":"Oct. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/248"},"text":"77 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/63/s2/b"},"text":"Pub. L. 109–63, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-09"},"text":"Sept. 9, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1994"},"text":"119 Stat. 1994","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/162/tXI/s1198/a"},"text":"Pub. L. 109–162, title XI, § 1198(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-05"},"text":"Jan. 5, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3132"},"text":"119 Stat. 3132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52396fcc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52396fcd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 15 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s11"},"text":"Mar. 3, 1911, ch. 231, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1089"},"text":"36 Stat. 1089","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was rewritten to include provision that notice of special terms should conform to rules approved by the judicial council of the circuit, thus insuring a uniform practice among the courts for convening special terms.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes of phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52396fce-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52396fcf-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/162"},"text":"Pub. L. 109–162","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/63"},"text":"Pub. L. 109–63","children":[],"tail":" designated first and second undesignated pars. as pars. (1) and (2), respectively, of subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/139"},"text":"Pub. L. 88–139","children":[],"tail":" substituted “sessions” for “terms” and “session” for “term” wherever appearing in text and section catchline, and struck out “pursuant to rules approved by the judicial council of the circuit” after “court orders” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
