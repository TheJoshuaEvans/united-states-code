{"tag":"section","attrib":{"id":"id5261df2e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A"},"text":null,"children":[{"tag":"num","attrib":{"value":"509A"},"text":"§ 509A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Security Division","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5261df2f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is a National Security Division of the Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5261df30-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Security Division shall consist of the elements of the Department of Justice (other than the Federal Bureau of Investigation) engaged primarily in support of the intelligence and intelligence-related activities of the United States Government, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5261df31-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Attorney General designated as the Assistant Attorney General for National Security under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s507A"},"text":"section 507A of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5261df32-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Intelligence Policy and Review (or any successor organization).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5261df33-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The counterterrorism section (or any successor organization).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5261df34-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The counterespionage section (or any successor organization).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5261df35-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s509A/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other element, component, or office designated by the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5261df36-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s506/b/1"},"text":"Pub. L. 109–177, title V, § 506(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/248"},"text":"120 Stat. 248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
