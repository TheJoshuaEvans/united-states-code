{"tag":"section","attrib":{"id":"id5232443e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s132"},"text":null,"children":[{"tag":"num","attrib":{"value":"132"},"text":"§ 132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation and composition of district courts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id5232443f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in each judicial district a district court which shall be a court of record known as the United States District Court for the district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52324440-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each district court shall consist of the district judge or judges for the district in regular active service. Justices or judges designated or assigned shall be competent to sit as judges of the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52324441-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by law, or rule or order of court, the judicial power of a district court with respect to any action, suit or proceeding may be exercised by a single judge, who may preside alone and hold a regular or special session of court at the same time other sessions are held by other judges.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52324442-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/895"},"text":"62 Stat. 895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/176/s2"},"text":"Pub. L. 88–176, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-11-13"},"text":"Nov. 13, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/331"},"text":"77 Stat. 331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52324443-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52324444-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 1, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s641"},"text":"section 641 of title 48","children":[],"tail":", U.S.C., 1940 ed., Territories and Insular Possessions ("},{"tag":"ref","attrib":{"href":"/us/act/1900-04-30/ch339/s86"},"text":"Apr. 30, 1900, ch. 339, § 86","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/31/158"},"text":"31 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1909-03-03/ch269/s1"},"text":"Mar. 3, 1909, ch. 269, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/838"},"text":"35 Stat. 838","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s1"},"text":"Mar. 3, 1911, ch. 231, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1087"},"text":"36 Stat. 1087","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1914-07-30/ch216"},"text":"July 30, 1914, ch. 216","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/580"},"text":"38 Stat. 580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-07-19/ch42/s313"},"text":"July 19, 1921, ch. 42, § 313","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/119"},"text":"42 Stat. 119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-02-12/ch220"},"text":"Feb. 12, 1925, ch. 220","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/890"},"text":"43 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-12-13/ch6/s1"},"text":"Dec. 13, 1926, ch. 6, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/19"},"text":"44 Stat. 19","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1"},"text":"section 1 of title 28","children":[],"tail":", U.S.C., 1940 ed., and "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s641"},"text":"section 641 of title 48","children":[],"tail":", U.S.C., 1940 ed., with changes in phraseology necessary to effect the consolidation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is derived from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s641"},"text":"section 641 of title 48","children":[],"tail":", U.S.C., 1940 ed., which applied only to the Territory of Hawaii. The revised section, by extending it to all districts, merely recognizes established practice."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Other portions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1"},"text":"section 1 of title 28","children":[],"tail":", U.S.C., 1940 ed., are incorporated in sections 133 and 134 of this title. The remainder of "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s641"},"text":"section 641 of title 48","children":[],"tail":", U.S.C., 1940 ed., is incorporated in sections 91 and 133 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52324445-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52324446-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1963—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/176"},"text":"Pub. L. 88–176","children":[],"tail":" inserted “regular” before “active service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52324447-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52324448-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Organization of Court","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s2/b"},"text":"Act June 25, 1948, ch. 646, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/985"},"text":"62 Stat. 985","children":[],"tail":", provided in part that the provisions of this title as set out in section 1 of act "},{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", with respect to the organization of the court, shall be construed as a continuation of existing law, and the tenure of the judges, officers, and employees thereof and of the United States attorneys and marshals and their deputies and assistants, in office on "},{"tag":"date","attrib":{"date":"1948-09-01"},"text":"Sept. 1, 1948","children":[],"tail":", shall not be affected by its enactment, but each of them shall continue to serve in the same capacity under the appropriate provisions of this title pursuant to his prior appointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
