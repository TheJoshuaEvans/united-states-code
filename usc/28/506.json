{"tag":"section","attrib":{"id":"id525d24c4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Attorneys General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall appoint, by and with the advice and consent of the Senate, 11 Assistant Attorneys General, who shall assist the Attorney General in the performance of his duties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id525d24c5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"Pub. L. 89–554, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/612"},"text":"80 Stat. 612","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s218"},"text":"Pub. L. 95–598, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2662"},"text":"92 Stat. 2662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tV/s506/a/2"},"text":"Pub. L. 109–177, title V, § 506(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/247"},"text":"120 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id525d24c6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id525d24c7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id525d24c8-3a70-