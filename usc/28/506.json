9"},"text":"38 Stat. 1049","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The number of Assistant Attorneys General referred to in the Act of ","children":[{"tag":"date","attrib":{"date":"1943-03-02"},"text":"Mar. 2, 1943","children":[],"tail":", is changed from “six” to “nine” to reflect the three additional Assistant Attorneys General authorized by 1950 Reorg. Plan No. 2, 1953 Reorg. Plan No. 4, and the Act of "},{"tag":"date","attrib":{"date":"1957-09-09"},"text":"Sept. 9, 1957","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “learned in the law” are omitted as unnecessary. Such a requirement is not made of the Attorney General, United States attorneys, or United States judges. (See reviser’s note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s501"},"text":"28 U.S.C. 501","children":[],"tail":", 1964 ed.)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reference in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s295"},"text":"section 295 of title 5","children":[],"tail":" to the Assistant Attorneys General assisting the Solicitor General are omitted on authority of the transfer of functions made by 1950 Reorg. Plan No. 2 and 1953 Reorg. Plan No. 4."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of 1950 Reorg. Plan No. 2, § 4, and 1953 Reorg. Plan No. 4, § 2, abolishing positions and transferring incumbents are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions relating to pay of Assistant Attorneys General are omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1964-08-14/s303/d"},"text":"§ 303(d) of the Act of August 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/426"},"text":"Pub. L. 88–426","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/418"},"text":"78 Stat. 418","children":[],"tail":", which is codified in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id525d24c9-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id525d24ca-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 506, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/909"},"text":"62 Stat. 909","children":[],"tail":", related to vacancies in the office of United States attorney, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s8/a"},"text":"Pub. L. 89–554, § 8(a)","children":[],"tail":", and reenactment in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s546"},"text":"section 546 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s4/c"},"text":"section 4(c) of Pub. L. 89–554","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id525d24cb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" substituted “11” for “ten”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" substituted “ten” for “nine”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role