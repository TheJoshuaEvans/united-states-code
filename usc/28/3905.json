{"tag":"section","attrib":{"id":"id52f5bbd5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3905"},"text":null,"children":[{"tag":"num","attrib":{"value":"3905"},"text":"§ 3905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney’s fees and interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52f5bbd6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney’s Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a covered employee, with respect to any claim under chapter 5 of title 3, or a qualified person with a disability, with respect to any claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s421"},"text":"section 421 of title 3","children":[],"tail":", is a prevailing party in any proceeding under section 1296 or section 1346(g), the court may award attorney’s fees, expert fees, and any other costs as would be appropriate if awarded under section 706(k) of the Civil Rights Act of 1964."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bbd7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any proceeding under section 1296 or section 1346(g), the same interest to compensate for delay in payment shall be made available as would be appropriate if awarded under section 717(d) of the Civil Rights Act of 1964.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52f5bbd8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s3905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Punitive Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in chapter 5 of title 3, no punitive damages may be awarded with respect to any claim under chapter 5 of title 3.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52f5bbd9-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/c"},"text":"Pub. L. 104–331, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4070"},"text":"110 Stat. 4070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52f5bbda-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52f5bbdb-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52f5bbdc-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 706 and 717 of the Civil Rights Act of 1964, referred to in subsecs. (a) and (b), are classified to sections 2000e–5 and 2000e–16, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52f5bbdd-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id52f5bbde-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/331/s3/d"},"text":"section 3(d) of Pub. L. 104–331","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1296"},"text":"section 1296 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
