{"tag":"section","attrib":{"id":"id52ba1256-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1744"},"text":null,"children":[{"tag":"num","attrib":{"value":"1744"},"text":"§ 1744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of United States Patent and Trademark Office documents, generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Copies of letters patent or of any records, books, papers, or drawings belonging to the United States Patent and Trademark Office and relating to patents, authenticated under the seal of the United States Patent and Trademark Office and certified by the Under Secretary of Commerce for Intellectual Property and Director of the United States Patent and Trademark Office, or by another officer of the United States Patent and Trademark Office authorized to do so by the Director, shall be admissible in evidence with the same effect as the originals.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any person making application and paying the required fee may obtain such certified copies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ba1257-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/948"},"text":"62 Stat. 948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s92/c"},"text":"May 24, 1949, ch. 139, § 92(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/103"},"text":"63 Stat. 103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/15/B"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(15)(B), (C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–584.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ba1258-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ba1259-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s127"},"text":"section 127 of title 15","children":[],"tail":", U.S.C., 1940 ed., Commerce and Trade, and title 28, U.S.C., 1940 ed., § 673 (R.S. § 892; "},{"tag":"ref","attrib":{"href":"/us/act/1920-03-19/ch104/s7"},"text":"Mar. 19, 1920, ch. 104, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/535"},"text":"41 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch535/s2"},"text":"Mar. 4, 1925, ch. 535, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1269"},"text":"43 Stat. 1269","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For purposes of uniformity, words “written or printed,” at the beginning of the section, were omitted. Similar sections in this chapter do not contain such words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or in his name attested by a chief of division duly designated by the commissioner,” after “Commissioner of Patents,” were omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ba125a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ba125b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “United States Patent and Trademark Office” for “Patent Office” wherever appearing in section catchline and text and in text substituted “Under Secretary of Commerce for Intellectual Property and Director of the United States Patent and Trademark Office” for “Commissioner of Patents” and “Director” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “patents” after “relating to” for “registered trade-marks, labels, or prints”, and inserted “or by another officer of the Patent Office authorized to do so by the Commissioner” after “Commissioner of Patents”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ba125c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52ba125d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" effective 4 months after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", see section 1000(a)(9) [title IV, § 4731] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t35/s1"},"text":"section 1 of Title 35","children":[],"tail":", Patents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
