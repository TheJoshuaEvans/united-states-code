{"tag":"section","attrib":{"id":"id528a76c7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621"},"text":null,"children":[{"tag":"num","attrib":{"value":"621"},"text":"§ 621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board; composition, tenure of members, compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id528a76c8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The activities of the Center shall be supervised by a Board to be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id528a76c9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Justice of the United States, who shall be the permanent Chairman of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76ca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two circuit judges, three district judges, one bankruptcy judge, and one magistrate judge, elected by vote of the members of the Judicial Conference of the United States, except that any circuit or district judge so elected may be either a judge in regular active service or a judge retired from regular active service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s371/b"},"text":"section 371(b) of this title","children":[],"tail":" but shall not be a member of the Judicial Conference of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id528a76cb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Administrative Office of the United States Courts, who shall be a permanent member of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528a76cc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of office of each elected member of the Board shall be four years. A member elected to serve for an unexpired term arising by virtue of the death, disability, retirement pursuant to section 371(a) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of this title","children":[],"tail":", or resignation of a member shall be elected only for such unexpired term."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528a76cd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No member elected for a four-year term shall be eligible for reelection to the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528a76ce-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s621/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Board shall serve without additional compensation, but shall be reimbursed for actual and necessary expenses incurred in the performance of their official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528a76cf-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/219/tI/s101"},"text":"Pub. L. 90–219, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-20"},"text":"Dec. 20, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/664"},"text":"81 Stat. 664","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII"},"text":"Pub. L. 95–598, title II","children":[],"tail":", §§ 228, 229, "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2665"},"text":"92 Stat. 2665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tVI/s601/b"},"text":"Pub. L. 104–317, title VI, § 601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3857"},"text":"110 Stat. 3857","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528a76d0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528a76d1-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528a76d2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317/s601/b/1"},"text":"Pub. L. 104–317, § 601(b)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “two active judges of the courts of appeals of the United States, three active judges of the district courts of the United States, one active judge of the bankruptcy courts of the United States elected by vote of the members of the Judicial Conference of the United States: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That the judges so elected shall not be members of the Judicial Conference of the United States; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317/s601/b/2"},"text":"Pub. L. 104–317, § 601(b)(2)","children":[],"tail":", substituted “retirement pursuant to section 371(a) or "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of this title","children":[],"tail":",” for “retirement,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/s228"},"text":"Pub. L. 95–598, § 228","children":[],"tail":", inserted reference to one active judge of the bankruptcy courts of the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598/s229"},"text":"Pub. L. 95–598, § 229","children":[],"tail":", struck out provisions requiring that "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s629"},"text":"section 629 of this title","children":[],"tail":" govern the terms of office of the first members elected to the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id528a76d3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528a76d4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/s402/c"},"text":"section 402(c) of Pub. L. 95–598","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of Title 11","children":[],"tail":", Bankruptcy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
