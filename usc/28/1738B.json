{"tag":"section","attrib":{"id":"id52ba11f7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738B"},"text":"§ 1738B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit for child support orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52ba11f8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate authorities of each State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba11f9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall enforce according to its terms a child support order made consistently with this section by a court of another State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba11fa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not seek or make a modification of such an order except in accordance with subsections (e), (f), and (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba11fb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba11fc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “child” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ba11fd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person under 18 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ba11fe-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person 18 or more years of age with respect to whom a child support order has been issued pursuant to the laws of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba11ff-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child’s State” means the State in which a child resides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1200-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child’s home State” means the State in which a child lived with a parent or a person acting as parent for at least 6 consecutive months immediately preceding the time of filing of a petition or comparable pleading for support and, if a child is less than 6 months old, the State in which the child lived from birth with any of them. A period of temporary absence of any of them is counted as part of the 6-month period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1201-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “child support” means a payment of money, continuing support, or arrearages or the provision of a benefit (including payment of health insurance, child care, and educational expenses) for the support of a child.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1202-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “child support order”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ba1203-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a judgment, decree, or order of a court requiring the payment of child support in periodic amounts or in a lump sum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ba1204-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52ba1205-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a permanent or temporary order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52ba1206-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial order or a modification of an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1207-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “contestant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ba1208-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person (including a parent) who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52ba1209-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims a right to receive child support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52ba120a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a party to a proceeding that may result in the issuance of a child support order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52ba120b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under a child support order; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ba120c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision of a State to which the right to obtain child support has been assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba120d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “court” means a court or administrative agency of a State that is authorized by State law to establish the amount of child support payable by a contestant or make a modification of a child support order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba120e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “modification” means a change in a child support order that affects the amount, scope, or duration of the order and modifies, replaces, supersedes, or otherwise is made subsequent to the child support order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba120f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the territories and possessions of the United States, and Indian country (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1210-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements of Child Support Orders","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A child support order made by a court of a State is made consistently with this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba1211-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a court that makes the order, pursuant to the laws of the State in which the court is located and subsections (e), (f), and (g)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ba1212-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has subject matter jurisdiction to hear the matter and enter such an order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ba1213-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has personal jurisdiction over the contestants; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1214-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable notice and opportunity to be heard is given to the contestants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1215-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court of a State that has made a child support order consistently with this section has continuing, exclusive jurisdiction over the order if the State is the child’s State or the residence of any individual contestant or the parties have consented in a record or open court that the tribunal of the State may continue to exercise jurisdiction to modify its order, unless the court of another State, acting in accordance with subsections (e) and (f), has made a modification of the order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1216-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Modify Orders","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A court of a State may modify a child support order issued by a court of another State if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba1217-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court has jurisdiction to make such a child support order pursuant to subsection (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1218-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52ba1219-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court of the other State no longer has continuing, exclusive jurisdiction of the child support order because that State no longer is the child’s State or the residence of any individual contestant and the parties have not consented in a record or open court that the tribunal of the other State may continue to exercise jurisdiction to modify its order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52ba121a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each individual contestant has filed written consent with the State of continuing, exclusive jurisdiction for a court of another State to modify the order and assume continuing, exclusive jurisdiction over the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba121b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recognition of Child Support Orders","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If 1 or more child support orders have been issued with regard to an obligor and a child, a court shall apply the following rules in determining which order to recognize for purposes of continuing, exclusive jurisdiction and enforcement:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba121c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If only 1 court has issued a child support order, the order of that court must be recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba121d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If 2 or more courts have issued child support orders for the same obligor and child, and only 1 of the courts would have continuing, exclusive jurisdiction under this section, the order of that court must be recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba121e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If 2 or more courts have issued child support orders for the same obligor and child, and more than 1 of the courts would have continuing, exclusive jurisdiction under this section, an order issued by a court in the current home State of the child must be recognized, but if an order has not been issued in the current home State of the child, the order most recently issued must be recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba121f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If 2 or more courts have issued child support orders for the same obligor and child, and none of the courts would have continuing, exclusive jurisdiction under this section, a court having jurisdiction over the parties shall issue a child support order, which must be recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1220-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court that has issued an order recognized under this subsection is the court having continuing, exclusive jurisdiction under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1221-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement of Modified Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A court of a State that no longer has continuing, exclusive jurisdiction of a child support order may enforce the order with respect to nonmodifiable obligations and unsatisfied obligations that accrued before the date on which a modification of the order is made under subsections (e) and (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1222-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Choice of Law.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id52ba1223-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a proceeding to establish, modify, or enforce a child support order, the forum State’s law shall apply except as provided in paragraphs (2) and (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1224-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Law of state of issuance of order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In interpreting a child support order including the duration of current payments and other obligations of support, a court shall apply the law of the State of the court that issued the order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52ba1225-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an action to enforce arrears under a child support order, a court shall apply the statute of limitation of the forum State or the State of the court that issued the order, whichever statute provides the longer period of limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52ba1226-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1738B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration for Modification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If there is no individual contestant or child residing in the issuing State, the party or support enforcement agency seeking to modify, or to modify and enforce, a child support order issued in another State shall register that order in a State with jurisdiction over the nonmovant for the purpose of modification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52ba1227-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/383/s3/a"},"text":"Pub. L. 103–383, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4064"},"text":"108 Stat. 4064","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tIII/s322"},"text":"Pub. L. 104–193, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2221"},"text":"110 Stat. 2221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV/s5554"},"text":"Pub. L. 105–33, title V, § 5554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/636"},"text":"111 Stat. 636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/183/tIII/s301/f/2"},"text":"Pub. L. 113–183, title III, § 301(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-29"},"text":"Sept. 29, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1944"},"text":"128 Stat. 1944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ba1228-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52ba1229-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52ba122a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/s301/f/2/C"},"text":"Pub. L. 113–183, § 301(f)(2)(C)","children":[],"tail":", inserted designations for pars. (1) to (9) and “The term” after each designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/s301/f/2/A"},"text":"Pub. L. 113–183, § 301(f)(2)(A)","children":[],"tail":", substituted “individual contestant or the parties have consented in a record or open court that the tribunal of the State may continue to exercise jurisdiction to modify its order,” for “individual contestant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/s301/f/2/B"},"text":"Pub. L. 113–183, § 301(f)(2)(B)","children":[],"tail":", substituted “individual contestant and the parties have not consented in a record or open court that the tribunal of the other State may continue to exercise jurisdiction to modify its order” for “individual contestant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (f)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5554/1"},"text":"Pub. L. 105–33, § 5554(1)","children":[],"tail":", substituted “a court having jurisdiction over the parties shall issue a child support order, which must be recognized.” for “a court may issue a child support order, which must be recognized.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5554/2"},"text":"Pub. L. 105–33, § 5554(2)","children":[],"tail":", inserted “under subsection (d)” after “jurisdiction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/1"},"text":"Pub. L. 104–193, § 322(1)","children":[],"tail":", substituted “subsections (e), (f), and (i)” for “subsection (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/2"},"text":"Pub. L. 104–193, § 322(2)","children":[],"tail":", inserted par. defining “child’s home State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/3"},"text":"Pub. L. 104–193, § 322(3)","children":[],"tail":", inserted “by a court of a State” before “is made” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/4"},"text":"Pub. L. 104–193, § 322(4)","children":[],"tail":", inserted “and subsections (e), (f), and (g)” after “located”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/5"},"text":"Pub. L. 104–193, § 322(5)","children":[],"tail":", inserted “individual” before “contestant” and substituted “subsections (e) and (f)” for “subsection (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/6"},"text":"Pub. L. 104–193, § 322(6)","children":[],"tail":", substituted “modify a child support order issued” for “make a modification of a child support order with respect to a child that is made” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/7"},"text":"Pub. L. 104–193, § 322(7)","children":[],"tail":", inserted “pursuant to subsection (i)” after “order”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/8"},"text":"Pub. L. 104–193, § 322(8)","children":[],"tail":", inserted “individual” before “contestant” in subpars. (A) and (B) and substituted “with the State of continuing, exclusive jurisdiction for a court of another State to modify the order and assume” for “to that court’s making the modification and assuming” in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/10"},"text":"Pub. L. 104–193, § 322(10)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/11"},"text":"Pub. L. 104–193, § 322(11)","children":[],"tail":", substituted “Modified” for “Prior” in heading and “subsections (e) and (f)” for “subsection (e)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/9"},"text":"Pub. L. 104–193, § 322(9)","children":[],"tail":", redesignated subsec. (f) as (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/12"},"text":"Pub. L. 104–193, § 322(12)","children":[],"tail":", inserted “including the duration of current payments and other obligations of support” before comma in par. (2) and “arrears under” after “enforce” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/9"},"text":"Pub. L. 104–193, § 322(9)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s322/13"},"text":"Pub. L. 104–193, § 322(13)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52ba122b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52ba122c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/183/tIII/s301/f/3/B"},"text":"Pub. L. 113–183, title III, § 301(f)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-09-29"},"text":"Sept. 29, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1945"},"text":"128 Stat. 1945","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/183/tIII/s301/f/3/B"},"text":"\n","children":[{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subparagraphs (A) and (B) of paragraph (2) [amending this section] shall take effect on the date on which the Hague Convention of 23 November 2007 on the International Recovery of Child Support and Other Forms of Family Maintenance enters into force for the United States [The Convention entered into force for the United States ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"Jan. 1, 2017","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subparagraph (C) of paragraph (2) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-09-29"},"text":"Sept. 29, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52ba122d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in enactment of title III of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5557"},"text":"section 5557 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s608"},"text":"section 608 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52ba122e-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see section 395(a)–(c) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s654"},"text":"section 654 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id52ba122f-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings and Declaration of Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/383/s2"},"text":"Pub. L. 103–383, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4063"},"text":"108 Stat. 4063","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/383/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a large and growing number of child support cases annually involving disputes between parents who reside in different States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws by which the courts of different jurisdictions determine their authority to establish child support orders are not uniform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" those laws, along with the limits imposed by the Federal system on the authority of each State to take certain actions outside its own boundaries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage noncustodial parents to relocate outside the States where their children and the custodial parents reside to avoid the jurisdiction of the courts of such States, resulting in an increase in the amount of interstate travel and communication required to establish and collect on child support orders and a burden on custodial parents that is expensive, time consuming, and disruptive of occupations and commercial activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute to the pressing problem of relatively low levels of child support payments in interstate cases and to inequities in child support payments levels that are based solely on the noncustodial parent’s choice of residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage a disregard of court orders resulting in massive arrearages nationwide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow noncustodial parents to avoid the payment of regularly scheduled child support payments for extensive periods of time, resulting in substantial hardship for the children for whom support is due and for their custodians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to the excessive relitigation of cases and to the establishment of conflicting orders by the courts of various jurisdictions, resulting in confusion, waste of judicial resources, disrespect for the courts, and a diminution of public confidence in the rule of law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" among the results of the conditions described in this subsection are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the courts of the States to give full faith and credit to the judicial proceedings of the other States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deprivation of rights of liberty and property without due process of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" burdens on commerce among the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harm to the welfare of children and their parents and other custodians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In view of the findings made in subsection (a), it is necessary to establish national standards under which the courts of the various States shall determine their jurisdiction to issue a child support order and the effect to be given by each State to child support orders issued by the courts of other States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this Act [enacting this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1"},"text":"section 1 of this title","children":[],"tail":"] are—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the enforcement of child support orders among the States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to discourage continuing interstate controversies over child support in the interest of greater financial stability and secure family relationships for the child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to avoid jurisdictional competition and conflict among State courts in the establishment of child support orders.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
