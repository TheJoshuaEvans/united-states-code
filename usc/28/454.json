{"tag":"section","attrib":{"id":"id52586986-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s454"},"text":null,"children":[{"tag":"num","attrib":{"value":"454"},"text":"§ 454.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practice of law by justices and judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any justice or judge appointed under the authority of the United States who engages in the practice of law is guilty of a high misdemeanor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52586987-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/908"},"text":"62 Stat. 908","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52586988-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52586989-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 373 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s258"},"text":"Mar. 3, 1911, ch. 231, § 258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1161"},"text":"36 Stat. 1161","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
