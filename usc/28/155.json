{"tag":"section","attrib":{"id":"id523e2b20-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s155"},"text":null,"children":[{"tag":"num","attrib":{"value":"155"},"text":"§ 155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary transfer of bankruptcy judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id523e2b21-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bankruptcy judge may be transferred to serve temporarily as a bankruptcy judge in any judicial district other than the judicial district for which such bankruptcy judge was appointed upon the approval of the judicial council of each of the circuits involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id523e2b22-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bankruptcy judge who has retired may, upon consent, be recalled to serve as a bankruptcy judge in any judicial district by the judicial council of the circuit within which such district is located. Upon recall, a bankruptcy judge may receive a salary for such service in accordance with regulations promulgated by the Judicial Conference of the United States, subject to the restrictions on the payment of an annuity in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s377"},"text":"section 377 of this title","children":[],"tail":" or in subchapter III of chapter 83, and chapter 84, of title 5 which are applicable to such judge."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id523e2b23-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/353/tI/s104/a"},"text":"Pub. L. 98–353, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-10"},"text":"July 10, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/339"},"text":"98 Stat. 339","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/651/tII/s202/a"},"text":"Pub. L. 99–651, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3648"},"text":"100 Stat. 3648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/659/s4/a"},"text":"Pub. L. 100–659, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-15"},"text":"Nov. 15, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3918"},"text":"102 Stat. 3918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id523e2b24-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id523e2b25-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id523e2b26-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/659"},"text":"Pub. L. 100–659","children":[],"tail":" inserted “"},{"tag":"ref","attrib":{"href":"/us/usc/t28/s377"},"text":"section 377 of this title","children":[],"tail":" or in” after “annuity in” and “which are applicable to such judge” after “title 5”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/651"},"text":"Pub. L. 99–651","children":[],"tail":" inserted reference to chapter 84 of title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id523e2b27-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id523e2b28-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/659"},"text":"Pub. L. 100–659","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-11-15"},"text":"Nov. 15, 1988","children":[],"tail":", and applicable to bankruptcy judges and magistrate judges who retire on or after "},{"tag":"date","attrib":{"date":"1988-11-15"},"text":"Nov. 15, 1988","children":[],"tail":", with exception for judges and magistrate judges retiring on or after "},{"tag":"date","attrib":{"date":"1987-07-31"},"text":"July 31, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/659/s9"},"text":"section 9 of Pub. L. 100–659","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s377"},"text":"section 377 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id523e2b29-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/651/tII/s203"},"text":"Pub. L. 99–651, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},