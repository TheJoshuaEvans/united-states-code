{"tag":"section","attrib":{"id":"id52cada99-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2043"},"text":null,"children":[{"tag":"num","attrib":{"value":"2043"},"text":"§ 2043.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of other moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except for public moneys deposited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2041"},"text":"section 2041 of this title","children":[],"tail":", each clerk of the United States courts shall deposit public moneys that the clerk collects into a checking account in the Treasury, subject to disbursement by the clerk. At the end of each accounting period, the earned part of public moneys accruing to the United States shall be deposited in the Treasury to the credit of the appropriate receipt accounts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52cada9a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2/g/4/E"},"text":"Pub. L. 97–258, § 2(g)(4)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1061"},"text":"96 Stat. 1061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52cada9b-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cada9c-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id52cada9d-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}