us/act/1944-12-21/ch631/s1"},"text":"Dec. 21, 1944, ch. 631, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/845"},"text":"58 Stat. 845","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Except for public moneys deposited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2041"},"text":"section 2041 of this title","children":[],"tail":" . . . public moneys” are substituted for “All fees and other collections other than moneys referred to in subsection (a) of this section” for consistency and because 31:725v(a) is superseded by 28:2041 and is not part of the revised title contained in section 1 of the bill. The word “Treasury” is substituted for “Treasurer of the United States” because of section 1 of Reorganization Plan No. 26 of 1950 (eff. "},{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":"), restated as section 321 of the revised title contained in section 1 of the bill. The text of 31:725v(b)(last sentence) is omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
