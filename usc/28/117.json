{"tag":"section","attrib":{"id":"id522fd2c3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oregon","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Oregon constitutes one judicial district.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Court shall be held at Coquille, Eugene or Springfield, Klamath Falls, Medford, Pendleton, and Portland.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id522fd2c4-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/888"},"text":"62 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-03/ch514"},"text":"Aug. 3, 1950, ch. 514","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/393"},"text":"64 Stat. 393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/272/s7"},"text":"Pub. L. 91–272, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/297"},"text":"84 Stat. 297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/518/tV/s502"},"text":"Pub. L. 106–518, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2422"},"text":"114 Stat. 2422","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522fd2c5-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522fd2c6-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 183 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s102"},"text":"Mar. 3, 1911, ch. 231, § 102","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1122"},"text":"36 Stat. 1122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1945-11-06/ch447"},"text":"Nov. 6, 1945, ch. 447","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/555"},"text":"59 Stat. 555","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions relating to appointment and residence of deputies by the clerk and marshal, and maintenance of offices by said officers, were omitted as covered by sections 541 [see 561], 542 [see 561], and 751 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522fd2c7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522fd2c8-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518"},"text":"Pub. L. 106–518","children":[],"tail":" substituted “Eugene or Springfield” for “Eugene”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/272"},"text":"Pub. L. 91–272","children":[],"tail":" provided for holding court at Coquille."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Act ","children":[{"tag":"date","attrib":{"date":"1950-08-03"},"text":"Aug. 3, 1950","children":[],"tail":", provided for holding court at Eugene."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
