{"tag":"section","attrib":{"id":"id521f3126-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"§ 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of former court of appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The records and proceedings of the court of appeals, appointed previous to the adoption of the Constitution, shall be kept until deposited with the National Archives of the United States in the office of the clerk of the Supreme Court, who shall furnish copies thereof to any person requiring and paying for them, in the manner provided by law for giving copies of the records and proceedings of the Supreme Court. Such copies shall have the same faith and credit as proceedings of the Supreme Court.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id521f3127-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/870"},"text":"62 Stat. 870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-25/ch562/s4/7"},"text":"Oct. 25, 1951, ch. 562, § 4(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/640"},"text":"65 Stat. 640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id521f3128-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id521f3129-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 329 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s222"},"text":"Mar. 3, 1911, ch. 231, § 222","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1153"},"text":"36 Stat. 1153","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In a letter dated ","children":[{"tag":"date","attrib":{"date":"1944-08-08"},"text":"August 8, 1944","children":[],"tail":", the clerk of the Supreme Court advised that many of the early records mentioned in this section were destroyed by fire. Others are on file in the Clerk’s office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Minor changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id521f312a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id521f312b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-25"},"text":"Oct. 25, 1951","children":[],"tail":", inserted “until deposited with the National Archives of the United States” in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
