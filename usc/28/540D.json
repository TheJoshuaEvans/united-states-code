{"tag":"section","attrib":{"id":"id52703783-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D"},"text":null,"children":[{"tag":"num","attrib":{"value":"540D"},"text":"§ 540D.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multidisciplinary teams","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52703784-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52703785-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “child sexual abuse material” means a visual depiction described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2256/8/A"},"text":"section 2256(8)(A) of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703786-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered investigation” means any investigation of child sexual exploitation or abuse, the production of child sexual abuse material, or child trafficking conducted by the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703787-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Director” means the Director of the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703788-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “multidisciplinary team” means a multidisciplinary team established or used under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703789-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “relevant children’s advocacy center personnel” means children’s advocacy center staff that regularly participate in multidisciplinary child support settings, including the director of the children’s advocacy center, the coordinator of a multidisciplinary team, forensic interviewers, victim advocates, forensic medical evaluators, physicians, sexual assault nurse examiners, and mental health clinicians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270378a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “victim advocate” means a person, whether paid or serving as a volunteer, who provides services to victims under the auspices or supervision of a victim services program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id5270378b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FBI Victim Support Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id5270378c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the functions described in subsection (c) in connection with each covered investigation conducted by the Federal Bureau of Investigation, the Director shall, unless unavailable or otherwise inconsistent with applicable Federal law—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5270378d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a multidisciplinary team; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5270378e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in accordance with paragraph (3), use—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5270378f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trained Federal Bureau of Investigation child adolescent forensic interviewer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703790-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of a trained Federal Bureau of Investigation child adolescent forensic interviewer, a trained forensic interviewer at a children’s advocacy center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703791-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use and coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall use and coordinate with children’s advocacy center-based multidisciplinary teams as necessary to carry out paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703792-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Children’s advocacy centers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52703793-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may work with children’s advocacy centers to implement a multidisciplinary team approaches ","children":[{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" for purposes of covered investigations; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id52703794-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall allow, facilitate, and encourage multidisciplinary teams to collaborate with a children’s advocacy center with regard to availability, provision, and use of services to and by victims and families that are participants in or affected by the actions at issue in a covered investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52703795-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit to the Attorney General an annual report identifying any interview of a victim reporting child sexual abuse material or child trafficking that took place—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id52703796-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without the use of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id52703797-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multidisciplinary approach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703798-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trained forensic interviewer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id52703799-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either the use of a multidisciplinary approach or a trained forensic interviewer; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5270379a-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each interview identified under subparagraph (A), describing the exigent circumstances that existed with respect to the interview, in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5270379b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Memoranda of understanding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall seek to enter into a memorandum of understanding with a reputable national accrediting organization for children’s advocacy centers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id5270379c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id5270379d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the children’s advocacy services of the national organization are made available to field offices of the Federal Bureau of Investigation in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id5270379e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special agents and other employees of the Federal Bureau of Investigation are made aware of the existence of such memoranda and its purposes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id5270379f-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which shall reflect a trauma-informed, victim-centered approach and provide for case review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037a0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id527037a1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide for the sharing of information among the members of a multidisciplinary team, when such a team is used, and with other appropriate personnel regarding the progress of a covered investigation by the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037a2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide for and enhance collaborative efforts among the members of a multidisciplinary team, when such a team is used, and other appropriate personnel regarding a covered investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037a3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enhance the social services available to victims in connection with a covered investigation, including through the enhancement of cooperation among specialists and other personnel providing such services in connection with a covered investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037a4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out other duties regarding the response to investigations of child sexual abuse or trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037a5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id527037a6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each multidisciplinary team shall be composed of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id527037a7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate investigative personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037a8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate mental health professionals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037a9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate medical personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037aa-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Victim advocates or victim specialists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037ab-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relevant children’s advocacy center personnel, with respect to covered investigations in which the children’s advocacy center or personnel of the children’s advocacy center were used in the course of the covered investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037ac-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prosecutors, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037ad-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise and training.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id527037ae-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any individual assigned to a multidisciplinary team shall possess such expertise, and shall undertake such training as is required to maintain such expertise, in order to ensure that members of the team remain appropriately qualified to carry out the functions of the team under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037af-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training and expertise required under subparagraph (A) shall include training and expertise on special victims’ crimes, including child sexual abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037b0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sharing of Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id527037b1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to information.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id527037b2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraphs (B) and (C), relevant children’s advocacy center personnel who are assigned to work on a covered investigation under this section shall be granted access to the case information necessary to perform their role conducting forensic interviews and providing mental health treatment, medical care, and victim advocacy for Federal Bureau of Investigation cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037b3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Included information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The case information described in subparagraph (A) to which relevant children’s advocacy center personnel shall be granted access includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id527037b4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case outcome of forensic interviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037b5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical evaluation outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037b6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mental health treatment referrals and treatment completion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037b7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety planning and child protection issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037b8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victim service needs and referrals addressed by the victim advocate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037b9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case disposition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037ba-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037bb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information required for a children’s advocacy centers ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" as a part of the standards of practice of the children’s advocacy center; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037bc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exempt information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The case information described in subparagraph (A) does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id527037bd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037be-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of confidential informants; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id527037bf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other investigative information not included as a part of the standards of practice of the children’s advocacy center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037c0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sharing information with fbi","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Children’s advocacy centers shall provide the Federal Bureau of Investigation with forensic interview recordings and documentation, medical reports, and other case information on Federal Bureau of Investigation-related cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037c1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security clearances.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id527037c2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Bureau of Investigation may provide security clearances to relevant children’s advocacy center personnel for purposes of case review by multidisciplinary teams, if it is determined that those personnel are eligible and possess a need-to-know specific classified information to perform or assist in a lawful and authorized government function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id527037c3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated such sums as are necessary to carry out subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037c4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Teams","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Multidisciplinary teams used under this section shall be made available to victims reporting child sexual abuse or child trafficking in covered investigations, regardless of the age of the victim making the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037c5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Case Review by Multidisciplinary Team","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Throughout a covered investigation, a multidisciplinary team supporting an investigation under this section shall, at regularly scheduled times, convene to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id527037c6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share information about case progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037c7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address any investigative or prosecutorial barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037c8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that victims receive support and needed treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037c9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Advocates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall make advocates available to each victim who reports child sexual abuse or child trafficking in connection with an investigation by the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id527037ca-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id527037cb-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigative authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to augment any existing investigative authority of the Federal Bureau of Investigation or to expand the jurisdiction of any Federal law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id527037cc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s540D/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protecting investigations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to limit the legal obligations of the Director under any other provision of law, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly known as the “Privacy Act of 1974”), or require the sharing of classified information with unauthorized persons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id527037cd-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/354/s2/a"},"text":"Pub. L. 117–354, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6270"},"text":"136 Stat. 6270","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
