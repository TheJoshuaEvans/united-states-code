{"tag":"section","attrib":{"id":"id52e9d4de-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640"},"text":null,"children":[{"tag":"num","attrib":{"value":"2640"},"text":"§ 2640.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope and standard of review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52e9d4df-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Court of International Trade shall make its determinations upon the basis of the record made before the court in the following categories of civil actions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52e9d4e0-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil actions contesting the denial of a protest under section 515 of the Tariff Act of 1930.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4e1-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil actions commenced under section 516 of the Tariff Act of 1930.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4e2-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil actions commenced to review a final determination made under section 305(b)(1) of the Trade Agreements Act of 1979.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4e3-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil actions commenced under section 777(c)(2) of the Tariff Act of 1930.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4e4-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil actions commenced to review any decision of the Secretary of the Treasury under section 641 of the Tariff Act of 1930, with the exception of decisions under section 641(d)(2)(B), which shall be governed by subdivision (d) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52e9d4e5-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil actions commenced under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1582"},"text":"section 1582 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d4e6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil action commenced in the Court of International Trade under section 516A of the Tariff Act of 1930, the court shall review the matter as specified in subsection (b) of such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d4e7-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil action commenced in the Court of International Trade to review any final determination of the Secretary of Labor under section 223 of the Trade Act of 1974 or any final determination of the Secretary of Commerce under section 251 or section 271 of such Act, the court shall review the matter as specified in section 284 of such Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d4e8-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil action commenced to review any order or decision of the Customs Service under section 499(b) of the Tariff Act of 1930, the court shall review the action on the basis of the record before the Customs Service at the time of issuing such decision or order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52e9d4e9-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2640/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any civil action not specified in this section, the Court of International Trade shall review the matter as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52e9d4ea-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/417/tIII/s301"},"text":"Pub. L. 96–417, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1736"},"text":"94 Stat. 1736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/573/tII/s212/b/5"},"text":"Pub. L. 98–573, title II, § 212(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2984"},"text":"98 Stat. 2984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/tVI/s684/a/4"},"text":"Pub. L. 103–182, title VI, § 684(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-08"},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2219"},"text":"107 Stat. 2219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52e9d4eb-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52e9d4ec-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52e9d4ed-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 515 of the Tariff Act of 1930, referred to in subsec. (a)(1), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1515"},"text":"section 1515 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 516 of the Tariff Act of 1930, referred to in subsec. (a)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516"},"text":"section 1516 of Title 19","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 305(b)(1) of the Trade Agreements Act of 1979, referred to in subsec. (a)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2515/b/1"},"text":"section 2515(b)(1) of Title 19","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 777(c)(2) of the Tariff Act of 1930, referred to in subsec. (a)(4), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677f/c/2"},"text":"section 1677f(c)(2) of Title 19","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 641 of the Tariff Act of 1930, referred to in subsec. (a)(5), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1641"},"text":"section 1641 of Title 19","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 516A of the Tariff Act of 1930, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of Title 19","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 223, 251, 271, and 284 of the Trade Act of 1974, referred to in subsec. (c), are classified to sections 2273, 2341, 2371, and 2395, respectively, of Title 19, Customs Duties. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2371"},"text":"Section 2371 of Title 19","children":[],"tail":" was omitted from the Code as terminated "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"Sept. 30, 1982","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 499(b) of the Tariff Act of 1930, referred to in subsec. (d), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1499/b"},"text":"section 1499(b) of Title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id52e9d4ee-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2640, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/982"},"text":"62 Stat. 982","children":[],"tail":", authorized the division which had decided a case or the single judge who had decided an appeal for a reappraisement to grant a rehearing or retrial, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/91/271/tI/s121"},"text":"Pub. L. 91–271, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-06-02"},"text":"June 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/281"},"text":"84 Stat. 281","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2646"},"text":"section 2646 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52e9d4ef-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/573"},"text":"Pub. L. 98–573","children":[],"tail":" amended par. (5) generally, substituting “under section 641 of the Tariff Act of 1930, with the exception of decisions under section 641(d)(2)(B), which shall be governed by subdivision (d) of this section” for “to deny or revoke a customhouse broker’s license under section 641(a) of the Tariff Act of 1930”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52e9d4f0-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment