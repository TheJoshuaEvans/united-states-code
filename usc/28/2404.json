{"tag":"section","attrib":{"id":"id52ddee31-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2404"},"text":null,"children":[{"tag":"num","attrib":{"value":"2404"},"text":"§ 2404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death of defendant in damage action","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A civil action for damages commenced by or on behalf of the United States or in which it is interested shall not abate on the death of a defendant but shall survive and be enforceable against his estate as well as against surviving defendants.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52ddee32-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/971"},"text":"62 Stat. 971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52ddee33-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52ddee34-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 780a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-16/ch103"},"text":"June 16, 1933, ch. 103","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/311"},"text":"48 Stat. 311","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Substitution of parties, see rule 25(a) of the Federal Rules of Civil Procedure.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
