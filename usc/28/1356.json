{"tag":"section","attrib":{"id":"id52a4b47e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1356"},"text":null,"children":[{"tag":"num","attrib":{"value":"1356"},"text":"§ 1356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizures not within admiralty and maritime jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts shall have original jurisdiction, exclusive of the courts of the States, of any seizure under any law of the United States on land or upon waters not within admiralty and maritime jurisdiction, except matters within the jurisdiction of the Court of International Trade under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1582"},"text":"section 1582 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a4b47f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/934"},"text":"62 Stat. 934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/417/tV/s508"},"text":"Pub. L. 96–417, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-10"},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1743"},"text":"94 Stat. 1743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52a4b480-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52a4b481-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 41(3) and 371(4) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-