{"tag":"section","attrib":{"id":"id5232440b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s125"},"text":null,"children":[{"tag":"num","attrib":{"value":"125"},"text":"§ 125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utah","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Utah constitutes one judicial district comprising two divisions.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id5232440c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s125/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Northern Division comprises the counties of Box Elder, Cache, Davis, Morgan, Rich, and Weber.","children":[{"tag":"p","attrib":{},"text":"Court for the Northern Division shall be held at Salt Lake City and Ogden.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id5232440d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s125/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Central Division comprises the counties of Beaver, Carbon, Daggett, Duchesne, Emery, Garfield, Grand, Iron, Juab, Kane, Millard, Piute, Salt Lake, San Juan, Sanpete, Sevier, Summit, Tooele, Uintah, Utah, Wasatch, Washington, and Wayne.","children":[{"tag":"p","attrib":{},"text":"Court for the Central Division shall be held at Salt Lake City, Provo, St. George, Moab, and Monticello..","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id5232440e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/893"},"text":"62 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/317/tVI/s606"},"text":"Pub. L. 104–317, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3859"},"text":"110 Stat. 3859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/250/s1"},"text":"Pub. L. 118–250, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2939"},"text":"138 Stat. 2939","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id5232440f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52324410-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 190 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s109"},"text":"Mar. 3, 1911, ch. 231, § 109","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1127"},"text":"36 Stat. 1127","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A provision relating to the maintenance of offices by the clerk was omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52324411-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52324412-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/250"},"text":"Pub. L. 118–250","children":[],"tail":" substituted “St. George, Moab, and Monticello.” for “and St. George”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317/s606/a"},"text":"Pub. L. 104–317, § 606(a)","children":[],"tail":", inserted “Salt Lake City and” before “Ogden”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/317/s606/b"},"text":"Pub. L. 104–317, § 606(b)","children":[],"tail":", inserted “, Provo, and St. George” after “Salt Lake City”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
