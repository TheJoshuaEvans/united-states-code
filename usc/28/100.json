{"tag":"section","attrib":{"id":"id522b185c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s100"},"text":null,"children":[{"tag":"num","attrib":{"value":"100"},"text":"§ 100.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maryland","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Maryland constitutes one judicial district comprising two divisions.","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id522d624d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s100/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Northern Division comprises the counties of Allegany, Anne Arundel, Baltimore, Caroline, Carroll, Cecil, Dorchester, Frederick, Garrett, Harford, Howard, Kent, Queen Anne’s, Somerset, Talbot, Washington, Wicomico, and Worcester, and the City of Baltimore.","children":[{"tag":"p","attrib":{},"text":"Court for the Northern Division shall be held at Baltimore, Cumberland, and Denton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id522d624e-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s100/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Southern Division comprises the counties of Calvert, Charles, Montgomery, Prince George’s, and St. Mary’s.","children":[{"tag":"p","attrib":{},"text":"Court for the Southern Division shall be held at a suitable site in Montgomery or Prince George’s County not more than five miles from the boundary of Montgomery and Prince George’s Counties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id522d624f-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/882"},"text":"62 Stat. 882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/546/s4"},"text":"Pub. L. 91–546, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-14"},"text":"Dec. 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1412"},"text":"84 Stat. 1412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/487/s1"},"text":"Pub. L. 100–487, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-14"},"text":"Oct. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2431"},"text":"102 Stat. 2431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id522d6250-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id522d6251-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 166 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s86"},"text":"Mar. 3, 1911, ch. 231, § 86","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1114"},"text":"36 Stat. 1114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch422"},"text":"Mar. 3, 1925, ch. 422","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1106"},"text":"43 Stat. 1106","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions relating to appointment of a deputy clerk and a deputy marshal and the maintenance of offices by such deputies were omitted as covered by sections 541 [see 561], 542 [see 561], and 751 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisions respecting court accommodations at Denton were omitted as covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in arrangement and phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id522d6252-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id522d6253-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/702"},"text":"Pub. L. 100–702","children":[],"tail":" amended section generally. Prior to amendment, section provided that Maryland constituted one judicial district and that court be held at Baltimore, Cumberland, Denton, and at a suitable site in Prince Georges County not more than five miles from the boundary of Montgomery and Prince Georges Counties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/546"},"text":"Pub. L. 91–546","children":[],"tail":" added a suitable site in Prince Georges County not more than five miles from the boundary of Montgomery and Prince Georges Counties to the list of enumerated places for holding court in Maryland."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id522d6254-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id522d6255-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/487/s2"},"text":"Pub. L. 100–487, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-14"},"text":"Oct. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2431"},"text":"102 Stat. 2431","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/487/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act and the amendments made by this Act [amending this section] shall take effect 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-10-14"},"text":"Oct. 14, 1988","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending Cases Not Affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act and the amendments made by this Act shall not affect any action commenced before the effective date of this Act and pending in the United States District Court for the District of Maryland on such date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Juries Not Affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act and the amendments made by this Act shall not affect the composition, or preclude the service, of any grand or petit jury summoned, empaneled, or actually serving in the Judicial District of Maryland on the effective date of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
