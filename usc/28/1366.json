{"tag":"section","attrib":{"id":"id52a4b4c6-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s1366"},"text":null,"children":[{"tag":"num","attrib":{"value":"1366"},"text":"§ 1366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of references to laws of the United States or Acts of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this chapter, references to laws of the United States or Acts of Congress do not include laws applicable exclusively to the District of Columbia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id52a4b4c7-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/358/tI/s172/c/1"},"text":"Pub. L. 91–358, title I, § 172(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-29"},"text":"July 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/590"},"text":"84 Stat. 590","children":[],"tail":", § 1363; renumbered § 1364, "},{"tag":"ref","attrib":{"href":"/us/pl/95/572/s6/b/1"},"text":"Pub. L. 95–572, § 6(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2456"},"text":"92 Stat. 2456","children":[],"tail":"; renumbered § 1366, "},{"tag":"ref","attrib":{"href":"/us/pl/99/336/s6/a/1/C"},"text":"Pub. L. 99–336, § 6(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/639"},"text":"100 Stat. 639","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
