{"tag":"section","attrib":{"id":"id52690b50-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s530A"},"text":null,"children":[{"tag":"num","attrib":{"value":"530A"},"text":"§ 530A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for travel and related expenses and for health care of personnel serving abroad","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are authorized to be used from appropriations, for any fiscal year, for the Department of Justice, such sums as may be necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52690b51-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s530A/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for travel and related expenses of employees of the Department of Justice serving abroad and their families, to be payable in the same manner as applicable with respect to the Foreign Service under paragraphs (2), (3), (5), (6), (8), (9), (11), and (15) of section 901 of the Foreign Service Act of 1980, and under the regulations issued by the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52690b52-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s530A/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for health care for such employees and families, to be provided under section 904 of that Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52690b53-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6281/a"},"text":"Pub. L. 100–690, title VI, § 6281(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4368"},"text":"102 Stat. 4368","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/55/dB/tII/s218"},"text":"Pub. L. 112–55, div. B, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/621"},"text":"125 Stat. 621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52690b54-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52690b55-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52690b56-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 901 and 904 of the Foreign Service Act of 1980, referred to in pars. (1) and (2), are classified to sections 4081 and 4084, respectively, of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52690b57-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52690b58-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/55"},"text":"Pub. L. 112–55","children":[],"tail":" substituted “used from appropriations” for “appropriated” in introductory provisions and inserted “(2),” before “(3)” in par. (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
