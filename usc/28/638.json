{"tag":"section","attrib":{"id":"id528f31bc-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s638"},"text":null,"children":[{"tag":"num","attrib":{"value":"638"},"text":"§ 638.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dockets and forms; United States Code; seals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id528f31bd-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s638/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall furnish to United States magistrate judges adequate docket books and forms prescribed by the Director. The Director shall also furnish to each such officer a copy of the current edition of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528f31be-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s638/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All property furnished to any such officer shall remain the property of the United States and, upon the termination of his term of office, shall be transmitted to his successor in office or otherwise disposed of as the Director orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id528f31bf-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s638/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall furnish to each United States magistrate judge appointed under this chapter an official impression seal in a form prescribed by the conference. Each such officer shall affix his seal to every jurat or certificate of his official acts without fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id528f31c0-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/917"},"text":"62 Stat. 917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/tI/s101"},"text":"Pub. L. 90–578, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1114"},"text":"82 Stat. 1114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5117"},"text":"104 Stat. 5117","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id528f31c1-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id528f31c2-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., §§ 528, 528a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-06-28/ch3573"},"text":"June 28, 1906, ch. 3573","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/546"},"text":"34 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-10/ch548"},"text":"July 10, 1946, ch. 548","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/525"},"text":"60 Stat. 525","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consolidates section 528 and part of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s528a"},"text":"section 528a of title 28","children":[],"tail":", U.S.C., 1940 ed., with changes in phraseology necessary to effect consolidation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s528a"},"text":"section 528a of title 28","children":[],"tail":", U.S.C., 1940 ed., relating to dockets and forms, are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s639"},"text":"section 639 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “Director of the Administrative Office of the United States Courts” were substituted for “Attorney General”, contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s528"},"text":"section 528 of title 28","children":[],"tail":", U.S.C., 1940 ed., in view of "},{"tag":"ref","attrib":{"href":"/us/act/1939-08-07/ch501/s6"},"text":"Act Aug. 7, 1939, ch. 501, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/1226"},"text":"53 Stat. 1226","children":[],"tail":", 28 U.S.C., 1940 ed., following § 446, giving the Directors supervision of court administrative matters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes in phraseology were made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id528f31c3-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id528f31c4-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" incorporated in provisions designated as subsec. (a) provisions of first par. of former "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s639"},"text":"section 639 of this title","children":[],"tail":", substituting “United States magistrates” for prior designation as “United States Commissioners”, specifying that the copy of the United States Code be a current edition, and dispensing with approval by the chief judge of the district court for a copy of such Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" incorporated in provisions designated as subsec. (b) provisions of the second par. of former "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s639"},"text":"section 639 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" designated existing provisions as subsec. (c), and substituted “United States magistrate” for “United States commissioner”, provision for appointment under this chapter rather than after "},{"tag":"date","attrib":{"date":"1946-07-10"},"text":"July 10, 1946","children":[],"tail":", provision that the form of the seal be prescribed by the conference rather than the Director, and “without fee” for “without additional fee”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id528f31c5-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id528f31c6-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States magistrate judges” and “United States magistrate judge” substituted for “United States magistrates” and “United States magistrate”, respectively, in subsecs. (a) and (c) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/s321"},"text":"section 321 of Pub. L. 101–650","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id528f31c7-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1968 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", except when a later effective date is applicable, which is the earlier of date when implementation of amendment by appointment of magistrates [now United States magistrate judges] and assumption of office takes place or third anniversary of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/90/578"},"text":"Pub. L. 90–578","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1968-10-17"},"text":"Oct. 17, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/578/s403"},"text":"section 403 of Pub. L. 90–578","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s631"},"text":"section 631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
