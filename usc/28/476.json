{"tag":"section","attrib":{"id":"id525ab454-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s476"},"text":null,"children":[{"tag":"num","attrib":{"value":"476"},"text":"§ 476.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of judicial information dissemination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id525ab455-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s476/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Administrative Office of the United States Courts shall prepare a semiannual report, available to the public, that discloses for each judicial officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id525ab456-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s476/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of motions that have been pending for more than six months and the name of each case in which such motion has been pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525ab457-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s476/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of bench trials that have been submitted for more than six months and the name of each case in which such trials are under submission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id525ab458-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s476/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and names of cases that have not been terminated within three years after filing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id525ab459-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s476/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ensure uniformity of reporting, the standards for categorization or characterization of judicial actions to be prescribed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s481"},"text":"section 481 of this title","children":[],"tail":" shall apply to the semiannual report prepared under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id525ab45a-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tI/s103/a"},"text":"Pub. L. 101–650, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5093"},"text":"104 Stat. 5093","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
