{"tag":"section","attrib":{"id":"id52cf958b-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2201"},"text":null,"children":[{"tag":"num","attrib":{"value":"2201"},"text":"§ 2201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation of remedy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id52cf958c-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a case of actual controversy within its jurisdiction, except with respect to Federal taxes other than actions brought under section 7428 of the Internal Revenue Code of 1986, a proceeding under section 505 or 1146 of title 11, or in any civil action involving an antidumping or countervailing duty proceeding regarding a class or kind of merchandise of a free trade area country (as defined in section 516A(f)(9) of the Tariff Act of 1930), as determined by the administering authority, any court of the United States, upon the filing of an appropriate pleading, may declare the rights and other legal relations of any interested party seeking such declaration, whether or not further relief is or could be sought. Any such declaration shall have the force and effect of a final judgment or decree and shall be reviewable as such.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id52cf958d-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For limitations on actions brought with respect to drug patents see section 505 or 512 of the Federal Food, Drug, and Cosmetic Act, or section 351 of the Public Health Service Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52cf958e-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/964"},"text":"62 Stat. 964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s111"},"text":"May 24, 1949, ch. 139, § 111","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/105"},"text":"63 Stat. 105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1033"},"text":"Aug. 28, 1954, ch. 1033","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/890"},"text":"68 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/508/s12/p"},"text":"Pub. L. 85–508, § 12(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-07-07"},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/349"},"text":"72 Stat. 349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/455/tXIII/s1306/b/8"},"text":"Pub. L. 94–455, title XIII, § 1306(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-04"},"text":"Oct. 4, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1719"},"text":"90 Stat. 1719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/598/tII/s249"},"text":"Pub. L. 95–598, title II, § 249","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-06"},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2672"},"text":"92 Stat. 2672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/417/tI/s106"},"text":"Pub. L. 98–417, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-09-24"},"text":"Sept. 24, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1597"},"text":"98 Stat. 1597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/449/tIV/s402/c"},"text":"