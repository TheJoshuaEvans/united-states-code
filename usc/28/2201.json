f","attrib":{"href":"/us/pl/100/449/s501/c"},"text":"section 501(c) of Pub. L. 100–449","children":[],"tail":", see Effective and Termination Dates of 1988 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cf9591-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cf9592-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1948 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 400 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-03/ch231/s274d"},"text":"Mar. 3, 1911, ch. 231, § 274d","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-14/ch512"},"text":"June 14, 1934, ch. 512","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/955"},"text":"48 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-30/ch829/s405"},"text":"Aug. 30, 1935, ch. 829, § 405","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1027"},"text":"49 Stat. 1027","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is based on the first paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s400"},"text":"section 400 of title 28","children":[],"tail":", U.S.C., 1940 ed. Other provisions of such section are incorporated in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2202"},"text":"section 2202 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"While this section does not exclude declaratory judgments with respect to State taxes, such suits will not ordinarily be entertained in the courts of the United States where State law makes provision for payment under protest and recovery back or otherwise affords adequate remedy in the State courts. See ","children":[{"tag":"i","attrib":{},"text":"Great Lakes Dredge & Dock Co. v. Huffman","children":[],"tail":", La. 1943, 63 S.Ct. 1070, 319 U.S. 293, 87 L.Ed. 1407. See also "},{"tag":"i","attrib":{},"text":"Spector Motor Service v. McLaughlin","children":[],"tail":", Conn. 1944, 65 S.Ct. 152, 323 U.S. 101, 89 L.Ed. 101. See also "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1341"},"text":"section 1341 of this title","children":[],"tail":" forbidding district courts to restrain enforcements of State taxes where State courts afford plain, speedy, and efficient remedy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52cf9593-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1949 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Section corrects a typographical error in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2201"},"text":"section 2201 of title 28","children":[],"tail":", U.S.C."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52cf9594-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id52cf9595-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7428 of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7428"},"text":"section 7428 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 516A(f)(9) of the Tariff Act of 1930, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a/f/9"},"text":"section 1516a(f)(9) of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 505 and 512 of the Federal Food, Drug, and Cosmetic Act, referred to in subsec. (b), are classified to sections 355 and 360b, respectively, of Title 21, Food and Drugs.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 351 of the Public Health Service Act, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52cf9596-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" substituted “section 516A(f)(9)” for “section 516A(f)(10)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" inserted “, or section 351 of the Public Health Service Act” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" substituted “merchandise of a free trade area country (as defined in section 516A(f)(10) of the Tariff Act of 1930),” for “Canadian merchandise,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/449"},"text":"Pub. L. 100–449","children":[],"tail":" temporarily substituted “1986,” for “1954 or” and inserted “or in any civil action involving an antidumping or countervailing duty proceeding regarding a class or kind of Canadian merchandise, as determined by the administering authority,” after “title 11,”. See Effective and Termination Dates of 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/670"},"text":"Pub. L. 100–670","children":[],"tail":" inserted “or 512” after “505”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/417"},"text":"Pub. L. 98–417","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/598"},"text":"Pub. L. 95–598","children":[],"tail":" inserted reference to proceedings under section 505 or 1146 of title 11."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/455"},"text":"Pub. L. 94–455","children":[],"tail":" substituted “taxes other than actions brought under section 7428 of the Internal Revenue Code of 1954” for “taxes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/508"},"text":"Pub. L. 85–508","children":[],"tail":" struck out provisions which related to District Court for Territory of Alaska. See "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s81A"},"text":"section 81A of this title","children":[],"tail":" which establishes a United States District Court for the State of Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-28"},"text":"Aug. 28, 1954","children":[],"tail":", extended provisions to Alaska."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", corrected spelling of “or” in second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52cf9597-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cf9598-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" effective on the date on which the USMCA enters into force ("},{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":"), but not applicable to certain determinations under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of Title 19","children":[],"tail":", Customs Duties, or binational panel reviews under NAFTA, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/s432"},"text":"section 432 of Pub. L. 116–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a"},"text":"section 1516a of Title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cf9599-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182"},"text":"Pub. L. 103–182","children":[],"tail":" effective on the date the North American Free Trade Agreement enters into force with respect to the United States ["},{"tag":"date","attrib":{"date":"1994-01-01"},"text":"Jan. 1, 1994","children":[],"tail":"], but not applicable to any final determination described in section 1516a(a)(1)(B) or (2)(B)(i), (ii), or (iii) of Title 19, Customs Duties, notice of which is published in the Federal Register before such date, or to a determination described in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1516a/a/2/B/vi"},"text":"section 1516a(a)(2)(B)(vi) of Title 19","children":[],"tail":", notice of which is received by the Government of Canada or Mexico before such date, or to any binational panel review under the United States-Canada Free-Trade Agreement, or to any extraordinary challenge arising out of any such review that was commenced before such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/182/s416"},"text":"section 416 of Pub. L. 103–182","children":[],"tail":", formerly set out as an Effective Date note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3431"},"text":"section 3431 of Title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52cf959a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/449"},"text":"Pub. L. 100–449","children":[],"tail":" effective on date United States-Canada Free-Trade Agreement enters into force ("},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":"), and to cease to have effect on date Agreement ceases to be in force, see section 501(a), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/449"},"text":"Pub. L. 100–449","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href