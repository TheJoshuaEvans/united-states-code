{"tag":"section","attrib":{"id":"id52c86a74-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2006"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006"},"text":"§ 2006.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Execution against revenue officer","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Execution shall not issue against a collector or other revenue officer on a final judgment in any proceeding against him for any of his acts, or for the recovery of any money exacted by or paid to him and subsequently paid into the Treasury, in performing his official duties, if the court certifies that:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id52c86a75-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2006/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" probable cause existed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id52c86a76-3a70-11f1-9e0c-dcbb1364dae6","identifier":"/us/usc/t28/s2006/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer acted under the directions of the Secretary of the Treasury, the Director, Bureau of Alcohol, Tobacco, Firearms, and Explosives, Department of Justice, or other proper Government officer.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"When such certificate has been issued, the amount of the judgment shall be paid out of the proper appropriation by the Treasury.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id52c86a77-3a70-11f1-9e0c-dcbb1364dae6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/960"},"text":"62 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXI/s1112"},"text":"Pub. L. 107–296, title XI, § 1112","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2277"},"text":"116 Stat. 2277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id52c86a78-3a70-11f1-9e0c-dcbb1364dae6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id52c86a79-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on title 28, U.S.C., 1940 ed., § 842 (R.S. § 989).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes were made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id52c86a7a-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id52c86a7b-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" inserted “, the Director, Bureau of Alcohol, Tobacco, Firearms, and Explosives, Department of Justice,” after “the Secretary of the Treasury”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id52c86a7c-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id52c86a7d-3a70-11f1-9e0c-dcbb1364dae6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
