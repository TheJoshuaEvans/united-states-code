{"tag":"section","attrib":{"id":"idbf2a892d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408"},"text":null,"children":[{"tag":"num","attrib":{"value":"10408"},"text":"§ 10408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants and uses of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf2a892e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/a"},"text":"section 10406(a) of this title","children":[],"tail":" shall use grant funds described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10406/b/2"},"text":"section 10406(b)(2) of this title","children":[],"tail":" to provide subgrants to eligible entities for programs and projects within such State, that is "},{"tag":"ref","attrib":{"idref":"fn003965"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003965"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “are”."}],"tail":" designed to prevent incidents of family violence, domestic violence, and dating violence by providing immediate shelter and supportive services for adult and youth victims of family violence, domestic violence, or dating violence (and their dependents), and that may provide prevention services to prevent future incidents of family violence, domestic violence, and dating violence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a892f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a8930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded to eligible entities under subsection (a) shall be used to provide shelter, supportive services, or prevention services to adult and youth victims of family violence, domestic violence, or dating violence, and their dependents, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2a8931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision, on a regular basis, of immediate shelter and related supportive services to adult and youth victims of family violence, domestic violence, or dating violence, and their dependents, including paying for the operating and administrative expenses of the facilities for such shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in developing safety plans, and supporting efforts of victims of family violence, domestic violence, or dating violence to make decisions related to their ongoing safety and well-being;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of individual and group counseling, peer support groups, and referral to community-based services to assist family violence, domestic violence, and dating violence victims, and their dependents, in recovering from the effects of the violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of services, training, technical assistance, and outreach to increase awareness of family violence, domestic violence, and dating violence and increase the accessibility of family violence, domestic violence, and dating violence services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of culturally and linguistically appropriate services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of services for children exposed to family violence, domestic violence, or dating violence, including age-appropriate counseling, supportive services, and services for the nonabusing parent that support that parent’s role as a caregiver, which may, as appropriate, include services that work with the nonabusing parent and child together;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provision of advocacy, case management services, and information and referral services, concerning issues related to family violence, domestic violence, or dating violence intervention and prevention, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf2a8938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in accessing related Federal and State financial assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2a8939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" legal advocacy to assist victims and their dependents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2a893a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical advocacy, including provision of referrals for appropriate health care services (including mental health, alcohol, and drug abuse treatment), but which shall not include reimbursement for any health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2a893b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance locating and securing safe and affordable permanent housing and homelessness prevention services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2a893c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of transportation, child care, respite care, job training and employment services, financial literacy services and education, financial planning, and related economic empowerment services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf2a893d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/G/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parenting and other educational services for victims and their dependents; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a893e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention services, including outreach to underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a893f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shelter and supportive services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 70 percent of the funds distributed by a State under subsection (a) shall be distributed to entities for the primary purpose of providing immediate shelter and supportive services to adult and youth victims of family violence, domestic violence, or dating violence, and their dependents, as described in paragraph (1)(A). Not less than 25 percent of the funds distributed by a State under subsection (a) shall be distributed to entities for the purpose of providing supportive services and prevention services as described in subparagraphs (B) through (H) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a8940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a subgrant from a State under this section, an entity shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a8941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local public agency, or a nonprofit private organization (including faith-based and charitable organizations, community-based organizations, tribal organizations, and voluntary associations), that assists victims of family violence, domestic violence, or dating violence, and their dependents, and has a documented history of effective work concerning family violence, domestic violence, or dating violence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a8942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a partnership of 2 or more agencies or organizations that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf2a8943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or organization described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf2a8944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or organization that has a demonstrated history of serving populations in their communities, including providing culturally appropriate services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf2a8945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf2a8946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payments to victims or dependants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided under this chapter may be used as direct payment to any victim of family violence, domestic violence, or dating violence, or to any dependent of such victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf2a8947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10408/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntarily accepted services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Receipt of supportive services under this chapter shall be voluntary. No condition may be applied for the receipt of emergency shelter as described in subsection (b)(1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf2a8948-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s308"},"text":"Pub. L. 98–457, title III, § 308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tII/s201"},"text":"Pub. L. 111–320, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3494"},"text":"124 Stat. 3494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf2a8949-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf2a894a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf2a894b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10408, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/tIII/s309"},"text":"Pub. L. 98–457, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1762"},"text":"98 Stat. 1762","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/295/tIII/s311/b"},"text":"Pub. L. 102–295, title III, § 311(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-05-28"},"text":"May 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/203"},"text":"106 Stat. 203","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIV/s40272/a"},"text":"Pub. L. 103–322, title IV, § 40272(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1937"},"text":"108 Stat. 1937","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tIV/s405"},"text":"Pub. L. 108–36, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/826"},"text":"117 Stat. 826","children":[],"tail":", which related to definitions, was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/98/457/s320"},"text":"section 320 of Pub. L. 98–457","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tIV/s415/5"},"text":"Pub. L. 108–36, title IV, § 415(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/830"},"text":"117 Stat. 830","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10421"},"text":"section 10421 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/457/s308"},"text":"section 308 of Pub. L. 98–457","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10407"},"text":"section 10407 of this title","children":[],"tail":" prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/111/320"},"text":"Pub. L. 111–320","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
