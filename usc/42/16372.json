{"tag":"section","attrib":{"id":"idc00f6bc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372"},"text":null,"children":[{"tag":"num","attrib":{"value":"16372"},"text":"§ 16372.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of eligibility and project selection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00f6bc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and carry out a carbon dioxide transportation infrastructure finance and innovation program, under which the Secretary shall provide for eligible projects in accordance with this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6bc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal credit instrument under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16373"},"text":"section 16373 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16374"},"text":"section 16374 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both a Federal credit instrument and a grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6bc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6bc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall be eligible to receive a Federal credit instrument or a grant under the CIFIA program if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity proposing to carry out the project submits a letter of interest prior to submission of an application under paragraph (3) for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project meets the criteria described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creditworthiness","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each project and obligor that receives a Federal credit instrument or a grant under the CIFIA program shall be creditworthy, such that there exists a reasonable prospect of repayment of the principal and interest on the Federal credit instrument, as determined by the Secretary under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable prospect of repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall base a determination of whether there is a reasonable prospect of repayment under subparagraph (A) on a comprehensive evaluation of whether the obligor has a reasonable prospect of repaying the Federal credit instrument for the eligible project, including evaluation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6bcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strength of the contractual terms of an eligible project (if available for the applicable market segment);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forecast of noncontractual cash flows supported by market projections from reputable sources, as determined by the Secretary, and cash sweeps or other structural enhancements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the projected financial strength of the obligor—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6bd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time of loan close; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6bd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" throughout the loan term, including after the project is completed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial strength of the investors and strategic partners of the obligor, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other financial metrics and analyses that are relied on by the private lending community and nationally recognized credit rating agencies, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for assistance under the CIFIA program, an obligor shall submit to the Secretary a project application at such time, in such manner, and containing such information as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A project under the CIFIA program shall have eligible project costs that are reasonably anticipated to equal or exceed $100,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revenue sources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The applicable Federal credit instrument shall be repayable, in whole or in part, from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" user fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments owing to the obligor under a public-private partnership; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other revenue sources that also secure or fund the project obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligor will be identified later","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, local government, agency, or instrumentality of a State or local government, or a public authority, may submit to the Secretary an application under paragraph (3), under which a private party to a public-private partnership will be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bdd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bde-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified at a later date through completion of a procurement and selection of the private party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficial effects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall determine that financial assistance for each project under the CIFIA program will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6be0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attract public or private investment for the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6be1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the project to proceed at an earlier date than the project would otherwise be able to proceed or reduce the lifecycle costs (including debt service costs) of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6be2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project readiness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for assistance under the CIFIA program, the applicant shall demonstrate a reasonable expectation that the contracting process for construction of the project can commence by not later than 90 days after the date on which a Federal credit instrument or grant is obligated for the project under the CIFIA program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6be3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection among eligible projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6be4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of application process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an application process under which projects that are eligible to receive assistance under subsection (b) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6be5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive credit assistance on terms acceptable to the Secretary, if adequate funds are available (including any funds provided on behalf of an eligible project under paragraph (3)(B)(ii)) to cover the subsidy amount associated with the Federal credit instrument; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6be6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" receive grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16374"},"text":"section 16374 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6be7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate funds are available to cover the amount of the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6be8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the project is eligible under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6be9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting projects to receive credit assistance under subsection (b), the Secretary shall give priority to projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are large-capacity, common carrier infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated demand for use of the infrastructure by associated projects that capture carbon dioxide from anthropogenic sources or ambient air;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable geographical diversity in associated projects that capture carbon dioxide from anthropogenic sources or ambient air, with the goal of enabling projects in all major carbon dioxide-emitting regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are sited within, or adjacent to, existing pipeline or other linear infrastructure corridors, in a manner that minimizes environmental disturbance and other siting concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master credit agreements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into a master credit agreement for a project that the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" will likely be eligible for credit assistance under subsection (b), on obtaining—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional commitments from associated carbon capture projects to use the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all necessary permits and approvals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a project of high priority, as determined in accordance with the criteria described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequate funding not available","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary fully obligates funding to eligible projects for a fiscal year and adequate funding is not available to fund a Federal credit instrument, a project sponsor (including a unit of State or local government) of an eligible project may elect—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc00f6bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into a master credit agreement in lieu of the Federal credit instrument; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc00f6bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to wait to execute a Federal credit instrument until the fiscal year for which additional funds are available to receive credit assistance; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the lack of adequate funding is solely with respect to amounts available for the subsidy amount, to pay the subsidy amount to fund the Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part supersedes the applicability of any other requirement under Federal law (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NEPA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal credit assistance may only be provided under this part for a project that has received an environmental categorical exclusion, a finding of no significant impact, or a record of decision under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of American iron, steel, and manufactured goods","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), no Federal credit instrument or grant provided under the CIFIA program shall be made available for a project unless all iron, steel, and manufactured goods used in the project are produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply in any case or category of cases with respect to which the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application would be inconsistent with the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" iron, steel, or a relevant manufactured good is not produced in the United States in sufficient and reasonably available quantity, or of a satisfactory quality; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inclusion of iron, steel, or a manufactured good produced in the United States will increase the cost of the overall project by more than 25 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary receives a request for a waiver under this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make available to the public a copy of the request, together with any information available to the Secretary concerning the request—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00f6c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an informal basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00f6c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by electronic means, including on the official public website of the Department;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for informal public comment relating to the request for not fewer than 15 days before making a determination with respect to the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve or disapprove the request by not later than the date that is 120 days after the date of receipt of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall be applied in accordance with any applicable obligations of the United States under international agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application processing procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00f6c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of complete application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date of receipt of an application under this section, the Secretary shall provide to the applicant a written notice describing whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00f6c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application is complete; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00f6c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional information or materials are needed to complete the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00f6c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or denial of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date of issuance of a written notice under paragraph (1), the Secretary shall provide to the applicant a written notice informing the applicant whether the Secretary has approved or disapproved the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00f6c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16372/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development-phase activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal credit instrument provided under the CIFIA program may be used to finance up to 100 percent of the cost of development-phase activities, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16371/4/A"},"text":"section 16371(4)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00f6c0f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999B"},"text":"Pub. L. 109–58, title IX, § 999B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40304/a"},"text":"Pub. L. 117–58, div. D, title III, § 40304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/991"},"text":"135 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00f6c10-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00f6c11-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00f6c12-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc00f6c13-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 16372, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s999B"},"text":"Pub. L. 109–58, title IX, § 999B","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/917"},"text":"119 Stat. 917","children":[],"tail":", related to administration of the program under former part J, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tIII/s301/a"},"text":"Pub. L. 113–67, div. A, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1181"},"text":"127 Stat. 1181","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc00f6c14-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc00f6c15-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
