{"tag":"section","attrib":{"id":"idbfab5320-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12909"},"text":null,"children":[{"tag":"num","attrib":{"value":"12909"},"text":"§ 12909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single room occupancy dwellings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfab5321-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section may be used to provide project-based rental assistance or grants to facilitate the development of single room occupancy dwellings. To the extent practicable, a program under this section shall be carried out in the manner provided for under section 1437f(n) ","children":[{"tag":"ref","attrib":{"idref":"fn004142"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab5322-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Recipients under this section shall require the provision to individuals assisted under this section of the following assistance:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab5323-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate services provided by qualified service providers in the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab5324-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intensive assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any individual with acquired immunodeficiency syndrome or related diseases who requires more care than can be provided in housing assisted under this section, locating a care provider who can appropriately care for the individual and referral of the individual to the care provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab5325-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s860"},"text":"Pub. L. 101–625, title VIII, § 860","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4381"},"text":"104 Stat. 4381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s606/j/7"},"text":"Pub. L. 102–550, title VI, § 606(j)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3810"},"text":"106 Stat. 3810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab5326-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab5327-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfab5328-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f/n"},"text":"Section 1437f(n) of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tV/s550/a/7"},"text":"Pub. L. 105–276, title V, § 550(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2609"},"text":"112 Stat. 2609","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfab5329-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" inserted “with acquired immunodeficiency syndrome or related diseases” after “any individual”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
