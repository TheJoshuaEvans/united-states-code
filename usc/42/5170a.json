{"tag":"section","attrib":{"id":"idbd147b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5170a"},"text":"§ 5170a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General Federal assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In any major disaster, the President may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd147b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct any Federal agency, with or without reimbursement, to utilize its authorities and the resources granted to it under Federal law (including personnel, equipment, supplies, facilities, and managerial, technical, and advisory services) in support of State and local assistance response or recovery efforts, including precautionary evacuations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate all disaster relief assistance (including voluntary assistance) provided by Federal agencies, private organizations, and State and local governments, including precautionary evacuations and recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide technical and advisory assistance to affected State and local governments for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd147b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of essential community services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuance of warnings of risks and hazards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health and safety information, including dissemination of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of health and safety measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management, control, and reduction of immediate threats to public health and safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery activities, including disaster impact assessments and planning;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist State and local governments in the distribution of medicine, food, and other consumable supplies, and emergency assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance to State and local governments for building code and floodplain management ordinance administration and enforcement, including inspections for substantial damage compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd147b4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide accelerated Federal assistance and Federal support where necessary to save lives, prevent human suffering, or mitigate severe damage, which may be provided in the absence of a specific request and in which case the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd147b4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the fullest extent practicable, promptly notify and coordinate with officials in a State in which such assistance or support is provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd147b4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5170a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not, in notifying and coordinating with a State under subparagraph (A), delay or impede the rapid deployment, use, and distribution of critical resources to victims of a major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd147b50-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s402"},"text":"Pub. L. 93–288, title IV, § 402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/a/3"},"text":"Pub. L. 100–707, title I, § 106(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4696"},"text":"102 Stat. 4696","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s681/a"},"text":"Pub. L. 109–295, title VI, § 681(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1444"},"text":"120 Stat. 1444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1206/a"},"text":"Pub. L. 115–254, div. D, § 1206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3440"},"text":"132 Stat. 3440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd147b51-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd147b52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd147b53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/s402"},"text":"section 402 of Pub. L. 93–288","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172"},"text":"section 5172 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd147b54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added par. (5) and redesignated former par. (5) as (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/a/1"},"text":"Pub. L. 109–295, § 681(a)(1)","children":[],"tail":", substituted “response or recovery efforts, including precautionary evacuations” for “efforts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/a/2"},"text":"Pub. L. 109–295, § 681(a)(2)","children":[],"tail":", substituted “, including precautionary evacuations and recovery;” for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/a/3"},"text":"Pub. L. 109–295, § 681(a)(3)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/s681/a/4"},"text":"Pub. L. 109–295, § 681(a)(4)","children":[],"tail":", (5), added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd147b55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd147b56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
