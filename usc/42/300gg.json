{"tag":"section","attrib":{"id":"idb6a4d6b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg"},"text":"§ 300gg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair health insurance premiums","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d6ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002441"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002441"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" Prohibiting discriminatory premium rates"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d6bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the premium rate charged by a health insurance issuer for health insurance coverage offered in the individual or small group market—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a4d6bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such rate shall vary with respect to the particular plan or coverage involved only by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6a4d6bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such plan or coverage covers an individual or family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d6be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rating area, as established in accordance with paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d6bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age, except that such rate shall not vary by more than 3 to 1 for adults (consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–6/c"},"text":"section 300gg–6(c) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6a4d6c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tobacco use, except that such rate shall not vary by more than 1.5 to 1; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a4d6c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such rate shall not vary with respect to the particular plan or coverage involved by any other factor not described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d6c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rating area","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6a4d6c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State shall establish 1 or more rating areas within that State for purposes of applying the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6a4d6c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review the rating areas established by each State under subparagraph (A) to ensure the adequacy of such areas for purposes of carrying out the requirements of this subchapter. If the Secretary determines a State’s rating areas are not adequate, or that a State does not establish such areas, the Secretary may establish rating areas for that State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d6c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible age bands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the National Association of Insurance Commissioners, shall define the permissible age bands for rating purposes under paragraph (1)(A)(iii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d6c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of variations based on age or tobacco use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to family coverage under a group health plan or health insurance coverage, the rating variations permitted under clauses (iii) and (iv) of paragraph (1)(A) shall be applied based on the portion of the premium that is attributable to each family member covered under the plan or coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d6c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for large group market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State permits health insurance issuers that offer coverage in the large group market in the State to offer such coverage through the State Exchange (as provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18032/f/2/B"},"text":"section 18032(f)(2)(B) of this title","children":[],"tail":"), the provisions of this subsection shall apply to all coverage offered in such market (other than self-insured group health plans offered in such market) in the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d6c8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2701, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1201/4"},"text":"Pub. L. 111–148, title I, § 1201(4)","children":[],"tail":", title X, § 10103(a), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/155"},"text":"124 Stat. 155","children":[],"tail":", 892.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d6c9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6a4d6ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6a4d6cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300gg, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXVII/s2701"},"text":"act July 1, 1944, ch. 373, title XXVII, § 2701","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s102/a"},"text":"Pub. L. 104–191, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1955"},"text":"110 Stat. 1955","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/3/tIII/s311/b/2"},"text":"Pub. L. 111–3, title III, § 311(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-04"},"text":"Feb. 4, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/70"},"text":"123 Stat. 70","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dB/tI/s1899D/c"},"text":"Pub. L. 111–5, div. B, title I, § 1899D(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/426"},"text":"123 Stat. 426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/344/tI/s114/c"},"text":"Pub. L. 111–344, title I, § 114(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-29"},"text":"Dec. 29, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3615"},"text":"124 Stat. 3615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s242/a/3"},"text":"Pub. L. 112–40, title II, § 242(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/419"},"text":"125 Stat. 419","children":[],"tail":", which related to increased portability through limitation on preexisting condition exclusions, was renumbered section 2704 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"Jan. 1, 2014","children":[],"tail":", with certain exceptions, and amended, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1201(2), 1563(c)(1), formerly § 1562(c)(1), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/154"},"text":"124 Stat. 154","children":[],"tail":", 264, 911, and was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 2701 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238"},"text":"section 238 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6a4d6cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10103/a"},"text":"Pub. L. 111–148, § 10103(a)","children":[],"tail":", inserted “(other than self-insured group health plans offered in such market)” after “such market”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d6cd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a4d6ce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1255"},"text":"Pub. L. 111–148, title I, § 1255","children":[],"tail":", formerly § 1253, title X, § 10103(e), (f)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/162"},"text":"124 Stat. 162","children":[],"tail":", 895, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tI/s1255"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This subtitle [subtitle C (§§ 1201–1255) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", enacting subchapter II of chapter 157 of this title and sections 300gg to 300gg–2 and 300gg–4 to 300gg–7 of this title, and amending sections 300gg–1 and 300gg–4 of this title and transferring former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"section 300gg–3 of this title","children":[],"tail":"] (and the amendments made by this subtitle) shall become effective for plan years beginning on or after "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":", except that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1251 [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18011"},"text":"section 18011 of this title","children":[],"tail":"] shall take effect on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of section 2704 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3"},"text":"42 U.S.C. 300gg–3","children":[],"tail":"] (as amended by section 1201), as they apply to enrollees who are under 19 years of age, shall become effective for plan years beginning on or after the date that is 6 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":"].. [sic]”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s102/c"},"text":"Pub. L. 104–191, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1976"},"text":"110 Stat. 1976","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/191/tI/s102/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this subsection, part A of title XXVII of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"42 U.S.C. 300gg","children":[],"tail":" et seq.] (as added by subsection (a)) shall apply with respect to group health plans, and health insurance coverage offered in connection with group health plans, for plan years beginning after "},{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of creditable coverage.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of coverage.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to clause (ii), no period before ","children":[{"tag":"date","attrib":{"date":"1996-07-01"},"text":"July 1, 1996","children":[],"tail":", shall be taken into account under part A of title XXVII of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"42 U.S.C. 300gg","children":[],"tail":" et seq.] (as added by this section) in determining creditable coverage."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for certain periods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services, consistent with section 104 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–92"},"text":"42 U.S.C. 300gg–92","children":[],"tail":" note], shall provide for a process whereby individuals who need to establish creditable coverage for periods before "},{"tag":"date","attrib":{"date":"1996-07-01"},"text":"July 1, 1996","children":[],"tail":", and who would have such coverage credited but for clause (i) may be given credit for creditable coverage for such periods through the presentation of documents or other means."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certifications, etc.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to clauses (ii) and (iii), subsection (e) of section 2701 [now 2704] of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3/e"},"text":"42 U.S.C. 300gg–3(e)","children":[],"tail":"] (as added by this section) shall apply to events occurring after "},{"tag":"date","attrib":{"date":"1996-06-30"},"text":"June 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No certification required to be provided before ","children":[{"tag":"date","attrib":{"date":"1997-06-01"},"text":"june 1, 1997","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In no case is a certification required to be provided under such subsection before ","children":[{"tag":"date","attrib":{"date":"1997-06-01"},"text":"June 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification only on written request for events occurring before ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"october 1, 1996","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an event occurring after ","children":[{"tag":"date","attrib":{"date":"1996-06-30"},"text":"June 30, 1996","children":[],"tail":", and before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":", a certification is not required to be provided under such subsection unless an individual (with respect to whom the certification is otherwise required to be made) requests such certification in writing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transitional rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual who seeks to establish creditable coverage for any period for which certification is not required because it relates to an event occurring before ","children":[{"tag":"date","attrib":{"date":"1996-06-30"},"text":"June 30, 1996","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual may present other credible evidence of such coverage in order to establish the period of creditable coverage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group health plan and a health insurance issuer shall not be subject to any penalty or enforcement action with respect to the plan’s or issuer’s crediting (or not crediting) such coverage if the plan or issuer has sought to comply in good faith with the applicable requirements under the amendments made by this section [enacting this section and sections 300gg–1, 300gg–11 to 300gg–13, 300gg–21 to 300gg–23, 300gg–91, and 300gg–92 of this title and amending sections 300e and 300bb–8 of this title].","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for collective bargaining agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2)(B), in the case of a group health plan maintained pursuant to 1 or more collective bargaining agreements between employee representatives and one or more employers ratified before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":"], part A of title XXVII of the Public Health Service Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"42 U.S.C. 300gg","children":[],"tail":" et seq.] (other than section 2701(e) [now 2704(e)] thereof ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–3/e"},"text":"42 U.S.C. 300gg–3(e)","children":[],"tail":"]) shall not apply to plan years beginning before the later of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the last of the collective bargaining agreements relating to the plan terminates (determined without regard to any extension thereof agreed to after the date of the enactment of this Act), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of subparagraph (A), any plan amendment made pursuant to a collective bargaining agreement relating to the plan which amends the plan solely to conform to any requirement of such part shall not be treated as a termination of such collective bargaining agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timely regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services, consistent with section 104 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–92"},"text":"42 U.S.C. 300gg–92","children":[],"tail":" note], shall first issue by not later than "},{"tag":"date","attrib":{"date":"1997-04-01"},"text":"April 1, 1997","children":[],"tail":", such regulations as may be necessary to carry out the amendments made by this section [enacting this section and sections 300gg–1, 300gg–11 to 300gg–13, 300gg–21 to 300gg–23, 300gg–91, and 300gg–92 of this title and amending sections 300e and 300bb–8 of this title] and section 111 [enacting sections 300gg–41 to 300gg–44 and 300gg–61 to 300gg–63 of this title]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No enforcement action shall be taken, pursuant to the amendments made by this section, against a group health plan or health insurance issuer with respect to a violation of a requirement imposed by such amendments before ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", or, if later, the date of issuance of regulations referred to in paragraph (4), if the plan or issuer has sought to comply in good faith with such requirements.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6a746cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings Relating to Exercise of Commerce Clause Authority; Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s195"},"text":"Pub. L. 104–191, title I, § 195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1991"},"text":"110 Stat. 1991","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/191/tI/s195"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings Relating to Exercise of Commerce Clause Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following in relation to the provisions of this title [enacting this subchapter and sections 1181 to 1183 and 1191 to 1191c of Title 29, Labor, amending sections 233, 300e, and 300bb–8 of this title and sections 1003, 1021, 1022, 1024, 1132, 1136, and 1144 of Title 29, and enacting provisions set out as notes under this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–92"},"text":"section 300gg–92 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1181"},"text":"section 1181 of Title 29","children":[],"tail":"]:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provisions in group health plans and health insurance coverage that impose certain preexisting condition exclusions impact the ability of employees to seek employment in interstate commerce, thereby impeding such commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health insurance coverage is commercial in nature and is in and affects interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is a necessary and proper exercise of Congressional authority to impose requirements under this title on group health plans and health insurance coverage (including coverage offered to individuals previously covered under group health plans) in order to promote commerce among the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress, however, intends to defer to States, to the maximum extent practicable, in carrying out such requirements with respect to insurers and health maintenance organizations that are subject to State regulation, consistent with the provisions of the Employee Retirement Income Security Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"29 U.S.C. 1001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Severability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any provision of this title or the application of such provision to any person or circumstance is held to be unconstitutional, the remainder of this title and the application of the provisions of such to any person or circumstance shall not be affected thereby.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6a746d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Health Coverage Availability Studies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s191"},"text":"Pub. L. 104–191, title I, § 191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1987"},"text":"110 Stat. 1987","children":[],"tail":", directed the Secretary of Health and Human Services to provide for a study on the effectiveness of the provisions of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":" and the various State laws, in ensuring the availability of reasonably priced health coverage to employers and individuals and a study on access to, and choice of, health care providers and the cost and cost-effectiveness to health insurance issuers of providing access to out-of-network providers, and the potential impact of providing such access on the cost and quality of health insurance coverage, and to report to the appropriate committees of Congress on each of such studies not later than "},{"tag":"date","attrib":{"date":"2000-01-01"},"text":"Jan. 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
