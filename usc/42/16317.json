{"tag":"section","attrib":{"id":"idc00d2137-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317"},"text":null,"children":[{"tag":"num","attrib":{"value":"16317"},"text":"§ 16317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems biology program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d2138-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2139-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a research, development, and demonstration program in microbial and plant systems biology, protein science, computational biology, and environmental science to support the energy, national security, and environmental missions of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d213a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall support individual researchers and multidisciplinary teams of researchers through competitive, merit-reviewed grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d213b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program, the Secretary shall consult with other Federal agencies that conduct genetic and protein research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d213c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall have the goal of developing technologies and methods based on the biological functions of genomes, microbes, and plants that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d213d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can facilitate the production of fuels, including hydrogen in sustainable production systems that reduce greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d213e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convert carbon dioxide to organic carbon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d213f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detoxify soils and water, including at facilities of the Department, contaminated with heavy metals and radiological materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2140-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop cellulosic and other feedstocks that are less resource and land intensive and that promote sustainable use of resources, including soil, water, energy, forests, and land, and ensure protection of air, water, and soil quality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2141-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address other Department missions as identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2142-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2143-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall prepare and transmit to Congress a research plan describing how the program authorized pursuant to this section will be undertaken to accomplish the program goals established in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2144-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall contract with the National Academy of Sciences to review the research plan developed under this subsection. The Secretary shall transmit the review to Congress not later than 18 months after transmittal of the research plan under paragraph (1), along with the Secretary’s response to the recommendations contained in the review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User facilities and ancillary equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the funds authorized to be appropriated pursuant to this part, amounts shall be available for projects to develop, plan, construct, acquire, or operate special equipment, instrumentation, or facilities, including user facilities at National Laboratories, for researchers conducting research, development, demonstration, and commercial application in systems biology and proteomics and associated biological disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on biomedical and human cell and human subject research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d2147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No biomedical research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the program under this section, the Secretary shall not conduct biomedical research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall authorize the Secretary to conduct any research or demonstrations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on human cells or human subjects; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d214a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to have direct application with respect to human cells or human subjects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d214b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy research centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00d214c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18644/a"},"text":"section 18644(a) of this title","children":[],"tail":", the Director shall support up to 6 bioenergy research centers to conduct fundamental research in plant and microbial systems biology, biological imaging and analysis, and genomics, and to accelerate advanced research and development of advanced biofuels, bioenergy or biobased materials, chemicals, and products that are produced from a variety of regionally diverse feedstocks, and to facilitate the translation of research results to industry. The activities of the centers authorized under this subsection may include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d214d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating the domestication of bioenergy-relevant plants, microbes, and associated microbial communities to enable high-impact, value-added coproduct development at multiple points in the bioenergy supply chain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d214e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing the science and technological advances to ensure process sustainability is considered in the creation of advanced biofuels and bioproducts from lignocellulosic biomass; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d214f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the latest tools in genomics, molecular biology, catalysis science, chemical engineering, systems biology, and computational and robotics technologies to sustainably produce and transform biomass into advanced biofuels and bioproducts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and duration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center established under paragraph (1) shall be selected on a competitive, merit-reviewed basis for a period of not more than 5 years, subject to the availability of appropriations, beginning on the date of establishment of that center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall consider applications from National Laboratories, multi-institutional collaborations, and other appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center already in existence on ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", may continue to receive support for a period of not more than 5 years beginning on the date of establishment of that center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall select any new center pursuant to paragraph (1) on a competitive, merit-reviewed basis, with special consideration for applications from an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") that is located in an eligible jurisdiction (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13503/b/3/A"},"text":"section 13503(b)(3)(A) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the end of the applicable period described in paragraph (2), the Director may renew support for a center for a period of not more than 5 years on a merit-reviewed basis. For a center in operation for 10 years after its previous selection on a competitive, merit-reviewed basis, the Director may renew support for the center on a competitive, merit-reviewed basis for a period of not more than 5 years, and may subsequently provide an additional renewal on a merit-reviewed basis for a period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Centers shall undertake research activities to accelerate the production of advanced biofuels and bioproducts from biomass resources by identifying the most suitable species of plants for use as energy crops; and improving methods of breeding, propagation, planting, producing, harvesting, storage and processing. Activities may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research activities to increase sustainability, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d2158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing knowledge of how bioenergy crop interactions with biotic and abiotic environmental factors influence crop growth, yield, and quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the most impactful research areas that address the economics of advanced biofuels and bioproducts production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d215a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing multiscale modeling to advance predictive understanding of advanced biofuel cropping ecosystems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d215b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research activities to further feedstock development, including lignocellulosic, algal, gaseous wastes including carbon oxides and methane, and direct air capture of single carbon gases via plants and microbes, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d215c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing genetic and genomic tools, high-throughput analytical tools, and biosystems design approaches to enhance bioenergy feedstocks and their associated microbiomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d215d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting field testing of new potential bioenergy feedstock crops under environmentally benign and geographically diverse conditions to assess viability and robustness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d215e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing quantitative models informed by experimentation to predict how bioenergy feedstocks perform under diverse conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d215f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research activities to improve lignocellulosic deconstruction and separation methods, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d2160-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing feedstock-agnostic deconstruction processes capable of efficiently fractionating biomass into targeted output streams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2161-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gaining a detailed understanding of plant cell wall biosynthesis, composition, structure, and properties during deconstruction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2162-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving enzymes and approaches for biomass breakdown and cellulose, hemicellulose, and lignin processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2163-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Research activities to improve the feedstock conversion process for advanced biofuels and bioproducts, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc00d2164-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing high-throughput methods to screen or select high-performance microbial strains and communities to improve product formation rates, yields, and selectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2165-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a broad set of platform microorganisms and microbial communities suitable for metabolic engineering to produce advanced biofuels and bioproducts and high-throughput methods for experimental validation of gene function;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2166-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing techniques to enhance microbial robustness for tolerating toxins to improve advanced biofuel and bioproduct yields and to gain a better understanding of the cellular and molecular bases of tolerance for major chemical classes of inhibitors found in these processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2167-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing technologies for the use of batch, continuous, and consolidated bioprocessing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2168-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, creating, and optimizing microbial and chemical pathways to produce promising, atom-economical intermediates and final bioproducts from biomass with considerations given to environmentally benign processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d2169-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing high-throughput, real-time, in situ analytical techniques to understand and characterize the pre- and post-bioproduct separation streams in detail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d216a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating methodologies for efficiently identifying viable target molecules, identifying high-value bioproducts in existing biomass streams, and utilizing current byproduct streams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d216b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and improving plant feedstocks with enhanced extractable levels of desired bioproducts or bioproduct precursors, including lignin streams; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc00d216c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/4/D/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing integrated biological and chemical catalytic approaches to valorize and produce a diverse portfolio of advanced biofuels and bioproducts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d216d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Centers shall establish industry partnerships to translate research results to commercial applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d216e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In coordination with the Bioenergy Technologies Office of the Department, the Secretary shall support interdisciplinary research activities to improve the capacity, efficiency, resilience, security, reliability, and affordability, of the production and use of advanced biofuels and bioproducts, as well as activities to enable positive impacts and avoid the potential negative impacts that the production and use of advanced biofuels and bioproducts may have on ecosystems, people, and historically marginalized communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d216f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds authorized to be appropriated under subsection (k) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18644"},"text":"section 18644 of this title","children":[],"tail":" for a fiscal year, there is authorized to be appropriated to the Secretary to carry out this subsection $30,000,000 per center established under paragraph (1) for each of fiscal years 2023 through 2027."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00d2170-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00d2171-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced biofuel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced biofuel” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"section 8101 of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2172-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bioenergy” means energy derived from biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2173-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “biomass” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15852/b"},"text":"section 15852(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00d2174-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16317/f/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioproduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bioproduct” has the meaning given the term “biobased product” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"section 8101 of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d2175-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s977"},"text":"Pub. L. 109–58, title IX, § 977","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/903"},"text":"119 Stat. 903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII"},"text":"Pub. L. 110–140, title II","children":[],"tail":", §§ 232(a), 233, "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1537"},"text":"121 Stat. 1537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tI/s10103/e"},"text":"Pub. L. 117–167, div. B, title I, § 10103(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1430"},"text":"136 Stat. 1430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc00d2176-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc00d2177-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc00d2178-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (d), was in the original “this subtitle”, meaning subtitle G (§§ 971–984A) of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/898"},"text":"119 Stat. 898","children":[],"tail":", which enacted this part and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5523"},"text":"section 5523 of Title 15","children":[],"tail":", Commerce and Trade. For complete classification of subtitle G to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc00d2179-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" added subsec. (f) and struck out former subsec. (f) which related to establishment of at least 7 bioenergy research centers to carry out the program under subsec. (a) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s232/a/1"},"text":"Pub. L. 110–140, § 232(a)(1)","children":[],"tail":", substituted “computational biology, and environmental science” for “and computational biology”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s232/a/2/A"},"text":"Pub. L. 110–140, § 232(a)(2)(A)","children":[],"tail":", inserted “in sustainable production systems that reduce greenhouse gas emissions” after “hydrogen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s232/a/2/B"},"text":"Pub. L. 110–140, § 232(a)(2)(B)","children":[],"tail":"–(D), added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s233"},"text":"Pub. L. 110–140, § 233","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc00d217a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc00d217b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
