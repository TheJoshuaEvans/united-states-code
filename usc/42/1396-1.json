{"tag":"section","attrib":{"id":"idba14a88c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1396–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1396–1"},"text":"§ 1396–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of enabling each State, as far as practicable under the conditions in such State, to furnish (1) medical assistance on behalf of families with dependent children and of aged, blind, or disabled individuals, whose income and resources are insufficient to meet the costs of necessary medical services, and (2) rehabilitation and other services to help such families and individuals attain or retain capability for independence or self-care, there is hereby authorized to be appropriated for each fiscal year a sum sufficient to carry out the purposes of this subchapter. The sums made available under this section shall be used for making payments to States which have submitted, and had approved by the Secretary, State plans for medical assistance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idba14a88d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XIX, § 1901, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/97/tI/s121/a"},"text":"Pub. L. 89–97, title I, § 121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/343"},"text":"79 Stat. 343","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/233/s13/a/1"},"text":"Pub. L. 93–233, § 13(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-31"},"text":"Dec. 31, 1973","children":[],"tail":", "},{"tag":"ref","attrib":