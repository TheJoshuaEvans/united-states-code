{"tag":"section","attrib":{"id":"idb56c7ce2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7c"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b–7c"},"text":"§ 285b–7c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tuberculosis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56c7ce3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health may expand, intensify, and coordinate research and development and related activities of the Institutes with respect to tuberculosis including activities toward the goal of eliminating such disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7ce4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under subsection (a) may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56c7ce5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing basic and clinical research on tuberculosis, including drug resistant tuberculosis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7ce6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding research on the relationship between such disease and the human immunodeficiency virus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7ce7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–7c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing new tools for the elimination of tuberculosis, including public health interventions and methods to enhance detection and response to outbreaks of tuberculosis, including multidrug resistant tuberculosis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56c7ce8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 424C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/392/tII/s201"},"text":"Pub. L. 110–392, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4201"},"text":"122 Stat. 4201","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
