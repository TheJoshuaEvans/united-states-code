{"tag":"section","attrib":{"id":"idbea04ac6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8628a"},"text":"§ 8628a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance, training, and compliance reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbea04ac7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the amounts appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621/b"},"text":"section 8621(b) of this title","children":[],"tail":" for any fiscal year, not more than $300,000 of such amounts may be reserved by the Secretary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbea04ac8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbea04ac9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to State and public agencies and private nonprofit organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbea04aca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts or jointly financed cooperative arrangements or interagency agreements with States and public agencies (including Federal agencies) and private nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to provide for training and technical assistance related to the purposes of this subchapter, including collection and dissemination of information about programs and projects assisted under this subchapter, and ongoing matters of regional or national significance that the Secretary finds would assist in the more effective provision of services under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbea04acb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct onsite compliance reviews of programs supported under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbea04acc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8628a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No provision of this section shall be construed to prevent the Secretary from making a grant pursuant to subsection (a) to one or more private nonprofit organizations that apply jointly with a business concern to receive such grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbea04acd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVI/s2609A"},"text":"Pub. L. 97–35, title XXVI, § 2609A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/425/tV/s505/a"},"text":"Pub. L. 99–425, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"Sept. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/975"},"text":"100 Stat. 975","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/252/tIII/s311/a/3"},"text":"Pub. L. 103–252, title III, § 311(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-05-18"},"text":"May 18, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/661"},"text":"108 Stat. 661","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tIII/s309"},"text":"Pub. L. 105–285, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2759"},"text":"112 Stat. 2759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbea04ace-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbea04acf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbea04ad0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, the first and second time appearing in subsec. (a)(1), was in the original “this subtitle” which was translated as “this title”, meaning title XXVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", as the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbea04ad1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285/s309/b"},"text":"Pub. L. 105–285, § 309(b)","children":[],"tail":", substituted “Technical 