{"tag":"section","attrib":{"id":"idbd086d5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116g"},"text":null,"children":[{"tag":"num","attrib":{"value":"5116g"},"text":"§ 5116g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National network for community-based family resource programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may allocate such sums as may be necessary from the amount provided under the State allotment to support the activities of the lead entity in the State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd086d5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create, operate, and maintain a peer review process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create, operate, and maintain an information clearinghouse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund a yearly symposium on State system change efforts that result from the operation of the community-based and prevention-focused programs and activities designed to strengthen and support families to prevent child abuse and neglect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create, operate, and maintain a computerized communication system between lead entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd086d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5116g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund State-to-State technical assistance through bi-annual conferences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd086d62-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/247/tII/s207"},"text":"Pub. L. 93–247, title II, § 207","children":[],"tail":", formerly § 208, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/235/tI/s121"},"text":"Pub. L. 104–235, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-03"},"text":"Oct. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3086"},"text":"110 Stat. 3086","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tI/s128"},"text":"Pub. L. 108–36, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/817"},"text":"117 Stat. 817","children":[],"tail":"; renumbered § 207 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/320/tI"},"text":"Pub. L. 111–320, title I","children":[],"tail":", §§ 138, 141, "},{"tag":"date","attrib":{"date":"2010-12-20"},"text":"Dec. 20, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3481"},"text":"124 Stat. 3481","children":[],"tail":", 3482.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd086d63-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":