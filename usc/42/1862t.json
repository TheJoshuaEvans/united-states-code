{"tag":"section","attrib":{"id":"idbb96dc2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862t"},"text":"§ 1862t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting veterans in STEM education and computer science","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb96dc2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting veteran involvement in scientific research and STEM education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall, through the research and education activities of the Foundation, encourage veterans to study and pursue careers in STEM and computer science, in coordination with other Federal agencies that serve veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran outreach plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-02-11"},"text":"February 11, 2020","children":[],"tail":", the Director shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a plan for how the Foundation can enhance its outreach efforts to veterans. Such plan shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb96dc2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report on the Foundation’s existing outreach activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the best method for the Foundation to leverage existing authorities and programs to facilitate and support veterans in STEM careers and studies, including teaching programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include options for how the Foundation could track veteran participation in research and education programs of the Foundation, and describe any barriers to collecting such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Science Board indicators report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Science Board shall provide in its biennial report on indicators of the state of science and engineering in the United States any available and relevant data on veterans in science and engineering careers or education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (g) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dc34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans and military families STEM education interagency working group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb96dc35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Science and Technology Policy shall establish, or designate, an interagency working group to improve veteran and military spouse equity and representation in STEM fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of interagency working group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An interagency working group established under paragraph (1) shall develop and facilitate the implementation by participating agencies of a strategic plan, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb96dc37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify and prioritize short- and long-term objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the common metrics that will be used by Federal agencies to assess progress toward achieving such objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify barriers veterans face in reentering the workforce, including a lack of formal STEM education, career guidance, and the process of transferring military credits and skills to college credits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify barriers military spouses face in establishing careers in STEM fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the approaches that each participating agency will take to address administratively the barriers described in subparagraphs (C) and (D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any barriers that require Federal or State legislative or regulatory changes in order to be addressed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Science and Technology Policy shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb96dc3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-02-11"},"text":"February 11, 2020","children":[],"tail":", submit to Congress the strategic plan required under paragraph (2); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb96dc3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the annual report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621/d"},"text":"section 6621(d) of this title","children":[],"tail":" a description of any progress made in carrying out the activities described in paragraph (2) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb96dc40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862t/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An interagency working group established under paragraph (1) shall terminate on the date that is 3 years after the date that it is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb96dc41-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3"},"text":"Pub. L. 116–115, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-02-11"},"text":"Feb. 11, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/106"},"text":"134 Stat. 106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10399D"},"text":"Pub. L. 117–167, div. B, title III, § 10399D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1599"},"text":"136 Stat. 1599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb96dc42-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb96dc43-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb96dc44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3"},"text":"section 3 of Pub. L. 116–115","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3"},"text":"section 3 of Pub. L. 116–115","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n–1"},"text":"section 1862n–1 of this title","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3"},"text":"section 3 of Pub. L. 116–115","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862n–1a"},"text":"section 1862n–1a of this title","children":[],"tail":". Subsecs. (f) and (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/115/s3"},"text":"section 3 of Pub. L. 116–115","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s7404"},"text":"section 7404 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Supporting Veterans in STEM Careers Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb96dc45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" substituted “biennial” for “annual”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb96dc46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb96dc47-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/115/s2"},"text":"Pub. L. 116–115, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-02-11"},"text":"Feb. 11, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/106"},"text":"134 Stat. 106","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/115/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this Act [see Short Title of 2020 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1861"},"text":"section 1861 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Director’ means the Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foundation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Foundation’ means the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"STEM","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘STEM’ has the meaning given the term in section 2 of the America COMPETES Reauthorization Act of 2010 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"42 U.S.C. 6621","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘veteran’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
