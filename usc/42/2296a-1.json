{"tag":"section","attrib":{"id":"idbc17a4b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2296a–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296a–1"},"text":"§ 2296a–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within 180 days of ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary shall issue regulations governing reimbursement under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2296a"},"text":"section 2296a of this title","children":[],"tail":". An active uranium or thorium processing site owner shall apply for reimbursement hereunder by submitting a request for the amount of reimbursement, together with reasonable documentation in support thereof, to the Secretary. Any such request for reimbursement, supported by reasonable documentation, shall be approved by the Secretary and reimbursement therefor shall be made in a timely manner subject only to the limitations of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2296a"},"text":"section 2296a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc17a4b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tX/s1002"},"text":"Pub. L. 102–486, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2947"},"text":"106 Stat. 2947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a4b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a4b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a4b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Policy Act of 1992, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
