{"tag":"section","attrib":{"id":"idc0083fe3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293"},"text":null,"children":[{"tag":"num","attrib":{"value":"16293"},"text":"§ 16293.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon storage validation and testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0083fe4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0083fe5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large-scale carbon sequestration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “large-scale carbon sequestration” means a scale that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083fe6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates the ability to inject into geologic formations and sequester carbon dioxide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083fe7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a goal of sequestering not less than 50 million metric tons of carbon dioxide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083fe8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0083fe9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon storage program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0083fea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program of research, development, demonstration, and commercialization for carbon storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083feb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities under the program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083fec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with relevant Federal agencies, developing and maintaining mapping tools and resources that assess the capacity of geologic storage formation in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083fed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing monitoring tools, modeling of geologic formations, and analyses—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0083fee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to predict carbon dioxide containment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0083fef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to account for sequestered carbon dioxide in geologic storage sites;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" researching—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0083ff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential environmental, safety, and health impacts in the event of a leak into the atmosphere or to an aquifer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0083ff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corresponding mitigation actions or responses to limit harmful consequences of such a leak;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the interactions of carbon dioxide with formation solids and fluids, including the propensity of injections to induce seismic activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing and ensuring the safety of operations relating to geologic sequestration of carbon dioxide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the fate of carbon dioxide concurrent with and following injection into geologic formations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting cost and business model assessments to examine the economic viability of technologies and systems developed under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information to the Environmental Protection Agency, States, local governments, Tribal governments, and other appropriate entities, to ensure the protection of human health and the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ff8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the quantity, location, and timing of geologic carbon storage deployment that may be needed, and developing strategies and resources to enable the deployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0083ff9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geologic settings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out research activities under this subsection, the Secretary shall consider a variety of candidate onshore and offshore geologic settings, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0083ffa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating oil and gas fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ffb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depleted oil and gas fields;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ffc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residual oil zones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ffd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unconventional reservoirs and rock types;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083ffe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unmineable coal seams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0083fff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" saline formations in both sedimentary and basaltic geologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic systems that may be used as engineered reservoirs to extract economical quantities of brine from geothermal resources of low permeability or porosity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084001-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geologic systems containing in situ carbon dioxide mineralization formations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0084002-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large-scale carbon sequestration demonstration program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0084003-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a demonstration program under which the Secretary shall provide funding for demonstration projects to collect and validate information on the cost and feasibility of commercial deployment of large-scale carbon sequestration technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084004-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing regional carbon sequestration partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary may provide additional funding to regional carbon sequestration partnerships that are carrying out or have completed a large-scale carbon sequestration demonstration project under this section (as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":") for additional work on that project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084005-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration components","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each demonstration project carried out under this subsection shall include longitudinal tests involving carbon dioxide injection and monitoring, mitigation, and verification operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084006-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearinghouse","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Energy Technology Laboratory shall act as a clearinghouse of shared information and resources for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0084007-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing or completed demonstration projects receiving additional funding under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084008-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new demonstration projects funded under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084009-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives a report that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc008400a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the progress of all regional carbon sequestration partnerships carrying out a demonstration project under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc008400b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the remaining challenges in achieving large-scale carbon sequestration that is reliable and safe for the environment and public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc008400c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates a roadmap for carbon storage research and development activities of the Department through 2025, with the goal of reducing economic and policy barriers to commercial carbon sequestration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008400d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated storage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc008400e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may transition large-scale carbon sequestration demonstration projects under subsection (c) into integrated commercial storage complexes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008400f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals and objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals and objectives of the Secretary in seeking to transition large-scale carbon sequestration demonstration projects into integrated commercial storage complexes under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0084010-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify geologic storage sites that are able to accept large volumes of carbon dioxide acceptable for commercial contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084011-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to understand the technical and commercial viability of carbon dioxide geologic storage sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084012-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out any other activities necessary to transition the large-scale carbon sequestration demonstration projects under subsection (c) into integrated commercial storage complexes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0084013-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Large-scale carbon storage commercialization program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0084014-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a commercialization program under which the Secretary shall provide funding for the development of new or expanded commercial large-scale carbon sequestration projects and associated carbon dioxide transport infrastructure, including funding for the feasibility, site characterization, permitting, and construction stages of project development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0084015-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications; selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0084016-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to enter into an agreement with the Secretary for funding under paragraph (1), an entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0084017-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish an application process that, to the maximum extent practicable—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0084018-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is open to projects at any stage of development described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0084019-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates expeditious development of projects described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc008401a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting projects for funding under paragraph (1), the Secretary shall give priority to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc008401b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects with substantial carbon dioxide storage capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc008401c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that will store carbon dioxide from multiple carbon capture facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc008401d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference in project selection from meritorious proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making competitive awards under this section, subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16353"},"text":"section 16353 of this title","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc008401e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the research, development, demonstration program components described in subsections (b) through (d) give preference to proposals from partnerships among industrial, academic, and government entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc008401f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require recipients to provide assurances that all laborers and mechanics employed by contractors and subcontractors in the construction, repair, or alteration of new or existing facilities performed in order to carry out a demonstration or commercial application activity authorized under this section shall be paid wages at rates not less than those prevailing on similar construction in the locality, as determined by the Secretary of Labor in accordance with subchapter IV of chapter 31 of title 40, and the Secretary of Labor shall, with respect to the labor standards in this paragraph, have the authority and functions set forth in Reorganization Plan Numbered 14 of 1950 (15 Fed. Reg. 3176; 5 U.S.C. Appendix) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0084020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities carried out under this section shall be subject to the cost-sharing requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0084021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16293/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $2,500,000,000 for the period of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0084022-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s963"},"text":"Pub. L. 109–58, title IX, § 963","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/891"},"text":"119 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVII/s702/a"},"text":"Pub. L. 110–140, title VII, § 702(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1704"},"text":"121 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIV/s4003/a"},"text":"Pub. L. 116–260, div. Z, title IV, § 4003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2536"},"text":"134 Stat. 2536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tIII/s40305"},"text":"Pub. L. 117–58, div. D, title III, § 40305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1001"},"text":"135 Stat. 1001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0084023-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0084024-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0084025-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/1"},"text":"Pub. L. 117–58, § 40305(1)","children":[],"tail":", struck out “over a 10-year period” after “carbon dioxide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/2/A"},"text":"Pub. L. 117–58, § 40305(2)(A)","children":[],"tail":", substituted “demonstration, and commercialization” for “and demonstration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/2/B"},"text":"Pub. L. 117–58, § 40305(2)(B)","children":[],"tail":", added subpar. (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/3"},"text":"Pub. L. 117–58, § 40305(3)","children":[],"tail":", (4), added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/3"},"text":"Pub. L. 117–58, § 40305(3)","children":[],"tail":", redesignated subsec. (e) as (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/5"},"text":"Pub. L. 117–58, § 40305(5)","children":[],"tail":", inserted “with respect to the research, development, demonstration program components described in subsections (b) through (d)” before “give preference”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/3"},"text":"Pub. L. 117–58, § 40305(3)","children":[],"tail":", redesignated subsec. (f) as (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/6"},"text":"Pub. L. 117–58, § 40305(6)","children":[],"tail":", added subsec. (h) and struck out former subsec. (h) which authorized appropriations for fiscal years 2021 to 2025."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s40305/3"},"text":"Pub. L. 117–58, § 40305(3)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/4"},"text":"Pub. L. 116–260, § 4003(a)(4)","children":[],"tail":", substituted “Carbon storage validation and testing” for “Carbon capture and sequestration research, development, and demonstration program” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/4"},"text":"Pub. L. 116–260, § 4003(a)(4)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to the establishment of a carbon capture and sequestration research, development, and demonstration program and program objectives."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/4"},"text":"Pub. L. 116–260, § 4003(a)(4)","children":[],"tail":", added subsec. (c) and struck out pars. (1) to (3) of former subsec. (c) which related to fundamental science and engineering research and development and demonstration supporting carbon capture and sequestration technologies and carbon use activities, field validation testing activities, and large-scale carbon dioxide sequestration testing, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/2/B"},"text":"Pub. L. 116–260, § 4003(a)(2)(B)","children":[],"tail":", redesignated par. (4) as subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/2/A"},"text":"Pub. L. 116–260, § 4003(a)(2)(A)","children":[],"tail":", struck out pars. (5) and (6) which related to cost sharing and program review and report."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/4"},"text":"Pub. L. 116–260, § 4003(a)(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/1"},"text":"Pub. L. 116–260, § 4003(a)(1)","children":[],"tail":", struck out subsec. (d) which authorized appropriations for fiscal years 2008 to 2012."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/3"},"text":"Pub. L. 116–260, § 4003(a)(3)","children":[],"tail":", redesignated subpars. (A) and (B) as pars. (1) and (2), respectively, substituted “section” for “subsection” in introductory provisions and in par. (2), and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/2/B"},"text":"Pub. L. 116–260, § 4003(a)(2)(B)","children":[],"tail":", redesignated par. (4) of subsec. (c) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/2/A"},"text":"Pub. L. 116–260, § 4003(a)(2)(A)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s4003/a/1"},"text":"Pub. L. 116–260, § 4003(a)(1)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s702/a/1"},"text":"Pub. L. 110–140, § 702(a)(1)","children":[],"tail":", substituted “and sequestration research, development, and demonstration” for “research and development” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s702/a/2"},"text":"Pub. L. 110–140, § 702(a)(2)","children":[],"tail":", in introductory provisions, substituted “and sequestration research, development, and demonstration” for “research and development” and “capture and sequestration technologies related to industrial sources of carbon dioxide” for “capture technologies on combustion-based systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s702/a/3"},"text":"Pub. L. 110–140, § 702(a)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s702/a/4"},"text":"Pub. L. 110–140, § 702(a)(4)","children":[],"tail":", added subsecs. (c) and (d) and struck out former subsec. (c). Text of former subsec. (c) read as follows: “From amounts authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16291/b"},"text":"section 16291(b) of this title","children":[],"tail":", the following sums are authorized for activities described in subsection (a)(2):"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $25,000,000 for fiscal year 2006;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $30,000,000 for fiscal year 2007; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) $35,000,000 for fiscal year 2008.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0084026-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idc0084027-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc0084028-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
