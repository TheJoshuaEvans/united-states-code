{"tag":"section","attrib":{"id":"idc0169705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491"},"text":null,"children":[{"tag":"num","attrib":{"value":"16491"},"text":"§ 16491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy production incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0169706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may provide to any entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0169707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a credit against any tax or fee owed to the State under a State law, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0169708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other tax incentive,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"determined by the State to be appropriate, in the amount calculated under and in accordance with a formula determined by the State, for production described in subsection (b) in the State by the entity that receives such credit or such incentive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0169709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall apply with respect to the production in the State of electricity from coal mined in the State and used in a facility, if such production meets all applicable Federal and State laws and if such facility uses scrubbers or other forms of clean coal technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc016970a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on interstate commerce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any action taken by a State in accordance with this section with respect to a tax or fee payable, or incentive applicable, for any period beginning after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc016970b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered to be a reasonable regulation of commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc016970c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16491/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be considered to impose an undue burden on interstate commerce or to otherwise impair, restrain, or discriminate, against interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc016970d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXIV/s1402"},"text":"Pub. L. 109–58, title XIV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1061"},"text":"119 Stat. 1061","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
