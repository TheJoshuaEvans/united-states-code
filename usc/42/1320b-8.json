inning "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb84abd91-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as specifically provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411"},"text":"section 411 of Pub. L. 100–360","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/360"},"text":"Pub. L. 100–360","children":[],"tail":", as it relates to a provision in the Omnibus Budget Reconciliation Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", effective as if included in the enactment of that provision in "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/a"},"text":"section 411(a) of Pub. L. 100–360","children":[],"tail":", set out as a Reference to OBRA; Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s106"},"text":"section 106 of Title 1","children":[],"tail":", General Provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb84abd92-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIX/s9318/b"},"text":"Pub. L. 99–509, title IX, § 9318(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2010"},"text":"100 Stat. 2010","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/119/tI/s107/c"},"text":"Pub. L. 100–119, title I, § 107(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-09-29"},"text":"Sept. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/784"},"text":"101 Stat. 784","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4009/g/1"},"text":"Pub. L. 100–203, title IV, § 4009(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-58"},"text":"101 Stat. 1330–58","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tIV/s4009/g/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 1138(a) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–8/a"},"text":"42 U.S.C. 1320b–8(a)","children":[],"tail":"] shall apply to hospitals participating in the programs under titles XVIII and XIX of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq., 1396 et seq.] as of "},{"tag":"date","attrib":{"date":"1987-11-21"},"text":"November 21, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Section 1138(b) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–8/b"},"text":"42 U.S.C. 1320b–8(b)","children":[],"tail":"] shall apply to costs of organs procured on or after "},{"tag":"date","attrib":{"date":"1988-03-31"},"text":"March 31, 1988","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4009/g/2"},"text":"Pub. L. 100–203, title IV, § 4009(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-58"},"text":"101 Stat. 1330–58","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tIV/s4009/g/2"},"text":"“The amendment made by paragraph (1) [amending this note] shall be effective as if included in the enactment of the Omnibus Budget Reconciliation Act of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb84abd93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Agreements With Organ Procurement Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/432/tI/s155/a/2"},"text":"Pub. L. 103–432, title I, § 155(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4439"},"text":"108 Stat. 4439","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/432/tI/s155/a/2"},"text":"“Any hospital or rural primary care hospital which has an agreement (as defined in section 1138(a)(3)(A) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–8/a/3/A"},"text":"42 U.S.C. 1320b–8(a)(3)(A)","children":[],"tail":"]) with an organ procurement agency other than such hospital’s designated organ procurement agency (as defined in section 1138(a)(3)(B) of such Act) on the date of the enactment of this section ["},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":"] shall, if such hospital desires to continue such agreement on and after the effective date of the amendments made by paragraph (1) [see Effective Date of 1994 Amendment note above], submit an application to the Secretary for a waiver under section 1138(a)(2) of such Act not later than "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", and such agreement may continue in effect pending the Secretary’s determination with respect to such application.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
