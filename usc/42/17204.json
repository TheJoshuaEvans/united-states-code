{"tag":"section","attrib":{"id":"idc02e64bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204"},"text":null,"children":[{"tag":"num","attrib":{"value":"17204"},"text":"§ 17204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High cost region geothermal energy grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02e64bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e64be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e64bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric cooperative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e64c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Native corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e64c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-cost region","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-cost region” means a region in which the average cost of electrical power or heat exceeds 150 percent of the national average retail cost, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e64c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use amounts made available to carry out this section to make grants to eligible entities for activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e64c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity may use grant funds under this section, with respect to a geothermal energy project in a high-cost region, only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e64c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct a feasibility study, including a study of exploration, geochemical testing, geomagnetic surveys, geologic information gathering, baseline environmental studies, well drilling, resource characterization, permitting, and economic analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e64c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for design and engineering costs, relating to the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e64ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate and promote commercial application of technologies related to geothermal energy as part of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e64cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cost-sharing requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":" shall apply to any project carried out under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e64cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17204/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17202"},"text":"section 17202 of this title","children":[],"tail":", there is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2021 through 2025."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02e64cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s625"},"text":"Pub. L. 110–140, title VI, § 625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1685"},"text":"121 Stat. 1685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3002"},"text":"Pub. L. 116–260, div. Z, title III, § 3002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2496"},"text":"134 Stat. 2496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02e64ce-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02e64cf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc02e64d0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s3002"},"text":"Pub. L. 116–260, § 3002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), inserted “or heat” after “electrical power”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s3002"},"text":"Pub. L. 116–260, § 3002","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), amended subsec. (e) generally. Prior to amendment, text read as follows: “There are authorized to be appropriated such sums as are necessary to carry out this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc02e64d1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc02e64d2-3a70-11f1-ae