{"tag":"section","attrib":{"id":"idbe6bcd17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i"},"text":null,"children":[{"tag":"num","attrib":{"value":"7671i"},"text":"§ 7671i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonessential products containing chlorofluorocarbons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe6bcd18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall promulgate regulations to carry out the requirements of this section within 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe6bcd19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonessential products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations under this section shall identify nonessential products that release class I substances into the environment (including any release occurring during manufacture, use, storage, or disposal) and prohibit any person from selling or distributing any such product, or offering any such product for sale or distribution, in interstate commerce. At a minimum, such prohibition shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe6bcd1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chlorofluorocarbon-propelled plastic party streamers and noise horns,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe6bcd1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chlorofluorocarbon-containing cleaning fluids for noncommercial electronic and photographic equipment, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe6bcd1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other consumer products that are determined by the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe6bcd1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to release class I substances into the environment (including any release occurring during manufacture, use, storage, or disposal), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe6bcd1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be nonessential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In determining whether a product is nonessential, the Administrator shall consider the purpose or intended use of the product, the technological availability of substitutes for such product and for such class I substance, safety, health, and other relevant factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe6bcd1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective 24 months after ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", it shall be unlawful for any person to sell or distribute, or offer for sale or distribution, in interstate commerce any nonessential product to which regulations under subsection (a) implementing subsection (b) are applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe6bcd20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe6bcd21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Effective ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", it shall be unlawful for any person to sell or distribute, or offer for sale or distribution, in interstate commerce—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe6bcd22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any aerosol product or other pressurized dispenser which contains a class II substance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe6bcd23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plastic foam product which contains, or is manufactured with, a class II substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe6bcd24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator is authorized to grant exceptions from the prohibition under subparagraph (A) of paragraph (1) where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe6bcd25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the aerosol product or pressurized dispenser is determined by the Administrator to be essential as a result of flammability or worker safety concerns, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe6bcd26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only available alternative to use of a class II substance is use of a class I substance which legally could be substituted for such class II substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe6bcd27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subparagraph (B) of paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe6bcd28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foam insulation product, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe6bcd29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an integral skin, rigid, or semi-rigid foam utilized to provide for motor vehicle safety in accordance with Federal Motor Vehicle Safety Standards where no adequate substitute substance (other than a class I or class II substance) is practicable for effectively meeting such Standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe6bcd2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7671i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical devices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall apply to any medical device as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7671/8"},"text":"section 7671(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe6bcd2b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title VI, § 610, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tVI/s602/a"},"text":"Pub. L. 101–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2664"},"text":"104 Stat. 2664","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
