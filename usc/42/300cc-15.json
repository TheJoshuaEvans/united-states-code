{"tag":"section","attrib":{"id":"idb6836bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–15"},"text":"§ 300cc–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of international efforts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts for research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under section 242","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title, the Secretary, acting through the Director of the National Institutes of Health—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, for the purpose described in paragraph (2), make grants to, enter into cooperative agreements and contracts with, and provide technical assistance to, international organizations concerned with public health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, for such purpose, provide technical assistance to foreign governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The purpose referred to in paragraph (1) is promoting and expediting international research and training concerning the natural history and pathogenesis of the human immunodeficiency virus and the development and evaluation of vaccines and treatments for acquired immune deficiency syndrome and opportunistic infections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and contracts for additional purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After consultation with the Administrator of the Agency for International Development, the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall under section 242","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title make grants to, enter into contracts with, and provide technical assistance to, international organizations concerned with public health and may provide technical assistance to foreign governments, in order to support—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects for training individuals with respect to developing skills and technical expertise for use in the prevention, diagnosis, and treatment of acquired immune deficiency syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" epidemiological research relating to acquired immune deficiency syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bf5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Programme of World Health Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support provided by the Secretary pursuant to this section shall be in furtherance of the global strategy of the World Health Organization Special Programme on Acquired Immunodeficiency Syndrome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing grants, cooperative agreements, contracts, and technical assistance under subsections (a) and (b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836bf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give preference to activities under such subsections conducted by, or in cooperation with, the World Health Organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836bf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to activities carried out under such subsections in the Western Hemisphere, give preference to activities conducted by, or in cooperation with, the Pan American Health Organization or the World Health Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant or enter into a cooperative agreement or contract under this section unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dbfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application for such assistance is submitted to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dbfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to carrying out the purpose for which such assistance is to be provided, the application provides assurances of compliance satisfactory to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dbfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application otherwise is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dbfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–15/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dbfe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2315, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3070"},"text":"102 Stat. 3070","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/18"},"text":"Pub. L. 102–531, title III, § 312(d)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1811/3"},"text":"Pub. L. 103–43, title XVIII, § 1811(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/199"},"text":"107 Stat. 199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dbff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc00-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb685dc01-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–15, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2316, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238m"},"text":"section 238m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb685dc02-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1811/3/A"},"text":"Pub. L. 103–43, § 1811(3)(A)","children":[],"tail":", substituted “international research and training concerning the natural history and pathogenesis of the human immunodeficiency virus and the development and evaluation of vaccines and treatments for acquired immune deficiency syndrome and opportunistic infections” for “international research concerning the development and evaluation of vaccines and treatments for acquired immune deficiency syndrome”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s1811/3/B"},"text":"Pub. L. 103–43, § 1811(3)(B)","children":[],"tail":", substituted “such sums as may be necessary for each fiscal year” for “there are authorized to be appropriated $40,000,000 for fiscal year 1989 and such sums as may be necessary for each of the fiscal years 1990 and 1991”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
