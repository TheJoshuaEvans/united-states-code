{"tag":"section","attrib":{"id":"idbc82e9b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3505a"},"text":"§ 3505a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Population Affairs; establishment; Deputy Assistant Secretary for Population Affairs; appointment; staff and consultants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc82e9b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established within the Department of Health and Human Services an Office of Population Affairs to be directed by a Deputy Assistant Secretary for Population Affairs under the direct supervision of the Assistant Secretary for Health and Scientific Affairs. The Deputy Assistant Secretary for Population Affairs shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc82e9b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3505a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to provide the Office of Population Affairs with such full-time professional and clerical staff and with the services of such consultants as may be necessary for it to carry out its duties and functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc82e9ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/572/s3"},"text":"Pub. L. 91–572, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1504"},"text":"84 Stat. 1504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc82e9bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc82e9bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbc82e9bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted for “Department of Health, Education, and Welfare” in subsec. (a) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
