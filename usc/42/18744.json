{"tag":"section","attrib":{"id":"idc067c45e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744"},"text":null,"children":[{"tag":"num","attrib":{"value":"18744"},"text":"§ 18744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 21st Century Energy Workforce Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc067c45f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a board, to be known as the “21st Century Energy Workforce Advisory Board”, to develop a strategy for the Department that, with respect to the role of the Department in the support and development of a skilled energy workforce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the current and future industry and labor needs of the energy sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides opportunities for students to become qualified for placement in traditional energy sector and emerging energy sector jobs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies areas in which the Department can effectively utilize the technical expertise of the Department to support the workforce activities of other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthens and engages the workforce training programs of the Department and the National Laboratories in carrying out the Equity in Energy Initiative of the Department and other Department workforce priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c464-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops plans to support and retrain displaced and unemployed energy sector workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c465-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritizes education and job training for underrepresented groups, including racial and ethnic minorities, Indian Tribes, women, veterans, and socioeconomically disadvantaged individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c466-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c467-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be composed of not fewer than 10 and not more than 15 members, with the initial members of the Board to be appointed by the Secretary not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c468-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall include not fewer than 1 representative of a labor organization with significant energy experience who has been nominated by a national labor federation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c469-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each individual appointed to the Board under paragraph (1) shall have expertise in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c46a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the field of economics or workforce development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c46b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant traditional energy industries or emerging energy industries, including energy efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c46c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secondary or postsecondary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c46d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy workforce development or apprenticeship programs of States or units of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c46e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant organized labor organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c46f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing underrepresented groups, including racial and ethnic minorities, women, veterans, and socioeconomically disadvantaged individuals, into the workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c470-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board review and recommendations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c471-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy required under subsection (a), the Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c472-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether there are opportunities to more effectively and efficiently use the capabilities of the Department in the development of a skilled energy workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c473-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify ways in which the Department could work with other relevant Federal agencies, States, units of local government, institutions of higher education, labor organizations, Indian Tribes and tribal organizations, and industry in the development of a skilled energy workforce, subject to applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify ways in which the Department and National Laboratories can—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase outreach to minority-serving institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make resources available to increase the number of skilled minorities and women trained to go into the energy and energy-related manufacturing sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase outreach to displaced and unemployed energy sector workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make resources available to provide training to displaced and unemployed energy sector workers to reenter the energy workforce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c47a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the energy sectors in greatest need of workforce training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c47b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Secretary of Labor, develop recommendations for the skills necessary to develop a workforce trained to work in those energy sectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c47c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy required under subsection (a), the Board shall analyze the effectiveness of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c47d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing Department-directed support; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c47e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing energy workforce training programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c47f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c480-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the Board is established under this section, and biennially thereafter until the date on which the Board is terminated under subsection (f), the Board shall submit to the Secretary a report containing, with respect to the strategy required under subsection (a)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed energy workforce strategy of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date on which a report is submitted to the Secretary under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Board a response to the report that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes whether the Secretary approves or disapproves of each recommendation of the Board under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary approves of a recommendation, provides an implementation plan for the recommendation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to Congress—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report of the Board under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the response of the Secretary under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c48a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of report","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc067c48b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall make each report under subparagraph (A) available to the public on the earlier of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc067c48c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Board receives the response of the Secretary under subparagraph (B)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc067c48d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 90 days after the date on which the Board submitted the report to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc067c48e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Board has received a response to a report from the Secretary under subparagraph (B)(i), the Board shall make that response publicly available with the applicable report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c48f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days before the date of expiration of a term of the Board under subsection (f), the Secretary shall submit to the Committees on Energy and Natural Resources and Appropriations of the Senate and the Committees on Energy and Commerce and Appropriations of the House of Representatives a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c490-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the effectiveness and accomplishments of the Board during the applicable term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c491-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains a determination of the Secretary as to whether the Board should be renewed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines that the Board should be renewed, any recommendations as to whether and how the scope and functions of the Board should be modified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach to minority-serving institutions, veterans, and displaced and unemployed energy workers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy under subsection (a), the Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give special consideration to increasing outreach to minority-serving institutions, veterans, and displaced and unemployed energy workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make resources available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc067c496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minority-serving institutions, with the objective of increasing the number of skilled minorities and women trained to go into the energy and manufacturing sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions that serve veterans, with the objective of increasing the number veterans in the energy industry by ensuring that veterans have the credentials and training necessary to secure careers in the energy industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc067c498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions that serve displaced and unemployed energy workers to increase the number of individuals trained for jobs in the energy industry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage the energy industry to improve the opportunities for students of minority-serving institutions, veterans, and displaced and unemployed energy workers to participate in internships, preapprenticeships, apprenticeships, and cooperative work-study programs in the energy industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the National Laboratories to increase the participation of underrepresented groups, veterans, and displaced and unemployed energy workers in internships, fellowships, training programs, and employment at the National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc067c49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc067c49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Board shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-09-30"},"text":"September 30, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc067c49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18744/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew the Board for 1 or more 5-year periods by submitting, not later than the date described in subsection (d), a report described in that subsection that contains a determination by the Secretary that the Board should be renewed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc067c49e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tII/s40211"},"text":"Pub. L. 117–58, div. D, title II, § 40211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/983"},"text":"135 Stat. 983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc067c49f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc067c4a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc067c4a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
