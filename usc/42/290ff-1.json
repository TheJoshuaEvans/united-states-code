"tag":"ref","attrib":{"href":"/us/pl/108/446"},"text":"Pub. L. 108–446","children":[],"tail":" substituted “and C” for “and H”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5c4aebb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5c4aebc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
