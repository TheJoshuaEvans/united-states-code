107–314","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXI/s3141/k/9/A"},"text":"Pub. L. 108–136, div. C, title XXXI, § 3141(k)(9)(A)","children":[],"tail":"–(C), "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1785"},"text":"117 Stat. 1785","children":[],"tail":", and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s2795"},"text":"section 2795 of Title 50","children":[],"tail":", War and National Defense, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s6338"},"text":"section 6338 of Title 10","children":[],"tail":", Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dC/tXXXI/s3111/a"},"text":"Pub. L. 119–60, div. C, title XXXI, § 3111(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1451"},"text":"139 Stat. 1451","children":[],"tail":", 1458."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
