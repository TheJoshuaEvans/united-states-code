{"tag":"section","attrib":{"id":"idb5609637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f"},"text":null,"children":[{"tag":"num","attrib":{"value":"284f"},"text":"§ 284f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parkinson’s disease","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5609638-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall establish a program for the conduct and support of research and training with respect to Parkinson’s disease (subject to the extent of amounts appropriated to carry out this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5609639-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inter-institute coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb560963a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall provide for the coordination of the program established under subsection (a) among all of the national research institutes conducting Parkinson’s disease research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb560963b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Coordination under paragraph (1) shall include the convening of a research planning conference not less frequently than once every 2 years. Each such conference shall prepare and submit to the Committee on Appropriations and the Committee on Labor and Human Resources of the Senate and the Committee on Appropriations and the Committee on Commerce of the House of Representatives a report concerning the conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb560963c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Morris K. Udall research centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb560963d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH is authorized to award Core Center Grants to encourage the development of innovative multidisciplinary research and provide training concerning Parkinson’s disease. The Director is authorized to award not more than 10 Core Center Grants and designate each center funded under such grants as a Morris K. Udall Center for Research on Parkinson’s Disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb560963e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb560963f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to Parkinson’s disease, each center assisted under this subsection shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5609640-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the facilities of a single institution or a consortium of cooperating institutions, and meet such qualifications as may be prescribed by the Director of the NIH; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5609641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct basic and clinical research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5609642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to Parkinson’s disease, each center assisted under this subsection may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5609643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct training programs for scientists and health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5609644-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct programs to provide information and continuing education to health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5609645-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct programs for the dissemination of information to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5609646-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately or in collaboration with other centers, establish a nationwide data system derived from patient populations with Parkinson’s disease, and where possible, comparing relevant data involving general populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5609647-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately or in collaboration with other centers, establish a Parkinson’s Disease Information Clearinghouse to facilitate and enhance knowledge and understanding of Parkinson’s disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5609648-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separately or in collaboration with other centers, establish a national education program that fosters a national focus on Parkinson’s disease and the care of those with Parkinson’s disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5609649-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends regarding training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center may use funds provided under paragraph (1) to provide stipends for scientists and health professionals enrolled in training programs under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb560964a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under this subsection may be for a period not exceeding five years. Such period may be extended by the Director of NIH for one or more additional periods of not more than five years if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director and if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb560964b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Morris K. Udall Awards for Excellence in Parkinson’s Disease Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH is authorized to establish a grant program to support investigators with a proven record of excellence and innovation in Parkinson’s disease research and who demonstrate potential for significant future breakthroughs in the understanding of the pathogensis,","children":[{"tag":"ref","attrib":{"idref":"fn002172"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “pathogenesis,”."}],"tail":" diagnosis, and treatment of Parkinson’s disease. Grants under this subsection shall be available for a period of not to exceed 5 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb560964c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 409B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/78/tVI/s603/c"},"text":"Pub. L. 105–78, title VI, § 603(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1520"},"text":"111 Stat. 1520","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/8"},"text":"Pub. L. 109–482, title I, § 103(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3687"},"text":"120 Stat. 3687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb560964d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb560964e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb560964f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/8/A"},"text":"Pub. L. 109–482, § 103(b)(8)(A)","children":[],"tail":", substituted “to carry out this section” for “under subsection (e) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s103/b/8/B"},"text":"Pub. L. 109–482, § 103(b)(8)(B)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “For the purpose of carrying out this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s241"},"text":"section 241 of this title","children":[],"tail":" and this subchapter with respect to research focused on Parkinson’s disease, there are authorized to be appropriated up to $100,000,000 for fiscal year 1998, and such sums as may be necessary for each of the fiscal years 1999 and 2000.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5609650-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5609651-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5609652-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5609653-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Grants","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dE/tII/s217"},"text":"Pub. L. 108–199, div. E, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/255"},"text":"118 Stat. 255","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dE/tII/s217"},"text":"“Notwithstanding section 409B(c) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s284f/c"},"text":"42 U.S.C. 284f(c)","children":[],"tail":"] regarding a limitation on the number of such grants, funds appropriated in this Act [div. E of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Pub. L. 108–199","children":[],"tail":", see Tables for classification] and Acts in fiscal years thereafter may be expended by the Director of the National Institutes of Health to award Core Center Grants to encourage the development of innovative multidisciplinary research and provide training concerning Parkinson’s disease. Each center funded under such grants shall be designated as a Morris K. Udall Center for Research on Parkinson’s Disease.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dG/tII/s218"},"text":"Pub. L. 108–7, div. G, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/326"},"text":"117 Stat. 326","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5609654-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Finding and Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/78/tVI/s603/b"},"text":"Pub. L. 105–78, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1519"},"text":"111 Stat. 1519","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/78/tVI/s603/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress finds that to take full advantage of the tremendous potential for finding a cure or effective treatment, the Federal investment in Parkinson’s disease must be expanded, as well as the coordination strengthened among the National Institutes of Health research institutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the purpose of this section [enacting this section] to provide for the expansion and coordination of research regarding Parkinson’s disease, and to improve care and assistance for afflicted individuals and their family caregivers.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
