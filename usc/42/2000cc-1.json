{"tag":"section","attrib":{"id":"idbbc8e7ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000cc–1"},"text":"§ 2000cc–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of religious exercise of institutionalized persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbc8e7ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No government shall impose a substantial burden on the religious exercise of a person residing in or confined to an institution, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1997"},"text":"section 1997 of this title","children":[],"tail":", even if the burden results from a rule of general applicability, unless the government demonstrates that imposition of the burden on that person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc8e7ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in furtherance of a compelling governmental interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc8e7ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the least restrictive means of furthering that compelling governmental interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbc8e7f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies in any case in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbc8e7f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial burden is imposed in a program or activity that receives Federal financial assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbc8e7f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000cc–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the substantial burden affects, or removal of that substantial burden would affect, commerce with foreign nations, among the several States, or with Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbc8e7f3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/274/s3"},"text":"Pub. L. 106–274, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-22"},"text":"Sept. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/804"},"text":"114 Stat. 804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
