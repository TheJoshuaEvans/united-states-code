{"tag":"section","attrib":{"id":"idb6884d90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–1"},"text":"§ 300ee–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of office with respect to minority health and acquired immune deficiency syndrome","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services, acting through the Director of the Centers for Disease Control and Prevention, shall establish an office for the purpose of ensuring that, in carrying out the duties of the Secretary with respect to prevention of acquired immune deficiency syndrome, the Secretary develops and implements prevention programs targeted at minority populations and provides appropriate technical assistance in the implementation of such programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb6884d91-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s252"},"text":"Pub. L. 100–607, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3108"},"text":"102 Stat. 3108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/e/2"},"text":"Pub. L. 102–531, title III, § 312(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3506"},"text":"106 Stat. 3506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6884d92-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6884d93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6884d94-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the AIDS Amendments of 1988 and as part of the Health Omnibus Programs Extension of 1988, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6884d95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6884d96-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb6884d97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Requirement of Study With Respect to Minority Health and Acquired Immune Deficiency Syndrome","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s251"},"text":"Pub. L. 100–607, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3108"},"text":"102 Stat. 3108","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2602/b"},"text":"Pub. L. 100–690, title II, § 2602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4234"},"text":"102 Stat. 4234","children":[],"tail":", required the Secretary of Health and Human Services, acting through the Director of the Office of Minority Health, to conduct a Study With Respect to Minority Health and Acquired Immune Deficiency Syndrome and report to Congress on the findings no later than 12 months after "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
