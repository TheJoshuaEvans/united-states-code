{"tag":"section","attrib":{"id":"idb5786432-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285m–3"},"text":"§ 285m–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multipurpose deafness and other communication disorders center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5786433-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development, modernization and operation; “modernization” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall, after consultation with the advisory council for the Institute, provide for the development, modernization, and operation (including care required for research) of new and existing centers for studies of disorders of hearing and other communication processes. For purposes of this section, the term “modernization” means the alteration, remodeling, improvement, expansion, and repair of existing buildings and the provision of equipment for such buildings to the extent necessary to make them suitable for use as centers described in the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786434-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of facilities; qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each center assisted under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5786435-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the facilities of a single institution or a consortium of cooperating institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5786436-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet such qualifications as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786437-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requisite programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each center assisted under this section shall, at least, conduct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5786438-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic and clinical research into the cause ","children":[{"tag":"ref","attrib":{"idref":"fn002195"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002195"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" diagnosis, early detection, prevention, control and treatment of disorders of hearing and other communication processes and complications resulting from such disorders, including research into rehabilitative aids, implantable biomaterials, auditory speech processors, speech production devices, and other otolaryngologic procedures;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5786439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for physicians, scientists, and other health and allied health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb578643a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and continuing education programs for physicians and other health and allied health professionals who will provide care for patients with disorders of hearing or other communication processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb578643b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs for the dissemination to the general public of information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb578643c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the importance of early detection of disorders of hearing and other communication processes, of seeking prompt treatment, rehabilitation, and of following an appropriate regimen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb578643d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the importance of avoiding exposure to noise and other environmental toxic agents that may affect disorders of hearing or other communication processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb578643e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stipends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A center may use funds provided under subsection (a) to provide stipends for health professionals enrolled in training programs described in subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb578643f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each center assisted under this section may conduct programs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5786440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the effectiveness of new and improved methods of detection, referral, and diagnosis of individuals at risk of developing disorders of hearing or other communication processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5786441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate the results of research, screening, and other activities, and develop means of standardizing patient data and recordkeeping.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable geographical distribution; needs of elderly and children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall, to the extent practicable, provide for an equitable geographical distribution of centers assisted under this section. The Director shall give appropriate consideration to the need for centers especially suited to meeting the needs of the elderly, and of children (particularly with respect to their education and training), affected by disorders of hearing or other communication processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5786443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285m–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of support; recommended extensions of peer review group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Support of a center under this section may be for a period not to exceed seven years. Such period may be extended by the Director of the Institute for one or more additional periods of not more than five years if the operations of such center have been reviewed by an appropriate technical and scientific peer review group established by the Director, with the advice of the Institute’s advisory council, if such group has recommended to the Director that such period should be extended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5786444-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 464C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/553/s2/4"},"text":"Pub. L. 100–553, § 2(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2771"},"text":"102 Stat. 2771","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s101/4"},"text":"Pub. L. 100–607, title I, § 101(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3050"},"text":"102 Stat. 3050","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2613/b/2"},"text":"Pub. L. 100–690, title II, § 2613(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4238"},"text":"102 Stat. 4238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5786445-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5786446-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5786447-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/553"},"text":"Pub. L. 100–553","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" contained identical provisions enacting this section. See 1988 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5786448-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" amended this section to read as if the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which enacted this section, had not been enacted. See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5786449-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb578644a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2613/b/1"},"text":"section 2613(b)(1) of Pub. L. 100–690","children":[],"tail":", set out as an Effect of Enactment of Similar Provisions note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285m"},"text":"section 285m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
