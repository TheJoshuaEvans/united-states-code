{"tag":"section","attrib":{"id":"idbe991f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502"},"text":null,"children":[{"tag":"num","attrib":{"value":"8502"},"text":"§ 8502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe991f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “severe energy supply interruption”, when used with respect to motor fuel or any other energy source, means a national energy supply shortage of such energy source which the President determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe991f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is, or is likely to be, of significant scope and duration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may cause major adverse impact on national security or the national economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe991f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results, or is likely to result, from an interruption in the energy supplies of the United States, including supplies of imported petroleum products, or from sabotage or an act of God.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “international energy program” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6202/7"},"text":"section 6202(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “motor fuel” means gasoline and diesel fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes (A) any individual, (B) any corporation, company, association, firm, partnership, society, trust, joint venture, or joint stock company, and (C) the government or any agency of the United States or any State or political subdivision thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “vehicle” means any vehicle propelled by motor fuel and manufactured primarily for use on public streets, roads, and highways.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Governor” means the chief executive officer of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe991fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe991fa4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/102/tII/s202"},"text":"Pub. L. 96–102, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-05"},"text":"Nov. 5, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/757"},"text":"93 Stat. 757","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
