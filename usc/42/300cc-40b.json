{"tag":"section","attrib":{"id":"idb685dc92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–40b"},"text":"§ 300cc–40b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council; coordinating committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb685dc93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory council for the purpose of providing advice to the Director of the Office on carrying out this part. (Such council is referred to in this subsection as the “Advisory Council”.)","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition, compensation, terms, chair, etc.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (b) through (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s284a"},"text":"section 284a of this title","children":[],"tail":" apply to the Advisory Council to the same extent and in the same manner as such subsections apply to advisory councils for the national research institutes, except that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb685dc96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addition to the ex officio members specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s284a/b/2"},"text":"section 284a(b)(2) of this title","children":[],"tail":", there shall serve as such members of the Advisory Council a representative from the advisory council of each of the National Cancer Institute and the National Institute on Allergy and Infectious Diseases; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb685dc97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the other national research institutes, there shall serve as ex officio members of such Council, in addition to such members specified in subparagraph (A), a representative from the advisory council of each of the 2 institutes that receive the greatest funding for AIDS activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb685dc98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual coordinating committees regarding research disciplines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb685dc99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office shall establish, for each research discipline in which any activity under the plan required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–40c"},"text":"section 300cc–40c of this title","children":[],"tail":" is carried out, a committee for the purpose of providing advice to the Director of the Office on carrying out this part with respect to such discipline. (Each such committee is referred to in this subsection as a “coordinating committee”.)"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb685dc9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–40b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each coordinating committee shall be composed of representatives of the agencies of the National Institutes of Health with significant responsibilities regarding the research discipline involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb685dc9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2352, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1801/a/3"},"text":"Pub. L. 103–43, title XVIII, § 1801(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/193"},"text":"107 Stat. 193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb685dc9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb685dc9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb685dc9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–40a"},"text":"section 300cc–40a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb685dc9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–40b, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXXIII/s2353"},"text":"act July 1, 1944, ch. 373, title XXIII, § 2353","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVIII/s1801/a/3"},"text":"Pub. L. 103–43, title XVIII, § 1801(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/194"},"text":"107 Stat. 194","children":[],"tail":", which required the establishment of a comprehensive plan, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–40c"},"text":"section 300cc–40c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb685dca0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb685dca1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory councils established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/641/s6"},"text":"Pub. L. 93–641, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2275"},"text":"88 Stat. 2275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s217a"},"text":"section 217a of this title","children":[],"tail":", provided that an advisory committee established pursuant to the Public Health Service Act shall terminate at such time as may be specifically prescribed by an Act of Congress enacted after "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
