te":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/291/s2"},"text":"Pub. L. 89–291, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1059"},"text":"79 Stat. 1059","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1970-03-13"},"text":"Mar. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/212/s10/b/3"},"text":"Pub. L. 91–212, § 10(b)(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/66"},"text":"84 Stat. 66","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tII/s202/b"},"text":"Pub. L. 93–353, title II, § 202(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/372"},"text":"88 Stat. 372","children":[],"tail":", which defined “sciences related to health”, “National Medical Libraries Assistance Advisory Board”, “Board”, and “medical library”, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280b–1"},"text":"section 280b–1 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/b"},"text":"Pub. L. 99–158, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/879"},"text":"99 Stat. 879","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5275e37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183"},"text":"Pub. L. 103–183","children":[],"tail":" inserted at end “In carrying out the preceding sentence, the Secretary shall disseminate such information to the public, including through elementary and secondary schools.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control” in subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/558/s2/a/1"},"text":"Pub. L. 101–558, § 2(a)(1)","children":[],"tail":", inserted “, or enter into cooperative agreements or contracts with,” after “grants to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/558/s2/a/2"},"text":"Pub. L. 101–558, § 2(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5275e38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5275e39-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/649/s2"},"text":"Pub. L. 99–649, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3633"},"text":"100 Stat. 3633","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/649/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds and declares that:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Injury is one of the principal public health problems in America, and causes over 140,000 deaths per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Injury rates are particularly high for children and the elderly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Injury causes 50 percent of all deaths for children over the age of one year and two-thirds of all deaths for children over the age of 15 years, and is the leading cause of death for individuals under the age of 44 years. Individuals over the age of 65 years have the highest fatality rates for many injuries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Injury control has not been given high priority in the United States, and the research being conducted on injury control and the number of personnel involved in injury control activities are not adequate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes of this Act [enacting this part] are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote research into the causes, diagnosis, treatment, prevention, and control of injuries and rehabilitation from injuries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote cooperation between specialists in fields involved in injury research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote coordination between Federal, State, and local governments and public and private entities in order to achieve a reduction in deaths from injuries.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
