{"tag":"section","attrib":{"id":"idbd1df080-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5189a"},"text":"§ 5189a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals of assistance decisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1df081-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any decision regarding eligibility for, from, or amount of assistance under this subchapter may be appealed within 60 days after the date on which the applicant for such assistance is notified of the award or denial of award of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df082-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period for decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A decision regarding an appeal under subsection (a) shall be rendered within 90 days after the date on which the Federal official designated to administer such appeals receives notice of such appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df083-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall issue rules which provide for the fair and impartial consideration of appeals under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df084-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of arbitration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1df085-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding this section, an applicant for assistance under this subchapter may request arbitration to dispute the eligibility for assistance or repayment of assistance provided for a dispute of more than $500,000 for any disaster that occurred after ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":". Such arbitration shall be conducted by the Civilian Board of Contract Appeals and the decision of such Board shall be binding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df086-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Civilian Board of Contract Appeals shall consider from the applicant all original and additional documentation, testimony, or other such evidence supporting the applicant’s position at any time during arbitration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df087-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For an applicant for assistance in a rural area under this subchapter, the assistance amount eligible for arbitration pursuant to this subsection shall be $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df088-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this subsection, the term “rural area” means an area with a population of less than 200,000 outside an urbanized area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1df089-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To participate in arbitration under this subsection, an applicant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd1df08a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit the dispute to the arbitration process established under the authority granted under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s601"},"text":"section 601 of Public Law 111–5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd1df08b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5189a/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may submit a request for arbitration after the completion of the first appeal under subsection (a) at any time before the Administrator of the Federal Emergency Management Agency has issued a final agency determination or 180 days after the Administrator’s receipt of the appeal if the Administrator has not provided the applicant with a final determination on the appeal. The applicant’s request shall contain documentation from the administrative record for the first appeal and may contain additional documentation supporting the applicant’s position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1df08c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s423"},"text":"Pub. L. 93–288, title IV, § 423","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106"},"text":"Pub. L. 100–707, title I, § 106","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1219"},"text":"Pub. L. 115–254, div. D, § 1219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3452"},"text":"132 Stat. 3452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df08d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df08e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd1df08f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/5/s601"},"text":"Section 601 of Public Law 111–5","children":[],"tail":", referred to in subsec. (d)(5)(A), is "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tVI/s601"},"text":"Pub. L. 111–5, div. A, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/164"},"text":"123 Stat. 164","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1df090-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1df091-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1df092-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd1df093-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dispute Resolution Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/2/dB/s1105"},"text":"Pub. L. 113–2, div. B, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-29"},"text":"Jan. 29, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/43"},"text":"127 Stat. 43","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/301/s2/c"},"text":"Pub. L. 114–301, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1514"},"text":"130 Stat. 1514","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/301/s2/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Administrator’ means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘eligible assistance’ means assistance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 403, 406, or 407 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170b"},"text":"42 U.S.C. 5170b","children":[],"tail":", 5172, 5173);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the legitimate amount in dispute is not less than $1,000,000, which sum the Administrator shall adjust annually to reflect changes in the Consumer Price Index for all Urban Consumers published by the Department of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the applicant has a non-Federal share; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the applicant has received a decision on a first appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2013-01-29"},"text":"Jan. 29, 2013","children":[],"tail":"], and in order to facilitate an efficient recovery from major disasters, the Administrator shall establish procedures under which an applicant may request the use of alternative dispute resolution, including arbitration by an independent review panel, to resolve disputes relating to eligible assistance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Binding effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A decision by an independent review panel under this section shall be binding upon the parties to the dispute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedures established under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow a party of a dispute relating to eligible assistance to request an independent review panel for the review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a party requesting an independent review panel as described in subparagraph (A) to agree to forgo rights to any further appeal of the dispute relating to any eligible assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require that the sponsor of an independent review panel for any alternative dispute resolution under this section be—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual or entity unaffiliated with the dispute (which may include a Federal agency, an administrative law judge, or a reemployed annuitant who was an employee of the Federal Government) selected by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible for identifying and maintaining an adequate number of independent experts qualified to review and resolve disputes under this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require an independent review panel to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolve any remaining disputed issue in accordance with all applicable laws, regulations, and Agency interpretations of those laws through its published policies and guidance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider only evidence contained in the administrative record, as it existed at the time at which the Agency made its initial decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only set aside a decision of the Agency found to be arbitrary, capricious, an abuse of discretion, or otherwise not in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a finding of material fact adverse to the claimant made on first appeal, only set aside or reverse such finding if the finding is clearly erroneous;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require an independent review panel to expeditiously issue a written decision for any alternative dispute resolution under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct that if an independent review panel for any alternative dispute resolution under this section determines that the basis upon which a party submits a request for alternative dispute resolution is frivolous, the independent review panel shall direct the party to pay the reasonable costs to the Federal Emergency Management Agency relating to the review by the independent review panel. Any funds received by the Federal Emergency Management Agency under the authority of this section shall be deposited to the credit of the appropriation or appropriations available for the eligible assistance in dispute on the date on which the funds are received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A request for review by an independent review panel under this section may not be made after ","children":[{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
