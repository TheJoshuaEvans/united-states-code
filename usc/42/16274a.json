{"tag":"section","attrib":{"id":"idc0013afc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16274a"},"text":"§ 16274a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University Nuclear Leadership Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0013afd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, the Administrator of the National Nuclear Security Administration, and the Chairman of the Commission shall jointly establish a program, to be known as the “University Nuclear Leadership Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013afe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013aff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2) and subsection (c), amounts made available to carry out the Program shall be used to provide financial assistance for scholarships, fellowships, and research and development projects at institutions of higher education in areas relevant to the programmatic mission of the applicable Federal agency, with an emphasis on providing the financial assistance with respect to research, development, demonstration, and commercial application activities relevant to civilian advanced nuclear reactors including, but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant fuel cycle technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced construction, manufacturing, and fabrication methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), amounts made available to carry out the Program may be used to provide financial assistance for a scholarship, fellowship, or multiyear research and development project that does not align directly with a programmatic mission of the Department of Energy, if the activity for which assistance is provided would facilitate the maintenance of the discipline of nuclear science or engineering, which may include nontechnical nuclear research..","children":[{"tag":"ref","attrib":{"idref":"fn004219"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004219"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nuclear energy traineeship subprogram","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall establish, as a subprogram of the Program, a nuclear energy traineeship subprogram under which the Commission, in coordination with institutions of higher education and trade schools, shall competitively award traineeships that provide focused training to meet critical mission needs of the Commission and nuclear workforce needs, including needs relating to the nuclear tradecraft workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the nuclear energy traineeship subprogram described in paragraph (1), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0013b07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinate with the Secretary of Energy to prioritize the funding of traineeships that focus on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0013b08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear workforce needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical mission needs of the Commission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage appropriate partnerships among—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0013b0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Laboratories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trade schools;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nuclear energy industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other entities, as the Commission determines to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0013b10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on an annual basis, evaluate nuclear workforce needs for the purpose of implementing traineeships in focused topical areas that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0013b11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the workforce needs of the nuclear energy community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0013b12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support critical mission needs of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced nuclear reactor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “advanced nuclear reactor” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16271/b"},"text":"section 16271(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Nuclear Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004220"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004220"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Another par. (3) follows par. (5)."}],"tail":" Institution of higher education"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Laboratory” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16271/b"},"text":"section 16271(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the University Nuclear Leadership Program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004221"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004221"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Another par. (3) follows par. (2)."}],"tail":" Nontechnical nuclear research"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nontechnical nuclear research” means research with specializations such as social sciences or law that can support an increase in community engagement, participation, and confidence in nuclear energy systems, including the navigation of the licensing required for advanced reactor deployment, aligned with the objectives in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16271/a/2"},"text":"section 16271(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0013b1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out the Program for each of fiscal years 2021 through 2025—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0013b1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 to the Secretary of Energy, of which $15,000,000 shall be for use by the Administrator of the National Nuclear Security Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0013b1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16274a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0013b1d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dC/tIII/s313"},"text":"Pub. L. 111–8, div. C, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/627"},"text":"123 Stat. 627","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2003/e"},"text":"Pub. L. 116–260, div. Z, title II, § 2003(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2465"},"text":"134 Stat. 2465","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10745/b"},"text":"Pub. L. 117–167, div. B, title VI, § 10745(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1721"},"text":"136 Stat. 1721","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/67/dB/tIV/s402"},"text":"Pub. L. 118–67, div. B, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1467"},"text":"138 Stat. 1467","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0013b1e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0013b1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0013b20-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development and Related Agencies Appropriations Act, 2009, and also as part of the Omnibus Appropriations Act, 2009, and not as part of the Energy Policy Act of 2005 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0013b21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/1"},"text":"Pub. L. 118–67, § 402(1)","children":[],"tail":", struck out “Nuclear Regulatory” before “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/2"},"text":"Pub. L. 118–67, § 402(2)","children":[],"tail":", inserted “and subsection (c)” after “paragraph (2)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/6"},"text":"Pub. L. 118–67, § 402(6)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/3"},"text":"Pub. L. 118–67, § 402(3)","children":[],"tail":", added pars. (1) to (4), redesignated former par. (2) as (5), and struck out former par. (1) which defined “advanced nuclear reactor” and “institution of higher education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/5"},"text":"Pub. L. 118–67, § 402(5)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/4"},"text":"Pub. L. 118–67, § 402(4)","children":[],"tail":", struck out “Nuclear Regulatory” before “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/67/s402/5"},"text":"Pub. L. 118–67, § 402(5)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10745/b/1"},"text":"Pub. L. 117–167, § 10745(b)(1)","children":[],"tail":", inserted “, which may include nontechnical nuclear research.” after “engineering”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10745/b/2"},"text":"Pub. L. 117–167, § 10745(b)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/s10745/b/3"},"text":"Pub. L. 117–167, § 10745(b)(3)","children":[],"tail":", substituted “$45,000,000” for “$30,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" amended section generally. Prior to amendment, section related to Integrated University Program."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0013b22-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc0013b23-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10745/a"},"text":"Pub. L. 117–167, div. B, title VI, § 10745(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1721"},"text":"136 Stat. 1721","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/167/dB/tVI/s10745/a"},"text":"“The purpose of this section [amending this section] is to support a diverse workforce for the complex landscape associated with effective and equitable development of advanced nuclear energy technologies, including interdisciplinary research to enable positive impacts and avoid potential negative impacts across the lifespan of nuclear energy technologies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
