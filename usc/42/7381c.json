{"tag":"section","attrib":{"id":"idbe054401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7381c"},"text":"§ 7381c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe054402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may authorize each Department research and development facility, to the extent practicable and consistent with the provisions of the laboratory’s management and operating contract, to enter into education partnership agreements with educational institutions in the United States (including local educational agencies, colleges, and universities) for the purpose of encouraging and enhancing study in scientific disciplines at all levels of education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe054403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under a partnership agreement entered into with an educational institution under subsection (a) and as authorized by the Secretary, a Department research and development facility may provide assistance to the educational institution by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe054404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loaning or transferring equipment to the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferring to the institution equipment determined by the director of the Department research and development facility to be surplus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making personnel of Department research and development facilities available to teach science courses or to assist in the development of science courses and materials for the institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054407-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involving faculty and students of the institution in research programs of Department research and development facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperating with the institution in developing a program under which students may be given academic credit for work on research projects of Department research and development facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe054409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing academic and career advice and assistance to students of the institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe05440a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7381c/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing funds to educational institutions to hire personnel to facilitate interactions between local school systems, Department research and development facilities, and corporate and governmental entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe05440b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXI/s3166"},"text":"Pub. L. 101–510, div. C, title XXXI, § 3166","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1843"},"text":"104 Stat. 1843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXI/s1102/c"},"text":"Pub. L. 109–58, title XI, § 1102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/938"},"text":"119 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe05440c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe05440d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe05440e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1102/c/1"},"text":"Pub. L. 109–58, § 1102(c)(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “loaning equipment to the institution;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s1102/c/2"},"text":"Pub. L. 109–58, § 1102(c)(2)","children":[],"tail":"–(4), added par. (7)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
