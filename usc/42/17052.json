{"tag":"section","attrib":{"id":"idc0203561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052"},"text":null,"children":[{"tag":"num","attrib":{"value":"17052"},"text":"§ 17052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable fuel infrastructure grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0203562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of renewable fuel blend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “renewable fuel blend” means a gasoline blend that contains not less than 11 percent, and not more than 85 percent, renewable fuel or diesel fuel that contains at least 10 percent renewable fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure development grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program for making grants for providing assistance to retail and wholesale motor fuel dealers or other entities for the installation, replacement, or conversion of motor fuel storage and dispensing infrastructure to be used exclusively to store and dispense renewable fuel blends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall establish criteria for evaluating applications for grants under this subsection that will maximize the availability and use of renewable fuel blends, and that will ensure that renewable fuel blends are available across the country. Such criteria shall provide for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0203566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the public demand for each renewable fuel blend in a particular geographic area based on State registration records showing the number of flexible-fuel vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0203567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the opportunity to create or expand corridors of renewable fuel blend stations along interstate or State highways;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0203568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the experience of each applicant with previous, similar projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0203569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of population, number of flexible-fuel vehicles, number of retail fuel outlets, and saturation of flexible-fuel vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc020356a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" priority consideration to applications that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc020356b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most likely to maximize displacement of petroleum consumption, measured as a total quantity and a percentage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc020356c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are best able to incorporate existing infrastructure while maximizing, to the extent practicable, the use of renewable fuel blends; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc020356d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest commitment on the part of the applicant to ensure funding for the proposed project and the greatest likelihood that the project will be maintained or expanded after Federal assistance under this subsection is completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020356e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under this subsection shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc020356f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 33 percent of the estimated cost of the installation, replacement, or conversion of motor fuel storage and dispensing infrastructure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0203570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $180,000 for a combination of equipment at any one retail outlet location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of renewable fuel blend stations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish rules that set forth requirements for grant recipients under this section that include providing to the public the renewable fuel blends, establishing a marketing plan that informs consumers of the price and availability of the renewable fuel blends, clearly labeling the dispensers and related equipment, and providing periodic reports on the status of the renewable fuel blend sales, the type and amount of the renewable fuel blends dispensed at each location, and the average price of such fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the date on which each renewable fuel blend station begins to offer renewable fuel blends to the public, the grant recipient that used grant funds to construct or upgrade such station shall notify the Secretary of such opening. The Secretary shall add each new renewable fuel blend station to the renewable fuel blend station locator on its Website when it receives notification under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Double counting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person that receives a credit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s30C"},"text":"section 30C of title 26","children":[],"tail":" may receive assistance under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve funds appropriated for the renewable fuel blends infrastructure development grant program for technical and marketing assistance described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail technical and marketing assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enter into contracts with entities with demonstrated experience in assisting retail fueling stations in installing refueling systems and marketing renewable fuel blends nationally, for the provision of technical and marketing assistance to recipients of grants under this section. Such assistance shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0203576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical advice for compliance with applicable Federal and State environmental requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help in identifying supply sources and securing long-term contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0203578-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of public outreach, education, and labeling materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0203579-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refueling infrastructure corridors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc020357a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant pilot program (referred to in this subsection as the “pilot program”), to be administered through the Vehicle Technology Deployment Program of the Department, to provide not more than 10 geographically-dispersed project grants to State governments, Indian tribal governments, local governments, metropolitan transportation authorities, or partnerships of those entities to carry out 1 or more projects for the purposes described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020357b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this subsection shall be used for the establishment of refueling infrastructure corridors, as designated by the Secretary, for renewable fuel blends, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc020357c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installation of infrastructure and equipment necessary to ensure adequate distribution of renewable fuel blends within the corridor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc020357d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installation of infrastructure and equipment necessary to directly support vehicles powered by renewable fuel blends; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc020357e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation and maintenance of infrastructure and equipment installed as part of a project funded by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc020357f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0203580-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0203581-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall issue requirements for use in applying for grants under the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0203582-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the Secretary shall require that an application for a grant under this subsection—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc0203583-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be submitted by—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc0203584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of a State, tribal, or local government or a metropolitan transportation authority, or any combination of those entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc0203585-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a registered participant in the Vehicle Technology Deployment Program of the Department; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc0203586-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idc0203587-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the project proposed in the application, including the ways in which the project meets the requirements of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc0203588-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the degree of use of the project, including the estimated size of fleet of vehicles operated with renewable fuels blend available within the geographic region of the corridor, measured as a total quantity and a percentage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc0203589-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the potential petroleum displaced as a result of the project (measured as a total quantity and a percentage), and a plan to collect and disseminate petroleum displacement and other relevant data relating to the project to be funded under the grant, over the expected life of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc0227d7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the means by which the project will be sustainable without Federal assistance after the completion of the term of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc0227d7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete description of the costs of the project, including acquisition, construction, operation, and maintenance costs over the expected life of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idc0227d7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/A/ii/II/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of which costs of the project will be supported by Federal assistance under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant under subparagraph (A) may carry out a project under the pilot program in partnership with public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227d7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications under the pilot program, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227d7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the experience of each applicant with previous, similar projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give priority consideration to applications that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227d81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are most likely to maximize displacement of petroleum consumption, measured as a total quantity and a percentage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are best able to incorporate existing infrastructure while maximizing, to the extent practicable, the use of advanced biofuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest commitment on the part of the applicant to ensure funding for the proposed project and the greatest likelihood that the project will be maintained or expanded after Federal assistance under this subsection is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent a partnership of public and private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceed the minimum requirements of paragraph (3)(A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227d86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot project requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227d87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide not more than $20,000,000 in Federal assistance under the pilot program to any applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of any activity relating to renewable fuel blend infrastructure development carried out using funds from a grant under this subsection shall be not less than 20 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum period of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not provide funds to any applicant under the pilot program for more than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment and distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek, to the maximum extent practicable, to ensure a broad geographic distribution of project sites funded by grants under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of information and knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish mechanisms to ensure that the information and knowledge gained by participants in the pilot program are transferred among the pilot program participants and to other interested parties, including other applicants that submitted applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227d8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227d8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial grants","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227d8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall publish in the Federal Register, Commerce Business Daily, and such other publications as the Secretary considers to be appropriate, a notice and request for applications to carry out projects under the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application described in clause (i) shall be submitted to the Secretary by not later than 180 days after the date of publication of the notice under that clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date by which applications for grants are due under clause (ii), the Secretary shall select by competitive, peer-reviewed proposal up to 5 applications for projects to be awarded a grant under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional grants","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227d92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Secretary shall publish in the Federal Register, Commerce Business Daily, and such other publications as the Secretary considers to be appropriate, a notice and request for additional applications to carry out projects under the pilot program that incorporate the information and knowledge obtained through the implementation of the first round of projects authorized under the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application described in clause (i) shall be submitted to the Secretary by not later than 180 days after the date of publication of the notice under that clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date by which applications for grants are due under clause (ii), the Secretary shall select by competitive, peer-reviewed proposal such additional applications for projects to be awarded a grant under the pilot program as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0227d95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0227d96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which grants are awarded under this subsection, the Secretary shall submit to Congress a report containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc0227d97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the grant recipients and a description of the projects to be funded under the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of other applicants that submitted applications for the pilot program but to which funding was not provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc0227d99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the mechanisms used by the Secretary to ensure that the information and knowledge gained by participants in the pilot program are transferred among the pilot program participants and to other interested parties, including other applicants that submitted applications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0227d9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", and annually thereafter until the termination of the pilot program, the Secretary shall submit to Congress a report containing an evaluation of the effectiveness of the pilot program, including an assessment of the petroleum displacement and benefits to the environment derived from the projects included in the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227d9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No grant shall be provided under subsection (b) or (c) to a large, vertically integrated oil company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0227d9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17052/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $200,000,000 for each of the fiscal years 2008 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0227d9d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s244"},"text":"Pub. L. 110–140, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1541"},"text":"121 Stat. 1541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0227d9e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0227d9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0227da0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
