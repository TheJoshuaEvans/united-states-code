{"tag":"section","attrib":{"id":"idbfe48bac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853"},"text":null,"children":[{"tag":"num","attrib":{"value":"15853"},"text":"§ 15853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rebate program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48bad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program providing rebates for consumers for expenditures made for the installation of a renewable energy system in connection with a dwelling unit or small business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of rebate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Rebates provided under the program established under paragraph (1) shall be in an amount not to exceed the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48baf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the expenditures described in paragraph (1) made by the consumer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “renewable energy system” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6865/c/6/A"},"text":"section 6865(c)(6)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48bb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section, to remain available until expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48bb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for fiscal year 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48bb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15853/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48bb8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s206/c"},"text":"Pub. L. 109–58, title II, § 206(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/655"},"text":"119 Stat. 655","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
