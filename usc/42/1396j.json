ate of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/417"},"text":"Pub. L. 106–417","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Oct. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/417/s3/c"},"text":"section 3(c) of Pub. L. 106–417","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1645"},"text":"section 1645 of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba60f3e1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as specifically provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411"},"text":"section 411 of Pub. L. 100–360","children":[],"tail":", amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/100/360"},"text":"Pub. L. 100–360","children":[],"tail":", as it relates to a provision in the Omnibus Budget Reconciliation Act of 1987, "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", effective as if included in the enactment of that provision in "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/360/s411/a"},"text":"section 411(a) of Pub. L. 100–360","children":[],"tail":", set out as a Reference to OBRA; Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s106"},"text":"section 106 of Title 1","children":[],"tail":", General Provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idba60f3e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tIV/s4118/f/2"},"text":"Pub. L. 100–203, title IV, § 4118(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-156"},"text":"101 Stat. 1330–156","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/203/tIV/s4118/f/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall apply to health care services performed on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/s4211/h/8"},"text":"section 4211(h)(8) of Pub. L. 100–203","children":[],"tail":" applicable to nursing facility services furnished on or after "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", without regard to whether regulations implementing such amendment are promulgated by such date, except as otherwise specifically provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r"},"text":"section 1396r of this title","children":[],"tail":", with transitional rule, see section 4214(a), (b)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396r"},"text":"section 1396r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idba60f3e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Agreements To Reimburse State Agency for Health Care and Services Provided by Agency to Indians","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s402/b"},"text":"Pub. L. 94–437, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1409"},"text":"90 Stat. 1409","children":[],"tail":", which authorized Secretary to enter into agreements to reimburse State agencies for health care and services provided in Service facilities to Indians eligible for medical assistance under this subchapter, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tIV/s401/b"},"text":"Pub. L. 100–713, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4818"},"text":"102 Stat. 4818","children":[],"tail":", applicable to services performed on or after the "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idba60f3e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payments Into Special Fund To Improve Indian Health Service Facilities To Achieve Compliance With Conditions and Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s402/c"},"text":"Pub. L. 94–437, title IV, § 402(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1409"},"text":"90 Stat. 1409","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/713/tIV/s401/a"},"text":"Pub. L. 100–713, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4818"},"text":"102 Stat. 4818","children":[],"tail":", provided that payments to which any Indian Health Service facility was entitled by reason of this section were to be placed in a special fund of the Secretary for improvements of facilities of the Service to comply with requirements of this subchapter, required minimum funding for each service unit making collections for such facilities, and provided for "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/s402/c"},"text":"section 402(c) of Pub. L. 94–437","children":[],"tail":" to cease to apply when Secretary determined that substantially all such facilities complied with requirements of this subchapter, prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/s402"},"text":"section 402 of Pub. L. 94–437","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIV/s401/b/1"},"text":"Pub. L. 102–573, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4565"},"text":"106 Stat. 4565","children":[],"tail":". Similar provisions are contained in "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/s401/c"},"text":"section 401(c) of Pub. L. 94–437","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1641/c"},"text":"section 1641(c) of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idba60f3e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Medicaid Payments Not Considered in Determining Appropriations for Indian Health Care","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/437/tIV/s402/d"},"text":"Pub. L. 94–437, title IV, § 402(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1410"},"text":"90 Stat. 1410","children":[],"tail":", provided that any payments received for services provided recipients under this section were not to be considered in determining appropriations for the provision of health care and services to Indians, prior to the general amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/s402"},"text":"section 402 of Pub. L. 94–437","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/102/573/tIV/s401/b/1"},"text":"Pub. L. 102–573, title IV, § 401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4565"},"text":"106 Stat. 4565","children":[],"tail":". Similar provisions are contained in "},{"tag":"ref","attrib":{"href":"/us/pl/94/437/s401/a"},"text":"section 401(a) of Pub. L. 94–437","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s1641/a"},"text":"section 1641(a) of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
