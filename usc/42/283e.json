{"tag":"section","attrib":{"id":"idb5596a64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e"},"text":null,"children":[{"tag":"num","attrib":{"value":"283e"},"text":"§ 283e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for use of animals in research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5596a65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of NIH, after consultation with the committee established under subsection (e), shall prepare a plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5596a66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the National Institutes of Health to conduct or support research into—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5596a67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of biomedical research and experimentation that do not require the use of animals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5596a68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of such research and experimentation that reduce the number of animals used in such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5596a69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of such research and experimentation that produce less pain and distress in such animals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5596a6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of such research and experimentation that involve the use of marine life (other than marine mammals);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for establishing the validity and reliability of the methods described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for encouraging the acceptance by the scientific community of such methods that have been found to be valid and reliable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for training scientists in the use of such methods that have been found to be valid and reliable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5596a6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", the Director of NIH shall submit to the Committee on Energy and Commerce of the House of Representatives, and to the Committee on Labor and Human Resources of the Senate, the plan required in subsection (a) and shall begin implementation of the plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5596a6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic review and revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall periodically review, and as appropriate, make revisions in the plan required under subsection (a). A description of any revision made in the plan shall be included in the first biennial report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283"},"text":"section 283 of this title","children":[],"tail":" that is submitted after the revision is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5596a70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of NIH shall take such actions as may be appropriate to convey to scientists and others who use animals in biomedical or behavioral research or experimentation information respecting the methods found to be valid and reliable under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5596a71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Coordinating Committee on the Use of Animals in Research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5596a72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of NIH shall establish within the National Institutes of Health a committee to be known as the Interagency Coordinating Committee on the Use of Animals in Research (in this subsection referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall provide advice to the Director of NIH on the preparation of the plan required in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5596a74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5596a75-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Directors of each of the national research institutes (or the designees of such Directors); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5596a76-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s283e/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the Environmental Protection Agency, the Food and Drug Administration, the Consumer Product Safety Commission, the National Science Foundation, and such additional agencies as the Director of NIH determines to be appropriate, which representatives shall include not less than one veterinarian with expertise in laboratory-animal medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5596a77-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 404C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tII/s205/a"},"text":"Pub. L. 103–43, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/146"},"text":"107 Stat. 146","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tII/s221/d/2"},"text":"Pub. L. 112–74, div. F, title II, § 221(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1090"},"text":"125 Stat. 1090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5596a78-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5596a79-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5596a7a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (e)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" struck out “and the Director of the Center for Research Resources” after “institutes”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5596a7b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5596a7c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Energy and Commerce of House of Representatives treated as referring to Committee on Commerce of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Commerce of House of Representatives changed to Committee on Energy and Commerce of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred to Committee on Financial Services of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, "},{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
