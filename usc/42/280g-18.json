{"tag":"section","attrib":{"id":"idb543e602-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–18"},"text":"§ 280g–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maternal mental health hotline","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543e603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain, by grant or contract, a national maternal mental health hotline to provide emotional support, information, brief intervention, and mental health and substance use disorder resources to pregnant and postpartum women at risk of, or affected by, maternal mental health and substance use disorders, and to their families or household members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for hotline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The hotline under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a 24/7 real-time hotline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide voice and text support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be staffed by certified peer specialists, licensed health care professionals, or licensed mental health professionals who are trained on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maternal mental health and substance use disorder prevention, identification, and intervention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing culturally and linguistically appropriate support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e60a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide maternal mental health and substance use disorder assistance and referral services to meet the needs of underserved populations, individuals with disabilities, and family and household members of pregnant or postpartum women at risk of experiencing maternal mental health and substance use disorders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e60b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In maintaining the hotline under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e60c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Domestic Violence Hotline, National Suicide Prevention Lifeline, and Veterans Crisis Line to ensure that pregnant and postpartum women are connected in real-time to the appropriate specialized hotline service, when applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e60d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a public awareness campaign for the hotline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e60e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with Federal departments and agencies, including the Substance Abuse and Mental Health Services Administration and the Department of Veterans Affairs, to increase awareness regarding the hotline; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e60f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with appropriate State, local, and Tribal public health officials, including officials who administer programs that serve low-income pregnant and postpartum individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit an annual report to the Congress on the hotline under subsection (a) and implementation of this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the effectiveness of activities conducted or supported under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a directory of entities or organizations to which staff maintaining the hotline funded under this section may make referrals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e613-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional information as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e614-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–18/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $10,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543e615-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399V–7, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1112"},"text":"Pub. L. 117–328, div. FF, title I, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5643"},"text":"136 Stat. 5643","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
