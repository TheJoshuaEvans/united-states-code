{"tag":"section","attrib":{"id":"idbc31e269-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2991h"},"text":"§ 2991h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals, notice, and hearing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc31e26a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commissioner shall prescribe procedures to assure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc31e26b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial assistance under this subchapter shall not be suspended, except in emergency situations, unless the assisted agency has been given reasonable notice and opportunity to show cause why such action should not be taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc31e26c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial assistance under this subchapter shall not be terminated, and application for refunding shall not be denied, and a suspension of financial assistance shall not be continued for longer than thirty days, unless the assisted agency has been afforded reasonable notice and opportunity for a full and fair hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc31e26d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2991h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an application is rejected on the grounds that the applicant is ineligible or that activities proposed by the applicant are ineligible for funding, the applicant may appeal to the Secretary, not later than 30 days after the date of receipt of notification of such rejection, for a review of the grounds for such rejection. On appeal, if the Secretary finds that an applicant is eligible or that its proposed activities are eligible, such eligibility shall not be effective until the next cycle of grant proposals are considered by the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc31e26e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/tVIII/s810"},"text":"Pub. L. 88–452, title VIII, § 810","children":[],"tail":", formerly § 809, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/644/s11"},"text":"Pub. L. 93–644, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2326"},"text":"88 Stat. 2326","children":[],"tail":"; renumbered § 810, "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tV/s502/3"},"text":"Pub. L. 100–175, title V, § 502(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/973"},"text":"101 Stat. 973","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVIII/s822/10"},"text":"Pub. L. 102–375, title VIII, § 822(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1298"},"text":"106 Stat. 1298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc31e26f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc31e270-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc31e271-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/s810"},"text":"section 810 of Pub. L. 88–452","children":[],"tail":" was renumbered section 811 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2992"},"text":"section 2992 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/452/s810"},"text":"section 810 of Pub. L. 88–452","children":[],"tail":", title VIII, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/222/tI/s110"},"text":"Pub. L. 90–222, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-23"},"text":"Dec. 23, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/722"},"text":"81 Stat. 722","children":[],"tail":", related to authority to establish full-time programs and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2992"},"text":"section 2992 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/113/tVI/s603"},"text":"Pub. L. 93–113, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/417"},"text":"87 Stat. 417","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc31e272-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375"},"text":"Pub. L. 102–375","children":[],"tail":" substituted “Commissioner” for “Secretary”, designated existing provisions as subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
