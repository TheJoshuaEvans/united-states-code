{"tag":"section","attrib":{"id":"idbaad3ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397k–2"},"text":"§ 1397k–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research protections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate guidelines to assist researchers working in the area of elder abuse, neglect, and exploitation, with issues relating to human subject protections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of legally authorized representative for application of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the application of subpart A of part 46 of title 45, Code of Federal Regulations, to research conducted under this subpart, the term “legally authorized representative” means, unless otherwise provided by law, the individual or judicial or other body authorized under the applicable law to consent to medical treatment on behalf of another person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3edb-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", 