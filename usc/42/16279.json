{"tag":"section","attrib":{"id":"idc0038483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279"},"text":null,"children":[{"tag":"num","attrib":{"value":"16279"},"text":"§ 16279.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0038484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-09-28"},"text":"September 28, 2018","children":[],"tail":", the Secretary shall submit to the Committee on Energy and Natural Resources of the Senate and the Committee on Science, Space, and Technology of the House of Representatives 2 alternative 10-year budget plans for civilian nuclear energy research and development by the Secretary, as described in subsections (b) through (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0038485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget plan alternative 1","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One of the budget plans submitted under subsection (a) shall assume constant annual funding for 10 years at the appropriated level for the current fiscal year for the civilian nuclear energy research and development of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0038486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget plan alternative 2","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"One of the budget plans submitted under subsection (a) shall be an unconstrained budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0038487-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each alternative budget plan submitted under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0038488-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prioritized list of the programs, projects, and activities of the Department to best support the development of advanced nuclear reactor technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0038489-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" realistic budget requirements for the Department to implement sections 16275(c), 16277, and 16278 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc003848a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification of the Department for continuing or terminating existing civilian nuclear energy research and development programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc003848b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the progress made under the programs described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16279a"},"text":"section 16279a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc003848c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16279/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once every 2 years, the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate updated 10-year budget plans which shall identify, and provide a justification for, any major deviation from a previous budget plan submitted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc003848d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s959"},"text":"Pub. L. 109–58, title IX, § 959","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/248/s2/i"},"text":"Pub. L. 115–248, § 2(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-09-28"},"text":"Sept. 28, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3160"},"text":"132 Stat. 3160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tII/s2005"},"text":"Pub. L. 116–260, div. Z, title II, § 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2470"},"text":"134 Stat. 2470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc003848e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc003848f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc0038490-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2005/1"},"text":"Pub. L. 116–260, § 2005(1)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “One of the budget plans submitted under subsection (a) shall assume constant annual funding for 10 years at the appropriated level for the civilian nuclear energy research and development of the Department for fiscal year 2016.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2005/2"},"text":"Pub. L. 116–260, § 2005(2)","children":[],"tail":"–(4), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s2005/5"},"text":"Pub. L. 116–260, § 2005(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
