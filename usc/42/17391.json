{"tag":"section","attrib":{"id":"idc03cbca2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391"},"text":null,"children":[{"tag":"num","attrib":{"value":"17391"},"text":"§ 17391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary state, regional, and local electricity distribution planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc03cbca3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the request of a State, regional organization, or electric utility, the Secretary of Energy shall provide assistance to States, regional organizations, and electric utilities to facilitate the development of State, regional, and local electricity distribution plans by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbca4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a resource assessment and analysis of future demand and distribution requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbca5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing open source tools for State, regional, and local planning and operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbca6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk and security analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment under subsection (a)(1) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbca7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of the physical security, cybersecurity, and associated communications needs of an advanced distribution management system and the integration of distributed energy resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbca8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced use of grid architecture to analyze risks in an all-hazards approach that includes communications infrastructure, control systems architecture, and power systems architecture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information collected for the assessment and analysis under subsection (a)(1)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbcaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to be critical electric infrastructure information under section 824","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of title 16; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall only be released in compliance with regulations implementing that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of assisting in the development of State and regional electricity distribution plans, the Secretary shall provide technical assistance to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc03cbcad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regional reliability entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc03cbcaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other distribution asset owners and operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or any entity that has requested technical assistance under this section may withdraw the request for technical assistance at any time, and on such withdrawal, the Secretary shall terminate all assistance efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc03cbcb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17391/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section authorizes the Secretary to require any State, regional organization, regional reliability entity, asset owner, or asset operator to adopt any model, tool, plan, analysis, or assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc03cbcb2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tVIII/s8010"},"text":"Pub. L. 116–260, div. Z, title VIII, § 8010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2588"},"text":"134 Stat. 2588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc03cbcb3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc03cbcb4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc03cbcb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Act of 2020, and not as part of the Energy Independence and Security Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
