{"tag":"section","attrib":{"id":"idbdd7f199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6939b"},"text":"§ 6939b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim control of hazardous waste injection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdd7f19a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underground source of drinking water","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No hazardous waste may be disposed of by underground injection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd7f19b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" into a formation which contains (within one-quarter mile of the well used for such underground injection) an underground source of drinking water; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f19c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" above such a formation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The prohibitions established under this section shall take effect 6 months after ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", except in the case of any State in which identical or more stringent prohibitions are in effect before such date under the Safe Drinking Water Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd7f19d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions under Comprehensive Environmental Response, Compensation, and Liability Act","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to the injection of contaminated ground water into the aquifer from which it was withdrawn, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd7f19e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such injection is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbdd7f19f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a response action taken under section 9604 or 9606 of this title, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbdd7f1a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part of corrective action required under this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn003528"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003528"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":null}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"intended to clean up such contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f1a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contaminated ground water is treated to substantially reduce hazardous constituents prior to such injection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f1a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such response action or corrective action will, upon completion, be sufficient to protect human health and the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd7f1a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to enforcement under the provisions of this chapter, the prohibitions established under paragraphs (1) and (2) of subsection (a) shall be enforceable under the Safe Drinking Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.] in any State—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdd7f1a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which has adopted identical or more stringent prohibitions under part C of the Safe Drinking Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300h"},"text":"42 U.S.C. 300h","children":[],"tail":" et seq.] and which has assumed primary enforcement responsibility under that Act for enforcement of such prohibitions; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdd7f1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the Administrator has adopted identical or more stringent prohibitions under the Safe Drinking Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.] and is exercising primary enforcement responsibility under that Act for enforcement of such prohibitions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdd7f1a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6939b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “primary enforcement responsibility”, “underground source of drinking water”, “formation” and “well” have the same meanings as provided in regulations of the Administrator under the Safe Drinking Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.]. The term “Safe Drinking Water Act” means title XIV of the Public Health Service Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdd7f1a7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s3020"},"text":"Pub. L. 89–272, title II, § 3020","children":[],"tail":", formerly § 7010, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tIV/s405/a"},"text":"Pub. L. 98–616, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3273"},"text":"98 Stat. 3273","children":[],"tail":"; renumbered § 3020, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/tII/s201/c"},"text":"Pub. L. 99–339, title II, § 201(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/654"},"text":"100 Stat. 654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdd7f1a8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdd7f1a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbdd7f1aa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title XIV of the Public Health Service Act, referred to in subsec. (d), is title XIV of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1974-12-16"},"text":"Dec. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/523/s2/a"},"text":"Pub. L. 93–523, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1660"},"text":"88 Stat. 1660","children":[],"tail":", known as the Safe Drinking Water Act, which is classified generally to subchapter XII (§ 300f et seq.) of chapter 6A of this title. Part C of the Act is classified generally to part C (§ 300h et seq.) of subchapter XII of chapter 6A of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdd7f1ab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6979a"},"text":"section 6979a of this title","children":[],"tail":", prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/99/339"},"text":"Pub. L. 99–339","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdd7f1ac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/339/s201/c/1"},"text":"Pub. L. 99–339, § 201(c)(1)","children":[],"tail":", substituted “enforcement under the provisions of this chapter” for “enforcement under sections 6972 and 6973 of this title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
