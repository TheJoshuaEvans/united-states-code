{"tag":"section","attrib":{"id":"idbf89e76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645d"},"text":null,"children":[{"tag":"num","attrib":{"value":"12645d"},"text":"§ 12645d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds for severely economically distressed communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf89e76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a severely economically distressed community that receives assistance from the Corporation for any program under the national service laws shall not be subject to any requirements to provide matching funds for any such program, and the Federal share of such assistance for such a community may be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf89e76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severely economically distressed community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “severely economically distressed community” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf89e770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an area that has a mortgage foreclosure rate, home price decline, and unemployment rate all of which are above the national average for such rates or level, for the most recent 12 months for which satisfactory data are available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf89e771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12645d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a residential area that lacks basic living necessities, such as water and sewer systems, electricity, paved roads, and safe, sanitary housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf89e772-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s189A"},"text":"Pub. L. 101–610, title I, § 189A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1612"},"text":"Pub. L. 111–13, title I, § 1612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1539"},"text":"123 Stat. 1539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf89e773-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf89e774-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf89e775-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
