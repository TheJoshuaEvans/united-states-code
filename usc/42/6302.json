{"tag":"section","attrib":{"id":"idbd8e1775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302"},"text":null,"children":[{"tag":"num","attrib":{"value":"6302"},"text":"§ 6302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd8e1776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8e1777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any manufacturer or private labeler to distribute in commerce any new covered product to which a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294"},"text":"section 6294 of this title","children":[],"tail":" applies, unless such covered product is labeled in accordance with such rule;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e1778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any manufacturer, distributor, retailer, or private labeler to remove from any new covered product or render illegible any label required to be provided with such product under a rule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294"},"text":"section 6294 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e1779-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any manufacturer to fail to permit access to, or copying of, records required to be supplied under this part, or fail to make reports or provide other information required to be supplied under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e177a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to fail to comply with an applicable requirement of section 6296(a), (b)(2), (b)(3), or (b)(5) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e177b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any manufacturer or private labeler to distribute in commerce any new covered product which is not in conformity with an applicable energy conservation standard established in or prescribed under this part, except to the extent that the new covered product is covered by a regional standard that is more stringent than the base national standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e177c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any manufacturer or private labeler to knowingly sell a product to a distributor, contractor, or dealer with knowledge that the entity routinely violates any regional standard applicable to the product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e177d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any manufacturer, distributor, retailer, or private labeler to distribute in commerce an adapter that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8e177e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to allow an incandescent lamp that does not have a medium screw base to be installed into a fixture or lampholder with a medium screw base socket; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8e177f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is capable of being operated at a voltage range at least partially within 110 and 130 volts; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8e1780-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8e1781-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to activate an activation lock for a grid-enabled water heater with knowledge that such water heater is not used as part of an electric thermal storage or demand response program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8e1782-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to distribute an activation key for a grid-enabled water heater with knowledge that such activation key will be used to activate a grid-enabled water heater that is not used as part of an electric thermal storage or demand response program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8e1783-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise enable a grid-enabled water heater to operate at its designed specification and capabilities with knowledge that such water heater is not used as part of an electric thermal storage or demand response program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8e1784-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to knowingly remove or render illegible the label of a grid-enabled water heater described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6295/e/6/A/ii/V"},"text":"section 6295(e)(6)(A)(ii)(V) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8e1785-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “New covered product” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “new covered product” means a covered product the title of which has not passed to a purchaser who buys such product for purposes other than (1) reselling such product, or (2) leasing such product for a period in excess of one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd8e1786-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s332"},"text":"Pub. L. 94–163, title III, § 332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/928"},"text":"89 Stat. 928","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/a/3"},"text":"Pub. L. 100–12, § 11(a)(3)","children":[],"tail":", (b)(5), "},{"tag":"date","attrib":{"date":"1987-03-17"},"text":"Mar. 17, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/125"},"text":"101 Stat. 125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII"},"text":"Pub. L. 110–140, title III","children":[],"tail":", §§ 306(b), 321(e), "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1559"},"text":"121 Stat. 1559","children":[],"tail":", 1586; "},{"tag":"ref","attrib":{"href":"/us/pl/114/11/tII/s201/2"},"text":"Pub. L. 114–11, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-30"},"text":"Apr. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/188"},"text":"129 Stat. 188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8e1787-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd8e1788-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd8e1789-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/11"},"text":"Pub. L. 114–11","children":[],"tail":" redesignated par. (6) relating to prohibition of distribution in commerce of certain adapters as (7) and added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s321/e/1"},"text":"Pub. L. 110–140, § 321(e)(1)","children":[],"tail":", which directed the striking out of “or” after semicolon at end, could not be executed after amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s306/b/1"},"text":"Pub. L. 110–140, § 306(b)(1)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s306/b/1"},"text":"Pub. L. 110–140, § 306(b)(1)","children":[],"tail":", struck out “or” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s321/e/2"},"text":"Pub. L. 110–140, § 321(e)(2)","children":[],"tail":", which directed substitution of “; or” for period at end, could not be executed after amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s306/b/2"},"text":"Pub. L. 110–140, § 306(b)(2)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s306/b/2"},"text":"Pub. L. 110–140, § 306(b)(2)","children":[],"tail":", substituted “part, except to the extent that the new covered product is covered by a regional standard that is more stringent than the base national standard; or” for “part.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s321/e/3"},"text":"Pub. L. 110–140, § 321(e)(3)","children":[],"tail":", added par. (6) relating to prohibition of distribution in commerce of certain adapters."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s306/b/3"},"text":"Pub. L. 110–140, § 306(b)(3)","children":[],"tail":", added par. (6) relating to sale of a product to a distributor, contractor, or dealer with knowledge that the entity routinely violates a regional standard."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/b/5/A"},"text":"Pub. L. 100–12, § 11(b)(5)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/a/3"},"text":"Pub. L. 100–12, § 11(a)(3)","children":[],"tail":", substituted “energy conservation standard established in or prescribed under” for “energy efficiency standard prescribed under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/b/5/B"},"text":"Pub. L. 100–12, § 11(b)(5)(B)","children":[],"tail":", inserted heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd8e178a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd8e178b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
