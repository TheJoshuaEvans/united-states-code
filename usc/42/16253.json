{"tag":"section","attrib":{"id":"idbffc59d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253"},"text":null,"children":[{"tag":"num","attrib":{"value":"16253"},"text":"§ 16253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business bioproduct marketing and certification grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffc59d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using amounts made available under subsection (g), the Secretary of Agriculture (referred to in this section as the “Secretary”) shall make available on a competitive basis grants to eligible entities described in subsection (b) for the biobased product marketing and certification purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible for a grant under this section is any manufacturer of biobased products that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposes to use the grant for the biobased product marketing and certification purposes described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not previously received a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Secretary shall provide a preference to an eligible entity that has fewer than 50 employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biobased product marketing and certification grant purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant made under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide working capital for marketing of biobased products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide for the certification of biobased products to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffc59dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualify for the label described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8102/b"},"text":"section 8102(b) of title 7","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffc59de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet other biobased standards determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant recipients shall provide matching non-Federal funds equal to the amount of the grant received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Matching funds shall be expended in advance of grant funding, so that for every dollar of grant that is advanced, an equal amount of matching funds shall have been funded prior to submitting the request for reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under this section shall not exceed $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish such administrative requirements for grants under this section, including requirements for applications for the grants, as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to make grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16253/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2007 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffc59e7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s944"},"text":"Pub. L. 109–58, title IX, § 944","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/881"},"text":"119 Stat. 881","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIX/s9002/b"},"text":"Pub. L. 113–79, title IX, § 9002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/928"},"text":"128 Stat. 928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbffc59e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbffc59e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbffc59ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “section 8102(b)” for “section 8102(h)(1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
