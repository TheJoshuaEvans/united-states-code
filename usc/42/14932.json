{"tag":"section","attrib":{"id":"idbfd6332c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932"},"text":null,"children":[{"tag":"num","attrib":{"value":"14932"},"text":"§ 14932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoptions of children emigrating from the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfd6332d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of accredited agency or approved person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a Convention adoption involving the emigration of a child residing in the United States to a foreign country, the accredited agency or approved person providing adoption services, or the prospective adoptive parent or parents acting on their own behalf (if permitted by the laws of such other Convention country in which they reside and the laws of the State in which the child resides), shall do the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd6332e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ensure that, in accordance with the Convention—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd6332f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a background study on the child is completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd63330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the accredited agency or approved person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfd63331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made reasonable efforts to actively recruit and make a diligent search for prospective adoptive parents to adopt the child in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfd63332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" despite such efforts, has not been able to place the child for adoption in the United States in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd63333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination is made that placement with the prospective adoptive parent or parents is in the best interests of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Furnish to the State court with jurisdiction over the case—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd63335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of the matters described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd63336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a background report (home study) on the prospective adoptive parent or parents (including a criminal background check) prepared in accordance with the laws of the receiving country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd63337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a declaration by the central authority (or other competent authority) of such other Convention country—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfd63338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the child will be permitted to enter and reside permanently, or on the same basis as the adopting parent, in the receiving country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfd63339-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the central authority (or other competent authority) of such other Convention country consents to the adoption, if such consent is necessary under the laws of such country for the adoption to become final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd6333a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Furnish to the United States central authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd6333b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" official copies of State court orders certifying the final adoption or grant of custody for the purpose of adoption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd6333c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information and documents described in paragraph (2), to the extent required by the United States central authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd6333d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information concerning the case required by the United States central authority to perform the functions specified in subsection (c) or otherwise to carry out the duties of the United States central authority under the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd6333e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on State court orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An order declaring an adoption to be final or granting custody for the purpose of adoption in a case described in subsection (a) shall not be entered unless the court—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfd6333f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has received and verified to the extent the court may find necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfd63340-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the material described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfd63341-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfactory evidence that the requirements of Articles 4 and 15 through 21 of the Convention have been met; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfd63342-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has determined that the adoptive placement is in the best interests of the child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63343-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In a case described in subsection (a), the Secretary, on receipt and verification as necessary of the material and information described in subsection (a)(3), shall issue, as applicable, an official certification that the child has been adopted or a declaration that custody for purposes of adoption has been granted, in accordance with the Convention and this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfd63344-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14932/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing with registry regarding non-Convention adoptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Accredited agencies, approved persons, and other persons, including governmental authorities, providing adoption services in an intercountry adoption not subject to the Convention that involves the emigration of a child from the United States shall file information required by regulations jointly issued by the Attorney General and the Secretary of State for purposes of implementing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s14912/e"},"text":"section 14912(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfd63345-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279/tIII/s303"},"text":"Pub. L. 106–279, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/839"},"text":"114 Stat. 839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfd63346-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfd63347-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfd63348-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/825"},"text":"114 Stat. 825","children":[],"tail":", known as the Intercountry Adoption Act of 2000, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfd63349-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbfd6334a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective upon entry into force for the United States of the Convention on Protection of Children and Co-operation in Respect of Intercountry Adoption, pursuant to Article 46(2)(a) of the Convention, with transition rule, see section 505(a)(2), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/279"},"text":"Pub. L. 106–279","children":[],"tail":", set out as an Effective Dates; Transition Rule note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14901"},"text":"section 14901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
