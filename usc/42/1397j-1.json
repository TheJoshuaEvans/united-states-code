{"tag":"section","attrib":{"id":"idbaaace86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397j–1"},"text":"§ 1397j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaaace87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In pursuing activities under this division, the Secretary shall ensure the protection of individual health privacy consistent with the regulations promulgated under section 264(c) of the Health Insurance Portability and Accountability Act of 1996 and applicable State and local privacy regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaaace88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this division shall be construed to interfere with or abridge an elder’s right to practice his or her religion through reliance on prayer alone for healing when this choice—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaace89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is contemporaneously expressed, either orally or in writing, with respect to a specific illness or injury which the elder has at the time of the decision by an elder who is competent at the time of the decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is previously set forth in a living will, health care proxy, or other advance directive document that is validly executed and applied under State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaace8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397j–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be unambiguously deduced from the elder’s life history.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3e8c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2012, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/785"},"text":"124 Stat. 785","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaad3e8d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaad3e8e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbaad3e8f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 264(c) of the Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191/s264/c"},"text":"section 264(c) of Pub. L. 104–191","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320d–2"},"text":"section 1320d–2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
