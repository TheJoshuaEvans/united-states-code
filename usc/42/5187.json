{"tag":"section","attrib":{"id":"idbd1df055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5187"},"text":null,"children":[{"tag":"num","attrib":{"value":"5187"},"text":"§ 5187.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire management assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1df056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5187/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to provide assistance, including grants, equipment, supplies, and personnel, to any State or local government for the mitigation, management, and control of any fire on public or private forest land or grassland that threatens such destruction as would constitute a major disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5187/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with State and tribal departments of forestry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this section, the President shall coordinate with State and tribal departments of forestry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5187/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this section, the President may use the authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170b"},"text":"section 5170b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5187/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazard mitigation assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whether or not a major disaster is declared, the President may provide hazard mitigation assistance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c"},"text":"section 5170c of this title","children":[],"tail":" in any area affected by a fire for which assistance was provided under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1df05a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5187/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall prescribe such rules and regulations as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1df05b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIV/s420"},"text":"Pub. L. 93–288, title IV, § 420","children":[],"tail":", formerly § 417, "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/158"},"text":"88 Stat. 158","children":[],"tail":"; renumbered § 420, "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s106/j"},"text":"Pub. L. 100–707, title I, § 106(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4705"},"text":"102 Stat. 4705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tIII/s303/a"},"text":"Pub. L. 106–390, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1572"},"text":"114 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1204/a"},"text":"Pub. L. 115–254, div. D, § 1204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3438"},"text":"132 Stat. 3438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1df05c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1df05d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1df05e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/390"},"text":"Pub. L. 106–390","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “The President is authorized to provide assistance, including grants, equipment, supplies, and personnel, to any State for the suppression of any fire on publicly or privately owned forest or grassland which threatens such destruction as would constitute a major disaster.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1df05f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1df060-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1df061-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/390/tIII/s303/b"},"text":"Pub. L. 106–390, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1573"},"text":"114 Stat. 1573","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/390/tIII/s303/b"},"text":"“The amendment made by subsection (a) [amending this section] takes effect 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd1df062-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reporting Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1204/c"},"text":"Pub. L. 115–254, div. D, § 1204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3439"},"text":"132 Stat. 3439","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dD/s1204/c"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"] and annually thereafter, the Administrator [of the Federal Emergency Management Agency] shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate, the Committee on Transportation and Infrastructure of the House of Representatives, and the Committees on Appropriations of the Senate and the House of Representatives a report containing a summary of any projects carried out, and any funding provided to those projects, under subsection (d) of section 420 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5187"},"text":"42 U.S.C. 5187","children":[],"tail":") (as amended by this section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
