{"tag":"section","attrib":{"id":"idc073aca9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994"},"text":null,"children":[{"tag":"num","attrib":{"value":"18994"},"text":"§ 18994.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STEM workforce data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc073acaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Skilled technical workforce portfolio review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc073acab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall conduct a full portfolio analysis of the Foundation’s skilled technical workforce investments across all Directorates in the areas of education, research, infrastructure, data collection, and analysis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073acac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date of the review under paragraph (1) is complete, the Director shall submit to Congress and make widely available to the public a summary report of the portfolio review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc073acad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc073acae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rotating topic modules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To meet evolving needs for data on the state of the science and engineering workforce, the Director shall assess, through coordination with other Federal statistical agencies and drawing on input from relevant stakeholders, the feasibility and benefits of incorporating questions or topic modules to existing National Center for Science and Engineering Statistics surveys that would vary from cycle to cycle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073acaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Director shall submit to Congress and the Board the results of an assessment, carried out in coordination with other Federal agencies and with input from relevant stakeholders, of the feasibility and benefits of incorporating new questions or topic modules to existing National Center for Science and Engineering Statistics surveys on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073acb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the skilled technical workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073acb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working conditions and work-life balance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073acb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harassment and discrimination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073acb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immigration and emigration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073acb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other topics at the discretion of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073acb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Longitudinal design","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall continue and accelerate efforts to enhance the usefulness of National Center for Science and Engineering Statistics survey data for longitudinal research and analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc073acb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-08-09"},"text":"August 9, 2022","children":[],"tail":", the Comptroller General of the United States shall submit a report to Congress that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc073acb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates Foundation processes for ensuring the data and analysis produced by the National Center for Science and Engineering Statistics meets current and future needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc073acb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18994/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes such recommendations as the Comptroller General determines are appropriate to improve such processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc073acb9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10314"},"text":"Pub. L. 117–167, div. B, title III, § 10314","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1529"},"text":"136 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
