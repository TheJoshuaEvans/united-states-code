{"tag":"section","attrib":{"id":"idb6326493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"300g–6"},"text":"§ 300g–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of lead pipes, solder, and flux","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6326494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6326495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6326496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may use any pipe, any pipe or plumbing fitting or fixture, any solder, or any flux, after ","children":[{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", in the installation or repair of—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb6326497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any public water system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6326498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plumbing in a residential or nonresidential facility providing water for human consumption,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that is not lead free (within the meaning of subsection (d)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6326499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leaded joints","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to leaded joints necessary for the repair of cast iron pipes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb632649a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public notice requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb632649b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each owner or operator of a public water system shall identify and provide notice to persons that may be affected by lead contamination of their drinking water where such contamination results from either or both of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb632649c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The lead content in the construction materials of the public water distribution system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb632649d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corrosivity of the water supply sufficient to cause leaching of lead.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The notice shall be provided in such manner and form as may be reasonably required by the Administrator. Notice under this paragraph shall be provided notwithstanding the absence of a violation of any national drinking water standard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb632649e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notice under this paragraph shall provide a clear and readily understandable explanation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb632649f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential sources of lead in the drinking water,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb63264a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential adverse health effects,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb63264a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably available methods of mitigating known or potential lead content in drinking water,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb63264a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any steps the system is taking to mitigate lead content in drinking water, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb63264a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessity for seeking alternative water supplies, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63264a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective 2 years after ","children":[{"tag":"date","attrib":{"date":"1996-08-06"},"text":"August 6, 1996","children":[],"tail":", it shall be unlawful—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63264a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to introduce into commerce any pipe, or any pipe or plumbing fitting or fixture, that is not lead free, except for a pipe that is used in manufacturing or industrial processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person engaged in the business of selling plumbing supplies, except manufacturers, to sell solder or flux that is not lead free; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any person to introduce into commerce any solder or flux that is not lead free unless the solder or flux bears a prominent label stating that it is illegal to use the solder or flux in the installation or repair of any plumbing providing water for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63264a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibitions in paragraphs (1) and (3) shall not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63264a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pipes, pipe fittings, plumbing fittings, or fixtures, including backflow preventers, that are used exclusively for nonpotable services such as manufacturing, industrial processing, irrigation, outdoor watering, or any other uses where the water is not anticipated to be used for human consumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toilets, bidets, urinals, fill valves, flushometer valves, tub fillers, shower valves, fire hydrants, service saddles, or water distribution main gate valves that are 2 inches in diameter or larger.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63264ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63264ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subsection (a)(1) shall be enforced in all States effective 24 months after ","children":[{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":". States shall enforce such requirements through State or local plumbing codes, or such other means of enforcement as the State may determine to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63264ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of public notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subsection (a)(2) shall apply in all States effective 24 months after ","children":[{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63264ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that a State is not enforcing the requirements of subsection (a) as required pursuant to subsection (b), the Administrator may withhold up to 5 percent of Federal funds available to that State for State program grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–2/a"},"text":"section 300j–2(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63264af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of lead free","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63264b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “lead free” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63264b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not containing more than 0.2 percent lead when used with respect to solder and flux; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than a weighted average of 0.25 percent lead when used with respect to the wetted surfaces of pipes, pipe fittings, plumbing fittings, and fixtures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63264b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The weighted average lead content of a pipe, pipe fitting, plumbing fitting, or fixture shall be calculated by using the following formula: For each wetted component, the percentage of lead in the component shall be multiplied by the ratio of the wetted surface area of that component to the total wetted surface area of the entire product to arrive at the weighted percentage of lead of the component. The weighted percentage of lead of each wetted component shall be added together, and the sum of these weighted percentages shall constitute the weighted average lead content of the product. The lead content of the material used to produce wetted components shall be used to determine compliance with paragraph (1)(B). For lead content of materials that are provided as a range, the maximum content of the range shall be used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63264b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plumbing fittings and fixtures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63264b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide accurate and timely technical information and assistance to qualified third-party certifiers in the development of voluntary standards and testing protocols for the leaching of lead from new plumbing fittings and fixtures that are intended by the manufacturer to dispense water for human ingestion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63264b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63264b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a voluntary standard for the leaching of lead is not established by the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"1996-08-06"},"text":"August 6, 1996","children":[],"tail":", the Administrator shall, not later than 2 years after "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"August 6, 1996","children":[],"tail":", promulgate regulations setting a health-effects-based performance standard establishing maximum leaching levels from new plumbing fittings and fixtures that are intended by the manufacturer to dispense water for human ingestion. The standard shall become effective on the date that is 5 years after the date of promulgation of the standard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If regulations are required to be promulgated under subparagraph (A) and have not been promulgated by the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"1996-08-06"},"text":"August 6, 1996","children":[],"tail":", no person may import, manufacture, process, or distribute in commerce a new plumbing fitting or fixture, intended by the manufacturer to dispense water for human ingestion, that contains more than 4 percent lead by dry weight."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb63264b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public education","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb63264ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall make information available to the public regarding lead in drinking water, including information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb63264bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risks associated with lead in drinking water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions that contribute to drinking water containing lead in a residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps that States, public water systems, and consumers can take to reduce the risks of lead in drinking water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb63264be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of additional resources that consumers can use to minimize lead exposure, including information on sampling for lead in drinking water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb63264bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300g–6/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vulnerable populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making information available to the public under this subsection, the Administrator shall, subject to the availability of appropriations, carry out targeted outreach strategies that focus on educating groups within the general population that may be at greater risk than the general population of adverse health effects from exposure to lead in drinking water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb63264c0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1417, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/339/tI/s109/a"},"text":"Pub. L. 99–339, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/651"},"text":"100 Stat. 651","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/182/tI/s118"},"text":"Pub. L. 104–182, title I, § 118","children":[],"tail":", title V, § 501(f)(1), "},{"tag":"date","attrib":{"date":"1996-08-06"},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1645"},"text":"110 Stat. 1645","children":[],"tail":", 1691; "},{"tag":"ref","attrib":{"href":"/us/pl/111/380/s2/a"},"text":"Pub. L. 111–380, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4131"},"text":"124 Stat. 4131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/64/s2"},"text":"Pub. L. 113–64, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/668"},"text":"127 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/322/tII/s2106/b"},"text":"Pub. L. 114–322, title II, § 2106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1726"},"text":"130 Stat. 1726","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb63264c1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb63264c2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb63264c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322"},"text":"Pub. L. 114–322","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/64"},"text":"Pub. L. 113–64","children":[],"tail":" inserted “fire hydrants,” after “shower valves,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/380/s2/a/1"},"text":"Pub. L. 111–380, § 2(a)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/380/s2/a/2"},"text":"Pub. L. 111–380, § 2(a)(2)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) defined “lead free” when used with respect to solders and flux, pipes and pipe fittings, and plumbing fittings and fixtures."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/s501/f/1"},"text":"Pub. L. 104–182, § 501(f)(1)","children":[],"tail":", made technical amendment to section catchline and subsec. (a) designation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/s118/1"},"text":"Pub. L. 104–182, § 118(1)","children":[],"tail":", substituted “Prohibitions” for “Prohibition” in heading and amended text generally. Prior to amendment, text read as follows: “Any pipe, solder, or flux, which is used after "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", in the installation or repair of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) any public water system, or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) any plumbing in a residential or nonresidential facility providing water for human consumption which is connected to a public water system,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"shall be lead free (within the meaning of subsection (d) of this section). This paragraph shall not apply to leaded joints necessary for the repair of cast iron pipes.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/s118/2"},"text":"Pub. L. 104–182, § 118(2)","children":[],"tail":", inserted “owner or operator of a” after “Each” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/s118/3"},"text":"Pub. L. 104–182, § 118(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/s118/4"},"text":"Pub. L. 104–182, § 118(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/182/s118/5"},"text":"Pub. L. 104–182, § 118(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb63264c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb63264c5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/380/s2/b"},"text":"Pub. L. 111–380, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4132"},"text":"124 Stat. 4132","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/380/s2/b"},"text":"“The provisions of subsections (a)(4) and (d) of section 1417 of the Safe Drinking Water Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–6/a/4"},"text":"42 U.S.C. 300g–6(a)(4)","children":[],"tail":", (d)], as added by this section, apply beginning on the day that is 36 months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb63264c6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation of Sources of Lead in Water Distribution Systems and Alternate Routing Systems","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/64/s3"},"text":"Pub. L. 113–64, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-20"},"text":"Dec. 20, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/668"},"text":"127 Stat. 668","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/64/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Administrator of the Environmental Protection Agency shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with and seek the advice of the National Drinking Water Advisory Council on potential changes to the regulations pertaining to lead under the Safe Drinking Water Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300f"},"text":"42 U.S.C. 300f","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the Council to consider sources of lead throughout drinking water distribution systems, including through components used to reroute drinking water during distribution system repairs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb63264c7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification to States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/339/tI/s109/b"},"text":"Pub. L. 99–339, title I, § 109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/652"},"text":"100 Stat. 652","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/339/tI/s109/b"},"text":"“The Administrator of the Environmental Protection Agency shall notify all States with respect to the requirements of section 1417 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300g–6"},"text":"42 U.S.C. 300g–6","children":[],"tail":"] within 90 days after the enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb63264c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Ban on Lead Water Pipes, Solder, and Flux in VA and HUD Insured or Assisted Property","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/339/tI/s109/c"},"text":"Pub. L. 99–339, title I, § 109(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/652"},"text":"100 Stat. 652","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/q/2"},"text":"Pub. L. 102–54, § 13(q)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/279"},"text":"105 Stat. 279","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/54/s13/q/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Housing and Urban Development and the Secretary of Veterans Affairs may not insure or guarantee a mortgage or furnish assistance with respect to newly constructed residential property which contains a potable water system unless such system uses only lead free pipe, solder, and flux.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of lead free","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1) the term ‘lead free’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when used with respect to solders and flux refers to solders and flux containing not more than 0.2 percent lead, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when used with respect to pipes and pipe fittings refers to pipes and pipe fittings containing not more than 8.0 percent lead.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall become effective 24 months after the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-06-19"},"text":"June 19, 1986","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
