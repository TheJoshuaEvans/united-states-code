{"tag":"section","attrib":{"id":"idbfe48b5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832"},"text":null,"children":[{"tag":"num","attrib":{"value":"15832"},"text":"§ 15832.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency public information initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe48b5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a comprehensive national program, including advertising and media awareness, to inform consumers about—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to reduce energy consumption during the 4-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits to consumers of reducing consumption of electricity, natural gas, and petroleum, particularly during peak use periods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importance of low energy costs to economic growth and preserving manufacturing jobs in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" practical, cost-effective measures that consumers can take to reduce consumption of electricity, natural gas, and gasoline, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe48b64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining and repairing heating and cooling ducts and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48b65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weatherizing homes and buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48b66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing energy efficient products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe48b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper tire maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program carried out under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe48b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include collaborative efforts with State and local government officials and the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe48b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate, to the maximum extent practicable, successful State and local public education programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-07-01"},"text":"July 1, 2009","children":[],"tail":", the Secretary shall submit to Congress a report describing the effectiveness of the program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program carried out under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2010-12-31"},"text":"December 31, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe48b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15832/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $90,000,000 for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe48b6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tI/s134"},"text":"Pub. L. 109–58, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/623"},"text":"119 Stat. 623","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
