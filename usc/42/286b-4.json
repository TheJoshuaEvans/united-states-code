{"tag":"section","attrib":{"id":"idb581d96c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"286b–4"},"text":"§ 286b–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for projects in sciences related to health, for research and development in medical library science, and for development of education technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb581d96d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of existing and original writings on health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to physicians and other practitioners in the sciences related to health, to scientists, and to public or nonprofit private institutions on behalf of such physicians, other practitioners, and scientists for the compilation of existing, or the writing of original, contributions relating to scientific, social, or cultural advancements in sciences related to health. In making such grants, the Secretary shall make appropriate arrangements under which the facilities of the Library and the facilities of libraries of public and private nonprofit institutions of higher learning may be made available in connection with the projects for which such grants are made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d96e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical library science and related activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to appropriate public or private nonprofit institutions and enter into contracts with appropriate persons, for purposes of carrying out projects of research, investigations, and demonstrations in the field of medical library science and related activities and for the development of new techniques, systems, and equipment, for processing, storing, retrieving, and distributing information pertaining to sciences related to health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d96f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of education technologies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d970-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make grants to public or nonprofit private institutions for the purpose of carrying out projects of research on, and development and demonstration of, new education technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d971-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes for which a grant under paragraph (1) may be made include projects concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb581d972-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer-assisted teaching and testing of clinical competence at health professions and research institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d973-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective transfer of new information from research laboratories to appropriate clinical applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d974-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of the laboratory and clinical uses of computer-stored research databases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d975-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing of new technologies for training health care professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d976-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not make a grant under paragraph (1) unless the applicant for the grant agrees to make the projects available with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb581d977-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the training of health professions students; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d978-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s286b–4/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing and improving the capabilities of health professionals regarding research and teaching.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb581d979-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 473, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/861"},"text":"99 Stat. 861","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXIV/s1411"},"text":"Pub. L. 103–43, title XIV, § 1411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/171"},"text":"107 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb581d97a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb581d97b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb581d97c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
