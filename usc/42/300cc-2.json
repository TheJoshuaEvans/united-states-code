{"tag":"section","attrib":{"id":"idb6836b67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300cc–2"},"text":"§ 300cc–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements with respect to processing of requests for personnel and administrative support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6836b68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Personnel Management or the Administrator of General Services, as the case may be, shall respond to any priority request made by the Administrator of the Substance Abuse and Mental Health Services Administration, the Director of the Centers for Disease Control and Prevention, the Commissioner of Food and Drugs, or the Director of the National Institutes of Health, not later than 21 days after the date on which such request is made. If the Director of the Office of Personnel Management or the Administrator of General Services, as the case may be, does not disapprove a priority request during the 21-day period, the request shall be deemed to be approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836b69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Secretary and to Assistant Secretary for Health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Substance Abuse and Mental Health Services Administration, the Director of the Centers for Disease Control and Prevention, the Commissioner of Food and Drugs, and the Director of the National Institutes of Health, shall, respectively, transmit to the Secretary and the Assistant Secretary for Health a copy of each priority request made under this section by the agency head involved. The copy shall be transmitted on the date on which the priority request involved is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6836b6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Priority request” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “priority request” means any request that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6836b6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as a priority request by the Administrator of the Substance Abuse and Mental Health Services Administration, the Director of the Centers for Disease Control and Prevention, the Commissioner of Food and Drugs, or the Director of the National Institutes of Health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6836b6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6836b6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made to the Director of the Office of Personnel Management for the allocation of personnel to carry out activities with respect to acquired immune deficiency syndrome; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6836b6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300cc–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made to the Administrator of General Services for administrative support or space in carrying out such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6836b6f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIII, § 2303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/4"},"text":"Pub. L. 100–607, title II, § 201(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3064"},"text":"102 Stat. 3064","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI"},"text":"Pub. L. 102–321, title I","children":[],"tail":", §§ 161, 163(b)(7), "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/375"},"text":"106 Stat. 375","children":[],"tail":", 376; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/17"},"text":"Pub. L. 102–531, title III, § 312(d)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3505"},"text":"106 Stat. 3505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6836b70-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6836b71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6836b72-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300cc–2, act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", § 2303, was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238b"},"text":"section 238b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6836b73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s161"},"text":"Pub. L. 102–321, § 161","children":[],"tail":", substituted “Administrator of the Substance Abuse and Mental Health Services Administration” for “Administrator of the Alcohol, Drug Abuse, and Mental Health Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"},{"tag":"p","at