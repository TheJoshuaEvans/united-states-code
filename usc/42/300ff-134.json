{"tag":"section","attrib":{"id":"idb6a4d66f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–134"},"text":"§ 300ff–134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for notification of exposure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of notification to officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a notification required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–132"},"text":"section 300ff–132 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–133/d/2"},"text":"section 300ff–133(d)(2) of this title","children":[],"tail":", a medical facility shall provide—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the infectious disease involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the victim of the emergency involved was transported by emergency response employees to the medical facility involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–132"},"text":"section 300ff–132 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–133/d/2"},"text":"section 300ff–133(d)(2) of this title","children":[],"tail":" is mailed or otherwise indirectly made—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6a4d674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the medical facility sending the notification shall, upon sending the notification, inform the designated officer to whom the notification is sent of the fact that the notification has been sent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6a4d675-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such designated officer shall, not later than 10 days after being informed by the medical facility that the notification has been sent, inform such medical facility whether the designated officer has received the notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d676-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2695C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s13"},"text":"Pub. L. 111–87, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2901"},"text":"123 Stat. 2901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d677-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d678-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a4d679-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if enacted on ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/3/B"},"text":"section 2(a)(3)(B) of Pub. L. 111–87","children":[],"tail":", set out as an Effective Date of 2009 Amendment; Revival of Section note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
