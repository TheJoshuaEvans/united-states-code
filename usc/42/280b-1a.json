{"tag":"section","attrib":{"id":"idb529a76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"280b–1a"},"text":"§ 280b–1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpersonal violence within families and among acquaintances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb529a76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to activities that are authorized in sections 280b and 280b–0 of this title, the Secretary, acting through the Director of the Centers for Disease Control and Prevention, shall carry out such activities with respect to interpersonal violence within families and among acquaintances. Activities authorized in the preceding sentence include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb529a76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collecting data relating to the incidence of such violence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making grants to public and nonprofit private entities for the evaluation of programs whose purpose is to prevent such violence, including the evaluation of demonstration projects under paragraph (6).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making grants to public and nonprofit private entities for the conduct of research on identifying effective strategies for preventing such violence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing to the public information and education on such violence, including information and education to increase awareness of the public health consequences of such violence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Training health care providers as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb529a771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify individuals whose medical conditions or statements indicate that the individuals are victims of such violence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To routinely determine, in examining patients, whether the medical conditions or statements of the patients so indicate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb529a773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To refer individuals so identified to entities that provide services regarding such violence, including referrals for counseling, housing, legal services, and services of community organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb529a774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making grants to public and nonprofit private entities for demonstration projects with respect to such violence, including with respect to prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb529a775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–1a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this part, the term “interpersonal violence within families and among acquaintances” includes behavior commonly referred to as domestic violence, sexual assault, spousal abuse, woman battering, partner abuse, elder abuse, and acquaintance rape.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb529a776-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 393, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tII/s201/2"},"text":"Pub. L. 103–183, title II, § 201(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2231"},"text":"107 Stat. 2231","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb529a777-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb529a778-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb529a779-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 393 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 394 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280b–2"},"text":"section 280b–2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 393 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was renumbered section 394 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280b–4"},"text":"section 280b–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
