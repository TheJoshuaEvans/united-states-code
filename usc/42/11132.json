{"tag":"section","attrib":{"id":"idbf38e233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132"},"text":null,"children":[{"tag":"num","attrib":{"value":"11132"},"text":"§ 11132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of sanctions taken by Boards of Medical Examiners","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf38e234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf38e235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions subject to reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Board of Medical Examiners—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which revokes or suspends (or otherwise restricts) a physician’s license or censures, reprimands, or places on probation a physician, for reasons relating to the physician’s professional competence or professional conduct, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which a physician’s license is surrendered,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall report, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11134"},"text":"section 11134 of this title","children":[],"tail":", the information described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf38e238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be reported","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information to be reported under paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf38e239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the physician involved,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e23a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the acts or omissions or other reasons (if known) for the revocation, suspension, or surrender of license, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf38e23b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information respecting the circumstances of the action or surrender as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf38e23c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after notice of noncompliance and providing opportunity to correct noncompliance, the Secretary determines that a Board of Medical Examiners has failed to report information in accordance with subsection (a), the Secretary shall designate another qualified entity for the reporting of information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11133"},"text":"section 11133 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf38e23d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIV/s422"},"text":"Pub. L. 99–660, title IV, § 422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3789"},"text":"100 Stat. 3789","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
