{"tag":"section","attrib":{"id":"idb6d9532e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–17"},"text":"§ 300jj–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal health information technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6d9532f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Coordinator shall support the development and routine updating of qualified electronic health record technology (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj"},"text":"section 300jj of this title","children":[],"tail":") consistent with subsections (b) and (c) and make available such qualified electronic health record technology unless the Secretary determines through an assessment that the needs and demands of providers are being substantially and adequately met through the marketplace."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d95330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making such electronic health record technology publicly available, the National Coordinator shall ensure that the qualified electronic health record technology described in subsection (a) is certified under the program developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–11/c/3"},"text":"section 300jj–11(c)(3) of this title","children":[],"tail":" to be in compliance with applicable standards adopted under section 300jj–12(a)(2) "},{"tag":"ref","attrib":{"idref":"fn002519"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002519"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) of section 300jj–12(a) has been enacted."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d95331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–17/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to charge a nominal fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Coordinator may impose a nominal fee for the adoption by a health care provider of the health information technology system developed or approved under subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002520"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002520"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subsections”."}],"tail":" (a) and (b). Such fee shall take into account the financial circumstances of smaller providers, low income providers, and providers located in rural or other medically underserved areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d95332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–17/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require that a private or government entity adopt or use the technology provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d95333-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3007, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13101"},"text":"Pub. L. 111–5, div. A, title XIII, § 13101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/241"},"text":"123 Stat. 241","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIV/s4003/e/2/E"},"text":"Pub. L. 114–255, div. A, title IV, § 4003(e)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1175"},"text":"130 Stat. 1175","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6d95334-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6d95335-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6d95336-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" substituted “300jj–12(a)(2)” for “300jj–13(a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
