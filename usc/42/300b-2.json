{"tag":"section","attrib":{"id":"idb60c4000-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–2"},"text":"§ 300b–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation by individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The participation by any individual in any program or portion thereof under this part shall be wholly voluntary and shall not be a prerequisite to eligibility for or receipt of any other service or assistance from, or to participation in, any other program.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb60c4001-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XI, § 1103, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/278/tIV/s403/a"},"text":"Pub. L. 94–278, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/408"},"text":"90 Stat. 408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60c4002-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60c4003-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb60c4004-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 300b–2, ","children":[{"tag":"ref","attrib":{"hre