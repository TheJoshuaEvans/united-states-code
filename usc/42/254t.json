{"tag":"section","attrib":{"id":"idb4fec75e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t"},"text":null,"children":[{"tag":"num","attrib":{"value":"254t"},"text":"§ 254t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fec75f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a demonstration project to provide for the participation of individuals who are chiropractic doctors or pharmacists in the Loan Repayment Program described in section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual that receives assistance under this section with regard to the program described in section 254","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1 of this title shall comply with all rules and requirements described in such section (other than subparagraphs (A) and (B) of section 254"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–1(b)(1) of this title) in order to receive assistance under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec761-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec762-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration project described in this section shall provide for the participation of individuals who shall provide services in rural and urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec763-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of other health professionals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not assign an individual receiving assistance under this section to provide obligated service at a site unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has assigned a physician (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/r"},"text":"section 1395x(r) of this title","children":[],"tail":") or other health professional licensed to prescribe drugs to provide obligated service at such site under section 254m or 254n of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such physician or other health professional will provide obligated service at such site concurrently with the individual receiving assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision of individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to require or imply that a physician or other health professional licensed to prescribe drugs must supervise an individual receiving assistance under the demonstration project under this section, with respect to such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensure of health professionals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to supersede State law regarding licensure of health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration project described in this section, and any providers who are selected to participate in such project, shall not be considered by the Secretary in the designation of a health professional shortage area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254e"},"text":"section 254e of this title","children":[],"tail":" during fiscal years 2002 through 2004."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be construed to require any State to participate in the project described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall evaluate the participation of individuals in the demonstration projects under this section and prepare and submit a report containing the information described in paragraph (2) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor, and Pensions of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Labor, Health and Human Services, and Education of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Labor, Health and Human Services, and Education of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report described in paragraph (1) shall detail—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fec772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which the demonstration project described in this section has affected access to primary care services, patient satisfaction, quality of care, and health care services provided for traditionally underserved populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the participation of chiropractic doctors and pharmacists in the Loan Repayment Program might affect the designation of health professional shortage areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fec774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether adding chiropractic doctors and pharmacists as permanent members of the National Health Service Corps would be feasible and would enhance the effectiveness of the National Health Service Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fec775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fec776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, such sums as may be necessary for fiscal years 2002 through 2004.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fec777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254t/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2005","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines and certifies to Congress by not later than ","children":[{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", that the number of individuals participating in the demonstration project established under this section is insufficient for purposes of performing the evaluation described in subsection (f)(1), the authorization of appropriations under paragraph (1) shall be extended to include fiscal year 2005."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fec778-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 338L, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIII/s317"},"text":"Pub. L. 107–251, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1653"},"text":"116 Stat. 1653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fec779-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4fec77a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4fec77b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 254t, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s338L"},"text":"act July 1, 1944, ch. 373, title III, § 338L","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/527/s8"},"text":"Pub. L. 101–527, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-06"},"text":"Nov. 6, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2328"},"text":"104 Stat. 2328","children":[],"tail":", related to demonstration grants to States for community scholarship programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/251/tIII/s316"},"text":"Pub. L. 107–251, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-26"},"text":"Oct. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1653"},"text":"116 Stat. 1653","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
