{"tag":"section","attrib":{"id":"idbc534e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030"},"text":null,"children":[{"tag":"num","attrib":{"value":"3030"},"text":"§ 3030.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster relief reimbursements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc534e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc534e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary may provide reimbursements to any State (or to any tribal organization receiving a grant under subchapter X), upon application for such reimbursement, for funds such State makes available to area agencies on aging in such State (or funds used by such tribal organization) for the delivery of supportive services (and related supplies) during any major disaster declared by the President in accordance with the Robert T. Stafford Disaster Relief and Emergency Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc534e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Total payments to all States and such tribal organizations under paragraph (1) in any fiscal year shall not exceed 2 percent of the total amount appropriated and available to carry out subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc534e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Assistant Secretary decides, in the 5-day period beginning on the date such disaster is declared by the President, to provide an amount of reimbursement under paragraph (1) to a State or such tribal organization, then the Assistant Secretary shall provide not less than 75 percent of such amount to such State or such tribal organization not later than 5 days after the date of such decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc534e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Setting aside of funds by Assistant Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc534e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the beginning of each fiscal year the Assistant Secretary shall set aside, for payment to States and such tribal organizations under subsection (a), an amount equal to 2 percent of the total amount appropriated and available to carry out subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc534e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts set aside under paragraph (1) which are not obligated by the end of the third quarter of any fiscal year shall be made available to carry out subchapter IV.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc534e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3030/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to prohibit expenditures by States and such tribal organizations for disaster relief for older individuals in excess of amounts reimbursable under this section, by using funds made available to them under other sections of this chapter or under other provisions of Federal or State law, or from private sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc534e40-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIII/s310"},"text":"Pub. L. 89–73, title III, § 310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tI/s103/b"},"text":"Pub. L. 95–478, title I, § 103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1533"},"text":"92 Stat. 1533","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/115"},"text":"Pub. L. 97–115","children":[],"tail":", §§ 3(d), 11(b)(2), "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1597"},"text":"95 Stat. 1597","children":[],"tail":", 1606; "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s109/q"},"text":"Pub. L. 100–707, title I, § 109(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4709"},"text":"102 Stat. 4709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tI/s102/b/10/A"},"text":"Pub. L. 102–375, title I, § 102(b)(10)(A)","children":[],"tail":", title III, § 309, "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1202"},"text":"106 Stat. 1202","children":[],"tail":", 1235; "},{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":", §§ 2(10), 3(a)(13), "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1989"},"text":"107 Stat. 1989","children":[],"tail":", 1990; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIII/s308"},"text":"Pub. L. 106–501, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2246"},"text":"114 Stat. 2246","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc534e41-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc534e42-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc534e43-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc534e44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s308/1/A"},"text":"Pub. L. 106–501, § 308(1)(A)","children":[],"tail":", inserted “(or to any tribal organization receiving a grant under subchapter X)” after “any State” and “(or funds used by such tribal organization)” before “for the delivery of supportive services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s308/1/B"},"text":"Pub. L. 106–501, § 308(1)(B)","children":[],"tail":", inserted “and such tribal organizations” after “States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s308/1/C"},"text":"Pub. L. 106–501, § 308(1)(C)","children":[],"tail":", inserted “or such tribal organization” after “State” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(1), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s308/2"},"text":"Pub. L. 106–501, § 308(2)","children":[],"tail":", inserted “and such tribal organizations” after “States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/13"},"text":"Pub. L. 103–171, § 3(a)(13)","children":[],"tail":", substituted “Assistant Secretary” for “Commissioner” wherever appearing in subsecs. (a)(1), (3) and (b)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s2/10"},"text":"Pub. L. 103–171, § 2(10)","children":[],"tail":", substituted “Robert T. Stafford Disaster Relief and Emergency Assistance Act” for “Disaster Relief and Emergency Assistance Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375"},"text":"Pub. L. 102–375","children":[],"tail":", §§ 102(b)(10)(A), 309(1)(A), substituted “area agencies on aging” for “area agencies” and inserted “(and related supplies)” after “supportive services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s309/2"},"text":"Pub. L. 102–375, § 309(2)","children":[],"tail":", substituted “2 percent” for “5 percent” and “to carry out subchapter IV” for “for carrying out the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035a"},"text":"section 3035a of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s309/1/B"},"text":"Pub. L. 102–375, § 309(1)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s309/2"},"text":"Pub. L. 102–375, § 309(2)","children":[],"tail":", substituted “2 percent” for “5 percent” and “to carry out subchapter IV” for “for carrying out the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035a"},"text":"section 3035a of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s309/2/B"},"text":"Pub. L. 102–375, § 309(2)(B)","children":[],"tail":", substituted “to carry out subchapter IV” for “for carrying out the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035a"},"text":"section 3035a of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/707"},"text":"Pub. L. 100–707","children":[],"tail":" substituted “Disaster Relief and Emergency Assistance Act” for “Disaster Relief Act of 1974”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s3/d"},"text":"Pub. L. 97–115, § 3(d)","children":[],"tail":", substituted “supportive services” for “social services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(2), (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/115/s11/b/2"},"text":"Pub. L. 97–115, § 11(b)(2)","children":[],"tail":", substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035a"},"text":"section 3035a of this title","children":[],"tail":" for reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3035b"},"text":"section 3035b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc534e45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc534e46-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective at the close of ","children":[{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/s504"},"text":"section 504 of Pub. 