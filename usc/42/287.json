{"tag":"section","attrib":{"id":"idb581d9ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287"},"text":null,"children":[{"tag":"num","attrib":{"value":"287"},"text":"§ 287.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Center for Advancing Translational Sciences","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb581d9cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the National Center for Advancing Translational Sciences (in this subpart referred to as the “Center”) is to advance translational sciences, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d9cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating and developing resources that leverage basic research in support of translational science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing partnerships and working cooperatively to foster synergy in ways that do not create duplication, redundancy, and competition with industry activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clinical trial activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d9cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Center may develop and provide infrastructure and resources for all phases of clinical trials research. Except as provided in paragraph (2), the Center may support clinical trials only through the end of phase IIB.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center may support clinical trial activities through the end of phase III for a treatment for a rare disease or condition (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s360bb"},"text":"section 360bb of title 21","children":[],"tail":") so long as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb581d9d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center gives public notice for a period of at least 120 days of the Center’s intention to support the clinical trial activities in phase III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d9d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no public or private organization provides credible written intent to the Center that the organization has timely plans to further the clinical trial activities or conduct clinical trials of a similar nature beyond phase IIB; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d9d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center ensures that support of the clinical trial activities in phase III will not increase the Federal Government’s liability beyond the award value of the Center’s support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall publish a report on a biennial basis that, with respect to all research supported by the Center, includes a complete list of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb581d9d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the molecules being studied;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical trial activities being conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods and tools in development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ongoing partnerships, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb581d9d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rationale for each partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d9da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of each partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d9db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding provided by the Center to other entities pursuant to each partnership, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb581d9dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities which have been transferred to industry pursuant to each partnership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" known research activity of other entities that is or will expand upon research activity of the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods and tools, if any, that have been developed since the last biennial report was prepared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb581d9df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods and tools, if any, that have been developed and are being utilized by the Food and Drug Administration to support medical product reviews.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first biennial report submitted under this section after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", shall include a complete list of all of the methods and tools, if any, which have been developed by research supported by the Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb581d9e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s287/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as authorizing the Secretary to disclose any information that is a trade secret, or other privileged or confidential information subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb581d9e2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 479, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/864"},"text":"99 Stat. 864","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXV/s1501/2/B"},"text":"Pub. L. 103–43, title XV, § 1501(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/172"},"text":"107 Stat. 172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tII/s221/a/1/C"},"text":"Pub. L. 112–74, div. F, title II, § 221(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1086"},"text":"125 Stat. 1086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII"},"text":"Pub. L. 114–255, div. A, title II","children":[],"tail":", §§ 2037, 2042(e), "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1063"},"text":"130 Stat. 1063","children":[],"tail":", 1073.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb581d9e3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb581d9e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb581d9e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/a/1"},"text":"Pub. L. 114–255, § 2037(a)(1)","children":[],"tail":", substituted “phase IIB” for “phase IIA”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/a/2/A"},"text":"Pub. L. 114–255, § 2037(a)(2)(A)","children":[],"tail":", substituted “phase III” for “phase IIB” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/a/2/B"},"text":"Pub. L. 114–255, § 2037(a)(2)(B)","children":[],"tail":", substituted “phase III” for “phase IIB”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/a/2/C"},"text":"Pub. L. 114–255, § 2037(a)(2)(C)","children":[],"tail":", substituted “phase IIB” for “phase IIA”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/a/2/D"},"text":"Pub. L. 114–255, § 2037(a)(2)(D)","children":[],"tail":", substituted “phase III” for “phase IIB”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2042/e"},"text":"Pub. L. 114–255, § 2042(e)","children":[],"tail":", substituted “Biennial” for “Annual” in heading and “a report on a biennial basis” for “an annual report” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/b/1"},"text":"Pub. L. 114–255, § 2037(b)(1)","children":[],"tail":", added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2037/b/2"},"text":"Pub. L. 114–255, § 2037(b)(2)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The general purpose of the National Center for Research Resources (in this subpart referred to as the ‘Center’) is to strengthen and enhance the research environments of entities engaged in health-related research by developing and supporting essential research resources.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" substituted “the National Center for Research Resources (in this subpart referred to as the ‘Center’)” for “the Division of Research Resources”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb581d9e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb581d9e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Shared Instrumentation Grant Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/505/tIII/s305"},"text":"Pub. L. 106–505, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2335"},"text":"114 Stat. 2335","children":[],"tail":", which was formerly set out as a note under this section, was renumbered section 404L of "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", the Public Health Service Act, by "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tII/s221/b/4/A"},"text":"Pub. L. 112–74, div. F, title II, § 221(b)(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1088"},"text":"125 Stat. 1088","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s283n"},"text":"section 283n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
