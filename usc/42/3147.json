{"tag":"section","attrib":{"id":"idbc74b80c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147"},"text":null,"children":[{"tag":"num","attrib":{"value":"3147"},"text":"§ 3147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for training, research, and technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc74b80d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b80e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants for training, research, and technical assistance, including grants for program evaluation and economic impact analyses, that would be useful in alleviating or preventing conditions of excessive unemployment or underemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b80f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants under paragraph (1) may be used for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b810-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project planning, project predevelopment, and feasibility studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b811-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrations of innovative activities or strategic economic development investments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b812-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management and operational assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b813-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of university centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b814-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishment of business outreach centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b815-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies evaluating the needs of, and development potential for, economic growth of areas that the Secretary determines have substantial need for the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b816-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies that evaluate the effectiveness of coordinating projects funded under this chapter with projects funded under other Acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b817-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessment, marketing, and establishment of business clusters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b818-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other activities determined by the Secretary to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b819-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a project assisted under this section that is national or regional in scope, the Secretary may waive the provision in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3122/6/A/vi"},"text":"section 3122(6)(A)(vi) of this title","children":[],"tail":" requiring a nonprofit organization or association to act in cooperation with officials of a political subdivision of a State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b81a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of provision of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing research and technical assistance under this section, the Secretary, in addition to making grants under subsection (a), may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b81b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide research and technical assistance through officers or employees of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b81c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay funds made available to carry out this section to Federal agencies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b81d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ private individuals, partnerships, businesses, corporations, or appropriate institutions under contracts entered into for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc74b81e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University centers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc74b81f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with subsection (a)(2)(D), the Secretary may make grants to institutions of higher education to serve as university centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b820-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographic coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the network of university centers established under this subsection provides services in each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b821-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, a university center established under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b822-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other university centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b823-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with economic development districts and other relevant Federal economic development technical assistance and service providers to provide expertise and technical assistance to develop, implement, and support comprehensive economic development strategies and other economic development planning at the local, regional, and State levels, with a focus on innovation, entrepreneurship, workforce development, and regional economic development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b824-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, business development, and technology transfer services to businesses in the area served by the university center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b825-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish partnerships with 1 or more commercialization intermediaries that are public or nonprofit technology transfer organizations eligible to receive a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862s–9"},"text":"section 1862s–9 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b826-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote local and regional capacity building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b827-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to communities and regions assistance relating to data collection and analysis and other research relating to economic conditions and vulnerabilities that can inform economic development and adjustment strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc74b828-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this subsection, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc74b829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significant role of regional public universities in supporting economic development in distressed communities through the planning and the implementation of economic development projects and initiatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc74b82a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3147/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the university center in or near a distressed community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc74b82b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s207"},"text":"Pub. L. 89–136, title II, § 207","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3604"},"text":"112 Stat. 3604","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tII/s205"},"text":"Pub. L. 108–373, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1761"},"text":"118 Stat. 1761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII"},"text":"Pub. L. 118–272, div. B, title II","children":[],"tail":", §§ 2211(b), 2217, "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3178"},"text":"138 Stat. 3178","children":[],"tail":", 3181.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc74b82c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc74b82d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc74b82e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2217/1"},"text":"Pub. L. 118–272, § 2217(1)","children":[],"tail":", inserted “, project predevelopment,” after “planning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2211/b"},"text":"Pub. L. 118–272, § 2211(b)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3122/4/A/vi"},"text":"section 3122(4)(A)(vi) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3122/6/A/vi"},"text":"section 3122(6)(A)(vi) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2217/2"},"text":"Pub. L. 118–272, § 2217(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(G) to (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s205/a"},"text":"Pub. L. 108–373, § 205(a)","children":[],"tail":", added subpars. (G) and (H) and redesignated former subpar. (G) as (I)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/373/s205/b"},"text":"Pub. L. 108–373, § 205(b)","children":[],"tail":", added par. (3) and struck out heading and text of former par. (3). Text read as follows: “In the case of a project assisted under this section, the Secretary may reduce or waive the non-Federal share, without regard to section 3144 or 3145 of this title, if the Secretary finds that the project is not feasible without, and merits, such a reduction or waiver.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc74b82f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc74b830-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
