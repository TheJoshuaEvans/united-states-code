{"tag":"section","attrib":{"id":"idbe8d38b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286"},"text":null,"children":[{"tag":"num","attrib":{"value":"8286"},"text":"§ 8286.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consensus on factors and data for energy conservation standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy shall assure that within 6 months after ","children":[{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", the Secretary of Energy, the Secretary of Housing and Urban Development, the Secretary of Agriculture, the Secretary of Health and Human Services, the Secretary of Defense, the Administrator of the General Services Administration, and the head of any other agency responsible for developing energy conservation standards for new or existing residential, commercial, or agricultural buildings shall reach a consensus regarding factors and data used to develop such standards. This consensus shall apply to, but not be limited to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d38b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel price projections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discount rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inflation rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" climatic conditions and zones; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d38b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8286/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost and energy saving characteristics of construction materials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d38b6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tV/s595"},"text":"Pub. L. 96–294, title V, § 595","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/762"},"text":"94 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d38b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d38b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe8d38b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy Security Act, and not as part of the National Energy Conservation Policy Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
