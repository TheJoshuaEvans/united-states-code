{"tag":"section","attrib":{"id":"idb618260b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44"},"text":null,"children":[{"tag":"num","attrib":{"value":"300d–44"},"text":"§ 300d–44.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb618260c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a grant to a trauma center under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a"},"text":"section 300d–41(a) of this title","children":[],"tail":" unless such center submits an application for the grant to the Secretary and the application is in such form, is made in such manner, and contains such agreements, assurances, and information as the Secretary determines to be necessary to carry out this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618260d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on duration of support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period during which a trauma center receives payments under a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/3"},"text":"section 300d–41(a)(3) of this title","children":[],"tail":" shall be for 3 fiscal years, except that the Secretary may waive such requirement for a center and authorize such center to receive such payments for 1 additional fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618260e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–42/a"},"text":"section 300d–42(a) of this title","children":[],"tail":", a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41"},"text":"section 300d–41 of this title","children":[],"tail":" may not be made in an amount exceeding $2,000,000 for each fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb618260f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–42/b/1/B/iii"},"text":"section 300d–42(b)(1)(B)(iii) of this title","children":[],"tail":", acquisition of, or eligibility for, a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a"},"text":"section 300d–41(a) of this title","children":[],"tail":" shall not preclude a trauma center from being eligible for other grants described in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6182610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount appropriated for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–45"},"text":"section 300d–45 of this title","children":[],"tail":", 70 percent shall be used for substantial uncompensated care awards under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/1"},"text":"section 300d–41(a)(1) of this title","children":[],"tail":", 20 percent shall be used for core mission awards under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/2"},"text":"section 300d–41(a)(2) of this title","children":[],"tail":", and 10 percent shall be used for emergency awards under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/3"},"text":"section 300d–41(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6182611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (e), if the amount appropriated for a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–45"},"text":"section 300d–45 of this title","children":[],"tail":" is less than $25,000,000, all available funding for such fiscal year shall be used for substantial uncompensated care awards under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41/a/1"},"text":"section 300d–41(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6182612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial uncompensated care award distribution and proportional share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–42/a"},"text":"section 300d–42(a) of this title","children":[],"tail":", of the amount appropriated for substantial uncompensated care grants for a fiscal year, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6182613-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6182614-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of such funds for category A trauma center grantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6182615-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 35 percent of such funds for category B trauma center grantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6182616-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of such funds for category C trauma center grantees; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6182617-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide available funds within each category in a manner proportional to the award basis specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–42/a/2"},"text":"section 300d–42(a)(2) of this title","children":[],"tail":" to each eligible trauma center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6182618-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300d–44/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and every 2 years thereafter, the Secretary shall biennially report to Congress regarding the status of the grants made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300d–41"},"text":"section 300d–41 of this title","children":[],"tail":" and on the overall financial stability of trauma centers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6182619-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XII, § 1244, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tVI/s601"},"text":"Pub. L. 102–321, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/435"},"text":"106 Stat. 435","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3505/a/4"},"text":"Pub. L. 111–148, title III, § 3505(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/524"},"text":"124 Stat. 524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb618261a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb618261b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb618261c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":" added subsecs. (a) to (h) and struck out former subsecs. (a) to (c) which related to application for grant, limitation on duration of support, and limitation on amount of grant."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb618261d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb618261e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", with programs making awards providing financial assistance in fiscal year 1993 and subsequent years effective for awards made on or after "},{"tag":"date",