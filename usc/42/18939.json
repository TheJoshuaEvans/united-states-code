{"tag":"section","attrib":{"id":"idc0713b1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18939"},"text":null,"children":[{"tag":"num","attrib":{"value":"18939"},"text":"§ 18939.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premise plumbing research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0713b1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18939/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director, shall create a program, in consultation with the Environmental Protection Agency, for premise plumbing research, including to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0713b1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18939/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct metrology research on premise plumbing in relation to water safety, security, efficiency, sustainability, and resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0713b20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18939/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate research activities with academia, the private sector, nonprofit organizations, and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0713b21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18939/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “premise plumbing” means the water distribution system located within the property lines of a property, including all buildings and permanent structures on such property. Such term includes building supply and distribution pipes, fixtures, fittings, water heaters, water-treating and water-using equipment, and all respective joints, connections, devices, and appurtenances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0713b22-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10234"},"text":"Pub. L. 117–167, div. B, title II, § 10234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1485"},"text":"136 Stat. 1485","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
