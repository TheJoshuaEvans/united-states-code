{"tag":"section","attrib":{"id":"idbc5cc3ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3032c"},"text":"§ 3032c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care service demonstration projects in rural areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc5cc400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary, after consultation with the State agency of the State involved, shall make grants to eligible public agencies and nonprofit private organizations to pay part or all of the cost of developing or operating model health care service projects (including related home health care services, adult day health care, mental health services, outreach, and transportation) through multipurpose senior centers that are located in rural areas and that provide nutrition services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3030e"},"text":"section 3030e of this title","children":[],"tail":", to meet the health care needs of medically underserved older individuals residing in such areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under subsection (a), a public agency or nonprofit private organization shall submit to the Assistant Secretary an application containing such information and assurances as the Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc5cc402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information describing the nature and extent of the applicant’s—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience in providing medical services of the type to be provided in the project for which a grant is requested; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordination and cooperation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5cc405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education having graduate programs with capability in public health, mental health, the medical sciences, psychology, pharmacology, nursing, social work, health education, nutrition, or gerontology, for the purpose of designing and developing such project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5cc406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical access hospitals (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/mm/1"},"text":"section 1395x(mm)(1) of this title","children":[],"tail":" and rural health clinics (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa/2"},"text":"section 1395x(aa)(2) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc407-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that the applicant will carry out the project for which a grant is requested, through a multipurpose senior center located—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc5cc408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5cc409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a rural area that has a population of less than 5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5cc40a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a county that has fewer than seven individuals per square mile; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc5cc40b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a State in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc5cc40c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 33⅓ of the population resides in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc5cc40d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 5 percent of the population resides in counties with fewer than seven individuals per square mile,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as defined by and determined in accordance with the most recent data available from the Bureau of the Census; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc5cc40e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the applicant will submit to the Assistant Secretary such evaluations and reports as the Assistant Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc5cc40f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3032c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall prepare and submit to the appropriate committees of Congress a report that includes summaries of the evaluations and reports required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc5cc410-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tIV/s414"},"text":"Pub. L. 89–73, title IV, § 414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tIV/s401"},"text":"Pub. L. 106–501, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2259"},"text":"114 Stat. 2259","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tIV/s404"},"text":"Pub. L. 109–365, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2553"},"text":"120 Stat. 2553","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc5cc411-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc5cc412-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc5cc413-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s404/1"},"text":"Pub. L. 109–365, § 404(1)","children":[],"tail":", inserted “mental health services,” after “adult day health care,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s404/2"},"text":"Pub. L. 109–365, § 404(2)","children":[],"tail":", inserted “mental health,” after “public health,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
