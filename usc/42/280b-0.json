{"tag":"section","attrib":{"id":"idb5275e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0"},"text":null,"children":[{"tag":"num","attrib":{"value":"280b–0"},"text":"§ 280b–0.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention and control activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5275e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, through the Director of the Centers for Disease Control and Prevention, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5275e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist States and political subdivisions of States in activities for the prevention and control of injuries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5275e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage regional activities between States designed to reduce injury rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5275e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary, through the Director of the Centers for Disease Control and Prevention, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5275e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements between the Service and public and private community health agencies which provide for cooperative planning of activities to deal with problems relating to the prevention and control of injuries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5275e40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in cooperation with other Federal agencies, and with public and nonprofit private entities, to promote activities regarding the prevention and control of injuries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5275e41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280b–0/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to States and, after consultation with State health agencies, to other public or nonprofit private entities for the purpose of carrying out demonstration projects for the prevention and control of injuries at sites that are not subject to the Occupational Safety and Health Act of 1970 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"29 U.S.C. 651","children":[],"tail":" et seq.], including homes, elementary and secondary schools, and public buildings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5275e42-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 392, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/649/s3"},"text":"Pub. L. 99–649, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3634"},"text":"100 Stat. 3634","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/558/s2/b"},"text":"Pub. L. 101–558, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2772"},"text":"104 Stat. 2772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII"},"text":"Pub. L. 102–531, title III","children":[],"tail":", §§ 301, 312(d)(4), "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3482"},"text":"106 Stat. 3482","children":[],"tail":", 3504; "},{"tag":"ref","attrib":{"href":"/us/pl/103/183/tII/s203/a/2"},"text":"Pub. L. 103–183, title II, § 203(a)(2)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2232"},"text":"107 Stat. 2232","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5275e43-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5275e44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5275e45-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb529a736-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280b–1"},"text":"section 280b–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb529a737-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 392 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII"},"text":"act July 1, 1944, ch. 373, title III","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1965-10-22"},"text":"Oct. 22, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/89/291/s2"},"text":"Pub. L. 89–291, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1060"},"text":"79 Stat. 1060","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1970-03-13"},"text":"Mar. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/212/s10/b/4"},"text":"Pub. L. 91–212, § 10(b)(4)","children":[],"tail":", (d)(2)(A), "},{"tag":"ref","attrib":{"href":"/us/stat/84/66"},"text":"84 Stat. 66","children":[],"tail":", 67; "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tII/s202/c"},"text":"Pub. L. 93–353, title II, § 202(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/372"},"text":"88 Stat. 372","children":[],"tail":", which related to composition, functions, etc., of the National Medical Libraries Assistance Advisory Board, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280b–2"},"text":"section 280b–2 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/b"},"text":"Pub. L. 99–158, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/879"},"text":"99 Stat. 879","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb529a738-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/s203/a/2/A"},"text":"Pub. L. 103–183, § 203(a)(2)(A)","children":[],"tail":", substituted “Prevention and control activities” for “Control activities” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/s203/a/2/B"},"text":"Pub. L. 103–183, § 203(a)(2)(B)","children":[],"tail":", inserted “and control” after “prevention”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/s203/a/2/C"},"text":"Pub. L. 103–183, § 203(a)(2)(C)","children":[],"tail":", substituted “the prevention and control of injuries” for “injuries and injury control”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/183/s203/b/1"},"text":"Pub. L. 103–183, § 203(b)(1)","children":[],"tail":", substituted “to promote activities regarding the prevention and control of injuries; and” for “to promote injury control. In carrying out the preceding sentence, the Secretary shall disseminate such information to the public, including through elementary and secondary schools; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/s312/d/4"},"text":"Pub. L. 102–531, § 312(d)(4)","children":[],"tail":", substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control” in introductory provisions of subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/s301/1"},"text":"Pub. L. 102–531, § 301(1)","children":[],"tail":", struck out “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/s301/2"},"text":"Pub. L. 102–531, § 301(2)","children":[],"tail":", inserted sentence requiring Secretary to disseminate information on injury control to the public, including through elementary and secondary schools and substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531/s301/3"},"text":"Pub. L. 102–531, § 301(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/558"},"text":"Pub. L. 101–558","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “work in cooperation with Federal, State, and local agencies to promote injury control.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
