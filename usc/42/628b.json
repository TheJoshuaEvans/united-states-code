{"tag":"section","attrib":{"id":"idb79f143e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b"},"text":null,"children":[{"tag":"num","attrib":{"value":"628b"},"text":"§ 628b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National random sample study of child welfare","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79f143f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct (directly, or by grant, contract, or interagency agreement) a national study based on random samples of children who are at risk of child abuse or neglect, or are determined by States to have been abused or neglected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f1440-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study required by subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79f1441-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a longitudinal component; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f1442-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" yield data reliable at the State level for as many States as the Secretary determines is feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f1443-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferred contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study required by subsection (a), the Secretary should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79f1444-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carefully consider selecting the sample from cases of confirmed abuse or neglect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f1445-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" follow each case for several years while obtaining information on, among other things—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79f1446-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of abuse or neglect involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f1447-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of contact with State or local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f1448-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the child involved has been separated from the family, and, if so, under what circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f1449-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, type, and characteristics of out-of-home placements of the child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79f144a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average duration of each placement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f144b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79f144c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From time to time, the Secretary shall prepare reports summarizing the results of the study required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f144d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the public any report prepared under paragraph (1), in writing or in the form of an electronic data tape.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79f144e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to charge fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may charge and collect a fee for the furnishing of reports under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79f144f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s628b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any money in the Treasury of the United States not otherwise appropriated, there are appropriated to the Secretary for each of fiscal years 1996 through 2002 $6,000,000 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79f1450-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IV, § 429, formerly § 429A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tV/s503"},"text":"Pub. L. 104–193, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2277"},"text":"110 Stat. 2277","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tV"},"text":"Pub. L. 105–33, title V","children":[],"tail":", §§ 5591(a), 5592(a)(1)(C), "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/643"},"text":"111 Stat. 643","children":[],"tail":", 644; renumbered § 429, "},{"tag":"ref","attrib":{"href":"/us/pl/109/288/s6/f/3"},"text":"Pub. L. 109–288, § 6(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-28"},"text":"Sept. 28, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1247"},"text":"120 Stat. 1247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79f1451-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79f1452-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb79f1453-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 429 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was renumbered section 426(c) and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s626/c"},"text":"section 626(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb79f1454-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5592/a/1/C"},"text":"Pub. L. 105–33, § 5592(a)(1)(C)","children":[],"tail":", transferred section in original to end of this subpart."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5591/a"},"text":"Pub. L. 105–33, § 5591(a)","children":[],"tail":", inserted “(directly, or by grant, contract, or interagency agreement)” after “conduct”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb79f1455-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb79f1456-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/33"},"text":"Pub. L. 105–33","children":[],"tail":" effective as if included in the enactment of title V of the Personal Responsibility and Work Opportunity Reconciliation Act of 1996, "},{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/s5593"},"text":"section 5593 of Pub. L. 105–33","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s622"},"text":"section 622 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
