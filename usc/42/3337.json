{"tag":"section","attrib":{"id":"idbc7bbd9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3337"},"text":null,"children":[{"tag":"num","attrib":{"value":"3337"},"text":"§ 3337.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations and certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying out his authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3335"},"text":"section 3335 of this title","children":[],"tail":", including the issuance of regulations, the Secretary shall consult with the Department of the Interior; the Department of Health and Human Services; the Department of Commerce; and the Federal Aviation Agency with respect to metropolitan development projects assisted by those departments and agencies; and he shall, for the purpose of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3336"},"text":"section 3336 of this title","children":[],"tail":", accept their respective certifications as to the cost of those projects and the amount of the non-Federal contribution paid or to be paid to that cost."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc7bbd9c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/754/tII/s207"},"text":"Pub. L. 89–754, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-03"},"text":"Nov. 3, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1264"},"text":"80 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/479/tII/s201/f"},"text":"Pub. L. 98–479, title II, § 201(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-17"},"text":"Oct. 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2228"},"text":"98 Stat. 2228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7bbd9d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7bbd9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7bbd9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/479"},"text":"Pub. L. 98–479","children":[],"tail":" substituted “Health and Human Services” for “Health, Education, and Welfare”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7bbda0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbc7bbda1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions, powers, and duties of Federal Aviation Agency and of Administrator and other offices and officers thereof transferred by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":", to Secretary of Transportation, with functions, powers, and duties of Secretary of Transportation pertaining to aviation safety to be exercised by Federal Aviation Administrator in Department of Transportation, see "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
