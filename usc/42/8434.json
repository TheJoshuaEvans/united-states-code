{"tag":"section","attrib":{"id":"idbe96adbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8434"},"text":null,"children":[{"tag":"num","attrib":{"value":"8434"},"text":"§ 8434.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions and other equitable relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever it appears to the Secretary that any person has engaged, is engaged, or is about to engage in acts or practices constituting a violation of this chapter, or any rule or order thereunder, a civil action,","children":[{"tag":"ref","attrib":{"idref":"fn003839"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003839"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" may be brought, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7192/c"},"text":"section 7192(c) of this title","children":[],"tail":", in the appropriate district court of the United States to enjoin such acts or practices, and, upon a proper showing, the court shall grant, without bond, mandatory or prohibitive injunctive relief, including interim equitable relief."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe96adbd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tVII/s724"},"text":"Pub. L. 95–620, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3335"},"text":"92 Stat. 3335","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe96adbe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe96adbf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe96adc0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
