{"tag":"section","attrib":{"id":"idbffc59fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255"},"text":null,"children":[{"tag":"num","attrib":{"value":"16255"},"text":"§ 16255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preprocessing and harvesting demonstration grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffc59fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (referred to in this section as the “Secretary”) shall make grants available on a competitive basis to enterprises owned by agricultural producers, for the purposes of demonstrating cost-effective, cellulosic biomass innovations in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preprocessing of feedstocks, including cleaning, separating and sorting, mixing or blending, and chemical or biochemical treatments, to add value and lower the cost of feedstock processing at a biorefinery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc59fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1-pass or other efficient, multiple crop harvesting techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc59fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc59ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 demonstration projects per fiscal year shall be funded under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc5a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal cost share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal cost share of a project under this section shall be not less than 20 percent, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc5a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant for a project under this section, a recipient of a grant or a participating entity shall agree to use the material harvested under the project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffc5a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce ethanol; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffc5a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for another energy purpose, such as the generation of heat or electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffc5a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16255/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2006 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffc5a05-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s946"},"text":"Pub. L. 109–58, title IX, § 946","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/883"},"text":"119 Stat. 883","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
