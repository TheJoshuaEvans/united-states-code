{"tag":"section","attrib":{"id":"idb6ba5a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–93"},"text":"§ 300gg–93.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health insurance consumer information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ba5a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to States to enable such States (or the Exchanges operating in such States) to establish, expand, or provide support for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offices of health insurance consumer assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health insurance ombudsman programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant, a State shall designate an independent office of health insurance consumer assistance, or an ombudsman, that, directly or in coordination with State health insurance regulators and consumer assistance organizations, receives and responds to inquiries and complaints concerning health insurance coverage with respect to Federal health insurance requirements and under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this section shall comply with criteria established by the Secretary for carrying out activities under such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The office of health insurance consumer assistance or health insurance ombudsman shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with the filing of complaints and appeals, including filing appeals with the internal appeal or grievance process of the group health plan or health insurance issuer involved and providing information about the external appeal process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, track, and quantify problems and inquiries encountered by consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate consumers on their rights and responsibilities with respect to group health plans and health insurance coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist consumers with enrollment in a group health plan or health insurance coverage by providing information, referral, and assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolve problems with obtaining premium tax credits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s36B"},"text":"section 36B of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a grant under subsection (a), an office of health insurance consumer assistance or ombudsman program shall be required to collect and report data to the Secretary on the types of problems and inquiries encountered by consumers. The Secretary shall utilize such data to identify areas where more enforcement action is necessary and shall share such information with State insurance regulators, the Secretary of Labor, and the Secretary of the Treasury for use in the enforcement activities of such agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ba5a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ba5a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby appropriated to the Secretary, out of any funds in the Treasury not otherwise appropriated, $30,000,000 for the first fiscal year for which this section applies to carry out this section. Such amount shall remain available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ba5a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–93/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for subsequent years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary for each fiscal year following the fiscal year described in paragraph (1), such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ba5a12-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2793, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1002"},"text":"Pub. L. 111–148, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/138"},"text":"124 Stat. 138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ba5a13-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6ba5a14-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6ba5a15-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective for fiscal years beginning with fiscal year 2010, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004/a"},"text":"section 1004(a) of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1004/b"},"text":"section 1004(b) of Pub. L. 111–148","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–11"},"text":"section 300gg–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
