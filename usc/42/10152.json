{"tag":"section","attrib":{"id":"idbf12bbae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10152"},"text":null,"children":[{"tag":"num","attrib":{"value":"10152"},"text":"§ 10152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available capacity for interim storage of spent nuclear fuel","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, the Commission, and other authorized Federal officials shall each take such actions as such official considers necessary to encourage and expedite the effective use of available storage, and necessary additional storage, at the site of each civilian nuclear power reactor consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf12bbaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10152/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of the public health and safety, and the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf12bbb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10152/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic considerations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf12bbb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10152/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued operation of such reactor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf12bbb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10152/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable provisions of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf12bbb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10152/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of the population surrounding such reactor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf12bbb4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/425/tI/s132"},"text":"Pub. L. 97–425, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-07"},"text":"Jan. 7, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2230"},"text":"96 Stat. 2230","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
