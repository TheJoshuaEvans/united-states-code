{"tag":"section","attrib":{"id":"idbffa0e96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16212"},"text":null,"children":[{"tag":"num","attrib":{"value":"16212"},"text":"§ 16212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High power density industry program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0e97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a comprehensive research, development, demonstration, and commercial application to improve the energy efficiency of high power density facilities, including data centers, server farms, and telecommunications facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0e98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall consider technologies that provide significant improvement in thermal controls, metering, load management, peak load reduction, or the efficient cooling of electronics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0e99-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s922"},"text":"Pub. L. 109–58, title IX, § 922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/864"},"text":"119 Stat. 864","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
