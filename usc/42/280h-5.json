{"tag":"section","attrib":{"id":"idb543e65a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"280h–5"},"text":"§ 280h–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School-based health centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543e65b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; establishment of criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e65c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive primary health services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “comprehensive primary health services” means the core services offered by school-based health centers, which shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e65d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physical","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Comprehensive health assessments, diagnosis, and treatment of minor, acute, and chronic medical conditions, and referrals to, and follow-up for, specialty care and oral and vision health services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e65e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Mental health and substance use disorder assessments, crisis intervention, counseling, treatment, and referral to a continuum of services including emergency psychiatric care, community support programs, inpatient care, and outpatient programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e65f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medically underserved children and adolescents","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e660-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “medically underserved children and adolescents” means a population of children and adolescents who are residents of an area designated as a medically underserved area or a health professional shortage area by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e661-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe criteria for determining the specific shortages of personal health services for medically underserved children and adolescents under subparagraph (A) that shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb543e662-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account any comments received by the Secretary from the chief executive officer of a State and local officials in a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e663-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include factors indicative of the health status of such children and adolescents of an area, including the ability of the residents of such area to pay for health services, the accessibility of such services, the availability of health professionals to such children and adolescents, and other factors as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e664-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School-based health center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “school-based health center” means a health clinic that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the definition of a school-based health center under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397jj/c/9/A"},"text":"section 1397jj(c)(9)(A) of this title","children":[],"tail":" and is administered by a sponsoring facility (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397jj/c/9/B"},"text":"section 1397jj(c)(9)(B) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides, at a minimum, comprehensive primary health services during school hours to children and adolescents by health professionals in accordance with established standards, community practice, reporting laws, and other State laws, including parental consent and notification laws that are not inconsistent with Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not perform abortion services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e668-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to award grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants for the costs of the operation of school-based health centers (referred to in this section as “SBHCs”) that meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e669-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e66a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an SBHC (as defined in subsection (a)(3)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e66b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e66c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence that the applicant meets all criteria necessary to be designated an SBHC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e66d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence of local need for the services to be provided by the SBHC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e66e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb543e66f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" SBHC services will be provided to those children and adolescents for whom parental or guardian consent has been obtained in cooperation with Federal, State, and local laws governing health care service provision to children and adolescents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e670-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SBHC has made and will continue to make every reasonable effort to establish and maintain collaborative relationships with other health care providers in the catchment area of the SBHC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e671-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SBHC will provide on-site access during the academic day when school is in session and 24-hour coverage through an on-call system and through its backup health providers to ensure access to services on a year-round basis when the school or the SBHC is closed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e672-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SBHC will be integrated into the school environment and will coordinate health services with school personnel, such as administrators, teachers, nurses, counselors, and support personnel, as well as with other community providers co-located at the school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e673-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SBHC sponsoring facility assumes all responsibility for the SBHC administration, operations, and oversight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e674-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the SBHC will comply with Federal, State, and local laws concerning patient privacy and student records, including regulations promulgated under the Health Insurance Portability and Accountability Act of 1996 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1232g"},"text":"section 1232g of title 20","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e675-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e676-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences and consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In reviewing applications:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e677-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may give preference to applicants who demonstrate an ability to serve the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e678-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communities that have evidenced barriers to primary health care and mental health and substance use disorder prevention services for children and adolescents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e679-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communities with high per capita numbers of children and adolescents who are uninsured, underinsured, or enrolled in public health insurance programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e67a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Populations of children and adolescents that have historically demonstrated difficulty in accessing health and mental health and substance use disorder prevention services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e67b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may give consideration to whether an applicant has received a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280h–4"},"text":"section 280h–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e67c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e67d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under appropriate circumstances, waive the application of all or part of the requirements of this subsection with respect to an SBHC for not to exceed 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e67e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon a showing of good cause, waive the requirement that the SBHC provide all required comprehensive primary health services for a designated period of time to be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e67f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e680-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded under a grant under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e681-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be used for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb543e682-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring and leasing equipment (including the costs of amortizing the principle of, and paying interest on, loans for such equipment);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e683-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training related to the provision of required comprehensive primary health services and additional health services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e684-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and operation of health center programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543e685-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of salaries for physicians, nurses, and other personnel of the SBHC; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e686-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used to provide abortions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e687-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants which may be used to pay the costs associated with expanding and modernizing existing buildings for use as an SBHC, including the purchase of trailers or manufactured buildings to install on the school property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e688-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543e689-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any provider of services that is determined by a State to be in violation of a State law described in subsection (a)(3)(B) with respect to activities carried out at a ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" SBHC shall not be eligible to receive additional funding under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543e68a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No overlapping grant period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No entity that has received funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":" for a grant period shall be eligible for a grant under this section for with respect to "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the same grant period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e68b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543e68c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible entity that receives a grant under this section shall provide, from non-Federal sources, an amount equal to 20 percent of the amount of the grant (which may be provided in cash or in-kind) to carry out the activities supported by the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543e68d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive all or part of the matching requirement described in paragraph (1) for any fiscal year for the SBHC if the Secretary determines that applying the matching requirement to the SBHC would result in serious hardship or an inability to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e68e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement, not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds provided under this section shall be used to supplement, not supplant, other Federal or State funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e68f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement a plan for evaluating SBHCs and monitoring quality performance under the awards made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e690-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Age appropriate services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving funds under this section shall only provide age appropriate services through a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" SBHC funded under this section to an individual."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e691-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental consent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity receiving funds under this section shall not provide services through a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" SBHC funded under this section to an individual without the consent of the parent or guardian of such individual if such individual is considered a minor under applicable State law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e692-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical assistance by grants or contracts awarded to private, nonprofit entities with demonstrated expertise related to school-based health centers. Such technical assistance, taking into account local and regional differences among school based ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" health centers, shall support such entities in providing services described in subsection (a)(1) pursuant to this section, including mental health and substance use disorder services, and may include technical assistance relating to program operations and support for the implementation of evidence-based or evidence-informed best practices related to the provision of high quality health care services to children and adolescents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543e693-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280h–5/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543e694-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 399Z–1, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIV/s4101/b"},"text":"Pub. L. 111–148, title IV, § 4101(b)","children":[],"tail":", title X, § 10402(a), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/547"},"text":"124 Stat. 547","children":[],"tail":", 975; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dBB/tIII/s317"},"text":"Pub. L. 116–260, div. BB, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2932"},"text":"134 Stat. 2932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1401"},"text":"Pub. L. 117–328, div. FF, title I, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5699"},"text":"136 Stat. 5699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5465795-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5465796-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5465797-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (c)(2)(C)(vi), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1936"},"text":"110 Stat. 1936","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5465798-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m). "},{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and redesignated former subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") as (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “2022 through 2026” for “2010 through 2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10402/a"},"text":"Pub. L. 111–148, § 10402(a)","children":[],"tail":", inserted “and vision” after “oral”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
