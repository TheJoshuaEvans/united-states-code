{"tag":"section","attrib":{"id":"idbc66611f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3057c"},"text":"§ 3057c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc666120-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tribal organization of an Indian tribe is eligible for assistance under this part only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc666121-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tribal organization represents at least 50 individuals who are 60 years of age or older; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc666122-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tribal organization demonstrates the ability to deliver supportive services, including nutritional services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666123-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An Indian tribe represented by an organization specified in subsection (a) shall be eligible for only one grant under this part for any fiscal year. Nothing in this subsection shall preclude an Indian tribe represented by an organization specified in subsection (a) from receiving a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3057k–11"},"text":"section 3057k–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc666124-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3057c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Indian tribe” and “tribal organization” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this part the terms “Indian tribe” and “tribal organization” have the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc666125-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVI/s612"},"text":"Pub. L. 89–73, title VI, § 612","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tI/s171"},"text":"Pub. L. 100–175, title I, § 171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/959"},"text":"101 Stat. 959","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVI/s601"},"text":"Pub. L. 106–501, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2287"},"text":"114 Stat. 2287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","