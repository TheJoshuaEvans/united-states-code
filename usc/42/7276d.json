{"tag":"section","attrib":{"id":"idbe0088b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7276d"},"text":null,"children":[{"tag":"num","attrib":{"value":"7276d"},"text":"§ 7276d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property protection program for power marketing administrations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrators of the Western Area Power Administration, the Southwestern Power Administration, and the Southeastern Power Administration may each carry out programs to reduce vandalism, theft, and destruction of property that is under their jurisdiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0088b9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/78/s1"},"text":"Pub. L. 107–78, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/808"},"text":"115 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0088ba-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0088bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe0088bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Department of Energy Organization Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
