{"tag":"section","attrib":{"id":"idbfee2879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973"},"text":null,"children":[{"tag":"num","attrib":{"value":"15973"},"text":"§ 15973.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western integrated coal gasification demonstration project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfee287a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall carry out a project to demonstrate production of energy from coal mined in the western United States using integrated gasification combined cycle technology (referred to in this section as the “demonstration project”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee287b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The demonstration project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfee287c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include repowering of existing facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee287d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be designed to demonstrate the ability to use coal with an energy content of not more than 9,000 Btu/lb.; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfee287e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be capable of removing and sequestering carbon dioxide emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee287f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All types of western coals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the foregoing, and to the extent economically feasible, the demonstration project shall also be designed to demonstrate the ability to use a variety of types of coal (including subbituminous and bituminous coal with an energy content of up to 13,000 Btu/lb.) mined in the western United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The demonstration project shall be located in a western State at an altitude of greater than 4,000 feet above sea level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of the demonstration project shall be determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16352"},"text":"section 16352 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfee2882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15973/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subchapter XIII, the demonstration project shall not be eligible for Federal loan guarantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfee2883-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIV/s413"},"text":"Pub. L. 109–58, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/755"},"text":"119 Stat. 755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfee2884-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfee2885-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfee2886-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter XIII, referred to in subsec. (f), was in the original “title XIV”, meaning title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1061"},"text":"119 Stat. 1061","children":[],"tail":", which enacted subchapter XIII of this chapter and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13557"},"text":"section 13557 of this title","children":[],"tail":". For complete classification of title XIV to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
