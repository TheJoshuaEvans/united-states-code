{"tag":"section","attrib":{"id":"idb556f8a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a"},"text":null,"children":[{"tag":"num","attrib":{"value":"282a"},"text":"§ 282a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556f8a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556f8a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" This subchapter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of carrying out this subchapter, there are authorized to be appropriated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556f8a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,331,309,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $32,831,309,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $34,851,000,000 for fiscal year 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $35,585,871,000 for fiscal year 2019; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $36,472,442,775 for fiscal year 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556f8af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for pediatric research initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7/B/ii"},"text":"section 282(b)(7)(B)(ii) of this title","children":[],"tail":", there is authorized to be appropriated to the Division of Program Coordination, Planning, and Strategic Initiatives, out of the Pediatric Research Initiative Fund described in "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9008"},"text":"section 9008 of title 26","children":[],"tail":", and in addition to amounts otherwise made available under paragraph (1) of this subsection, $12,600,000 for each of fiscal years 2024 through 2028."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f8b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated under subsection (a) for a fiscal year, there are authorized to be appropriated for programs and activities under this subchapter carried out through the Office of the Director of NIH such sums as may be necessary for each of the fiscal years 2007 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f8b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trans-NIH research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556f8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556f8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of allocations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7/B/i"},"text":"section 282(b)(7)(B)(i) of this title","children":[],"tail":" (relating to research identified by the Division of Program Coordination, Planning, and Strategic Initiatives), there is established an account to be known as the Common Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb556f8b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount appropriated under subsection (a)(1) for fiscal year 2007 or any subsequent fiscal year, the Director of NIH shall reserve an amount for the Common Fund, subject to any applicable provisions in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb556f8b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, the percentage constituted by the amount reserved under clause (i) relative to the total amount appropriated under subsection (a)(1) for such year may not be less than the percentage constituted by the amount so reserved for the preceding fiscal year relative to the total amount appropriated under subsection (a)(1) for such preceding fiscal year, subject to any applicable provisions in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common Fund strategic planning report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the National Institutes of Health Strategic Plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/m"},"text":"section 282(m) of this title","children":[],"tail":", the Secretary, acting through the Director of NIH, shall submit a report to the Congress containing a strategic plan for funding research described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7/A/i"},"text":"section 282(b)(7)(A)(i) of this title","children":[],"tail":" (including personnel needs) through the Common Fund. Each such plan shall include the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"idb556f8b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the amounts determined by the Director of NIH to be appropriate for maximizing the potential of such research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb556f8b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the amounts determined by the Director of NIH to be sufficient only for continuing to fund research activities previously identified by the Division of Program Coordination, Planning, and Strategic Initiatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb556f8ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An estimate of the amounts determined by the Director of NIH to be necessary to fund research described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7/A/i"},"text":"section 282(b)(7)(A)(i) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb556f8bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is in addition to the research activities described in clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb556f8bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which there is the most substantial need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 6-month period following the end of the first fiscal year for which the total amount reserved under subparagraph (B) is equal to 5 percent of the total amount appropriated under subsection (a)(1) for such fiscal year, the Secretary, acting through the Director of NIH, in consultation with the advisory council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/k"},"text":"section 282(k) of this title","children":[],"tail":", shall submit recommendations to the Congress for changes regarding amounts for the Common Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556f8be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trans-NIH research reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556f8bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the total amount appropriated under subsection (a) for fiscal year 2008 or any subsequent fiscal year, if the head of a national research institute or national center fails to submit the report required by subparagraph (B) for the preceding fiscal year, the amount made available for the institute or center for the fiscal year involved may not exceed the amount made available for the institute or center for fiscal year 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", the head of each national research institute or national center shall submit to the Director of the National Institutes of Health a report, to be included in the triennial report under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s283"},"text":"section 283 of this title","children":[],"tail":", on the amount made available by the institute or center for conducting or supporting research that involves collaboration between the institute or center and 1 or more other national research institutes or national centers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining the amount or percentage of funds to be reported under subparagraph (B), any amounts made available to an institute or center under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7/B/i"},"text":"section 282(b)(7)(B)(i) of this title","children":[],"tail":" shall be included."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of each report submitted under subparagraph (B), the Director of NIH shall review and, in cases of discrepancy, verify the accuracy of the amounts specified in the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556f8c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of any national research institute or national center, the Director of NIH may waive the application of this paragraph to such institute or center if the Director finds that the conduct or support of research described in subparagraph (B) is inconsistent with the mission of such institute or center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f8c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the total amount appropriated under subsection (a)(1) for a fiscal year, the Director of NIH may (in addition to the reservation under subsection (c)(1) for such year) transfer not more than 1 percent for programs or activities that are authorized in this subchapter and identified by the Director to receive funds pursuant to this subsection. In making such transfers, the Director may not decrease any appropriation account under subsection (a)(1) by more than 1 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556f8c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s282a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may not be construed as affecting the authorities of the Director of NIH under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb556f8c6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 402A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/a"},"text":"Pub. L. 109–482, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3685"},"text":"120 Stat. 3685","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/94/s3/b"},"text":"Pub. L. 113–94, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-04-03"},"text":"Apr. 3, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1087"},"text":"128 Stat. 1087","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII"},"text":"Pub. L. 114–255, div. A, title II","children":[],"tail":", §§ 2001, 2031(b), 2042(a), "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1047"},"text":"130 Stat. 1047","children":[],"tail":", 1056, 1073; "},{"tag":"ref","attrib":{"href":"/us/pl/118/228/s2/1"},"text":"Pub. L. 118–228, § 2(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2822"},"text":"138 Stat. 2822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb556f8c7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb556f8c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb556f8c9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/228/s2/1"},"text":"Pub. L. 118–228, § 2(1)","children":[],"tail":", struck out “10-year” before “pediatric” and “through Common Fund” after “initiative” in heading, and in text substituted “to the Division of Program Coordination, Planning, and Strategic Initiatives” for “to the Common Fund” and “2024 through 2028” for “2014 through 2023”, and struck out “10-Year” before “Pediatric Research Initiative Fund” and “and reserved under subsection (c)(1)(B)(i) of this section” after “paragraph (1) of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A), (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/228/s2/2"},"text":"Pub. L. 118–228, § 2(2)","children":[],"tail":", substituted “section 282(b)(7)(B)(i)” for “section 282(b)(7)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2001"},"text":"Pub. L. 114–255, § 2001","children":[],"tail":", added subpars. (D) to (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2031/b"},"text":"Pub. L. 114–255, § 2031(b)","children":[],"tail":", substituted “As part of the National Institutes of Health Strategic Plan required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/m"},"text":"section 282(m) of this title","children":[],"tail":",” for “Not later than "},{"tag":"date","attrib":{"date":"2007-06-01"},"text":"June 1, 2007","children":[],"tail":", and every 2 years thereafter,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2042/a/1"},"text":"Pub. L. 114–255, § 2042(a)(1)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, text read as follows: “Not later than "},{"tag":"date","attrib":{"date":"2008-01-01"},"text":"January 1, 2008","children":[],"tail":", and each January 1st thereafter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the head of each national research institute or national center shall submit to the Director of NIH a report on the amount made available by the institute or center for conducting or supporting research that involves collaboration between the institute or center and 1 or more other national research institutes or national centers; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the Secretary shall submit a report to the Congress identifying the percentage of funds made available by each national research institute and national center with respect to such fiscal year for conducting or supporting research described in clause (i).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2042/a/2"},"text":"Pub. L. 114–255, § 2042(a)(2)","children":[],"tail":", substituted “(B)” for “(B)(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/94/s3/b/1/B"},"text":"Pub. L. 113–94, § 3(b)(1)(B)","children":[],"tail":", which directed amendment of subsec. (a) by striking “For purposes of carrying out this subchapter” and inserting par. (1) designation, heading, and “For purposes of carrying out this subchapter”, was executed by striking “For the purpose of carrying out this subchapter” and making the insertions as directed, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/94/s3/b/1/A"},"text":"Pub. L. 113–94, § 3(b)(1)(A)","children":[],"tail":", redesignated pars. (1) to (3) as subpars. (A) to (C), respectively, and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/94/s3/b/1/C"},"text":"Pub. L. 113–94, § 3(b)(1)(C)","children":[],"tail":", added par. (2). Former par. (2) redesignated subpar. (B) of par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(1)(B), (D), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/94/s3/b/2"},"text":"Pub. L. 113–94, § 3(b)(2)","children":[],"tail":", substituted “subsection (a)(1)” for “subsection (a)” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb556f8ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb556f8cb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as an Effective Date of 2007 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb556f8cc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Supplement, Not Supplant; Prohibition Against Transfer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/94/s3/c"},"text":"Pub. L. 113–94, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-04-03"},"text":"Apr. 3, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1087"},"text":"128 Stat. 1087","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/94/s3/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Funds appropriated pursuant to section 402A(a)(2) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282a/a/2"},"text":"42 U.S.C. 282a(a)(2)","children":[],"tail":"], as added by subsection (b)—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used to supplement, not supplant, the funds otherwise allocated by the National Institutes of Health for pediatric research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any transfer authority in any appropriation Act, shall not be used for any purpose other than allocating funds for making grants as described in section 402(b)(7)(B)(ii) of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/7/B/ii"},"text":"42 U.S.C. 282(b)(7)(B)(ii)","children":[],"tail":"], as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
