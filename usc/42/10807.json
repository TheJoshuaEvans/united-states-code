{"tag":"section","attrib":{"id":"idbf31b537-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10807"},"text":null,"children":[{"tag":"num","attrib":{"value":"10807"},"text":"§ 10807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf31b538-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to instituting any legal action in a Federal or State court on behalf of a ","children":[{"tag":"ref","attrib":{"idref":"fn003977"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003977"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" individual with mental illness, an eligible system, or a State agency or nonprofit organization which entered into a contract with an eligible system under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s10804/a"},"text":"section 10804(a) of this title","children":[],"tail":", shall exhaust in a timely manner all administrative remedies where appropriate. If, in pursuing administrative remedies, the system, agency, or organization determines that any matter with respect to such individual will not be resolved within a reasonable time, the system, agency, or organization may pursue alternative remedies, including the initiation of a legal action."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b539-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) does not apply to any legal action instituted to prevent or eliminate imminent serious harm to a ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" individual with mental illness."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf31b53a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s107"},"text":"Pub. L. 99–319, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/482"},"text":"100 Stat. 482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/1"},"text":"Pub. L. 102–173, § 10(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1219"},"text":"105 Stat. 1219","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf31b53b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf31b53c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf31b53d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":" substituted “individual with mental illness” for “mentally ill individual” in subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
