{"tag":"section","attrib":{"id":"idbafe4590-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437m"},"text":"§ 1437m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of non-Federal share","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any of the following may be used as the non-Federal share required in connection with activities undertaken under Federal grant-in-aid programs which provide social, educational, employment, and other services to the tenants in a project assisted under this chapter, other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":";"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbafe4591-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual contributions under this chapter for operation of the project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbafe4592-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rental or use-value of buildings or facilities paid for, in whole or in part, from development, modernization, or operation cost financed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbafe4593-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title I, § 15, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tII/s212"},"text":"Pub. L. 96–399, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08