{"tag":"section","attrib":{"id":"idb85b86aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320c–10"},"text":"§ 1320c–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Congress not later than April 1 of each year, a full and complete report on the administration, impact, and cost of the program under this part during the preceding fiscal year, including data and information on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85b86ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, status, and service areas of all quality improvement organizations participating in the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of health care institutions and practitioners whose services are subject to review by such organizations, and the number of beneficiaries and recipients who received services subject to such review during such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the various methods of reimbursement utilized in contracts under this part, and the relative efficiency of each such method of reimbursement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the imposition of penalties and sanctions under this title for violations of law and for failure to comply with the obligations imposed by this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total costs incurred under subchapters XVIII and XIX of this chapter in the implementation and operation of all procedures required by such subchapters for the review of services to determine their medical necessity, appropriateness of use, and quality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85b86b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320c–10/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptions of the criteria upon which decisions are made, and the selection and relative weights of such criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85b86b1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1161, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tI/s143"},"text":"Pub. L. 97–248, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/392"},"text":"96 Stat. 392","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/tII/s261/a/2/C"},"text":"Pub. L. 112–40, title II, § 261(a)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-10-21"},"text":"Oct. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/423"},"text":"125 Stat. 423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85b86b2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85b86b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb85b86b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1320c–10, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tXI/s1161"},"text":"act Aug. 14, 1935, ch. 531, title XI, § 1161","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tII/s249F/b"},"text":"Pub. L. 92–603, title II, § 249F(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1440"},"text":"86 Stat. 1440","children":[],"tail":", related to giving of notice to a practitioner or provider by a Professional Standards Review Organization immediately after taking certain action or making certain determinations, prior to the general revision of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85b86b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":" substituted “quality improvement” for “utilization and quality control peer review”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85b86b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85b86b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/40"},"text":"Pub. L. 112–40","children":[],"tail":" applicable to contracts entered into or renewed on or after "},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"Jan. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/40/s261/e"},"text":"section 261(e) of Pub. L. 112–40","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320c"},"text":"section 1320c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb85b86b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Performance of Professional Standards Review Organizations; Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2112/a/2/D"},"text":"Pub. L. 97–35, title XXI, § 2112(a)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/793"},"text":"95 Stat. 793","children":[],"tail":", provided that the Secretary of Health and Human Services, not later than "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", was to report to the Congress on his assessment (under former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320c–3/g"},"text":"section 1320c–3(g) of this title","children":[],"tail":") of the relative performance of Professional Standards Review Organizations and on any determinations made not to renew agreements with such Organizations on the basis of such performance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
