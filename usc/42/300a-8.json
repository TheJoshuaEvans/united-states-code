{"tag":"section","attrib":{"id":"idb60c3fc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"300a–8"},"text":"§ 300a–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for United States, etc., officer or employee coercing or endeavoring to coerce procedure upon beneficiary of Federal program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb60c3fc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officer or employee of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60c3fc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" officer or employee of any State, political subdivision of a State, or any other entity, which administers or supervises the administration of any program receiving Federal financial assistance, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb60c3fc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300a–8/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" person who receives, under any program receiving Federal financial assistance, compensation for services,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"who coerces or endeavors to coerce any person to undergo an abortion or sterilization procedure by threatening such person with the loss of, or disqualification for the receipt of, any benefit or service under a program receiving Federal financial assistance shall be fined not more than $1,000 or imprisoned for not more than one year, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb60c3fc8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/63/tII/s205"},"text":"Pub. L. 94–63, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/308"},"text":"89 Stat. 308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb60c3fc9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb60c3fca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb60c3fcb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Family Planning and Population Research Act of 1975, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb60c3fcc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb60c3fcd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1975-07-01"},"text":"July 1, 1975","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/s608"},"text":"section 608 of Pub. L. 94–63","children":[],"tail":", set out as an Effective Date of 1975 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247b"},"text":"section 247b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
