{"tag":"section","attrib":{"id":"idc00ab05e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298"},"text":null,"children":[{"tag":"num","attrib":{"value":"16298"},"text":"§ 16298.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carbon utilization program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00ab05f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Administrator of the Environmental Protection Agency, shall carry out a program of research, development, demonstration, and commercialization relating to carbon utilization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab060-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program described in subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab061-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess and monitor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab062-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential changes in lifecycle carbon dioxide and other greenhouse gas emissions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab063-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other environmental safety indicators of new technologies, practices, processes, or methods used in enhanced hydrocarbon recovery as part of the activities authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16293"},"text":"section 16293 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab064-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and evaluate novel uses for carbon (including conversion of carbon oxides) that, on a full lifecycle basis, achieve a permanent reduction, or avoidance of a net increase, in carbon dioxide in the atmosphere, for use in commercial and industrial products such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc00ab065-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemicals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab066-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plastics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab067-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab068-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab069-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab06a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products of coal utilization in power systems or in other applications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc00ab06b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other products with demonstrated market value;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab06c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and assess carbon capture technologies for industrial systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab06d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and assess alternative uses for coal that result in zero net emissions of carbon dioxide or other pollutants, including products derived from carbon engineering, carbon fiber, and coal conversion methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab06e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In supporting demonstration and commercialization research under the program described in subsection (a), the Secretary shall prioritize consideration of projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc00ab06f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to a carbon dioxide emissions stream generated by a stationary source in the United States that is capable of supplying not less than 250 metric tons per day of carbon dioxide for research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to equipment for testing small-scale carbon dioxide utilization technologies, with onsite access to larger test bays for scale-up; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc00ab071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have 1 or more existing partnerships with a National Laboratory, an institution of higher education, a private company, or a State or other government entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate the activities authorized under this section with the activities authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16298a"},"text":"section 16298a of this title","children":[],"tail":" as part of a single consolidated program of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00ab073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16298/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $50,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00ab074-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s969"},"text":"Pub. L. 109–58, title IX, § 969","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dS/s102/c/1"},"text":"Pub. L. 116–260, div. S, § 102(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2248"},"text":"134 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
