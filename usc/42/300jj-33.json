{"tag":"section","attrib":{"id":"idb6dbc3e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33"},"text":null,"children":[{"tag":"num","attrib":{"value":"300jj–33"},"text":"§ 300jj–33.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State grants to promote health information technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6dbc3e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the National Coordinator, shall establish a program in accordance with this section to facilitate and expand the electronic movement and use of health information among organizations according to nationally recognized standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc3ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award a grant to a State or qualified State-designated entity (as described in subsection (f)) that submits an application to the Secretary at such time, in such manner, and containing such information as the Secretary may specify, for the purpose of planning activities described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc3eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant to a State or qualified State designated ","children":[{"tag":"ref","attrib":{"idref":"fn002529"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002529"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “State-designated”."}],"tail":" entity that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc3ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has submitted, and the Secretary has approved, a plan described in subsection (e) (regardless of whether such plan was prepared using amounts awarded under subsection (b); ","children":[{"tag":"ref","attrib":{"idref":"fn002530"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002530"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Another closing parenthesis probably should precede the semicolon."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits an application at such time, in such manner, and containing such information as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc3ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received under a grant under subsection (c) shall be used to conduct activities to facilitate and expand the electronic movement and use of health information among organizations according to nationally recognized standards through activities that include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc3ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing broad and varied participation in the authorized and secure nationwide electronic use and exchange of health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying State or local resources available towards a nationwide effort to promote health information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complementing other Federal grants, programs, and efforts towards the promotion of health information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance for the development and dissemination of solutions to barriers to the exchange of electronic health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting effective strategies to adopt and utilize health information technology in medically underserved communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting patients in utilizing health information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging clinicians to work with Health Information Technology Regional Extension Centers as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–32"},"text":"section 300jj–32 of this title","children":[],"tail":", to the extent they are available and valuable;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting public health agencies’ authorized use of and access to electronic health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the use of electronic health records for quality improvement including through quality measures reporting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other activities as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc3f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc3fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A plan described in this subsection is a plan that describes the activities to be carried out by a State or by the qualified State-designated entity within such State to facilitate and expand the electronic movement and use of health information among organizations according to nationally recognized standards and implementation specifications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc3fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan described in paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6dbc3fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be pursued in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc3fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the strategic plan developed by the National Coordinator, (and, as available) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–11"},"text":"section 300jj–11 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc3fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a description of the ways the State or qualified State-designated entity will carry out the activities described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc3ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain such elements as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified State-designated entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, to be a qualified State-designated entity, with respect to a State, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designated by the State as eligible to receive awards under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc402-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a not-for-profit entity with broad stakeholder representation on its governing board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc403-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that one of its principal goals is to use information technology to improve health care quality and efficiency through the authorized and secure electronic exchange and use of health information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc404-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt nondiscrimination and conflict of interest policies that demonstrate a commitment to open, fair, and nondiscriminatory participation by stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc405-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to such other requirements as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc406-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out activities described in subsections (b) and (c), a State or qualified State-designated entity shall consult with and consider the recommendations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc407-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers (including providers that provide services to low income and underserved populations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc408-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc409-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient or consumer organizations that represent the population to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc40a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health information technology vendors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc40b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care purchasers and employers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc40c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc40d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health professions schools, universities and colleges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc40e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical researchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc40f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other users of health information technology such as the support and clerical staff of providers and others involved in the care and care coordination of patients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc410-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/g/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other entities, as may be determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc411-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuous improvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually evaluate the activities conducted under this section and shall, in awarding grants under this section, implement the lessons learned from such evaluation in a manner so that awards made subsequent to each such evaluation are made in a manner that, in the determination of the Secretary, will lead towards the greatest improvement in quality of care, decrease in costs, and the most effective authorized and secure electronic exchange of health information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6dbc412-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required match","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6dbc413-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a fiscal year (beginning with fiscal year 2011), the Secretary may not make a grant under this section to a State unless the State agrees to make available non-Federal contributions (which may include in-kind contributions) toward the costs of a grant awarded under subsection (c) in an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6dbc414-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2011, not less than $1 for each $10 of Federal funds provided under the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc415-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2012, not less than $1 for each $7 of Federal funds provided under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6dbc416-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2013 and each subsequent fiscal year, not less than $1 for each $3 of Federal funds provided under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6dbc417-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300jj–33/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require State match for fiscal years before fiscal year 2011","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any fiscal year during the grant program under this section before fiscal year 2011, the Secretary may determine the extent to which there shall be required a non-Federal contribution from a State receiving a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6dbc418-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXX, § 3013, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/5/dA/tXIII/s13301"},"text":"Pub. L. 111–5, div. A, title XIII, § 13301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-02-17"},"text":"Feb. 17, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/250"},"text":"123 Stat. 250","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
