{"tag":"section","attrib":{"id":"idbb9491e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862r"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862r"},"text":"§ 1862r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research in disabilities education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb9491e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862r–1"},"text":"section 1862r–1 of this title","children":[],"tail":" alters the National Science Foundation’s Research in Disabilities Education program for fundamental and implementation research about learners (of all ages) with disabilities, including dyslexia, in science, technology, engineering, and mathematics (STEM). The National Science Foundation shall continue to encourage efforts to understand and address disability-based differences in STEM education and workforce participation, including differences for dyslexic learners."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9491e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Line item","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation shall include the amount requested for the Research in Disabilities Education program in the Foundation’s annual congressional budget justification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb9491e7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/124/s3"},"text":"Pub. L. 114–124, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/120"},"text":"130 Stat. 120","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9491e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9491e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9491ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Research Excellence and Advancements for Dyslexia Act or READ Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb9491eb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb9491ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/124/s2"},"text":"Pub. L. 114–124, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/120"},"text":"130 Stat. 120","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/124/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As many as 1 out of 6, or 8,500,000, American school children may have dyslexia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Since 1975, dyslexia has been included in the list of qualifying learning disabilities under the Education for All Handicapped Children Act of 1975 [see Short Title of 1975 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":", Education] and the Individuals with Disabilities Education Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"20 U.S.C. 1400","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
