{"tag":"section","attrib":{"id":"idbfa697c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12871"},"text":null,"children":[{"tag":"num","attrib":{"value":"12871"},"text":"§ 12871.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa697c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12871/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to make—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa697c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12871/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning grants to enable applicants to develop homeownership programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa697c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12871/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation grants to enable applicants to carry out homeownership programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa697c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12871/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to reserve housing assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with a grant under this part, the Secretary may reserve authority to provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":" to the extent necessary to provide rental assistance for a nonpurchasing tenant who resides in the project on the date the Secretary approves the application for an implementation grant, for use by the tenant in another project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa697c6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s421"},"text":"Pub. L. 101–625, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4162"},"text":"104 Stat. 4162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s181/a/2/B/i"},"text":"Pub. L. 102–550, title I, § 181(a)(2)(B)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3735"},"text":"106 Stat. 3735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa697c7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfa697c8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfa697c9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in subsec. (b), was in the original “this subtitle”, meaning subtitle B (§§ 421–431) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4162"},"text":"104 Stat. 4162","children":[],"tail":", which enacted this part and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1709"},"text":"section 1709 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfa697ca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" struck out subsec. (c) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—There is authorized to be appropriated for grants under this part $51,000,000 for fiscal year 1991 and $280,000,000 for fiscal year 1992. Any amounts appropriated pursuant to this subsection shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
