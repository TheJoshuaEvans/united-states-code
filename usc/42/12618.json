{"tag":"section","attrib":{"id":"idbf82bbc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618"},"text":null,"children":[{"tag":"num","attrib":{"value":"12618"},"text":"§ 12618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized benefits for Corps members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf82bbc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide for members of the National Civilian Community Corps to receive benefits authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Living allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide a living allowance to members of the Corps for the period during which such members are engaged in training or any activity on a Corps project. The Director shall establish the amount of the allowance at any amount not in excess of the amount equal to 100 percent of the poverty line that is applicable to a family of two (as defined by the Office of Management and Budget and revised annually in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9902/2"},"text":"section 9902(2) of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn004069"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004069"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorized benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"While receiving training or engaging in service projects as members of the National Civilian Community Corps, members may be provided the following benefits, as the Director determines appropriate:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bbca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Allowances for travel expenses, personal expenses, and other expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsistence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbcf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Uniforms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other services determined by the Director to be consistent with the purposes of the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supportive services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As the Director determines appropriate, the Director may provide each member of the Corps with health care services, child care services, counseling services, and other supportive services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post-service benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the agreed period of service with the Corps, a member shall elect to receive the educational assistance under subsection (f) or the cash benefit under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National service educational awards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Corps member who successfully completes a period of agreed service in the Corps may receive the national service educational award described in division D if the Corps member—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bbd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves in an approved national service position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bbd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the eligibility requirements specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12602"},"text":"section 12602 of this title","children":[],"tail":" with respect to service in that approved national service position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bbd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12618/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a Corps member who successfully completes a period of agreed service in the Corps is ineligible for the national service educational award described in division D, the Director may provide for the provision of a suitable alternative benefit for the Corps member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bbd8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s158"},"text":"Pub. L. 101–610, title I, § 158","children":[],"tail":", formerly § 195G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2526"},"text":"106 Stat. 2526","children":[],"tail":"; renumbered § 158 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", (g), title IV, § 403(b), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 847, 920; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1508"},"text":"Pub. L. 111–13, title I, § 1508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1525"},"text":"123 Stat. 1525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf82bbd9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf82bbda-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf82bbdb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653g"},"text":"section 12653g of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"Pub. L. 103–82, § 104(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf82bbdc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1508/1"},"text":"Pub. L. 111–13, § 1508(1)","children":[],"tail":", inserted “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1508/2/A"},"text":"Pub. L. 111–13, § 1508(2)(A)","children":[],"tail":", in introductory provisions, inserted “National” before “Civilian Community Corps” and “, as the Director determines appropriate” before colon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1508/2/B"},"text":"Pub. L. 111–13, § 1508(2)(B)","children":[],"tail":", substituted “Uniforms” for “Clothing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1508/2/C"},"text":"Pub. L. 111–13, § 1508(2)(C)","children":[],"tail":", substituted “Supplies” for “Recreational services and supplies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/b"},"text":"Pub. L. 103–82, § 403(b)","children":[],"tail":", substituted “Director” for “Director of the Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/g"},"text":"Pub. L. 103–82, § 104(g)","children":[],"tail":", added subsecs. (f) and (g) and struck out former subsecs. (f) to (h) which related to monetary educational assistance, cash benefit election for Corps members, and other post-service benefits, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf82bbdd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf82bbde-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf82bbdf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 104(b), (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
