{"tag":"section","attrib":{"id":"idb56c7cf6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"285b–9"},"text":"§ 285b–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" HHS valvular heart disease activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56c7cf7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”) shall, as appropriate, continue activities related to research, education, and awareness of valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7cf8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIH research related to valvular heart diseases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56c7cf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health, in consultation with the Director of the National Heart, Lung, and Blood Institute, may support or conduct research regarding valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7cfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support further research","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to improve information on, and understanding of, causation and risk factors for valvular heart diseases, research conducted or supported under this subsection for such diseases may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56c7cfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of advanced technological imaging and other relevant methods to generate data related to valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56c7cfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing potential risk factors for sudden cardiac arrest or sudden cardiac death from valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56c7cfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities, as appropriate, in order to improve the availability of information on, and advance research related to, valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7cfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mitral valve prolapse workshop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-20"},"text":"December 20, 2022","children":[],"tail":", the Director of the National Heart, Lung, and Blood Institute shall, as appropriate, convene a workshop composed of subject matter experts and stakeholders to identify research needs and opportunities to develop recommendations for the identification and treatment of individuals with mitral valve prolapse, including such individuals who may be at risk for sudden cardiac arrest or sudden cardiac death."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7cff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention activities to improve awareness of sudden cardiac death as a result of valvular heart diseases","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56c7d00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out activities to increase education and awareness of valvular heart diseases in order to reduce the incidence of sudden cardiac death caused by such diseases. The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56c7d01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants or contracts to public or nonprofit private entities to carry out activities under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56c7d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly, or through grants or contracts, provide technical assistance with respect to such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon availability of applicable data, projects carried out under paragraph (1) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56c7d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing activities at the Centers for Disease Control and Prevention related to valvular heart diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56c7d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the awareness of the public concerning any risk factors for, the symptoms of, and the public health impact of, valvular heart diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56c7d06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing public health data collection and improving the quality of such data, as appropriate, regarding cardiac arrests, including cardiac arrests that occur outside of the hospital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7d07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, in awarding grants or entering into contracts pursuant to paragraph (1), give priority to entities seeking to carry out projects for populations most impacted by valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7d08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as appropriate, ensure that activities under this section are coordinated with other agencies and offices of the Department of Health and Human Services that carry out activities regarding valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56c7d09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as applicable and appropriate, identify and disseminate best practices for relevant health care providers related to valvular heart diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56c7d0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285b–9/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of carrying out this section, there are authorized to be appropriated $28,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56c7d0b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/244/s2"},"text":"Pub. L. 117–244, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2340"},"text":"136 Stat. 2340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56c7d0c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56c7d0d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb56c7d0e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Cardiovascular Advances in Research and Opportunities Legacy Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
