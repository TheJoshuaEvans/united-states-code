{"tag":"section","attrib":{"id":"idb56ec794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285d–2"},"text":"§ 285d–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and training","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Institute shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56ec795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–2/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out programs of support for research and training (other than training for which Ruth L. Kirschstein National Research Service Awards may be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s288"},"text":"section 288 of this title","children":[],"tail":") in the diagnosis, prevention, and treatment of arthritis and musculoskeletal and skin diseases, including support for training in medical schools, graduate clinical training, graduate training in epidemiology, epidemiology studies, clinical trials, and interdisciplinary research programs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56ec796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285d–2/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish programs of evaluation, planning, and dissemination of knowledge related to such research and training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56ec797-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 437, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","chi