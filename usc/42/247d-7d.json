{"tag":"section","attrib":{"id":"idb4d3e6b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7d"},"text":null,"children":[{"tag":"num","attrib":{"value":"247d–7d"},"text":"§ 247d–7d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security for countermeasure development and production","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d3e6b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Attorney General and the Secretary of Defense, may provide technical or other assistance to provide security to persons or facilities that conduct development, production, distribution, or storage of priority countermeasures (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6/e/4"},"text":"section 247d–6(e)(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d3e6b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s247d–7d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop guidelines to enable entities eligible to receive assistance under subsection (a) to secure their facilities against potential terrorist attack.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d3e6b4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 319K, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/188/tI/s124"},"text":"Pub. L. 107–188, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/614"},"text":"116 Stat. 614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tVII/s705/a/2"},"text":"Pub. L. 116–22, title VII, § 705(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/964"},"text":"133 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4d3e6b5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4d3e6b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4d3e6b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22"},"text":"Pub. L. 116–22","children":[],"tail":" substituted “section 247d–6(e)(4)” for “section 247d–6(h)(4)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
