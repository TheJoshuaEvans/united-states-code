"text":"Jan. 2, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1315"},"text":"93 Stat. 1315","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/a/2"},"text":"Pub. L. 98–24, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/176"},"text":"97 Stat. 176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/509/tIII/s302"},"text":"Pub. L. 98–509, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2364"},"text":"98 Stat. 2364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/2"},"text":"Pub. L. 99–158, § 3(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/878"},"text":"99 Stat. 878","children":[],"tail":", 879; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4004/c"},"text":"Pub. L. 99–570, title IV, § 4004(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-111"},"text":"100 Stat. 3207–111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/b/1"},"text":"Pub. L. 99–660, title III, § 311(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3779"},"text":"100 Stat. 3779","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/227"},"text":"Pub. L. 117–286, § 4(a)(227)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4330"},"text":"136 Stat. 4330","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb42cf8b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb42cf8b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb42cf8b9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"Section 254b of this title","children":[],"tail":", referred to in subsecs. (a) and (b), was in the original a reference to section 329, meaning section 329 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was omitted in the general amendment of subpart I (§ 254b et seq.) of part D of subchapter II of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/299/s2"},"text":"Pub. L. 104–299, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3626"},"text":"110 Stat. 3626","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/104/299/s2"},"text":"Section 2 of Pub. L. 104–299","children":[],"tail":" enacted a new section 330 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b"},"text":"section 254b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb42cf8ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":"” for “Section 14(a) of the Federal Advisory Committee Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":" redesignated former subsec. (e)(1) to (4) as subsecs. (a) to (d), respectively, in subsec. (c), further redesignated former cls. (A) and (B) as (1) and (2), respectively, and struck out former subsecs. (a) to (d), which related, respectively, to composition, qualifications, appointment and tenure of the National Advisory Mental Health Council and the National Advisory Council on Alcohol Abuse and Alcoholism; duties of the National Advisory Mental Health Council; duties of the National Advisory Council on Alcohol Abuse and Alcoholism; and the composition, qualifications, and duties of the National Advisory Council on Drug Abuse."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/660"},"text":"Pub. L. 99–660","children":[],"tail":" which directed that “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc"},"text":"section 300cc of this title","children":[],"tail":"” be substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa"},"text":"section 300aa of this title","children":[],"tail":"” could not be executed because the reference in question appeared in former subsec. (c) which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/2/A"},"text":"Pub. L. 99–158, § 3(a)(2)(A)","children":[],"tail":", in first sentence substituted “National Advisory Mental Health Council and the National Advisory Council on Alcohol Abuse and Alcoholism” for “National Advisory Health Council, the National Advisory Mental Health Council, the National Advisory Council on Alcohol Abuse and Alcoholism, and the National Advisory Dental Research Council”, and substituted “by the Secretary” for “by the Surgeon General with the approval of the Secretary of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/2/B/i"},"text":"Pub. L. 99–158, § 3(a)(2)(B)(i)","children":[],"tail":", in second sentence struck out “in the case of the National Advisory Health Council, are skilled in the sciences related to health, and” after “scientific authorities who,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/2/B/ii"},"text":"Pub. L. 99–158, § 3(a)(2)(B)(ii)","children":[],"tail":", which directed the substitution in second sentence of “the National Advisory Mental Health Council and the National Advisory Council on Alcohol Abuse and Alcoholism” for “the National Advisory Mental Health Council, the National Advisory Council on Alcohol Abuse and Alcoholism, the National Advisory Heart Council, and the National Advisory Dental Research Council” was executed by making the substitution for “the National Advisory Mental Health Council, the National Advisory Council on Alcohol Abuse and Alcoholism, and the National Advisory Dental Research Council” as the probable intent of Congress in view of the prior deletion of “the National Advisory Heart Council,” by "},{"tag":"ref","attrib":{"href":"/us/pl/92/423"},"text":"Pub. L. 92–423","children":[],"tail":". See 1972 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/2/B/iii"},"text":"Pub. L. 99–158, § 3(a)(2)(B)(iii)","children":[],"tail":", in second sentence substituted “and alcohol abuse and alcoholism” for “, alcohol abuse and alcoholism, and dental diseases and conditions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/2/C"},"text":"Pub. L. 99–158, § 3(a)(2)(C)","children":[],"tail":", struck out third sentence which provided that in the case of the National Advisory Dental Research Council, four of the six members selected from among the leading medical or scientific authorities be dentists."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/3"},"text":"Pub. L. 99–158, § 3(a)(3)","children":[],"tail":", redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to the duties of the National Advisory Health Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/a/3"},"text":"Pub. L. 99–158, § 3(a)(3)","children":[],"tail":", redesignated subsecs. (d), (e), and (g) as (c), (d), and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/509"},"text":"Pub. L. 98–509","children":[],"tail":" inserted provision requiring the Secretary to assure that the membership of the National Advisory Council on Alcohol Abuse and Alcoholism is broadly representative of experts in the fields of prevention, research, and treatment of alcohol abuse, alcoholism, and rehabilitation of alcohol abusers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/24"},"text":"Pub. L. 98–24","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa"},"text":"section 300aa of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s219"},"text":"section 219 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/180"},"text":"Pub. L. 96–180","children":[],"tail":" authorized appointees to serve after the expiration of their terms until their successors have taken office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/181"},"text":"Pub. L. 96–181","children":[],"tail":", in provisions relating to the eligibility for selection of members, inserted officers or employees of State and local drug abuse agencies, and inserted provision that appointed members may serve after the expiration of their terms until their successors have taken office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/622"},"text":"Pub. L. 95–622","children":[],"tail":" struck out subsec. (f) which related to the establishment of a National Advisory Council for the Protection of Subjects of Biomedical and Behavioral Research."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/626"},"text":"Pub. L. 95–626","children":[],"tail":" substituted “section 254b” for “section 247d”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/371"},"text":"Pub. L. 94–371","children":[],"tail":" inserted provision that the Council advise the Secretary regarding policies and priorities with respect to grants and contracts in the field of alcohol abuse and alcoholism."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/63"},"text":"Pub. L. 94–63","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/348"},"text":"Pub. L. 93–348","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/423/s7/a/1"},"text":"Pub. L. 92–423, § 7(a)(1)","children":[],"tail":", (2), struck out “the National Advisory Heart Council,” after “the National Advisory Council on Alcohol Abuse and Alcoholism” in two places and “heart diseases,” after “alcohol abuse and alcoholism,”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/423/s7/a/2"},"text":"Pub. L. 92–423, § 7(a)(2)","children":[],"tail":", struck out “heart,” after “alcohol abuse and alcoholism,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/255"},"text":"Pub. L. 92–255","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/218/s6/a/1/A"},"text":"Pub. L. 92–218, § 6(a)(1)(A)","children":[],"tail":", (B), struck out reference to National Advisory Cancer Council before National Advisory Mental Health Council in two places and struck out “cancer,” before “psychiatric disorders”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/157"},"text":"Pub. L. 92–157","children":[],"tail":" substituted “National Advisory Council on Alcohol Abuse and Alcoholism” for “National Advisory Council on Alcoholic Abuse and Alcoholism” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/218/s6/a/1/B"},"text":"Pub. L. 92–218, § 6(a)(1)(B)","children":[],"tail":", struck out “cancer,” before “mental health” in listing of various diseases."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subse