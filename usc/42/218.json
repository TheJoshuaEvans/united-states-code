{"tag":"section","attrib":{"id":"idb42cf8b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s218"},"text":null,"children":[{"tag":"num","attrib":{"value":"218"},"text":"§ 218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Councils on Migrant Health","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb42cf8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 120 days of ","children":[{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", the Secretary shall appoint and organize a National Advisory Council on Migrant Health (hereinafter in this subsection referred to as the “Council”) which shall advise, consult with, and make recommendations to, the Secretary on matters concerning the organization, operation, selection, and funding of migrant health centers and other entities under grants and contracts under section 254b "},{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42cf8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall consist of fifteen members, at least twelve of whom shall be members of the governing boards of migrant health centers or other entities assisted under section 254b ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title. Of such twelve members who are members of such governing boards, at least nine shall be chosen from among those members of such governing boards who are being served by such centers or grantees and who are familiar with the delivery of health care to migratory agricultural workers and seasonal agricultural workers. The remaining three Council members shall be individuals qualified by training and experience in the medical sciences or in the administration of health programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42cf8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s218/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council shall hold office for a term of four years, except that (1) any member appointed to fill a vacancy occurring prior to the expiration of the term for which his predecessor was appointed shall be appointed for the remainder of such term; and (2) the terms of the members first taking office after ","children":[{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", shall expire as follows: four shall expire four years after such date, four shall expire three years after such date, four shall expire two years after such date, and three shall expire one year after such date, as designated by the Secretary at the time of appointment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42cf8b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s218/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"section 1013(a) of title 5","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013/a"},"text":"Section 1013(a) of title 5","children":[],"tail":" shall not apply to the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb42cf8b6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 217, "},{"tag":"ref","attrib":{"href":"/us/stat/58/691"},"text":"58 Stat. 691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1946-07-03/ch538/s5/b"},"text":"July 3, 1946, ch. 538, § 5(b)","children":[],"tail":"–(d), "},{"tag":"ref","attrib":{"href":"/us/stat/60/422"},"text":"60 Stat. 422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-16/ch481"},"text":"June 16, 1948, ch. 481","children":[],"tail":", §§ 4(a)–(c), 6(b), "},{"tag":"ref","attrib":{"href":"/us/stat/62/467"},"text":"62 Stat. 467","children":[],"tail":", 469; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-24/ch621/s4/a"},"text":"June 24, 1948, ch. 621, § 4(a)","children":[],"tail":"–(c), "},{"tag":"ref","attrib":{"href":"/us/stat/62/600"},"text":"62 Stat. 600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-15/ch714/s3/a"},"text":"Aug. 15, 1950, ch. 714, § 3(a)","children":[],"tail":"–(d), "},{"tag":"ref","attrib":{"href":"/us/stat/64/446"},"text":"64 Stat. 446","children":[],"tail":"; 1953 Reorg. Plan No. 1, §§ 5, 8, eff. "},{"tag":"date","attrib":{"date":"1953-04-11"},"text":"Apr. 11, 1953","children":[],"tail":", 18 F.R. 2053, "},{"tag":"ref","attrib":{"href":"/us/stat/67/631"},"te