{"tag":"section","attrib":{"id":"idb5227c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"274f–2"},"text":"§ 274f–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants regarding hospital organ donation coordinators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5227c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5227c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to qualified organ procurement organizations and hospitals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s273"},"text":"section 273 of this title","children":[],"tail":" to establish programs coordinating organ donation activities of eligible hospitals and qualified organ procurement organizations under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s273"},"text":"section 273 of this title","children":[],"tail":". Such activities shall be coordinated to increase the rate of organ donations for such hospitals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5227c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible hospital","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “eligible hospital” means a hospital that performs significant trauma care, or a hospital or consortium of hospitals that serves a population base of not fewer than 200,000 individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of coordination program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A condition for the receipt of a grant under subsection (a) is that the applicant involved agree that the program under such subsection will be carried out jointly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5227c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by representatives from the eligible hospital and the qualified organ procurement organization with respect to which the grant is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5227c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by such other entities as the representatives referred to in paragraph (1) may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each entity receiving a grant under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5227c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish joint organ procurement organization and hospital designated leadership responsibility and accountability for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5227c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop mutually agreed upon overall project performance goals and outcome measures, including interim outcome targets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5227c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaboratively design and implement an appropriate data collection process to provide ongoing feedback to hospital and organ procurement organization leadership on project progress and results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to interfere with regulations in force on ","children":[{"tag":"date","attrib":{"date":"2004-04-05"},"text":"April 5, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 3 years after the award of grants under this section, the Secretary shall ensure an evaluation of programs carried out pursuant to subsection (a) in order to determine the extent to which the programs have increased the rate of organ donation for the eligible hospitals involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a grant to a qualifying organ donation entity under this section unless such entity agrees that, with respect to costs to be incurred by the entity in carrying out activities for which the grant was awarded, the entity shall contribute (directly or through donations from public or private entities) non-Federal contributions in cash or in kind, in an amount equal to not less than 30 percent of the amount of the grant awarded to such entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5227c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274f–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this section, there are authorized to be appropriated $3,000,000 for fiscal year 2005, and such sums as may be necessary for each of fiscal years 2006 through 2009.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5227c17-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 377B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/216/s4"},"text":"Pub. L. 108–216, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-05"},"text":"Apr. 5, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/586"},"text":"118 Stat. 586","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
