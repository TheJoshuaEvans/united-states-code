{"tag":"section","attrib":{"id":"idbc8ed0f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3606"},"text":null,"children":[{"tag":"num","attrib":{"value":"3606"},"text":"§ 3606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination in the provision of brokerage services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1968-12-31"},"text":"December 31, 1968","children":[],"tail":", it shall be unlawful to deny any person access to or membership or participation in any multiple-listing service, real estate brokers’ organization or other service, organization, or facility relating to the business of selling or renting dwellings, or to discriminate against him in the terms or conditions of such access, membership, or participation, on account of race, color, religion, sex, handicap, familial status, or national origin."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc8ed0f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/284/tVIII/s806"},"text":"Pub. L. 90–284, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/84"},"text":"82 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVIII/s808/b/3"},"text":"Pub. L. 93–383, title VIII, § 808(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/729"},"text":"88 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/430/s6/b/1"},"text":"Pub. L. 100–430, § 6(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-13"},"text":"Sept. 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"hre