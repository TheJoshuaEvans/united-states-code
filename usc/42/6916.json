{"tag":"section","attrib":{"id":"idbdc99a27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916"},"text":null,"children":[{"tag":"num","attrib":{"value":"6916"},"text":"§ 6916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc99a28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Administrator for the purpose of carrying out the provisions of this chapter, $35,000,000 for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1977-09-30"},"text":"September 30, 1977","children":[],"tail":", $38,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", $42,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1979-09-30"},"text":"September 30, 1979","children":[],"tail":", $70,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"September 30, 1980","children":[],"tail":", $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"September 30, 1981","children":[],"tail":", $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", $70,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", and $80,000,000 for the fiscal year 1988."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource Recovery and Conservation Panels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 20 percent of the amount appropriated under subsection (a), or $5,000,000 per fiscal year, whichever is less, shall be used only for purposes of Resource Recovery and Conservation Panels established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6913"},"text":"section 6913 of this title","children":[],"tail":" (including travel expenses incurred by such panels in carrying out their functions under this chapter)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous waste","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 30 percent of the amount appropriated under subsection (a) shall be used only for purposes of carrying out subchapter III of this chapter (relating to hazardous waste) other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6931"},"text":"section 6931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 25 per centum of the total amount appropriated under this chapter, up to the amount authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6948/a/1"},"text":"section 6948(a)(1) of this title","children":[],"tail":", shall be used only for purposes of support to State, regional, local, and interstate agencies in accordance with subchapter IV of this chapter other than section 6948(a)(2) or 6949 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal investigators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Administrator $3,246,000 for the fiscal year 1985, $2,408,300 for the fiscal year 1986, $2,529,000 for the fiscal year 1987, and $2,529,000 for the fiscal year 1988 to be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc99a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for additional officers or employees of the Environmental Protection Agency authorized by the Administrator to conduct criminal investigations (to investigate, or supervise the investigation of, any activity for which a criminal penalty is provided) under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for support costs for such additional officers or employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc99a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Underground storage tanks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc99a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Administrator for the purpose of carrying out the provisions of subchapter IX (relating to regulation of underground storage tanks), $10,000,000 for each of the fiscal years 1985 through 1988.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc99a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6916/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated $25,000,000 for each of the fiscal years 1985 through 1988 to be used to make grants to the States for purposes of assisting the States in the development and implementation of approved State underground storage tank release detection, prevention, and correction programs under subchapter IX.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc99a32-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s2007"},"text":"Pub. L. 89–272, title II, § 2007","children":[],"tail":", formerly § 2006, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2805"},"text":"90 Stat. 2805","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/96/463/s4/a"},"text":"Pub. L. 96–463, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2055"},"text":"94 Stat. 2055","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/482"},"text":"Pub. L. 96–482","children":[],"tail":", §§ 6, 31(a), "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2336"},"text":"94 Stat. 2336","children":[],"tail":", 2352; "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/s2/a"},"text":"Pub. L. 98–616, § 2(a)","children":[],"tail":", (i), "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3222"},"text":"98 Stat. 3222","children":[],"tail":", 3223.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc99a33-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc99a34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc99a35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/616/s2/a"},"text":"Pub. L. 98–616, § 2(a)","children":[],"tail":", substituted “$80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":", $70,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":", $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1986-09-30"},"text":"September 30, 1986","children":[],"tail":", $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", and $80,000,000 for the fiscal year 1988” for “and $80,000,000 for the fiscal year ending "},{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/616/s2/i"},"text":"Pub. L. 98–616, § 2(i)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482/s31/a"},"text":"Pub. L. 96–482, § 31(a)","children":[],"tail":", authorized appropriation of $70,000,000, $80,000,000, and $80,000,000 for fiscal years ending "},{"tag":"date","attrib":{"date":"1980-09-30"},"text":"Sept. 30, 1980","children":[],"tail":", through 1982, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482/s6/a"},"text":"Pub. L. 96–482, § 6(a)","children":[],"tail":", inserted “, or $5,000,000 per fiscal year, whichever is less,” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482/s6/b"},"text":"Pub. L. 96–482, § 6(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbdc99a36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbdc99a37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Administrator or other official of Environmental Protection Agency under this chapter to Federal Inspector, Office of Federal Inspector for the Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
