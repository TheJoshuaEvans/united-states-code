{"tag":"section","attrib":{"id":"idbb70b5cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1778"},"text":null,"children":[{"tag":"num","attrib":{"value":"1778"},"text":"§ 1778.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The food and milk service programs in schools and nonprofit institutions receiving assistance under this chapter shall be conducted on a nonprofit basis.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb70b5cd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s9"},"text":"Pub. L. 89–642, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/888"},"text":"80 Stat. 888","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
