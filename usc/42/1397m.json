{"tag":"section","attrib":{"id":"idbaad3ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397m"},"text":"§ 1397m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of long-term care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and incentives for long-term care staffing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out activities, including activities described in paragraphs (2) and (3), to provide incentives for individuals to train for, seek, and maintain employment providing direct care in long-term care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific programs to enhance training, recruitment, and retention of staff","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with Secretary of Labor to recruit and train long-term care staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate activities under this subsection with the Secretary of Labor in order to provide incentives for individuals to train for and seek employment providing direct care in long-term care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career ladders and wage or benefit increases to increase staffing in long-term care","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaad3ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to eligible entities to carry out programs through which the entities—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbaad3ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer, to employees who provide direct care to residents of an eligible entity or individuals receiving community-based long-term care from an eligible entity, continuing training and varying levels of certification, based on observed clinical care practices and the amount of time the employees spend providing direct care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbaad3efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, or make arrangements to provide, bonuses or other increased compensation or benefits to employees who achieve certification under such a program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subparagraph, an eligible entity shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require (which may include evidence of consultation with the State in which the eligible entity is located with respect to carrying out activities funded under the grant).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to limit number of applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subparagraph shall be construed as prohibiting the Secretary from limiting the number of applicants for a grant under this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific programs to improve management practices","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to eligible entities to enable the entities to provide training and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under subparagraph (A) shall use funds made available through the grant to provide training and technical assistance regarding management practices using methods that are demonstrated to promote retention of individuals who provide direct care, such as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaad3f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of standard human resource policies that reward high performance, including policies that provide for improved wages and benefits on the basis of job reviews;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3f01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of motivational and thoughtful work organization practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3f02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of a workplace culture that respects and values caregivers and their needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3f03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of a workplace culture that respects the rights of residents of an eligible entity or individuals receiving community-based long-term care from an eligible entity and results in improved care for the residents or the individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3f04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of other programs that promote the provision of high quality care, such as a continuing education program that provides additional hours of training, including on-the-job training, for employees who are certified nurse aides.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this paragraph, an eligible entity shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require (which may include evidence of consultation with the State in which the eligible entity is located with respect to carrying out activities funded under the grant).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to limit number of applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall be construed as prohibiting the Secretary from limiting the number of applicants for a grant under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop accountability measures to ensure that the activities conducted using funds made available under this subsection benefit individuals who provide direct care and increase the stability of the long-term care workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community-based long-term care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community-based long-term care” has the meaning given such term by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaad3f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A long-term care facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A community-based long-term care entity (as defined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified EHR technology grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make grants to long-term care facilities for the purpose of assisting such entities in offsetting the costs related to purchasing, leasing, developing, and implementing certified EHR technology (as defined in section 1395w–4(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4) of this title) designed to improve patient safety and reduce adverse events and health care complications resulting from medication errors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under grants under this subsection may be used for any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Purchasing, leasing, and installing computer software and hardware, including handheld computer technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making improvements to existing computer software and hardware.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making upgrades and other improvements to existing computer software and hardware to enable e-prescribing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing education and training to eligible long-term care facility staff on the use of such technology to implement the electronic transmission of prescription and patient information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this subsection, a long-term care facility shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require (which may include evidence of consultation with the State in which the long-term care facility is located with respect to carrying out activities funded under the grant).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to limit number of applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed as prohibiting the Secretary from limiting the number of applicants for a grant under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in State health exchanges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A long-term care facility that receives a grant under this subsection shall, where available, participate in activities conducted by a State or a qualified State-designated entity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–33/f"},"text":"section 300jj–33(f) of this title","children":[],"tail":") under a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–33"},"text":"section 300jj–33 of this title","children":[],"tail":" to coordinate care and for other purposes determined appropriate by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop accountability measures to ensure that the activities conducted using funds made available under this subsection help improve patient safety and reduce adverse events and health care complications resulting from medication errors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of standards for transactions involving clinical data by long-term care facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and compatibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adopt electronic standards for the exchange of clinical data by long-term care facilities, including, where available, standards for messaging and nomenclature. Standards adopted by the Secretary under the preceding sentence shall be compatible with standards established under part C of subchapter XI, standards established under subsections (b)(2)(B)(i) and (e)(4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–104"},"text":"section 1395w–104 of this title","children":[],"tail":", standards adopted under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300jj–14"},"text":"section 300jj–14 of this title","children":[],"tail":", and general health information technology standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic submission of data to the Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3f1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 10 years after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall have procedures in place to accept the optional electronic submission of clinical data by long-term care facilities pursuant to the standards adopted under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3f1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to require a long-term care facility to submit clinical data electronically to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to carry out this subsection. Such regulations shall require a State, as a condition of the receipt of funds under this part, to conduct such data collection and reporting as the Secretary determines are necessary to satisfy the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3f1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2011, $20,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2012, $17,500,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397m/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2013 and 2014, $15,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3f23-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2041, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/791"},"text":"124 Stat. 791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaad3f24-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaad3f25-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbaad3f26-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part C of subchapter XI, referred to in subsec. (c)(1), is classified to section 1320d et seq. of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
