{"tag":"section","attrib":{"id":"idbe8d390c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8287a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8287a"},"text":"§ 8287a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any amount paid by a Federal agency pursuant to any contract entered into under this subchapter may be paid only from funds appropriated or otherwise made available to the agency for fiscal year 1986 or any fiscal year thereafter for the payment of energy, water, or wastewater treatment expenses, including related operations and maintenance expense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe8d390d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVIII/s802"},"text":"Pub. L. 95–619, title VIII, § 802","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tVII/s7201/a"},"text":"Pub. L. 99–272, title VII, § 7201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/142"},"text":"100 Stat. 142","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1090/b"},"text":"Pub. L. 108–375, div. A, title X, § 1090(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2067"},"text":"118 Stat. 2067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tI/s1002/e"},"text":"Pub. L. 116–260, div. Z, title I, § 1002(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2423"},"text":"134 Stat. 2423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe8d390e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe8d390f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe8d3910-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “, including related operations and maintenance expenses” for “(and related operation and maintenance expenses)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" inserted “, water, or wastewater treatment” after “payment of energy”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
