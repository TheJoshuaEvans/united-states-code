{"tag":"section","attrib":{"id":"idb5b67e23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–41"},"text":"§ 290bb–41.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health awareness training grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5b67e24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5b67e25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mental health awareness training grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5b67e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to States, political subdivisions of States, Indian Tribes, Tribal organizations, and nonprofit private entities to train teachers and other relevant school personnel to recognize symptoms of childhood and adolescent mental disorders, to refer family members to the appropriate mental health services if necessary, to train emergency services personnel ","children":[{"tag":"ref","attrib":{"idref":"fn002236"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002236"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A comma probably should appear."}],"tail":" veterans, law enforcement, and other categories of individuals, as determined by the Secretary, to identify and appropriately respond to persons with a mental illness, and to provide education to such teachers and personnel regarding resources that are available in the community for individuals with a mental illness."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency services personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “emergency services personnel” includes paramedics, firefighters, and emergency medical technicians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that such grants awarded under this subsection are equitably distributed among the geographical regions of the United States and between urban and rural populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, political subdivision of a State, Indian Tribe, Tribal organization, or nonprofit private entity that desires a grant under this subsection shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require, including a plan for the rigorous evaluation of activities that are carried out with funds received under a grant under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, political subdivision of a State, Indian Tribe, Tribal organization, or nonprofit private entity receiving a grant under this subsection shall use funds from such grant for evidence-based programs that provide training and education in accordance with paragraph (1) on matters including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizing the signs and symptoms of mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5b67e2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resources available in the community for individuals with a mental illness and other relevant resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5b67e2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safely de-escalating crisis situations involving individuals with a mental illness; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suicide intervention and prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, political subdivision of a State, Indian Tribe, Tribal organization, or nonprofit private entity that receives a grant under this subsection shall prepare and submit an evaluation to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require, including an evaluation of activities carried out with funds received under the grant under this subsection and a process and outcome evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide technical assistance to grantees in carrying out this section, which may include assistance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5b67e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program evaluation and related activities, including related data collection and reporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing and disseminating evidence-based practices and programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5b67e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating collaboration among grantees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5b67e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–41/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $24,963,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5b67e36-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 520J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXII/s3213"},"text":"Pub. L. 106–310, div. B, title XXXII, § 3213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1206"},"text":"114 Stat. 1206","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tIX/s9010"},"text":"Pub. L. 114–255, div. B, title IX, § 9010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1244"},"text":"130 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1122/b"},"text":"Pub. L. 117–328, div. FF, title I, § 1122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5651"},"text":"136 Stat. 5651","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5b67e37-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5b67e38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5b67e39-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/A"},"text":"Pub. L. 117–328, § 1122(b)(1)(A)","children":[],"tail":", substituted “Indian Tribes, Tribal organizations” for “Indian tribes, tribal organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/2/A"},"text":"Pub. L. 117–328, § 1122(b)(2)(A)","children":[],"tail":", substituted “Emergency services personnel” for “Emergency Services Personnel” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/2/B"},"text":"Pub. L. 117–328, § 1122(b)(2)(B)","children":[],"tail":", substituted “Distribution of awards” for “Distribution of Awards” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/B"},"text":"Pub. L. 117–328, § 1122(b)(1)(B)","children":[],"tail":", substituted “Indian Tribe, Tribal organization” for “Indian tribe, tribal organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/C/i"},"text":"Pub. L. 117–328, § 1122(b)(1)(C)(i)","children":[],"tail":", substituted “Indian Tribe, Tribal organization” for “Indian tribe, tribal organization” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/C/ii"},"text":"Pub. L. 117–328, § 1122(b)(1)(C)(ii)","children":[],"tail":"–(iv), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/D"},"text":"Pub. L. 117–328, § 1122(b)(1)(D)","children":[],"tail":", substituted “Indian Tribe, Tribal organization” for “Indian tribe, tribal organization”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/F"},"text":"Pub. L. 117–328, § 1122(b)(1)(F)","children":[],"tail":", added par. (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1122/b/1/E"},"text":"Pub. L. 117–328, § 1122(b)(1)(E)","children":[],"tail":", (G), redesignated par. (7) as (8) and substituted “$24,963,000 for each of fiscal years 2023 through 2027” for “$14,693,000 for each of fiscal years 2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9010/1"},"text":"Pub. L. 114–255, § 9010(1)","children":[],"tail":", inserted “Mental health awareness” before “training” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9010/2/A"},"text":"Pub. L. 114–255, § 9010(2)(A)","children":[],"tail":", substituted “health” for “illness” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9010/2/B"},"text":"Pub. L. 114–255, § 9010(2)(B)","children":[],"tail":", inserted “veterans, law enforcement, and other categories of individuals, as determined by the Secretary,” after “emergency services personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9010/2/C"},"text":"Pub. L. 114–255, § 9010(2)(C)","children":[],"tail":", substituted “for evidence-based programs that provide training and education in accordance with paragraph (1) on matters including” for “to” in introductory provisions, added subpars. (A) and (B), and struck out former subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) train teachers and other relevant school personnel to recognize symptoms of childhood and adolescent mental disorders and appropriately respond;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) train emergency services personnel to identify and appropriately respond to persons with a mental illness; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) provide education to such teachers and personnel regarding resources that are available in the community for individuals with a mental illness.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s9010/2/D"},"text":"Pub. L. 114–255, § 9010(2)(D)","children":[],"tail":", substituted “$14,693,000 for each of fiscal years 2018 through 2022.” for “, $25,000,000 for fiscal year 2001 and such sums as may be necessary for each of fiscal years 2002 through 2003.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
