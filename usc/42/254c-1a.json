{"tag":"section","attrib":{"id":"idb4e6f98d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–1a"},"text":"§ 254c–1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to nurse-managed health clinics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e6f98e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e6f98f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive primary health care services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “comprehensive primary health care services” means the primary health services described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254b/b/1"},"text":"section 254b(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e6f990-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nurse-managed health clinic","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nurse-managed health clinic” means a nurse-practice arrangement, managed by advanced practice nurses, that provides primary care or wellness services to underserved or vulnerable populations and that is associated with a school, college, university or department of nursing, federally qualified health center, or independent nonprofit health or social services agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e6f991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to award grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants for the cost of the operation of nurse-managed health clinics that meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e6f992-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e6f993-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an NMHC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e6f994-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e6f995-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that nurses are the major providers of services at the NMHC and that at least 1 advanced practice nurse holds an executive management position within the organizational structure of the NMHC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e6f996-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the NMHC will continue providing comprehensive primary health care services or wellness services without regard to income or insurance status of the patient for the duration of the grant period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e6f997-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that, not later than 90 days of receiving a grant under this section, the NMHC will establish a community advisory committee, for which a majority of the members shall be individuals who are served by the NMHC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e6f998-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of any grant made under this section for any fiscal year shall be determined by the Secretary, taking into account—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e6f999-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial need of the NMHC, considering State, local, and other operational funding provided to the NMHC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e6f99a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e6f99b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–1a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of carrying out this section, there are authorized to be appropriated $50,000,000 for the fiscal year 2010 and such sums as may be necessary for each of the fiscal years 2011 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e6f99c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 330A–1, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5208/b"},"text":"Pub. L. 111–148, title V, § 5208(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/613"},"text":"124 Stat. 613","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e6f99d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4e6f99e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4e6f99f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5208/a"},"text":"Pub. L. 111–148, title V, § 5208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/612"},"text":"124 Stat. 612","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/148/tV/s5208/a"},"text":"“The purpose of this section [enacting this section] is to fund the development and operation of nurse-managed health clinics.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
