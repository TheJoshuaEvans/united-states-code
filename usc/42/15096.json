{"tag":"section","attrib":{"id":"idbfdfcff0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15096"},"text":null,"children":[{"tag":"num","attrib":{"value":"15096"},"text":"§ 15096.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfcff1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15096/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15093"},"text":"section 15093 of this title","children":[],"tail":" shall use the funds made available through the grant to carry out systems change activities that accomplish the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfcff2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15096/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out activities authorized under this subchapter, a State shall ensure that such activities address the needs of families of children with disabilities from unserved or underserved populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfcff3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tII/s207"},"text":"Pub. L. 106–402, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1732"},"text":"114 Stat. 1732","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
