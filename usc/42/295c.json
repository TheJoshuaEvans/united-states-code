{"tag":"section","attrib":{"id":"idb5e88b2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c"},"text":null,"children":[{"tag":"num","attrib":{"value":"295c"},"text":"§ 295c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventive medicine and public health training grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88b2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Health Resources and Services Administration and in consultation with the Director of the Centers for Disease Control and Prevention, shall award grants to, or enter into contracts with, eligible entities to provide training to graduate medical residents in preventive medicine specialties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant or contract under subsection (a), an entity shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accredited school of public health or school of medicine or osteopathic medicine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accredited public or private nonprofit hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or tribal health department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of 2 or more entities described in paragraphs (1) through (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts received under a grant or contract under this section shall be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan, develop (including the development of curricula), operate, or participate in an accredited residency or internship program in preventive medicine or public health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defray the costs of practicum experiences, as required in such a program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, maintain, or improve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5e88b36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic administrative units (including departments, divisions, or other appropriate units) in preventive medicine and public health; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5e88b37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs that improve clinical teaching in preventive medicine and public health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Congress an annual report on the program carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88b3