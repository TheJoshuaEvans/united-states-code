{"tag":"section","attrib":{"id":"idb68a96f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ee–15"},"text":"§ 300ee–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of reports and audits by States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb68a96fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees to prepare and submit to the Secretary an annual report in such form and containing such information as the Secretary determines to be necessary for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a96fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing a record and a description of the purposes for which payments received by the State pursuant to such section were expended and of the recipients of such payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether the payments were expended in accordance with the needs within the State required to be identified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–13/a/2"},"text":"section 300ee–13(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether the payments were expended in accordance with the purpose described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/b"},"text":"section 300ee–11(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a96fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the percentage of payments received pursuant to such section that were expended by the State for administrative expenses during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a96ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb68a9700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees to establish such fiscal control and fund accounting procedures as may be necessary to ensure the proper disbursal of, and accounting for, amounts received by the State under such section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb68a9702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State will provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb68a9703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial and compliance audit of such payments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb68a9704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single financial and compliance audit of each entity administering such payments;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the audit will be performed biennially and will cover expenditures in each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb68a9706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the audit will be conducted in accordance with standards established by the Comptroller General of the United States for the audit of governmental organizations, programs, activities, and functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees that, not later than 30 days after the completion of an audit under paragraph (2), the State will provide a copy of the audit report to the State legislature."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb68a9708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (2), the term “financial and compliance audit” means an audit to determine whether the financial statements of an audited entity present fairly the financial position, and the results of financial operations, of the entity in accordance with generally accepted accounting principles, and whether the entity has complied with laws and regulations that may have a material effect upon the financial statements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a9709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" for a fiscal year unless the State involved agrees to make copies of the reports and audits described in this section available for public inspection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb68a970a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ee–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations by Comptroller General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General of the United States shall, from time to time, evaluate the expenditures by States of payments received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ee–11/a"},"text":"section 300ee–11(a) of this title","children":[],"tail":" in order to ensure that expenditures are consistent with the provisions of this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb68a970b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXV, formerly title XV, § 2505, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s221"},"text":"Pub. L. 100–607, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3095"},"text":"102 Stat. 3095","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2619/d"},"text":"Pub. L. 100–690, title II, § 2619(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4242"},"text":"102 Stat. 4242","children":[],"tail":"; renumbered title XXV, "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s5/e/1"},"text":"Pub. L. 101–93, § 5(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/612"},"text":"103 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb68a970c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb68a970d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb68a970e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2505 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238d"},"text":"section 238d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb68a970f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “make payments” for “payments”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb68a9710-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb68a9711-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
