{"tag":"section","attrib":{"id":"idbef87d58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857"},"text":null,"children":[{"tag":"num","attrib":{"value":"9857"},"text":"§ 9857.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbef87d59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter may be cited as the “Child Care and Development Block Grant Act of 1990”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef87d5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef87d5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow each State maximum flexibility in developing child care programs and policies that best suit the needs of children and parents within that State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote parental choice to empower working parents to make their own decisions regarding the child care services that best suit their family’s needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage States to provide consumer education information to help parents make informed choices about child care services and to promote involvement by parents and family members in the development of their children in child care settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist States in delivering high-quality, coordinated early childhood care and education services to maximize parents’ options and support parents trying to achieve independence from public assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist States in improving the overall quality of child care services and programs by implementing the health, safety, licensing, training, and oversight standards established in this subchapter and in State law (including State regulations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve child care and development of participating children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87d61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9857/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the number and percentage of low-income children in high-quality child care settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbef87d62-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s658A"},"text":"Pub. L. 97–35, title VI, § 658A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5082/2"},"text":"Pub. L. 101–508, title V, § 5082(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-236"},"text":"104 Stat. 1388–236","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/401/s3/a"},"text":"Pub. L. 102–401, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-07"},"text":"Oct. 7, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1959"},"text":"106 Stat. 1959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/586/s8/c/1"},"text":"Pub. L. 102–586, § 8(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5036"},"text":"106 Stat. 5036","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVI/s602"},"text":"Pub. L. 104–193, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2279"},"text":"110 Stat. 2279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/186/s2"},"text":"Pub. L. 113–186, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-19"},"text":"Nov. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1971"},"text":"128 Stat. 1971","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbef87d63-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbef87d64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbef87d65-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) of this section was formerly set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9801"},"text":"section 9801 of this title","children":[],"tail":". Subsection (b) of this section was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9858"},"text":"section 9858 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbef87d66-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/186"},"text":"Pub. L. 113–186","children":[],"tail":" amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—This subchapter may be cited as the ‘Child Care and Development Block Grant Act of 1990’."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—The goals of this subchapter are—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) to allow each State maximum flexibility in developing child care programs and policies that best suit the needs of children and parents within such State;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) to promote parental choice to empower working parents to make their own decisions on the child care that best suits their family’s needs;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) to encourage States to provide consumer education information to help parents make informed choices about child care;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) to assist States to provide child care to parents trying to achieve independence from public assistance; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) to assist States in implementing the health, safety, licensing, and registration standards established in State regulations.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" inserted “and goals” after “title” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/401"},"text":"Pub. L. 102–401","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/102/586"},"text":"Pub. L. 102–586","children":[],"tail":" made identical technical corrections to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5082/2"},"text":"Pub. L. 101–508, § 5082(2)","children":[],"tail":", which added this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
