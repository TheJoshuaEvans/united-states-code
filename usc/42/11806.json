{"tag":"section","attrib":{"id":"idbf57db59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11806"},"text":null,"children":[{"tag":"num","attrib":{"value":"11806"},"text":"§ 11806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the end of each fiscal year, the Secretary shall submit, to the Speaker of the House of Representatives and the President pro tempore of the Senate, a report describing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57db5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11806/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of projects and activities for which grants and contracts were made under this subchapter for such fiscal year,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11806/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and characteristics of the youth and families served by such projects and activities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57db5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11806/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of such projects and activities the Secretary considers to be exemplary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57db5d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3506"},"text":"Pub. L. 100–690, title III, § 3506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/132/s1/c"},"text":"Pub. L. 102–132, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-18"},"text":"Oct. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/630"},"text":"105 Stat. 630","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57db5e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf57db5f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf57db60-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/132/s3"},"text":"section 3 of Pub. L. 102–132","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11801"},"text":"section 11801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
