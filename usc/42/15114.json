{"tag":"section","attrib":{"id":"idbfdfd037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114"},"text":null,"children":[{"tag":"num","attrib":{"value":"15114"},"text":"§ 15114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff development curriculum authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdfd038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award funding, on a competitive basis, through a grant, cooperative agreement, or contract, to a public or private entity or a combination of such entities, for the development, evaluation, and dissemination of a staff development curriculum, and related guidelines, for computer-assisted, competency-based, multimedia, interactive instruction, relating to service as a direct support worker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd03a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The curriculum shall be developed for individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd03b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to become direct support workers who assist individuals with developmental disabilities or are such direct support workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd03c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to upgrade their skills and competencies related to being a direct support worker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdfd03d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive an award under this section, an entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdfd03e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive analysis of the content of direct support roles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd03f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information identifying an advisory group that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd040-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comprised of individuals with experience and expertise with regard to the support provided by direct support workers, and effective ways to provide the support, for individuals with developmental disabilities in diverse settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd041-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will advise the entity throughout the development, evaluation, and dissemination of the staff development curriculum and guidelines;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd042-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information describing how the entity will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdfd043-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop, field test, and validate a staff development curriculum that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdfd044-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relates to the appropriate reading level for direct service workers who assist individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd045-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for multiple levels of instruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd046-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides instruction appropriate for direct support workers who work in diverse settings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd047-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15001"},"text":"section 15001 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15009"},"text":"section 15009 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd048-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop, field test, and validate guidelines for the organizations that use the curriculum that provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdfd049-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing necessary technical and instructional support to trainers and mentors for the participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd04a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring easy access to and use of such curriculum by workers that choose to participate in using, and agencies that choose to use, the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd04b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the proficiency of the participants with respect to the content of the curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd04c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing necessary support to the participants to assure that the participants have access to, and proficiency in using, a computer in order to participate in the development, testing, and validation process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd04d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing necessary technical and instructional support to trainers and mentors for the participants in conjunction with the development, testing, and validation process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd04e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing the satisfaction of participants, individuals with developmental disabilities and their families, providers of services for such individuals and families, and other relevant entities with the curriculum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd04f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing methods to maintain a record of the instruction completed, and the content mastered, by each participant under the curriculum; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdfd050-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nationally disseminate the curriculum and guidelines, including dissemination through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdfd051-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent training and information centers funded under part D of the Individuals with Disabilities Education Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1451"},"text":"20 U.S.C. 1451","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd052-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations of and for individuals with developmental disabilities and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd053-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities funded under subchapter I;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd054-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" centers for independent living;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd055-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State educational agencies and local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd056-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities operating appropriate medical facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd057-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" postsecondary education entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdfd058-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/3/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdfd059-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15114/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdfd05a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIII/s304"},"text":"Pub. L. 106–402, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1735"},"text":"114 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfdfd05b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfdfd05c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbfdfd05d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Individuals with Disabilities Education Act, referred to in subsec. (b)(3)(C)(i), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/230"},"text":"Pub. L. 91–230","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-04-13"},"text":"Apr. 13, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/175"},"text":"84 Stat. 175","children":[],"tail":". Part D of the Act is classified generally to subchapter IV (§ 1450 et seq.) of chapter 33 of Title 20, Education. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1400"},"text":"section 1400 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
