{"tag":"section","attrib":{"id":"idb66b9d26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–30"},"text":"§ 300x–30.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort regarding State expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66b9d27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the principal agency of a State for carrying out authorized activities, a funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for the State for a fiscal year is that such agency will for such year maintain aggregate State expenditures for authorized activities at a level that is not less than the average level of such expenditures maintained by the State for the 2-year period preceding the fiscal year for which the State is applying for the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exclude from the aggregate State expenditures under subsection (a), funds appropriated to the principle agency for authorized activities which are of a non-recurring nature and for a specific purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of a State, the Secretary may waive all or part of the requirement established in subsection (a) if the Secretary determines that extraordinary economic conditions exist in the State, or any part of the State, to justify the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Date certain for acting upon request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall approve or deny a request for a waiver under paragraph (1) not later than 120 days after the date on which the request is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any waiver provided by the Secretary under paragraph (1) shall be applicable only to the fiscal year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance by State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" to a State for a fiscal year, the Secretary shall make a determination of whether, for the previous fiscal year, the State maintained material compliance with any agreement made under subsection (a). If the Secretary determines that a State has failed to maintain such compliance, the Secretary shall reduce the amount of the allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for the State for the fiscal year for which the grant is being made by an amount equal to the amount constituting such failure for the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" for a fiscal year only if the State involved submits to the Secretary information sufficient for the Secretary to make the determination required in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–30/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that has failed to comply with this section and would otherwise be subject to a reduction in the State’s allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":", may, upon request by the State, in lieu of having the State’s allotment under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" reduced, agree to comply with a negotiated agreement that is approved by the Secretary and carried out in accordance with guidelines issued by the Secretary. If a State fails to enter into or comply with a negotiated agreement, the Secretary may take action under this paragraph or the terms of the negotiated agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66b9d31-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1930, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/397"},"text":"106 Stat. 397","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3303/c"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1210"},"text":"114 Stat. 1210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVIII/s8002/g"},"text":"Pub. L. 114–255, div. B, title VIII, § 8002(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1230"},"text":"130 Stat. 1230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66b9d32-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66b9d33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb66b9d34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1930 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300y–9"},"text":"section 300y–9 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/280"},"text":"Pub. L. 99–280","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb66b9d35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8002/g/1"},"text":"Pub. L. 114–255, § 8002(g)(1)","children":[],"tail":", substituted “exist in the State, or any part of the State, to justify the waiver” for “in the State justify the waiver”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s8002/g/2"},"text":"Pub. L. 114–255, § 8002(g)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
