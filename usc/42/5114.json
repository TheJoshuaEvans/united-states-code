{"tag":"section","attrib":{"id":"idbd0622d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114"},"text":null,"children":[{"tag":"num","attrib":{"value":"5114"},"text":"§ 5114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report of unlicensed or unregulated adoption placements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0622d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for a study (the results of which shall be reported to the appropriate committees of the Congress not later than eighteen months after ","children":[{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":") designed to determine—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0622d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, scope, and effects of the interstate (and, to the extent feasible, intrastate) placement of children in adoptive homes (not including the homes of stepparents or relatives of the child in question) by persons or agencies.","children":[{"tag":"ref","attrib":{"idref":"fn003396"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003396"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0622d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how interstate placements are being financed across State lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0622d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on best practice models for both interstate and intrastate adoptions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0622d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how State policies in defining special needs children differentiate or group similar categories of children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0622d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dynamics of successful adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct research (directly or by grant to, or contract with, public or private nonprofit research agencies or organizations) about adoption outcomes and the factors affecting those outcomes. The Secretary shall submit a report containing the results of such research to the appropriate committees of the Congress not later than the date that is 36 months after ","children":[{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0622da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interjurisdictional adoption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", the Secretary shall submit to the appropriate committees of the Congress a report that contains recommendations for an action plan to facilitate the interjurisdictional adoption of foster children."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0622db-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/266/tII/s204"},"text":"Pub. L. 95–266, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-24"},"text":"Apr. 24, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/210"},"text":"92 Stat. 210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/36/tII"},"text":"Pub. L. 108–36, title II","children":[],"tail":", §§ 203, 204, "},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/821"},"text":"117 Stat. 821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0622dc-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0622dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0622de-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/36"},"text":"Pub. L. 108–36","children":[],"tail":" designated existing provisions as subsec. (a), inserted subsec. heading and par. (1) designation, substituted “"},{"tag":"date","attrib":{"date":"2003-06-25"},"text":"June 25, 2003","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1978-04-24"},"text":"April 24, 1978","children":[],"tail":"” and “to determine—” for “to determine”, struck out “which are not licensed by or subject to regulation by any governmental entity” after “by persons or agencies”, and added pars. (2) to (4) and subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
