{"tag":"section","attrib":{"id":"idb8222760-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1311"},"text":null,"children":[{"tag":"num","attrib":{"value":"1311"},"text":"§ 1311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public assistance payments to legal representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of subchapters I, X, XIV, and XVI, and part A of subchapter IV, payments on behalf of an individual, made to another person who has been judicially appointed, under the law of the State in which such individual resides, as legal representative of such individual for the purpose of receiving and managing such payments (whether or not he is such individual’s legal representative for other purposes), shall be regarded as money payments to such individual.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8222761-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1111, as added "},{"tag":"ref","attrib":{"href":"/us/pl/85/840/tV/s511/a"},"text":"Pub. L. 85–840, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1051"},"text":"72 Stat. 1051","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/543/tI/s141/d"},"text":"Pub. L. 87–543, title I, § 141(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-07-25"},"text":"July 25, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/205"},"text":"76 Stat. 205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tII/s241/c/3"},"text":"Pub. L. 90–248, title II, § 241(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/917"},"text":"81 Stat. 917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8222762-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8222763-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8222764-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/248"},"text":"Pub. L. 90–248","children":[],"tail":" struck out “IV,” after “I,” and inserted “and part A of subchapter IV,” after “XVI,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/543"},"text":"Pub. L. 87–543","children":[],"tail":" inserted reference to subchapter XVI."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8222765-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8222766-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/840/tV/s511/b"},"text":"Pub. L. 85–840, title V, § 511(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1052"},"text":"72 Stat. 1052","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/840/tV/s511/b"},"text":"“The amendment made by subsection (a) [enacting this section] shall be applicable in the case of payments to legal representatives by any State made after ","children":[{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":"; and to such payments by any State made after "},{"tag":"date","attrib":{"date":"1955-12-31"},"text":"December 31, 1955","children":[],"tail":", and prior to "},{"tag":"date","attrib":{"date":"1958-07-01"},"text":"July 1, 1958","children":[],"tail":", if certifications for payment to such State have been made by the Secretary of Health, Education, and Welfare [now Health and Human Services] with respect thereto, or such State has presented to the Secretary a claim (and such other data as the Secretary may require) with respect thereto, prior to "},{"tag":"date","attrib":{"date":"1959-07-01"},"text":"July 1, 1959","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
