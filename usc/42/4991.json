{"tag":"section","attrib":{"id":"idbcebe439-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4991"},"text":null,"children":[{"tag":"num","attrib":{"value":"4991"},"text":"§ 4991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This part provides for special emphasis and demonstration volunteer programs, together with appropriate powers and responsibilities designed to assist in the development and coordination of such programs. The purpose of this part is to strengthen and supplement efforts to meet a broad range of needs, particularly those related to poverty, by encouraging and enabling persons from all walks of life and from all age groups to perform meaningful and constructive volunteer service in agencies, institutions, and organizations where the application of human talent and dedication may help to meet such needs. It is the further purpose of this part to provide technical and financial assistance to encourage voluntary organizations and volunteer efforts at the national, State, and local level.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcebe43a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tI/s121"},"text":"Pub. L. 93–113, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/400"},"text":"87 Stat. 400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s11"},"text":"Pub. L. 98–288, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/191"},"text":"98 Stat. 191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tII/s2131"},"text":"Pub. L. 111–13, title II, § 2131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1584"},"text":"123 Stat. 1584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcebe43b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcebe43c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcebe43d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" substituted “organizations” for “situations” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/288"},"text":"Pub. L. 98–288","children":[],"tail":" struck out “human, social, and environmental” after “broad range of”, and inserted at end “It is the further purpose of this part to provide technical and financial assistance to encourage voluntary organizations and volunteer efforts at the national, State, and local level.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcebe43e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcebe43f-3a70-11f1-ae07-e4213316b5fa"},"text