{"tag":"section","attrib":{"id":"idbcca79ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4369"},"text":null,"children":[{"tag":"num","attrib":{"value":"4369"},"text":"§ 4369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcca79ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4369/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All reports to or by the Administrator relevant to the Agency’s program of research, development, and demonstration shall promptly be made available to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Environment and Public Works of the Senate, unless otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4369/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of jurisdictional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall keep the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Environment and Public Works of the Senate fully and currently informed with respect to matters falling within or related to the jurisdiction of the committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4369/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comment by Government agencies and the public","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reports provided for in section 5910 ","children":[{"tag":"ref","attrib":{"idref":"fn003362"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003362"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall be made available to the public for comment, and to the heads of affected agencies for comment and, in the case of recommendations for action, for response."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcca79af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4369/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of research information to the Department of Energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of assisting the Department of Energy in planning and assigning priorities in research development and demonstration activities related to environmental control technologies, the Administrator shall actively make available to the Department all information on research activities and results of research programs of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcca79b0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/477/s5"},"text":"Pub. L. 95–477, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1510"},"text":"92 Stat. 1510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/437/s15/c/6"},"text":"Pub. L. 103–437, § 15(c)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4592"},"text":"108 Stat. 4592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcca79b1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcca79b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcca79b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5910"},"text":"Section 5910 of this title","children":[],"tail":", referred to in subsec. (c), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2021/i"},"text":"Pub. L. 104–66, title II, § 2021(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/727"},"text":"109 Stat. 727","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbcca79b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Environmental Research, Development, and Demonstration Authorization Act of 1979, and not as part of the National Environmental Policy Act of 1969 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcca79b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Science, Space, and Technology” for “Science and Technology”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
