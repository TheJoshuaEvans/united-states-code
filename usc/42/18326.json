{"tag":"section","attrib":{"id":"idc054b199-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326"},"text":null,"children":[{"tag":"num","attrib":{"value":"18326"},"text":"§ 18326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of technologies and in-space capabilities for beyond near-Earth space missions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc054b19a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may initiate activities to develop the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b19b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technologies identified as necessary elements of missions beyond low-Earth orbit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b19c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In-space capabilities such as refueling and storage technology, orbital transfer stages, innovative in-space propulsion technology, communications, and data management that facilitate a broad range of users (including military and commercial) and applications defining the architecture and design of such missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b19d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Spacesuit development and associated life support technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b19e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Flagship missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc054b19f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing technologies and capabilities under subsection (a), the Administrator may make investments—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc054b1a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in space technologies such as advanced propulsion, propellant depots, in situ resource utilization, and robotic payloads or capabilities that enable human missions beyond low-Earth orbit ultimately leading to Mars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a space-based transfer vehicle including these technologies with an ability to conduct space-based operations that provide capabilities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc054b1a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to integrate with the Space Launch System and other space-based systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc054b1a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide opportunities for in-space servicing of and delivery to multiple space-based platforms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc054b1a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate international efforts to expand human presence to deep space destinations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in advanced life support technologies and capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in technologies and capabilities relating to in-space power, propulsion, and energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in technologies and capabilities relating to in-space propellant transfer and storage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in technologies and capabilities relating to in situ resource utilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc054b1a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in expanded research to understand the greatest biological impediments to human deep space missions, especially the radiation challenge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc054b1aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of ISS as testbed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may utilize the ISS as a testbed for any technology or capability developed under subsection (a) in a manner consistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc054b1ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall coordinate development of technologies and capabilities under this section through an overall agency technology approach, as authorized by section 905 of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc054b1ac-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tIII/s308"},"text":"Pub. L. 111–267, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2818"},"text":"124 Stat. 2818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc054b1ad-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc054b1ae-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc054b1af-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 905 of this Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/267/tIX/s905"},"text":"Pub. L. 111–267, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-11"},"text":"Oct. 11, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2836"},"text":"124 Stat. 2836","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
