{"tag":"section","attrib":{"id":"idbf7b901f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592"},"text":null,"children":[{"tag":"num","attrib":{"value":"12592"},"text":"§ 12592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of national service participants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf7b9020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b) and (c) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12583/f"},"text":"section 12583(f) of this title","children":[],"tail":", the actual recruitment and selection of an individual to serve in a national service program receiving assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" or to fill an approved national service position shall be conducted by the entity to which the assistance and approved national service positions are provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b9021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination and nonpolitical selection of participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recruitment and selection of individuals to serve in national service programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":" or to fill approved national service positions shall be consistent with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12635"},"text":"section 12635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b9022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Acceptance into a national service program to serve a second term of service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12593"},"text":"section 12593 of this title","children":[],"tail":" shall only be available to individuals who perform satisfactorily in their first term of service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b9023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment and placement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation and each State Commission shall establish a system to recruit individuals who desire to perform national service and to assist the placement of these individuals in approved national service positions, which may include positions available under titles I and II of the Domestic Volunteer Service Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4951"},"text":"42 U.S.C. 4951","children":[],"tail":" et seq. [and 5000 et seq.]). The Corporation and State Commissions shall disseminate information regarding available approved national service positions through cooperation with secondary schools, institutions of higher education, employment service offices, State vocational rehabilitation agencies within the meaning of the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.) and other State agencies that primarily serve individuals with disabilities, and other appropriate entities, particularly those organizations that provide outreach to disadvantaged youths and youths who are individuals with disabilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b9024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National leadership pool","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf7b9025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection and training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From among individuals recruited under subsection (d), the Corporation may select individuals with significant leadership potential, as determined by the Corporation, to receive special training to enhance their leadership ability. The leadership training shall be provided by the Corporation directly or through a grant or contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b9026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis on certain individuals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting individuals to receive leadership training under this subsection, the Corporation shall make special efforts to select individuals who have served—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf7b9027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Peace Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b9028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as VISTA volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b9029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as participants in national service programs receiving assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12571"},"text":"section 12571 of this title","children":[],"tail":", particularly those who were considered, at the time of their service, disadvantaged youth;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b902a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as participants in programs receiving assistance under part D of this subchapter, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1993-09-21"},"text":"September 21, 1993","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf7b902b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as members of the Armed Forces of the United States and who were honorably discharged from such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf7b902c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a program that receives assistance under the national service laws, the Corporation may assign an individual who receives leadership training under paragraph (1) to work with the program in a leadership position and carry out assignments not otherwise performed by regular participants. An individual assigned to a program shall be considered to be a participant of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf7b902d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12592/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall issue regulations regarding the manner and criteria by which the service of a participant shall be evaluated to determine whether the service is satisfactory and successful for purposes of eligibility for a second term of service or a national service educational award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf7b902e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s138"},"text":"Pub. L. 101–610, title I, § 138","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s101/b"},"text":"Pub. L. 103–82, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/809"},"text":"107 Stat. 809","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1313"},"text":"Pub. L. 111–13, title I, § 1313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1510"},"text":"123 Stat. 1510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf7b902f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf7b9030-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf7b9031-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Domestic Volunteer Service Act of 1973, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113"},"text":"Pub. L. 93–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/394"},"text":"87 Stat. 394","children":[],"tail":". Titles I and II of the Act are classified generally to subchapters I (§ 4951 et seq.) and II (§ 5000 et seq.), respectively, of chapter 66 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Rehabilitation Act of 1973, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Pub. L. 93–112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-09-26"},"text":"Sept. 26, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":", which is classified generally to chapter 16 (§ 701 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"section 701 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Part D of this subchapter, as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1993-09-21"},"text":"September 21, 1993","children":[],"tail":", referred to in subsec. (e)(2)(D), means former part D of this subchapter prior to the general amendment of subtitle D of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/101/610"},"text":"Pub. L. 101–610","children":[],"tail":" [former part D of this subchapter] by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s102/a"},"text":"Pub. L. 103–82, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/816"},"text":"107 Stat. 816","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf7b9032-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1313/1"},"text":"Pub. L. 111–13, § 1313(1)","children":[],"tail":", substituted “conducted by the entity” for “conducted by the State, subdivision of a State, Indian tribe, public or private nonprofit organization, institution of higher education, Federal agency, or other entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1313/2"},"text":"Pub. L. 111–13, § 1313(2)","children":[],"tail":", inserted “, particularly those who were considered, at the time of their service, disadvantaged youth” before semicolon at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf7b9033-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf7b9034-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf7b9035-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as an Effective Date of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
