{"tag":"section","attrib":{"id":"idbea776f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8855"},"text":null,"children":[{"tag":"num","attrib":{"value":"8855"},"text":"§ 8855.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forest Service leases and permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the intent of the Congress that the Secretary of Agriculture shall process applications for leases of National Forest System lands and for permits to explore, drill, and develop resources on land leased from the Forest Service, notwithstanding the current status of any plan being prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1604"},"text":"section 1604 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbea776f9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s262"},"text":"Pub. L. 96–294, title II, § 262","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/710"},"text":"94 Stat. 710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
