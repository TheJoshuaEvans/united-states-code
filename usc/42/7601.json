{"tag":"section","attrib":{"id":"idbe540028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601"},"text":null,"children":[{"tag":"num","attrib":{"value":"7601"},"text":"§ 7601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe540029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; delegation of powers and duties; regional officers and employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe54002a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator is authorized to prescribe such regulations as are necessary to carry out his functions under this chapter. The Administrator may delegate to any officer or employee of the Environmental Protection Agency such of his powers and duties under this chapter, except the making of regulations subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7607/d"},"text":"section 7607(d) of this title","children":[],"tail":", as he may deem necessary or expedient."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe54002b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1977-08-07"},"text":"August 7, 1977","children":[],"tail":", the Administrator shall promulgate regulations establishing general applicable procedures and policies for regional officers and employees (including the Regional Administrator) to follow in carrying out a delegation under paragraph (1), if any. Such regulations shall be designed—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe54002c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure fairness and uniformity in the criteria, procedures, and policies applied by the various regions in implementing and enforcing the chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe54002d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assure at least an adequate quality audit of each State’s performance and adherence to the requirements of this chapter in implementing and enforcing the chapter, particularly in the review of new sources and in enforcement of the chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe54002e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a mechanism for identifying and standardizing inconsistent or varying criteria, procedures, and policies being employed by such officers and employees in implementing and enforcing the chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe54002f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Environmental Protection Agency personnel to air pollution control agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of an air pollution control agency, personnel of the Environmental Protection Agency may be detailed to such agency for the purpose of carrying out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe540030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments under grants; installments; advances or reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under grants made under this chapter may be made in installments, and in advance or by way of reimbursement, as may be determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe540031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe540032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the provisions of paragraph (2), the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe540033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is authorized to treat Indian tribes as States under this chapter, except for purposes of the requirement that makes available for application by each State no less than one-half of 1 percent of annual appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7405"},"text":"section 7405 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe540034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide any such Indian tribe grant and contract assistance to carry out functions provided by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe540035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall promulgate regulations within 18 months after ","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"November 15, 1990","children":[],"tail":", specifying those provisions of this chapter for which it is appropriate to treat Indian tribes as States. Such treatment shall be authorized only if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe540036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe has a governing body carrying out substantial governmental duties and powers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe540037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the functions to be exercised by the Indian tribe pertain to the management and protection of air resources within the exterior boundaries of the reservation or other areas within the tribe’s jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe540038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian tribe is reasonably expected to be capable, in the judgment of the Administrator, of carrying out the functions to be exercised in a manner consistent with the terms and purposes of this chapter and all applicable regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe540039-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may promulgate regulations which establish the elements of tribal implementation plans and procedures for approval or disapproval of tribal implementation plans and portions thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe54003a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case in which the Administrator determines that the treatment of Indian tribes as identical to States is inappropriate or administratively infeasible, the Administrator may provide, by regulation, other means by which the Administrator will directly administer such provisions so as to achieve the appropriate purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe54003b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7601/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until such time as the Administrator promulgates regulations pursuant to this subsection, the Administrator may continue to provide financial assistance to eligible Indian tribes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7405"},"text":"section 7405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe54003c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 301, formerly § 8, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/206/s1"},"text":"Pub. L. 88–206, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-17"},"text":"Dec. 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/400"},"text":"77 Stat. 400","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/tI/s101/4"},"text":"Pub. L. 89–272, title I, § 101(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/992"},"text":"79 Stat. 992","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/504"},"text":"81 Stat. 504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/604"},"text":"Pub. L. 91–604","children":[],"tail":", §§ 3(b)(2), 15(c)(2), "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1677"},"text":"84 Stat. 1677","children":[],"tail":", 1713; "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tIII/s305/e"},"text":"Pub. L. 95–95, title III, § 305(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/776"},"text":"91 Stat. 776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tI"},"text":"Pub. L. 101–549, title I","children":[],"tail":", §§ 107(d), 108(i), "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2464"},"text":"104 Stat. 2464","children":[],"tail":", 2467.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe54003d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe54003e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe54003f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857g"},"text":"section 1857g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe540040-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s108/i"},"text":"Pub. L. 101–549, § 108(i)","children":[],"tail":", inserted “subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7607/d"},"text":"section 7607(d) of this title","children":[],"tail":"” after “regulations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s107/d"},"text":"Pub. L. 101–549, § 107(d)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary” and “Environmental Protection Agency” for “Department of Health, Education, and Welfare”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s3/b/2"},"text":"Pub. L. 91–604, § 3(b)(2)","children":[],"tail":", substituted “Environmental Protection Agency” for “Public Health Service” and struck out provisions covering the payment of salaries and allowances."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/2"},"text":"Pub. L. 91–604, § 15(c)(2)","children":[],"tail":", substituted “Administrator” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/148"},"text":"Pub. L. 90–148","children":[],"tail":" reenacted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe540041-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe540042-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe540043-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification or Rescission of Rules, Regulations, Orders, Determinations, Contracts, Certifications, Authorizations, Delegations, and Other Actions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"All rules, regulations, orders, determinations, contracts, certifications, authorizations, delegations, or other actions duly issued, made, or taken by or pursuant to act ","children":[{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", the Clean Air Act, as in effect immediately prior to the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":"] to continue in full force and effect until modified or rescinded in accordance with act "},{"tag":"date","attrib":{"date":"1955-07-14"},"text":"July 14, 1955","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" [this chapter], see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/b"},"text":"section 406(b) of Pub. L. 95–95","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbe540044-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disadvantaged Business Concerns; Use of Quotas Prohibited","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/tX"},"text":"Pub. L. 101–549, title X","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2708"},"text":"104 Stat. 2708","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/549/tX"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1001"},"text":"“SEC. 1001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DISADVANTAGED BUSINESS CONCERNS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In providing for any research relating to the requirements of the amendments made by the Clean Air Act Amendments of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549"},"text":"Pub. L. 101–549","children":[],"tail":", see Tables for classification] which uses funds of the Environmental Protection Agency, the Administrator of the Environmental Protection Agency shall, to the extent practicable, require that not less than 10 percent of total Federal funding for such research will be made available to disadvantaged business concerns."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subsection (a), the term ‘disadvantaged business concern’ means a concern—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is at least 51 percent owned by one or more socially and economically disadvantaged individuals or, in the case of a publicly traded company, at least 51 percent of the stock of which is owned by one or more socially and economically disadvantaged individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the management and daily business operations of which are controlled by such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A for-profit business concern is presumed to be a disadvantaged business concern for purposes of subsection (a) if it is at least 51 percent owned by, or in the case of a concern which is a publicly traded company at least 51 percent of the stock of the company is owned by, one or more individuals who are members of the following groups:","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Black Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"“(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Native Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"“(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Asian Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"“(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Women.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"“(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disabled Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The presumption established by clause (i) may be rebutted with respect to a particular business concern if it is reasonably established that the individual or individuals referred to in that clause with respect to that business concern are not experiencing impediments to establishing or developing such concern as a result of the individual’s identification as a member of a group specified in that clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following institutions are presumed to be disadvantaged business concerns for purposes of subsection (a):","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Historically black colleges and universities, and colleges and universities having a student body in which 40 percent of the students are Hispanic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Minority institutions (as that term is defined by the Secretary of Education pursuant to the General Education Provision Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1221"},"text":"20 U.S.C. 1221","children":[],"tail":" et seq.))."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Private and voluntary organizations controlled by individuals who are socially and economically disadvantaged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A joint venture may be considered to be a disadvantaged business concern under subsection (a), notwithstanding the size of such joint venture, if—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party to the joint venture is a disadvantaged business concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that party owns at least 51 percent of the joint venture.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A person who is not an economically disadvantaged individual or a disadvantaged business concern, as a party to a joint venture, may not be a party to more than 2 awarded contracts in a fiscal year solely by reason of this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this paragraph shall prohibit any member of a racial or ethnic group that is not listed in subparagraph (B)(i) from establishing that they have been impeded in establishing or developing a business concern as a result of racial or ethnic discrimination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1002"},"text":"“Sec. 1002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Quotas Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title shall permit or require the use of quotas or a requirement that has the effect of a quota in determining eligibility under section 1001.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
