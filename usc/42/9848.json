{"tag":"section","attrib":{"id":"idbef60cdf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848"},"text":null,"children":[{"tag":"num","attrib":{"value":"9848"},"text":"§ 9848.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability of wages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbef60ce0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability of wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take such action as may be necessary to assure that persons employed in carrying out programs financed under this subchapter shall not receive compensation at a rate which is (1) in excess of the average rate of compensation paid in the area where the program is carried out to a substantial number of the persons providing substantially comparable services, or in excess of the average rate of compensation paid to a substantial number of the persons providing substantially comparable services in the area of the person’s immediately preceding employment, whichever is higher; or (2) less than the minimum wage rate prescribed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"section 206(a)(1) of title 29","children":[],"tail":". The Secretary shall encourage Head Start agencies to provide compensation according to salary scales that are based on training and experience."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbef87ce1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbef87ce2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no Federal funds may be used to pay any part of the compensation of an individual employed by a Head Start agency, if such compensation, including non-Federal funds, exceeds an amount equal to the rate payable for level II of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbef87ce3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “compensation”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbef87ce4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes salary, bonuses, periodic payments, severance pay, the value of any vacation time, the value of a compensatory or paid leave benefit not excluded by subparagraph (B), and the fair market value of any employee perquisite or benefit not excluded by subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbef87ce5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9848/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excludes any Head Start agency expenditure for a health, medical, life insurance, disability, retirement, or any other employee welfare or pension benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbef87ce6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s653"},"text":"Pub. L. 97–35, title VI, § 653","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/507"},"text":"95 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/tI/s122"},"text":"Pub. L. 101–501, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1237"},"text":"104 Stat. 1237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/134/s22"},"text":"Pub. L. 110–134, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-12"},"text":"Dec. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1442"},"text":"121 Stat. 1442","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbef87ce7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbef87ce8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbef87ce9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/134"},"text":"Pub. L. 110–134","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" inserted at end “The Secretary shall encourage Head Start agencies to provide compensation according to salary scales that are based on training and experience.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbef87cea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbef87ceb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501"},"text":"Pub. L. 101–501","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
