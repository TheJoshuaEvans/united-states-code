{"tag":"section","attrib":{"id":"idbf0b8fc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10001"},"text":null,"children":[{"tag":"num","attrib":{"value":"10001"},"text":"§ 10001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf0b8fc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the interest of public health and safety to minimize unnecessary exposure to potentially hazardous radiation due to medical and dental radiologic procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the interest of public health and safety to have a continuing supply of adequately educated persons and appropriate accreditation and certification programs administered by State governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of the public health and safety from unnecessary exposure to potentially hazardous radiation due to medical and dental radiologic procedures and the assurance of efficacious procedures are the responsibility of State and Federal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons who administer radiologic procedures, including procedures at Federal facilities, should be required to demonstrate competence by reason of education, training, and experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf0b8fcd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the administration of radiologic procedures and the effect on individuals of such procedures have a substantial and direct effect upon United States interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf0b8fce-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s976"},"text":"Pub. L. 97–35, title IX, § 976","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/598"},"text":"95 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf0b8fcf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf0b8fd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbf0b8fd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIX/s975"},"text":"Pub. L. 97–35, title IX, § 975","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/598"},"text":"95 Stat. 598","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tIX/s975"},"text":"“This subtitle [subtitle I (§§ 975–983) of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", enacting this chapter] may be cited as the ‘Consumer-Patient Radiation Health and Safety Act of 1981’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
