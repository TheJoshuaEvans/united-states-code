{"tag":"section","attrib":{"id":"idbcf09f06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5024"},"text":null,"children":[{"tag":"num","attrib":{"value":"5024"},"text":"§ 5024.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of locally generated contributions in National Senior Service Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever locally generated contributions made to National Senior Service Corps projects under this subchapter are in excess of the amount required by the Director, the Director may not restrict the manner in which such contributions are expended if expenditures from locally generated contributions are not inconsistent with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcf09f07-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s224"},"text":"Pub. L. 93–113, title II, § 224","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/288/s16/a"},"text":"Pub. L. 98–288, § 16(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-05-21"},"text":"May 21, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/194"},"text":"98 Stat. 194","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/551/s10/b/1"},"text":"Pub. L. 99–551, § 10(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3077"},"text":"100 Stat. 3077","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tIX/s902/6"},"text":"Pub. L. 101–204, title IX, § 902(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1826"},"text":"103 Stat. 1826","c