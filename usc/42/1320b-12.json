{"tag":"section","attrib":{"id":"idb84d2eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–12"},"text":"§ 1320b–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on outcomes of health care services and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb84d2eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84d2eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Director of the Agency for Healthcare Research and Quality, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84d2eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support research with respect to the outcomes, effectiveness, and appropriateness of health care services and procedures in order to identify the manner in which diseases, disorders, and other health conditions can most effectively and appropriately be prevented, diagnosed, treated, and managed clinically; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84d2eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that the needs and priorities of the program under subchapter XVIII are appropriately reflected in the development and periodic review and updating (through the process set forth in section 299b–2 ","children":[{"tag":"ref","attrib":{"idref":"fn002714"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002714"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) of treatment-specific or condition-specific practice guidelines for clinical treatments and conditions in forms appropriate for use in clinical practice, for use in educational programs, and for use in reviewing quality and appropriateness of medical care."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84d2eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations of alternative services and procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall conduct or support evaluations of the comparative effects, on health and functional capacity, of alternative services and procedures utilized in preventing, diagnosing, treating, and clinically managing diseases, disorders, and other health conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84d2eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial guidelines","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84d2eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out paragraph (1)(B) of this subsection, and section 299b–1(d) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, the Secretary shall, by not later than "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", assure the development of an initial set of the guidelines specified in paragraph (1)(B) that shall include not less than 3 clinical treatments or conditions that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb84d2eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb84d2eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for a significant portion of expenditures under subchapter XVIII; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb84d2ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a significant variation in the frequency or the type of treatment provided; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb84d2ebc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meet the needs and priorities of the program under subchapter XVIII, as set forth under subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84d2ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb84d2ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide for the use of guidelines developed under subparagrah ","children":[{"tag":"ref","attrib":{"idref":"fn002715"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002715"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subparagraph”."}],"tail":" (A) to improve the quality, effectiveness, and appropriateness of care provided under subchapter XVIII. The Secretary shall determine the impact of such use on the quality, appropriateness, effectiveness, and cost of medical care provided under such subchapter and shall report to the Congress on such determination by not later than "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb84d2ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of carrying out clause (i), the Secretary shall expend, from the amounts specified in clause (iii), $1,000,000 for fiscal year 1990 and $1,500,000 for each of the fiscal years 1991 and 1992.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb84d2ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each fiscal year, for purposes of expenditures required in clause (ii)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb84d2ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent of an amount equal to the expenditure involved is appropriated from the Federal Hospital Insurance Trust Fund (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i"},"text":"section 1395i of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb84d2ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/a/3/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent of an amount equal to the expenditure involved is appropriated from the Federal Supplementary Medical Insurance Trust Fund (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"section 1395t of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84d2ec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84d2ec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish priorities with respect to the diseases, disorders, and other health conditions for which research and evaluations are to be conducted or supported under subsection (a). In establishing such priorities, the Secretary shall, with respect to a disease, disorder, or other health condition, consider the extent to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved methods of prevention, diagnosis, treatment, and clinical management can benefit a significant number of individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is significant variation among physicians in the particular services and procedures utilized in making diagnoses and providing treatments or there is significant variation in the outcomes of health care services or procedures due to different patterns of diagnosis or treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services and procedures utilized for diagnosis and treatment result in relatively substantial expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data necessary for such evaluations are readily available or can readily be developed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of establishing priorities under paragraph (1), the Secretary may, with respect to services and procedures utilized in preventing, diagnosing, treating, and clinically managing diseases, disorders, and other health conditions, conduct or support assessments of the extent to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates of utilization vary among similar populations for particular diseases, disorders, and other health conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uncertainties exist on the effect of utilizing a particular service or procedure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inappropriate services and procedures are provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship with medicare program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing priorities under paragraph (1) for research and evaluation, and under section 299b–3(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title for the agenda under such section, the Secretary shall assure that such priorities appropriately reflect the needs and priorities of the program under subchapter XVIII, as set forth by the Administrator of the Centers for Medicare & Medicaid Services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methodologies and criteria for evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of facilitating research under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support research with respect to the improvement of methodologies and criteria utilized in conducting research with respect to outcomes of health care services and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support reviews and evaluations of existing research findings with respect to such treatment or conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support reviews and evaluations of the existing methodologies that use large data bases in conducting such research and shall develop new research methodologies, including data-based methods of advancing knowledge and methodologies that measure clinical and functional status of patients, with respect to such research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants and contracts to research centers, and contracts to other entities, to conduct such research on such treatment or conditions, including research on the appropriate use of prescription drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support research and demonstrations on the use of claims data and data on clinical and functional status of patients in determining the outcomes, effectiveness, and appropriateness of such treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct and support supplementation of existing data bases, including the collection of new information, to enhance data bases for research purposes, and the design and development of new data bases that would be used in outcomes and effectiveness research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for data bases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall develop—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform definitions of data to be collected and used in describing a patient’s clinical and functional status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" common reporting formats and linkages for such data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards to assure the security, confidentiality, accuracy, and appropriate maintenance of such data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of research findings and guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the dissemination of the findings of research and the guidelines described in subsection (a), and for the education of providers and others in the application of such research findings and guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative educational activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In disseminating findings and guidelines under paragraph (1), and in providing for education under such paragraph, the Secretary shall work with professional associations, medical specialty and subspecialty organizations, and other relevant groups to identify and implement effective means to educate physicians, other providers, consumers, and others in using such findings and guidelines, including training for physician managers within provider organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct and support evaluations of the activities carried out under this section to determine the extent to which such activities have had an effect on the practices of physicians in providing medical treatment, the delivery of health care, and the outcomes of health care services and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research with respect to dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct or support research with respect to improving methods of disseminating information on the effectiveness and appropriateness of health care services and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 1990;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for fiscal year 1991;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $110,000,000 for fiscal year 1992;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $148,000,000 for fiscal year 1993; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $185,000,000 for fiscal year 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of carrying out this section, for each of the fiscal years 1990 through 1992 an amount equal to two-thirds of the amounts authorized to be appropriated under paragraph (1), and for each of the fiscal years 1993 and 1994 an amount equal to 70 percent of such amounts, are to be appropriated in the following proportions from the following trust funds:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent from the Federal Hospital Insurance Trust Fund (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395i"},"text":"section 1395i of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent from the Federal Supplementary Medical Insurance Trust Fund (established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"section 1395t of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year, of the amounts transferred or otherwise appropriated to carry out this section, the Secretary shall reserve appropriate amounts for each of the purposes specified in clauses (i) through (iv) of subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The purposes referred to in subparagraph (A) are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb84f78dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of guidelines, standards, performance measures, and review criteria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb84f78dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb84f78de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data-base standards and development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb84f78df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–12/i/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and information dissemination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb84f78e0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1142, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/b/1"},"text":"Pub. L. 101–239, title VI, § 6103(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2195"},"text":"103 Stat. 2195","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/b/2"},"text":"Pub. L. 106–129, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1670"},"text":"113 Stat. 1670","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tIX/s900/e/1/C"},"text":"Pub. L. 108–173, title IX, § 900(e)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2371"},"text":"117 Stat. 2371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb84f78e1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb84f78e2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb84f78e3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 299b–1 to 299b–3 of this title, referred to in subsecs. (a) and (b), were in the original references to sections 912 to 914 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which were omitted in the general amendment of subchapter VII of chapter 6A of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Pub. L. 106–129, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-06"},"text":"Dec. 6, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1653"},"text":"113 Stat. 1653","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/106/129/s2/a"},"text":"Section 2(a) of Pub. L. 106–129","children":[],"tail":" enacted new sections 912 to 914 of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which are classified to sections 299b–1 to 299b–3, respectively, of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb84f78e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h) of this section, which required the Secretary to report biennially to Congress on the progress of the activities under this section during the preceding 2 fiscal years, including the impact of such activities on medical care (particularly medical care for individuals receiving benefits under subchapter XVIII of this chapter), terminated, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance. See, also, item 10 on page 94 of House Document No. 103–7."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 1142 of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", was renumbered section 1143 by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5111/a/1"},"text":"Pub. L. 101–508, title V, § 5111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-272"},"text":"104 Stat. 1388–272","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–13"},"text":"section 1320b–13 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb84f78e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s900/e/1/C"},"text":"Pub. L. 108–173, § 900(e)(1)(C)","children":[],"tail":", substituted “Centers for Medicare & Medicaid Services” for “Health Care Financing Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":" substituted “Director of the Agency for Healthcare Research and Quality” for “Administrator for Health Care Policy and Research” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb84f78e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb84f78e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"AHCPR Study on Effect of Credentialing of Technologists and Sonographers on Quality of Ultrasound","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/6/tII/s229/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(6) [title II, § 229(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–357, required a study on the effect of credentialing of technologists and sonographers on the quality of ultrasounds and submission of a report to Congress no later than two years after "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb84f78e8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Linkage of Public and Private Research Related Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/b/2"},"text":"Pub. L. 101–239, title VI, § 6103(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2198"},"text":"103 Stat. 2198","children":[],"tail":", provided that, no later than 1 year after "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", the Secretary of Health and Human Services would report to Congress on the feasibility of linking research-related data described in subsec. (d) of this section with similar data collected or maintained by non-Federal entities and by Federal agencies other than the Department of Health and Human Services (including the Departments of Defense and Veterans Affairs and the Office of Personnel Management)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
