{"tag":"section","attrib":{"id":"idb6a4d695-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–138"},"text":"§ 300ff–138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6a4d696-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of medical facilities, designated officers, public health officers, and governing entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part may not be construed to authorize any cause of action for damages or any civil penalty against any medical facility, any designated officer, any other public health officer, or any governing entity of such facility or officer for failure to comply with the duties established in this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d697-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part may not, with respect to victims of emergencies, be construed to authorize or require a medical facility to test any such victim for any infectious disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d698-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part may not be construed to authorize or require any medical facility, any designated officer of emergency response employees, or any such employee, to disclose identifying information with respect to a victim of an emergency or with respect to an emergency response employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d699-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to provide emergency services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This part may not be construed to authorize any emergency response employee to fail to respond, or to deny services, to any victim of an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d69a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and reporting deadlines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the Secretary determines that, wholly or partially as a result of a public health emergency that has been determined pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d/a"},"text":"section 247d(a) of this title","children":[],"tail":", individuals or public or private entities are unable to comply with the requirements of this part, the Secretary may, notwithstanding any other provision of law, temporarily suspend, in whole or in part, the requirements of this part as the circumstances reasonably require. Before or promptly after such a suspension, the Secretary shall notify the Congress of such action and publish in the Federal Register a notice of the suspension."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6a4d69b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–138/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued application of State and local law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to limit the application of State or local laws that require the provision of data to public health authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6a4d69c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2695G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s13"},"text":"Pub. L. 111–87, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2902"},"text":"123 Stat. 2902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6a4d69d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6a4d69e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6a4d69f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as if enacted on ","children":[{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/3/B"},"text":"section 2(a)(3)(B) of Pub. L. 111–87","children":[],"tail":", set out as an Effective Date of 2009 Amendment; Revival of Section note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
