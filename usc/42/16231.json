{"tag":"section","attrib":{"id":"idbffa0ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231"},"text":null,"children":[{"tag":"num","attrib":{"value":"16231"},"text":"§ 16231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewable energy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Objectives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct programs of renewable energy research, development, demonstration, and commercial application, including activities described in this part. Such programs shall take into consideration the following objectives:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the conversion efficiency of all forms of renewable energy through improved technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the cost of renewable energy generation and delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promoting the diversity of the energy supply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the dependence of the United States on foreign energy supplies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving United States energy security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Decreasing the environmental impact of energy-related activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the export of renewable generation equipment from the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geothermal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for geothermal energy. The program shall focus on developing improved technologies for reducing the costs of geothermal energy installations, including technologies for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0ef5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving detection of geothermal resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0ef6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreasing drilling costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0ef7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreasing maintenance costs through improved materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0ef8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the potential for other revenue sources, such as mineral production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0ef9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the understanding of reservoir life cycle and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0efa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydropower","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for cost competitive technologies that enable the development of new and incremental hydropower capacity, adding to the diversity of the energy supply of the United States, including:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fish-friendly large turbines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced technologies to enhance environmental performance and yield greater energy efficiencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct research, development, demonstration, and commercial application programs for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ocean energy, including wave energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the combined use of renewable energy technologies with one another and with other energy technologies, including the combined use of wind power and coal gasification technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable energy technologies for cogeneration of hydrogen and electricity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kinetic hydro turbines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out renewable energy research, development, demonstration, and commercial application activities, including activities authorized under this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $632,000,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $743,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $852,000,000 for fiscal year 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $963,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts authorized under subsection (b), there are authorized to be appropriated to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16232"},"text":"section 16232 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $213,000,000 for fiscal year 2007, of which $100,000,000 shall be for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16232/d"},"text":"section 16232(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $377,000,000 for fiscal year 2008, of which $125,000,000 shall be for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16232/d"},"text":"section 16232(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $398,000,000 for fiscal year 2009, of which $150,000,000 shall be for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16232/d"},"text":"section 16232(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $419,000,000 for fiscal year 2010, of which $150,000,000 shall be for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16232/d"},"text":"section 16232(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds authorized under subsection (c), not less than $5,000,000 for each fiscal year shall be made available for grants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" part B institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tribal Colleges or Universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1059c/b"},"text":"section 1059c(b) of title 20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic-serving institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural demonstration projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary, in consultation with the Secretary of Agriculture, shall demonstrate the use of renewable energy technologies to assist in delivering electricity to rural and remote locations including —","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced wind power technology, including combined use with coal gasification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biomass; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geothermal energy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct analysis and evaluation in support of the renewable energy programs under this part. These activities shall be used to guide budget and program decisions, and shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0f16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic and technical analysis of renewable energy potential, including resource assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis of past program performance, both in terms of technical advances and in market introduction of renewable energy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other analysis or evaluation that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16231/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate up to 1 percent of the funds appropriated for carrying out this part for analysis and evaluation activities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0f1a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s931"},"text":"Pub. L. 109–58, title IX, § 931","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/868"},"text":"119 Stat. 868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s231"},"text":"Pub. L. 110–140, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1536"},"text":"121 Stat. 1536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3006/b/3"},"text":"Pub. L. 116–260, div. Z, title III, § 3006(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2512"},"text":"134 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbffa0f1b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbffa0f1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbffa0f1d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s3006/b/3/A/i"},"text":"Pub. L. 116–260, § 3006(b)(3)(A)(i)","children":[],"tail":", (ii), redesignated subpars. (C) to (E) as (A) to (C), respectively, and struck out former subpars. (A) and (B) which related to solar and wind energy programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s3006/b/3/B"},"text":"Pub. L. 116–260, § 3006(b)(3)(B)","children":[],"tail":", (C), redesignated subsecs. (e) to (g) as (d) to (f), respectively, and struck out former subsec. (d) which related to solar power."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s231/1"},"text":"Pub. L. 110–140, § 231(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s231/2"},"text":"Pub. L. 110–140, § 231(2)","children":[],"tail":", in par. (2), substituted “$377,000,000” for “$251,000,000”, in par. (3), substituted “$398,000,000” for “$274,000,000”, and added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbffa0f1e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbffa0f1f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"