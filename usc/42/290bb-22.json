{"tag":"section","attrib":{"id":"idb5a82608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"290bb–22"},"text":"§ 290bb–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority substance use disorder prevention needs of regional and national significance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5a82609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall address priority substance use disorder prevention needs of regional and national significance (as determined under subsection (b)) through the provision of or through assistance for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a8260a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge development and application projects for prevention and the conduct or support of evaluations of such projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a8260b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a8260c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" targeted capacity response programs, including such programs that focus on emerging drug use issues.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may carry out the activities described in this section directly or through grants, contracts, or cooperative agreements with States, political subdivisions of States, Indian Tribes or Tribal organizations (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), health facilities, or programs operated by or in accordance with a contract or grant with the Indian Health Service, or other public or nonprofit private entities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a8260d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority substance use disorder prevention needs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a8260e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Priority substance use disorder prevention needs of regional and national significance shall be determined by the Secretary in consultation with the States and other interested groups. The Secretary shall meet with the States and interested groups on an annual basis to discuss program priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a8260f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing program priorities under paragraph (1), the Secretary shall give special consideration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5a82610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying the most promising strategies and research-based primary prevention approaches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a82611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the integration of substance use disorder prevention information and activities into primary health care systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5a82612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance use disorder prevention among high-risk groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a82613-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5a82614-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of grants, contracts, and cooperative agreements under this section shall comply with information and application requirements determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a82615-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant, contract, or cooperative agreement awarded under this section, the period during which payments under such award are made to the recipient may not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a82616-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, for projects carried out under subsection (a), require that entities that apply for grants, contracts, or cooperative agreements under that project provide non-Federal matching funds, as determined appropriate by the Secretary, to ensure the institutional commitment of the entity to the projects funded under the grant, contract, or cooperative agreement. Such non-Federal matching funds may be provided directly or through donations from public or private entities and may be in cash or in kind, fairly evaluated, including plant, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5a82617-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to activities for which a grant, contract, or cooperative agreement is awarded under this section, the Secretary may require that recipients for specific projects under subsection (a) agree to maintain expenditures of non-Federal amounts for such activities at a level that is not less than the level of such expenditures maintained by the entity for the fiscal year preceding the fiscal year for which the entity receives such a grant, contract, or cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a82618-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate each project carried out under subsection (a)(1) and shall disseminate the findings with respect to each such evaluation to appropriate public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a82619-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish comprehensive information and education programs to disseminate the findings of the knowledge development and application, training and technical assistance programs, and targeted capacity response programs under this section to the general public and to health professionals. The Secretary shall make every effort to provide linkages between the findings of supported projects and State agencies responsible for carrying out substance use disorder prevention and treatment programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5a8261a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290bb–22/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section, $218,219,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5a8261b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 516, formerly § 509, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4005/a"},"text":"Pub. L. 99–570, title IV, § 4005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-112"},"text":"100 Stat. 3207–112","children":[],"tail":"; renumbered § 516 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s113/f"},"text":"Pub. L. 102–321, title I, § 113(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/345"},"text":"106 Stat. 345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIII/s3302/a"},"text":"Pub. L. 106–310, div. B, title XXXIII, § 3302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1209"},"text":"114 Stat. 1209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVII/s7005"},"text":"Pub. L. 114–255, div. B, title VII, § 7005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1224"},"text":"130 Stat. 1224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tI/s1214"},"text":"Pub. L. 117–328, div. FF, title I, § 1214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5661"},"text":"136 Stat. 5661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5a8261c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5a8261d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5a8261e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–7"},"text":"section 290aa–7 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5a8261f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 516 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s290cc–1"},"text":"section 290cc–1 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s123/c"},"text":"Pub. L. 102–321, title I, § 123(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/363"},"text":"106 Stat. 363","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5a82620-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1214/1/B"},"text":"Pub. L. 117–328, § 1214(1)(B)","children":[],"tail":", substituted “Tribes or Tribal organizations” for “tribes or tribal organizations” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1214/1/A"},"text":"Pub. L. 117–328, § 1214(1)(A)","children":[],"tail":", substituted “use” for “abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1214/2"},"text":"Pub. L. 117–328, § 1214(2)","children":[],"tail":", substituted “use disorder” for “abuse” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s1214/3"},"text":"Pub. L. 117–328, § 1214(3)","children":[],"tail":", substituted “$218,219,000 for each of fiscal years 2023 through 2027” for “$211,148,000 for each of fiscal years 2018 through 2022”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7005/1"},"text":"Pub. L. 114–255, § 7005(1)","children":[],"tail":", substituted “use disorder” for “abuse” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7005/2/A"},"text":"Pub. L. 114–255, § 7005(2)(A)","children":[],"tail":", (C), in introductory provisions, substituted “use disorder” for “abuse” and, in concluding provisions, inserted “, contracts,” before “or cooperative agreements” and substituted “Indian tribes or tribal organizations (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), health facilities, or programs operated by or in accordance with a contract or grant with the Indian Health Service,” for “Indian tribes and tribal organizations,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7005/2/B"},"text":"Pub. L. 114–255, § 7005(2)(B)","children":[],"tail":", inserted “, including such programs that focus on emerging drug abuse issues” before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7005/3"},"text":"Pub. L. 114–255, § 7005(3)","children":[],"tail":", substituted “use disorder” for “abuse” in pars. (1) and (2)(B) and added par. (2)(C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7005/4"},"text":"Pub. L. 114–255, § 7005(4)","children":[],"tail":", substituted “use disorder” for “abuse”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s7005/5"},"text":"Pub. L. 114–255, § 7005(5)","children":[],"tail":", substituted “$211,148,000 for each of fiscal years 2018 through 2022.” for “$300,000,000 for fiscal year 2001, and such sums as may be necessary for each of the fiscal years 2002 and 2003.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to priority substance abuse prevention needs of regional and national significance for provisions relating to community programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321/s113/f/4"},"text":"Pub. L. 102–321, § 113(f)(4)","children":[],"tail":", amended section generally, substituting provisions relating to community programs for provisions relating to alcohol and drug abuse information clearinghouse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5a82621-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5a82622-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
