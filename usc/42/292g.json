{"tag":"section","attrib":{"id":"idb5d09610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g"},"text":null,"children":[{"tag":"num","attrib":{"value":"292g"},"text":"§ 292g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk-based premiums","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5d09611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a loan made under this subpart on or after ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":", the Secretary, in accordance with subsection (b), shall assess a risk-based premium on an eligible borrower and, if required under this section, an eligible institution that is based on the default rate of the eligible institution involved (as defined in section 292"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d09612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of premium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d)(2), the risk-based premium to be assessed under subsection (a) shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d30713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-risk rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an eligible borrower seeking to obtain a loan for attendance at an eligible institution that has a default rate of not to exceed five percent, such borrower shall be assessed a risk-based premium in an amount equal to 6 percent of the principal amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medium-risk rate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d30715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an eligible borrower seeking to obtain a loan for attendance at an eligible institution that has a default rate of in excess of five percent but not to exceed 10 percent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d30716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such borrower shall be assessed a risk-based premium in an amount equal to 8 percent of the principal amount of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d30717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such institution shall be assessed a risk-based premium in an amount equal to 5 percent of the principal amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d30718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of the type described in subparagraph (A) shall prepare and submit to the Secretary for approval, an annual default management plan, that shall specify the detailed short-term and long-term procedures that such institution will have in place to minimize defaults on loans to borrowers under this subpart. Under such plan the institution shall, among other measures, provide an exit interview to all borrowers that includes information concerning repayment schedules, loan deferments, forbearance, and the consequences of default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-risk rate","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d3071a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an eligible borrower seeking to obtain a loan for attendance at an eligible institution that has a default rate of in excess of 10 percent but not to exceed 20 percent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5d3071b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such borrower shall be assessed a risk-based premium in an amount equal to 8 percent of the principal amount of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5d3071c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such institution shall be assessed a risk-based premium in an amount equal to 10 percent of the principal amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d3071d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default management plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution of the type described in subparagraph (A) shall prepare and submit to the Secretary for approval a plan that meets the requirements of paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d3071e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual shall not be eligible to obtain a loan under this subpart for attendance at an institution that has a default rate in excess of 20 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d3071f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of risk-based premium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Lenders shall reduce by 50 percent the risk-based premium to eligible borrowers if a credit worthy parent or other responsible party co-signs the loan note.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d30720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative waivers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5d30721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall afford an institution not less than one hearing, and may consider mitigating circumstances, prior to making such institution ineligible for participation in the program under this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section with respect to an institution, the Secretary may grant an institution a waiver of requirements of paragraphs (2) through (4) of subsection (b) if the Secretary determines that the default rate for such institution is not an accurate indicator because the volume of the loans under this subpart made by such institution has been insufficient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5d30723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition for certain institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the 3-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1992-10-13"},"text":"October 13, 1992","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5d30724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(4) shall not apply with respect to any eligible institution that is a Historically Black College or University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5d30725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any such institution that has a default rate in excess of 20 percent, and any eligible borrower seeking a loan for attendance at the institution, shall be subject to subsection (b)(3) to the same extent and in the same manner as eligible institutions and borrowers described in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5d30726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s292g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payoff to reduce risk category","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An institution may pay off the outstanding principal and interest owed by the borrowers of such institution who have defaulted on loans made under this subpart in order to reduce the risk category of the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5d30727-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 708, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2004"},"text":"106 Stat. 2004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5d30728-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5d30729-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5d3072a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 292g, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s707"},"text":"act July 1, 1944, ch. 373, title VII, § 707","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s205"},"text":"Pub. L. 94–484, title II, § 205","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2249"},"text":"90 Stat. 2249","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/r"},"text":"Pub. L. 95–83, title III, § 307(r)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/395"},"text":"91 Stat. 395","children":[],"tail":", related to delegation of authority by the Secretary, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 292g, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s708"},"text":"act July 1, 1944, ch. 373, title VII, § 708","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-30/ch779/s2"},"text":"July 30, 1956, ch. 779, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/720"},"text":"70 Stat. 720","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1961-10-05"},"text":"Oct. 5, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/395/s8/d"},"text":"Pub. L. 87–395, § 8(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/827"},"text":"75 Stat. 827","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/129/s2/a"},"text":"Pub. L. 88–129, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/164"},"text":"77 Stat. 164","children":[],"tail":", prohibited Federal interference with administration of institutions where grants were made for construction of health research facilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tII/s201/a"},"text":"Pub. L. 94–484, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2246"},"text":"90 Stat. 2246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 708 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292h"},"text":"section 292h of this title","children":[],"tail":" prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5d3072b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5d3072c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1993-01-01"},"text":"Jan. 1, 1993","children":[],"tail":", and until such date, former "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294e/c"},"text":"section 294e(c) of this title","children":[],"tail":", as in effect on the day before "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", to continue in effect in lieu of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/s103"},"text":"section 103 of Pub. L. 102–408","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292"},"text":"section 292 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
