{"tag":"section","attrib":{"id":"idbb0ee6d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437aaa–5"},"text":"§ 1437aaa–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0ee6d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “applicant” means the following entities that may represent the tenants of the project:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public housing agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A resident management corporation, established in accordance with requirements of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437r"},"text":"section 1437r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A resident council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cooperative association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public or private nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public body, including an agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible family” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0ee6d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a family or individual who is a tenant in the public housing project on the date the Secretary approves an implementation grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a low-income family; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a family or individual who is assisted under a housing program administered by the Secretary or the Secretary of Agriculture (not including any non-low income families assisted under any mortgage insurance program administered by either Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “homeownership program” means a program for homeownership meeting the requirements under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “recipient” means an applicant approved to receive a grant under this subchapter or such other entity specified in the approved application that will assume the obligations of the recipient under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “resident council” means any incorporated nonprofit organization or association that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb0ee6df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is representative of the tenants of the housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopts written procedures providing for the election of officers on a regular basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb0ee6e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–5/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a democratically elected governing board, elected by the tenants of the housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0ee6e2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title III, § 306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s411"},"text":"Pub. L. 101–625, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4158"},"text":"104 Stat. 4158","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/tV/s501/c/2"},"text":"Pub. L. 104–330, title V, § 501(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4042"},"text":"110 Stat. 4042","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb0ee6e3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb0ee6e4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb0ee6e5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/s501/c/2/A"},"text":"Pub. L. 104–330, § 501(c)(2)(A)","children":[],"tail":", struck out “(including an Indian housing authority)” after “agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330/s501/c/2/B"},"text":"Pub. L. 104–330, § 501(c)(2)(B)","children":[],"tail":", struck out “or Indian” after “public”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb0ee6e6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb0ee6e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/330"},"text":"Pub. L. 104–330","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/330/s107"},"text":"section 107 of Pub. L. 104–330","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s4101"},"text":"section 4101 of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
