{"tag":"section","attrib":{"id":"idbfcf06ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14335"},"text":null,"children":[{"tag":"num","attrib":{"value":"14335"},"text":"§ 14335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on sale of other mercuric-oxide batteries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfcf0700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or after ","children":[{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", no person shall sell, offer for sale, or offer for promotional purposes a mercuric-oxide battery for use in the United States unless the battery manufacturer, or the importer of such a battery—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfcf0701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies a collection site in the United States that has all required Federal, State, and local government approvals, to which persons may send used mercuric-oxide batteries for recycling or proper disposal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs each of its purchasers of mercuric-oxide batteries of the collection site identified under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfcf0703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14335/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs each of its purchasers of mercuric-oxide batteries of a telephone number that the purchaser may call to get information about sending mercuric-oxide batteries for recycling or proper disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfcf0704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s14335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply to a sale or offer of a mercuric-oxide button cell battery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfcf0705-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/142/tII/s206"},"text":"Pub. L. 104–142, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-05-13"},"text":"May 13, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1336"},"text":"110 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
