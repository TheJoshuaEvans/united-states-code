{"tag":"section","attrib":{"id":"idbb0ee6f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"1437aaa–8"},"text":"§ 1437aaa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually submit to the Congress a report setting forth—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb0ee6f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–8/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number, type, and cost of public housing units sold pursuant to this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–8/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income, race, gender, children, and other characteristics of families participating (or not participating) in homeownership programs funded under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–8/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and type of financial assistance provided under and in conjunction with this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–8/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of financial assistance provided under this subchapter that was needed to ensure continued affordability and meet future maintenance and repair costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb0ee6f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1437aaa–8/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Secretary for statutory and regulatory improvements to the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb0ee6f9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-09-01/ch896"},"text":"Sept. 1, 1937, ch. 896","children":[],"tail":", title III, § 309, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIV/s411"},"text":"Pub. L. 101–625, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4159"},"text":"104 Stat. 4159","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
