{"tag":"section","attrib":{"id":"idb64ca396-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f"},"text":null,"children":[{"tag":"num","attrib":{"value":"300j–19f"},"text":"§ 300j–19f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational sustainability of small public water systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb64ca397-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca398-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca399-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca39a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca39b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public corporation established by a unit of local government to provide water service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca39c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit corporation, public trust, or cooperative association that owns or operates a public water system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca39d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe that owns or operates a public water system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca39e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization that provides technical assistance to public water systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca39f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational sustainability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational sustainability” means the ability to improve the operation of a small system through the identification and prevention of potable water loss due to leaks, breaks, and other metering or infrastructure failures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the grant program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “small system”, for the purposes of this section, means a public water system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves fewer than 10,000 people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is owned or operated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb64ca3a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cooperative association; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb64ca3aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, the Administrator shall establish a program to award grants to eligible entities for the purpose of improving the operational sustainability of 1 or more small systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under the program, an eligible entity shall submit to the Administrator an application at such time, in such manner, and containing such information as the Administrator may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal of the project to be carried out using grant funds under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation provided by the eligible entity describing the deficiencies or suspected deficiencies in operational sustainability of 1 or more small systems that are to be addressed through the proposed project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the proposed project will improve the operational sustainability of 1 or more small systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the improvements described in paragraph (3) will be maintained beyond the life of the proposed project, including a plan to maintain and update any asset data collected as a result of the proposed project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional information the Administrator may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional required information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the award of funds for a grant under the program to a grant recipient, the grant recipient shall submit to the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the grant recipient is located in a State that has established a State drinking water treatment revolving loan fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of this title","children":[],"tail":", a copy of a written agreement between the grant recipient and the State in which the grant recipient agrees to provide a copy of any data collected under the proposed project to the State agency administering the State drinking water treatment revolving loan fund (or a designee); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the grant recipient is located in an area other than a State that has established a State drinking water treatment revolving loan fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300j–12"},"text":"section 300j–12 of this title","children":[],"tail":", a copy of a written agreement between the grant recipient and the Administrator in which the eligible entity agrees to provide a copy of any data collected under the proposed project to the Administrator (or a designee)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the program shall use the grant funds to carry out projects that improve the operational sustainability of 1 or more small systems through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a detailed asset inventory, which may include drinking water sources, wells, storage, valves, treatment systems, distribution lines, hydrants, pumps, controls, and other essential infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development of an infrastructure asset map, including a map that uses technology such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic information system software; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global positioning system software;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment of leak detection technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment of metering technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training in asset management strategies, techniques, and technologies for appropriate staff employed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb64ca3bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb64ca3be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the small systems for which the grant was received;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deployment of strategies, techniques, and technologies to enhance the operational sustainability and effective use of water resources through water reuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development or deployment of other strategies, techniques, or technologies that the Administrator may determine to be appropriate under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb64ca3c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Federal share of the cost of a project carried out using a grant under the program shall be 90 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb64ca3c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may increase the Federal share under paragraph (1) to 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall submit to Congress a report that describes the implementation of the program, which shall include a description of the use and deployment of amounts made available under the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb64ca3c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300j–19f/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb64ca3c6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIV, § 1459E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dE/tI/s50106"},"text":"Pub. L. 117–58, div. E, title I, § 50106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1142"},"text":"135 Stat. 1142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
