{"tag":"section","attrib":{"id":"idbffa0f59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234"},"text":null,"children":[{"tag":"num","attrib":{"value":"16234"},"text":"§ 16234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concentrating solar power research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0f5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a program of research and development to evaluate the potential for concentrating solar power for hydrogen production, including cogeneration approaches for both hydrogen and electricity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall take advantage of existing facilities to the extent practicable and shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of optimized technologies that are common to both electricity and hydrogen production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of thermochemical cycles for hydrogen production at the temperatures attainable with concentrating solar power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of materials issues for the thermochemical cycles described in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cogeneration of solar thermal electric power and photo-synthetic-based hydrogen production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" system architectures and economics studies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with activities under the Next Generation Nuclear Plant Project established under part B of subchapter VI on high temperature materials, thermochemical cycles, and economic issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess conflicting guidance on the economic potential of concentrating solar power for electricity production received from the National Research Council in the report entitled “Renewable Power Pathways: A Review of the U.S. Department of Energy’s Renewable Energy Programs” and dated 2000 and subsequent reviews of that report funded by the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an assessment of the potential impact of technology used to concentrate solar power for electricity before, or concurrent with, submission of the budget for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16234/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall provide to Congress a report on the economic and technical potential for electricity or hydrogen production, with or without cogeneration, with concentrating solar power, including the economic and technical feasibility of potential construction of a pilot demonstration facility suitable for commercial production of electricity or hydrogen from concentrating solar power."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0f66-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s934"},"text":"Pub. L. 109–58, title IX, § 934","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/872"},"text":"119 Stat. 872","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
