{"tag":"section","attrib":{"id":"idbd526e26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5415"},"text":null,"children":[{"tag":"num","attrib":{"value":"5415"},"text":"§ 5415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by manufacturer of conformity of manufactured home with standards; form and placement of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every manufacturer of manufactured homes shall furnish to the distributor or retailer at the time of delivery of each such manufactured home produced by such manufacturer certification that such manufactured home conforms to all applicable Federal construction and safety standards. Such certification shall be in the form of a label or tag permanently affixed to each such manufactured home.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd526e27-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/383/tVI/s616"},"text":"Pub. L. 93–383, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-22"},"text":"Aug. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/711"},"text":"88 Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/399/tIII/s308/c/4"},"text":"Pub. L. 96–399, title III, § 308(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-08"},"text":"Oct. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1641"},"text":"94 Stat. 1641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tIII/s339B/c"},"text":"Pub. L. 97–35, title III, § 339B(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/417"},"text":"95 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVI/s603/b/4"},"text":"Pub. L. 106–569, title VI, § 603(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2999"},"text":"114 Stat. 2999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd526e28-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd526e29-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbd526e2a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to “mobile homes”, wherever appearing in text, changed to “manufactured homes” in view of the amendment of title VI of the Housing and Community Development Act of 1974 (this chapter) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399/s308/c/4"},"text":"section 308(c)(4) of Pub. L. 96–399","children":[],"tail":" requiring the substitution of “manufactured home” for “mobile home” wherever appearing in title VI of the Housing and Community Development Act of 1974, and "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s339B/c"},"text":"section 339B(c) of Pub. L. 97–35","children":[],"tail":" (set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1703"},"text":"section 1703 of Title 12","children":[],"tail":", Banks and Banking) providing that the terms “mobile home” and “manufactured home” shall be deemed to include the terms “mobile homes” and “manufactured homes”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd526e2b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" substituted “retailer” for “dealer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/399"},"text":"Pub. L. 96–399","children":[],"tail":" substituted “manufactured home” for “mobile home” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd526e2c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd526e2d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", except that amendment has no effect on any order or interpretative bulletin issued under this chapter and published as a proposed rule pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"5 U.S.C. 553","children":[],"tail":" on or before "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s612"},"text":"section 612 of Pub. L. 106–569","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"