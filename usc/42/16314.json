{"tag":"section","attrib":{"id":"idc00d20ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16314"},"text":null,"children":[{"tag":"num","attrib":{"value":"16314"},"text":"§ 16314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrogen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc00d2100-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a program of fundamental research and development in support of programs authorized under subchapter VIII.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc00d2101-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall include support for methods of generating hydrogen without the use of natural gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc00d2102-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s974"},"text":"Pub. L. 109–58, title IX, § 974","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/903"},"text":"119 Stat. 903","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
