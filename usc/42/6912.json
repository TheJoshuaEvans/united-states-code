{"tag":"section","attrib":{"id":"idbdc999e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912"},"text":null,"children":[{"tag":"num","attrib":{"value":"6912"},"text":"§ 6912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of Administrator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc999e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, the Administrator is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc999e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe, in consultation with Federal, State, and regional authorities, such regulations as are necessary to carry out his functions under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc999e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with or exchange information with other Federal agencies undertaking research, development, demonstration projects, studies, or investigations relating to solid waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc999e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical and financial assistance to States or regional agencies in the development and implementation of solid waste plans and hazardous waste management programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc999e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with representatives of science, industry, agriculture, labor, environmental protection and consumer organizations, and other groups, as he deems advisable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc999e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize the information, facilities, personnel and other resources of Federal agencies, including the National Institute of Standards and Technology and the National Bureau of the Census, on a reimbursable basis, to perform research and analyses and conduct studies and investigations related to resource recovery and conservation and to otherwise carry out the Administrator’s functions under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc999ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to delegate to the Secretary of Transportation the performance of any inspection or enforcement function under this chapter relating to the transportation of hazardous waste where such delegation would avoid unnecessary duplication of activity and would carry out the objectives of this chapter and of chapter 51 of title 49.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc999eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each regulation promulgated under this chapter shall be reviewed and, where necessary, revised not less frequently than every three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc999ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the provisions of this chapter, the Administrator, and duly-designated agents and employees of the Environmental Protection Agency, are authorized to initiate and conduct investigations under the criminal provisions of this chapter, and to refer the results of these investigations to the Attorney General for prosecution in appropriate cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc999ed-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s2002"},"text":"Pub. L. 89–272, title II, § 2002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2804"},"text":"90 Stat. 2804","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/482/s5"},"text":"Pub. L. 96–482, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2335"},"text":"94 Stat. 2335","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/616/tIV/s403/d/4"},"text":"Pub. L. 98–616, title IV, § 403(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3272"},"text":"98 Stat. 3272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tV/s5115/c"},"text":"Pub. L. 100–418, title V, § 5115(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1433"},"text":"102 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdc999ee-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdc999ef-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdc999f0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(6), “chapter 51 of title 49” substituted for “the Hazardous Materials Transportation Act [49 App. U.S.C. 1801 et seq.]” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbdc999f1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":" substituted “National Institute of Standards and Technology” for “National Bureau of Standards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/616"},"text":"Pub. L. 98–616","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482"},"text":"Pub. L. 96–482","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbdc999f2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbdc999f3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Administrator or other official of Environmental Protection Agency under this chapter to Federal Inspector, Office of Federal Inspector for the Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
