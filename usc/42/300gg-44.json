{"tag":"section","attrib":{"id":"idb6b59ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–44"},"text":"§ 300gg–44.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State flexibility in individual market reforms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6b59ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of requirements where implementation of acceptable alternative mechanism","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b59ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–41"},"text":"section 300gg–41 of this title","children":[],"tail":" shall not apply with respect to health insurance coverage offered in the individual market in the State so long as a State is found to be implementing, in accordance with this section and consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–62/b"},"text":"section 300gg–62(b) of this title","children":[],"tail":", an alternative mechanism (in this section referred to as an “acceptable alternative mechanism”)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b59ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which all eligible individuals are provided a choice of health insurance coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which such coverage does not impose any preexisting condition exclusion with respect to such coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which such choice of coverage includes at least one policy form of coverage that is comparable to comprehensive health insurance coverage offered in the individual market in such State or that is comparable to a standard option of coverage available under the group or individual health insurance laws of such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a State which is implementing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b59ec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a model act described in subsection (c)(1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b59ec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified high risk pool described in subsection (c)(2), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b59ec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism described in subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59ec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible forms of mechanisms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A private or public individual health insurance mechanism (such as a health insurance coverage pool or programs, mandatory group conversion policies, guaranteed issue of one or more plans of individual health insurance coverage, or open enrollment by one or more health insurance issuers), or combination of such mechanisms, that is designed to provide access to health benefits for individuals in the individual market in the State in accordance with this section may constitute an acceptable alternative mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b59ec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of acceptable alternative mechanisms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b59ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b59eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the succeeding provisions of this subsection, a State is presumed to be implementing an acceptable alternative mechanism in accordance with this section as of ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":", if, by not later than "},{"tag":"date","attrib":{"date":"1997-04-01"},"text":"April 1, 1997","children":[],"tail":", the chief executive officer of a State—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb6b59ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the Secretary that the State has enacted or intends to enact (by not later than ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", or "},{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":", in the case of a State described in subparagraph (B)(ii)) any necessary legislation to provide for the implementation of a mechanism reasonably designed to be an acceptable alternative mechanism as of "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002474"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002474"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" (or, in the case of a State described in subparagraph (B)(ii), "},{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b59ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the Secretary with such information as the Secretary may require to review the mechanism and its implementation (or proposed implementation) under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay permitted for certain States","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b59ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of delay","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a State described in clause (ii) that provides notice under subparagraph (A)(i), for the presumption to continue on and after ","children":[{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":", the chief executive officer of the State by "},{"tag":"date","attrib":{"date":"1998-04-01"},"text":"April 1, 1998","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb6b59ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must notify the Secretary that the State has enacted any necessary legislation to provide for the implementation of a mechanism reasonably designed to be an acceptable alternative mechanism as of ","children":[{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6b59ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must provide the Secretary with such information as the Secretary may require to review the mechanism and its implementation (or proposed implementation) under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b59ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State described in this clause is a State that has a legislature that does not meet within the 12-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order for a mechanism to continue to be presumed to be an acceptable alternative mechanism, the State shall provide the Secretary every 3 years with information described in subparagraph (A)(ii) or (B)(i)(II) (as the case may be).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59ed3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary finds, after review of information provided under paragraph (1) and in consultation with the chief executive officer of the State and the insurance commissioner or chief insurance regulatory official of the State, that such a mechanism is not an acceptable alternative mechanism or is not (or no longer) being implemented, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b59ed4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall notify the State of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6b59ed5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such preliminary determination, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6b59ed6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences under paragraph (3) of a failure to implement such a mechanism; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ed7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall permit the State a reasonable opportunity in which to modify the mechanism (or to adopt another mechanism) in a manner so that may be an acceptable alternative mechanism or to provide for implementation of such a mechanism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59ed8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after providing notice and opportunity under paragraph (2), the Secretary finds that the mechanism is not an acceptable alternative mechanism or the State is not implementing such a mechanism, the Secretary shall notify the State that the State is no longer considered to be implementing an acceptable alternative mechanism and that the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–41"},"text":"section 300gg–41 of this title","children":[],"tail":" shall apply to health insurance coverage offered in the individual market in the State, effective as of a date specified in the notice."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59ed9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on secretarial authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make a determination under paragraph (2) or (3) on any basis other than the basis that a mechanism is not an acceptable alternative mechanism or is not being implemented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59eda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Future adoption of mechanisms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State, after ","children":[{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":", submits the notice and information described in paragraph (1), unless the Secretary makes a finding described in paragraph (3) within the 90-day period beginning on the date of submission of the notice and information, the mechanism shall be considered to be an acceptable alternative mechanism for purposes of this section, effective 90 days after the end of such period, subject to the second sentence of paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6b59edb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision related to risk","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6b59edc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of NAIC models","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The model act referred to in subsection (a)(1)(D)(i) is the Small Employer and Individual Health Insurance Availability Model Act (adopted by the National Association of Insurance Commissioners on ","children":[{"tag":"date","attrib":{"date":"1996-06-03"},"text":"June 3, 1996","children":[],"tail":") insofar as it applies to individual health insurance coverage or the Individual Health Insurance Portability Model Act (also adopted by such Association on such date)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59edd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified high risk pool","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1)(D)(ii), a “qualified high risk pool” described in this paragraph is a high risk pool that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b59ede-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides to all eligible individuals health insurance coverage (or comparable coverage) that does not impose any preexisting condition exclusion with respect to such coverage for all eligible individuals, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59edf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for premium rates and covered benefits for such coverage consistent with standards included in the NAIC Model Health Plan for Uninsurable Individuals Act (as in effect as of ","children":[{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6b59ee0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other mechanisms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1)(D)(iii), a mechanism described in this paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6b59ee1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for risk adjustment, risk spreading, or a risk spreading mechanism (among issuers or policies of an issuer) or otherwise provides for some financial subsidization for eligible individuals, including through assistance to participating issuers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6b59ee2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–44/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a mechanism under which each eligible individual is provided a choice of all individual health insurance coverage otherwise available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6b59ee3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2744, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s111/a"},"text":"Pub. L. 104–191, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1984"},"text":"110 Stat. 1984","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s605/b/1"},"text":"Pub. L. 104–204, title VI, § 605(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2942"},"text":"110 Stat. 2942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6b59ee4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6b59ee5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6b59ee6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1996-08-21"},"text":"August 21, 1996","children":[],"tail":", referred to in subsec. (b)(1)(B)(ii), was in the original “the date of enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", which enacted this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6b59ee7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Pub. L. 104–204","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–62/b"},"text":"section 300gg–62(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6b59ee8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb6b59ee9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204/tVI/s605/c"},"text":"Pub. L. 104–204, title VI, § 605(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-26"},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2942"},"text":"110 Stat. 2942","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/204/tVI/s605/c"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–51"},"text":"section 300gg–51 of this title","children":[],"tail":" and amending this section and sections 300gg–61 and 300gg–62 of this title] shall apply with respect to health insurance coverage offered, sold, issued, renewed, in effect, or operated in the individual market on or after "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6b59eea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to health insura