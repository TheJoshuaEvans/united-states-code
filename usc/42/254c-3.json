{"tag":"section","attrib":{"id":"idb4e942b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"254c–3"},"text":"§ 254c–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special diabetes programs for Indians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e942b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants for providing services for the prevention and treatment of diabetes in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e942b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services through Indian health facilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), services under such subsection are provided in accordance with this subsection if the services are provided through any of the following entities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e942ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian health program operated by an Indian tribe or tribal organization pursuant to a contract, grant, cooperative agreement, or compact with the Indian Health Service pursuant to the Indian Self-Determination Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An urban Indian health program operated by an urban Indian organization pursuant to a grant or contract with the Indian Health Service pursuant to title V of the Indian Health Care Improvement Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1651"},"text":"25 U.S.C. 1651","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e942bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e942be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferred funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397dd/a"},"text":"section 1397dd(a) of this title","children":[],"tail":", from the amounts appropriated in such section for each of fiscal years 1998 through 2002, $30,000,000, to remain available until expended, is hereby transferred and made available in such fiscal year for grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e942bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of making grants under this section, there is appropriated, out of any money in the Treasury not otherwise appropriated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e942c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 for each of fiscal years 2001 and 2002 (which shall be combined with amounts transferred under paragraph (1) for each such fiscal years);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for each of fiscal years 2004 through 2017;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e942c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s254c–3/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib"