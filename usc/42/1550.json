{"tag":"section","attrib":{"id":"idbb32c2cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1550"},"text":null,"children":[{"tag":"num","attrib":{"value":"1550"},"text":"§ 1550.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of subchapters II to VII of this chapter, or the application thereof to any persons or circumstances, is held invalid, the remainder of said subchapters, or application of such provision to other persons or circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb32c2d0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-10-14/ch862"},"text":"Oct. 14, 1940, ch. 862","children":[],"tail":", title III, § 310, formerly § 13, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1128"},"text":"54 Stat. 1128","children":[],"tail":"; renumbered title III, § 310, "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-28/ch260/s4/b"},"text":"June 28, 1941, ch. 260, § 4(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/363"},"text":"55 Stat. 363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb32c2d1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb32c2d2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb32c2d3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapters III and VI of this chapter, referred to in text, were comprised of sections 1531 to 1536 and 1571 to 1576, respectively, of this title and have been omitted from the Code. For further details, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
