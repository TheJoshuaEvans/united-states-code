{"tag":"section","attrib":{"id":"idbff071f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091"},"text":null,"children":[{"tag":"num","attrib":{"value":"16091"},"text":"§ 16091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean school bus program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff071f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative fuel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “alternative fuel” means liquefied natural gas, compressed natural gas, hydrogen, propane, or biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean school bus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clean school bus” means a school bus that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff071fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator certifies reduces emissions and is operated entirely or in part using an alternative fuel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff071fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a zero-emission school bus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible contractor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible contractor” means a contractor that is a for-profit, not-for-profit, or nonprofit entity that has the capacity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff071ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell, lease, license, or contract for service clean school buses, zero-emission school buses, charging or fueling infrastructure, or other equipment needed to charge, fuel, or maintain clean school buses or zero-emission school buses, to individuals or entities that own, lease, license, or contract for service a school bus or a fleet of school buses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07200-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to arrange financing for such a sale, lease, license, or contract for service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07201-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipient","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07202-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the term “eligible recipient” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07203-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 or more local or State governmental entities responsible for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbff07204-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing school bus service to 1 or more public school systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff07205-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase, lease, license, or contract for service of school buses;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07206-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an eligible contractor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07207-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit school transportation association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07208-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a charter school (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7221i"},"text":"section 7221i of title 20","children":[],"tail":") responsible for the purchase, lease, license, or contract for service of school buses for that charter school; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07209-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an Indian Tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"), Tribal organization (as defined in that section), or tribally controlled school (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2511"},"text":"section 2511 of title 25","children":[],"tail":") that is responsible for—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbff0720a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing school bus service to 1 or more Bureau-funded schools (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021"},"text":"section 2021 of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbff0720b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/A/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase, lease, license, or contract for service of school buses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0720c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of eligible recipients identified under clauses (ii) and (iii) of subparagraph (A), the Administrator shall establish timely and appropriate requirements for notice and shall establish timely and appropriate requirements for approval by the public school systems that would be served by buses purchased using award funds made available under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0720d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-need local educational agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-need local educational agency” means a local educational agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":") that is among the local educational agencies in the applicable State with high percentages of children counted under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6333/c"},"text":"section 6333(c) of title 20","children":[],"tail":", on the basis of the most recent satisfactory data available, as determined by the Secretary of Education (or, for a local educational agency for which no such data is available, such other data as the Secretary of Education determines to be satisfactory)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0720e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" School bus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “school bus” has the meaning given the term “schoolbus” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30125/a"},"text":"section 30125(a) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0720f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-emission school bus","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “zero-emission school bus” means a school bus that is certified by the Administrator to have a drivetrain that produces, under any possible operational mode or condition, zero exhaust emission of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07210-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any air pollutant that is listed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408/a"},"text":"section 7408(a) of this title","children":[],"tail":" (or any precursor to such an air pollutant); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07211-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any greenhouse gas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07212-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program for replacement of existing school buses with clean school buses and zero-emission school buses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff07213-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish a program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07214-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants and rebates on a competitive basis to eligible recipients for the replacement of existing school buses with clean school buses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07215-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants and rebates on a competitive basis to eligible recipients for the replacement of existing school buses with zero-emission school buses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award contracts to eligible contractors to provide rebates for the replacement of existing school buses with clean school buses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award contracts to eligible contractors to provide rebates for the replacement of existing school buses with zero-emission school buses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available for awards under paragraph (1) in a fiscal year, the Administrator shall award—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent to replace existing school buses with zero-emission school buses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0721a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent to replace existing school buses with clean school buses and zero-emission school buses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0721b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under paragraph (2)(B), the Administrator shall take into account the following criteria and shall not give preference to any individual criterion:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0721c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lowest overall cost of bus replacement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0721d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local conditions, including the length of bus routes and weather conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0721e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technologies that most reduce emissions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0721f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether funds will bring new technologies to scale or promote cost parity between old technology and new technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of applications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under paragraph (1), the Administrator may prioritize applicants that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to replace school buses that serve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high-need local educational agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07223-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Bureau-funded school (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2021"},"text":"section 2021 of title 25","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency that receives a basic support payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7703/b/1"},"text":"section 7703(b)(1) of title 20","children":[],"tail":" for children who reside on Indian land;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve rural or low-income areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" propose to complement the assistance received through the award by securing additional sources of funding for the activities supported through the award, such as through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public-private partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants from other entities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuance of school bonds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0722a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of school bus fleet","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All clean school buses and zero-emission school buses acquired with funds provided under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0722b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be operated as part of the school bus fleet for which the award was made for not less than 5 years, except that, if the award is to an eligible contractor and the contract with the local educational agency (including charter schools operating as local educational agencies under State law) ends before the end of the 5-year period, those school buses may be operated as part of another local educational agency eligible for the same or higher priority consideration under paragraph (4), subject to the limitations under paragraph (7);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0722c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be maintained, operated, and charged or fueled according to manufacturer recommendations or State requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0722d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be manufactured or retrofitted with, or otherwise have installed, a power unit or other technology that creates air pollution within the school bus, such as an unvented diesel passenger heater.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0722e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0722f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making awards under paragraph (1), the Administrator may make awards for up to 100 percent of the costs for replacement of existing school buses with clean school buses, zero-emission school buses, and charging or fueling infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structuring awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making an award under paragraph (1)(A), the Administrator shall decide whether to award a grant or rebate, or a combination thereof, based primarily on how best to facilitate replacing existing school buses with clean school buses or zero-emission school buses, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment and distribution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, achieve nationwide deployment of clean school buses and zero-emission school buses through the program under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure a broad geographic distribution of awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that the amount received by all eligible entities in a State from grants and rebates under this section does not exceed 10 percent of the amounts made available to carry out this section during a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff07236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than January 31 of each year, the Administrator shall submit to Congress a report that evaluates the implementation of this section and describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff07237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of applications received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity and amount of grants and rebates awarded and the location of the recipients of the grants and rebates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria used to select the recipients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff0723a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/b/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0723b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education and outreach","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff0723c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Administrator shall develop an education and outreach program to promote and explain the award program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0723d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with stakeholders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The education and outreach program under paragraph (1) shall be designed and conducted in conjunction with interested stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0723e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The education and outreach program under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbff0723f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform potential award recipients on the process of applying for awards and fulfilling the requirements of awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the available technologies and the benefits of using the technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explain the benefits and costs incurred by participating in the award program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make available information regarding best practices, lessons learned, and technical and other information regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbff07243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean school bus and zero-emission school bus acquisition and deployment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the build-out of associated infrastructure and advance planning with the local electricity supplier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce development, training, and Registered Apprenticeships that meet the requirements under parts 29 and 30 of title 29, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2019-12-01"},"text":"December 1, 2019","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbff07246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that is necessary, as determined by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbff07247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, as appropriate, information from the annual report required under subsection (b)(7).","children":[{"tag":"ref","attrib":{"idref":"fn004204"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004204"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (b)(8).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07248-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may use, for the administrative costs of carrying out this section, not more than 3 percent of the amounts made available to carry out this section for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff07249-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall have the authority to issue such regulations or other guidance, forms, instructions, and publications as may be necessary or appropriate to carry out the programs, projects, or activities authorized under this section, including to ensure that such programs, projects, or activities are completed in a timely and effective manner, result in emissions reductions, and maximize public health benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff0724a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to the Administrator to carry out this section, to remain available until expended, $1,000,000,000 for each of fiscal years 2022 through 2026, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff0724b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000,000 shall be made available for the adoption of clean school buses and zero-emission school buses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff0724c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16091/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000,000 shall be made available for the adoption of zero-emission school buses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff0724d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s741"},"text":"Pub. L. 109–58, title VII, § 741","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/821"},"text":"119 Stat. 821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tXI/s71101"},"text":"Pub. L. 117–58, div. G, title XI, § 71101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1321"},"text":"135 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tIV/s405"},"text":"Pub. L. 117–328, div. O, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5229"},"text":"136 Stat. 5229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff0724e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff0724f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff07250-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/1/A/i"},"text":"Pub. L. 117–328, § 405(1)(A)(i)","children":[],"tail":", inserted “, lease, license, or contract for service” after “to sell” and after “that own”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/1/A/ii"},"text":"Pub. L. 117–328, § 405(1)(A)(ii)","children":[],"tail":", inserted “, lease, license, or contract for service” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A)(i)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/1/B/i"},"text":"Pub. L. 117–328, § 405(1)(B)(i)","children":[],"tail":", inserted “, lease, license, or contract for service” after “purchase”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A)(iii) to (v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/1/B/ii"},"text":"Pub. L. 117–328, § 405(1)(B)(ii)","children":[],"tail":"–(iv), added cl. (iv) and redesignated former cl. (iv) as (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A)(v)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/1/B/v"},"text":"Pub. L. 117–328, § 405(1)(B)(v)","children":[],"tail":", inserted “, lease, license, or contract for service” after “purchase”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s405/2"},"text":"Pub. L. 117–328, § 405(2)","children":[],"tail":", inserted before period at end “, except that, if the award is to an eligible contractor and the contract with the local educational agency (including charter schools operating as local educational agencies under State law) ends before the end of the 5-year period, those school buses may be operated as part of another local educational agency eligible for the same or higher priority consideration under paragraph (4), subject to the limitations under paragraph (7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" amended section generally. Prior to amendment, section related to program for retrofit or replacement of certain existing school buses with clean school buses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
