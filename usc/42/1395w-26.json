{"tag":"section","attrib":{"id":"idb9393c60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–26"},"text":"§ 1395w–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9393c61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of solvency standards for provider-sponsored organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9393c62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9393c63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, on an expedited basis and using a negotiated rulemaking process under subchapter III of chapter 5 of title 5, standards described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–25/c/1"},"text":"section 1395w–25(c)(1) of this title","children":[],"tail":" (relating to the financial solvency and capital adequacy of the organization) that entities must meet to qualify as provider-sponsored organizations under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9393c64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors to consider for solvency standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing solvency standards under subparagraph (A) for provider-sponsored organizations, the Secretary shall consult with interested parties and shall take into account—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9393c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery system assets of such an organization and ability of such an organization to provide services directly to enrollees through affiliated providers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9393c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alternative means of protecting against insolvency, including reinsurance, unrestricted surplus, letters of credit, guarantees, organizational insurance coverage, partnerships with other licensed entities, and valuation attributable to the ability of such an organization to meet its service obligations through direct delivery of care, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9393c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any standards developed by the National Association of Insurance Commissioners specifically for risk-based health care delivery organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9393c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enrollee protection against insolvency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such standards shall include provisions to prevent enrollees from being held liable to any person or entity for the Medicare+ÐChoice organization’s debts in the event of the organization’s insolvency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the rulemaking process under this subsection, the Secretary, after consultation with the National Association of Insurance Commissioners, the American Academy of Actuaries, organizations representative of medicare beneficiaries, and other interested parties, shall publish the notice provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s564/a"},"text":"section 564(a) of title 5","children":[],"tail":" by not later than 45 days after "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"August 5, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target date for publication of rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the notice under paragraph (2), and for purposes of this subsection, the “target date for publication” (referred to in section 564(a)(5) of such title) shall be ","children":[{"tag":"date","attrib":{"date":"1998-04-01"},"text":"April 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abbreviated period for submission of comments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In applying section 564(c) of such title under this subsection, “15 days” shall be substituted for “30 days”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of negotiated rulemaking committee and facilitator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9393c6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment of a negotiated rulemaking committee under section 565(a) of such title by not later than 30 days after the end of the comment period provided for under section 564(c) of such title (as shortened under paragraph (4)), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9393c6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nomination of a facilitator under section 566(c) of such title by not later than 10 days after the date of appointment of the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preliminary committee report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The negotiated rulemaking committee appointed under paragraph (5) shall report to the Secretary, by not later than ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", regarding the committee’s progress on achieving a consensus with regard to the rulemaking proceeding and whether such consensus is likely to occur before 1 month before the target date for publication of the rule. If the committee reports that the committee has failed to make significant progress towards such consensus or is unlikely to reach such consensus by the target date, the Secretary may terminate such process and provide for the publication of a rule under this subsection through such other methods as the Secretary may provide."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c70-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final committee report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the committee is not terminated under paragraph (6), the rulemaking committee shall submit a report containing a proposed rule by not later than 1 month before the target date of publication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c71-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim, final effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a rule under this subsection in the Federal Register by not later than the target date of publication. Such rule shall be effective and final immediately on an interim basis, but is subject to change and revision after public notice and opportunity for a period (of not less than 60 days) for public comment. In connection with such rule, the Secretary shall specify the process for the timely review and approval of applications of entities to be certified as provider-sponsored organizations pursuant to such rules and consistent with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9393c72-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of rule after public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for consideration of such comments and republication of such rule by not later than 1 year after the target date of publication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9393c73-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of other standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9393c74-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish by regulation other standards (not described in subsection (a)) for Medicare+Choice organizations and plans consistent with, and to carry out, this part. The Secretary shall publish such regulations by ","children":[{"tag":"date","attrib":{"date":"1998-06-01"},"text":"June 1, 1998","children":[],"tail":". In order to carry out this requirement in a timely manner, the Secretary may promulgate regulations that take effect on an interim basis, after notice and pending opportunity for public comment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93b8665-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of current standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the requirements of this part, standards established under this subsection shall be based on standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395mm"},"text":"section 1395mm of this title","children":[],"tail":" to carry out analogous provisions of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93b8666-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards established under this part shall supersede any State law or regulation (other than State licensing laws or State laws relating to plan solvency) with respect to MA plans which are offered by MA organizations under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb93b8667-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–26/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of midyear implementation of significant new regulatory requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not implement, other than at the beginning of a calendar year, regulations under this section that impose new, significant regulatory requirements on a Medicare+Choice organization or plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb93b8668-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1856, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tIV/s4001"},"text":"Pub. L. 105–33, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/317"},"text":"111 Stat. 317","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tVI/s612/a"},"text":"Pub. L. 106–554, § 1(a)(6) [title VI, §§ 612(a), 614(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–560; "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tII/s232/a"},"text":"Pub. L. 108–173, title II, § 232(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2208"},"text":"117 Stat. 2208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb93b8669-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb93b866a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb93b866b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173"},"text":"Pub. L. 108–173","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text consisted of subpars. (A) and (B) stating general rule and listing standards specifically superseded."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(3)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tVI/s614/a/1"},"text":"Pub. L. 106–554, § 1(a)(6) [title VI, § 614(a)(1)]","children":[],"tail":", inserted “(including cost-sharing requirements)” after “Benefit requirements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tVI/s614/a/2"},"text":"Pub. L. 106–554, § 1(a)(6) [title VI, § 614(a)(2)]","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tVI/s612/a"},"text":"Pub. L. 106–554, § 1(a)(6) [title VI, § 612(a)]","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb93b866c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb93b866d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to Medicare+Choice deemed to refer to Medicare Advantage or MA, subject to an appropriate transition provided by the Secretary of Health and Human Services in the use of those terms, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/173/s201"},"text":"section 201 of Pub. L. 108–173","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–21"},"text":"section 1395w–21 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb93b866e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tVI/s612/b"},"text":"Pub. L. 106–554, § 1(a)(6) [title VI, § 612(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–560, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/6/tVI/s612/b"},"text":"“The amendment made by subsection (a) [amending this section] takes effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/6/tVI/s614/b"},"text":"Pub. L. 106–554, § 1(a)(6) [title VI, § 614(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–561, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/6/tVI/s614/b"},"text":"“The amendments made by subsection (a) [amending this section] take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
