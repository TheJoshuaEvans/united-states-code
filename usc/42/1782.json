{"tag":"section","attrib":{"id":"idbb70b5fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1782"},"text":null,"children":[{"tag":"num","attrib":{"value":"1782"},"text":"§ 1782.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centralization in Department of Agriculture of administration of food service programs for children","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Authority for the conduct and supervision of Federal programs to assist schools in providing food service programs for children is assigned to the Department of Agriculture. To the extent practicable, other Federal agencies administering programs under which funds are to be provided to schools for such assistance shall transfer such funds to the Department of Agriculture for distribution through the administrative channels and in accordance with the standards established under this chapter and the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb70b5fd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s13"},"text":"Pub. L. 89–642, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/889"},"text":"80 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/16"},"text":"Pub. L. 106–78, title VII, § 752(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1170"},"text":"113 Stat. 1170","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb70b5fe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb70b5ff-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb70b600-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb70b601-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" substituted “Richard B. Russell National School Lunch Act” for “National School Lunch Act”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
