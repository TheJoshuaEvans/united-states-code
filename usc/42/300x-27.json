{"tag":"section","attrib":{"id":"idb66b9cfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27"},"text":null,"children":[{"tag":"num","attrib":{"value":"300x–27"},"text":"§ 300x–27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment services for pregnant women","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb66b9cfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that the State involved—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9cff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will ensure that each pregnant woman in the State who seeks or is referred for and would benefit from such services is given preference in admissions to treatment facilities receiving funds pursuant to the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will, in carrying out paragraph (1), publicize the availability to such women of services from the facilities and the fact that the women receive such preference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb66b9d01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referrals regarding States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A funding agreement for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300x–21"},"text":"section 300x–21 of this title","children":[],"tail":" is that, in carrying out subsection (a)(1)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb66b9d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State involved will require that, in the event that a treatment facility has insufficient capacity to provide treatment services to any woman described in such subsection who seeks the services from the facility, the facility refer the woman to the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb66b9d03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State, in the case of each woman for whom a referral under paragraph (1) is made to the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb66b9d04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will refer the woman to a treatment facility that has the capacity to provide treatment services to the woman; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb66b9d05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300x–27/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will, if no treatment facility has the capacity to admit the woman, make interim services available to the woman not later than 48 hours after the women ","children":[{"tag":"ref","attrib":{"idref":"fn002391"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002391"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “woman”."}],"tail":" seeks the treatment services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb66b9d06-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XIX, § 1927, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tII/s202"},"text":"Pub. L. 102–321, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/395"},"text":"106 Stat. 395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s2/a/10"},"text":"Pub. L. 102–352, § 2(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/938"},"text":"106 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb66b9d07-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb66b9d08-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb66b9d09-3a70-11f1-ae07-e4213316b5fa"},"text":null,