{"tag":"section","attrib":{"id":"idc05240c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18202"},"text":null,"children":[{"tag":"num","attrib":{"value":"18202"},"text":"§ 18202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Pregnancy Assistance Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc05240c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration and coordination with the Secretary of Education (as appropriate), shall establish a Pregnancy Assistance Fund to be administered by the Secretary, for the purpose of awarding competitive grants to States to assist pregnant and parenting teens and women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05240c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may apply for a grant under subsection (a) to carry out any activities provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18203"},"text":"section 18203 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc05240c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (a), a State shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, including a description of the purposes for which the grant is being requested and the designation of a State agency for receipt and administration of funding received under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc05240c4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10212"},"text":"Pub. L. 111–148, title X, § 10212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/932"},"text":"124 Stat. 932","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
