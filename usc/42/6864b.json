{"tag":"section","attrib":{"id":"idbdc023d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6864b"},"text":"§ 6864b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical transfer grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdc023d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, to the extent funds are made available, provide financial assistance to entities receiving funding from the Federal Government or from a State through a weatherization assistance program under section 6863 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6864"},"text":"section 6864 of this title","children":[],"tail":" for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc023d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating technical and management measures which increase program and/or private entity performance in weatherizing low-income housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producing technical information for use by persons involved in weatherizing low-income housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchanging information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting training programs for persons involved in weatherizing low-income housing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdc023dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdc023dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 50 percent of amounts provided under this section shall be awarded to entities other than States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdc023de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6864b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recipient of financial assistance under this section may contract with nonprofit entities to carry out all or part of the activities for which such financial assistance is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdc023df-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/385/tIV/s414B"},"text":"Pub. L. 94–385, title IV, § 414B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s142/a"},"text":"Pub. L. 102–486, title I, § 142(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2842"},"text":"106 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
