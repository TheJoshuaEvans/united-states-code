{"tag":"section","attrib":{"id":"idc07ad721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19102"},"text":null,"children":[{"tag":"num","attrib":{"value":"19102"},"text":"§ 19102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the Directorate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s19101"},"text":"section 19101 of this title","children":[],"tail":" are to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idc07ad722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support use-inspired and translational research and accelerate the development and use of federally funded research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen United States competitiveness by accelerating the development of key technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc07ad724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grow the domestic workforce in key technology focus areas, and expand the participation of United States students and researchers in areas of societal, national, and geostrategic importance, at all levels of education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc07ad725-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10382"},"text":"Pub. L. 117–167, div. B, title III, § 10382","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1576"},"text":"136 Stat. 1576","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
