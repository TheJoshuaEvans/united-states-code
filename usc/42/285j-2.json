{"tag":"section","attrib":{"id":"idb575f38f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285j–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285j–2"},"text":"§ 285j–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioengineering research","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall make grants or enter into contracts for research on the means to overcome paralysis of the extremities through electrical stimulation and the use of computers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb575f390-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 459, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/857"},"text":"99 Stat. 857","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
