{"tag":"section","attrib":{"id":"idbd7fc01e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6294b"},"text":"§ 6294b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WaterSense program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7fc01f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of WaterSense program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fc020-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established within the Environmental Protection Agency a voluntary program, to be known as the WaterSense program, to identify and promote water-efficient products, buildings, landscapes, facilities, processes, and services in order to, through voluntary labeling of, or other forms of communications regarding, such products, buildings, landscapes, facilities, processes, and services while meeting strict performance criteria, sensibly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fc021-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce water use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc022-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the strain on public water systems, community water systems, and wastewater and stormwater infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc023-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conserve energy used to pump, heat, transport, and treat water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc024-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve water resources for future generations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc025-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Categories of products, buildings, landscapes, facilities, processes, and services that may be included under the program include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fc026-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" irrigation technologies and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc027-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" point-of-use water treatment devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc028-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plumbing products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc029-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water reuse and recycling technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc02a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landscaping and gardening products, including moisture control or water enhancing technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc02b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" xeriscaping and other landscape conversions that reduce water use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc02c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whole house humidifiers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc02d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water-efficient buildings or facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fc02e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Environmental Protection Agency, in coordination with the Secretary of Energy as appropriate, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fc02f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fc030-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a WaterSense label to be used for products, buildings, landscapes, facilities, processes, and services meeting the certification criteria established pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc031-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedure, including the methods and means, and criteria by which products, buildings, landscapes, facilities, processes, and services may be certified to display the WaterSense label;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc032-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance public awareness regarding the WaterSense label through outreach and public education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc033-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" preserve the integrity of the WaterSense label by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fc034-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and maintaining feasible performance criteria so that products, buildings, landscapes, facilities, processes, and services certified to display the WaterSense label perform as well or better than less water-efficient counterparts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc035-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseeing WaterSense certifications made by third parties, which shall be independent third-party product certification bodies accredited by an accreditation entity domiciled in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc036-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using testing protocols, from the appropriate, applicable, and relevant consensus standards, for the purpose of determining compliance with performance criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fc037-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" auditing the use of the WaterSense label in the marketplace and preventing cases of misuse;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fc038-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more frequently than every 6 years after adoption or major revision of any WaterSense performance criteria, review and, if appropriate, revise the performance criteria to achieve additional water savings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd820929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in revising any WaterSense criteria—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd82092a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasonable notice to interested parties and the public of any changes, including effective dates, and an explanation of the changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd82092b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit comments from interested parties and the public prior to any changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd82092c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, respond to comments submitted by interested parties and the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd82092d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an appropriate transition time prior to the applicable effective date of any changes, taking into account the timing necessary for the manufacture, marketing, training, and distribution of the specific product, building, landscape, process, or service category being addressed; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd82092e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2019-12-31"},"text":"December 31, 2019","children":[],"tail":", consider for review and revise, if necessary, any WaterSense performance criteria adopted before "},{"tag":"date","attrib":{"date":"2012-01-01"},"text":"January 1, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd82092f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall, to the extent practicable and not less than annually, estimate and make available to the public the relative water and energy savings attributable to the use of WaterSense-labeled products, buildings, landscapes, facilities, processes, and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd820930-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distinction of authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In setting or maintaining specifications and criteria for Energy Star pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"section 6294a of this title","children":[],"tail":", and WaterSense under this section, the Secretary of Energy and the Administrator of the Environmental Protection Agency shall coordinate to prevent duplicative or conflicting requirements among the respective programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd820931-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No warranty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A WaterSense label shall not create any express or implied warranty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd820932-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods for establishing performance criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing performance criteria for products, buildings, landscapes, facilities, processes, or services pursuant to this section, the Administrator of the Environmental Protection Agency shall use technical specifications and testing protocols established by voluntary consensus standards organizations relevant to specific products, buildings, landscapes, facilities, processes, or services, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd820933-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6294b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of feasible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “feasible” means feasible with the use of the best technology, techniques, and other means that the Administrator of the Environmental Protection Agency finds, after examination for efficacy under field conditions and not solely under laboratory conditions, are available (taking cost into consideration).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd820934-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s324B"},"text":"Pub. L. 94–163, title III, § 324B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/270/tIV/s4306/a"},"text":"Pub. L. 115–270, title IV, § 4306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-23"},"text":"Oct. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3884"},"text":"132 Stat. 3884","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
