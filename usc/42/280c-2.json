{"tag":"section","attrib":{"id":"idb52c1934-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"280c–2"},"text":"§ 280c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52c1935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":" to a State unless the State agrees that not more than 10 percent of the grant will be expended for administrative expenses with respect to the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c1936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of intended use of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":" to a State unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c1937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State submits to the Secretary a description of the purposes for which the State intends to expend the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such description provides information relating to the programs and activities to be supported and services to be provided, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52c1939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals who will receive services pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":" and the average costs of providing such services to each such individual; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52c193a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which such programs and activities will be coordinated with any similar programs and activities of public and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c193b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":" to a State unless the State has submitted to the Secretary an application for the grant. The application shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c193c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the description of intended expenditures required in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c193d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to carrying out the purpose for which the grant is to be made, provide assurances of compliance satisfactory to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c193e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise be in such form, be made in such manner, and contain such information and agreements as the Secretary determines to be necessary to carry out this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c193f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations and report by Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52c1940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an evaluation of each demonstration project for which a grant is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s280c/a"},"text":"section 280c(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52c1941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 6 months after the completion of such evaluations, submit to the Congress a report describing the findings made as a result of the evaluations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52c1942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280c–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this subpart, there are authorized to be appropriated $5,000,000 for each of the fiscal years 1988 through 1990, $7,500,000 for fiscal year 1991, and such sums as may be necessary for each of the fiscal years 1992 and 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52c1943-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 397, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/175/tVI/s602"},"text":"Pub. L. 100–175, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-29"},"text":"Nov. 29, 1987","children":[],"tail":", "},{"tag":"ref","attr