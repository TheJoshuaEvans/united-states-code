{"tag":"section","attrib":{"id":"idbe07b501-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7382c"},"text":"§ 7382c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe07b502-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b503-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Albert Einstein Distinguished Educator Fellowship Program (hereafter in this subchapter referred to as the “Program”) to provide 12 elementary or secondary school mathematics or science teachers with fellowships in each fiscal year in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b504-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order of priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may reduce the number of fellowships awarded under this subchapter for any fiscal year in which the amount appropriated for the Program is insufficient to support 12 fellowships. If the number of fellowships awarded under this subchapter is reduced for any fiscal year, then the Secretary shall award fellowships based on the following order of priority:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b505-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three fellowships in the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b506-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two fellowships in the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b507-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two fellowships in the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b508-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" One fellowship in each of the following entities:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe07b509-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b50a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b50b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b50c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b50d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b50e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fellowship awarded under this subchapter shall be awarded for a period of ten months that, to the extent practicable, coincide with the academic year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b50f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a fellowship under this subchapter, an elementary or secondary school mathematics or science teacher must demonstrate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b510-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such teacher would bring unique and valuable contributions to the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b511-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such teacher is recognized for excellence in mathematics or science education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b512-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe07b513-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sabbatical leave from teaching will be granted in order to participate in the Program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b514-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the teacher will return to a teaching position comparable to the position held prior to participating in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b515-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b516-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the development and administration of an application and selection process for fellowships under the Program, including a process whereby final selections of fellowship recipients are made in accordance with subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b517-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the publication of information on the Program in appropriate professional publications, including an invitation for applications from teachers listed in the directories of national and State recognition programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b518-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select from the pool of applicants 12 elementary and secondary school mathematics teachers and 12 elementary and secondary school science teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b519-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a program of orientation for fellowship recipients under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b51a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than August 31 of each year in which fellowships are awarded, prepare and submit an annual report and evaluation of the Program to the appropriate Committees of the Senate and the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe07b51b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe07b51c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall arrange for the 24 semifinalists to travel to Washington, D.C., to participate in interviews in accordance with the selection process described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe07b51d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final selection","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe07b51e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than May 1 of each year preceding each year in which fellowships are to be awarded, the Secretary shall select and announce the names of the fellowship recipients.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe07b51f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide for the development and administration of a process to select fellowship recipients from the pool of semifinalists as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe07b520-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall select three fellowship recipients who shall be assigned to the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Majority Leader of the Senate and the Minority Leader of the Senate, or their designees, shall each select a fellowship recipient who shall be assigned to the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Speaker of the House of Representatives and the Minority Leader of the House of Representatives, or their designees, shall each select a fellowship recipient who shall be assigned to the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe07b523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each of the following individuals, or their designees, shall select one fellowship recipient who shall be assigned within the department, office, agency, or institute such individual administers:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbe07b524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe07b525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe07b526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe07b527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe07b528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7382c/c/2/B/iv/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Science and Technology Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe07b529-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382/tV/s515"},"text":"Pub. L. 103–382, title V, § 515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4042"},"text":"108 Stat. 4042","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
