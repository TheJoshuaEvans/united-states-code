{"tag":"section","attrib":{"id":"idbf31b53f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821"},"text":null,"children":[{"tag":"num","attrib":{"value":"10821"},"text":"§ 10821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf31b540-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission for allotment; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No allotment may be made under this subchapter to an eligible system unless an application therefor is submitted to the Secretary. Each such application shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf31b541-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that amounts paid to such system from an allotment under this subchapter will be used to supplement and not to supplant the level of non-Federal funds available in the State in which such system is established to protect and advocate the rights of individuals with mental illness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that such system will have a staff which is trained or being trained to provide advocacy services to individuals with mental illness and to work with family members of clients served by the system where the individuals with mental illness are minors, legally competent and do not object, and legally incompetent and the legal guardians, conservators, or other legal representatives are family members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that such system, and any State agency or nonprofit organization with which such system may enter into a contract under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10804/a"},"text":"section 10804(a) of this title","children":[],"tail":", will not, in the case of any individual who has a legal guardian, conservator, or representative other than the State, take actions which are duplicative of actions taken on behalf of such individual by such guardian, conservator, or representative unless such guardian, conservator, or representative requests the assistance of such system; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Satisfaction of requirements regarding trained staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The assurance required under subsection (a)(2) regarding trained staff may be satisfied through the provision of training by individuals who have received or are receiving mental health services and family members of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10821/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of applications and assurances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications submitted under this section shall remain in effect for a 4-year period, and the assurances required under this section shall be for the same 4-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf31b547-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s111"},"text":"Pub. L. 99–319, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/482"},"text":"100 Stat. 482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/509/s7/d"},"text":"Pub. L. 100–509, § 7(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-20"},"text":"Oct. 20, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2545"},"text":"102 Stat. 2545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":", §§ 7, 10(2), "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1218"},"text":"105 Stat. 1218","children":[],"tail":", 1219; "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s163/c/3/A"},"text":"Pub. L. 102–321, title I, § 163(c)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/377"},"text":"106 Stat. 377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf31b548-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf31b549-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf31b54a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" substituted “4-year” for “3-year” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/2"},"text":"Pub. L. 102–173, § 10(2)","children":[],"tail":", substituted “individuals with mental illness” for “mentally ill individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":", §§ 7(1), 10(2), substituted “individuals with mental illness” for “mentally ill individuals” and inserted before semicolon at end “and to work with family members of clients served by the system where the individuals with mental illness are minors, legally competent and do not object, and legally incompetent and the legal guardians, conservators, or other legal representatives are family members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173/s7/2"},"text":"Pub. L. 102–173, § 7(2)","children":[],"tail":", (3) added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/509"},"text":"Pub. L. 100–509","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf31b54b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf31b54c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
