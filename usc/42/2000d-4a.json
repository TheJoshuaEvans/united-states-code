{"tag":"section","attrib":{"id":"idbbb84593-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2000d–4a"},"text":"§ 2000d–4a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Program or activity” and “program” defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, the term “program or activity” and the term “program” mean all of the operations of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbb84594-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbb84595-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department, agency, special purpose district, or other instrumentality of a State or of a local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb84596-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity of such State or local government that distributes such assistance and each such department or agency (and each other State or local government entity) to which the assistance is extended, in the case of assistance to a State or local government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb84597-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbb84598-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college, university, or other postsecondary institution, or a public system of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb84599-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local educational agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"), system of vocational education, or other school system;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb8459a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbb8459b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an entire corporation, partnership, or other private organization, or an entire sole proprietorship—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbb8459c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if assistance is extended to such corporation, partnership, private organization, or sole proprietorship as a whole; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbb8459d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is principally engaged in the business of providing education, health care, housing, social services, or parks and recreation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbb8459e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire plant or other comparable, geographically separate facility to which Federal financial assistance is extended, in the case of any other corporation, partnership, private organization, or sole proprietorship; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbb8459f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2000d–4a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity which is established by two or more of the entities described in paragraph (1), (2), or (3);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"any part of which is extended Federal financial assistance.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbb845a0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352/tVI/s606"},"text":"Pub. L. 88–352, title VI, § 606","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/259/s6"},"text":"Pub. L. 100–259, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-03-22"},"text":"Mar. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/31"},"text":"102 Stat. 31","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s391/q"},"text":"Pub. L. 103–382, title III, § 391(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4024"},"text":"108 Stat. 4024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/110/tX/s1076/y"},"text":"Pub. L. 107–110, title X, § 1076(y)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-08"},"text":"Jan. 8, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2093"},"text":"115 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/r"},"text":"Pub. L. 114–95, title IX, § 9215(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2171"},"text":"129 Stat. 2171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbb845a1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbb845a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbb845a3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (2)(B). ","children":[{"tag":"re