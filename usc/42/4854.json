{"tag":"section","attrib":{"id":"idbce4b829-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4854"},"text":null,"children":[{"tag":"num","attrib":{"value":"4854"},"text":"§ 4854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on lead exposure from other sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation with other Federal agencies, shall conduct research on strategies to reduce the risk of lead exposure from other sources, including exterior soil and interior lead dust in carpets, furniture, and forced air ducts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbce4b82a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tX/s1051"},"text":"Pub. L. 102–550, title X, § 1051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3925"},"text":"106 Stat. 3925","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
