{"tag":"section","attrib":{"id":"idbf9114cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p"},"text":null,"children":[{"tag":"num","attrib":{"value":"12653p"},"text":"§ 12653p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer generation fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf9114ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations for this section, the Corporation may make grants to State Commissions and nonprofit organizations for the purpose of assisting the State Commissions and nonprofit organizations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9114cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and carry out volunteer programs described in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make subgrants to support and create new local community-based entities that recruit, manage, or support volunteers as described in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9114d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9114d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State Commission or nonprofit organization desiring a grant under this section shall submit an application to the Corporation at such time, in such manner, and accompanied by such information as the Corporation may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9114d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted pursuant to paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9114d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf9114d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004090"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004090"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No cl. (ii) has been enacted."}],"tail":" a description of the program that the applicant will provide;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9114d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assurance that the applicant will annually collect information on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf9114d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of volunteers recruited for activities carried out under this section, using funds received under this section, and the type and amount of activities carried out by such volunteers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf9114d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of volunteers managed or supported using funds received under this section, and the type and amount of activities carried out by such volunteers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9114d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the outcomes the applicant will use to annually measure and track performance with regard to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf9384da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities carried out by volunteers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf9384db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteers recruited, managed, or supported; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9384dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional assurances as the Corporation determines to be essential to ensure compliance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9384dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible volunteer programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State Commission or nonprofit organization receiving a grant under this section shall use the assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9384de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly to carry out volunteer programs or to develop and support community-based entities that recruit, manage, or support volunteers, by carrying out activities consistent with the goals of the subgrants described in paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" through subgrants to community-based entities to carry out volunteer programs or develop and support such entities that recruit, manage, or support volunteers, through 1 or more of the following types of subgrants:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9384e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A subgrant to a community-based entity for activities that are consistent with the priorities set by the State’s national service plan as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12638/e"},"text":"section 12638(e) of this title","children":[],"tail":", or by the Corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9384e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A subgrant to recruit, manage, or support volunteers to a community-based entity such as a volunteer coordinating agency, a nonprofit resource center, a volunteer training clearinghouse, an institution of higher education, or a collaborative partnership of faith-based and community-based organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9384e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A subgrant to a community-based entity that provides technical assistance and support to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf9384e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the capacity of local volunteer infrastructure organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf9384e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address areas of national need (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653b/a"},"text":"section 12653b(a) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf9384e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the number of volunteers nationally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9384e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9384e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds allocated by the Corporation for provision of assistance under this section for a fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf9384e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation shall use 50 percent of such funds to award grants, on a competitive basis, to State Commissions and nonprofit organizations for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf9384e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation shall use 50 percent of such funds make ","children":[{"tag":"ref","attrib":{"idref":"fn004091"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “to”."}],"tail":" an allotment to the State Commissions of each of the several States, the District of Columbia, and the Commonwealth of Puerto Rico based on the formula described in subsections (e) and (f) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12581"},"text":"section 12581 of this title","children":[],"tail":", subject to paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure that each State Commission is able to improve efforts to recruit, manage, or support volunteers, the Corporation may determine a minimum grant amount for allotments under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9384eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the amount of any grant provided under this section for a fiscal year may be used to pay for administrative costs incurred by either the recipient of the grant or any community-based entity receiving assistance or a subgrant under such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf9384ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching fund requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation share of the cost of carrying out a program that receives assistance under this section, whether the assistance is provided directly or as a subgrant from the original recipient of the assistance, may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf9384ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of such cost for the first year in which the recipient receives such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of such cost for the second year in which the recipient receives such assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent of such cost for the third year in which the recipient receives such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf9384f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12653p/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of such cost for the fourth year in which the recipient receives such assistance and each year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf9384f1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s198P"},"text":"Pub. L. 101–610, title I, § 198P","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1808"},"text":"Pub. L. 111–13, title I, § 1808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1573"},"text":"123 Stat. 1573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf9384f2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf9384f3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf9384f4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
