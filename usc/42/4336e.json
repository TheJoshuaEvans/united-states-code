{"tag":"section","attrib":{"id":"idbcc82f7a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e"},"text":null,"children":[{"tag":"num","attrib":{"value":"4336e"},"text":"§ 4336e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcc82f7b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Categorical exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “categorical exclusion” means a category of actions that a Federal agency has determined normally does not significantly affect the quality of the human environment within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f7c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperating agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cooperating agency” means any Federal, State, Tribal, or local agency that has been designated as a cooperating agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336a/a/3"},"text":"section 4336a(a)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f7d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Council on Environmental Quality established in subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f7e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “environmental assessment” means an environmental assessment prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336/b/2"},"text":"section 4336(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f7f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “environmental document” means an environmental impact statement, an environmental assessment, or a finding of no significant impact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f80-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “environmental impact statement” means a detailed written statement that is required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4332/2/C"},"text":"section 4332(2)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f81-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding of no significant impact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “finding of no significant impact” means a determination by a Federal agency that a proposed agency action does not require the issuance of an environmental impact statement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f82-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating Federal agency” means a Federal agency participating in an environmental review or authorization of an action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lead agency” means, with respect to a proposed agency action—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency that proposed such action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there are 2 or more involved Federal agencies with respect to such action, the agency designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4336a/a/1"},"text":"section 4336a(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major Federal action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcc82f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “major Federal action” means an action that the agency carrying out such action determines is subject to substantial Federal control and responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcc82f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major Federal action” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcc82f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a non-Federal action—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbcc82f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with no or minimal Federal funding; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbcc82f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with no or minimal Federal involvement where a Federal agency cannot control the outcome of the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding assistance solely in the form of general revenue sharing funds which do not provide Federal agency compliance or enforcement responsibility over the subsequent use of such funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans, loan guarantees, or other forms of financial assistance where a Federal agency does not exercise sufficient control and responsibility over the subsequent use of such financial assistance or the effect of the action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business loan guarantees provided by the Small Business Administration pursuant to section 7(a) or (b) and ","children":[{"tag":"ref","attrib":{"idref":"fn003356"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003356"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":" of the Small Business Act ( U.S.C. 636(a)),"},{"tag":"ref","attrib":{"idref":"fn003357"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003357"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should refer to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s636/a"},"text":"15 U.S.C. 636(a)","children":[],"tail":", (b)."}],"tail":" or title V of the Small Business Investment Act of 1958 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s695"},"text":"15 U.S.C. 695","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing judicial or administrative civil or criminal enforcement actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extraterritorial activities or decisions, which means agency activities or decisions with effects located entirely outside of the jurisdiction of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcc82f91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/10/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities or decisions that are non-discretionary and made in accordance with the agency’s statutory authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programmatic environmental document","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “programmatic environmental document” means an environmental impact statement or environmental assessment analyzing all or some of the environmental effects of a policy, program, plan, or group of related actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “proposal” means a proposed action at a stage when an agency has a goal, is actively preparing to make a decision on one or more alternative means of accomplishing that goal, and can meaningfully evaluate its effects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcc82f94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s4336e/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special expertise","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “special expertise” means statutory responsibility, agency mission, or related program experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcc82f95-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190/tI/s111"},"text":"Pub. L. 91–190, title I, § 111","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/5/dC/tIII/s321/b"},"text":"Pub. L. 118–5, div. C, title III, § 321(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-06-03"},"text":"June 3, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/44"},"text":"137 Stat. 44","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcc82f96-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcc82f97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcc82f98-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Investment Act of 1958, referred to in par. (10)(B)(iv), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/699"},"text":"Pub. L. 85–699","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-21"},"text":"Aug. 21, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/689"},"text":"72 Stat. 689","children":[],"tail":". Title V of the Act is classified generally to subchapter V (§ 695 et seq.) of chapter 14B of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s661"},"text":"section 661 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
