{"tag":"section","attrib":{"id":"idbea776f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8854"},"text":null,"children":[{"tag":"num","attrib":{"value":"8854"},"text":"§ 8854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization of National Forest System in wood energy development projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may make available the timber resources of the National Forest System, in accordance with appropriate timber appraisal and sale procedures, for use by biomass energy projects.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbea776f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s261"},"text":"Pub. L. 96–294, title II, § 261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/710"},"text":"94 Stat. 710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
