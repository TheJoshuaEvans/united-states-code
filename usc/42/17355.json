{"tag":"section","attrib":{"id":"idc035924d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355"},"text":null,"children":[{"tag":"num","attrib":{"value":"17355"},"text":"§ 17355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Foundation; related provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc035924e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035924f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have perpetual succession unless dissolved by a law enacted after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt, alter, and use a seal, which shall be judicially noticed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make and perform such contracts, grants, and other agreements with any person or government however designated and wherever situated, as may be necessary for carrying out the functions of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359252-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may determine and prescribe the manner in which its obligations shall be incurred and its expenses allowed and paid, including expenses for representation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359253-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may lease, purchase, or otherwise acquire, improve, and use such real property wherever situated, as may be necessary for carrying out the functions of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359254-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept money, funds, services, or property (real, personal, or mixed), tangible or intangible, made available by gift, bequest ","children":[{"tag":"ref","attrib":{"idref":"fn004273"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004273"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A comma probably should appear."}],"tail":" grant, or otherwise for the purpose of carrying out the provisions of this subchapter from domestic or foreign private individuals, charities, nongovernmental organizations, corporations, or governments;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359255-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the United States mails in the same manner and on the same conditions as the executive departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359256-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may contract with individuals for personal services, who shall not be considered Federal employees for any provision of law administered by the Office of Personnel Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359257-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may hire or obtain passenger motor vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359258-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have such other powers as may be necessary and incident to carrying out this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0359259-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall maintain its principal office in the metropolitan area of Washington, District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035925a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Government Corporation Control Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035925b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be subject to chapter 91 of subtitle VI of title 31, except that the Foundation shall not be authorized to issue obligations or offer obligations to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035925c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc035925d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc035925e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of State shall serve as Inspector General of the Foundation, and, in acting in such capacity, may conduct reviews, investigations, and inspections of all aspects of the operations and activities of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc035925f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the responsibilities under this subsection, the Inspector General shall report to and be under the general supervision of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0359260-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement and authorization of services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0359261-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall reimburse the Department of State for all expenses incurred by the Inspector General in connection with the Inspector General’s responsibilities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0359262-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17355/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17357/a"},"text":"section 17357(a) of this title","children":[],"tail":" for a fiscal year, up to $500,000 is authorized to be made available to the Inspector General of the Department of State to conduct reviews, investigations, and inspections of operations and activities of the Foundation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0359263-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIX/s925"},"text":"Pub. L. 110–140, title IX, § 925","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1736"},"text":"121 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc0359264-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc0359265-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc0359266-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a)(6), was in the original “this title”, meaning title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1725"},"text":"121 Stat. 1725","children":[],"tail":", which enacted this subchapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of Title 31","children":[],"tail":", Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3021"},"text":"section 3021 of Title 50","children":[],"tail":", War and National Defense. For complete classification of title IX to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc0359267-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s925"},"text":"section 925 of Pub. L. 110–140","children":[],"tail":". Subsec. (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s925"},"text":"section 925 of Pub. L. 110–140","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc0359268-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idc0359269-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
