{"tag":"section","attrib":{"id":"idbba9ee32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1962d–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1962d–6"},"text":"§ 1962d–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility studies; acceleration; advancement of costs by non-Federal sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may accelerate feasibility studies authorized by law when and to the extent that the costs of such studies shall have been advanced by non-Federal sources.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbba9ee33-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/561/s5"},"text":"Pub. L. 89–561, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-07"},"text":"Sept. 7, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/714"},"text":"80 Stat. 714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbba9ee34-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbba9ee35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbba9ee36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Water Resources Planning Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
