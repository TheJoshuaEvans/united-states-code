{"tag":"section","attrib":{"id":"idc02e6584-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17218"},"text":null,"children":[{"tag":"num","attrib":{"value":"17218"},"text":"§ 17218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this part $186,600,000 for each of fiscal years 2021 through 2025, including $137,428,378 for marine energy and $49,171,622 for hydropower research, development, and demonstration activities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idc02e6585-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s639"},"text":"Pub. L. 110–140, title VI, § 639","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3001/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2486"},"text":"134 Stat. 2486","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
