{"tag":"section","attrib":{"id":"idc08b791f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302"},"text":null,"children":[{"tag":"num","attrib":{"value":"19302"},"text":"§ 19302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean Energy Technology University Prize competition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08b7920-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b7921-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means a nonprofit entity, an institution of higher education, or an entity working with one or more institutions of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7922-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority-serving institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “minority-serving institution” means an institution described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7923-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program, known as the “Clean Energy Technology University Prize”, to award funding for eligible entities to carry out regional and one national clean energy technology prize competitions, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3719"},"text":"section 3719 of title 15","children":[],"tail":". In carrying out such prize competitions, students shall compete to develop a business model for furthering the commercial application of an innovative clean energy technology."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7924-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this program, the Secretary may provide funding to train participating students in skills needed for the successful commercial application of clean energy technologies, including through virtual training sessions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7925-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall prioritize awarding grants to eligible entities that work with students at minority-serving institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7926-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this program, the Secretary shall coordinate and partner with other clean energy technology prize competitions. In doing so, the Secretary may develop and disseminate best practices for administering prize competitions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7927-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary shall report annually on the progress and implementation of the program established under section (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7928-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16391a"},"text":"section 16391a of this title","children":[],"tail":", the Secretary shall submit to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Energy and Natural Resources of the Senate an evaluation on the long-term outcomes of the program established under this section and the progress towards achieving the purposes of the program in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b7929-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19302/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out the activities authorized in this section $1,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08b792a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10714"},"text":"Pub. L. 117–167, div. B, title VI, § 10714","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1703"},"text":"136 Stat. 1703","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
