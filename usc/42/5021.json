{"tag":"section","attrib":{"id":"idbcf09ee7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021"},"text":null,"children":[{"tag":"num","attrib":{"value":"5021"},"text":"§ 5021.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of National Senior Service Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf09ee8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf09ee9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this subchapter, the Director shall consult with the Departments of Labor and Health and Human Services, and any other Federal agencies administering relevant programs with a view to achieving optimal coordination with such other programs, and shall promote the coordination of projects under this subchapter with other public or private programs or projects carried out at State and local levels. Such Federal agencies shall cooperate with the Director in disseminating information about the availability of assistance under this subchapter and in promoting the identification and interest of low-income and other older persons whose services may be utilized in projects under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the maximum extent practicable, the Director shall enter into agreements with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf09eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Department of Health and Human Services to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcf09eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve retired and senior volunteers, and foster grandparents, in Head Start programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcf09eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve retired and senior volunteers, and senior companions, in providing services authorized by title III of the Older Americans Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3021"},"text":"42 U.S.C. 3021","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcf09eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the recognition of such volunteers who are qualified to provide in-home services for reimbursement under title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.] for providing such services;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf09eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Education to promote intergenerational tutoring and mentoring for at-risk children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf09ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Environmental Protection Agency to support conservation efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf09ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf09ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this subchapter, the Director shall encourage and facilitate the efforts of private organizations to promote the programs established in parts A, B, and C and the involvement of older individuals as volunteers in such programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall take appropriate actions to ensure that special efforts are made to publicize the programs established in parts A, B, and C, in order to facilitate recruitment efforts, to encourage greater participation of volunteers of all ages and backgrounds, living in urban or rural communities, and to emphasize the value of volunteering to the health and well-being of volunteers and the communities of such volunteers. Such actions shall include informing recipients of grants and contracts under this subchapter of all informational materials available from the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf09ef4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5021/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From funds appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5082"},"text":"section 5082 of this title","children":[],"tail":", the Director shall expend not less than $375,000 in each fiscal year to carry out paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf09ef5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/113/tII/s221"},"text":"Pub. L. 93–113, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-01"},"text":"Oct. 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/403"},"text":"87 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/143/s18/b"},"text":"Pub. L. 96–143, § 18(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-13"},"text":"Dec. 13, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1083"},"text":"93 Stat. 1083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s608/f/2"},"text":"Pub. L. 97–35, title VI, § 608(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/488"},"text":"95 Stat. 488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/204/tV/s505"},"text":"Pub. L. 101–204, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-07"},"text":"Dec. 7, 1989","children":[