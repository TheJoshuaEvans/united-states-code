{"tag":"section","attrib":{"id":"idc02e6559-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215"},"text":null,"children":[{"tag":"num","attrib":{"value":"17215"},"text":"§ 17215.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Marine Energy Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc02e655a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants, each such grant up to $10,000,000 per year, to institutions of higher education (or consortia thereof) for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e655b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuation and expansion of the research, development, demonstration, testing, and commercial application activities at the National Marine Energy Centers (referred to in this section as “Centers”) established as of ","children":[{"tag":"date","attrib":{"date":"2020-01-01"},"text":"January 1, 2020","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e655c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of new National Marine Energy Centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e655d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting institutions of higher education for new Centers, the Secretary shall consider the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e655e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the institution hosts an existing marine energy research and development program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e655f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the institution has proven technical expertise to support marine energy research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6560-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the institution has access to marine resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e6561-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Centers shall coordinate among themselves, the Department, and National Laboratories to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e6562-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance research, development, demonstration, and commercial application of marine energy technologies in response to industry and commercial needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6563-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support in-water testing and demonstration of marine energy technologies, including facilities capable of testing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc02e6564-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine energy systems of various technology readiness levels and scales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6565-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a variety of technologies in multiple test berths at a single location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6566-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrays of technology devices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc02e6567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interconnectivity to an electrical grid, including microgrids; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e6568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and disseminate information on best practices in all areas relating to developing and managing marine energy resources and energy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e6569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Centers shall coordinate their activities with the Secretary of Commerce, acting through the Undersecretary of Commerce for Oceans and Atmosphere, and other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc02e656a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17215/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent otherwise authorized by law, the Secretary may terminate funding for a Center described in paragraph (a) if such Center is under-performing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02e656b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s636"},"text":"Pub. L. 110–140, title VI, § 636","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3001/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2484"},"text":"134 Stat. 2484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02e656c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02e656d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc02e656e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 17215, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s636"},"text":"Pub. L. 110–140, title VI, § 636","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1688"},"text":"121 Stat. 1688","children":[],"tail":", related to authorization of appropriations, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
