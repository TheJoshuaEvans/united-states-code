{"tag":"section","attrib":{"id":"idbbe5979b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093"},"text":null,"children":[{"tag":"num","attrib":{"value":"2093"},"text":"§ 2093.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic distribution of source material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbe5979c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" License","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission is authorized to issue licenses for and to distribute source material within the United States to qualified applicants requesting such material—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe5979d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the conduct of research and development activities of the types specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2051"},"text":"section 2051 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe5979e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use in the conduct of research and development activities or in medical therapy under a license issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2134"},"text":"section 2134 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe5979f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for use under a license issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2133"},"text":"section 2133 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe597a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any other use approved by the Commission as an aid to science or industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe597a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum criteria for licenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall establish, by rule, minimum criteria for the issuance of specific or general licenses for the distribution of source material depending upon the degree of importance to the common defense and security or to the health and safety of the public of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbe597a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physical characteristics of the source material to be distributed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe597a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantities of source material to be distributed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbe597a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intended use of the source material to be distributed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbe597a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2093/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may make a reasonable charge determined pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2201/m"},"text":"section 2201(m) of this title","children":[],"tail":" for the source material licensed and distributed under subsection (a)(1), (a)(2), or (a)(4) and shall make a reasonable charge determined pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2201/m"},"text":"section 2201(m) of this title","children":[],"tail":", for the source material licensed and distributed under subsection (a)(3). The Commission shall establish criteria in writing for the determination of whether a charge will be made for the source material licensed and distributed under subsection (a)(1), (a)(2), or (a)(4), considering, among other things, whether the licensee is a nonprofit or eleemosynary institution and the purposes for which the source material will be used."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbe597a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 63, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/933"},"text":"68 Stat. 933","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbe597a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbe597a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbe597a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1805/b/3"},"text":"section 1805(b)(3) of this title","children":[],"tail":", prior to the general amendment and renumbering of act "},{"tag":"date","attrib":{"date":"1946-08-01"},"text":"Aug. 1, 1946","children":[],"tail":", by act "},{"tag":"date","attrib":{"date":"1954-08-30"},"text":"Aug. 30, 1954","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
