{"tag":"section","attrib":{"id":"idbe8d3838-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8273"},"text":null,"children":[{"tag":"num","attrib":{"value":"8273"},"text":"§ 8273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of the program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8272"},"text":"section 8272 of this title","children":[],"tail":" is to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe8d3839-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8273/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate the growth of a commercially viable and competitive industry to make photovoltaic solar electric systems available to the general public as an option in order to reduce national consumption of fossil fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d383a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8273/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce fossil fuel costs to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d383b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8273/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate the general use within the Federal Government of methods for the minimization of life cycle costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe8d383c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8273/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop performance data on the program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s8272"},"text":"section 8272 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe8d383d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s564"},"text":"Pub. L. 95–619, title V, § 564","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3280"},"text":"92 Stat. 3280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
