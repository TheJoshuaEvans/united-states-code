{"tag":"section","attrib":{"id":"idb5890542-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"288–1"},"text":"§ 288–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intramural loan repayment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5890543-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health shall, as appropriate and based on workforce and scientific priorities, carry out a program through the subcategories listed in subsection (b)(1) (or modified subcategories as provided for in subsection (b)(2)) of entering into agreements with appropriately qualified health professionals under which such health professionals agree to conduct research, as employees of the National Institutes of Health, in consideration of the Federal Government agreeing to repay, for each year of such service, not more than $50,000 of the principal and interest of the educational loans of such health professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5890544-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcategories of research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5890545-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Director of the National Institutes of Health—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5890546-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall continue to focus on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5890547-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5890548-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on acquired immune deficiency syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5890549-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical research conducted by appropriately qualified health professional ","children":[{"tag":"ref","attrib":{"idref":"fn002210"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002210"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “professionals”."}],"tail":" who are from disadvantaged backgrounds; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb589054a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may focus on an area of emerging scientific or workforce need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb589054b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination or establishment of subcategories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health may eliminate one or more subcategories provided for in paragraph (1) due to changes in workforce or scientific needs related to biomedical research. The Director may establish other subcategory areas based on workforce and scientific priorities if the total number of subcategories does not exceed the number of subcategories listed in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb589054c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institutes of Health may not enter into a contract with a health professional pursuant to subsection (a) unless such professional has a substantial amount of education loans relative to income (as determined pursuant to guidelines issued by the Director).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb589054d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the National Health Service Corps Loan Repayment Program established in subpart III of part D of subchapter II, the provisions of such subpart shall, except as inconsistent with subsection (a) of this section, apply to the program established in such subsection (a) in the same manner and to the same extent as such provisions apply to the National Health Service Corps Loan Repayment Program established in such subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5892c5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s288–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts available for carrying out this section shall remain available until the expiration of the second fiscal year beginning after the fiscal year for which such amounts are made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5892c5f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 487A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s634/a"},"text":"Pub. L. 100–607, title VI, § 634(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3148"},"text":"102 Stat. 3148","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVI/s1611/a"},"text":"Pub. L. 103–43, title XVI, § 1611(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/181"},"text":"107 Stat. 181","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tIV/s410/a"},"text":"Pub. L. 105–392, title IV, § 410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3589"},"text":"112 Stat. 3589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/48"},"text":"Pub. L. 109–482, title I, § 103(b)(48)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII/s2022/a"},"text":"Pub. L. 114–255, div. A, title II, § 2022(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1052"},"text":"130 Stat. 1052","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5892c60-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5892c61-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5892c62-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/a/1"},"text":"Pub. L. 114–255, § 2022(a)(1)","children":[],"tail":", amended section catchline generally. Prior to amendment, catchline read as follows: “Loan repayment program for research with respect to acquired immune deficiency syndrome”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/a/2"},"text":"Pub. L. 114–255, § 2022(a)(2)","children":[],"tail":", substituted “The Director of the National Institutes of Health shall, as appropriate and based on workforce and scientific priorities, carry out a program through the subcategories listed in subsection (b)(1) (or modified subcategories as provided for in subsection (b)(2))” for “The Secretary shall carry out a program”, “conduct research” for “conduct”, and “$50,000” for “$35,000”, and struck out “research with respect to acquired immune deficiency syndrome” after “National Institutes of Health,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/a/3"},"text":"Pub. L. 114–255, § 2022(a)(3)","children":[],"tail":", (4), added subsecs. (b) and (c) and redesignated former subsec. (b) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2022/a/5"},"text":"Pub. L. 114–255, § 2022(a)(5)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (c). Text read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated such sums as may be necessary for each of the fiscal years 1994 through 2001.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s410/a/1"},"text":"Pub. L. 105–392, § 410(a)(1)","children":[],"tail":", substituted “$35,000” for “$20,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/392/s410/a/2"},"text":"Pub. L. 105–392, § 410(a)(2)","children":[],"tail":", substituted “2001” for “1996”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43"},"text":"Pub. L. 103–43","children":[],"tail":" amended section generally, in subsec. (a) redesignating former par. (1) as entire subsec., striking out provisions setting a deadline for implementation of the program and former par. (2) containing a limitation that the health professional have a substantial amount of educational loans relative to income and not have been employed at the National Institutes of Health during the 1-year period preceding "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", reenacting subsec. (b) without change, and in subsec. (c) redesignating former par. (1) as entire subsec., substituting authorization of appropriations for fiscal years 1994 through 1996 for authorization of appropriations for fiscal years 1989 through 1991, and striking out former par. (2) relating to continued availability of appropriated amounts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5895373-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5895374-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb5895375-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXVI/s1611/b"},"text":"Pub. L. 103–43, title XVI, § 1611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/182"},"text":"107 Stat. 182","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/43/tXVI/s1611/b"},"text":"“The amendment made by subsection (a) [amending this section] does not apply to any agreement entered into under section 487A of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s288–1"},"text":"42 U.S.C. 288–1","children":[],"tail":"] before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":"]. Each such agreement continues to be subject to the terms of the agreement in effect on the day before such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
