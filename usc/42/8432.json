{"tag":"section","attrib":{"id":"idbe96ad9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8432"},"text":null,"children":[{"tag":"num","attrib":{"value":"8432"},"text":"§ 8432.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who willfully violates any provision of this chapter, or any rule or order thereunder, shall be subject to a fine of not more than $50,000, or to imprisonment for not more than one year, or both, for each violation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe96ada0-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620/tVII/s722"},"text":"Pub. L. 95–620, title VII, § 722","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3333"},"text":"92 Stat. 3333","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/42/s1/c/19"},"text":"Pub. L. 100–42, § 1(c)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-05-21"},"text":"May 21, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/313"},"text":"101 Stat. 313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe96ada1-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe96ada2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe96ada3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/620"},"text":"Pub. L. 95–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3289"},"text":"92 Stat. 3289","children":[],"tail":", known as the Powerplant and Industrial Fuel Use Act of 1978, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe96ada4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/42"},"text":"Pub. L. 100–42","children":[],"tail":" struck out “(other than "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8372"},"text":"section 8372 of this title","children":[],"tail":")” after “this chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
