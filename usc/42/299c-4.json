82","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", which Act enacted Title 31, Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb607853d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 299c–4, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIX/s925"},"text":"act July 1, 1944, ch. 373, title IX, § 925","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI/s6103/c"},"text":"Pub. L. 101–239, title VI, § 6103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2203"},"text":"103 Stat. 2203","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1723/a/3/B"},"text":"Pub. L. 104–201, div. A, title XVII, § 1723(a)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2759"},"text":"110 Stat. 2759","children":[],"tail":", related to certain administrative authorities, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/129"},"text":"Pub. L. 106–129","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s299c–5"},"text":"section 299c–5 of this title","children":[],"tail"