{"tag":"section","attrib":{"id":"idbc17a452-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2286j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2286j"},"text":"§ 2286j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of inspector general services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Within 90 days of ","children":[{"tag":"date","attrib":{"date":"2011-12-23"},"text":"December 23, 2011","children":[],"tail":", the Defense Nuclear Facilities Safety Board shall enter into an agreement for inspector general services with the Office of Inspector General for the Nuclear Regulatory Commission for fiscal years 2012 and 2013: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That at the expiration of such agreement, the Defense Nuclear Facilities Safety Board shall procure inspector general services annually thereafter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc17a453-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dB/tIV"},"text":"Pub. L. 112–74, div. B, title IV","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/880"},"text":"125 Stat. 880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc17a454-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc17a455-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc17a456-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Energy and Water Development and Related Agencies Appropriations Act, 2012, and also as part of the Consolidated Appropriations Act, 2012, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
