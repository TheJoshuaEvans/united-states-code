{"tag":"section","attrib":{"id":"idbff79e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181"},"text":null,"children":[{"tag":"num","attrib":{"value":"16181"},"text":"§ 16181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff79e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to achieve the purposes of this subchapter, the Secretary shall conduct a balanced set of programs of energy research, development, demonstration, and commercial application with the general goals of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the efficiency of all energy intensive sectors through conservation and improved technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting diversity of energy supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreasing the dependence of the United States on foreign energy supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the energy security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreasing the environmental impact of energy-related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall publish measurable cost and performance-based goals, comparable over time, with each annual budget submission in at least the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff79e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Energy efficiency for buildings, energy-consuming industries, and vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electric energy generation (including distributed generation), transmission, and storage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Renewable energy technologies, including wind power, photovoltaics, solar thermal systems, geothermal energy, hydrogen-fueled systems, biomass-based systems, biofuels, and hydropower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fossil energy, including power generation, onshore and offshore oil and gas resource recovery, and transportation fuels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff79e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nuclear energy, including programs for existing and advanced reactors, and education of future specialists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide mechanisms for input on the annually published goals from industry, institutions of higher education, and other public sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff79e3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16181/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of goals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) or the annually published goals creates any new authority for any Federal agency, or may be used by any Federal agency, to support the establishment of regulatory standards or regulatory requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff79e40-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s902"},"text":"Pub. L. 109–58, title IX, § 902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/856"},"text":"119 Stat. 856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff79e41-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff79e42-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbff79e43-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (a), was in the original “this title”, meaning title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/856"},"text":"119 Stat. 856","children":[],"tail":", which enacted this subchapter, amended sections 8101 and 8102 of Title 7, Agriculture, and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s5523"},"text":"section 5523 of Title 15","children":[],"tail":", Commerce and Trade, enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8102"},"text":"section 8102 of Title 7","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s2001"},"text":"section 2001 of Title 30","children":[],"tail":", Mineral Lands and Mining, and amended provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"section 8101 of Title 7","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t30/s1902"},"text":"section 1902 of Title 30","children":[],"tail":". For complete classification of title IX to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff79e44-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbff79e45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58"},"text":"Pub. L. 109–58","children":[],"tail":", which enacted this subchapter, as the “Energy Research, Development, Demonstration, and Commercial Application Act of 2005”, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/s431"},"text":"section 431 of Pub. L. 109–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801"},"text":"section 15801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
