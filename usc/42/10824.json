{"tag":"section","attrib":{"id":"idbf31b567-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824"},"text":null,"children":[{"tag":"num","attrib":{"value":"10824"},"text":"§ 10824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf31b568-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall include in each report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15005"},"text":"section 15005 of this title","children":[],"tail":" a separate statement which contains—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf31b569-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the activities, accomplishments, and expenditures of systems to protect and advocate the rights of individuals with mental illness supported with payments from allotments under this subchapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf31b56a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification of the total number of individuals with mental illness served by such systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b56b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of activities undertaken by such systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b56c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the types of facilities providing care or treatment with respect to which such activities are undertaken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b56d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the manner in which such activities are initiated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b56e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the accomplishments resulting from such activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b56f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf31b570-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" systems to protect and advocate the rights of individuals with mental illness supported with payments from allotments under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b571-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities conducted by States to protect and advocate such rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b572-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanisms established by residential facilities for individuals with mental illness to protect and advocate such rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf31b573-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination among such systems, activities, and mechanisms;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b574-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specification of the number of systems established with allotments under this subchapter and of whether each such system was established by a public or nonprofit private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b575-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for activities and services to improve the protection and advocacy of the rights of individuals with mental illness and a description of needs for such activities and services which have not been met by systems established under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf31b576-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using data from the existing required annual program progress reports submitted by each system funded under this subchapter, a detailed accounting for each such system of how funds are spent, disaggregated according to whether the funds were received from the Federal Government, the State government, a local government, or a private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf31b577-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10824/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In preparing each statement required by subsection (a), the Secretary shall use and include information submitted to the Secretary in the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s10805/a/7"},"text":"section 10805(a)(7) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf31b578-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/319/tI/s114"},"text":"Pub. L. 99–319, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-23"},"text":"May 23, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/484"},"text":"100 Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/173/s10/2"},"text":"Pub. L. 102–173, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-27"},"text":"Nov. 27, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1219"},"text":"105 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/402/tIV/s401/b/13/B"},"text":"Pub. L. 106–402, title IV, § 401(b)(13)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1739"},"text":"114 Stat. 1739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVI/s6022/b"},"text":"Pub. L. 114–255, div. B, title VI, § 6022(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1216"},"text":"130 Stat. 1216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf31b579-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf31b57a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf31b57b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255"},"text":"Pub. L. 114–255","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402"},"text":"Pub. L. 106–402","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15005"},"text":"section 15005 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6006/c"},"text":"section 6006(c) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/173"},"text":"Pub. L. 102–173","children":[],"tail":" substituted “individuals with mental illness” for “mentally ill individuals” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
