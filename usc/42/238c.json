{"tag":"section","attrib":{"id":"idb4806fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s238c"},"text":null,"children":[{"tag":"num","attrib":{"value":"238c"},"text":"§ 238c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of remains of officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations available for traveling expenses of the Service shall be available for meeting the cost of preparation for burial and of transportation to the place of burial of remains of commissioned officers, and of personnel specified in regulations, who die in line of duty. Appropriations available for carrying out the provisions of this chapter shall also be available for the payment of such expenses relating to the recovery, care and disposition of the remains of personnel or their dependents as may be authorized under other provisions of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4806fbd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 234, formerly title V, § 506, "},{"tag":"ref","attrib":{"href":"/us/stat/58/710"},"text":"58 Stat. 710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-07-15/ch507/s14/b"},"text":"July 15, 1954, ch. 507, § 14(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/481"},"text":"68 Stat. 481","children":[],"tail":"; renumbered title XXI, § 2106, "},{"tag":"ref","attrib":{"href":"/us/pl/98/24/s2/a/1"},"text":"Pub. L. 98–24, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-04-26"},"text":"Apr. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/176"},"text":"97 Stat. 176","children":[],"tail":"; renumbered title XXIII, § 2306, "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/a"},"text":"Pub. L. 99–660, title III, § 311(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3755"},"text":"100 Stat. 3755","children":[],"tail":"; renumbered title XXV, § 2504, "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tII/s201/1"},"text":"Pub. L. 100–607, title II, § 201(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3062"},"text":"102 Stat. 3062","children":[],"tail":", 3063; renumbered title XXVI, § 2604, "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2620/a"},"text":"Pub. L. 100–690, title II, § 2620(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4244"},"text":"102 Stat. 4244","children":[],"tail":"; renumbered title XXVII, § 2704, "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tI/s101/1"},"text":"Pub. L. 101–381, title I, § 101(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/576"},"text":"104 Stat. 576","children":[],"tail":"; renumbered title II, § 234, "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tXX/s2010/a/1"},"text":"Pub. L. 103–43, title XX, § 2010(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/213"},"text":"107 Stat. 213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4806fbe-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4806fbf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"chil