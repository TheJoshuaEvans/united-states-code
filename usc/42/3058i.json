{"tag":"section","attrib":{"id":"idbc6b1bf9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058i"},"text":"§ 3058i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of elder abuse, neglect, and exploitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6b1bfa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to receive an allotment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058b"},"text":"section 3058b of this title","children":[],"tail":" from funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" and made available to carry out this subpart, a State agency shall, in accordance with this section, and in consultation with area agencies on aging, develop and enhance programs to address elder abuse, neglect, and exploitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1bfb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of allotments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The State agency shall use an allotment made under subsection (a) to carry out, through the programs described in subsection (a), activities to develop, strengthen, and carry out programs for the prevention, detection, assessment, and treatment of, intervention in, investigation of, and response to elder abuse, neglect, and exploitation, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6b1bfc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for public education and outreach to identify and prevent elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1bfd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for public education and outreach to promote financial literacy and prevent identity theft and financial exploitation of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1bfe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the coordination of services provided by area agencies on aging with services instituted under the State adult protection service program, State and local law enforcement systems, and courts of competent jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1bff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the development of information and data systems, including elder abuse reporting systems, to quantify the extent of elder abuse, neglect, and exploitation in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the submission of data on elder abuse, neglect, and exploitation for the appropriate database of the Administration or another database specified by the Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting analyses of State information concerning elder abuse, neglect, and exploitation and identifying unmet service, enforcement, or intervention needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting training for individuals, including caregivers described in part E of subchapter III, professionals, and paraprofessionals, in relevant fields on the identification, prevention, and treatment of elder abuse, neglect, and exploitation, with particular focus on prevention and enhancement of self-determination and autonomy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance to programs that provide or have the potential to provide services for victims of elder abuse, neglect, and exploitation and for family members of the victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting special and on-going training, for individuals involved in serving victims of elder abuse, neglect, and exploitation, on the topics of self-determination, individual rights, State and Federal requirements concerning confidentiality, and other topics determined by a State agency to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promoting the development of an elder abuse, neglect, and exploitation system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6b1c06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that includes a State elder abuse, neglect, and exploitation law that includes provisions for immunity, for persons reporting instances of elder abuse, neglect, and exploitation, from prosecution arising out of such reporting, under any State or local law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which a State agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc6b1c08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on receipt of a report of known or suspected instances of elder abuse, neglect, or exploitation, shall promptly initiate an investigation to substantiate the accuracy of the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a finding of elder abuse, neglect, or exploitation, shall take steps, including appropriate referral, to protect the health and welfare of the abused, neglected, or exploited older individual;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that includes, throughout the State, in connection with the enforcement of elder abuse, neglect, and exploitation laws and with the reporting of suspected instances of elder abuse, neglect, and exploitation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc6b1c0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such administrative procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such personnel, such as forensic specialists, trained in the special problems of elder abuse, neglect, and exploitation prevention and treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such training procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such institutional and other facilities (public and private); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such related multidisciplinary programs and services, including programs and arrangements that protect against financial exploitation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as may be necessary or appropriate to ensure that the State will deal effectively with elder abuse, neglect, and exploitation cases in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that preserves the confidentiality of records in order to protect the rights of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides for the cooperation of law enforcement officials, courts of competent jurisdiction, and State agencies providing human services with respect to special problems of elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that enables an older individual to participate in decisions regarding the welfare of the older individual, and makes the least restrictive alternatives available to an older individual who is abused, neglected, or exploited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that includes a State clearinghouse for dissemination of information to the general public with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbc6b1c14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the problems of elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facilities described in subparagraph (C)(iv); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbc6b1c16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/10/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention and treatment methods available to combat instances of elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining various types of shelters serving older individuals (in this paragraph referred to as “safe havens”), and testing various safe haven models for establishing safe havens (at home or elsewhere), that recognize autonomy and self-determination, and fully protect the due process rights of older individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supporting multidisciplinary elder justice activities, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6b1c19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and studying team approaches for bringing a coordinated multidisciplinary or interdisciplinary response to elder abuse, neglect, and exploitation, including a response from individuals in social service, health care, public safety, and legal disciplines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a State coordinating council, which shall identify the individual State’s needs and provide the Assistant Secretary with information and recommendations relating to efforts by the State to combat elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training, technical assistance, community outreach and education, and other methods of support to groups carrying out multidisciplinary efforts at the State (referred to in some States as “State Working Groups”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broadening and studying various models for elder fatality and serious injury review teams, to make recommendations about their composition, protocols, functions, timing, roles, and responsibilities, with a goal of producing models and information that will allow for replication based on the needs of States and communities (other than the ones in which the review teams were used);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing best practices, for use in long-term care facilities, that reduce the risk of elder abuse for residents, including the risk of resident-to-resident abuse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/12/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and implementing innovative practices, programs, and materials in communities to develop partnerships across disciplines for the prevention, investigation, and prosecution of abuse, neglect, and exploitation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" addressing underserved populations of older individuals, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6b1c20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" older individuals living in rural locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" older individuals in minority populations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/b/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-income older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing and enhancing programs under subsection (a), the State agency shall use a comprehensive approach, in consultation with area agencies on aging, to identify and assist older individuals who are subject to abuse, neglect, and exploitation, including older individuals who live in State licensed facilities, unlicensed facilities, or domestic or community-based settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and enhancing programs under subsection (a), the State agency shall coordinate the programs with other State and local programs and services for the protection of vulnerable adults, particularly vulnerable older individuals, including programs and services such as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6b1c25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" area agency on aging programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adult protective service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Long-Term Care Ombudsman program established in subpart II of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection and advocacy programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility and long-term care provider licensure and certification programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medicaid fraud and abuse services, including services provided by a State medicaid fraud control unit, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/q"},"text":"section 1396b(q) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victim assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer protection and State and local law enforcement programs, as well as other State and local programs that identify and assist vulnerable older individuals, and services provided by agencies and courts of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and enhancing programs under subsection (a), the State agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6b1c2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not permit involuntary or coerced participation in such programs by alleged victims, abusers, or members of their households;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require that all information gathered in the course of receiving a report described in subsection (b)(10)(B)(i), and making a referral described in subsection (b)(10)(B)(ii), shall remain confidential except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6b1c30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if all parties to such complaint or report consent in writing to the release of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the release of such information is to a law enforcement agency, public protective service agency, licensing or certification agency, ombudsman program, or protection or advocacy system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon court order; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make all reasonable efforts to resolve any conflicts with other public agencies with respect to confidentiality of the information described in paragraph (2) by entering into memoranda of understanding that narrowly limit disclosure of information, consistent with the requirement described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State agency may designate a State entity to carry out the programs and activities described in this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6b1c36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Department of the Treasury and the Attorney General of the United States, State attorneys general, and tribal and local prosecutors, shall conduct a study of the nature and extent of financial exploitation of older individuals. The purpose of this study would be to define and describe the scope of the problem of financial exploitation of the elderly and to provide an estimate of the number and type of financial transactions considered to constitute financial exploitation faced by older individuals. The study shall also examine the adequacy of current Federal and State legal protections to prevent such exploitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6b1c37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2000-11-13"},"text":"November 13, 2000","children":[],"tail":", the Secretary shall submit to Congress a report, which shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6b1c38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the study conducted under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6b1c39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for future actions to combat the financial exploitation of older individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall develop accountability measures to ensure the effectiveness of the activities carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluating programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall evaluate the activities carried out under this section, using funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3017/h"},"text":"section 3017(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6b1c3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058i/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with applicable laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to receive funds made available to carry out this section, an entity shall comply with all applicable laws, regulations, and guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6b1c3d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s721"},"text":"Pub. L. 89–73, title VII, § 721","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s703/b"},"text":"Pub. L. 102–375, title VII, § 703(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1282"},"text":"106 Stat. 1282","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVII/s705"},"text":"Pub. L. 106–501, title VII, § 705","children":[],"tail":", title VIII, § 801(e)(3), "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2290"},"text":"114 Stat. 2290","children":[],"tail":", 2293; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tVII/s702"},"text":"Pub. L. 109–365, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2591"},"text":"120 Stat. 2591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e"},"text":"Pub. L. 114–144, § 8(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-04-19"},"text":"Apr. 19, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/351"},"text":"130 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/131/tVI/s603"},"text":"Pub. L. 116–131, title VI, § 603","children":[],"tail":", title VII, § 701(12), "},{"tag":"date","attrib":{"date":"2020-03-25"},"text":"Mar. 25, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/269"},"text":"134 Stat. 269","children":[],"tail":", 272.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6b1c3e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6b1c3f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc6b1c40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(12)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s603/1"},"text":"Pub. L. 116–131, § 603(1)","children":[],"tail":", inserted “community outreach and education,” after “technical assistance,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s603/2"},"text":"Pub. L. 116–131, § 603(2)","children":[],"tail":", substituted “implementing” for “studying” and inserted “, programs, and materials” after “practices”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/131/s701/12"},"text":"Pub. L. 116–131, § 701(12)","children":[],"tail":", substituted “3017(h) of this title” for “3017(g) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/A"},"text":"Pub. L. 114–144, § 8(e)(1)(A)","children":[],"tail":", struck out “(including financial exploitation)” after “and exploitation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/B"},"text":"Pub. L. 114–144, § 8(e)(1)(B)","children":[],"tail":", (C), added par. (5) and redesignated former pars. (5) to (9) as (6) to (10), respectively. Former par. (10) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/D/i"},"text":"Pub. L. 114–144, § 8(e)(1)(D)(i)","children":[],"tail":", inserted “, such as forensic specialists,” after “such personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10)(C)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/D/ii"},"text":"Pub. L. 114–144, § 8(e)(1)(D)(ii)","children":[],"tail":", inserted before comma at end “, including programs and arrangements that protect against financial exploitation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(11), (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/B"},"text":"Pub. L. 114–144, § 8(e)(1)(B)","children":[],"tail":", redesignated pars. (10) and (11) as (11) and (12), respectively. Former par. (12) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/E"},"text":"Pub. L. 114–144, § 8(e)(1)(E)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/1/B"},"text":"Pub. L. 114–144, § 8(e)(1)(B)","children":[],"tail":", redesignated par. (12) as (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/144/s8/e/2"},"text":"Pub. L. 114–144, § 8(e)(2)","children":[],"tail":", substituted “subsection (b)(10)(B)(i)” for “subsection (b)(9)(B)(i)” and “subsection (b)(10)(B)(ii)” for “subsection (b)(9)(B)(ii)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s702/1"},"text":"Pub. L. 109–365, § 702(1)","children":[],"tail":", substituted “programs to address” for “programs for the prevention of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s702/2/A"},"text":"Pub. L. 109–365, § 702(2)(A)","children":[],"tail":", substituted “programs for the prevention, detection, assessment, and treatment of, intervention in, investigation of, and response to elder abuse, neglect, and exploitation (including financial exploitation), including—” for “programs for the prevention and treatment of elder abuse, neglect, and exploitation (including financial exploitation), including—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s702/2/B"},"text":"Pub. L. 109–365, § 702(2)(B)","children":[],"tail":", (C), added par. (2) and redesignated former pars. (2) to (8) as (3) to (9), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s702/2/D"},"text":"Pub. L. 109–365, § 702(2)(D)","children":[],"tail":"–(F), added pars. (10) to (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s702/3"},"text":"Pub. L. 109–365, § 702(3)","children":[],"tail":", substituted “subsection (b)(9)(B)(i)” for “subsection (b)(8)(B)(i)” and “subsection (b)(9)(B)(ii)” for “subsection (b)(8)(B)(ii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s702/4"},"text":"Pub. L. 109–365, § 702(4)","children":[],"tail":", added subsecs. (h) to (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s801/e/3"},"text":"Pub. L. 106–501, § 801(e)(3)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a"},"text":"section 3058a of this title","children":[],"tail":" and made available to carry out this subpart” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3058a/b"},"text":"section 3058a(b) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s705/1/A"},"text":"Pub. L. 106–501, § 705(1)(A)","children":[],"tail":", in introductory provisions, inserted “(including financial exploitation)” after “exploitation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s705/1/B"},"text":"Pub. L. 106–501, § 705(1)(B)","children":[],"tail":", inserted “, State and local law enforcement systems, and courts of competent jurisdiction” after “service program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501/s705/1/C"},"text":"Pub. L. 106–501, § 705(1)(C)","children":[],"tail":", inserted “including caregivers described in part E of subchapter III,” after “individuals,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(8). ","children":[{"tag":"ref","attrib":{"href