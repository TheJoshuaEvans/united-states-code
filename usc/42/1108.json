{"tag":"section","attrib":{"id":"idb80f13eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108"},"text":null,"children":[{"tag":"num","attrib":{"value":"1108"},"text":"§ 1108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council on Unemployment Compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb80f13ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"February 1, 1992","children":[],"tail":", and every 4th year thereafter, the Secretary of Labor shall establish an advisory council to be known as the Advisory Council on Unemployment Compensation (referred to in this section as the “Council”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f13ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be the function of each Council to evaluate the unemployment compensation program, including the purpose, goals, countercyclical effectiveness, coverage, benefit adequacy, trust fund solvency, funding of State administrative costs, administrative efficiency, and any other aspects of the program and to make recommendations for improvement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f13ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f13ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Council shall consist of 11 members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb80f13f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members appointed by the President, to include representatives of business, labor, State government, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f13f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the President pro tempore of the Senate, in consultation with the Chairman and ranking member of the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f13f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the Speaker of the House of Representatives, in consultation with the Chairman and ranking member of the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f13f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In appointing members under subparagraphs (B) and (C) of paragraph (1), the President pro tempore of the Senate and the Speaker of the House of Representatives shall each appoint—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb80f13f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the interests of business,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f13f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the interests of labor, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f13f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of the interests of State governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f13f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in any Council shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f13f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint the Chairman of the Council from among its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f13f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff and other assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f13fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Council may engage any technical assistance (including actuarial services) required by the Council to carry out its functions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f13fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from Secretary of Labor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor shall provide each Council with any staff, office facilities, and other assistance, and any data prepared by the Department of Labor, required by the Council to carry out its functions under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f13fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of any Council—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f13fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be entitled to receive compensation at the rate of pay for level V of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of title 5","children":[],"tail":" for each day (including travel time) during which such member is engaged in the actual performance of duties vested in the Council, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f13fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while engaged in the performance of such duties away from such member’s home or regular place of business, shall be allowed travel expenses (including per diem in lieu of subsistence) as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons in the Government employed intermittently."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f13ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f1400-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than February 1 of the third year following the year in which any Council is required to be established under subsection (a), the Council shall submit to the President and the Congress a report setting forth the findings and recommendations of the Council as a result of its evaluation of the unemployment compensation program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1401-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1108/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of first Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall include in its report required to be submitted by ","children":[{"tag":"date","attrib":{"date":"1995-02-01"},"text":"February 1, 1995","children":[],"tail":", the Council’s findings and recommendations with respect to determining eligibility for extended unemployment benefits on the basis of unemployment statistics for regions, States, or subdivisions of States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb80f1402-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IX, § 908, as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/373/tI/s141"},"text":"Pub. L. 91–373, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-10"},"text":"Aug. 10, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/706"},"text":"84 Stat. 706","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVI/s2663/d/4"},"text":"Pub. L. 98–369, div. B, title VI, § 2663(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1167"},"text":"98 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/164/tIII/s303"},"text":"Pub. L. 102–164, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-15"},"text":"Nov. 15, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1059"},"text":"105 Stat. 1059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/152/s6"},"text":"Pub. L. 103–152, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1518"},"text":"107 Stat. 1518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb80f1403-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb80f1404-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb80f1405-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/107/s9"},"text":"Section 9 of Pub. L. 102–107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-17"},"text":"Aug. 17, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/547"},"text":"105 Stat. 547","children":[],"tail":", which contained provisions substantially identical to those of "},{"tag":"ref","attrib":{"href":"/us/pl/102/164/s303"},"text":"section 303 of Pub. L. 102–164","children":[],"tail":", amending this section, did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/102/107/s10/b"},"text":"section 10(b) of Pub. L. 102–107","children":[],"tail":", because the President did not take the action required by that section by "},{"tag":"date","attrib":{"date":"1991-08-17"},"text":"Aug. 17, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb80f1406-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 1108, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tIX/s908"},"text":"act Aug. 14, 1935, ch. 531, title IX, § 908","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/643"},"text":"49 Stat. 643","children":[],"tail":", related to rules and regulations. For further details, see Prior Law note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb80f1407-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/152"},"text":"Pub. L. 103–152","children":[],"tail":" substituted “third year” for “2d year” in par. (1) and “1995” for “1994” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/164"},"text":"Pub. L. 102–164","children":[],"tail":" amended section generally, substituting present provisions for provisions which in subsec. (a) established the Federal Advisory Council and its membership, in subsec. (b) prescribed the appointment of its members, in subsec. (c) required that secretarial, clerical, and other assistance be made available to the Council, in subsec. (d) provided for compensation of members, in subsec. (e) encouraged the organization of State advisory councils, and in subsec. (f) authorized certain appropriations for the work of the Council."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" substituted “5703” for “5703(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb80f1408-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb80f1409-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", but not to be construed as changing or affecting any right, liability, status, or interpretation which existed (under the provisions of law involved) before that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2664/b"},"text":"section 2664(b) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb80f140a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory councils established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by the Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb80f140b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Agricultural Labor Performed by Aliens","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/318/tIII/s303/b"},"text":"Pub. L. 102–318, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-03"},"text":"July 3, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/297"},"text":"106 Stat. 297","children":[],"tail":", directed Advisory Council on Unemployment Compensation to submit a report to Congress, not later than "},{"tag":"date","attrib":{"date":"1994-02-01"},"text":"Feb. 1, 1994","children":[],"tail":", on its recommendations with respect to the treatment of agricultural labor performed by aliens."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
