{"tag":"section","attrib":{"id":"idb58d9986-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289f"},"text":null,"children":[{"tag":"num","attrib":{"value":"289f"},"text":"§ 289f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts and donations; memorials","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s238"},"text":"section 238 of this title","children":[],"tail":", accept conditional gifts for the National Institutes of Health or a national research institute or for the acquisition of grounds or for the erection, equipment, or maintenance of facilities for the National Institutes of Health or a national research institute. Donations of $50,000 or over for the National Institutes of Health or a national research institute for carrying out the purposes of this subchapter may be acknowledged by the establishment within the National Institutes of Health or a national research institute of suitable memorials to the donors."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb58f4737-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 497, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/877"},"text":"99 Stat. 877","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIII/s311/b/1"},"text":"Pub. L. 99–660, title III, § 311(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3779"},"text":"100 Stat.