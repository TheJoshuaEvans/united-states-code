{"tag":"section","attrib":{"id":"idc024ef07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084"},"text":null,"children":[{"tag":"num","attrib":{"value":"17084"},"text":"§ 17084.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate spaces with high-performance energy efficiency measures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc024ef08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-performance energy efficiency measure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-performance energy efficiency measure” means a technology, product, or practice that will result in substantial operational cost savings by reducing energy consumption and utility costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate spaces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “separate spaces” means areas within a commercial building that are leased or otherwise occupied by a tenant or other occupant for a period of time pursuant to the terms of a written agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", the Secretary, acting through the Assistant Secretary of Energy Efficiency and Renewable Energy, shall complete a study on the feasibility of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly improving energy efficiency in commercial buildings through the design and construction, by owners and tenants, of separate spaces with high-performance energy efficiency measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging owners and tenants to implement high-performance energy efficiency measures in separate spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The study shall, at a minimum, include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" descriptions of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc024ef11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-performance energy efficiency measures that should be considered as part of the initial design and construction of separate spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes that owners, tenants, architects, and engineers may replicate when designing and constructing separate spaces with high-performance energy efficiency measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and best practices to achieve reductions in energy intensities for lighting, plug loads, heating, cooling, cooking, laundry, and other systems to satisfy the needs of the commercial building tenant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return on investment and payback analyses of the incremental cost and projected energy savings of the proposed set of high-performance energy efficiency measures, including consideration of available incentives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" models and simulation methods that predict the quantity of energy used by separate spaces with high-performance energy efficiency measures and that compare that predicted quantity to the quantity of energy used by separate spaces without high-performance energy efficiency measures but that otherwise comply with applicable building code requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurement and verification platforms demonstrating actual energy use of high-performance energy efficiency measures installed in separate spaces, and whether such measures generate the savings intended in the initial design and construction of the separate spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices that encourage an integrated approach to designing and constructing separate spaces to perform at optimum energy efficiency in conjunction with the central systems of a commercial building; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc024ef18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impact on employment resulting from the design and construction of separate spaces with high-performance energy efficiency measures; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef19-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" case studies reporting economic and energy savings returns in the design and construction of separate spaces with high-performance energy efficiency measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", the Secretary shall publish a notice in the Federal Register requesting public comments regarding effective methods, measures, and practices for the design and construction of separate spaces with high-performance energy efficiency measures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17084/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish the study on the website of the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc024ef1c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s424"},"text":"Pub. L. 110–140, title IV, § 424","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/11/tI/s103/a"},"text":"Pub. L. 114–11, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-30"},"text":"Apr. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/183"},"text":"129 Stat. 183","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
