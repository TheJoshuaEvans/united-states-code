{"tag":"section","attrib":{"id":"idb53cb9d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c"},"text":null,"children":[{"tag":"num","attrib":{"value":"280g–4c"},"text":"§ 280g–4c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanding access to forensics for victims of interpersonal violence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53cb9d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cb9da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community health aide; community health practitioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “community health aide” and “community health practitioner” have the meanings given such terms for purposes of section 1616","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of title 25."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care provider","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health care provider” has the meaning given such term by the Secretary, and includes registered nurses, nurse practitioners, nurse midwives, clinical nurse specialists, physician assistants, and physicians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe; Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Indian Tribe” and “Tribal organization” shall have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interpersonal violence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interpersonal violence” means any form of violence that is emotional and trauma-inducing for victims, families of victims, perpetrators, and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native Hawaiian organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Native Hawaiian organization” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11711"},"text":"section 11711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trauma-informed care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “trauma-informed care” means care received by trauma survivors that is culturally competent in accordance with professional standards of practice and accounting for patients’ experiences and preferences in order to eliminate or mitigate triggers that may cause re-traumatization of the patient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban Indian organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Urban Indian organization” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s1603"},"text":"section 1603 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cb9e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration grants for comprehensive forensic training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cb9e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a demonstration program to award grants to eligible entities for the clinical training of health care providers to provide generalist forensic services and trauma-informed care to survivors of interpersonal violence of all ages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the demonstration program under this subsection is to develop training and curriculum to provide health care providers with the skills to support the provision of forensic assessment and trauma-informed care to individuals, families, and communities that have experienced violence or trauma and to be available to collaborate with members of an inter-professional forensic team.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this subsection shall be for a term of 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this subsection, an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cb9e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an institute of higher education, including a minority serving institution as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q"},"text":"section 1067q of title 20","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cb9e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant awarded under this subsection shall be in an amount that does not exceed $400,000 per year. A grant recipient may carry over funds from one fiscal year to the next without obtaining approval from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53cb9ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $5,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53cb9ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Set-aside","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount appropriated under this paragraph for a fiscal year, the Secretary shall reserve 10 percent for purposes of making grants to support training and curricula that addresses the unique needs of Indian Tribes, Tribal organizations, Urban Indian organizations, and Native Hawaiian organizations. Amounts so reserved may be used to support training, referrals, and the delivery of emergency first aid, culturally competent support, and forensic evidence collection training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cb9ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance grants and learning collectives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cb9ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a State and Tribal forensic provider technical resource center to provide technical assistance and support collaboration and best practices for health care providers, community health aides, and community health practitioners to improve the quality of, and increase access to, forensic services for all survivors of interpersonal violence. The Secretary may enter into contracts with national experts for purposes of carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection, $2,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53cb9f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"March 15, 2022","children":[],"tail":", and annually thereafter, the Office for Victims of Crime of the Department of Justice, the Centers for Disease Control and Prevention, the Health Resources and Services Administration, the Indian Health Service, the Office on Women’s Health of the Department of Health and Human Services, and the Office on Violence Against Women of the Department of Justice shall jointly submit to the Secretary a report on the need for, throughout the States, Indian Tribes, and territories—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53cb9f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to generalist medical forensic services, evidence collection, and documentation that aids in meeting the needs of health care patients and improves future law enforcement investigation and prosecution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53cb9f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s280g–4c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data for research to support the response to and prevention of interpersonal violence, improved ability of health care providers to adequately respond to patients who exhibit signs of victimization, and address the unique needs of Tribal communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53cb9f4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/tV/s507"},"text":"Pub. L. 117–103, div. W, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/879"},"text":"136 Stat. 879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53cb9f5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53cb9f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb53cb9f7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Violence Against Women Act Reauthorization Act of 2022, and also as part of the Consolidated Appropriations Act, 2022, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb53cb9f8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb53cb9f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section not effective until Oct. 1 of the first fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s4/a"},"text":"section 4(a) of div. W of Pub. L. 117–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s6851"},"text":"section 6851 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb53cb9fa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “law enforcement” and “State” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of Title 34","children":[],"tail":", Crime Control and Law Enforcement, as made applicable by "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dW/s2/b"},"text":"section 2(b) of div. W of Pub. L. 117–103","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t34/s12291"},"text":"section 12291 of Title 34","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
