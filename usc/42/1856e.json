{"tag":"section","attrib":{"id":"idbb817eea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1856e"},"text":"§ 1856e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of fire funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb817eeb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “State” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817eec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817eed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817eee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State seeks reimbursement for amounts expended for resources and services provided to another State for the management and suppression of a wildfire, the Secretary, subject to subsections (c) and (d)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817eef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept the reimbursement amounts from the other State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817ef0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall pay those amounts to the State seeking reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817ef1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mutual assistance agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of seeking and providing reimbursement under subsection (b), the State seeking reimbursement and the State providing reimbursement must each have a mutual assistance agreement with the Forest Service or another Federal agency for providing and receiving wildfire management and suppression resources and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817ef2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe the terms and conditions determined to be necessary to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb817ef3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on prior reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any acceptance of funds or reimbursements made by the Secretary before ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", that otherwise would have been authorized under this section shall be considered to have been made in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb817ef4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVIII/s8304"},"text":"Pub. L. 113–79, title VIII, § 8304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/924"},"text":"128 Stat. 924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb817ef5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb817ef6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb817ef7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agricultural Act of 2014, and not as part of act ","children":[{"tag":"date","attrib":{"date":"1955-05-27"},"text":"May 27, 1955","children":[],"tail":", which comprises this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s8304"},"text":"section 8304 of Pub. L. 113–79","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/s8304"},"text":"section 8304 of Pub. L. 113–79","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856d"},"text":"section 1856d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb817ef8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb817ef9-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
