{"tag":"section","attrib":{"id":"idbf6aef3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375"},"text":null,"children":[{"tag":"num","attrib":{"value":"12375"},"text":"§ 12375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of Conference","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aef40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proposed report of the Conference which shall include a statement of comprehensive coherent national policy on children, youth, and families together with recommendations for the implementation of such policy, shall be published and submitted to the chief executive officers of the States not later than 180 days following the date on which the Conference is adjourned. The findings and recommendations included in the published proposed report shall be available immediately to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aef41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response to proposed report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief executive officers of the States, after reviewing and soliciting recommendations and comments on the proposed report of the Conference, shall submit to the Secretary, not later than 180 days after receiving such report, their views and findings on the recommendations of the Conference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aef42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after submission of the views and comments of the chief executive officers of the States, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aef43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare a final report on the conference, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aef44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the policy and recommendations of the Conference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views and comments of the chief executive officers of the States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aef46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Secretary, after taking into consideration the views and comments of such officers, for administrative and legislative action necessary to implement the recommendations of the Conference; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aef47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12375/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and transmit such report to the President and the chairman of the Committee on Education and Labor of the House of Representatives and chairman of the Committee on Labor and Human Resources of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6d5e48-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s986"},"text":"Pub. L. 101–501, title IX, § 986","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1282"},"text":"104 Stat. 1282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6d5e49-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6d5e4a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbf6d5e4b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Labor and Human Resources of Senate changed to Committee on Health, Education, Labor, and Pensions of Senate by Senate Resolution No. 20, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-19"},"text":"Jan. 19, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6d5e4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
