{"tag":"section","attrib":{"id":"idbc094bea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2210c"},"text":"§ 2210c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of pension offset for certain rehired Federal retirees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc094beb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may waive the application of section 8344 or 8468 of title 5 on a case-by-case basis for employment of an annuitant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc094bec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a position of the Commission for which there is exceptional difficulty in recruiting or retaining a qualified employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094bed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a temporary emergency hiring need exists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc094bee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall prescribe procedures for the exercise of authority under this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc094bef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for any exercise of authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc094bf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for a delegation of authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc094bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee as to whom a waiver under this section is in effect shall not be considered an employee for purposes of subchapter II of chapter 83, or chapter 84, of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc094bf2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 170C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s624/a"},"text":"Pub. L. 109–58, title VI, § 624(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/783"},"text":"119 Stat. 783","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
