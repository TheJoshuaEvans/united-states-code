{"tag":"section","attrib":{"id":"idbb994ce8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1869c"},"text":"§ 1869c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income scholarship program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb994ce9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Science Foundation (referred to in this section as the “Director”) shall award scholarships to low-income individuals to enable such individuals to pursue associate, undergraduate, or graduate level degrees in mathematics, engineering, computer science, or cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb994cea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb994ceb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a scholarship under this section, an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb994cec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be a citizen of the United States, a national of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a"},"text":"section 1101(a) of title 8","children":[],"tail":"), an alien admitted as a refugee under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"section 1157 of title 8","children":[],"tail":", or an alien lawfully admitted to the United States for permanent residence;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb994ced-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prepare and submit to the Director an application at such time, in such manner, and containing such information as the Director may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb994cee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall certify to the Director that the individual intends to use amounts received under the scholarship to enroll or continue enrollment at an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":") in order to pursue an associate, undergraduate, or graduate level degree in mathematics, engineering, computer science, cybersecurity, or other technology and science programs designated by the Director."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb994cef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Awards of scholarships under this section shall be made by the Director solely on the basis of the ability of the applicant, except that in any case in which 2 or more applicants for scholarships are deemed by the Director to be possessed of substantially equal ability, and there are not sufficient scholarships available to grant one to each of such applicants, the available scholarship or scholarships shall be awarded to the applicants in a manner that will tend to result in a geographically wide distribution throughout the United States of recipients’ places of permanent residence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb994cf0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a scholarship awarded under this section shall be determined by the Director. The Director may renew scholarships for up to 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb994cf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out this section only with funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1356/s/3"},"text":"section 1356(s)(3) of title 8","children":[],"tail":". The Director may use no more than 50 percent of such funds for undergraduate programs for curriculum development, professional and workforce development, and to advance technological education. Funds for these other programs may be used for purposes other than scholarships."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb994cf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1869c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2004-12-08"},"text":"December 8, 2004","children":[],"tail":", the Director shall publish in the Federal Register a list of eligible programs of study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb994cf3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tIV/s414/d"},"text":"Pub. L. 105–277, div. C, title IV, § 414(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-653"},"text":"112 Stat. 2681–653","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/313/tI/s110/b"},"text":"Pub. L. 106–313, title I, § 110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1256"},"text":"114 Stat. 1256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tIV/s429"},"text":"Pub. L. 108–447, div. J, title IV, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3360"},"text":"118 Stat. 3360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCIV/s9405/c"},"text":"Pub. L. 116–283, div. H, title XCIV, § 9405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4812"},"text":"134 Stat. 4812","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10393/f/3"},"text":"Pub. L. 117–167, div. B, title III, § 10393(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1590"},"text":"136 Stat. 1590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb994cf4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb994cf5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb994cf6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"Section 1157 of title 8","children":[],"tail":", referred to in par. (2)(A)(i), was in the original “section 207 of the Immigration and Nationality”, and was translated as reading section 207 of the Immigration and Nationality Act to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb994cf7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Competitiveness and Workforce Improvement Act of 1998, and also as part of the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb994cf8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167"},"text":"Pub. L. 117–167","children":[],"tail":" struck out “, except that the Director shall not award a scholarship in an amount exceeding $10,000 per year” after “by the Director” and substituted “5 years” for “4 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9405/c/1"},"text":"Pub. L. 116–283, § 9405(c)(1)","children":[],"tail":", substituted “computer science, or cybersecurity” for “or computer science”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9405/c/2"},"text":"Pub. L. 116–283, § 9405(c)(2)","children":[],"tail":", inserted “cybersecurity,” after “computer science,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s429/a"},"text":"Pub. L. 108–447, § 429(a)","children":[],"tail":", substituted “computer science, or other technology and science programs designated by the Director” for “or computer science”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s429/b"},"text":"Pub. L. 108–447, § 429(b)","children":[],"tail":", substituted “$10,000 per year” for “$3,125 per year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s429/c"},"text":"Pub. L. 108–447, § 429(c)","children":[],"tail":", inserted at end “The Director may use no more than 50 percent of such funds for undergraduate programs for curriculum development, professional and workforce development, and to advance technological education. Funds for these other programs may be used for purposes other than scholarships.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s429/d"},"text":"Pub. L. 108–447, § 429(d)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/313"},"text":"Pub. L. 106–313","children":[],"tail":" substituted “$3,125 per year. The Director may renew scholarships for up to 4 years” for “$2,500 per year.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb994cf9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb994cfa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s430/a"},"text":"section 430(a) of Pub. L. 108–447","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
