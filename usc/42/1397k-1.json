{"tag":"section","attrib":{"id":"idbaad3eaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397k–1"},"text":"§ 1397k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board on Elder Abuse, Neglect, and Exploitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbaad3eb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a board to be known as the “Advisory Board on Elder Abuse, Neglect, and Exploitation” (in this section referred to as the “Advisory Board”) to create short- and long-term multidisciplinary strategic plans for the development of the field of elder justice and to make recommendations to the Elder Justice Coordinating Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397k"},"text":"section 1397k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall be composed of 27 members appointed by the Secretary from among members of the general public who are individuals with experience and expertise in elder abuse, neglect, and exploitation prevention, detection, treatment, intervention, or prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of nominations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish a notice in the Federal Register soliciting nominations for the appointment of members of the Advisory Board under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3eb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3eb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Advisory Board shall be appointed for a term of 3 years, except that, of the members first appointed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3eb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9 shall be appointed for a term of 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3eb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9 shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3eb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9 shall be appointed for a term of 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3eb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3eb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy on the Advisory Board shall not affect its powers, but shall be filled in the same manner as the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3eba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filling unexpired term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual chosen to fill a vacancy shall be appointed for the unexpired term of the member replaced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ebb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of any member shall not expire before the date on which the member’s successor takes office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ebc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall elect a Chair and Vice Chair from among its members. The Advisory Board shall elect its initial Chair and Vice Chair at its initial meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ebd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3ebe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhance communication on promoting quality of, and preventing abuse, neglect, and exploitation in, long-term care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall develop collaborative and innovative approaches to improve the quality of, including preventing abuse, neglect, and exploitation in, long-term care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ebf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaborative efforts to develop consensus around the management of certain quality-related factors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3ec0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall establish multidisciplinary panels to address, and develop consensus on, subjects relating to improving the quality of long-term care. At least 1 such panel shall address, and develop consensus on, methods for managing resident-to-resident abuse in long-term care.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ec1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities conducted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The multidisciplinary panels established under subparagraph (A) shall examine relevant research and data, identify best practices with respect to the subject of the panel, determine the best way to carry out those best practices in a practical and feasible manner, and determine an effective manner of distributing information on such subject.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ec2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 18 months after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", and annually thereafter, the Advisory Board shall prepare and submit to the Elder Justice Coordinating Council, the Committee on Finance of the Senate, and the Committee on Ways and Means and the Committee on Energy and Commerce of the House of Representatives a report containing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaad3ec3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the status of Federal, State, and local public and private elder justice activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ec4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations (including recommended priorities) regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbaad3ec5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elder justice programs, research, training, services, practice, enforcement, and coordination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3ec6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination between entities pursuing elder justice efforts and those involved in related areas that may inform or overlap with elder justice efforts, such as activities to combat violence against women and child abuse and neglect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbaad3ec7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities relating to adult fiduciary systems, including guardianship and other fiduciary arrangements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ec8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for specific modifications needed in Federal and State laws (including regulations) or for programs, research, and training to enhance prevention, detection, and treatment (including diagnosis) of, intervention in (including investigation of), and prosecution of elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3ec9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on methods for the most effective coordinated national data collection with respect to elder justice, and elder abuse, neglect, and exploitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaad3eca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for a multidisciplinary strategic plan to guide the effective and efficient development of the field of elder justice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ecb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Advisory Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaad3ecc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397j–1/a"},"text":"section 1397j–1(a) of this title","children":[],"tail":", the Advisory Board may secure directly from any Federal department or agency such information as the Advisory Board considers necessary to carry out this section. Upon request of the Chair of the Advisory Board, the head of such department or agency shall furnish such information to the Advisory Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ecd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of data and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board may request from any entity pursuing elder justice activities under the Elder Justice Act of 2009 or an amendment made by that Act, any data, reports, or recommendations generated in connection with such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaad3ece-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Postal services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board may use the United States mails in the same manner and under the same conditions as other departments and agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ecf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Board shall not receive compensation for the performance of services for the Advisory Board. The members shall be allowed travel expenses for up to 4 meetings per year, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5, while away from their homes or regular places of business in the performance of services for the Advisory Board. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Secretary may accept the voluntary and uncompensated services of the members of the Advisory Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ed0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of Government employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Federal Government employee may be detailed to the Advisory Board without reimbursement, and such detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ed1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as permanent advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" shall not apply to the advisory board."},{"tag":"ref","attrib":{"idref":"fn003082"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003082"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Advisory Board”."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbaad3ed2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397k–1/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaad3ed3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2022, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6703/a/1/C"},"text":"Pub. L. 111–148, title VI, § 6703(a)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/787"},"text":"124 Stat. 787","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/257"},"text":"Pub. L. 117–286, § 4(a)(257)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4334"},"text":"136 Stat. 4334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbaad3ed4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbaad3ed5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbaad3ed6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elder Justice Act of 2009, referred to in subsec. (g)(2), is subtitle H (§§ 6701–6703) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/782"},"text":"124 Stat. 782","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2010 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbaad3ed7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":"” for “Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
