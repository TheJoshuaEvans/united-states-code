{"tag":"section","attrib":{"id":"idbeae7bbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9126"},"text":null,"children":[{"tag":"num","attrib":{"value":"9126"},"text":"§ 9126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbeae7bbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test platforms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall not apply to any test platform which will not operate as an ocean thermal energy conversion facility or plantship after conclusion of the testing period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbeae7bc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial demonstration ocean thermal energy conversion facilities or plantships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter shall not apply to ownership, construction, or operation of any ocean thermal energy conversion facility or plantship which the Secretary of Energy has designated in writing as a demonstration proj­ect for the development of alternative energy sources for the United States which is conducted by, participated in, or approved by the Department of Energy. The Secretary of Energy, after consultation with the Administrator, shall require such demonstration projects to abide by as many of the substantive requirements of this subchapter as he deems to be practicable without damaging the nature of or unduly delaying such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbeae7bc1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/320/tI/s116"},"text":"Pub. L. 96–320, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-08-03"},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/991"},"text":"94 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/623/tVI/s602/e/4"},"text":"Pub. L. 98–623, title VI, § 602(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3412"},"text":"98 Stat. 3412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbeae7bc2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbeae7bc3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbeae7bc4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/623"},"text":"Pub. L. 98–623","children":[],"tail":" substituted “facility or plantship” for “facility or platform”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
