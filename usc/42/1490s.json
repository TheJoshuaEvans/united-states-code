{"tag":"section","attrib":{"id":"idbb2e07ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s"},"text":null,"children":[{"tag":"num","attrib":{"value":"1490s"},"text":"§ 1490s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb2e07ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity skimming","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb2e07ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever, as an owner, agent, employee, or manager, or is otherwise in custody, control, or possession of property that is security for a loan made or guaranteed under this subchapter, willfully uses, or authorizes the use, of any part of the rents, assets, proceeds, income, or other funds derived from such property, for any purpose other than to meet actual, reasonable, and necessary expenses of the property, or for any other purpose not authorized by this subchapter or the regulations adopted pursuant to this subchapter, shall be fined under title 18 or imprisoned not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e07f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity or individual who as an owner, operator, employee, or manager, or who acts as an agent for a property that is security for a loan made or guaranteed under this subchapter where any part of the rents, assets, proceeds, income, or other funds derived from such property are used for any purpose other than to meet actual, reasonable, and necessary expenses of the property, or for any other purpose not authorized by this subchapter or the regulations adopted pursuant to this subchapter, shall be subject to a fine of not more than $25,000 per violation. The sanctions provided in this paragraph may be imposed in addition to any other civil sanctions or civil monetary penalties authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb2e07f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil monetary penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb2e07f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, after notice and opportunity for a hearing, impose a civil monetary penalty in accordance with this subsection against any individual or entity, including its owners, officers, directors, general partners, limited partners, or employees, who knowingly and materially violate, or participate in the violation of, the provisions of this subchapter, the regulations issued by the Secretary pursuant to this subchapter, or agreements made in accordance with this subchapter, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb2e07f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitting information to the Secretary that is false;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e07f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Secretary with false certifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e07f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to submit information requested by the Secretary in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e07f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to maintain the property subject to loans made or guaranteed under this subchapter in good repair and condition, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e07f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to provide management for a project which received a loan made or guaranteed under this subchapter that is acceptable to the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e07f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to comply with the provisions of applicable civil rights statutes and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e07f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions for renewal or extension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require that expiring loan or assistance agreements entered into under this subchapter shall not be renewed or extended unless the owner executes an agreement to comply with additional conditions prescribed by the Secretary, or executes a new loan or assistance agreement in the form prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e07fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb2e07fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a civil monetary penalty imposed under this subsection shall not exceed the greater of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb2e07fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" twice the damages the Department of Agriculture, the guaranteed lender, or the project that is secured for a loan under this section suffered or would have suffered as a result of the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e07fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000 per violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e07fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a civil monetary penalty under this subsection, the Secretary shall take into consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb2e07ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gravity of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any history of prior offenses by the violator (including offenses occurring prior to the enactment of this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the violator to pay the penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any injury to tenants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any injury to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefits received by the violator as a result of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deterrence of future violations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb2e0806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as the Secretary may establish by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e0807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No payment of a penalty assessed under this section may be made from funds provided under this subchapter or from funds of a project which serve as security for a loan made or guaranteed under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb2e0808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for noncompliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb2e0809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial intervention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person or entity fails to comply with a final determination by the Secretary imposing a civil monetary penalty under this subsection, the Secretary may request the Attorney General of the United States to bring an action in an appropriate United States district court to obtain a monetary judgment against such individual or entity and such other relief as may be available. The monetary judgment may, in the court’s discretion, include the attorney’s fees and other expenses incurred by the United States in connection with the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb2e080a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1490s/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewability of determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In an action under this paragraph, the validity and appropriateness of a determination by the Secretary imposing the penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb2e080b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-15/ch338"},"text":"July 15, 1949, ch. 338","children":[],"tail":", title V, § 543, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVII/s708/a"},"text":"Pub. L. 106–569, title VII, § 708(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3016"},"text":"114 Stat. 3016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb2e080c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb2e080d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb2e080e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section, referred to in subsec. (b)(3)(B)(ii), means enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":", which enacted this section and was approved "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
