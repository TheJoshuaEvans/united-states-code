{"tag":"section","attrib":{"id":"idbff071ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062"},"text":null,"children":[{"tag":"num","attrib":{"value":"16062"},"text":"§ 16062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic manufacturing conversion grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbff071ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbff071ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to encourage domestic production and sales of efficient hybrid and advanced diesel vehicles and components of those vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall include grants and loan guarantees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s16513"},"text":"section 16513 of this title","children":[],"tail":" to automobile manufacturers and suppliers and hybrid component manufacturers to encourage domestic production of efficient hybrid, plug-in electric hybrid, plug-in electric drive, and advanced diesel vehicles."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbff071af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Priority shall be given to the refurbishment or retooling of manufacturing facilities that have recently ceased operation or will cease operation in the near future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with State and local programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may coordinate implementation of this section with State and local programs designed to accomplish similar goals, including the retention and retraining of skilled workers from the manufacturing facilities, including by establishing matching grant arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbff071b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16062/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbff071b2-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s712"},"text":"Pub. L. 109–58, title VII, § 712","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/818"},"text":"119 Stat. 818","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI"},"text":"Pub. L. 110–140, title I","children":[],"tail":", §§ 132, 134(a), "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1511"},"text":"121 Stat. 1511","children":[],"tail":", 1513.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbff071b3-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbff071b4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbff071b5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s132"},"text":"Pub. L. 110–140, § 132","children":[],"tail":", amended section generally. Prior to amendment, section related to program to encourage domestic production and sales of efficient hybrid and advanced diesel vehicles and authorization of appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s134/a"},"text":"Pub. L. 110–140, § 134(a)","children":[],"tail":", inserted “and loan guarantees under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s16513"},"text":"section 16513 of this title","children":[],"tail":"” after “grants”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbff071b6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbff071b7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
