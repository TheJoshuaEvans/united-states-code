{"tag":"section","attrib":{"id":"idbd120a89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5165b"},"text":"§ 5165b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120a8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of management cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “management cost” includes any indirect cost, any direct administrative cost, and any other administrative expense associated with a specific project under a major disaster, emergency, or disaster preparedness or mitigation activity or measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of management cost rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law (including any administrative rule or guidance), the President shall by regulation implement management cost rates, for grantees and subgrantees, that shall be used to determine contributions under this chapter for management costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific management costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency shall provide the following percentage rates, in addition to the eligible project costs, to cover direct and indirect costs of administering the following programs:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd120a8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazard mitigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170c"},"text":"section 5170c of this title","children":[],"tail":" may be reimbursed not more than 15 percent of the total amount of the grant award under such section of which not more than 10 percent may be used by the grantee and 5 percent by the subgrantee for such costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120a8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee under sections 5170b, 5172, 5173, and 5192 of this title may be reimbursed not more than 12 percent of the total award amount under such sections, of which not more than 7 percent may be used by the grantee and 5 percent by the subgrantee for such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5165b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall review the management cost rates established under subsection (b) not later than 3 years after the date of establishment of the rates and periodically thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd120a91-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s324"},"text":"Pub. L. 93–288, title III, § 324","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/390/tII/s202/a"},"text":"Pub. L. 106–390, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1560"},"text":"114 Stat. 1560","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1215"},"text":"Pub. L. 115–254, div. D, § 1215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3449"},"text":"132 Stat. 3449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a92-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a93-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd120a94-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd120a95-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1215/1"},"text":"Pub. L. 115–254, § 1215(1)","children":[],"tail":", substituted “any direct administrative cost, and any other administrative expense associated with” for “any administrative expense, and any other expense not directly chargeable to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1215/2"},"text":"Pub. L. 115–254, § 1215(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “implement” for “establish”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd120a96-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd120a97-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2017-08-01"},"text":"Aug. 1, 2017","children":[],"tail":", and authorities provided under div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" applicable to each major disaster and emergency declared by the President on or after "},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"Jan. 1, 2016","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1202"},"text":"section 1202 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd120a98-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/390/tII/s202/b"},"text":"Pub. L. 106–390, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1560"},"text":"114 Stat. 1560","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/390/tII/s202/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), subsections (a) and (b) of section 324 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5165b/a"},"text":"42 U.S.C. 5165b(a)","children":[],"tail":", (b)] (as added by subsection (a)) shall apply to major disasters declared under that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.] on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Until the date on which the President establishes the management cost rates under section 324 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (as added by subsection (a)), section 406(f) of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172/f"},"text":"42 U.S.C. 5172(f)","children":[],"tail":") (as in effect on the day before the date of the enactment of this Act) shall be used to establish management cost rates.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
