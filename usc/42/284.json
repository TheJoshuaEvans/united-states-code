{"tag":"section","attrib":{"id":"idb55e25a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284"},"text":null,"children":[{"tag":"num","attrib":{"value":"284"},"text":"§ 284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directors of national research institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55e25a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e25a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Cancer Institute shall be appointed by the President, and the Directors of the other national research institutes and national centers shall be appointed by the Secretary, acting through the Director of National Institutes of Health. Each Director of a national research institute or national center shall report directly to the Director of National Institutes of Health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e25a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Director of a national research institute or national center who is appointed by the Secretary, acting through the Director of National Institutes of Health, shall be appointed for 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of the term of a Director of a national research institute or national center, the Director may be reappointed in accordance with standards applicable to the relevant appointment mechanism. There shall be no limit on the number of terms that a Director may serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the office of a Director of a national research institute or national center becomes vacant before the end of such Director’s term, the Director appointed to fill the vacancy shall be appointed for a 5-year term starting on the date of such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Director of a national research institute or national center who is serving on ","children":[{"tag":"date","attrib":{"date":"2016-12-13"},"text":"December 13, 2016","children":[],"tail":", shall be deemed to be appointed for a 5-year term under this subsection beginning on such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to limit the authority of the Secretary or the Director of National Institutes of Health to terminate the appointment of a director referred to in subparagraph (A) before the expiration of such director’s 5-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25ad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointments and reappointments under this subsection shall be made on the basis of ability and experience as it relates to the mission of the National Institutes of Health and its components, including compliance with any legal requirement that the Secretary or Director of National Institutes of Health determines relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of certain provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The restrictions contained in section 202 of the Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Act, 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/394"},"text":"Public Law 102–394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238f"},"text":"42 U.S.C. 238f","children":[],"tail":" note) related to consultants and individual scientists appointed for limited periods of time shall not apply to Directors appointed under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55e25af-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and authority; grants, contracts, and cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e25b0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s241"},"text":"section 241 of this title","children":[],"tail":" with respect to human diseases or disorders or other aspects of human health for which the national research institutes were established, the Secretary, acting through the Director of each national research institute—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e25b1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall encourage and support research, investigations, experiments, demonstrations, and studies in the health sciences related to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55e25b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of health,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e25b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detection, diagnosis, treatment, and prevention of human diseases and disorders,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e25b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation of individuals with human diseases, disorders, and disabilities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e25b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expansion of knowledge of the processes underlying human diseases, disorders, and disabilities, the processes underlying the normal and pathological functioning of the body and its organ systems, and the processes underlying the interactions between the human organism and the environment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, subject to the peer review prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a/b"},"text":"section 289a(b) of this title","children":[],"tail":" and any advisory council review under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s284a/a/3/A/i"},"text":"section 284a(a)(3)(A)(i) of this title","children":[],"tail":", conduct the research, investigations, experiments, demonstrations, and studies referred to in subparagraph (A);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, as appropriate, conduct and support research that has the potential to transform the scientific field, has inherently higher risk, and that seeks to address major current challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct and support research training (i) for which fellowship support is not provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s288"},"text":"section 288 of this title","children":[],"tail":", and (ii) which is not residency training of physicians or other health professionals;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may develop, implement, and support demonstrations and programs for the application of the results of the activities of the institute to clinical practice and disease prevention activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25ba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may develop, conduct, and support public and professional education and information programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25bb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may secure, develop and maintain, distribute, and support the development and maintenance of resources needed for research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25bc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make available the facilities of the institute to appropriate entities and individuals engaged in research activities and cooperate with and assist Federal and State agencies charged with protecting the public health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25bd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept unconditional gifts made to the institute for its activities, and, in the case of gifts of a value in excess of $50,000, establish suitable memorials to the donor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25be-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may secure for the institute consultation services and advice of persons from the United States or abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25bf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use, with their consent, the services, equipment, personnel, information, and facilities of other Federal, State, or local public agencies, with or without reimbursement therefor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept voluntary and uncompensated services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may perform such other functions as the Secretary determines are needed to carry out effectively the purposes of the institute.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The indemnification provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3861"},"text":"section 3861 of title 10","children":[],"tail":" shall apply with respect to contracts entered into under this subsection and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b"},"text":"section 282(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Support for an activity or program under this subsection may be provided through grants, contracts, and cooperative agreements. The Secretary, acting through the Director of each national research institute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e25c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into a contract for research, training, or demonstrations only if the contract has been recommended after technical and scientific peer review required by regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a"},"text":"section 289a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may make grants and cooperative agreements under paragraph (1) for research, training, or demonstrations, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55e25c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the direct cost of the grant or cooperative agreement to be made does not exceed $50,000, such grant or cooperative agreement may be made only if such grant or cooperative agreement has been recommended after technical and scientific peer review required by regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a"},"text":"section 289a of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e25c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the direct cost of the grant or cooperative agreement to be made exceeds $50,000, such grant or cooperative agreement may be made only if such grant or cooperative agreement has been recommended after technical and scientific peer review required by regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a"},"text":"section 289a of this title","children":[],"tail":" and is recommended under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s284a/a/3/A/ii"},"text":"section 284a(a)(3)(A)(ii) of this title","children":[],"tail":" by the advisory council for the national research institute involved; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300cc–40c/d/2"},"text":"section 300cc–40c(d)(2) of this title","children":[],"tail":", receive from the President and the Office of Management and Budget directly all funds appropriated by the Congress for obligation and expenditure by the Institute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before an award is made by a national research institute or by a national center for a grant for a research program or project (commonly referred to as an “R-series grant”), other than an award constituting a noncompetitive renewal of such a grant, or a noncompetitive administrative supplement to such a grant, the Director of such national research institute or national center shall, consistent with the peer review process—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e25c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and make the final decision with respect to making the award; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into consideration, as appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55e25cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mission of the national research institute or national center and the scientific priorities identified in the strategic plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/m"},"text":"section 282(m) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e25cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs or projects funded by other agencies on similar research topics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55e25cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advice by staff and the advisory council or board of such national research institute or national center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55e25ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other public and private entities; cooperation with other national research institutes; appointment of additional peer review groups","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b), each Director of a national research institute—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55e25cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall coordinate, as appropriate, the activities of the institute with similar programs of other public and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall cooperate with the Directors of the other national research institutes in the development and support of multidisciplinary research and research that involves more than one institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may, in consultation with the advisory council for the Institute and with the approval of the Director of NIH—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55e25d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish technical and scientific peer review groups in addition to those appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/16"},"text":"section 282(b)(16) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55e25d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint the members of peer review groups established under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55e25d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s284/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may publish, or arrange for the publication of, information with respect to the purpose of the Institute without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the duration of a peer review group appointed under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55e25d5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 405, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/826"},"text":"99 Stat. 826","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s116"},"text":"Pub. L. 100–607, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3053"},"text":"102 Stat. 3053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tII/s2613/c"},"text":"Pub. L. 100–690, title II, § 2613(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4239"},"text":"102 Stat. 4239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tIII/s301/a/1"},"text":"Pub. L. 103–43, title III, § 301(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/150"},"text":"107 Stat. 150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s102/f/1/B"},"text":"Pub. L. 109–482, title I, § 102(f)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3685"},"text":"120 Stat. 3685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tII"},"text":"Pub. L. 114–255, div. A, title II","children":[],"tail":", §§ 2033(a), (b), 2036(c), "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1057"},"text":"130 Stat. 1057","children":[],"tail":", 1058, 1063; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/j/1/B"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(j)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2159"},"text":"135 Stat. 2159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/232"},"text":"Pub. L. 117–286, § 4(a)(232)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4331"},"text":"136 Stat. 4331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55e25d6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55e25d7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb55e25d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “section 3861” for “section 2354” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2033/a"},"text":"Pub. L. 114–255, § 2033(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “The Director of the National Cancer Institute shall be appointed by the President and the Directors of the other national research institutes shall be appointed by the Secretary. Each Director of a national research institute shall report directly to the Director of NIH.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C) to (M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2036/c"},"text":"Pub. L. 114–255, § 2036(c)","children":[],"tail":", added par. (C) and redesignated former pars. (C) to (L) as (D) to (M), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s2033/b"},"text":"Pub. L. 114–255, § 2033(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" substituted “section 282(b)(16)” for “section 282(b)(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s301/a/1"},"text":"Pub. L. 103–43, § 301(a)(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s301/b/2"},"text":"Pub. L. 103–43, § 301(b)(2)","children":[],"tail":", inserted concluding provisions relating to Federal Advisory Committee Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s301/b/1"},"text":"Pub. L. 103–43, § 301(b)(1)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “may, in consultation with the advisory council for the Institute and the approval of the Director of NIH, establish and appoint technical and scientific peer review groups in addition to those established and appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/6"},"text":"section 282(b)(6) of this title","children":[],"tail":"; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s116/1"},"text":"Pub. L. 100–607, § 116(1)","children":[],"tail":", struck out “the” after “with respect to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" substituted “establish and appoint” and “established and appointed” for “establish” and “established”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s116/2/A"},"text":"Pub. L. 100–607, § 116(2)(A)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “may, with the approval of the advisory council for the institute and the Director of NIH, appoint technical and scientific peer review groups in addition to those appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s282/b/6"},"text":"section 282(b)(6) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s116/2/C"},"text":"Pub. L. 100–607, § 116(2)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb55e25d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb55e25da-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb55e25db-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" effective immediately after enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s2600"},"text":"section 2600 of Pub. L. 100–690","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242m"},"text":"section 242m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55e25dc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Research","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/215/tIV/s401"},"text":"Pub. L. 117–215, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-02"},"text":"Dec. 2, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2265"},"text":"136 Stat. 2265","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/215/tIV/s401"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-02"},"text":"Dec. 2, 2022","children":[],"tail":"], the Secretary of Health and Human Services, in coordination with the Director of the National Institutes of Health and the heads of other relevant Federal agencies, shall submit to the Caucus on International Narcotics Control, the Committee on the Judiciary, and the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce and the Committee on the Judiciary of the House of Representatives a report on—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential therapeutic effects of cannabidiol or marijuana on serious medical conditions, including intractable epilepsy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the potential effects of marijuana, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of increasing delta-9-tetrahydrocannabinol levels on the human body and developing adolescent brains; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of various delta-9-tetrahydrocannabinol levels on cognitive abilities, such as those that are required to operate motor vehicles or other heavy equipment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the barriers associated with researching marijuana or cannabidiol in States that have legalized the use of such substances, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations as to how such barriers might be overcome, including whether public-private partnerships or Federal-State research partnerships may or should be implemented to provide researchers with access to additional strains of marijuana and cannabidiol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations as to what safeguards must be in place to verify—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the levels of tetrahydrocannabinol, cannabidiol, or other cannabinoids contained in products obtained from such States is accurate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such products do not contain harmful or toxic components.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the Secretary of Health and Human Services, either directly or through awarding grants, contacts, or cooperative agreements, shall expand and coordinate the activities of the National Institutes of Health and other relevant Federal agencies to better determine the effects of cannabidiol and marijuana, as outlined in the report submitted under paragraphs (1) and (2) of subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/215/s401"},"text":"section 401 of Pub. L. 117–215","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/215/s2/a"},"text":"section 2(a) of Pub. L. 117–215","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":", Food and Drugs.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55e25dd-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enhancing the Clinical and Translational Science Award","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s106"},"text":"Pub. L. 109–482, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3696"},"text":"120 Stat. 3696","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/482/tI/s106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the Clinical and Translational Science Award, the Director of NIH shall establish a mechanism to preserve independent funding and infrastructure for pediatric clinical research centers by—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing the appointment of a secondary principal investigator under a single Clinical and Translational Science Award, such that a pediatric principal investigator may be appointed with direct authority over a separate budget and infrastructure for pediatric clinical research; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise securing institutional independence of pediatric clinical research centers with respect to finances, infrastructure, resources, and research agenda.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the biennial report under section 403 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s283"},"text":"42 U.S.C. 283","children":[],"tail":"], the Director of NIH shall provide an evaluation and comparison of outcomes and effectiveness of training programs under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘Director of NIH’ has the meaning given such term in section 401 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"42 U.S.C. 281","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
