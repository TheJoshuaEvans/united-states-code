{"tag":"section","attrib":{"id":"idb7e6a492-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a"},"text":null,"children":[{"tag":"num","attrib":{"value":"679a"},"text":"§ 679a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Adoption Information Clearinghouse","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall establish, either directly or by grant or contract, a National Adoption Information Clearinghouse. The Clearinghouse shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e6a493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, compile, and maintain information obtained from available research, studies, and reports by public and private agencies, institutions, or individuals concerning all aspects of infant adoption and adoption of children with special needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" compile, maintain, and periodically revise directories of information concerning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e6a495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crisis pregnancy centers,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shelters and residences for pregnant women,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs on adoption,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational programs on adoption,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensed adoption agencies,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a49a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State laws relating to adoption,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a49b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intercountry adoption, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e6a49c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information relating to adoption for pregnant women, infertile couples, adoptive parents, unmarried individuals who want to adopt children, individuals who have been adopted, birth parents who have placed a child for adoption, adoption agencies, social workers, counselors, or other individuals who work in the adoption field;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a49d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate the information compiled and maintained pursuant to paragraph (1) and the directories compiled and maintained pursuant to paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e6a49e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s679a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the establishment of an adoption and foster care data collection system pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s679"},"text":"section 679 of this title","children":[],"tail":", disseminate the data and information made available through that system."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e6a49f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIX/s9442"},"text":"Pub. L. 99–509, title IX, § 9442","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2073"},"text":"100 Stat. 2073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e6a4a0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e6a4a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7e6a4a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Medicare and Medicaid Budget Reconciliation Amendments of 1985 and also as part of the Omnibus Budget Reconciliation Act of 1986, and not as part of the Social Security Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
