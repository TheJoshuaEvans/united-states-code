{"tag":"section","attrib":{"id":"idbf82bc25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622"},"text":null,"children":[{"tag":"num","attrib":{"value":"12622"},"text":"§ 12622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf82bc26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liaison office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bc27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the Program, the Secretary of Defense shall establish an office to provide for liaison between the Secretary and the National Civilian Community Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The office shall provide assistance in the coordination of Department of Defense activities with the Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bc29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corps cadre","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf82bc2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of recommended personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the Program, the Secretary of Defense, in consultation with the liaison office established under subsection (a) shall develop a list of individuals from which individuals may be selected for appointment by the Director in the permanent cadre of Corps personnel. Such personnel shall be selected from among members and former members of the Armed Forces referred to in section 12611(3) ","children":[{"tag":"ref","attrib":{"idref":"fn004072"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title who are commissioned officers, noncommissioned officers, former commissioned officers, or former noncommissioned officers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations regarding grade and pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall recommend to the Director an appropriate rate of pay for each person recommended for the cadre pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf82bc2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution for retired member’s pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a listed individual receiving retired or retainer pay is appointed to a position in the cadre and the rate of pay for that individual is established at the amount equal to the difference between the active duty pay and allowances which that individual would receive if ordered to active duty and the amount of the individual’s retired or retainer pay, the Secretary of Defense shall pay, by transfer to the Corporation from amounts available for pay of active duty members of the Armed Forces, the amount equal to 50 percent of that individual’s rate of pay for service in the cadre.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bc2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the Program, the Secretary of Defense shall identify military installations and other facilities of the Department of Defense and, in consultation with the adjutant generals of the State National Guards, National Guard facilities that may be used, in whole or in part, by the National Civilian Community Corps for training or housing Corps members. The Secretary of Defense shall carry out this subsection in consultation with the liaison office established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf82bc2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12622/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information regarding Corps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense may permit Armed Forces recruiters to inform potential applicants for the Corps regarding service in the Corps as an alternative to service in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf82bc2f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s162"},"text":"Pub. L. 101–610, title I, § 162","children":[],"tail":", formerly § 195K, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2531"},"text":"106 Stat. 2531","children":[],"tail":"; renumbered § 162 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", (e)(2)(G), title IV, § 402(b)(2), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 847, 919; "},{"tag":"ref","attrib":{"href":"/us/pl/103/304/s3/b/5/C"},"text":"Pub. L. 103–304, § 3(b)(5)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1567"},"text":"108 Stat. 1567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1512"},"text":"Pub. L. 111–13, title I, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1526"},"text":"123 Stat. 1526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tV/s553/b/4"},"text":"Pub. L. 115–232, div. A, title V, § 553(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1772"},"text":"132 Stat. 1772","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf82bc30-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf82bc31-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf82bc32-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12611"},"text":"Section 12611 of this title","children":[],"tail":", referred to in subsec. (b)(1), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1501"},"text":"Pub. L. 111–13, title I, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1521"},"text":"123 Stat. 1521","children":[],"tail":", and section 12611(3) no longer relates to members and former members of the Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf82bc33-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653k"},"text":"section 12653k of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"Pub. L. 103–82, § 104(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf82bc34-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12622, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s166"},"text":"Pub. L. 101–610, title I, § 166","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3159"},"text":"104 Stat. 3159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/384/s8"},"text":"Pub. L. 102–384, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1456"},"text":"106 Stat. 1456","children":[],"tail":", related to assistance for Head Start programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/a"},"text":"Pub. L. 103–82, § 104(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s162"},"text":"section 162 of Pub. L. 101–610","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12613"},"text":"section 12613 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf82bc35-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “shall provide” for “shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in order to assist in the recruitment of personnel for appointment in the permanent cadre, make available to the Director information in the registry established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143a"},"text":"section 1143a of title 10","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) provide other”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/b/2"},"text":"Pub. L. 111–13, § 1512(b)(2)","children":[],"tail":"–(5)(A), substituted “Liaison office” for “Secretary of Defense” as subsec. (a) heading, struck out par. (1) heading “Liaison office” after subsec. (a) heading, redesignated subpars. (A) and (B) of former subsec. (a)(1) as pars. (1) and (2), respectively, of subsec. (a), redesignated cls. (i) and (ii) of former subsec. (a)(1)(B) as subpars. (A) and (B), respectively, of subsec. (a)(2), redesignated former pars. (2) to (4) of subsec. (a) as subsecs. (b) to (d), respectively, redesignated former subpars. (A) to (C) of former subsec. (a)(2) as pars. (1) to (3), respectively, of subsec. (b), and realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/b/1"},"text":"Pub. L. 111–13, § 1512(b)(1)","children":[],"tail":", substituted “Department of Defense” for “other departments” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/a/1/A"},"text":"Pub. L. 111–13, § 1512(a)(1)(A)","children":[],"tail":", inserted “National” before “Civilian Community Corps” in subpar. (A) and substituted “the registry established by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143a"},"text":"section 1143a of title 10","children":[],"tail":";” for “the registry established by section 4462 of the National Defense Authorization Act for Fiscal Year 1993;” in subpar. (B)(i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/a/1/B"},"text":"Pub. L. 111–13, § 1512(a)(1)(B)","children":[],"tail":", substituted “from which individuals may be selected for appointment by the Director” for “to be recommended for appointment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/a/1/C"},"text":"Pub. L. 111–13, § 1512(a)(1)(C)","children":[],"tail":", inserted “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/a/2"},"text":"Pub. L. 111–13, § 1512(a)(2)","children":[],"tail":", struck out subsec. (b). Text read as follows: “Upon the establishment of the Program, the Secretary of Labor shall identify and assist in establishing a system for the recruitment of persons to serve as members of the Civilian Community Corps. In carrying out this subsection, the Secretary of Labor may utilize the Employment Service Agency or the Office of Job Training.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/b/5/B"},"text":"Pub. L. 111–13, § 1512(b)(5)(B)","children":[],"tail":", substituted “subsection (a)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/b/5/C"},"text":"Pub. L. 111–13, § 1512(b)(5)(C)","children":[],"tail":", substituted “subsection” for “paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1512/b/6"},"text":"Pub. L. 111–13, § 1512(b)(6)","children":[],"tail":", substituted “this subsection” for “this paragraph” and “subsection (a)” for “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/304"},"text":"Pub. L. 103–304","children":[],"tail":", which directed the substitution of “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1143a"},"text":"section 1143a of title 10","children":[],"tail":"” for “section 4462 of the National Defense Authorization Act for Fiscal Year 1993”, could not be executed because “section 4462 of the National Defense Authorization Act for Fiscal Year 1993” did not appear in cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/e/2/G"},"text":"Pub. L. 103–82, § 104(e)(2)(G)","children":[],"tail":", substituted “section 12611(3)” for “section 12653(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/2"},"text":"Pub. L. 103–82, § 402(b)(2)","children":[],"tail":", substituted “Corporation” for “Commission on National and Community Service”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf82bc36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf82bc37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/s6101/a"},"text":"section 6101(a) of Pub. L. 111–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4950"},"text":"section 4950 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf82bc38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 104(b), (e)(2)(G) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s123"},"text":"section 123 of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1701"},"text":"section 1701 of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s402/b/2"},"text":"section 402(b)(2) of Pub. L. 103–82","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"Oct. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s406/a"},"text":"section 406(a) of Pub. L. 103–82","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5061"},"text":"section 5061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
