{"tag":"section","attrib":{"id":"idb49aadc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c"},"text":null,"children":[{"tag":"num","attrib":{"value":"244c"},"text":"§ 244c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cardiomyopathy research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49aadc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Director of the National Institutes of Health, may expand and coordinate research and related activities of the National Institutes of Health with respect to cardiomyopathy, which may include research with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causation of cardiomyopathy, including genetic causes and molecular biomarkers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-term health outcomes in individuals with cardiomyopathy, including infants, children, teenagers, adults, and elderly individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" studies using longitudinal data and retrospective analysis to identify effective treatments and outcomes for individuals with cardiomyopathy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that any research and activities related to cardiomyopathy under this section do not unnecessarily duplicate activities, programs, or efforts of other agencies and offices within the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NIH report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary, in consultation with the Director of the National Institutes of Health, shall submit to Congress a report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aadc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlining the ongoing research efforts of the National Institutes of Health regarding cardiomyopathy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aadc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aadc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a research agenda regarding adult forms of cardiomyopathy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for researching cardiomyopathy affecting the pediatric population; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aadcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas of greatest need for such research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aadcc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cardiomyopathy defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “cardiomyopathy” has the meaning given to such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s244a"},"text":"section 244a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49aadcd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 312C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/176/s2/a"},"text":"Pub. L. 118–176, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2608"},"text":"138 Stat. 2608","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
