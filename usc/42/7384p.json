{"tag":"section","attrib":{"id":"idbe0c6f6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7384p"},"text":null,"children":[{"tag":"num","attrib":{"value":"7384p"},"text":"§ 7384p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary of Health and Human Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall carry out that Secretary’s responsibilities with respect to the compensation program with the assistance of the Director of the National Institute for Occupational Safety and Health.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbe0c6f6e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3625"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3625]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–504.)"}],"tail":"\n"}],"tail":null}
