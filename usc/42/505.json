{"tag":"section","attrib":{"id":"idb77b870d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb77b870e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State demonstration projects authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor may enter into agreements, with up to 10 States that submit an application described in subsection (b), for the purpose of allowing such States to conduct demonstration projects to test and evaluate measures designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b870f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expedite the reemployment of individuals who have established a benefit year and are otherwise eligible to claim unemployment compensation under the State law of such State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the effectiveness of a State in carrying out its State law with respect to reemployment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for demonstration project; required content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Governor of any State desiring to conduct a demonstration project under this section shall submit an application to the Secretary of Labor. Any such application shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b8712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general description of the proposed demonstration project, including the authority (under the laws of the State) for the measures to be tested, as well as the period of time during which such demonstration project would be conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a waiver under subsection (c) is requested, a statement describing the specific aspects of the project to which the waiver would apply and the reasons why such waiver is needed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the goals and the expected programmatic outcomes of the demonstration project, including how the project would contribute to the objective described in subsection (a)(1), subsection (a)(2), or both;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances (accompanied by supporting analysis) that the demonstration project would operate for a period of at least 1 calendar year and not result in any increased net costs to the State’s account in the Unemployment Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the manner in which the State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb77b8717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will conduct an impact evaluation, using a methodology appropriate to determine the effects of the demonstration project, including on individual skill levels, earnings, and employment retention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb77b8718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will determine the extent to which the goals and outcomes described in paragraph (3) were achieved;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the State will provide any reports relating to the demonstration project, after its approval, as the Secretary of Labor may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b871a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that employment meets the State’s suitable work requirement and the requirements of section 3304(a)(5) of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b871b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of certain requirements allowed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may waive any of the requirements of section 3304(a)(4) of the Internal Revenue Code of 1986 or of paragraph (1) or (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s503/a"},"text":"section 503(a) of this title","children":[],"tail":", to the extent and for the period the Secretary of Labor considers necessary to enable the State to carry out a demonstration project under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b871c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for demonstration project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A demonstration project under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b871d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be commenced any time after ","children":[{"tag":"date","attrib":{"date":"2012-02-22"},"text":"February 22, 2012","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b871e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be approved for a period of time greater than 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b871f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be completed by not later than ","children":[{"tag":"date","attrib":{"date":"2015-12-31"},"text":"December 31, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8720-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities that may be pursued under a demonstration project under this section are limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b8721-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsidies for employer-provided training, such as wage subsidies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8722-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct disbursements to employers who hire individuals receiving unemployment compensation, not to exceed the weekly benefit amount for each such individual, to pay part of the cost of wages that exceed the unemployed individual’s prior benefit level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8723-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of approval or denial of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor shall, in the case of any State for which an application is submitted under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb77b8724-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the State as to whether such application has been approved or denied within 30 days after receipt of a complete application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb77b8725-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide public notice of the decision within 10 days after providing notification to the State in accordance with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Public notice under paragraph (2) may be provided through the Internet or other appropriate means. Any application under this section that has not been denied within the 30-day period described in paragraph (1) shall be deemed approved, and public notice of any approval under this sentence shall be provided within 10 days thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8726-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of demonstration project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Labor may terminate a demonstration project under this section if the Secretary determines that the State has violated the substantive terms or conditions of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb77b8727-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s505/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s502/a"},"text":"section 502(a) of this title","children":[],"tail":" may be used for an approved demonstration project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb77b8728-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title III, § 305, as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/tII/s2102"},"text":"Pub. L. 112–96, title II, § 2102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/159"},"text":"126 Stat. 159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb77b8729-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb77b872a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb77b872b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsecs. (b)(7) and (c), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
