{"tag":"section","attrib":{"id":"idbef87d02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9852"},"text":null,"children":[{"tag":"num","attrib":{"value":"9852"},"text":"§ 9852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of affording adequate notice of funding available under this subchapter, appropriations for carrying out this subchapter are authorized to be included in an appropriation Act for the fiscal year preceding the fiscal year for which they are available for obligation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbef87d03-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s657"},"text":"Pub. L. 97–35, title VI, § 657","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/508"},"text":"95 Stat. 508","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
