{"tag":"section","attrib":{"id":"idbf281847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371"},"text":null,"children":[{"tag":"num","attrib":{"value":"10371"},"text":"§ 10371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water prediction and forecasting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf281848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Water Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf281849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf28184a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary of Commerce for Oceans and Atmosphere shall establish a center—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf28184b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as the research and operational center of excellence for hydrologic analyses, forecasting, and related decision support services within the National Oceanic and Atmospheric Administration and the National Weather Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf28184c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate collaboration across Federal and State departments and agencies, academia, and the private sector on matters relating to water resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf28184d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The center established under subparagraph (A) shall be known as the “National Water Center”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28184e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the National Water Center shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf28184f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving understanding of water resources, stakeholder needs regarding water resources, and identifying science and services gaps relating to water resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281850-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Developing and implementing advanced water resources modeling capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281851-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitating the transition of hydrologic research into operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281852-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Delivering analyses, forecasts, and inundation information and guidance for all hydrologic events in the United States, including flash flooding, riverine flooding, and water resources outlooks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281853-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In coordination with warning coordination meteorologists, providing decision-support services to inform emergency management and water resources decisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf281854-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National instructions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf281855-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", the Under Secretary, acting through the Director of the National Weather Service, shall make public an operations and services policy directive for the National Water Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281856-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The directive required by paragraph (1) shall include national instructions to perform the functions of the National Water Center, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf281857-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational staff responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281858-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guidelines for content, format, and provision of hydrologic and inundation products developed by the National Water Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf281859-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for cooperation and coordination between the National Water Center, the National Weather Service National Centers for Environmental Prediction, National Weather Service River Forecast Centers, and National Weather Service Weather Forecast Offices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf28185a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total water prediction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary, acting through the Director of the Office of Water Prediction of the National Weather Service, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf28185b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate and lead research and development activities to develop operational water resource prediction and related decision support products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf28185c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collaborate with, and provide decision support regarding total water prediction to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf28185d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant Federal agencies represented on the National Science and Technology Council, Committee on Environment, Natural Resources, and Sustainability and the Subcommittee on Disaster Reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf28185e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State water resource agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf28185f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local emergency management agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281860-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the responsibilities described in paragraphs (1) and (2), collaboratively develop capabilities necessary for total water predictive capacity, including observations, modeling, data management, supercomputing, social science, and communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf281861-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out the activities under this section amounts as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf281862-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $44,500,000 for fiscal year 2021.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281863-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281864-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,500,000 for fiscal year 2023.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf281865-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $46,000,000 for fiscal year 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf281866-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s10371/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Derivation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds to carry out this section shall be derived from amounts authorized to be appropriated to the National Weather Service and the National Ocean Service that are enacted after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf281867-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/271/tIII/s301"},"text":"Pub. L. 116–271, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3347"},"text":"134 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf281868-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf281869-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf28186a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Coordinated Ocean Observations and Research Act of 2020, and not as part of subtitle F of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11"},"text":"Pub. L. 111–11","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
