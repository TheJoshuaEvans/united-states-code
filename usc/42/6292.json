{"tag":"section","attrib":{"id":"idbd7d4f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292"},"text":null,"children":[{"tag":"num","attrib":{"value":"6292"},"text":"§ 6292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7d4f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following consumer products, excluding those consumer products designed solely for use in recreational vehicles and other mobile equipment, are covered products:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d4f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Refrigerators, refrigerator-freezers, and freezers which can be operated by alternating current electricity, excluding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any type designed to be used without doors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any type which does not include a compressor and condenser unit as an integral part of the cabinet assembly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Room air conditioners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Central air conditioners and central air conditioning heat pumps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water heaters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Furnaces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dishwashers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clothes washers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clothes dryers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct heating equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Kitchen ranges and ovens.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pool heaters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Television sets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fluorescent lamp ballasts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General service fluorescent lamps, general service incandescent lamps, and incandescent reflector lamps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Showerheads, except safety shower showerheads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Faucets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water closets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Urinals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Metal halide lamp fixtures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/a/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other type of consumer product which the Secretary classifies as a covered product under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d4f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special classification of consumer product","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d4f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may classify a type of consumer product as a covered product if he determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classifying products of such type as covered products is necessary or appropriate to carry out the purposes of this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average annual per-household energy use by products of such type is likely to exceed 100 kilowatt-hours (or its Btu equivalent) per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4f49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “average annual per-household energy use with respect to a type of product” means the estimated aggregate annual energy use (in kilowatt-hours or the Btu equivalent) of consumer products of such type which are used by households in the United States, divided by the number of such households which use products of such type.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4f4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Btu equivalent of one kilowatt-hour is 3,412 British thermal units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4f4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6292/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “household” shall be defined under rules of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d4f4c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s322"},"text":"Pub. L. 94–163, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/918"},"text":"89 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI/s691/b/2"},"text":"Pub. L. 95–619, title VI, § 691(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3288"},"text":"92 Stat. 3288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/12"},"text":"Pub. L. 100–12","children":[],"tail":", §§ 3, 11(b)(1), "},{"tag":"date","attrib":{"date":"1987-03-17"},"text":"Mar. 17, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/105"},"text":"101 Stat. 105","children":[],"tail":", 125; "},{"tag":"ref","attrib":{"href":"/us/pl/100/357/s2/b"},"text":"Pub. L. 100–357, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-28"},"text":"June 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/672"},"text":"102 Stat. 672","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s123/c"},"text":"Pub. L. 102–486, title I, § 123(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2821"},"text":"106 Stat. 2821","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/388/s5/a/3"},"text":"Pub. L. 105–388, § 5(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3478"},"text":"112 Stat. 3478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIII"},"text":"Pub. L. 110–140, title III","children":[],"tail":", §§ 321(a)(2), 324(b), "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1577"},"text":"121 Stat. 1577","children":[],"tail":", 1593.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d4f4d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7d4f4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd7d4f4f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163"},"text":"Pub. L. 94–163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/871"},"text":"89 Stat. 871","children":[],"tail":", known as the Energy Policy and Conservation Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd7d4f50-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s321/a/2"},"text":"Pub. L. 110–140, § 321(a)(2)","children":[],"tail":", inserted “, general service incandescent lamps,” after “fluorescent lamps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(19), (20). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s324/b"},"text":"Pub. L. 110–140, § 324(b)","children":[],"tail":", added par. (19) and redesignated former par. (19) as (20)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/388"},"text":"Pub. L. 105–388","children":[],"tail":" inserted closing quotation marks after “type of product”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(14) to (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486"},"text":"Pub. L. 102–486","children":[],"tail":" added pars. (14) to (18) and redesignated former par. (14) as (19)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/357"},"text":"Pub. L. 100–357","children":[],"tail":" added par. (13) and redesignated former par. (13) as (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12/s3"},"text":"Pub. L. 100–12, § 3","children":[],"tail":", inserted heading and amended text generally. Prior to amendment, text read as follows: “A consumer product is a covered product if it is one of the following types (or is designed to perform a function which is the principal function of any of the following types):"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Refrigerators and refrigerator-freezers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Freezers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Dishwashers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Clothes dryers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) Water heaters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) Room air conditioners.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) Home heating equipment, not including furnaces.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) Television sets.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(9) Kitchen ranges and ovens.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(10) Clothes washers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(11) Humidifiers and dehumidifiers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(12) Central aid conditioners.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(13) Furnaces.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(14) Any other type of consumer product which the Secretary classifies as a covered product under subsection (b) of this section.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/12/s11/b/1"},"text":"Pub. L. 100–12, § 11(b)(1)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a)(14), (b)(1), (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619"},"text":"Pub. L. 95–619","children":[],"tail":" substituted “Secretary” for “Administrator”, meaning Administrator of the Federal Energy Administration, wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7d4f51-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd7d4f52-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4f53-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Energy Efficiency Labeling for Windows and Window Systems","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s121"},"text":"Pub. L. 102–486, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2805"},"text":"106 Stat. 2805","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tI/s121"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, after consulting with the National Fenestration Rating Council, industry representatives, and other appropriate organizations, provide financial assistance to support a voluntary national window rating program that will develop energy ratings and labels for windows and window systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such rating program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifications for testing procedures and labels that will enable window buyers to make more informed purchasing decisions about the energy efficiency of windows and window systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information (which may be disseminated through catalogs, trade publications, labels, or other mechanisms) that will allow window buyers to assess the energy consumption and potential cost savings of alternative window products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such rating program shall be developed by the National Fenestration Rating Council according to commonly accepted procedures for the development of national testing procedures and labeling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall monitor and evaluate the efforts of the National Fenestration Rating Council and, not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"], make a determination as to whether the program developed by the Council is consistent with the objectives of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative System","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary makes a determination under subsection (b) that a voluntary national window rating program consistent with the objectives of subsection (a) has not been developed, the Secretary shall, after consultation with the National Institute of Standards and Technology, develop, not later than two years after such determination, test procedures under section 323 of the Energy Policy and Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6293"},"text":"42 U.S.C. 6293","children":[],"tail":") for windows and window systems."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the Secretary develops test procedures under paragraph (1), the Federal Trade Commission (hereafter in this section referred to as the ‘Commission’) shall prescribe labeling rules under section 324 of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294"},"text":"42 U.S.C. 6294","children":[],"tail":") for those windows and window systems for which the Secretary has prescribed test procedures under paragraph (1) except that, with respect to any type of window or window system (or class thereof), the Secretary may determine that such labeling is not technologically feasible or economically justified or is not likely to assist consumers in making purchasing decisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of sections 323, 324, and 327 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6293"},"text":"42 U.S.C. 6293","children":[],"tail":", 6294, 6297], each product for which the Secretary has established test procedures or labeling rules pursuant to this subsection shall be considered a new covered product under section 322 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6292"},"text":"42 U.S.C. 6292","children":[],"tail":") to the extent necessary to carry out this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of section 327(a) of such Act, the term ‘this part’ includes this subsection to the extent necessary to carry out this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4f54-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Energy Efficiency Information for Commercial Office Equipment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s125"},"text":"Pub. L. 102–486, title I, § 125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2833"},"text":"106 Stat. 2833","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tI/s125"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, after consulting with the Computer and Business Equipment Manufacturers Association and other interested organizations, provide financial and technical assistance to support a voluntary national testing and information program for those types of commercial office equipment that are widely used and for which there is a potential for significant energy savings as a result of such program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such program shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the objectives of paragraph (1), determine the commercial office equipment to be covered under such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include specifications for testing procedures that will enable purchasers of such commercial office equipment to make more informed decisions about the energy efficiency and costs of alternative products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include information, which may be disseminated through catalogs, trade publications, labels, or other mechanisms, that will allow consumers to assess the energy consumption and potential cost savings of alternative products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such program shall be developed by an appropriate organization (composed of interested parties) according to commonly accepted procedures for the development of national testing procedure and labeling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall monitor and evaluate the efforts to develop the program described in subsection (a) and, not later than three years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"], shall make a determination as to whether such program is consistent with the objectives of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative System","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary makes a determination under subsection (b) that a voluntary national testing and information program for commercial office equipment consistent with the objectives of subsection (a) has not been developed, the Secretary shall, after consultation with the National Institute of Standards and Technology, develop, not later than two years after such determination, test procedures under section 323 of the Energy Policy and Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6293"},"text":"42 U.S.C. 6293","children":[],"tail":") for such commercial office equipment."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the Secretary develops test procedures under paragraph (1), the Federal Trade Commission (hereafter in this section referred to as the ‘Commission’) shall prescribe labeling rules under section 324 of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294"},"text":"42 U.S.C. 6294","children":[],"tail":") for commercial office equipment for which the Secretary has prescribed test procedures under paragraph (1) except that, with respect to any type of commercial office equipment (or class thereof), the Secretary may determine that such labeling is not technologically feasible or economically justified or is not likely to assist consumers in making purchasing decisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of sections 323, 324, and 327 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6293"},"text":"42 U.S.C. 6293","children":[],"tail":", 6294, 6297], each product for which the Secretary has established test procedures or labeling rules pursuant to this subsection shall be considered a new covered product under section 322 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6292"},"text":"42 U.S.C. 6292","children":[],"tail":") to the extent necessary to carry out this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of section 327(a) of such Act, the term ‘this part’ includes this subsection to the extent necessary to carry out this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4f55-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Energy Efficiency Information for Luminaires","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s126"},"text":"Pub. L. 102–486, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2834"},"text":"106 Stat. 2834","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/486/tI/s126"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, after consulting with the National Electric Manufacturers Association, the American Lighting Association, and other interested organizations, provide financial and technical assistance to support a voluntary national testing and information program for those types of luminaires that are widely used and for which there is a potential for significant energy savings as a result of such program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such program shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the objectives of paragraph (1), determine the luminaires to be covered under such program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include specifications for testing procedures that will enable purchasers of such luminaires to make more informed decisions about the energy efficiency and costs of alternative products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include information, which may be disseminated through catalogs, trade publications, labels, or other mechanisms, that will allow consumers to assess the energy consumption and potential cost savings of alternative products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such program shall be developed by an appropriate organization (composed of interested parties) according to commonly accepted procedures for the development of national testing procedures and labeling programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall monitor and evaluate the efforts to develop the program described in subsection (a) and, not later than three years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"], shall make a determination as to whether the program developed is consistent with the objectives of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative System","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary makes a determination under subsection (b) that a voluntary national testing and information program for luminaires consistent with the objectives of subsection (a) has not been developed, the Secretary shall, after consultation with the National Institute of Standards and Technology, develop, not later than two years after such determination, test procedures under section 323 of the Energy Policy and Conservation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6293"},"text":"42 U.S.C. 6293","children":[],"tail":") for such luminaires."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the Secretary develops test procedures under paragraph (1), the Federal Trade Commission (hereafter in this section referred to as the ‘Commission’) shall prescribe labeling rules under section 324 of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294"},"text":"42 U.S.C. 6294","children":[],"tail":") for those luminaires for which the Secretary has prescribed test procedures under paragraph (1) except that, with respect to any type of luminaire (or class thereof), the Secretary may determine that such labeling is not technologically feasible or economically justified or is not likely to assist consumers in making purchasing decisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of sections 323, 324, and 327 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6293"},"text":"42 U.S.C. 6293","children":[],"tail":", 6294, 6297], each product for which the Secretary has established test procedures or labeling rules pursuant to this subsection shall be considered a new covered product under section 322 of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6292"},"text":"42 U.S.C. 6292","children":[],"tail":") to the extent necessary to carry out this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of section 327(a) of such Act, the term ‘this part’ includes this subsection to the extent necessary to carry out this subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4f56-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Potential of Cooperative Advanced Appliance Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s127"},"text":"Pub. L. 102–486, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2835"},"text":"106 Stat. 2835","children":[],"tail":", provided that not later than 18 months after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", the Secretary would, in consultation with the Administrator of the Environmental Protection Agency, utilities, and appliance manufacturers, submit to Congress a report, based on certain criteria, on the potential for the development and commercialization of appliances substantially more efficient than required by Federal or State law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4f57-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation of Utility Early Replacement Programs for Appliances","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s128"},"text":"Pub. L. 102–486, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2836"},"text":"106 Stat. 2836","children":[],"tail":", required the Secretary, within 18 months after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", and in consultation with the Administrator of the Environmental Protection Agency, utilities, and appliance manufacturers, to evaluate and report to Congress on the energy savings and environmental benefits of programs directed to the early replacement of older, less efficient appliances (as defined in subsec. (a) of this section) in use by consumers with products more efficient than required by Federal law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
