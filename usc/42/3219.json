{"tag":"section","attrib":{"id":"idbc7973d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3219"},"text":null,"children":[{"tag":"num","attrib":{"value":"3219"},"text":"§ 3219.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to assistance under other law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter authorizes or permits any reduction in the amount of Federal assistance that any State or other entity eligible under this chapter is entitled to receive under any other Act.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc7973d4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tVI/s609"},"text":"Pub. L. 89–136, title VI, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3616"},"text":"112 Stat. 3616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/373/tVI/s602"},"text":"Pub. L. 108–373, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-27"},"text":"Oct. 27, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1769"},"text":"118 Stat. 1769","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc7973d5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc7973d6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"pr