{"tag":"section","attrib":{"id":"idbe0c7070-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"7385s–2"},"text":"§ 7385s–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation schedule for contractor employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe0c7071-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation provided","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of contractor employee compensation under this part for a covered DOE contractor employee shall be the sum of the amounts determined under paragraphs (1) and (2), as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe0c7072-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impairment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0c7073-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe0c7074-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum impairment rating of that employee, expressed as a number of percentage points; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe0eb965-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of those points that are the result of any covered illness contracted by that employee through exposure to a toxic substance at a Department of Energy facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0eb966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee shall receive an amount under this paragraph equal to $2,500 multiplied by the number referred to in clause (ii) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe0eb967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wage loss","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe0eb968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall determine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe0eb969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the calendar month during which the employee first experienced wage loss as the result of any covered illness contracted by that employee through exposure to a toxic substance at a Department of Energy facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe0eb96a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average annual wage of the employee for the 36-month period immediately preceding the calendar month referred to in clause (i), excluding any portions of that period during which the employee was unemployed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe0eb96b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" beginning with the calendar year that includes the calendar month referred to in clause (i), through and including the calendar year during which the employee attained normal retirement age (for purposes of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s301"},"text":"42 U.S.C. 301","children":[],"tail":" et seq.])—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbe0eb96c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of calendar years during which, as the result of any covered illness contracted by that employee through exposure to a toxic substance at a Department of Energy facility, the employee’s annual wage exceeded 50 percent of the average annual wage determined under clause (ii), but did not exceed 75 percent of the average annual wage determined under clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbe0eb96d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of calendar years during which, as the result of any covered illness contracted by that employee through exposure to a toxic substance at a Department of Energy facility, the employee’s annual wage did not exceed 50 percent of the average annual wage determined under clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe0eb96e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The employee shall receive an amount under this paragraph equal to the sum of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbe0eb96f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000 multiplied by the number referred to in clause (iii)(I) of subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbe0eb970-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000 multiplied by the number referred to in clause (iii)(II) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe0eb971-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7385s–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of minimum impairment rating","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), a minimum impairment rating shall be determined in accordance with the American Medical Association’s Guides to the Evaluation of Permanent Impairment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe0eb972-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dC/tXXXVI/s3673"},"text":"Pub. L. 106–398, § 1 [div. C, title XXXVI, § 3673]","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dC/tXXXI/s3161"},"text":"Pub. L. 108–375, div. C, title XXXI, § 3161","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2179"},"text":"118 Stat. 2179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe0eb973-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe0eb974-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbe0eb975-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(2)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
