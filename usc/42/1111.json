{"tag":"section","attrib":{"id":"idb80f141e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111"},"text":null,"children":[{"tag":"num","attrib":{"value":"1111"},"text":"§ 1111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data exchange standardization for improved interoperability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb80f141f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data exchange standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f1420-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor, in consultation with an interagency work group which shall be established by the Office of Management and Budget, and considering State and employer perspectives, shall, by rule, designate a data exchange standard for any category of information required under subchapter III, subchapter XII, or this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1421-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data exchange standards designated under paragraph (1) shall, to the extent practicable, be nonproprietary and interoperable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1422-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In designating data exchange standards under this subsection, the Secretary of Labor shall, to the extent practicable, incorporate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb80f1423-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperable standards developed and maintained by an international voluntary consensus standards body, as defined by the Office of Management and Budget, such as the International Organization for Standardization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f1424-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperable standards developed and maintained by intergovernmental partnerships, such as the National Information Exchange Model; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f1425-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperable standards developed and maintained by Federal entities with authority over contracting and financial assistance, such as the Federal Acquisition Regulations Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80f1426-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data exchange standards for reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb80f1427-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor, in consultation with an interagency work group established by the Office of Management and Budget, and considering State and employer perspectives, shall, by rule, designate data exchange standards to govern the reporting required under subchapter III, subchapter XII, or this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f1428-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The data exchange standards required by paragraph (1) shall, to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb80f1429-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate a widely accepted, nonproprietary, searchable, computer-readable format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f142a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with and implement applicable accounting principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb80f142b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be capable of being continually upgraded as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb80f142c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In designating reporting standards under this subsection, the Secretary of Labor shall, to the extent practicable, incorporate existing nonproprietary standards, such as the eXtensible Markup Language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb80f142d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IX, § 911, as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/96/tII/s2104/a"},"text":"Pub. L. 112–96, title II, § 2104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/161"},"text":"126 Stat. 161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb80f142e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb80f142f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb80f1430-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/96/tII/s2104/b"},"text":"Pub. L. 112–96, title II, § 2104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/162"},"text":"126 Stat. 162","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/96/tII/s2104/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data exchange standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall issue a proposed rule under section 911(a)(1) of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1111/a/1"},"text":"42 U.S.C. 1111(a)(1)","children":[],"tail":"] (as added by subsection (a)) within 12 months after the date of the enactment of this section ["},{"tag":"date","attrib":{"date":"2012-02-22"},"text":"Feb. 22, 2012","children":[],"tail":"], and shall issue a final rule under such section 911(a)(1), after public comment, within 24 months after such date of enactment."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data reporting standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reporting standards required under section 911(b)(1) of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1111/b/1"},"text":"42 U.S.C. 1111(b)(1)","children":[],"tail":"] (as so added) shall become effective with respect to reports required in the first reporting period, after the effective date of the final rule referred to in paragraph (1) of this subsection, for which the authority for data collection and reporting is established or renewed under the Paperwork Reduction Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
