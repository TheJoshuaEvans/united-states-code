{"tag":"section","attrib":{"id":"idbfbbf45e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13333"},"text":null,"children":[{"tag":"num","attrib":{"value":"13333"},"text":"§ 13333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean coal, waste-to-energy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program of research, development, demonstration, and commercial application with respect to the use of solid waste combined with coal as a fuel source for clean coal combustion technologies. The program shall address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfbbf45f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13333/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of cofiring coal and used vehicle tires in fluidized bed combustion units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf460-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13333/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the combined gasification of coal and municipal sludge using integrated gasification combined cycle technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf461-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13333/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of fuel pellets combining coal and material reclaimed from solid waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf462-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13333/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of cofiring, in fluidized bed combustion units, waste methane from coal mines, including ventilation air, together with coal or coal wastes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfbbf463-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13333/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other sources of waste and coal mixtures in other applications that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfbbf464-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXIII/s1303"},"text":"Pub. L. 102–486, title XIII, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2972"},"text":"106 Stat. 2972","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
