{"tag":"section","attrib":{"id":"idb58d9940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289c"},"text":null,"children":[{"tag":"num","attrib":{"value":"289c"},"text":"§ 289c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on public health emergencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines, after consultation with the Director of NIH, the Commissioner of the Food and Drug Administration, or the Director of the Centers for Disease Control and Prevention, that a disease or disorder constitutes a public health emergency, the Secretary, acting through the Director of NIH—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb58d9941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall expedite the review by advisory councils under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s284a"},"text":"section 284a of this title","children":[],"tail":" and by peer review groups under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s289a"},"text":"section 289a of this title","children":[],"tail":" of applications for grants for research on such disease or disorder or proposals for contracts for such research;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall exercise the authority in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":" respecting public exigencies to waive the advertising requirements of such section in the case of proposals for contracts for such research;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide administrative supplemental increases in existing grants and contracts to support new research relevant to such disease or disorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb58d9944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s289c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall disseminate, to health professionals and the public, information on the cause, prevention, and treatment of such disease or disorder that has been developed in research assisted under this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The amount of an increase in a grant or contract provided under paragraph (3) may not exceed one-half the original amount of the grant or contract.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb58d9945-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 494, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/875"},"text":"99 Stat. 875","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s312/d/9"},"text":"Pub. L. 102–531, title III, § 312(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3504"},"text":"106 Stat. 3504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s104/b/1/P"},"text":"Pub. L. 109–482, title I, § 104(b)(1)(P)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3693"},"text":"120 Stat. 3693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb58d9946-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb58d9947-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb58d9948-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. (2), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb58d9949-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out subsec. (a) designation before “If the Secretary” and subsec. (b) which read as follows: “Not later than 90 days after the end of a fiscal year, the Secretary shall report to the Committee on Energy and Commerce of the House of Representatives and the Committee on Labor and Human Resources of the Senate on actions taken under subsection (a) of this section in such fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/531"},"text":"Pub. L. 102–531","children":[],"tail":" substituted “Centers for Disease Control and Prevention” for “Centers for Disease Control”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb58d994a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb58d994b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
