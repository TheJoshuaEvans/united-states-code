{"tag":"section","attrib":{"id":"idbc6d8c55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"3058aa"},"text":"§ 3058aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Native American program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc6d8c56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, acting through the Director of the Office for American Indian, Alaskan Native, and Native Hawaiian Aging, shall establish and carry out a program for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6d8c57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting eligible entities in prioritizing, on a continuing basis, the needs of the service population of the entities relating to elder rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making grants to eligible entities to carry out vulnerable elder rights protection activities that the entities determine to be priorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enabling the eligible entities to support multidisciplinary elder justice activities, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc6d8c5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a coordinating council, which shall identify the needs of an individual Indian tribe or other Native American group and provide the Assistant Secretary with information and recommendations relating to efforts by the Indian tribe or the governing entity of the Native American group to combat elder abuse, neglect, and exploitation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8c5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training, technical assistance, and other methods of support to groups carrying out multidisciplinary efforts for an Indian tribe or other Native American group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc6d8c5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" broadening and studying various models for elder fatality and serious injury review teams, to make recommendations about their composition, protocols, functions, timing, roles, and responsibilities, with a goal of producing models and information that will allow for replication based on the needs of Indian tribes and other Native American groups (other than the ones in which the review teams were used).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to be eligible to receive assistance under this section, an entity shall submit an application to the Assistant Secretary, at such time, in such manner, and containing such information as the Assistant Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to receive assistance under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc6d8c5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc6d8c60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public agency, or a nonprofit organization, serving older individuals who are Native Americans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc6d8c61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3058aa/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this part such sums as may be necessary for fiscal year 2007, and such sums as may be necessary for subsequent fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc6d8c62-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/73/tVII/s751"},"text":"Pub. L. 89–73, title VII, § 751","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/375/tVII/s706"},"text":"Pub. L. 102–375, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"Sept. 30, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1290"},"text":"106 Stat. 1290","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/171/s3/a/10"},"text":"Pub. L. 103–171, § 3(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-02"},"text":"Dec. 2, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1990"},"text":"107 Stat. 1990","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/501/tVII/s707"},"text":"Pub. L. 106–501, title VII, § 707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2291"},"text":"114 Stat. 2291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/365/tVII/s703"},"text":"Pub. L. 109–365, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2592"},"text":"120 Stat. 2592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc6d8c63-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc6d8c64-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc6d8c65-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s703/1"},"text":"Pub. L. 109–365, § 703(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s703/2"},"text":"Pub. L. 109–365, § 703(2)","children":[],"tail":", substituted “this section” for “this part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/365/s703/3"},"text":"Pub. L. 109–365, § 703(3)","children":[],"tail":", substituted “this part” for “this section” and “2007” for “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/501"},"text":"Pub. L. 106–501","children":[],"tail":" amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “There are authorized to be appropriated to carry out this section, $5,000,000 for fiscal year 1992, and such sums as may be necessary for fiscal years 1993, 1994, and 1995.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171"},"text":"Pub. L. 103–171","children":[],"tail":" substituted “Assistant Secretary” for “Commissioner” and “Director of the Office for” for “Associate Commissioner on” in subsec. (a) and “Assistant Secretary” for “Commissioner” in two places in subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc6d8c66-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc6d8c67-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section inapplicable with respect to fiscal year 1993, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/171/s4/b"},"text":"section 4(b) of Pub. L. 103–171","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section inapplicable with respect to fiscal year 1992, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/375/s905/b/6"},"text":"section 905(b)(6) of Pub. L. 102–375","children":[],"tail":", set out as an Effective Date of 1992 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
