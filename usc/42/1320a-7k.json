{"tag":"section","attrib":{"id":"idb83ed6ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320a–7k"},"text":"§ 1320a–7k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare and Medicaid program integrity provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb83ed6ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data matching","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83ed6ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated data repository","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83ed6f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of certain data","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83ed6f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Integrated Data Repository of the Centers for Medicare & Medicaid Services shall include, at a minimum, claims and payment data from the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb83ed6f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The programs under subchapters XVIII and XIX (including parts A, B, C, and D of subchapter XVIII).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program under subchapter XXI.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health-related programs administered by the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Health-related programs administered by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The program of old-age, survivors, and disability insurance benefits established under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Indian Health Service and the Contract Health Service program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83ed6f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for inclusion of certain data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Inclusion of the data described in subclause (I) of such clause ","children":[{"tag":"ref","attrib":{"idref":"fn002700"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002700"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “clause (i)”."}],"tail":" in the Integrated Data Repository shall be a priority. Data described in subclauses (II) through (VI) of such clause "},{"tag":"ref","attrib":{"idref":"fn002700"},"text":"1","children":[],"tail":" shall be included in the Integrated Data Repository as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed6f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data sharing and matching","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83ed6fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into agreements with the individuals described in clause (ii) under which such individuals share and match data in the system of records of the respective agencies of such individuals with data in the system of records of the Department of Health and Human Services for the purpose of identifying potential fraud, waste, and abuse under the programs under subchapters XVIII and XIX.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83ed6fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following individuals are described in this clause:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb83ed6fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb83ed6ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Indian Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83ed700-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of system of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this paragraph, the term “system of records” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/a/5"},"text":"section 552a(a)(5) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83ed701-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to claims and payment databases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of conducting law enforcement and oversight activities and to the extent consistent with applicable information, privacy, security, and disclosure laws, including the regulations promulgated under the Health Insurance Portability and Accountability Act of 1996 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", and subject to any information systems security requirements under such laws or otherwise required by the Secretary, the Inspector General of the Department of Health and Human Services and the Attorney General shall have access to claims and payment data of the Department of Health and Human Services and its contractors related to subchapters XVIII, XIX, and XXI."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83ed702-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OIG authority to obtain information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83ed703-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding and in addition to any other provision of law, the Inspector General of the Department of Health and Human Services may, for purposes of protecting the integrity of the programs under subchapters XVIII and XIX, obtain information from any individual (including a beneficiary provided all applicable privacy protections are followed) or entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83ed704-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a provider of medical or other items or services, supplier, grant recipient, contractor, or subcontractor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed705-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or indirectly provides, orders, manufactures, distributes, arranges for, prescribes, supplies, or receives medical or other items or services payable by any Federal health care program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320a–7b/f"},"text":"section 1320a–7b(f) of this title","children":[],"tail":") regardless of how the item or service is paid for, or to whom such payment is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83ed706-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of certain information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information which the Inspector General may obtain under paragraph (1) includes any supporting documentation necessary to validate claims for payment or payments under subchapter XVIII or XIX, including a prescribing physician’s medical records for an individual who is prescribed an item or service which is covered under part B of subchapter XVIII, a covered part D drug (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–102/e"},"text":"section 1395w–102(e) of this title","children":[],"tail":") for which payment is made under an MA–PD plan under part C of such subchapter, or a prescription drug plan under part D of such subchapter, and any records necessary for evaluation of the economy, efficiency, and effectiveness of the programs under subchapters XVIII and XIX."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83ed707-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative remedy for knowing participation by beneficiary in health care fraud scheme","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83ed708-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other applicable remedies, if an applicable individual has knowingly participated in a Federal health care fraud offense or a conspiracy to commit a Federal health care fraud offense, the Secretary shall impose an appropriate administrative penalty commensurate with the offense or conspiracy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83ed709-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “applicable individual” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83ed70a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to, or enrolled for, benefits under part A of subchapter XVIII or enrolled under part B of such subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed70b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for medical assistance under a State plan under subchapter XIX or under a waiver of such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed70c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for child health assistance under a child health plan under subchapter XXI.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83ed70d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting and returning of overpayments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb83ed70e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person has received an overpayment, the person shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83ed70f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report and return the overpayment to the Secretary, the State, an intermediary, a carrier, or a contractor, as appropriate, at the correct address; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed710-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Secretary, State, intermediary, carrier, or contractor to whom the overpayment was returned in writing of the reason for the overpayment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83ed711-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for reporting and returning overpayments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An overpayment must be reported and returned under paragraph (1) by the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83ed712-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date which is 60 days after the date on which the overpayment was identified; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed713-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date any corresponding cost report is due, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83ed714-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any overpayment retained by a person after the deadline for reporting and returning the overpayment under paragraph (2) is an obligation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729/b/3"},"text":"section 3729(b)(3) of title 31","children":[],"tail":") for purposes of section 3729 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb83ed715-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb83ed716-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowing and knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “knowing” and “knowingly” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729/b"},"text":"section 3729(b) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed717-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overpayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “overpayment” means any funds that a person receives or retains under subchapter XVIII or XIX to which the person, after applicable reconciliation, is not entitled under such subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb83ed718-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb83ed719-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means a provider of services, supplier, medicaid managed care organization (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396b/m/1/A"},"text":"section 1396b(m)(1)(A) of this title","children":[],"tail":"), Medicare Advantage organization (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–28/a/1"},"text":"section 1395w–28(a)(1) of this title","children":[],"tail":"), or PDP sponsor (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–151/a/13"},"text":"section 1395w–151(a)(13) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb83ed71a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/d/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such term does not include a beneficiary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83ed71b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320a–7k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion of national provider identifier on all applications and claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate a regulation that requires, not later than ","children":[{"tag":"date","attrib":{"date":"2011-01-01"},"text":"January 1, 2011","children":[],"tail":", all providers of medical or other items or services and suppliers under the programs under subchapters XVIII and XIX that qualify for a national provider identifier to include their national provider identifier on all applications to enroll in such programs and on all claims for payment submitted under such programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb83ed71c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1128J, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tVI/s6402/a"},"text":"Pub. L. 111–148, title VI, § 6402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/753"},"text":"124 Stat. 753","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb83ed71d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb83ed71e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb83ed71f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Health Insurance Portability and Accountability Act of 1996, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/191"},"text":"Pub. L. 104–191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1936"},"text":"110 Stat. 1936","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
