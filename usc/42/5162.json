{"tag":"section","attrib":{"id":"idbd120a4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162"},"text":null,"children":[{"tag":"num","attrib":{"value":"5162"},"text":"§ 5162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance of non-Federal share","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd120a4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may lend or advance to an eligible applicant or a State the portion of assistance for which the State is responsible under the cost-sharing provisions of this chapter in any case in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State is unable to assume its financial responsibility under such cost-sharing provisions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd120a51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to concurrent, multiple major disasters in a jurisdiction, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd120a52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after incurring extraordinary costs as a result of a particular disaster; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the damages caused by such disasters or disaster are so overwhelming and severe that it is not possible for the applicant or the State to assume immediately their financial responsibility under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of loans and advances","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd120a55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any loan or advance under this section shall be repaid to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd120a56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loans and advances under this section shall bear interest at a rate determined by the Secretary of the Treasury, taking into consideration the current market yields on outstanding marketable obligations of the United States with remaining periods to maturity comparable to the reimbursement period of the loan or advance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd120a57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall issue regulations describing the terms and conditions under which any loan or advance authorized by this section may be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd120a58-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288/tIII/s319"},"text":"Pub. L. 93–288, title III, § 319","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/707/tI/s105/m/1"},"text":"Pub. L. 100–707, title I, § 105(m)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4695"},"text":"102 Stat. 4695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd120a59-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd120a5a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd120a5b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
