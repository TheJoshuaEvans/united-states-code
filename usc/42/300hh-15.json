{"tag":"section","attrib":{"id":"idb6cfde1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"300hh–15"},"text":"§ 300hh–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer Medical Reserve Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6cfde1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-12-19"},"text":"December 19, 2006","children":[],"tail":", the Secretary, in collaboration with State, local, and tribal officials, shall build on State, local, and tribal programs in existence on "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"December 19, 2006","children":[],"tail":", to establish and maintain a Medical Reserve Corps (referred to in this section as the “Corps”) to provide for an adequate supply of volunteers in the case of a Federal, State, local, or tribal public health emergency. The Secretary may appoint a Director to head the Corps and oversee the activities of the Corps chapters that exist at the State, local, Tribal, and territorial levels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, local, and tribal coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corps shall be established using existing State, local, and tribal teams and shall not alter such teams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corps shall be composed of individuals who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfde22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6cfde23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are health professionals who have appropriate professional training and expertise as determined appropriate by the Director of the Corps; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6cfde24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are non-health professionals who have an interest in serving in an auxiliary or support capacity to facilitate access to health care services in a public health emergency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are certified in accordance with the certification program developed under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are geographically diverse in residence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have registered and carry out training exercises with a local chapter of the Medical Reserve Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate whether they are willing to be deployed outside the area in which they reside in the event of a public health emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification; drills","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfde2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in collaboration with State, local, and tribal officials, shall establish a process for the periodic certification of individuals who volunteer for the Corps, as determined by the Secretary, which shall include the completion by each individual of the core training programs developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–6"},"text":"section 247d–6 of this title","children":[],"tail":", as required by the Director. Such certification shall not supercede State licensing or credentialing requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drills","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conjunction with the core training programs referred to in paragraph (1), and in order to facilitate the integration of trained volunteers into the health care system at the local level, Corps members shall engage in periodic training exercises to be carried out at the local level. Such training exercises shall, as appropriate and applicable, incorporate the needs of at-risk individuals in the event of a public health emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During a public health emergency, the Secretary shall have the authority to activate and deploy willing members of the Corps to areas of need, taking into consideration the public health and medical expertise required, with the concurrence of the State, local, or tribal officials from the area where the members reside.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses and transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While engaged in performing duties as a member of the Corps pursuant to an assignment by the Secretary (including periods of travel to facilitate such assignment), members of the Corps who are not otherwise employed by the Federal Government shall be allowed travel or transportation expenses, including per diem in lieu of subsistence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in cooperation and consultation with the States, shall develop a Medical Reserve Corps Identification Card that describes the licensure and certification information of Corps members, as well as other identifying information determined necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermittent disaster-response personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6cfde30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of assisting the Corps in carrying out duties under this section, during a public health emergency, the Secretary may appoint selected individuals to serve as intermittent personnel of such Corps in accordance with applicable civil service laws and regulations. In all other cases, members of the Corps are subject to the laws of the State in which the activities of the Corps are undertaken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (c)(2), (d), and (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11"},"text":"section 300hh–11 of this title","children":[],"tail":" shall apply to an individual appointed under paragraph (1) in the same manner as such subsections apply to an individual appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300hh–11/c"},"text":"section 300hh–11(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6cfde32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State, local, and tribal officials shall have no authority to designate a member of the Corps as Federal intermittent disaster-response personnel, but may request the services of such members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6cfde33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300hh–15/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $11,200,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6cfde34-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVIII, § 2813, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/417/tIII/s303/a"},"text":"Pub. L. 109–417, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2856"},"text":"120 Stat. 2856","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/5/tII/s203/b/2"},"text":"Pub. L. 113–5, title II, § 203(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-13"},"text":"Mar. 13, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/175"},"text":"127 Stat. 175","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/22/tIII/s301/b"},"text":"Pub. L. 116–22, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-06-24"},"text":"June 24, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/932"},"text":"133 Stat. 932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6cfde35-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6cfde36-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6cfde37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s301/b/1"},"text":"Pub. L. 116–22, § 301(b)(1)","children":[],"tail":", substituted “The Secretary may appoint a Director to head the Corps and oversee the activities of the Corps chapters that exist at the State, local, Tribal, and territorial levels.” for “The Corps shall be headed by a Director who shall be appointed by the Secretary and shall oversee the activities of the Corps chapters that exist at the State, local, and tribal levels.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/22/s301/b/2"},"text":"Pub. L. 116–22, § 301(b)(2)","children":[],"tail":", substituted “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/b/2/A"},"text":"Pub. L. 113–5, § 203(b)(2)(A)","children":[],"tail":", inserted at end “Such training exercises shall, as appropriate and applicable, incorporate the needs of at-risk individuals in the event of a public health emergency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/5/s203/b/2/B"},"text":"Pub. L. 113–5, § 203(b)(2)(B)","children":[],"tail":", substituted “$11,200,000 for each of fiscal years 2014 through 2018” for “$22,000,000 for fiscal year 2007, and such sums as may be necessary for each of fiscal years 2008 through 2011”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
