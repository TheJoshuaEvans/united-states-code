{"tag":"section","attrib":{"id":"idc02e64f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17212"},"text":null,"children":[{"tag":"num","attrib":{"value":"17212"},"text":"§ 17212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water power technology research, development, and demonstration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to conduct research, development, demonstration, and commercial application of water power technologies in support of each of the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc02e64f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17212/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote research, development, demonstration, and commercial application of water power generation technologies in order to increase capacity and reduce the cost of those technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e64f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17212/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote research and development to improve the environmental impact of water power technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e64f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17212/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide grid reliability and resilience, including through technologies that facilitate new market opportunities, such as ancillary services, for water power.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc02e64f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17212/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote the development of water power technologies to improve economic growth and enhance cross-institutional foundational workforce development in the water power sector, including in coastal communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc02e64f7-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s633"},"text":"Pub. L. 110–140, title VI, § 633","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3001/a"},"text":"Pub. L. 116–260, div. Z, title III, § 3001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2480"},"text":"134 Stat. 2480","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc02e64f8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc02e64f9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idc02e64fa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 17212, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tVI/s633"},"text":"Pub. L. 110–140, title VI, § 633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1686"},"text":"121 Stat. 1686","children":[],"tail":", related to marine and hydrokinetic renewable energy research and development, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
