{"tag":"section","attrib":{"id":"idbfe946c0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922"},"text":null,"children":[{"tag":"num","attrib":{"value":"15922"},"text":"§ 15922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation regarding oil and gas leasing on public land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfe946c1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary of the Interior and the Secretary of Agriculture shall enter into a memorandum of understanding regarding oil and gas leasing on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe946c2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public land under the jurisdiction of the Secretary of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946c3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National Forest System land under the jurisdiction of the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfe946c4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The memorandum of understanding shall include provisions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfe946c5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish administrative procedures and lines of authority that ensure timely processing of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946c6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil and gas lease applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946c7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surface use plans of operation, including steps for processing surface use plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946c8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications for permits to drill consistent with applicable timelines;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946c9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate duplication of effort by providing for coordination of planning and environmental compliance efforts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946ca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that lease stipulations are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946cb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied consistently;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated between agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only as restrictive as necessary to protect the resource for which the stipulations are applied;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a joint data retrieval system that is capable of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracking applications and formal requests made in accordance with procedures of the Federal onshore oil and gas leasing program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information regarding the status of the applications and requests within the Department of the Interior and the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfe946d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a joint geographic information system mapping system for use in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfe946d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracking surface resource values to aid in resource management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfe946d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15922/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing surface use plans of operation and applications for permits to drill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfe946d4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIII/s363"},"text":"Pub. L. 109–58, title III, § 363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/722"},"text":"119 Stat. 722","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
