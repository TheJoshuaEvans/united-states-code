{"tag":"section","attrib":{"id":"idbdf95cc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174"},"text":null,"children":[{"tag":"num","attrib":{"value":"7174"},"text":"§ 7174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral of other rulemaking proceedings to Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbdf95cca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of Commission of proposed action; public comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7173"},"text":"section 7173 of this title","children":[],"tail":", whenever the Secretary proposes to prescribe rules, regulations, and statements of policy of general applicability in the exercise of any function which is transferred to the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7151"},"text":"section 7151 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60501"},"text":"section 60501 of title 49","children":[],"tail":", he shall notify the Commission of the proposed action. If the Commission, in its discretion, determines within such period as the Secretary may prescribe, that the proposed action may significantly affect any function within the jurisdiction of the Commission pursuant to section 7172(a)(1) and (c)(1) of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60502"},"text":"section 60502 of title 49","children":[],"tail":", the Secretary shall immediately refer the matter to the Commission, which shall provide an opportunity for public comment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ccb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of Commission; publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following such opportunity for public comment the Commission, after consultation with the Secretary, shall either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf95ccc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concur in adoption of the rule or statement as proposed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf95ccd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concur in adoption of the rule or statement only with such changes as it may recommend; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf95cce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend that the rule or statement not be adopted.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Commission shall promptly publish its recommendations, adopted under this subsection, along with an explanation of the reason for its actions and an analysis of the major comments, criticisms, and alternatives offered during the comment period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbdf95ccf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options of Secretary; final agency action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following publication of the Commission’s recommendations the Secretary shall have the option of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbdf95cd0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing a final rule or statement in the form initially proposed by the Secretary if the Commission has concurred in such rule pursuant to subsection (b)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf95cd1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing a final rule or statement in amended form so that the rule conforms in all respects with the changes proposed by the Commission if the Commission has concurred in such rule or statement pursuant to subsection (b)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbdf95cd2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7174/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ordering that the rule shall not be issued.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The action taken by the Secretary pursuant to this subsection shall constitute a final agency action for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s704"},"text":"section 704 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbdf95cd3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91/tIV/s404"},"text":"Pub. L. 95–91, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/586"},"text":"91 Stat. 586","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbdf95cd4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbdf95cd5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbdf95cd6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60501"},"text":"section 60501 of title 49","children":[],"tail":"” substituted for reference to section 306 of this Act, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/s306"},"text":"section 306 of Pub. L. 95–91","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7155"},"text":"42 U.S.C. 7155","children":[],"tail":"], and “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60502"},"text":"section 60502 of title 49","children":[],"tail":"” substituted for reference to section 402(b), meaning "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/s402/b"},"text":"section 402(b) of Pub. L. 95–91","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7172/b"},"text":"42 U.S.C. 7172(b)","children":[],"tail":"] on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s6/b"},"text":"Pub. L. 103–272, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", the first section of which enacted subtitles II, III, and V to X of Title 49, Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
