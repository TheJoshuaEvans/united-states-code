{"tag":"section","attrib":{"id":"idb42a875a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s214"},"text":null,"children":[{"tag":"num","attrib":{"value":"214"},"text":"§ 214.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of United States flag upon retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb42a875b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s214/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presentation of flag","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the release of an officer of the commissioned corps of the Service from active commissioned service for retirement, the Secretary of Health and Human Services shall present a United States flag to the officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42a875c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s214/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple presentations not authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer is not eligible for presentation of a flag under subsection (a) if the officer has previously been presented a flag under this section or any other provision of law providing for the presentation of a United States flag incident to release from active service for retirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb42a875d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s214/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No cost to recipient","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The presentation of a flag under this section shall be at no cost to the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb42a875e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 213, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s652/b"},"text":"Pub. L. 106–65, div. A, title VI, § 652(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/665"},"text":"113 Stat. 665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb42a875f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb42a8760-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb42a8761-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 214, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title II, § 213, "},{"tag":"ref","attrib":{"href":"/us/stat/58/689"},"text":"58 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-04-27/ch211/s2/a"},"text":"Apr. 27, 1956, ch. 211, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/116"},"text":"70 Stat. 116","children":[],"tail":", authorized allowances for uniforms, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/649/s14b"},"text":"Pub. L. 87–649, § 14b","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-07"},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/499"},"text":"76 Stat. 499","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s415"},"text":"section 415 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb42a8762-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb42a8763-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to releases from service described in section on or after ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s652/d"},"text":"section 652(d) of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12605"},"text":"section 12605 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
