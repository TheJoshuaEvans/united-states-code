{"tag":"section","attrib":{"id":"idb5deeda0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e"},"text":null,"children":[{"tag":"num","attrib":{"value":"294e"},"text":"§ 294e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allied health and other disciplines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5deeda1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants or contracts under this section to help entities fund activities of the type described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5deeda2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities of the type described in this subsection include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5deeda3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Assisting entities in meeting the costs associated with expanding or establishing programs that will increase the number of individuals trained in allied health professions. Programs and activities funded under this paragraph may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5deeda4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that expand enrollments in allied health professions with the greatest shortages or whose services are most needed by geriatric populations or for maternal and child health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deeda5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that provide rapid transition training programs in allied health fields to individuals who have baccalaureate degrees in health-related sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deeda6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that establish community-based allied health training programs that link academic centers to rural clinical settings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deeda7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that provide career advancement training for practicing allied health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deeda8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that expand or establish clinical training sites for allied health professionals in medically underserved or rural communities in order to increase the number of individuals trained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deeda9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that develop curriculum that will emphasize knowledge and practice in the areas of prevention and health promotion, geriatrics, long-term care, home health and hospice care, and ethics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deedaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that expand or establish interdisciplinary training programs that promote the effectiveness of allied health practitioners in geriatric assessment and the rehabilitation of the elderly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deedab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those that expand or establish demonstration centers to emphasize innovative models to link allied health clinical practice, education, and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deedac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" those that provide financial assistance (in the form of traineeships) to students who are participants in any such program; and","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5deedad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/I/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who plan to pursue a career in an allied health field that has a demonstrated personnel shortage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5deedae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/I/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who agree upon completion of the training program to practice in a medically underserved community;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that shall be utilized to assist in the payment of all or part of the costs associated with tuition, fees and such other stipends as the Secretary may consider necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5deedaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those to meet the costs of projects to plan, develop, and operate or maintain graduate programs in behavioral and mental health practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deedb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Planning and implementing projects in preventive and primary care training for podiatric physicians in approved or provisionally approved residency programs that shall provide financial assistance in the form of traineeships to residents who participate in such projects and who plan to specialize in primary care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deedb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Carrying out demonstration projects in which chiropractors and physicians collaborate to identify and provide effective treatment for spinal and lower-back conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5deedb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing educational opportunities in physical therapy, occupational therapy, respiratory therapy, audiology, and speech-language pathology professions, which may include offering scholarships or stipends and carrying out other activities to improve retention, for individuals from disadvantaged backgrounds or individuals who are underrepresented in such professions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5deedb3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 755, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s103"},"text":"Pub. L. 105–392, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3548"},"text":"112 Stat. 3548","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dA/tIII/s3401/8"},"text":"Pub. L. 116–136, div. A, title III, § 3401(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/386"},"text":"134 Stat. 386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dFF/tII/s2224"},"text":"Pub. L. 117–328, div. FF, title II, § 2224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5749"},"text":"136 Stat. 5749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5deedb4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5deedb5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5deedb6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 294e, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s767"},"text":"act July 1, 1944, ch. 373, title VII, § 767","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tI/s102"},"text":"Pub. L. 102–408, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2048"},"text":"106 Stat. 2048","children":[],"tail":", authorized grants and contracts for establishment of programs to increase number of allied health professionals, prior to the general amendment of this part by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392"},"text":"Pub. L. 105–392","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 294e, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s732"},"text":"act July 1, 1944, ch. 373, title VII, § 732","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s401/b/3"},"text":"Pub. L. 94–484, title IV, § 401(b)(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2260"},"text":"90 Stat. 2260","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1977-08-01"},"text":"Aug. 1, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/83/tIII/s307/c/3"},"text":"Pub. L. 95–83, title III, § 307(c)(3)","children":[],"tail":", (4), "},{"tag":"ref","attrib":{"href":"/us/stat/91/390"},"text":"91 Stat. 390","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1977-12-19"},"text":"Dec. 19, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/215/s4/e/8"},"text":"Pub. L. 95–215, § 4(e)(8)","children":[],"tail":", (9), "},{"tag":"ref","attrib":{"href":"/us/stat/91/1506"},"text":"91 Stat. 1506","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2729"},"text":"Pub. L. 97–35, title XXVII, § 2729","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/918"},"text":"95 Stat. 918","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s208/e"},"text":"Pub. L. 99–129, title II, § 208(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/531"},"text":"99 Stat. 531","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVI/s602/g"},"text":"Pub. L. 100–607, title VI, § 602(g)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3123"},"text":"102 Stat. 3123","children":[],"tail":", related to certificates of loan insurance, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/102/408"},"text":"Pub. L. 102–408","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s292e"},"text":"section 292e of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 294e, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s744"},"text":"act July 1, 1944, ch. 373, title VII, § 744","children":[],"tail":", formerly § 745, as added "},{"tag":"date","attrib":{"date":"1963-09-24"},"text":"Sept. 24, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/129/s2/b"},"text":"Pub. L. 88–129, § 2(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/173"},"text":"77 Stat. 173","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1971-11-18"},"text":"Nov. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/157/tI/s105/f/2"},"text":"Pub. L. 92–157, title I, § 105(f)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/451"},"text":"85 Stat. 451","children":[],"tail":"; renumbered § 744, "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/484/tIV/s406/a/2"},"text":"Pub. L. 94–484, title IV, § 406(a)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2268"},"text":"90 Stat. 2268","children":[],"tail":", which related to administrative provisions, was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s294q"},"text":"section 294q of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5deedb7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136"},"text":"Pub. L. 116–136","children":[],"tail":" substituted “geriatric populations or for maternal and child health” for “the elderly”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
