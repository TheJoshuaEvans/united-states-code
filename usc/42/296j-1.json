{"tag":"section","attrib":{"id":"idb5f20145-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"296j–1"},"text":"§ 296j–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration grants for family nurse practitioner training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5f20146-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services (referred to in this section as the “Secretary”) shall establish a training demonstration program for family nurse practitioners (referred to in this section as the “program”) to employ and provide 1-year training for nurse practitioners who have graduated from a nurse practitioner program for careers as primary care providers in Federally qualified health centers (referred to in this section as “FQHCs”) and nurse-managed health clinics (referred to in this section as “NMHCs”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20147-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the program is to enable each grant recipient to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20148-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide new nurse practitioners with clinical training to enable them to serve as primary care providers in FQHCs and NMHCs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20149-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train new nurse practitioners to work under a model of primary care that is consistent with the principles set forth by the Institute of Medicine and the needs of vulnerable populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f2014a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a model of FQHC and NMHC training for nurse practitioners that may be replicated nationwide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2014b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award 3-year grants to eligible entities that meet the requirements established by the Secretary, for the purpose of operating the nurse practitioner primary care programs described in subsection (a) in such entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f2014c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f2014d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5f2014e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a FQHC as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395x/aa"},"text":"section 1395x(aa) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f2014f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a nurse-managed health clinic, as defined in section 330A–1 of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s254c–1a"},"text":"42 U.S.C. 254c–1a","children":[],"tail":"] (as added by section 5208 of this Act); "},{"tag":"ref","attrib":{"idref":"fn002291"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002291"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority in awarding grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to eligible entities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate sufficient infrastructure in size, scope, and capacity to undertake the requisite training of a minimum of 3 nurse practitioners per year, and to provide to each awardee 12 full months of full-time, paid employment and benefits consistent with the benefits offered to other full-time employees of such entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will assign not less than 1 staff nurse practitioner or physician to each of 4 precepted clinics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will provide to each awardee specialty rotations, including specialty training in prenatal care and women’s health, adult and child psychiatry, orthopedics, geriatrics, and at least 3 other high-volume, high-burden specialty areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide sessions on high-volume, high-risk health problems and have a record of training health care professionals in the care of children, older adults, and underserved populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f20156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with other safety net providers, schools, colleges, and universities that provide health professions training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f20157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of nurse practitioners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5f20158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for acceptance to a program funded through a grant awarded under this section, an individual shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5f47159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be licensed or eligible for licensure in the State in which the program is located as an advanced practice registered nurse or advanced practice nurse and be eligible or board-certified as a family nurse practitioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5f4715a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate commitment to a career as a primary care provider in a FQHC or in a NMHC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f4715b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting awardees under the program, each grant recipient shall give preference to bilingual candidates that meet the requirements described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5f4715c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral of certain service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The starting date of required service of individuals in the National Health Service Corps Service program under title II of the Public Health Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s202"},"text":"42 U.S.C. 202","children":[],"tail":" et seq.) who receive training under this section shall be deferred until the date that is 22 days after the date of completion of the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f4715d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant awarded under this section shall be in an amount not to exceed $600,000 per year. A grant recipient may carry over funds from 1 fiscal year to another without obtaining approval from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f4715e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award technical assistance grants to 1 or more FQHCs or NMHCs that have demonstrated expertise in establishing a nurse practitioner residency training program. Such technical assistance grants shall be for the purpose of providing technical assistance to other recipients of grants under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5f4715f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s296j–1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there is authorized to be appropriated such sums as may be necessary for each of fiscal years 2011 through 2014.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5f47160-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tV/s5316"},"text":"Pub. L. 111–148, title V, § 5316","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tX/s10501/e"},"text":"Pub. L. 111–148, title X, § 10501(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/995"},"text":"124 Stat. 995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5f47161-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5f47162-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5f47163-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (d)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/119"},"text":"124 Stat. 119","children":[],"tail":", known as the Patient Protection and Affordable Care Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18001"},"text":"section 18001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Public Health Service Act, referred to in subsec. (f)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"act July 1, 1944, ch. 373","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/682"},"text":"58 Stat. 682","children":[],"tail":". Title II of the Act is classified generally to subchapter I (§ 201 et seq.) of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s201"},"text":"section 201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5f47164-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Patient Protection and Affordable Care Act, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5f47165-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 296k and 296","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s123/1"},"text":"Pub. L. 105–392, title I, § 123(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3562"},"text":"112 Stat. 3562","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 296k, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s820"},"text":"act July 1, 1944, ch. 373, title VIII, § 820","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIX/s931/a"},"text":"Pub. L. 94–63, title IX, § 931(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/359"},"text":"89 Stat. 359","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/76/tI/s105"},"text":"Pub. L. 96–76, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/579"},"text":"93 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2753/a/1"},"text":"Pub. L. 97–35, title XXVII, § 2753(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/929"},"text":"95 Stat. 929","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/92/s3"},"text":"Pub. L. 99–92, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/393"},"text":"99 Stat. 393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s227/a"},"text":"Pub. L. 99–129, title II, § 227(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/547"},"text":"99 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVII"},"text":"Pub. L. 100–607, title VII","children":[],"tail":", §§ 701(a)(2), (b)–(i), 721(b)(1), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3153-3156"},"text":"102 Stat. 3153–3156","children":[],"tail":", 3165; "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tII/s202/a"},"text":"Pub. L. 102–408, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2069"},"text":"106 Stat. 2069","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/531/tIII/s313/a/9"},"text":"Pub. L. 102–531, title III, § 313(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3507"},"text":"106 Stat. 3507","children":[],"tail":", authorized grants and contracts for special projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 296","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVIII/s821"},"text":"act July 1, 1944, ch. 373, title VIII, § 821","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/63/tIX/s931/a"},"text":"Pub. L. 94–63, title IX, § 931(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-29"},"text":"July 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/361"},"text":"89 Stat. 361","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/76/tI/s106"},"text":"Pub. L. 96–76, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/579"},"text":"93 Stat. 579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXVII/s2754"},"text":"Pub. L. 97–35, title XXVII, § 2754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/930"},"text":"95 Stat. 930","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/92/s4"},"text":"Pub. L. 99–92, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/394"},"text":"99 Stat. 394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/129/tII/s227/b"},"text":"Pub. L. 99–129, title II, § 227(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-10-22"},"text":"Oct. 22, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/548"},"text":"99 Stat. 548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tVII/s702"},"text":"Pub. L. 100–607, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3157"},"text":"102 Stat. 3157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/408/tII/s203"},"text":"Pub. L. 102–408, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-13"},"text":"Oct. 13, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2072"},"text":"106 Stat. 2072","children":[],"tail":", authorized grants and contracts for advanced nurse education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
