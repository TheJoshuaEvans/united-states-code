{"tag":"section","attrib":{"id":"idbbdbfa3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2021c"},"text":"§ 2021c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities for disposal of low-level radioactive waste","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbdbfa3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbdbfa40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each State shall be responsible for providing, either by itself or in cooperation with other States, for the disposal of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbdbfa41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level radioactive waste generated within the State (other than by the Federal Government) that consists of or contains class A, B, or C radioactive waste as defined by section 61.55 of title 10, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"1983-01-26"},"text":"January 26, 1983","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" low-level radioactive waste described in subparagraph (A) that is generated by the Federal Government except such waste that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbbdbfa43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or generated by the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbdbfa44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or generated by the United States Navy as a result of the decommissioning of vessels of the United States Navy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbbdbfa45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or generated as a result of any research, development, testing, or production of any atomic weapon; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level radioactive waste described in subparagraphs (A) and (B) that is generated outside of the State and accepted for disposal in accordance with sections ","children":[{"tag":"ref","attrib":{"idref":"fn003253"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003253"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 2021e or 2021f of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No regional disposal facility may be required to accept for disposal any material—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbdbfa48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not low-level radioactive waste as defined by section 61.55 of title 10, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"1983-01-26"},"text":"January 26, 1983","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified under the Formerly Utilized Sites Remedial Action Program.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this paragraph shall be deemed to prohibit a State, subject to the provisions of its compact, or a compact region from accepting for disposal any material identified in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbdbfa4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbbdbfa4b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Federal Government shall be responsible for the disposal of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbdbfa4c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level radioactive waste owned or generated by the Department of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa4d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level radioactive waste owned or generated by the United States Navy as a result of the decommissioning of vessels of the United States Navy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa4e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-level radioactive waste owned or generated by the Federal Government as a result of any research, development, testing, or production of any atomic weapon; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa4f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other low-level radioactive waste with concentrations of radionuclides that exceed the limits established by the Commission for class C radioactive waste, as defined by section 61.55 of title 10, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"1983-01-26"},"text":"January 26, 1983","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa50-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All radioactive waste designated a Federal responsibility pursuant to subparagraph (b)(1)(D) that results from activities licensed by the Nuclear Regulatory Commission under the Atomic Energy Act of 1954, as amended, shall be disposed of in a facility licensed by the Nuclear Regulatory Commission that the Commission determines is adequate to protect the public health and safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa51-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1986-01-15"},"text":"January 15, 1986","children":[],"tail":", the Secretary shall submit to the Congress a comprehensive report setting forth the recommendations of the Secretary for ensuring the safe disposal of all radioactive waste designated a Federal responsibility pursuant to subparagraph (b)(1)(D). Such report shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbbdbfa52-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the radioactive waste involved, including the source of such waste, and the volume, concentration, and other relevant characteristics of such waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa53-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the Federal and non-Federal options for disposal of such radioactive waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa54-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions proposed to ensure the safe disposal of such radioactive waste;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa55-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the projected costs of undertaking such actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the options for ensuring that the beneficiaries of the activities resulting in the generation of such radioactive wastes bear all reasonable costs of disposing of such wastes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbbdbfa57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any statutory authority required for disposal of such waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbbdbfa58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2021c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not dispose of any radioactive waste designated a Federal responsibility pursuant to paragraph (b)(1)(D) that becomes a Federal responsibility for the first time pursuant to such paragraph until ninety days after the report prepared pursuant to paragraph (3) has been submitted to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbdbfa59-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s3"},"text":"Pub. L. 96–573, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/tI/s102"},"text":"Pub. L. 99–240, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-15"},"text":"Jan. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1843"},"text":"99 Stat. 1843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbdbfa5a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbdbfa5b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbbdbfa5c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1986-01-15"},"text":"January 15, 1986","children":[],"tail":", referred to in subsec. (b)(3), was in the original “the date of enactment of this Act” and was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/99/240"},"text":"Pub. L. 99–240","children":[],"tail":" to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbbdbfa5d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Low-Level Radioactive Waste Policy Act, and not as part of the Atomic Energy Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbbdbfa5e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2021c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/573/s3"},"text":"Pub. L. 96–573, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3347"},"text":"94 Stat. 3347","children":[],"tail":", related to the applicability of low-level radioactive waste compacts, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/240/s102"},"text":"Pub. L. 99–240, § 102","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2021d"},"text":"section 2021d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
