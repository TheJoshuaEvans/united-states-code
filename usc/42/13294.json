{"tag":"section","attrib":{"id":"idbfb9aaad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13294"},"text":null,"children":[{"tag":"num","attrib":{"value":"13294"},"text":"§ 13294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with existing law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be deemed to convey to any person, partnership, corporation, or other entity, immunity from civil or criminal liability under any antitrust law or to create defenses to actions under any antitrust law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbfb9aaae-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tVI/s624"},"text":"Pub. L. 102–486, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2905"},"text":"106 Stat. 2905","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
