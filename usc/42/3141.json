{"tag":"section","attrib":{"id":"idbc724787-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141"},"text":null,"children":[{"tag":"num","attrib":{"value":"3141"},"text":"§ 3141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for public works and economic development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc724788-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the application of an eligible recipient, the Secretary may make grants for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc724789-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition or development of land and improvements for use for a public works, public service, or development facility or for the improvement of waste management and recycling systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72478a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquisition, design and engineering, construction, rehabilitation, alteration, expansion, increasing the resilience ","children":[{"tag":"ref","attrib":{"idref":"fn003315"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003315"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" or improvement of such a facility, including related machinery and equipment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc72478b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a grant under this section only if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc72478c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project for which the grant is applied for will, directly or indirectly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc72478d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the opportunities, in the area where the project is or will be located, for the successful establishment, expansion, or retention,","children":[{"tag":"ref","attrib":{"idref":"fn003316"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003316"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" of industrial or commercial plants or facilities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc72478e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the creation of additional long-term employment opportunities in the area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc72478f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily benefit the long-term unemployed and underemployed and members of low-income families;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724790-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project for which the grant is applied for will fulfill a pressing need of the area, or a part of the area, in which the project is or will be located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724791-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area for which the project is to be carried out has a comprehensive economic development strategy and the project is consistent with the strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc724792-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under subsection (a) and subject to the criteria in subsection (b), the Secretary may also consider the extent to which a project would—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc724793-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to economic diversification in the area, or a part of the area, in which the project is or will be located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724794-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address and mitigate economic impacts from extreme weather events, including development of resilient infrastructure, products, and processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724795-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit highly rural communities without adequate tax revenues to invest in long-term or costly infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724796-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase access to high-speed broadband;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724797-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support outdoor recreation to spur economic development, with a focus on rural communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724798-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote job creation or retention relative to the population of the impacted region with outsized significance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc724799-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote travel and tourism; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc72479a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote blue economy activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc72479b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3141/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum assistance for each State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 15 percent of the amounts made available to carry out this section may be expended in any 1 State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc72479c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s201"},"text":"Pub. L. 89–136, title II, § 201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/tI/s102/a"},"text":"Pub. L. 105–393, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3601"},"text":"112 Stat. 3601","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2213/a"},"text":"Pub. L. 118–272, div. B, title II, § 2213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3179"},"text":"138 Stat. 3179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc72479d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc72479e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbc72479f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3141, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/136/tII/s201"},"text":"Pub. L. 89–136, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-26"},"text":"Aug. 26, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/554"},"text":"79 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/304/s1/b"},"text":"Pub. L. 91–304, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-06"},"text":"July 6, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/375"},"text":"84 Stat. 375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/65/tI/s104"},"text":"Pub. L. 92–65, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-08-05"},"text":"Aug. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/167"},"text":"85 Stat. 167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/46/s2"},"text":"Pub. L. 93–46, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-06-18"},"text":"June 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/96"},"text":"87 Stat. 96","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/423/s4/a"},"text":"Pub. L. 93–423, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-27"},"text":"Sept. 27, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1158"},"text":"88 Stat. 1158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/487/tI/s107/a"},"text":"Pub. L. 94–487, title I, § 107(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1976-10-12"},"text":"Oct. 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2332"},"text":"90 Stat. 2332","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/506/s1/3"},"text":"Pub. L. 96–506, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-08"},"text":"Dec. 8, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2745"},"text":"94 Stat. 2745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVIII/s1821/a/2"},"text":"Pub. L. 97–35, title XVIII, § 1821(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/766"},"text":"95 Stat. 766","children":[],"tail":", authorized public works and development facility loans, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s102/a"},"text":"Pub. L. 105–393, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc7247a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2213/a/1/A"},"text":"Pub. L. 118–272, § 2213(a)(1)(A)","children":[],"tail":", inserted “or for the improvement of waste management and recycling systems” after “development facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2213/a/1/B"},"text":"Pub. L. 118–272, § 2213(a)(1)(B)","children":[],"tail":", inserted “increasing the resilience” after “expansion,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2213/a/2/A"},"text":"Pub. L. 118–272, § 2213(a)(2)(A)","children":[],"tail":", substituted “successful establishment, expansion, or retention,” for “successful establishment or expansion”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2213/a/2/B"},"text":"Pub. L. 118–272, § 2213(a)(2)(B)","children":[],"tail":", inserted “and underemployed” after “unemployed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2213/a/3"},"text":"Pub. L. 118–272, § 2213(a)(3)","children":[],"tail":", (4), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc7247a1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbc7247a2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1999-02-11"},"text":"Feb. 11, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/393/s105"},"text":"section 105 of Pub. L. 105–393","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3121"},"text":"section 3121 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
