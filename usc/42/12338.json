{"tag":"section","attrib":{"id":"idbf6aee8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338"},"text":null,"children":[{"tag":"num","attrib":{"value":"12338"},"text":"§ 12338.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supportive services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf6aee8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall carry out a program for making grants to a State, that has designated an independent State body under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12336"},"text":"section 12336 of this title","children":[],"tail":" and provided for coordinated services under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12337"},"text":"section 12337 of this title","children":[],"tail":", for distribution by the chief executive officer under a State plan approved under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12337"},"text":"section 12337 of this title","children":[],"tail":" to demonstrate successful program approaches to fill service gaps identified through State planning and advocacy efforts for any of the areas specified in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf6aee8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services eligible to be provided under subsection (a) are services—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf6aee8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are designed to facilitate the provision of comprehensive community based services that are efficient, coordinated, and readily available through such activities as case planning, case management, intake and assessment, and information and referral; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf6aee8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that serve any of the following purposes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf6aee8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide adequate and safe physical shelter to young individuals and the families of such individuals, especially in emergency circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide transitional living services to young individuals who are homeless;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable young individuals to attain and maintain physical and mental well-being;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide health screening to detect or prevent illnesses, or both, that occur most frequently in young individuals as well as better treatment and counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the development of children to ensure that such children enter school prepared and ready to learn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the highest quality of educational opportunity, especially through drop-out prevention programs, remediation for young individuals who have dropped out of school, and vocational education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide effective training apprenticeships and employment opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote participation in community service and civic, cultural, and recreational activities that value young individuals as resources and promote self-esteem and a stake in the community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the participation of young individuals in decisions concerning planning and managing the lives of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage young individuals and the families of such individuals to use any community facilities and services that are available to such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that young individuals who are unable to live with the biological families of such individuals have a safe place to live until such individuals can return home or move into independent adult life; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf6aee9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12338/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent the abuse, neglect, or exploitation of young individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf6aee9b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/501/tIX/s932"},"text":"Pub. L. 101–501, title IX, § 932","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-03"},"text":"Nov. 3, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1273"},"text":"104 Stat. 1273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf6aee9c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf6aee9d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf6aee9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"Oct. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/501/s1001/a"},"text":"section 1001(a) of Pub. L. 101–501","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8621"},"text":"section 8621 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
