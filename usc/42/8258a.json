{"tag":"section","attrib":{"id":"idbe885603-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8258a"},"text":"§ 8258a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration of new technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe885604-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", the Secretary, in cooperation with the Administrator of General Services, shall establish a demonstration program to install, in federally owned facilities or federally assisted housing, energy conservation measures for which the Secretary has determined that such installation would accelerate commercial viability. In those cases where technologies are determined to be equivalent, priority shall be given to those technologies that have received or are receiving Federal financial assistance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe885605-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the determination under subsection (a), the Secretary shall select, in cooperation with the Administrator of General Services, proposals to be funded under this section on the basis of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe885606-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885607-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical feasibility and system reliability in a working environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885608-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lack of market penetration in the Federal sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885609-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential needs of the proposing Federal agency for the technology, projected over 5 to 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe88560a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential Federal sector market, projected over 5 to 10 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe88560b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe88560c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other environmental benefits, including the projected reduction of greenhouse gas emissions and indoor air pollution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe88560d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Federal agencies may submit to the Secretary, for each fiscal year, proposals for projects to be funded by the Secretary under this section. Each such proposal shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe88560e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the proposed project emphasizing the innovative use of technology in the Federal sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe88560f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the technical reliability and cost-effectiveness data expected to be acquired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885610-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the potential needs of the Federal agency for the technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885611-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commitment to adopt the technology, if the project establishes its technical reliability and life cycle cost-effectiveness, to supply at least 10 percent of the Federal agency’s potential needs identified under paragraph (3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885612-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schedules and milestones for installing additional units; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe885613-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a technology transfer plan to publicize the results of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe885614-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation by GSA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only select a project for funding under this section which is proposed to be carried out in a building under the jurisdiction of the General Services Administration if the project will be carried out by the Administrator of General Services. If such project involves a total expenditure in excess of $1,600,000, no appropriation shall be made for such project unless such project has been approved by a resolution adopted by the Committee on Public Works and Transportation of the House of Representatives and the Committee on Environment and Public Works of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe885615-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a study to evaluate the potential use of the purchasing power of the Federal Government to promote the development and commercialization of energy efficient products. The study shall identify products for which there is a high potential for Federal purchasing power to substantially promote their development and commercialization, and shall include a plan to develop such potential. The study shall be conducted in consultation with utilities, manufacturers, and appropriate nonprofit organizations concerned with energy efficiency. The Secretary shall report to the Congress on the results of the study not later than two years after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe885616-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s8258a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section $5,000,000 for each of the fiscal years 1993, 1994, and 1995.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe885617-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/tV/s549"},"text":"Pub. L. 95–619, title V, § 549","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tI/s152/h/2"},"text":"Pub. L. 102–486, title I, § 152(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2848"},"text":"106 Stat. 2848","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe885618-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe885619-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe88561a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/619/s549"},"text":"section 549 of Pub. L. 95–619","children":[],"tail":" was renumbered section 551 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s8259"},"text":"section 8259 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe88561b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbe88561c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Public Works and Transportation of House of Representatives treated as referring to Committee on Transportation and Infrastructure of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
