{"tag":"section","attrib":{"id":"idbf879e31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643"},"text":null,"children":[{"tag":"num","attrib":{"value":"12643"},"text":"§ 12643.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of access, examination, and copying","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf879e32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with otherwise applicable law, the Comptroller General, or any of the duly authorized representatives of the Comptroller General, shall have access to, and the right to examine and copy, any books, documents, papers, records, and other recorded information in any form—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the possession or control of the Corporation or any State or local government, territory, Indian tribe, or public or private nonprofit organization receiving assistance directly or indirectly under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Comptroller General, or his representative, considers necessary to the performance of an evaluation, audit, or review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Financial Officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with otherwise applicable law, the Chief Financial Officer of the Corporation shall have access to, and the right to examine and copy, any books, documents, papers, records, and other recorded information in any form—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the possession or control of the Corporation or any State or local government, territory ","children":[{"tag":"ref","attrib":{"idref":"fn004076"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004076"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" Indian tribe, or public or private nonprofit organization receiving assistance directly or indirectly under this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that relates to the duties of the Chief Financial Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf879e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with otherwise applicable law, the Inspector General of the Corporation shall have access to, and the right to examine and copy, any books, documents, papers, records, and other recorded information in any form—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf879e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the possession or control of the Corporation or any State or local government, territory, Indian tribe, or public or private nonprofit organization receiving assistance directly or indirectly under the national service laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf879e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that relates to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf879e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf879e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12643/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duties of the Inspector General under chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf879e3d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s183"},"text":"Pub. L. 101–61