{"tag":"section","attrib":{"id":"idbc0e2e1a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2233"},"text":null,"children":[{"tag":"num","attrib":{"value":"2233"},"text":"§ 2233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of licenses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each license shall be in such form and contain such terms and conditions as the Commission may, by rule or regulation, prescribe to effectuate the provisions of this chapter, including the following provisions:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbc0e2e1b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/489/s18"},"text":"Pub. L. 88–489, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-26"},"text":"Aug. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/607"},"text":"78 Stat. 607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0e2e1c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No right to the special nuclear material shall be conferred by the license except as defined by the license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0e2e1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Neither the license nor any right under the license shall be assigned or otherwise transferred in violation of the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbc0e2e1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2233/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Every license issued under this chapter shall be subject to the right of recapture or control reserved by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2138"},"text":"section 2138 of this title","children":[],"tail":", and to all of the other provisions of this chapter, now or hereafter in effect and to all valid rules and regulations of the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc0e2e1f-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 183, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/954"},"text":"68 Stat. 954","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/88/489/s18"},"text":"Pub. L. 88–489, § 18","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-26"},"text":"Aug. 26, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/607"},"text":"78 Stat. 607","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc0e2e20-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc0e2e21-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbc0e2e22-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", known as the Atomic Energy Act of 1954, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc0e2e23-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1964—Par. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/489"},"text":"Pub. L. 88–489","children":[],"tail":" struck out par. (a) which placed title to all special nuclear material utilized or produced by facilities pursuant to license in the United States at all times."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
