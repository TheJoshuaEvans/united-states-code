{"tag":"section","attrib":{"id":"idbb39eee3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1592"},"text":null,"children":[{"tag":"num","attrib":{"value":"1592"},"text":"§ 1592.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to the provisions and limitations of this subchapter and subchapter VIII of this chapter, the Secretary of Housing and Urban Development (hereinafter referred to as the “Secretary”) is authorized to provide housing in any areas (subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1591"},"text":"section 1591 of this title","children":[],"tail":") needed for defense workers or military personnel or to extend assistance for the provision of, or to provide, community facilities or services required in connection with national defense activities in any area which the President, pursuant to the authority contained in said section, has determined to be a critical defense housing area."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbb39eee4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-09-01/ch378"},"text":"Sept. 1, 1951, ch. 378","children":[],"tail":", title III, § 301, "},{"tag":"ref","attrib":{"href":"/us/stat/65/303"},"text":"65 Stat. 303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s5/a"},"text":"Pub. L. 89–174, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/669"},"text":"79 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb39eee5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb39eee6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbb39eee7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions to Secretary of Housing and Urban Development, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1581"},"text":"section 1581 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
