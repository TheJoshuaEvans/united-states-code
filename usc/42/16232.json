{"tag":"section","attrib":{"id":"idbffa0f20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232"},"text":null,"children":[{"tag":"num","attrib":{"value":"16232"},"text":"§ 16232.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbffa0f21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biomass","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “biomass” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0f23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organic material grown for the purpose of being converted to energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organic byproduct of agriculture (including wastes from food production and processing) that can be converted into energy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any waste material that can be converted to energy, is segregated from other waste materials, and is derived from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0f26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the following forest-related resources: mill residues, precommercial thinnings, slash, brush, or otherwise nonmerchantable material; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wood waste materials, including waste pallets, crates, dunnage, manufacturing and construction wood wastes (other than pressure-treated, chemically-treated, or painted wood wastes), and landscape or right-of-way tree trimmings, but not including municipal solid waste, gas derived from the biodegradation of municipal solid waste, or paper that is commonly recycled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lignocellulosic feedstock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lignocellulosic feedstock” means any portion of a plant or coproduct from conversion, including crops, trees, forest residues, and agricultural residues not specifically grown for food, including from barley grain, grapeseed, rice bran, rice hulls, rice straw, soybean matter, and sugarcane bagasse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a program of research, development, demonstration, and commercial application for bioenergy, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biopower energy systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biofuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bioproducts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated biorefineries that may produce biopower, biofuels, and bioproducts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-cutting research and development in feedstocks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biofuels and bioproducts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the biofuels and bioproducts programs shall be to develop, in partnership with industry and institutions of higher education—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced biochemical and thermochemical conversion technologies capable of making fuels from lignocellulosic feedstocks that are price-competitive with gasoline or diesel in either internal combustion engines or fuel cell-powered vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced biotechnology processes capable of making biofuels and bioproducts with emphasis on development of biorefinery technologies using enzyme-based processing systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advanced biotechnology processes capable of increasing energy production from lignocellulosic feedstocks, with emphasis on reducing the dependence of industry on fossil fuels in manufacturing facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other advanced processes that will enable the development of cost-effective bioproducts, including biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated biorefinery demonstration projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a program to demonstrate the commercial application of integrated biorefineries. The Secretary shall ensure geographical distribution of biorefinery demonstrations under this subsection. The Secretary shall not provide more than $100,000,000 under this subsection for any single biorefinery demonstration. In making awards under this subsection, the Secretary shall encourage—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0f37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstration of a wide variety of lignocellulosic feedstocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the commercial application of biomass technologies for a variety of uses, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbffa0f39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liquid transportation fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-value biobased chemicals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substitutes for petroleum-based feedstocks and products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbffa0f3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy in the form of electricity or useful heat; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstration of the collection and treatment of a variety of biomass feedstocks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2005-08-08"},"text":"August 8, 2005","children":[],"tail":", the Secretary shall solicit proposals for demonstration of advanced biorefineries. The Secretary shall select only proposals that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbffa0f3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the project will be able to operate profitably without direct Federal subsidy after initial construction costs are paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbffa0f40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the biorefinery to be easily replicated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University biodiesel program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a demonstration program to determine the feasibility of the operation of diesel electric power generators, using biodiesel fuels with ratings as high as B100, at electric generation facilities owned by institutions of higher education. The program shall examine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbffa0f42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heat rates of diesel fuels with large quantities of cellulosic content;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reliability of operation of various fuel blends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance in cold or freezing weather;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stability of fuel after extended storage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbffa0f46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other criteria, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn004215"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004215"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (f) has been enacted."}],"tail":" Biorefinery energy efficiency"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program of research, development, demonstration, and commercial application for increasing energy efficiency and reducing energy consumption in the operation of biorefinery facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbffa0f48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16232/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retrofit technologies for the development of ethanol from cellulosic materials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program of research, development, demonstration, and commercial application on technologies and processes to enable biorefineries that exclusively use corn grain or corn starch as a feedstock to produce ethanol to be retrofitted to accept a range of biomass, including lignocellulosic feedstocks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbffa0f49-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tIX/s932"},"text":"Pub. L. 109–58, title IX, § 932","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/870"},"text":"119 Stat. 870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tII/s224"},"text":"Pub. L. 110–140, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1533"},"text":"121 Stat. 1533","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbffa0f4a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbffa0f4b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbffa0f4c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" added subsecs. (g) and (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbffa0f4d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbffa0f4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
