{"tag":"section","attrib":{"id":"idb6943474-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ff–20"},"text":"§ 300ff–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6943475-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of carrying out this part, there are authorized to be appropriated $604,000,000 for fiscal year 2007, $626,300,000 for fiscal year 2008, $649,500,000 for fiscal year 2009, $681,975,000 for fiscal year 2010, $716,074,000 for fiscal year 2011, $751,877,000 for fiscal year 2012, and $789,471,000 for fiscal year 2013. Amounts appropriated under the preceding sentence for a fiscal year are available for obligation by the Secretary until the end of the second succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6943476-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6943477-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2007","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under subsection (a) for fiscal year 2007, the Secretary shall reserve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6943478-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $458,310,000 for grants under subpart I; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6943479-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $145,690,000 for grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–19"},"text":"section 300ff–19 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb694347a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent fiscal years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount appropriated under subsection (a) for fiscal year 2008 and each subsequent fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb694347b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall reserve an amount for grants under subpart I; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb694347c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall reserve an amount for grants under "