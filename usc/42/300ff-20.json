2/s300ff–20/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb694348b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb694348c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to clause (ii), an amount equal to the amount of the reduction under subparagraph (A) for such year is, notwithstanding subsection (a), transferred and made available for grants pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/a/1"},"text":"section 300ff–28(a)(1) of this title","children":[],"tail":", in addition to amounts available for such grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31b"},"text":"section 300ff–31b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb694348d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each of fiscal years 2010 through 2013, notwithstanding subsection (a)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb694348e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there shall be transferred to the State containing the metropolitan area, for purposes described in ","childre