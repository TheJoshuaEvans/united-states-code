ldren":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/a/1"},"text":"section 300ff–28(a)(1) of this title","children":[],"tail":" for the fiscal year, in addition to amounts available for such grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31b"},"text":"section 300ff–31b of this title","children":[],"tail":", an amount equal to the total amount of the reduction for such fiscal year under subparagraph (A), less the amount transferred for such fiscal year under subclause (I)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6943493-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a metropolitan area is a transitional area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–19"},"text":"section 300ff–19 of this title","children":[],"tail":" for a fiscal year, but for a subsequent fiscal year qualifies as an eligible area under subpart I—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6943494-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount reserved under subsection (b)(2)(B) of this section for the first such subsequent fiscal year of becoming an eligible area is deemed to be reduced by an amount equal to the amount of the grant that, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–13/a"},"text":"section 300ff–13(a) of this title","children":[],"tail":", was made under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–19/d/2/A"},"text":"section 300ff–19(d)(2)(A) of this title","children":[],"tail":" for the metropolitan area for the preceding fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6943495-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount reserved under subsection (b)(2)(A) for such fiscal year is deemed to be increased by an amount equal to the amount of the reduction under subparagraph (A) for such year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6943496-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers; allocations between programs under subpart I","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to paragraphs (1)(B)(i) and (2)(A)(ii) of subsection (c), the Secretary shall administer any reductions under such paragraphs for a fiscal year in accordance with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6943497-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reductions shall be made from amounts available for the single program referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–19/d/2/C"},"text":"section 300ff–19(d)(2)(C) of this title","children":[],"tail":" (relating to supplemental grants)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6943498-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reductions shall be made before the amounts referred to in paragraph (1) are used for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–13/a/4"},"text":"section 300ff–13(a)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6943499-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the amounts referred to in paragraph (1) are not sufficient for making all the reductions, the reductions shall be reduced until the total amount of the reductions equals the total of the amounts referred to in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb694349a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction regarding first subsequent fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) of subsection (c) apply with respect to each series of fiscal years during which a metropolitan area is an eligible area under subpart I or a transitional area under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–19"},"text":"section 300ff–19 of this title","children":[],"tail":" for a fiscal year and then for a subsequent fiscal year ceases to be such an area by reason of section 300ff–11(b) or 300ff–19(c)(2) of this title, respectively, rather than applying to a single such series. Paragraph (3) of subsection (c) applies with respect to each series of fiscal years during which a metropolitan area is a transitional area under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–19"},"text":"section 300ff–19 of this title","children":[],"tail":" for a fiscal year and then for a subsequent fiscal year becomes an eligible area under subpart I, rather than applying to a single such series."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb694349b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVI, § 2610, as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/tI/s108"},"text":"Pub. L. 109–415, title I, § 108","children":[],"tail":", title VII, § 703, "},{"tag":"date","attrib":{"date":"2006-12-19"},"text":"Dec. 19, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2783"},"text":"120 Stat. 2783","children":[],"tail":", 2820; "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", §§ 2(a)(1), (3)(A), (b), 4(b), "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2885"},"text":"123 Stat. 2885","children":[],"tail":", 2889.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb694349c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb694349d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb694349e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", (3)(A), repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", and revived the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":". See 2006 Amendment note and Effective Date of 2009 Amendment; Revival of Section note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/b"},"text":"Pub. L. 111–87, § 2(b)","children":[],"tail":", substituted “$649,500,000 for fiscal year 2009, $681,975,000 for fiscal year 2010, $716,074,000 for fiscal year 2011, $751,877,000 for fiscal year 2012, and $789,471,000 for fiscal year 2013” for “and $649,500,000 for fiscal year 2009”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s4/b"},"text":"Pub. L. 111–87, § 4(b)","children":[],"tail":", designated existing provisions as cl. (i), inserted “subject to clause (ii),” before “an amount equal to the amount”, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"Pub. L. 109–415, § 703","children":[],"tail":", which directed repeal of this section effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", was itself repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"Pub. L. 111–87, § 2(a)(1)","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb694349f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb69434a0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment; Revival of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions that repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/87/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 111–87","children":[],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/pl/109/415/s703"},"text":"section 703 of Pub. L. 109–415","children":[],"tail":" be effective "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", that the provisions of this section as in effect on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", be revived, and that amendment by sections 2(b) and 4(b) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":" be applicable to this section as so revived and effective as if enacted on "},{"tag":"date","attrib":{"date":"2009-09-30"},"text":"Sept. 30, 2009","children":[],"tail":", see section 2(a)(2), (3) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/87"},"text":"Pub. L. 111–87","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–11"},"text":"section 300ff–11 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
