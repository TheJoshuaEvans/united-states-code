a"},"text":"section 300ff–13(a) of this title","children":[],"tail":" for the metropolitan area for the preceding fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6943481-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb6943482-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the metropolitan area qualifies for such first subsequent fiscal year as a transitional area under 300ff–19 ","children":[{"tag":"ref","attrib":{"idref":"fn002426"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002426"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title, the amount reserved under paragraph (1)(B) or (2)(B) of subsection (b) for such fiscal year is deemed to be increased by an amount equal to the amount of the reduction under subparagraph (A) for such year; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb6943483-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the metropolitan area does not qualify for such first subsequent fiscal year as a transitional area under 300ff–19 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, an amount equal to the amount of such reduction is, notwithstanding subsection (a), transferred and made available for grants pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/a/1"},"text":"section 300ff–28(a)(1) of this title","children":[],"tail":", in addition to amounts available for such grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31b"},"text":"section 300ff–31b of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6943484-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if a transfer under subparagraph (A)(ii)(II) is made with respect to the metropolitan area for such first subsequent fiscal year, then—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6943485-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount reserved under paragraph (1)(A) or (2)(A) of subsection (b) of this section for such year is deemed to be reduced by an additional $500,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6943486-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ff–20/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amount of such additional reduction is, notwithstanding subsection (a), transferred and made available for grants pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–28/a/1"},"text":"section 300ff–28(a)(1) of this title","children":[],"tail":", in addition to amounts available for such grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300ff–31b"},"text":"section 300ff–31b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"i