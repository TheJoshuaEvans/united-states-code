{"tag":"section","attrib":{"id":"idc062e32d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b"},"text":null,"children":[{"tag":"num","attrib":{"value":"18715b"},"text":"§ 18715b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interregional and offshore wind electricity transmission planning, modeling, and analysis","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc062e32e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available, there is appropriated to the Secretary for fiscal year 2022, out of any money in the Treasury not otherwise appropriated, $100,000,000, to remain available through ","children":[{"tag":"date","attrib":{"date":"2031-09-30"},"text":"September 30, 2031","children":[],"tail":", to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc062e32f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts made available under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc062e330-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay expenses associated with convening relevant stakeholders to address the development of interregional electricity transmission and transmission of electricity that is generated by offshore wind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc062e331-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to conduct planning, modeling, and analysis regarding interregional electricity transmission and transmission of electricity that is generated by offshore wind, taking into account the local, regional, and national economic, reliability, resilience, security, public policy, and environmental benefits of interregional electricity transmission and transmission of electricity that is generated by offshore wind, including planning, modeling, and analysis, as the Secretary determines appropriate, pertaining to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc062e332-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clean energy integration into the electric grid, including the identification of renewable energy zones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e333-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of changes in weather due to climate change on the reliability and resilience of the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e334-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost allocation methodologies that facilitate the expansion of the bulk power system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e335-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of coordination between generator interconnection processes and transmission planning processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e336-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of increased electrification on the electric grid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e337-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" power flow modeling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e338-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits of increased interconnections or interties between or among the Western Interconnection, the Eastern Interconnection, the Electric Reliability Council of Texas, and other interconnections, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e339-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cooptimization of transmission and generation, including variable energy resources, energy storage, and demand-side management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e33a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunities for use of nontransmission alternatives, energy storage, and grid-enhancing technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e33b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic development opportunities for communities arising from development of interregional electricity transmission and transmission of electricity that is generated by offshore wind;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e33c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of existing rights-of-way and the need for additional transmission corridors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc062e33d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18715b/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a planned national transmission grid, which would include a networked transmission system to optimize the existing grid for interconnection of offshore wind farms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc062e33e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/tV/s50153"},"text":"Pub. L. 117–169, title V, § 50153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2048"},"text":"136 Stat. 2048","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc062e33f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc062e340-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idc062e341-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":", and not as part of div. D of "},{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which enacted this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc062e342-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idc062e343-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Energy, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169/s50111"},"text":"section 50111 of Pub. L. 117–169","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17113b"},"text":"section 17113b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
