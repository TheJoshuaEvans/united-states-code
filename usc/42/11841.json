{"tag":"section","attrib":{"id":"idbf57db9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841"},"text":null,"children":[{"tag":"num","attrib":{"value":"11841"},"text":"§ 11841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community youth activity program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf57db9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Block grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services shall make grants to eligible States to enable such States to carry out the activities described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57db9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57db9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under this section, a State, acting on its own behalf or on behalf of a person, shall submit to the Secretary an application that contains such information and is in such form as may be required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dba0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration of need","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the application submitted under paragraph (1), the State shall demonstrate a need for the activities described in subsection (e) and provide a description of those activities and projects that will receive financial assistance from a grant made under this section to the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dba1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57dba2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State that submits for a fiscal year an application under subsection (b) that meets the requirements of the Secretary shall, subject to the availability of appropriations, receive a grant in an amount determined in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dba3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs of national significance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts appropriated or otherwise available to carry out this section for any fiscal year, the Secretary shall reserve 5 percent to be provided for activities and projects of national significance or projects expected to have a significant impact in preventing the abuse of drugs by youth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dba4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf57dba5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the aggregate amount appropriated under subsection (g) for any fiscal year and after reserving the amount required by paragraph (2), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf57dba6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allot—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbf57dba7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent equally among the eligible States if such amount is less than $40,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbf57dba8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $250,000 to each eligible State if such amount equals or exceeds $40,000,000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf57dba9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allot one-half of 1 percent of such amount on the basis of need among Guam, American Samoa, the Virgin Islands of the United States, the Commonwealth of the Northern Mariana Islands, and the Trust Territory of the Pacific Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf57dbaa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set aside the remainder to be disbursed as described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this subparagraph, the term “State” does not include Guam, American Samoa, the Virgin Islands of the United States, the Commonwealth of the Northern Mariana Islands, and the Trust Territory of the Pacific Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remainder","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts referred to in subparagraph (A)(iii) shall be used by the Secretary to make grants, on a competitive basis and taking into consideration with respect to the States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf57dbac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest proportions of school-aged youth are ","children":[{"tag":"ref","attrib":{"idref":"fn004016"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004016"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “who are”."}],"tail":" at risk of drug abuse;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf57dbad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a tangible need has been identified by the State involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf57dbae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the State involved has proposed the funding of additional projects targeted at the areas of highest need;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to carry out the activities and projects that are consistent with the activities described in subsection (e)(1). The activities and projects for which such grants are made shall be selected by the Secretary from among proposed activities and projects submitted to the Secretary by the States. Such grants shall be made to the States for redistribution to the persons on whose behalf the State submitted an application under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbaf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary shall give priority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57dbb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects aimed at youth who are not in school or who are at risk of dropping out of school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that seek to reinvolve dropouts in educational programs, involve youth community-based activities, develop training or employment opportunities for dropouts, or provide youth with alternatives to drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects to provide after-school, vacation, and weekend activities designed to give youth opportunities to actively participate in a variety of activities, including youth sports programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities and projects that are consistent with activities and projects described in subsection (e)(1) and that include participation by the business community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that provide outreach to individuals of all ages who are at high risk of involvement with drug abuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects targeted to communities with the most serious drug abuse problems to enable such communities to develop programs that coordinate Federal, State, and local efforts to develop comprehensive, long-term, community-wide prevention and education strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" projects that seek to involve youth who are members of gangs or who may join a gang, in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf57dbb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training or employment opportunities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other alternatives to gang involvement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" programs for unsupervised children before and after school, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf57dbbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education and instruction consistent with part A of title IV of the Elementary and Secondary Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7101"},"text":"20 U.S.C. 7101","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" athletic activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creative activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other programs designed to reduce the risk of drug abuse; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that seek to inform youth regarding the existence and operation of the projects referred to in paragraph (7).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities and projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance may be provided with a grant received under subsection (a) ","children":[{"tag":"ref","attrib":{"idref":"fn004017"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004017"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Words “under subsection (a)” probably should not appear."}],"tail":" under this section by a State as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf57dbc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community services and partnerships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such assistance may be provided for community services and partnerships designed to develop community activities targeted at drug abuse prevention through education, training, and recreation projects. Such services may be provided by, and such partnerships may be entered into with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf57dbc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local educational agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community-based organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community action agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local or State recreational departments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf57dbc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business organizations; and","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in consultation with local and State health departments and with community health or mental health centers when appropriate. Such assistance may be provided to any entity described in subparagraphs (A) through (F), either individually or in partnerships. Applications for such assistance shall include a description of the method to be used to evaluate the impact the particular service or partnership is designed to have on the drug abuse problem within the community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf57dbc9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other activities and projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such assistance may be provided to carry out projects or activities that are consistent with the activities and projects described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbca-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the evaluation of activities and projects conducted with financial assistance received under this section. Applications for grants under this section shall include a description of the method to be used in evaluating the impact such activities and programs have on the drug abuse problem within the communities in which such activities and projects are carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf57dbcb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11841/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $40,000,000 for fiscal year 1989, $55,000,000 for fiscal year 1990, $60,000,000 for fiscal year 1991, $66,550,000 for fiscal year 1992, and $73,205,000 for fiscal year 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf57dbcc-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIII/s3521"},"text":"Pub. L. 100–690, title III, § 3521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4258"},"text":"102 Stat. 4258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/93/s4/1"},"text":"Pub. L. 101–93, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-16"},"text":"Aug. 16, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/611"},"text":"103 Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/226/s23"},"text":"Pub. L. 101–226, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1941"},"text":"103 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/382/tIII/s394/b"},"text":"Pub. L. 103–382, title III, § 394(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-20"},"text":"Oct. 20, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4027"},"text":"108 Stat. 4027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s202/d"},"text":"Pub. L. 105–285, title II, § 202(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2755"},"text":"112 Stat. 2755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/tIX/s9215/k"},"text":"Pub. L. 114–95, title IX, § 9215(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2168"},"text":"129 Stat. 2168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf57dbcd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf57dbce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf57dbcf-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Elementary and Secondary Education Act of 1965, referred to in subsec. (d)(8)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/10"},"text":"Pub. L. 89–10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-04-11"},"text":"Apr. 11, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/27"},"text":"79 Stat. 27","children":[],"tail":". Part A of title IV of the Act is classified generally to part A (§ 7101 et seq.) of subchapter IV of chapter 70 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf57dbd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(8)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" substituted “education and instruction consistent with part A of title IV of the Elementary and Secondary Education Act of 1965” for “education and instruction consistent with title IV of the Elementary and Secondary Education Act of 1965”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/285"},"text":"Pub. L. 105–285","children":[],"tail":" struck out “, such as activities authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910/a/2/F"},"text":"section 9910(a)(2)(F) of this title","children":[],"tail":",” after “national significance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(8)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Pub. L. 103–382","children":[],"tail":" substituted “title IV of the Elementary and Secondary Education Act of 1965” for “the Drug-Free Schools and Communities Act of 1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93/s4/1/A"},"text":"Pub. L. 101–93, § 4(1)(A)","children":[],"tail":", substituted “subsection (e)” for “subsections (c)(3)(B) and (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/93/s4/1/B"},"text":"Pub. L. 101–93, § 4(1)(B)","children":[],"tail":", substituted “subsection (g)” for “subsection (h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/226"},"text":"Pub. L. 101–226","children":[],"tail":", which directed amendment of section 3521(d) of the National Narcotics Leadership Act of 1988 by adding par. (8) and redesignating former par. (8) as (9), was executed to "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s3521/d"},"text":"section 3521(d) of Pub. L. 100–690","children":[],"tail":", the Anti-Drug Abuse Act of 1988, as the probable intent of Congress. Subtitle A (§§ 1001–1012) of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" is the National Narcotics Leadership Act of 1988."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf57dbd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf57dbd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/95"},"text":"Pub. L. 114–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-12-10"},"text":"Dec. 10, 2015","children":[],"tail":", except with respect to certain noncompetitive programs and competitive programs, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/95/s5"},"text":"section 5 of Pub. L. 114–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s6301"},"text":"section 6301 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbf57dbd3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbf57dbd4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
