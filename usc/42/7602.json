{"tag":"section","attrib":{"id":"idbe564935-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602"},"text":null,"children":[{"tag":"num","attrib":{"value":"7602"},"text":"§ 7602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe564936-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Administrator” means the Administrator of the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564937-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “air pollution control agency” means any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe564938-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A single State agency designated by the Governor of that State as the official State air pollution control agency for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe564939-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency established by two or more States and having substantial powers or duties pertaining to the prevention and control of air pollution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe56493a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A city, county, or other local government health authority, or, in the case of any city, county, or other local government in which there is an agency other than the health authority charged with responsibility for enforcing ordinances or laws relating to the prevention and control of air pollution, such other agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe56493b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency of two or more municipalities located in the same State or in different States and having substantial powers or duties pertaining to the prevention and control of air pollution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe56493c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56493d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “interstate air pollution control agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe56493e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air pollution control agency established by two or more States, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe56493f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air pollution control agency of two or more municipalities located in different States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564940-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, and American Samoa and includes the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes an individual, corporation, partnership, association, State, municipality, political subdivision of a State, and any agency, department, or instrumentality of the United States and any officer, agent, or employee thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “municipality” means a city, town, borough, county, parish, district, or other public body created by or pursuant to State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “air pollutant” means any air pollution agent or combination of such agents, including any physical, chemical, biological, radioactive (including source material, special nuclear material, and byproduct material) substance or matter which is emitted into or otherwise enters the ambient air. Such term includes any precursors to the formation of any air pollutant, to the extent the Administrator has identified such precursor or precursors for the particular purpose for which the term “air pollutant” is used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All language referring to effects on welfare includes, but is not limited to, effects on soils, water, crops, vegetation, manmade materials, animals, wildlife, weather, visibility, and climate, damage to and deterioration of property, and hazards to transportation, as well as effects on economic values and on personal comfort and well-being, whether caused by transformation, conversion, or combination with other air pollutants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal land manager” means, with respect to any lands in the United States, the Secretary of the department with authority over such lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise expressly provided, the terms “major stationary source” and “major emitting facility” mean any stationary facility or source of air pollutants which directly emits, or has the potential to emit, one hundred tons per year or more of any air pollutant (including any major emitting facility or source of fugitive emissions of any such pollutant, as determined by rule by the Administrator).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “emission limitation” and “emission standard” mean a requirement established by the State or the Administrator which limits the quantity, rate, or concentration of emissions of air pollutants on a continuous basis, including any requirement relating to the operation or maintenance of a source to assure continuous emission reduction, and any design, equipment, work practice or operational standard promulgated under this chapter..","children":[{"tag":"ref","attrib":{"idref":"fn003699"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003699"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “standard of performance” means a requirement of continuous emission reduction, including any requirement relating to the operation or maintenance of a source to assure continuous emission reduction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “means of emission limitation” means a system of continuous emission reduction (including the use of specific technology or fuels with specified pollution characteristics).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56494a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “primary standard attainment date” means the date specified in the applicable implementation plan for the attainment of a national primary ambient air quality standard for any air pollutant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56494b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “delayed compliance order” means an order issued by the State or by the Administrator to an existing stationary source, postponing the date required under an applicable implementation plan for compliance by such source with any requirement of such plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56494c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “schedule and timetable of compliance” means a schedule of required measures including an enforceable sequence of actions or operations leading to compliance with an emission limitation, other limitation, prohibition, or standard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56494d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/q"},"text":null,"children":[{"tag":"num","attrib":{"value":"q"},"text":"(q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this chapter, the term “applicable implementation plan” means the portion (or portions) of the implementation plan, or most recent revision thereof, which has been approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410"},"text":"section 7410 of this title","children":[],"tail":", or promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7410/c"},"text":"section 7410(c) of this title","children":[],"tail":", or promulgated or approved pursuant to regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7601/d"},"text":"section 7601(d) of this title","children":[],"tail":" and which implements the relevant requirements of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56494e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/r"},"text":null,"children":[{"tag":"num","attrib":{"value":"r"},"text":"(r)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian Tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian tribe” means any Indian tribe, band, nation, or other organized group or community, including any Alaska Native village, which is Federally recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe56494f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/s"},"text":null,"children":[{"tag":"num","attrib":{"value":"s"},"text":"(s)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" VOC.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"The term “VOC” means volatile organic compound, as defined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/t"},"text":null,"children":[{"tag":"num","attrib":{"value":"t"},"text":"(t)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PM–10.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"The term “PM–10” means particulate matter with an aerodynamic diameter less than or equal to a nominal ten micrometers, as measured by such method as the Administrator may determine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/u"},"text":null,"children":[{"tag":"num","attrib":{"value":"u"},"text":"(u)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NAAQS ","children":[{"tag":"inline","attrib":{},"text":"and","children":[],"tail":" CTG.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “NAAQS” means national ambient air quality standard. The term “CTG” means a Control Technique Guideline published by the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7408"},"text":"section 7408 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564952-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NO","children":[{"tag":"sub","attrib":{},"text":"x","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “NO","children":[{"tag":"sub","attrib":{},"text":"x","children":[],"tail":"” means oxides of nitrogen."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564953-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/w"},"text":null,"children":[{"tag":"num","attrib":{"value":"w"},"text":"(w)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CO.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"The term “CO” means carbon monoxide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564954-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small Source","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “small source” means a source that emits less than 100 tons of regulated pollutants per year, or any class of persons that the Administrator determines, through regulation, generally lack technical ability or knowledge regarding control of air pollution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564955-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/y"},"text":null,"children":[{"tag":"num","attrib":{"value":"y"},"text":"(y)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Implementation Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal implementation plan” means a plan (or portion thereof) promulgated by the Administrator to fill all or a portion of a gap or otherwise correct all or a portion of an inadequacy in a State implementation plan, and which includes enforceable emission limitations or other control measures, means or techniques (including economic incentives, such as marketable permits or auctions of emissions allowances), and provides for attainment of the relevant national ambient air quality standard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe564956-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7602/z"},"text":null,"children":[{"tag":"num","attrib":{"value":"z"},"text":"(z)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stationary Source","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “stationary source” means generally any source of an air pollutant except those emissions resulting directly from an internal combustion engine for transportation purposes or from a nonroad engine or nonroad vehicle as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7550"},"text":"section 7550 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe564957-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 302, formerly § 9, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/206/s1"},"text":"Pub. L. 88–206, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-12-17"},"text":"Dec. 17, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/400"},"text":"77 Stat. 400","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/tI/s101/4"},"text":"Pub. L. 89–272, title I, § 101(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-20"},"text":"Oct. 20, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/992"},"text":"79 Stat. 992","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/148/s2"},"text":"Pub. L. 90–148, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-11-21"},"text":"Nov. 21, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/504"},"text":"81 Stat. 504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/a/1"},"text":"Pub. L. 91–604, § 15(a)(1)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1710"},"text":"84 Stat. 1710","children":[],"tail":", 1713; "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/tII/s218/c"},"text":"Pub. L. 95–95, title II, § 218(c)","children":[],"tail":", title III, § 301, "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/761"},"text":"91 Stat. 761","children":[],"tail":", 769; "},{"tag":"ref","attrib":{"href":"/us/pl/95/190/s14/a/76"},"text":"Pub. L. 95–190, § 14(a)(76)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-16"},"text":"Nov. 16, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1404"},"text":"91 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tI"},"text":"Pub. L. 101–549, title I","children":[],"tail":", §§ 101(d)(4), 107(a), (b), 108(j), 109(b), title III, § 302(e), title VII, § 709, "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2409"},"text":"104 Stat. 2409","children":[],"tail":", 2464, 2468, 2470, 2574, 2684.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe564958-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbe564959-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbe56495a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857h"},"text":"section 1857h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbe56495b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (b) and (d) of this section were contained in a ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1857e"},"text":"section 1857e of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360/s6"},"text":"act July 14, 1955, ch. 360, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/323"},"text":"69 Stat. 323","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/88/206"},"text":"Pub. L. 88–206","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbe56495c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s107/a/1"},"text":"Pub. L. 101–549, § 107(a)(1)","children":[],"tail":", (2), struck out “or” at end of par. (3) and substituted periods for semicolons at end of pars. (1) to (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s107/a/3"},"text":"Pub. L. 101–549, § 107(a)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s108/j/2"},"text":"Pub. L. 101–549, § 108(j)(2)","children":[],"tail":", inserted at end “Such term includes any precursors to the formation of any air pollutant, to the extent the Administrator has identified such precursor or precursors for the particular purpose for which the term ‘air pollutant’ is used.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s109/b"},"text":"Pub. L. 101–549, § 109(b)","children":[],"tail":", inserted before period at end “, whether caused by transformation, conversion, or combination with other air pollutants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s303/e"},"text":"Pub. L. 101–549, § 303(e)","children":[],"tail":", inserted before period at end “, and any design, equipment, work practice or operational standard promulgated under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (q). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s101/d/4"},"text":"Pub. L. 101–549, § 101(d)(4)","children":[],"tail":", added subsec. (q)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (r). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s107/b"},"text":"Pub. L. 101–549, § 107(b)","children":[],"tail":", added subsec. (r)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (s) to (y). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s108/j/1"},"text":"Pub. L. 101–549, § 108(j)(1)","children":[],"tail":", added subsecs. (s) to (y)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (z). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/549/s709"},"text":"Pub. L. 101–549, § 709","children":[],"tail":", added subsec. (z)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s218/c"},"text":"Pub. L. 95–95, § 218(c)","children":[],"tail":", inserted “and includes the Commonwealth of the Northern Mariana Islands” after “American Samoa”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/190"},"text":"Pub. L. 95–190","children":[],"tail":" substituted “individual, corporation” for “individual corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s301/b"},"text":"Pub. L. 95–95, § 301(b)","children":[],"tail":", expanded definition of “person” to include agencies, departments, and instrumentalities of the United States and officers, agents, and employees thereof."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s301/c"},"text":"Pub. L. 95–95, § 301(c)","children":[],"tail":", expanded definition of “air pollutant” so as, expressly, to include physical, chemical, biological, and radioactive substances or matter emitted into or otherwise entering the ambient air."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (i) to (p). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95/s301/a"},"text":"Pub. L. 95–95, § 301(a)","children":[],"tail":", added subsecs. (i) to (p)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/c/1"},"text":"Pub. L. 91–604, § 15(c)(1)","children":[],"tail":", substituted definition of “Administrator” as meaning Administrator of the Environmental Protection Agency for definition of “Secretary” as meaning Secretary of Health, Education, and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/604/s15/a/1"},"text":"Pub. L. 91–604, § 15(a)(1)","children":[],"tail":", added subsec. (g) defining “air pollutant”, redesignated former subsec. (g) as (h) and substituted references to effects on soil, water, crops, vegetation, manmade materials, animals, wildlife, weather, visibility, and climate for references to injury to agricultural crops and livestock, and inserted references to effects on economic values and on personal comfort and well being."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/148"},"text":"Pub. L. 90–148","children":[],"tail":" reenacted section without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe56495d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbe56495e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/95"},"text":"Pub. L. 95–95","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-08-07"},"text":"Aug. 7, 1977","children":[],"tail":", except as otherwise expressly provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/95/s406/d"},"text":"section 406(d) of Pub. L. 95–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
