y "},{"tag":"ref","attrib":{"href":"/us/pl/91/696/s101"},"text":"section 101 of Pub. L. 91–696","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 295d–2, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tVII/s767"},"text":"act July 1, 1944, ch. 373, title VII, § 767","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1970-12-25"},"text":"Dec. 25, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/91/696/s101"},"text":"Pub. L. 91–696, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2080-4"},"text":"84 Stat. 2080–4","children":[],"tail":", established Advisory Council on Family Medicine and provided for its composition, term and compensation of its members, and its duties and functions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
