{"tag":"section","attrib":{"id":"idb5e88b3e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d"},"text":null,"children":[{"tag":"num","attrib":{"value":"295d"},"text":"§ 295d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health administration traineeships and special projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5e88b3f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to State or local governments (that have in effect preventive medical and dental public health residency programs) or public or nonprofit private educational entities (including graduate schools of social work and business schools that have health management programs) that offer a program described in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b40-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide traineeships for students enrolled in such a program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b41-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist accredited programs health administration in the development or improvement of programs to prepare students for employment with public or nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b42-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program referred to in subsection (a) is an accredited program in health administration, hospital administration, or health policy analysis and planning, which program is accredited by a body or bodies approved for such purpose by the Secretary of Education and which meets such other quality standards as the Secretary of Health and Human Services by regulation may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b43-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference in making grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under subsection (a), the Secretary shall give preference to qualified applicants that meet the following conditions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b44-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 25 percent of the graduates of the applicant are engaged in full-time practice settings in medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b45-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicant recruits and admits students from medically underserved communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b46-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of training students, the applicant has established relationships with public and nonprofit providers of health care in the community involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b47-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In training students, the applicant emphasizes employment with public or nonprofit private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5e88b48-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain provisions regarding traineeships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5e88b49-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Traineeships awarded under grants made under subsection (a) shall provide for tuition and fees and such stipends and allowances (including travel and subsistence expenses and dependency allowances) for the trainees as the Secretary may deem necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5e88b4a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s295d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for certain students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each entity applying for a grant under subsection (a) for traineeships shall assure to the satisfaction of the Secretary that the entity will give priority to awarding the traineeships to students who demonstrate a commitment to employment with public or nonprofit private entities in the fields with respect to which the traineeships are awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5e88b4b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 769, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s105"},"text":"Pub. L. 105–392, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3556"},"text":"112 Stat. 3556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5e88b4c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5e88b4d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5e88b4e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 295d, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-