{"tag":"section","attrib":{"id":"idb52031ae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s274a"},"text":null,"children":[{"tag":"num","attrib":{"value":"274a"},"text":"§ 274a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, by grant or contract, develop and maintain a scientific registry of the recipients of organ transplants. The registry shall include such information respecting patients and transplant procedures as the Secretary deems necessary to an ongoing evaluation of the scientific and clinical status of organ transplantation. The Secretary shall prepare for inclusion in the report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s274d"},"text":"section 274d of this title","children":[],"tail":" an analysis of information derived from the registry."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb52031af-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 373, as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/507/tII/s201"},"text":"Pub. L. 98–507, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2345"},"text":"98 Stat. 2345","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tIV/s404"},"text":"Pub. L. 100–607, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3116"},"text":"102 Stat. 3116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/616/tI/s101/b"},"text":"Pub. L. 101–616, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3282"},"text":"104 Stat. 3282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52031b0-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52031b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb52031b2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 373 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", added by "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch907/s1"},"text":"act Aug. 3, 1956, ch. 907, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/960"},"text":"70 Stat. 960","children":[],"tail":", which related to a Board of Regents of National Library of Medicine, was renumbered section 383 and classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s277"},"text":"section 277 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s3/b"},"text":"Pub. L. 99–158, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/879"},"text":"99 Stat. 879","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb52031b3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/616"},"text":"Pub. L. 101–616","children":[],"tail":" struck out “and bone marrow registry” after “Scientific registry” in section catchline and struck out subsec. (a) designation and subsec. (b) which directed establishment of bone marrow registry and authorized appropriations for fiscal years 1989 and 1990 for such purpose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":" inserted “and bone marrow registry” in section catchline, designated existing text as subsec. (a), and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
