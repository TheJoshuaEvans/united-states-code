{"tag":"section","attrib":{"id":"idbf80728d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615"},"text":null,"children":[{"tag":"num","attrib":{"value":"12615"},"text":"§ 12615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Civilian Community Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf80728e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the establishment of the National Civilian Community Corps Program, the National Civilian Community Corps shall be under the direction of the Director appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12619/c/1"},"text":"section 12619(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf80728f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership in National Civilian Community Corps","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf807290-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participants to be members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Persons selected to participate in the national service program or the summer national service program components of the Program shall become members of the National Civilian Community Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf807291-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director or the Director’s designee shall select individuals for membership in the Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf807292-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application for membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be selected to become a Corps member an individual shall submit an application to the Director or to any other office as the Director may designate, at such time, in such manner, and containing such information as the Director shall require. At a minimum, the application shall contain information about the work experience of the applicant and sufficient information to enable the Director, or the campus director of the appropriate campus, to determine whether selection of the applicant for membership in the Corps is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf807293-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Team leaders","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf807294-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may select individuals with prior supervisory or service experience to be team leaders within units in the National Civilian Community Corps, to perform service that includes leading and supervising teams of Corps members. Each team leader shall be selected without regard to the age limitation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12613/b"},"text":"section 12613(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf807295-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A team leader shall be provided the same rights and benefits applicable to other Corps members, except that the Director may increase the limitation on the amount of the living allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12618/b"},"text":"section 12618(b) of this title","children":[],"tail":" by not more than 10 percent for a team leader."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf807296-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization of Corps into units","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf807297-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Units","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corps shall be divided into permanent units. Each Corps member shall be assigned to a unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf807298-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit leaders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The leader of each unit shall be selected from among persons in the permanent cadre established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12619/c/2"},"text":"section 12619(c)(2) of this title","children":[],"tail":". The designated leader shall accompany the unit throughout the period of agreed service of the members of the unit."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf807299-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Campuses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf80729a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Units to be assigned to campuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The units of the Corps shall be grouped together as appropriate in campuses for operational, support, and boarding purposes. The Corps campus for a unit shall be in a facility or central location established as the operational headquarters and boarding place for the unit. Corps members may be housed in the campuses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf80729b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Campus director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a campus director for each campus. The campus director is the head of the campus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf80729c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible site for campus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A campus shall be cost effective and may, upon the completion of a feasibility study, be located in a facility referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12622/c"},"text":"section 12622(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf80729d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of units and campuses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that the Corps units and campuses are cost effective and are distributed in urban areas and rural areas such that each Corps unit in a region can be easily deployed for disaster and emergency response to such region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf80729e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of conduct","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf80729f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The campus director of each campus shall establish and enforce standards of conduct to promote proper moral and disciplinary conditions in the campus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8072a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under procedures prescribed by the Director, the campus director of a campus may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf8072a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer a member of the Corps in that campus to another unit or campus if the campus director determines that the retention of the member in the member’s unit or in the campus director’s campus will jeopardize the enforcement of the standards or diminish the opportunities of other Corps members in that unit or campus, as the case may be; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf8072a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dismiss a member of the Corps from the Corps if the campus director determines that retention of the member in the Corps will jeopardize the enforcement of the standards or diminish the opportunities of other Corps members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf8072a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12615/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under procedures prescribed by the Director, a member of the Corps may appeal to the Director a determination of a campus director to transfer or dismiss the member. The Director shall provide for expeditious disposition of appeals under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8072a4-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s155"},"text":"Pub. L. 101–610, title I, § 155","children":[],"tail":", formerly § 195D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1092/a/1"},"text":"Pub. L. 102–484, div. A, title X, § 1092(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2524"},"text":"106 Stat. 2524","children":[],"tail":"; renumbered § 155 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tI/s104/b"},"text":"Pub. L. 103–82, title I, § 104(b)","children":[],"tail":", (e)(2)(C), title IV, § 403(b), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/840"},"text":"107 Stat. 840","children":[],"tail":", 847, 920; "},{"tag":"ref","attrib":{"href":"/us/pl/103/304/s3/b/5/A"},"text":"Pub. L. 103–304, § 3(b)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1567"},"text":"108 Stat. 1567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1505"},"text":"Pub. L. 111–13, title I, § 1505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1522"},"text":"123 Stat. 1522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8072a5-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8072a6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbf8072a7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12653d"},"text":"section 12653d of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/b"},"text":"Pub. L. 103–82, § 104(b)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf8072a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12615, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s164"},"text":"Pub. L. 101–610, title I, § 164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3159"},"text":"104 Stat. 3159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/384/s4"},"text":"Pub. L. 102–384, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-05"},"text":"Oct. 5, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1455"},"text":"106 Stat. 1455","children":[],"tail":", related to evaluation reports on Peace Corps and VISTA demonstration programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/a"},"text":"Pub. L. 103–82, § 104(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/s155"},"text":"section 155 of Pub. L. 101–610","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12591"},"text":"section 12591 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/82"},"text":"Pub. L. 103–82","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf8072a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/1"},"text":"Pub. L. 111–13, § 1505(1)","children":[],"tail":", amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/2"},"text":"Pub. L. 111–13, § 1505(2)","children":[],"tail":", substituted “National Civilian Community Corps Program” for “Civilian Community Corps Demonstration Program” and “the National Civilian Community Corps shall” for “the Civilian Community Corps shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/3/A"},"text":"Pub. L. 111–13, § 1505(3)(A)","children":[],"tail":", amended heading generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/3/B"},"text":"Pub. L. 111–13, § 1505(3)(B)","children":[],"tail":", inserted “National” before “Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/3/C"},"text":"Pub. L. 111–13, § 1505(3)(C)","children":[],"tail":", substituted “campus director of the appropriate campus” for “superintendent of the appropriate camp”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/3/D"},"text":"Pub. L. 111–13, § 1505(3)(D)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/4/A"},"text":"Pub. L. 111–13, § 1505(4)(A)","children":[],"tail":", amended heading generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/4/B"},"text":"Pub. L. 111–13, § 1505(4)(B)","children":[],"tail":", amended heading generally and substituted “in campuses” for “in camps”, “Corps campus” for “Corps camp”, and “in the campuses” for “in the camps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/4/C"},"text":"Pub. L. 111–13, § 1505(4)(C)","children":[],"tail":", amended pars. (2) and (3) generally. Prior to amendment, pars. (2) and (3) related to camp superintendents and eligible sites for camps, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/5"},"text":"Pub. L. 111–13, § 1505(5)","children":[],"tail":", amended heading generally and substituted “campuses are cost effective and are distributed” for “camps are distributed” and “rural areas such that each Corps unit in a region can be easily deployed for disaster and emergency response to such region.” for “rural areas in various regions throughout the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/6/A"},"text":"Pub. L. 111–13, § 1505(6)(A)","children":[],"tail":", substituted “campus director” for “superintendent” and, in two places, substituted “campus” for “camp”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/6/B/i"},"text":"Pub. L. 111–13, § 1505(6)(B)(i)","children":[],"tail":", substituted “campus director of a campus” for “superintendent of a camp” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/6/B/ii"},"text":"Pub. L. 111–13, § 1505(6)(B)(ii)","children":[],"tail":", substituted “campus to another unit or campus” for “camp to another unit or camp”, “campus director” for “superintendent”, “campus director’s campus” for “superintendent’s camp”, and “that unit or campus” for “that unit or camp”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/6/B/iii"},"text":"Pub. L. 111–13, § 1505(6)(B)(iii)","children":[],"tail":", substituted “campus director” for “superintendent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13/s1505/6/C"},"text":"Pub. L. 111–13, § 1505(6)(C)","children":[],"tail":", substituted “campus director” for “camp superintendent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/304"},"text":"Pub. L. 103–304","children":[],"tail":" substituted “camps” for “Corps” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s403/b"},"text":"Pub. L. 103–82, § 403(b)","children":[],"tail":", substituted “Director” for “Director of the Civilian Community Corps”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/e/2/C/i"},"text":"Pub. L. 103–82, § 104(e)(2)(C)(i)","children":[],"tail":", substituted “section 12619(c)(1)” for “section 12653h(c)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/e/2/C/ii"},"text":"Pub. L. 103–82, § 104(e)(2)(C)(ii)","children":[],"tail":", substituted “section 12619(c)(2)” for “section 12653h(c)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/82/s104/e/2/C/iii"},"text":"Pub. L. 103–82, § 104(e)(2)(C)(iii)","children":[],"tail":", substituted “section 12622(a)(3)” for “section 12653k(a)(3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf8072aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbf8072ab-3a70-11f1-ae07-e4213316b5fa"},"tex