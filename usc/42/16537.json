{"tag":"section","attrib":{"id":"idc01b526f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537"},"text":null,"children":[{"tag":"num","attrib":{"value":"16537"},"text":"§ 16537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distinguished scientist program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc01b5270-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to promote scientific and academic excellence through collaborations between institutions of higher education and National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5271-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to support the joint appointment of distinguished scientists by institutions of higher education and National Laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5272-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for appointment as a distinguished scientist under this section, an individual, by reason of professional background and experience, shall be able to bring international recognition to the appointing institution of higher education or National Laboratory in the field of scientific endeavor of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5273-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A distinguished scientist appointed under this section shall be selected through an open, competitive process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5274-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5275-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appointment by an institution of higher education under this section shall be filled within the tenure allotment of the institution of higher education, at a minimum rank of professor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5276-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An appointment by a National Laboratory under this section shall be at the rank of the highest grade of distinguished scientist or technical staff of the National Laboratory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5277-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An appointment under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5278-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for a term of 6 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5279-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of 2 3-year funding allotments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b527a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds made available under this section may be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b527b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the salary of the distinguished scientist and support staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b527c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undergraduate, graduate, and post-doctoral appointments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b527d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research-related equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b527e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b527f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other requirements as the Secretary determines to be necessary to carry out the purpose of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5280-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5281-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appointment of a distinguished scientist under this section shall be reviewed at the end of the first 3-year allotment for the distinguished scientist through an open peer-review process to determine whether the appointment is meeting the purpose of this section under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5282-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funding of the appointment of the distinguished scientist for the second 3-year allotment shall be determined based on the review conducted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5283-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for assistance under this section, an appointing institution of higher education shall pay at least 50 percent of the total costs of the appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc01b5284-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc01b5285-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5286-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5287-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5288-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $31,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b5289-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $32,000,000 for fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc01b528a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16537/j/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,000,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc01b528b-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69/tV/s5011"},"text":"Pub. L. 110–69, title V, § 5011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/620"},"text":"121 Stat. 620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/tIX/s902/e"},"text":"Pub. L. 111–358, title IX, § 902(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4045"},"text":"124 Stat. 4045","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc01b528c-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc01b528d-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc01b528e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (j)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358"},"text":"Pub. L. 111–358","children":[],"tail":" added pars. (4) to (6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
