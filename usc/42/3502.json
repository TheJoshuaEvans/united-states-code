{"tag":"section","attrib":{"id":"idbc82e991-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary for Administration; appointment and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Health and Human Services an Assistant Secretary of Health and Human Services for Administration who shall be appointed, with the approval of the President, by the Secretary of Health and Human Services under the classified civil service, who shall perform such duties as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbc82e992-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/568/tII/s202"},"text":"Pub. L. 86–568, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-01"},"text":"July 1, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/305"},"text":"74 Stat. 305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/426/tIII"},"text":"Pub. L. 88–426, title III","children":[],"tail":", §§ 305(34), 307, "},{"tag":"date","attrib":{"date":"1964-08-14"},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/426"},"text":"78 Stat. 426","children":[],"tail":", 432; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbc82e993-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbc82e994-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbc82e995-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 623g of former Title 5, Executive Departments and Government Officers and Employees, prior to the general revision and enactment of Title 5, Government Organization and Employees, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-01"},"text":"Sept. 1, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbc82e996-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1964—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/426/s305/34"},"text":"Pub. L. 88–426, § 305(34)","children":[],"tail":", struck out provisions which prescribed compensation of Administrative Assistant Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbc82e997-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbc82e998-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","ch