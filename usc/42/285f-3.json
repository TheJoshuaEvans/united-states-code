{"tag":"section","attrib":{"id":"idb573a8b2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"285f–3"},"text":"§ 285f–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexually transmitted disease clinical research and training awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573a8b3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute is authorized to establish and maintain a program to enhance and promote the translation of new scientific knowledge into clinical practice related to the diagnosis, care and treatment of individuals with sexually transmitted diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a8b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of promising clinicians","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to foster the application of the most current developments in the etiology, pathogenesis, diagnosis, prevention and treatment of sexually transmitted diseases, amounts made available under this section shall be directed to the support of promising clinicians through awards for research, study, and practice at centers of excellence in sexually transmitted disease research and treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573a8b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285f–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excellence in certain fields","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Research shall be carried out under awards made under subsection (b) in environments of demonstrated excellence in the etiology and pathogenesis of sexually transmitted diseases and shall foster innovation and integration of such disciplines or other environments determined suitable by the Director of the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb573a8b6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 447B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/505/tIX/s901"},"text":"Pub. L. 106–505, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2349"},"text":"114 Stat. 2349","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/tI/s103/b/28"},"text":"Pub. L. 109–482, title I, § 103(b)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-15"},"text":"Jan. 15, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3688"},"text":"120 Stat. 3688","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a8b7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a8b8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb573a8b9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" struck out heading and text of subsec. (d). Text read as follows: “For the purpose of carrying out this section, there are authorized to be appropriated $2,250,000 for fiscal year 2001, and such sums as may be necessary for each of fiscal years 2002 through 2005.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb573a8ba-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb573a8bb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/482"},"text":"Pub. L. 109–482","children":[],"tail":" applicable only with respect to amounts appropriated for fiscal year 2007 or subsequent fiscal years, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/482/s109"},"text":"section 109 of Pub. L. 109–482","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s281"},"text":"section 281 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
