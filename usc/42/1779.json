{"tag":"section","attrib":{"id":"idbb70b5ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779"},"text":null,"children":[{"tag":"num","attrib":{"value":"1779"},"text":"§ 1779.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb70b5cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe such regulations as the Secretary may deem necessary to carry out this chapter and the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.], including regulations relating to the service of food in participating schools and service institutions in competition with the programs authorized under this chapter and the Richard B. Russell National School Lunch Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb70b5d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National school nutrition standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb70b5d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb70b5d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb70b5d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish science-based nutrition standards for foods sold in schools other than foods provided under this chapter and the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb70b5d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-12-13"},"text":"December 13, 2010","children":[],"tail":", promulgate proposed regulations to carry out clause (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb70b5d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The nutrition standards shall apply to all foods sold—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb70b5d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the school meal programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb70b5d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the school campus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb70b5d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time during the school day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb70b5d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing nutrition standards under this paragraph, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb70b5da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish standards that are consistent with the most recent Dietary Guidelines for Americans published under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5341"},"text":"section 5341 of title 7","children":[],"tail":", including the food groups to encourage and nutrients of concern identified in the Dietary Guidelines; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb70b5db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbb70b5dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authoritative scientific recommendations for nutrition standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb70b5dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing school nutrition standards, including voluntary standards for beverages and snack foods and State and local standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb70b5de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the practical application of the nutrition standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbb70b5df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" special exemptions for school-sponsored fundraisers (other than fundraising through vending machines, school stores, snack bars, a la carte sales, and any other exclusions determined by the Secretary), if the fundraisers are approved by the school and are infrequent within the school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb70b5e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updating standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the date of publication by the Department of Agriculture and the Department of Health and Human Services of a new edition of the Dietary Guidelines for Americans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5341"},"text":"section 5341 of title 7","children":[],"tail":", the Secretary shall review and update as necessary the school nutrition standards and requirements established under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb70b5e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb70b5e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The interim or final regulations under this subsection shall take effect at the beginning of the school year that is not earlier than 1 year and not later than 2 years following the date on which the regulations are finalized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb70b5e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall submit to the Committee on Agriculture, Nutrition, and Forestry of the Senate and the Committee on Education and Labor of the House of Representatives a quarterly report that describes progress made toward promulgating final regulations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb70b5e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1779/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds; reserve for special projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In such regulations the Secretary may provide for the transfer of funds by any State between the programs authorized under this chapter and the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.] on the basis of an approved State plan of operation for the use of the funds and may provide for the reserve of up to 1 per centum of the funds available for apportionment to any State to carry out special developmental projects."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb70b5e5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642/s10"},"text":"Pub. L. 89–642, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/889"},"text":"80 Stat. 889","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/248/s8"},"text":"Pub. L. 91–248, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-14"},"text":"May 14, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/212"},"text":"84 Stat. 212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/433/s7"},"text":"Pub. L. 92–433, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-09-26"},"text":"Sept. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/729"},"text":"86 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/166/s17"},"text":"Pub. L. 95–166, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-11-10"},"text":"Nov. 10, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1345"},"text":"91 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/147/tIII/s323"},"text":"Pub. L. 101–147, title III, § 323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/916"},"text":"103 Stat. 916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/448/tII/s203"},"text":"Pub. L. 103–448, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4738"},"text":"108 Stat. 4738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVII/s725"},"text":"Pub. L. 104–193, title VII, § 725","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2302"},"text":"110 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s752/b/16"},"text":"Pub. L. 106–78, title VII, § 752(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1170"},"text":"113 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/tII/s208"},"text":"Pub. L. 111–296, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3221"},"text":"124 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb70b5e6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb70b5e7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb70b5e8-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Richard B. Russell National School Lunch Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281"},"text":"act June 4, 1946, ch. 281","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/230"},"text":"60 Stat. 230","children":[],"tail":", which is classified generally to chapter 13 (§ 1751 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb70b5e9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/296"},"text":"Pub. L. 111–296","children":[],"tail":" inserted subsec. (a) heading, added subsec. (b), and struck out former subsec. (b) which related to sale of competitive foods approved by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" substituted “Richard B. Russell National School Lunch Act” for “National School Lunch Act” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193"},"text":"Pub. L. 104–193","children":[],"tail":" redesignated par. (1) as subsec. (b) and struck out pars. (2) to (4) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary shall develop and provide to State agencies, for distribution to private elementary schools and to public elementary schools through local educational agencies, model language that bans the sale of competitive foods of minimal nutritional value anywhere on elementary school grounds before the end of the last lunch period.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The Secretary shall provide to State agencies, for distribution to private secondary schools and to public secondary schools through local educational agencies, a copy of regulations (in existence on the effective date of this paragraph) concerning the sale of competitive foods of minimal nutritional value.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Paragraphs (2) and (3) shall not apply to a State that has in effect a ban on the sale of competitive foods of minimal nutritional value in schools in the State.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/448"},"text":"Pub. L. 103–448","children":[],"tail":" designated existing provisions as subsecs. (a) to (c), realigned margins, and in subsec. (b) designated existing provisions as par. (1), substituted “The regulations” for “Such regulations”, and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/147"},"text":"Pub. L. 101–147","children":[],"tail":" substituted “the Secretary” for “he” before “may deem” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/166"},"text":"Pub. L. 95–166","children":[],"tail":" inserted “approved by the Secretary” after “competitive foods”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/433"},"text":"Pub. L. 92–433","children":[],"tail":" inserted provision that regulations issued under the section shall not prohibit the sale of competitive foods in food service facilities or areas during the time of service of food if the proceeds from the sales of such foods inures to the benefit of the schools or organizations of students approved by the school."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/248"},"text":"Pub. L. 91–248","children":[],"tail":" provided that regulations under this chapter and under the National School Lunch Act may include provisions relating to the service of food in participating schools and service institutions in competition with programs under this chapter and the National School Lunch Act, provided for transfer of funds by any State between programs authorized under this chapter and under the National School Lunch Act, and provided for a reserve of up to one percent of the funds available for apportionment to any State to carry out special development projects."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb70b5ea-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbb70b5eb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Education and Labor of House of Representatives changed to Committee on Education and the Workforce of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb70b5ec-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/296"},"text":"Pub. L. 111–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2010-10-01"},"text":"Oct. 1, 2010","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/s445"},"text":"section 445 of Pub. L. 111–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb70b5ed-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/448"},"text":"Pub. L. 103–448","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/448/s401"},"text":"section 401 of Pub. L. 103–448","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1755"},"text":"section 1755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
