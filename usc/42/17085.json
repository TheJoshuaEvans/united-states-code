{"tag":"section","attrib":{"id":"idc024ef1d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085"},"text":null,"children":[{"tag":"num","attrib":{"value":"17085"},"text":"§ 17085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenant Star program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc024ef1e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef1f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-performance energy efficiency measure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-performance energy efficiency measure” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17084"},"text":"section 17084 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef20-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate spaces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “separate spaces” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17084"},"text":"section 17084 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef21-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenant Star","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Environmental Protection Agency, in consultation with the Secretary of Energy, shall develop a voluntary program within the Energy Star program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6294a"},"text":"section 6294a of this title","children":[],"tail":", which may be known as “Tenant Star”, to promote energy efficiency in separate spaces leased by tenants or otherwise occupied within commercial buildings."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef22-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanding survey data","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Energy, acting through the Administrator of the Energy Information Administration, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef23-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect, through each Commercial Buildings Energy Consumption Survey of the Energy Information Administration that is conducted after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", data on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef24-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categories of building occupancy that are known to consume significant quantities of energy, such as occupancy by data centers, trading floors, and restaurants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef25-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other aspects of the property, building operation, or building occupancy determined by the Administrator of the Energy Information Administration, in consultation with the Administrator of the Environmental Protection Agency, to be relevant in lowering energy consumption;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef26-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the first Commercial Buildings Energy Consumption Survey conducted after ","children":[{"tag":"date","attrib":{"date":"2015-04-30"},"text":"April 30, 2015","children":[],"tail":", to the extent full compliance with the requirements of paragraph (1) is not feasible, conduct activities to develop the capability to collect such data and begin to collect such data; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef27-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make data collected under paragraphs (1) and (2) available to the public in aggregated form and provide such data, and any associated results, to the Administrator of the Environmental Protection Agency for use in accordance with subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc024ef28-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of owners and tenants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc024ef29-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Occupancy-based recognition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which sufficient data is received pursuant to subsection (c), the Administrator of the Environmental Protection Agency shall, following an opportunity for public notice and comment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc024ef2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner similar to the Energy Star rating system for commercial buildings, develop policies and procedures to recognize tenants in commercial buildings that voluntarily achieve high levels of energy efficiency in separate spaces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish building occupancy categories eligible for Tenant Star recognition based on the data collected under subsection (c) and any other appropriate data sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc024ef2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider other forms of recognition for commercial building tenants or other occupants that lower energy consumption in separate spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc024ef2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s17085/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design- and construction-based recognition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the study required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s17084/b"},"text":"section 17084(b) of this title","children":[],"tail":" is completed, the Administrator of the Environmental Protection Agency, in consultation with the Secretary and following an opportunity for public notice and comment, may develop a voluntary program to recognize commercial building owners and tenants that use high-performance energy efficiency measures in the design and construction of separate spaces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc024ef2e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s425"},"text":"Pub. L. 110–140, title IV, § 425","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/11/tI/s104/a"},"text":"Pub. L. 114–11, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-04-30"},"text":"Apr. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/185"},"text":"129 Stat. 185","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
