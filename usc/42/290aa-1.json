{"tag":"section","attrib":{"id":"idb59c3f97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290aa–1"},"text":"§ 290aa–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory councils","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb59c3f98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3f99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint an advisory council for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Substance Abuse and Mental Health Services Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center for Substance Abuse Treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center for Substance Abuse Prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3f9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center for Mental Health Services.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Each such advisory council shall advise, consult with, and make recommendations to the Secretary and the Assistant Secretary or Director of the Administration or Center for which the advisory council is established concerning matters relating to the activities carried out by and through the Administration or Center and the policies respecting such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3f9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advisory council—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3f9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3fa0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may on the basis of the materials provided by the organization respecting activities conducted at the organization, make recommendations to the Assistant Secretary or Director of the Administration or Center for which it was established respecting such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3fa1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review applications submitted for grants and cooperative agreements for activities for which advisory council approval is required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–3/d/2"},"text":"section 290aa–3(d)(2) of this title","children":[],"tail":" and recommend for approval applications for projects that show promise of making valuable contributions to the Administration’s mission; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3fa2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may review any grant, contract, or cooperative agreement proposed to be made or entered into by the organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fa3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may collect, by correspondence or by personal investigation, information as to studies and services that are being carried on in the United States or any other country as to the diseases, disorders, or other aspects of human health with respect to which the organization was established and with the approval of the Assistant Secretary or Director, whichever is appropriate, make such information available through appropriate publications for the benefit of public and private health entities and health professions personnel and for the information of the general public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fa4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may appoint subcommittees and convene workshops and conferences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3fa5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3fa6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each advisory council shall consist of nonvoting ex officio members and not more than 12 members to be appointed by the Secretary under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3fa7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ex officio members of an advisory council shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3fa8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fa9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3faa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Center for which the council is established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Health of the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Defense for Health Affairs (or the designates of such officers);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fad-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Medical Officer, appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa/g"},"text":"section 290aa(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fae-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute of Mental Health for the advisory councils appointed under subsections (a)(1)(A) and (a)(1)(D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3faf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute on Drug Abuse for the advisory councils appointed under subsections (a)(1)(A), (a)(1)(B), and (a)(1)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fb0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute on Alcohol Abuse and Alcoholism for the advisory councils appointed under subsections (a)(1)(A), (a)(1)(B), and (a)(1)(C); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fb1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional officers or employees of the United States as the Secretary determines necessary for the advisory council to effectively carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3fb2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointed members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Individuals shall be appointed to an advisory council under paragraph (1) as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb59c3fb3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nine of the members shall be appointed by the Secretary from among the leading representatives of the health disciplines (including public health and behavioral and social sciences) relevant to the activities of the Administration or Center for which the advisory council is established.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fb4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three of the members shall be appointed by the Secretary from the general public and shall include leaders in fields of public policy, public relations, law, health policy economics, or management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fb5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not less than half of the members of the advisory council appointed under subsection (a)(1)(D)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3fb6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb59c3fb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a medical degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb59c3fb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a doctoral degree in psychology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb59c3fb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an advanced degree in nursing or social work from an accredited graduate school or be a certified physician assistant; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3fba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall specialize in the mental health field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb59c3fbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not less than half of the members of the advisory councils appointed under subsections (a)(1)(B) and (a)(1)(C)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb59c3fbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb59c3fbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a medical degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb59c3fbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a doctoral degree; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb59c3fbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an advanced degree in nursing, public health, behavioral or social sciences, or social work from an accredited graduate school or be a certified physician assistant; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb59c3fc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have experience in the provision of substance use disorder services or the development and implementation of programs to prevent substance misuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3fc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of an advisory council who are officers or employees of the United States shall not receive any compensation for service on the advisory council. The remaining members of an advisory council shall receive, for each day (including travel time) they are engaged in the performance of the functions of the advisory council, compensation at rates not to exceed the daily equivalent to the annual rate in effect for grade GS–18 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3fc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb59c3fc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of office of a member of an advisory council appointed under subsection (b) shall be 4 years, except that any member appointed to fill a vacancy for an unexpired term shall serve for the remainder of such term. The Secretary shall make appointments to an advisory council in such a manner as to ensure that the terms of the members not all expire in the same year. A member of an advisory council may serve after the expiration of such member’s term until a successor has been appointed and taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3fc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member who has been appointed to an advisory council for a term of 4 years may not be reappointed to an advisory council during the 2-year period beginning on the date on which such 4-year term expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb59c3fc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a vacancy occurs in an advisory council among the members under subsection (b), the Secretary shall make an appointment to fill such vacancy within 90 days from the date the vacancy occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3fc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall select a member of an advisory council to serve as the chair of the council. The Secretary may so select an individual from among the appointed members, or may select the Assistant Secretary or the Director of the Center involved. The term of office of the chair shall be 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3fc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An advisory council shall meet at the call of the chairperson or upon the request of the Assistant Secretary or Director of the Administration or Center for which the advisory council is established, but in no event less than 2 times during each fiscal year. The location of the meetings of each advisory council shall be subject to the approval of the Assistant Secretary or Director of Administration or Center for which the council was established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb59c3fc8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s290aa–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Secretary and staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary or Director of the Administration or Center for which the advisory council is established shall designate a member of the staff of the Administration or Center for which the advisory council is established to serve as the Executive Secretary of the advisory council. The Assistant Secretary or Director shall make available to the advisory council such staff, information, and other assistance as it may require to carry out its functions. The Assistant Secretary or Director shall provide orientation and training for new members of the advisory council to provide for their effective participation in the functions of the advisory council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb59c3fc9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title V, § 502, formerly § 505, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4004/a"},"text":"Pub. L. 99–570, title IV, § 4004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-109"},"text":"100 Stat. 3207–109","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/527/s10/4"},"text":"Pub. L. 100–527, § 10(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2641"},"text":"102 Stat. 2641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/381/tI/s102/6"},"text":"Pub. L. 101–381, title I, § 102(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/586"},"text":"104 Stat. 586","children":[],"tail":"; renumbered § 502 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s102"},"text":"Pub. L. 102–321, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/331"},"text":"106 Stat. 331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s2/a/6"},"text":"Pub. L. 102–352, § 2(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/938"},"text":"106 Stat. 938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/446/tXII/s1203/a/1"},"text":"Pub. L. 103–446, title XII, § 1203(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4689"},"text":"108 Stat. 4689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/310/dB/tXXXIV/s3402"},"text":"Pub. L. 106–310, div. B, title XXXIV, § 3402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1219"},"text":"114 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dB/tVI"},"text":"Pub. L. 114–255, div. B, title VI","children":[],"tail":", §§ 6001(c)(2), 6008, "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1203"},"text":"130 Stat. 1203","children":[],"tail":", 1214.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb59c3fca-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb59c3fcb-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb59c3fcc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–3a"},"text":"section 290aa–3a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb59c3fcd-3a70-11f1-ae07-e4213316b5fa"},"text"