","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/98/509/tII/s205/b/2"},"text":"Pub. L. 98–509, title II, § 205(b)(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2361"},"text":"98 Stat. 2361","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4005/b/1"},"text":"Pub. L. 99–570, title IV, § 4005(b)(1)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-114"},"text":"100 Stat. 3207–114","children":[],"tail":", related to National Institute on Alcohol Abuse and Alcoholism, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321/tI/s101/b"},"text":"Pub. L. 102–321, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-07-10"},"text":"July 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/331"},"text":"106 Stat. 331","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285n"},"text":"section 285n of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 502 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s220"},"text":"section 220 of this title","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238a"},"text":"section 238a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb59c3fce-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A)(i), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F) to (J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6008/1"},"text":"Pub. L. 114–255, § 6008(1)","children":[],"tail":", added subpars. (F) to (I) and redesignated former subpar. (F) as (J)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6008/2"},"text":"Pub. L. 114–255, § 6008(2)","children":[],"tail":", added subpars. (C) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/255/s6001/c/2"},"text":"Pub. L. 114–255, § 6001(c)(2)","children":[],"tail":", substituted “Assistant Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/310"},"text":"Pub. L. 106–310","children":[],"tail":" substituted “2 times during each fiscal year” for “3 times during each fiscal year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/446"},"text":"Pub. L. 103–446","children":[],"tail":" amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “the Chief Medical Director of the Veterans Administration; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" substituted “or management” for “and management” in subsec. (b)(3)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" amended section generally, substituting provisions relating to appointment of advisory councils to Substance Abuse and Mental Health Services Administration, Center for Substance Abuse Treatment, Center for Substance Abuse Prevention, and Center for Mental Health Services for provisions appointing advisory councils for National Institute on Alcohol Abuse and Alcoholism, National Institute on Drug Abuse, and National Institute of Mental Health."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/381"},"text":"Pub. L. 101–381","children":[],"tail":" made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aaa"},"text":"section 300aaa of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":" substituted “Chief Medical Director of the Department of Veterans Affairs” for “Chief Medical Director of the Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb59c3fcf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb59c3fd0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/352"},"text":"Pub. L. 102–352","children":[],"tail":" effective immediately upon effectuation of amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/352/s3/1"},"text":"section 3(1) of Pub. L. 102–352","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285n"},"text":"section 285n of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-01"},"text":"Oct. 1, 1992","children":[],"tail":", with provision for programs providing financial assistance, see section 801(c), (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/321"},"text":"Pub. L. 102–321","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s236"},"text":"section 236 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb59c3fd1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-03-15"},"text":"Mar. 15, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/527/s18/a"},"text":"section 18(a) of Pub. L. 100–527","children":[],"tail":", set out as a Department of Veterans Affairs Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s301"},"text":"section 301 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb59c3fd2-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory councils established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a council established by the President or an officer of the Federal Government, such council is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a council established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/641/s6"},"text":"Pub. L. 93–641, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2275"},"text":"88 Stat. 2275","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s217a"},"text":"section 217a of this title","children":[],"tail":", provided that an advisory committee established pursuant to the Public Health Service Act shall terminate at such time as may be specifically prescribed by an Act of Congress enacted after "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb59e89c3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb59e89c4-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Existing Advisory Councils","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tIV/s4004/b"},"text":"Pub. L. 99–570, title IV, § 4004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-111"},"text":"100 Stat. 3207–111","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/570/tIV/s4004/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a) [enacting this section and renumbering this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–5"},"text":"section 290aa–5 of this title","children":[],"tail":"] does not terminate the membership of any advisory council for the National Institute on Alcohol Abuse and Alcoholism, the National Institute on Drug Abuse, or the National Institute of Mental Health which was in existence on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":"]. After such date—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services shall make appointments to each such advisory council in such a manner as to bring about as soon as practicable the composition for such council prescribed by section 505 [now 502] of the Public Health Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s290aa–1"},"text":"42 U.S.C. 290aa–1","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each advisory council shall organize itself in accordance with such section and exercise the functions prescribed by such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of each such institute shall perform for such advisory council the functions prescribed by such section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
