{"tag":"section","attrib":{"id":"idbfdd5f83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082"},"text":null,"children":[{"tag":"num","attrib":{"value":"15082"},"text":"§ 15082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfdd5f84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants, contracts, or cooperative agreements to public or private nonprofit entities for projects of national significance relating to individuals with developmental disabilities to carry out activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15081/2"},"text":"section 15081(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfdd5f85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal interagency initiatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfdd5f86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfdd5f87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with Federal agencies to jointly carry out activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15081/2"},"text":"section 15081(2) of this title","children":[],"tail":" or to jointly carry out activities of common interest related to the objectives of such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer to such agencies for such purposes funds appropriated under this part, and receive and use funds from such agencies for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to program purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds transferred or received pursuant to this paragraph shall be used only in accordance with statutes authorizing the appropriation of such funds. Such funds shall be made available through grants, contracts, or cooperative agreements only to recipients eligible to receive such funds under such statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfdd5f8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures and criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary enters into an agreement under this subsection for the administration of a jointly funded project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbfdd5f8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement shall specify which agency’s procedures shall be used to award grants, contracts, or cooperative agreements and to administer such awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating agencies may develop a single set of criteria for the jointly funded project, and may require applicants to submit a single application for joint review by such agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbfdd5f8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the heads of the participating agencies develop joint eligibility requirements, an applicant for an award for the project shall meet the eligibility requirements of each program involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfdd5f8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s15082/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not construe the provisions of this subsection to take precedence over a limitation on joint funding contained in an applicable statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfdd5f90-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/402/tI/s162"},"text":"Pub. L. 106–402, title I, § 162","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1727"},"text":"114 Stat. 1727","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
