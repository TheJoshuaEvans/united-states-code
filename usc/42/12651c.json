{"tag":"section","attrib":{"id":"idbf8c5808-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651c"},"text":null,"children":[{"tag":"num","attrib":{"value":"12651c"},"text":"§ 12651c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Executive Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf8c5809-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall be headed by an individual who shall serve as Chief Executive Officer of the Corporation, and who shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c580a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall be compensated at the rate provided for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":", plus 3 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf8c580b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12651c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall prescribe such rules and regulations as are necessary or appropriate to carry out the national service laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf8c580c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/610/tI/s193"},"text":"Pub. L. 101–610, title I, § 193","children":[],"tail":", as added and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/82/tII"},"text":"Pub. L. 103–82, title II","children":[],"tail":", §§ 202(a), 203(a)(1)(B), "},{"tag":"date","attrib":{"date":"1993-09-21"},"text":"Sept. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/877"},"text":"107 Stat. 877","children":[],"tail":", 891; "},{"tag":"ref","attrib":{"href":"/us/pl/111/13/tI/s1703"},"text":"Pub. L. 111–13, title I, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-04-21"},"text":"Apr. 21, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1545"},"text":"123 Stat. 1545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf8c580d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf8c580e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbf8c580f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/13"},"text":"Pub. L. 111–13","children":[],"tail":" inserted “, plus 3 percent” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","chil