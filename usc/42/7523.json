{"tag":"section","attrib":{"id":"idbe43373b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7523"},"text":null,"children":[{"tag":"num","attrib":{"value":"7523"},"text":"§ 7523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions to restrain violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe43373c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district courts of the United States shall have jurisdiction to restrain violations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7522/a"},"text":"section 7522(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe43373d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions brought by or in name of United States; subpenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Actions to restrain such violations shall be brought by and in the name of the United States. In any such action, subpenas for witnesses who are required to attend a district court in any district may run into any other district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe43373e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title II, § 204, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/272/tI/s101/8"},"text":"Pub. L. 89–272, title I, § 101(8)"