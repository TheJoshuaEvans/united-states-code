{"tag":"section","attrib":{"id":"idbe67124d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7661e"},"text":"§ 7661e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe67124e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall prevent a State, or interstate permitting authority, from establishing additional permitting requirements not inconsistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe67124f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7661e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permits implementing acid rain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter, including provisions regarding schedules for submission and approval or disapproval of permit applications, shall apply to permits implementing the requirements of subchapter IV–A except as modified by that subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe671250-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title V, § 506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/549/tV/s501"},"text":"Pub. L. 101–549, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2645"},"text":"104 Stat. 2645","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
