{"tag":"section","attrib":{"id":"idbb96dbc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862s–6"},"text":"§ 1862s–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential awards for excellence in STEM mentoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb96dbc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foundation shall continue to administer awards on behalf of the Office of Science and Technology Policy to recognize outstanding mentoring in STEM fields.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb96dbc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862s–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual award recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foundation shall provide Congress with a list of award recipients, including the name, institution, and a brief synopsis of the impact of the mentoring efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb96dbc5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/329/tIII/s307"},"text":"Pub. L. 114–329, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-06"},"text":"Jan. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/3010"},"text":"130 Stat. 3010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb96dbc6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb96dbc7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb96dbc8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the American Innovation and Competitiveness Act, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb96dbc9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb96dbca-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Presidential Awards for Educators and Mentors in Fields Relating to Cybersecurity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCIV/s9405/d"},"text":"Pub. L. 116–283, div. H, title XCIV, § 9405(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4812"},"text":"134 Stat. 4812","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dH/tXCIV/s9405/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"