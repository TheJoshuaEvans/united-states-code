{"tag":"section","attrib":{"id":"idbf4739f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384"},"text":null,"children":[{"tag":"num","attrib":{"value":"11384"},"text":"§ 11384.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentives for high-performing communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf4739f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation as a high-performing community","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4739f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall designate, on an annual basis, which collaborative applicants represent high-performing communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to designate a collaborative applicant as a high-performing community under paragraph (1), the Secretary shall establish criteria to ensure that the requirements described under paragraphs (1)(B) and (2)(B) of subsection (d) are measured by comparing homeless individuals and families under similar circumstances, in order to encourage projects in the geographic area to serve homeless individuals and families with more severe barriers to housing stability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2-year phase in","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each of the first 2 years after the effective date under section 1503 of the Homeless Emergency Assistance and Rapid Transition to Housing Act of 2009, the Secretary shall designate not more than 10 collaborative applicants as high-performing communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess of qualified applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, during the 2-year period described under paragraph (2), more than 10 collaborative applicants could qualify to be designated as high-performing communities, the Secretary shall designate the 10 that have, in the discretion of the Secretary, the best performance based on the criteria described under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit on designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation of any collaborative applicant as a high-performing community under this subsection shall be effective only for the year in which such designation is made. The Secretary, on an annual basis, may renew any such designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4739fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4739fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A collaborative applicant seeking designation as a high-performing community under subsection (a) shall submit an application to the Secretary at such time, and in such manner as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4739ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any application submitted under paragraph (1), a collaborative applicant shall include in such application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf473a00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report showing how any money received under this part in the preceding year was expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf473a01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that such applicant can meet the requirements described under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf473a02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf473a03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish any report or information submitted in an application under this section in the geographic area represented by the collaborative applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf473a04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek comments from the public as to whether the collaborative applicant seeking designation as a high-performing community meets the requirements described under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf473a05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/a"},"text":"section 11382(a) of this title","children":[],"tail":" to a project sponsor who is located in a high-performing community may be used—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf473a06-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any of the eligible activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11383"},"text":"section 11383 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf473a07-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any of the eligible activities described in paragraphs (4) and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11374/a"},"text":"section 11374(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf473a08-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of high-performing community","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “high-performing community” means a geographic area that demonstrates through reliable data that all five of the following requirements are met for that geographic area:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf473a09-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of homelessness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mean length of episodes of homelessness for that geographic area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf473a0a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is less than 20 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf473a0b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for individuals and families in similar circumstances in the preceding year was at least 10 percent less than in the year before.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf473a0c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Families leaving homelessness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of individuals and families—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf473a0d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who leave homelessness, fewer than 5 percent of such individuals and families become homeless again at any time within the next 2 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf473a0e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in similar circumstances who leave homelessness, the percentage of such individuals and families who become homeless again within the next 2 years has decreased by at least 20 percent from the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf473a0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The communities that compose the geographic area have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf473a10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively encouraged homeless individuals and families to participate in homeless assistance services available in that geographic area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf473a11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included each homeless individual or family who sought homeless assistance services in the data system used by that community for determining compliance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf473a12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of previous activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If recipients in the geographic area have used funding awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/a"},"text":"section 11382(a) of this title","children":[],"tail":" for eligible activities described under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11374/a"},"text":"section 11374(a) of this title","children":[],"tail":" in previous years based on the authority granted under subsection (c), that such activities were effective at reducing the number of individuals and families who became homeless in that community."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf473a13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility to serve persons defined as homeless under other Federal laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to collaborative applicants exercising the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11382/j"},"text":"section 11382(j) of this title","children":[],"tail":" to serve homeless families with children and youth defined as homeless under other Federal statutes, effectiveness in achieving the goals and outcomes identified in subsection "},{"tag":"ref","attrib":{"idref":"fn004005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 11386a(b)(1)(F) of this title according to such standards as the Secretary shall promulgate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf473a14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11384/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation among entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A collaborative applicant designated as a high-performing community under this section shall cooperate with the Secretary in distributing information about successful efforts within the geographic area represented by the collaborative applicant to reduce homelessness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf473a15-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s424"},"text":"Pub. L. 100–77, title IV, § 424","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1303"},"text":"Pub. L. 111–22, div. B, title III, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1687"},"text":"123 Stat. 1687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf473a16-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf473a17-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbf473a18-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date under section 1503 of the Homeless Emergency Assistance and Rapid Transition to Housing Act of 2009, referred to in subsec. (a)(3), is the effective date under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tV/s1503"},"text":"section 1503 of title V of div. B of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf473a19-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11384, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s424"},"text":"Pub. L. 100–77, title IV, § 424","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1403/a"},"text":"Pub. L. 102–550, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4016"},"text":"106 Stat. 4016","children":[],"tail":", which related to supportive housing, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/dB/tIII/s1303"},"text":"Pub. L. 111–22, div. B, title III, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1687"},"text":"123 Stat. 1687","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 11384, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIV/s424"},"text":"Pub. L. 100–77, title IV, § 424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/501"},"text":"101 Stat. 501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/628/tIV"},"text":"Pub. L. 100–628, title IV","children":[],"tail":", §§ 442(b)(2), 448(b), 450(a)(1), (b), 451, "},{"tag":"date","attrib":{"date":"1988-11-07"},"text":"Nov. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3233-3235"},"text":"102 Stat. 3233–3235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s833/f"},"text":"Pub. L. 101–625, title VIII, § 833(f)","children":[],"tail":", (h)–(j), (k)(2), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4363-4365"},"text":"104 Stat. 4363–4365","children":[],"tail":", which provided for applications, selection criteria, and other program requirements for assistance under the supportive housing demonstration program, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tXIV/s1403/a"},"text":"Pub. L. 102–550, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4013"},"text":"106 Stat. 4013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf473a1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbf473a1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the earlier of 18 months after ","children":[{"tag":"date","attrib":{"date":"2009-05-20"},"text":"May 20, 2009","children":[],"tail":", or 3 months after publication of certain final regulations by Secretary of Housing and Urban Development, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/22/s1503"},"text":"section 1503 of Pub. L. 111–22","children":[],"tail":", set out as an Effective Date of 2009 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11302"},"text":"section 11302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
