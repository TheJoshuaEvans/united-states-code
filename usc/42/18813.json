{"tag":"section","attrib":{"id":"idc06c7fd3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813"},"text":null,"children":[{"tag":"num","attrib":{"value":"18813"},"text":"§ 18813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging smart manufacturing infrastructure at National Laboratories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc06c7fd4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc06c7fd5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall conduct a study on how the Department can increase access to existing high-performance computing resources in the National Laboratories, particularly for small and medium manufacturers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fd6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying ways to increase access to National Laboratories under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc06c7fd7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on increasing access to the computing facilities of the National Laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc06c7fd8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc06c7fd9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information from the manufacturer is protected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc06c7fda-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security of the National Laboratory facility is maintained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc06c7fdb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"November 15, 2021","children":[],"tail":", the Secretary shall submit to Congress a report describing the results of the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc06c7fdc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions for increased access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall facilitate access to the National Laboratories studied under subsection (a) for small and medium manufacturers so that small and medium manufacturers can fully use the high-performance computing resources of the National Laboratories to enhance the manufacturing competitiveness of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc06c7fdd-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dD/tV/s40533"},"text":"Pub. L. 117–58, div. D, title V, § 40533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1069"},"text":"135 Stat. 1069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc06c7fde-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idc06c7fdf-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idc06c7fe0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Wage Rate Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to rates of wages to be paid to laborers and mechanics on projects for construction, alteration, or repair work funded under div. D or an amendment by div. D of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", including authority of Secretary of Labor, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s18851"},"text":"section 18851 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
