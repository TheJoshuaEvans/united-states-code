{"tag":"section","attrib":{"id":"idbfab52f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12906"},"text":null,"children":[{"tag":"num","attrib":{"value":"12906"},"text":"§ 12906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for AIDS housing information and coordination services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Grants under this section may only be used for the following activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfab52f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing information services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To provide (or contract to provide) counseling, information, and referral services to assist eligible persons to locate, acquire, finance, and maintain housing and meet their housing needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfab52f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resource identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To identify, coordinate, and develop housing assistance resources (including conducting preliminary research and making expenditures necessary to determine the feasibility of specific housing-related initiatives) for eligible persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab52f3-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tVIII/s857"},"text":"Pub. L. 101–625, title VIII, § 857","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4379"},"text":"104 Stat. 4379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s606/j/11/B"},"text":"Pub. L. 102–550, title VI, § 606(j)(11)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3811"},"text":"106 Stat. 3811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab52f4-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab52f5-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfab52f6-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Pars. (1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted “eligible persons” for “individuals with acquired immunodeficiency syndrome or related diseases”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
