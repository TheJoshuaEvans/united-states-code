{"tag":"section","attrib":{"id":"idb7f01a2a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of Federal and State programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f01a2b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall designate an identifiable administrative unit with expertise in maternal and child health within the Department of Health and Human Services, which unit shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f01a2c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s702/a"},"text":"section 702(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a2d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting coordination at the Federal level of the activities authorized under this subchapter and under subchapter XIX of this chapter, especially early and periodic screening, diagnosis and treatment, related activities funded by the Departments of Agriculture and Education, and under health block grants and categorical health programs, such as immunizations, administered by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a2e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminating information to the States in such areas as preventive health services and advances in the care and treatment of mothers and children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a2f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance, upon request, to the States in such areas as program planning, establishment of goals and objectives, standards of care, and evaluation and in developing consistent and accurate data collection mechanisms in order to report the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s706/a/2"},"text":"section 706(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a30-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the National Center for Health Statistics and in a manner that avoids duplication of data collection, collection, maintenance, and dissemination of information relating to the health status and health service needs of mothers and children in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a31-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the preparation of reports to the Congress on the activities funded and accomplishments achieved under this subchapter from the information required to be reported by the States under sections 705(a) and 706 of this title; and ","children":[{"tag":"ref","attrib":{"idref":"fn002648"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002648"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a32-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting States in the development of care coordination services (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s701/b/3"},"text":"section 701(b)(3) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f01a33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and making available to the State agency (or agencies) administering the State’s program under this subchapter a national directory listing by State the toll-free numbers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s705/a/5/E"},"text":"section 705(a)(5)(E) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f01a34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State health agency of each State shall be responsible for the administration (or supervision of the administration) of programs carried out with allotments made to the State under this subchapter, except that, in the case of a State which on ","children":[{"tag":"date","attrib":{"date":"1967-07-01"},"text":"July 1, 1967","children":[],"tail":", provided for administration (or supervision thereof) of the State plan under this subchapter (as in effect on such date) by a State agency other than the State health agency, that State shall be considered to comply "},{"tag":"ref","attrib":{"idref":"fn002649"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002649"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “comply with”."}],"tail":" the requirement of this subsection if it would otherwise comply but for the fact that such other State agency administers (or supervises the administration of) any such program providing services for children with special health care needs."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f01a35-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title V, § 509, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXI/s2192/a"},"text":"Pub. L. 97–35, title XXI, § 2192(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/825"},"text":"95 Stat. 825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tIX/s9527/e"},"text":"Pub. L. 99–272, title IX, § 9527(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/219"},"text":"100 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tVI"},"text":"Pub. L. 101–239, title VI","children":[],"tail":", §§ 6503(c)(4), 6505, "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2278"},"text":"103 Stat. 2278","children":[],"tail":", 2281.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f01a36-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f01a37-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7f01a38-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 709, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531/tV/s509"},"text":"act Aug. 14, 1935, ch. 531, title V, § 509","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/90/248/tIII/s301"},"text":"Pub. L. 90–248, title III, § 301","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/926"},"text":"81 Stat. 926","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1972-07-10"},"text":"July 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/345/s2/e"},"text":"Pub. L. 92–345, § 2(e)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/457"},"text":"86 Stat. 457","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1972-10-30"},"text":"Oct. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/603/tII"},"text":"Pub. L. 92–603, title II","children":[],"tail":", §§ 221(c)(3), 233(e), "},{"tag":"ref","attrib":{"href":"/us/stat/86/1389"},"text":"86 Stat. 1389","children"