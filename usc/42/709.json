:"idb7f01a39-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6505/1"},"text":"Pub. L. 101–239, § 6505(1)","children":[],"tail":", inserted before semicolon at end “and in developing consistent and accurate data collection mechanisms in order to report the information required under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s706/a/2"},"text":"section 706(a)(2) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/c/4"},"text":"Pub. L. 101–239, § 6503(c)(4)","children":[],"tail":", substituted “705(a)” for “705”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6505/2"},"text":"Pub. L. 101–239, § 6505(2)","children":[],"tail":"–(4), added pars. (7) and (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" substituted “children with special health care needs” for “crippled children”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7f01a3a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7f01a3b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6503/c/4"},"text":"section 6503(c)(4) of Pub. L. 101–239","children":[],"tail":" applicable to payments for allotments for fiscal years beginning with fiscal year 1991, and amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/s6505"},"text":"section 6505 of Pub. L. 101–239","children":[],"tail":" applicable to appropriations for fiscal years beginning with fiscal year 1990, see section 6510(a), (b)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/239"},"text":"Pub. L. 101–239","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s701"},"text":"section 701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7f01a3c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress; Evaluation of Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/97/tII/s206"},"text":"Pub. L. 89–97, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-07-30"},"text":"July 30, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/354"},"text":"79 Stat. 354","children":[],"tail":", authorized Secretary to submit to President for transmission to Congress before "},{"tag":"date","attrib":{"date":"1969-07-01"},"text":"July 1, 1969","children":[],"tail":", a full report of administration of provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s729–1"},"text":"section 729–1 of this title","children":[],"tail":", which was covered by former sections 701, 702(1)(B), and 709 of this title, together with an evaluation of program established thereby and his recommendations as to continuation of and modifications in that program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
