{"tag":"section","attrib":{"id":"idb610fa0f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"300b–17"},"text":"§ 300b–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report by Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb610fa10-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Health and Human Services shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb610fa11-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", submit to the Committee on Health, Education, Labor, and Pensions of the Senate and the Committee on Energy and Commerce of the House of Representatives a report on activities related to—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb610fa12-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" newborn screening; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb610fa13-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening children who have or are at risk for heritable disorders; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610fa14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than every 2 years, submit to such committees an updated version of such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb610fa15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under this section shall contain a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb610fa16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ongoing activities under sections 300b–8, 300b–9, and 300b–11 through 300b–14 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb610fa17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300b–17/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts expended on such activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb610fa18-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/240/s11/b"},"text":"Pub. L. 113–240, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2856"},"text":"128 Stat. 2856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb610fa19-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb610fa1a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb610fa1b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Newborn Screening Saves Lives Reauthorization Act of 2014, and not as part of the Public Health Service Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb610fa1c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 300c to 300c–4 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/278/tIV/s403/a"},"text":"Pub. L. 94–278, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/407"},"text":"90 Stat. 407","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300c, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXI/s1111"},"text":"act July 1, 1944, ch. 373, title XI, § 1111","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/414/s3"},"text":"Pub. L. 92–414, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/650"},"text":"86 Stat. 650","children":[],"tail":", authorized Secretary to make grants and enter contracts with public and private entities for establishment of screening, treatment, and counseling programs with respect to Cooley’s Anemia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300c–1, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXI/s1112"},"text":"act July 1, 1944, ch. 373, title XI, § 1112","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/414/s3"},"text":"Pub. L. 92–414, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/651"},"text":"86 Stat. 651","children":[],"tail":", required that any participation by an individual in any Cooley’s Anemia programs should be on a purely voluntary basis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300c–2, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXI/s1113"},"text":"act July 1, 1944, ch. 373, title XI, § 1113","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/414/s3"},"text":"Pub. L. 92–414, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/651"},"text":"86 Stat. 651","children":[],"tail":", provided for making of grant upon application to Secretary and listed certain requirements to be met by applicant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300c–3, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXI/s1114"},"text":"act July 1, 1944, ch. 373, title XI, § 1114","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/414/s3"},"text":"Pub. L. 92–414, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/652"},"text":"86 Stat. 652","children":[],"tail":", authorized Secretary to establish a program with Public Health Service to provide for screening, counseling, and treatment with respect to Cooley’s Anemia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 300c–4, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXI/s1115"},"text":"act July 1, 1944, ch. 373, title XI, § 1115","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1972-08-29"},"text":"Aug. 29, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/92/414/s3"},"text":"Pub. L. 92–414, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/652"},"text":"86 Stat. 652","children":[],"tail":", provided for Secretary’s submission of a report to President for transmittal to Congress annually."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
