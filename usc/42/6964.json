{"tag":"section","attrib":{"id":"idbddf1e33-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964"},"text":null,"children":[{"tag":"num","attrib":{"value":"6964"},"text":"§ 6964.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of solid waste disposal guidelines to Executive agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbddf1e34-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbddf1e35-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbddf1e36-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") or any unit of the legislative branch of the Federal Government has jurisdiction over any real property or facility the operation or administration of which involves such agency in solid waste management activities, or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e37-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such an agency enters into a contract with any person for the operation by such person of any Federal property or facility, and the performance of such contract involves such person in solid waste management activities,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then such agency shall insure compliance with the guidelines recommended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6907"},"text":"section 6907 of this title","children":[],"tail":" and the purposes of this chapter in the operation or administration of such property or facility, or the performance of such contract, as the case may be."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e38-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each Executive agency or any unit of the legislative branch of the Federal Government which conducts any activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbddf1e39-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which generates solid waste, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbddf1e3a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which, if conducted by a person other than such agency, would require a permit or license from such agency in order to dispose of such solid waste,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall insure compliance with such guidelines and the purposes of this chapter in conducting such activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e3b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Executive agency which permits the use of Federal property for purposes of disposal of solid waste shall insure compliance with such guidelines and the purposes of this chapter in the disposal of such waste.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbddf1e3c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President or the Committee on House Oversight of the House of Representatives and the Committee on Rules and Administration of the Senate with regard to any unit of the legislative branch of the Federal Government shall prescribe regulations to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbddf1e3d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6964/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licenses and permits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Executive agency which issues any license or permit for disposal of solid waste shall, prior to the issuance of such license or permit, consult with the Administrator to insure compliance with guidelines recommended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6907"},"text":"section 6907 of this title","children":[],"tail":" and the purposes of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbddf1e3e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/272/tII/s6004"},"text":"Pub. L. 89–272, title II, § 6004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/580/s2"},"text":"Pub. L. 94–580, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2823"},"text":"90 Stat. 2823","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/609/s7"},"text":"Pub. L. 95–609, § 7","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3083"},"text":"92 Stat. 3083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/482/s23"},"text":"Pub. L. 96–482, § 23","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2347"},"text":"94 Stat. 2347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s222/2"},"text":"Pub. L. 104–186, title II, § 222(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1751"},"text":"110 Stat. 1751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbddf1e3f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbddf1e40-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbddf1e41-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3254e"},"text":"section 3254e of this title","children":[],"tail":", prior to the general amendment of the Solid Waste Disposal Act by "},{"tag":"ref","attrib":{"href":"/us/pl/94/580"},"text":"Pub. L. 94–580","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbddf1e42-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “House Oversight” for “House Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482/s23/1"},"text":"Pub. L. 96–482, § 23(1)","children":[],"tail":", inserted reference to any unit of the legislative branch of the Federal Government."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482/s23/2"},"text":"Pub. L. 96–482, § 23(2)","children":[],"tail":", required any unit of the legislative branch of the Federal Government to insure compliance with solid waste disposal guidelines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/482/s23/3"},"text":"Pub. L. 96–482, § 23(3)","children":[],"tail":", required House Committee on House Administration and Senate Committee on Rules and Administration with regard to any unit of the legislative branch of the Federal Government to prescribe implementing regulations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/609/s7"},"text":"Pub. L. 95–609, § 7","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), (2), substituted “management” for “disposal” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/609/s7"},"text":"Pub. L. 95–609, § 7","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3), substituted “Administrator” for “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbddf1e43-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbddf1e44-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on House Oversight of House of Representatives changed to Committee on House Administration of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbddf1e45-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbddf1e46-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of certain enforcement functions of Administrator or other official of Environmental Protection Agency under this chapter to Federal Inspector, Office of Federal Inspector for the Alaska Natural Gas Transportation System, and subsequent transfer to Secretary of Energy, then to Federal Coordinator for Alaska Natural Gas Transportation Projects, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903"},"text":"section 6903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
