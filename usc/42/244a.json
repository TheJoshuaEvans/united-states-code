{"tag":"section","attrib":{"id":"idb49aad88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a"},"text":null,"children":[{"tag":"num","attrib":{"value":"244a"},"text":"§ 244a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials and resources to increase education and awareness of cardiomyopathy among school administrators, educators, and families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb49aad89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Materials and resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary, in consultation with the Director of the Centers for Disease Control and Prevention, shall develop public education materials and resources to be disseminated to school administrators, educators, school health professionals, coaches, families, guardians, caregivers, and other appropriate individuals. The materials and resources shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aad8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on the signs, symptoms, and risk factors associated with high-risk cardiac conditions and genetic heart rhythm abnormalities that may cause sudden cardiac arrest in children, adolescents, and young adults, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aad8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cardiomyopathy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aad8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long QT syndrome, Brugada syndrome, catecholaminergic polymorphic ventricular tachycardia, short QT syndrome, and Wolff-Parkinson-White syndrome; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aad8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other high-risk cardiac conditions, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aad8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines regarding the placement of automated external defibrillators in schools, early childhood education programs, and child care centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aad8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training information on automated external defibrillators and cardiopulmonary resuscitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aad90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for how schools, early childhood education programs, and child care centers can develop and implement a cardiac emergency response plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aad91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of materials and resources","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 months after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary shall disseminate the materials and resources developed under subsection (a) in accordance with the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aad92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution by State educational agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make available such materials and resources to State educational agencies to distribute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aad93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to school administrators, educators, school health professionals, coaches, families, guardians, caregivers, and other appropriate individuals, the information developed under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aad94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to parents, guardians, or other caregivers, the cardiomyopathy risk assessment developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s244b/b/1"},"text":"section 244b(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aad95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to school administrators, educators, school health professionals, and coaches—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb49aad96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines described in subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb49aad97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training information described in subsection (a)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb49aad98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations described in subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aad99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination to health departments and professionals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available the materials and resources developed under subsection (a) to State and local health departments, pediatricians, hospitals, and other health professionals, such as nurses and first responders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aad9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting on website","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aad9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CDC","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb49aad9c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, through the Director, shall post the materials and resources developed under subsection (a) on the public Internet website of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb49aad9d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director is encouraged to maintain on such public Internet website such additional information regarding cardiomyopathy as deemed appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aad9e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State educational agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State educational agencies are encouraged to create public Internet webpages dedicated to cardiomyopathy and post the materials and resources developed under subsection (a) on such webpages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb49aad9f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb49aada0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “cardiomyopathy” means a heart disease that affects the heart’s muscle (myocardium)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb49aada1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the symptoms of which may vary from case to case, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb49aada2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cases in which no symptoms are present (asymptomatic); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb49aada3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cases in which there are symptoms of a progressive condition that may result from an impaired ability of the heart to pump blood, such as fatigue, irregular heartbeats (arrhythmia), heart failure, and, potentially, sudden cardiac death; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb49aada4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recognized types of which include dilated, hypertrophic, restrictive, arrhythmogenic right ventricular dysplasia, and left ventricular non-compaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aada5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Director” means the Director of the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aada6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “early childhood education program”, “elementary school”, and “secondary school” have the meanings given to those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7801"},"text":"section 7801 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aada7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “school administrator” means a principal, director, manager, or other supervisor or leader within an elementary school, secondary school, State-based early childhood education program, or child care center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb49aada8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s244a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “school health professional” means a health professional serving at an elementary school, secondary school, State-based early childhood education program, or child care center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb49aada9-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title III, § 312A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/176/s2/a"},"text":"Pub. L. 118–176, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2605"},"text":"138 Stat. 2605","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb49aadaa-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb49aadab-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb49aadac-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 244a, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tIII/s312a"},"text":"act July 1, 1944, ch. 373, title III, § 312a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-31/ch1158/s2"},"text":"Aug. 31, 1954, ch. 1158, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1025"},"text":"68 Stat. 1025","children":[],"tail":", related to birth and death statistics, annual collection, and compensation for transcription, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/93/353/tI/s102/a"},"text":"Pub. L. 93–353, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-23"},"text":"July 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/362"},"text":"88 Stat. 362","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s242k/h/1"},"text":"section 242k(h)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
