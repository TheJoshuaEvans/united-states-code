{"tag":"section","attrib":{"id":"idb5713840-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e–5"},"text":"§ 285e–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research relevant to appropriate services for individuals with Alzheimer’s disease and related dementias and their families","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5713841-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall conduct, or make grants for the conduct of, research relevant to appropriate services for individuals with Alzheimer’s disease and related dementias and their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713842-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of plan; contents; revision","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5713843-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Within 6 months after ","children":[{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":", the Director of the Institute shall prepare and transmit to the Chairman of the Council on Alzheimer’s Disease (in this section referred to as the “Council”) a plan for the research to be conducted under subsection (a). The plan shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5713844-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for research concerning—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5713845-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the epidemiology of, and the identification of risk factors for, Alzheimer’s disease and related dementias; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5713846-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and evaluation of reliable and valid multidimensional diagnostic and assessment procedures and instruments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5713847-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that research carried out under the plan is coordinated with, and uses, to the maximum extent feasible, resources of, other Federal programs relating to Alzheimer’s disease and related dementias, including centers supported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2"},"text":"section 285e–2 of this title","children":[],"tail":", centers supported by the National Institute of Mental Health on the psychopathology of the elderly, relevant activities of the Administration on Aging, other programs and centers involved in research on Alzheimer’s disease and related dementias supported by the Department, and other programs relating to Alzheimer’s disease and related dementias which are planned or conducted by Federal agencies other than the Department, State or local agencies, community organizations, or private foundations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5713848-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within one year after transmitting the plan required under paragraph (1), and annually thereafter, the Director of the Institute shall prepare and transmit to the Chairman of the Council such revisions of such plan as the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5713849-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation for preparation and revision of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing and revising the plan required by subsection (b), the Director of the Institute shall consult with the Chairman of the Council and the heads of agencies within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb571384a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for promoting independence and preventing secondary disabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"the ","children":[{"tag":"ref","attrib":{"idref":"fn002190"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002190"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" Director of the Institute may develop, or make grants to develop—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb571384b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" model techniques to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb571384c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote greater independence, including enhanced independence in performing activities of daily living and instrumental activities of daily living, for persons with Alzheimer’s disease and related disorders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571384d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or reduce the severity of secondary disabilities, including confusional episodes, falls, bladder and bowel incontinence, and adverse effects of prescription and over-the-counter medications, in such persons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb571384e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" model curricula for health care professionals, health care paraprofessionals, and family caregivers, for training and application in the use of such techniques.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb571384f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285e–5/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Council on Alzheimer’s Disease” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Council on Alzheimer’s Disease” means the council established in section 11211(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002191"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002191"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5713850-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 445C, formerly "},{"tag":"ref","attrib":{"href":"/us/pl/99/660/tIX/s941"},"text":"Pub. L. 99–660, title IX, § 941","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3808"},"text":"100 Stat. 3808","children":[],"tail":"; renumbered § 445C of act "},{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", and amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/607/tI/s142/a"},"text":"Pub. L. 100–607, title I, § 142(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"1988-11-04"},"text":"Nov. 4, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3057"},"text":"102 Stat. 3057","children":[],"tail":", 3058; "},{"tag":"ref","attrib":{"href":"/us/pl/102/507/s9"},"text":"Pub. L. 102–507, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3287"},"text":"106 Stat. 3287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/43/tVIII/s804"},"text":"Pub. L. 103–43, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-10"},"text":"June 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/164"},"text":"107 Stat. 164","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5713851-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5713852-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5713853-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11211"},"text":"Section 11211 of this title","children":[],"tail":", referred to in subsec. (e), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tVI/s601/a/2/E"},"text":"Pub. L. 105–362, title VI, § 601(a)(2)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3286"},"text":"112 Stat. 3286","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5713854-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11241"},"text":"section 11241 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/100/607"},"text":"Pub. L. 100–607","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5713855-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s804/1"},"text":"Pub. L. 103–43, § 804(1)","children":[],"tail":", inserted “on Alzheimer’s Disease (in this section referred to as the ‘Council’)” after “Council”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/43/s804/2"},"text":"Pub. L. 103–43, § 804(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/507"},"text":"Pub. L. 102–507","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/a"},"text":"Pub. L. 100–607, § 142(a)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11241"},"text":"section 11241 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/2/A"},"text":"Pub. L. 100–607, § 142(d)(2)(A)","children":[],"tail":", substituted “the Institute” for “the National Institute on Aging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/2/B/i/I"},"text":"Pub. L. 100–607, § 142(d)(2)(B)(i)(I)","children":[],"tail":", in introductory provisions, substituted “the date of enactment of the Alzheimer’s Disease and Related Dementias Services Research Act of 1986” for “the date of enactment of this Act”, which for purposes of codification was translated as “"},{"tag":"date","attrib":{"date":"1986-11-14"},"text":"November 14, 1986","children":[],"tail":"”, thus requiring no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/2/B/i/II"},"text":"Pub. L. 100–607, § 142(d)(2)(B)(i)(II)","children":[],"tail":", in introductory provisions, substituted “the Institute” for “the National Institute on Aging”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/2/B/ii"},"text":"Pub. L. 100–607, § 142(d)(2)(B)(ii)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s285e–2"},"text":"section 285e–2 of this title","children":[],"tail":" to correct reference to corresponding provision of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(2), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/607/s142/d/2/B/iii"},"text":"Pub. L. 100–607, § 142(d)(2)(B)(iii)","children":[],"tail":", (C), substituted “the Institute” for “the National Institute on Aging”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
