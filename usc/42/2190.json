{"tag":"section","attrib":{"id":"idbbffd646-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2190"},"text":null,"children":[{"tag":"num","attrib":{"value":"2190"},"text":"§ 2190.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Saving clause for prior patent applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any patent application on which a patent was denied by the United States Patent and Trademark Office under sections 1811(a)(1), 1811(a)(2), or 1811(b) ","children":[{"tag":"ref","attrib":{"idref":"fn003267"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and which is not prohibited by section 2181 or 2185 of this title may be reinstated upon application to the Commissioner of Patents and Trademarks within one year after "},{"tag":"date","attrib":{"date":"1954-08-30"},"text":"August 30, 1954","children":[],"tail":" and shall then be deemed to have been continuously pending since its original filing date: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no patent issued upon any patent application so reinstated shall in any way furnish a basis of claim against the Government of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbbffd647-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 160, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/948"},"text":"68 Stat. 948","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/596/s3"},"t