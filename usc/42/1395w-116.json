{"tag":"section","attrib":{"id":"idb95aa764-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116"},"text":null,"children":[{"tag":"num","attrib":{"value":"1395w–116"},"text":"§ 1395w–116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicare Prescription Drug Account in the Federal Supplementary Medical Insurance Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb95aa765-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and operation of Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa766-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is created within the Federal Supplementary Medical Insurance Trust Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395t"},"text":"section 1395t of this title","children":[],"tail":" an account to be known as the “Medicare Prescription Drug Account” (in this section referred to as the “Account”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa767-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Account shall consist of such gifts and bequests as may be made as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401/i/1"},"text":"section 401(i)(1) of this title","children":[],"tail":", accrued interest on balances in the Account, and such amounts as may be deposited in, or appropriated to, such Account as provided in this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa768-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate from rest of Trust Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this part to the Account shall be kept separate from all other funds within the Federal Supplementary Medical Insurance Trust Fund, but shall be invested, and such investments redeemed, in the same manner as all other funds and investments within such Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa769-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments from Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa76a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Managing Trustee shall pay from time to time from the Account such amounts as the Secretary certifies are necessary to make payments to operate the program under this part, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb95aa76b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114"},"text":"section 1395w–114 of this title","children":[],"tail":" (relating to low-income subsidy payments);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa76c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–115"},"text":"section 1395w–115 of this title","children":[],"tail":" (relating to subsidy payments and payments for fallback plans);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa76d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments to sponsors of qualified retiree prescription drug plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–132/a"},"text":"section 1395w–132(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa76e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments with respect to administrative expenses under this part in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401/g"},"text":"section 401(g) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb95aa76f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–114d"},"text":"section 1395w–114d of this title","children":[],"tail":" (relating to selected drug subsidy payments)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa770-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to Medicaid account for increased administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Managing Trustee shall transfer from time to time from the Account to the Grants to States for Medicaid account amounts the Secretary certifies are attributable to increases in payment resulting from the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396u–5/b"},"text":"section 1396u–5(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa771-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments of premiums withheld","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Managing Trustee shall make payment to the PDP sponsor or MA organization involved of the premiums (and the portion of late enrollment penalties) that are collected in the manner described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–24/d/2/A"},"text":"section 1395w–24(d)(2)(A) of this title","children":[],"tail":" and that are payable under a prescription drug plan or MA–PD plan offered by such sponsor or organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa772-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment in relation to part B premium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts payable from the Account shall not be taken into account in computing actuarial rates or premium amounts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395r"},"text":"section 1395r of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb95aa773-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits into Account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb95aa774-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-income transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1396u–5/c"},"text":"section 1396u–5(c) of this title","children":[],"tail":" (and any amounts collected or offset under paragraph (1)(C) of such section) are deposited into the Account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa775-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts withheld","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to sections 1395w–113(c) and 1395w–24(d) of this title (as applied under this part), amounts that are withheld (and allocated) to the Account are deposited into the Account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa776-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations to cover Government contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated from time to time, out of any moneys in the Treasury not otherwise appropriated, to the Account, an amount equivalent to the amount of payments made from the Account under subsection (b) plus such amounts as the Managing Trustee certifies is necessary to maintain an appropriate contingency margin, reduced by the amounts deposited under paragraph (1) or subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa777-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial funding and reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assure prompt payment of benefits provided under this part and the administrative expenses thereunder during the early months of the program established by this part and to provide an initial contingency reserve, there are authorized to be appropriated to the Account, out of any moneys in the Treasury not otherwise appropriated, such amount as the Secretary certifies are required, but not to exceed 10 percent of the estimated total expenditures from such Account in 2006.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb95aa778-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1395w–116/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of any remaining balance from Transitional Assistance Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any balance in the Transitional Assistance Account that is transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395w–141/k/5"},"text":"section 1395w–141(k)(5) of this title","children":[],"tail":" shall be deposited into the Account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb95aa779-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XVIII, § 1860D–16, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/173/tI/s101/a/2"},"text":"Pub. L. 108–173, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-08"},"text":"Dec. 8, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2120"},"text":"117 Stat. 2120","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/169/tI/s11201/c/3"},"text":"Pub. L. 117–169, title I, § 11201(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-16"},"text":"Aug. 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1888"},"text":"136 Stat. 1888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb95aa77a-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb95aa77b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb95aa77c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/169"},"text":"Pub. L. 117–169","children":[],"tail":" added subpar. (E)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
