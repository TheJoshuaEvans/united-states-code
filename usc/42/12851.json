{"tag":"section","attrib":{"id":"idbfa42635-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851"},"text":null,"children":[{"tag":"num","attrib":{"value":"12851"},"text":"§ 12851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Homeownership Trust","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa42636-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the National Homeownership Trust, which shall be in the Department of Housing and Urban Development and shall provide assistance to first-time homebuyers in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42637-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Trust shall be governed by a Board of Directors, which shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa42638-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Housing and Urban Development, who shall be the chairperson of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42639-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4263a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairperson of the Board of Directors of the Federal Deposit Insurance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4263b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairperson of the Federal Housing Finance Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4263c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairperson of the Board of Directors of the Federal National Mortgage Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4263d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairperson of the Board of Directors of the Federal Home Loan Mortgage Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa4263e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 individual representing consumer interests, who shall be appointed by the President of the United States, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa4263f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Trust","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trust shall have the same powers as the powers given the Government National Mortgage Association in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1723a/a"},"text":"section 1723a(a) of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42640-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and per diem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board of Directors shall receive no additional compensation by reason of service on the Board, but shall be allowed travel expenses, including per diem in lieu of subsistence, as provided for employees of the Federal Government or in the same manner as persons employed intermittently in the Government service are allowed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa42641-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director and staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa42642-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Directors may appoint an executive director of the Trust and fix the compensation of the executive director, which shall be paid from amounts in the National Homeownership Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa42643-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12851/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to such rules as the Board of Directors may prescribe, the Trust may appoint and hire such staff and provide for offices as may be necessary to carry out its duties. The Trust may fix the compensation of the staff, which shall be paid from amounts in the National Homeownership Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfa42644-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625/tIII/s302"},"text":"Pub. L. 101–625, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4129"},"text":"104 Stat. 4129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfa42645-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfa42646-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbfa42647-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this subchapter as the “National Homeownership Trust Act”, see Short Title note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12701"},"text":"section 12701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
