{"tag":"section","attrib":{"id":"idb80f140c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1109"},"text":null,"children":[{"tag":"num","attrib":{"value":"1109"},"text":"§ 1109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Employees Compensation Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established in the Unemployment Trust Fund a Federal Employees Compensation Account which shall be used for the purposes specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8509"},"text":"section 8509 of title 5","children":[],"tail":". For the purposes provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1104/e"},"text":"section 1104(e) of this title","children":[],"tail":", such account shall be maintained as a separate book account."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb80f140d-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title IX, § 909, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/499/tX/s1023/a"},"text":"Pub. L. 96–499, title X, § 1023(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2657"},"text":"94 Stat. 2657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb80f140e-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb80f140f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb80f1410-3a70-11f1-ae07-e4213316