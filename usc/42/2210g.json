{"tag":"section","attrib":{"id":"idbc0bbd14-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2210g"},"text":"§ 2210g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses authorized to be paid by the Commission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbc0bbd15-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay transportation, lodging, and subsistence expenses of employees who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbc0bbd16-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist scientific, professional, administrative, or technical employees of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbc0bbd17-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are students in good standing at an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":") pursuing courses related to the field in which the students are employed by the Commission; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbc0bbd18-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2210g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the costs of health and medical services furnished, pursuant to an agreement between the Commission and the Department of State, to employees of the Commission and dependents of the employees serving in foreign countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbc0bbd19-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 170G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVI/s651/c/3"},"text":"Pub. L. 109–58, title VI, § 651(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/801"},"text":"119 Stat. 801","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
