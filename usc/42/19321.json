{"tag":"section","attrib":{"id":"idc08b7966-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321"},"text":null,"children":[{"tag":"num","attrib":{"value":"19321"},"text":"§ 19321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special hiring authority for scientific, engineering, and project management personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc08b7967-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary for Science shall have the authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b7968-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make appointments of not more than 60 scientific, engineering, and professional personnel, without regard to civil service laws, to assist the Department in meeting specific project or research needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7969-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the basic pay of any employee appointed under this section at a rate to be determined by the Under Secretary at rates not in excess of Level II of the Executive Schedule (EX–II) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5311"},"text":"section 5311 of title 5","children":[],"tail":" without regard to the civil service laws; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b796a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay any employee appointed under this section payments in addition to basic pay, except that the total amount of additional payments paid to an employee under this subsection for any 12-month period shall not exceed the lesser of the following amounts:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc08b796b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08b796c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount equal to 25 percent of the annual rate of basic pay of that employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc08b796d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the limitation that is applicable for a calendar year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5307/a/1"},"text":"section 5307(a)(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc08b796e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08b796f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of any employee appointed under this section shall not exceed 3 years unless otherwise authorized in law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08b7970-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Science shall have the authority to terminate any employee appointed under this section at any time based on performance or changing project or research needs of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08b7971-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tVI/s10726"},"text":"Pub. L. 117–167, div. B, title VI, § 10726","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1710"},"text":"136 Stat. 1710","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
