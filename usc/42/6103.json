{"tag":"section","attrib":{"id":"idbd6a3c59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd6a3c5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register of proposed general regulations, final general regulations, and anti-discrimination regulations; effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6a3c5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than one year after the transmission of the report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6106/b"},"text":"section 6106(b) of this title","children":[],"tail":", or two and one-half years after "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"November 28, 1975","children":[],"tail":", whichever occurs first, the Secretary of Health and Human Services shall publish in the Federal Register proposed general regulations to carry out the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6a3c5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6a3c5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall not publish such proposed general regulations until the expiration of a period comprised of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd6a3c5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forty-five day period specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6106/e"},"text":"section 6106(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd6a3c5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an additional forty-five day period, immediately following the period described in clause (i), during which any committee of the Congress having jurisdiction over the subject matter involved may conduct hearings with respect to the report which the Commission is required to transmit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6106/d"},"text":"section 6106(d) of this title","children":[],"tail":", and with respect to the comments and recommendations submitted by Federal departments and agencies under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6106/e"},"text":"section 6106(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6a3c60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The forty-five day period specified in subparagraph (A)(ii) shall include only days during which both Houses of the Congress are in session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6a3c61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ninety days after the Secretary publishes proposed regulations under paragraph (1), the Secretary shall publish in the Federal Register final general regulations to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":", after taking into consideration any comments received by the Secretary with respect to the regulations proposed under paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6a3c62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ninety days after the Secretary publishes final general regulations under paragraph (a)(3), the head of each Federal department or agency which extends Federal financial assistance to any program or activity by way of grant, entitlement, loan, or contract other than a contract of insurance or guaranty, shall transmit to the Secretary and publish in the Federal Register proposed regulations to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":" and to provide appropriate investigative, conciliation, and enforcement procedures. Such regulations shall be consistent with the final general regulations issued by the Secretary, and shall not become effective until approved by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6a3c63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section, no regulations issued pursuant to this section shall be effective before ","children":[{"tag":"date","attrib":{"date":"1979-07-01"},"text":"July 1, 1979","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6a3c64-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonviolative actions; program or activity exemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6a3c65-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall not be a violation of any provision of this chapter, or of any regulation issued under this chapter, for any person to take any action otherwise prohibited by the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6102"},"text":"section 6102 of this title","children":[],"tail":" if, in the program or activity involved—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6a3c66-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such action reasonably takes into account age as a factor necessary to the normal operation or the achievement of any statutory objective of such program or activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6a3c67-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the differentiation made by such action is based upon reasonable factors other than age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6a3c68-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this chapter shall not apply to any program or activity established under authority of any law which (A) provides any benefits or assistance to persons based upon the age of such persons; or (B) establishes criteria for participation in age-related terms or describes intended beneficiaries or target groups in such terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6a3c69-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment practices and labor-management joint apprenticeship training program exemptions; Age Discrimination in Employment Act unaffected","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6a3c6a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed to authorize action under this chapter by any Federal department or agency with respect to any employment practice of any employer, employment agency, or labor organization, or with respect to any labor-management joint apprenticeship training program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6a3c6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed to amend or modify the Age Discrimination in Employment Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s621–634"},"text":"29 U.S.C. 621–634","children":[],"tail":"), as amended, or to affect the rights or responsibilities of any person or party pursuant to such Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd6a3c6c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135/tIII/s304"},"text":"Pub. L. 94–135, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/729"},"text":"89 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/tIV/s401/b"},"text":"Pub. L. 95–478, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-18"},"text":"Oct. 18, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1555"},"text":"92 Stat. 1555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/300/tI/s183"},"text":"Pub. L. 97–300, title I, § 183","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-13"},"text":"Oct. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1357"},"text":"96 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/f/tVIII/s405/d/37"},"text":"Pub. L. 105–277, div. A, § 101(f) [title VIII, § 405(d)(37)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-337"},"text":"112 Stat. 2681–337","children":[],"tail":", 2681–427.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd6a3c6d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd6a3c6e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd6a3c6f-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Age Discrimination in Employment Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s621–634"},"text":"29 U.S.C. 621–634","children":[],"tail":"), as amended, referred to in subsec. (c)(2), is "},{"tag":"ref","attrib":{"href":"/us/pl/90/202"},"text":"Pub. L. 90–202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-15"},"text":"Dec. 15, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/602"},"text":"81 Stat. 602","children":[],"tail":", which is classified generally to chapter 14 (§ 621 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s621"},"text":"section 621 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd6a3c70-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “Nothing” for “Except with respect to any program or activity receiving Federal financial assistance for public service employment under the Job Training Partnership Act, nothing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/478/s401/b/1"},"text":"Pub. L. 95–478, § 401(b)(1)","children":[],"tail":", provided that the regulations shall not become effective until approved by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/478/s401/b/2"},"text":"Pub. L. 95–478, § 401(b)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1979-07-01"},"text":"July 1, 1979","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd6a3c71-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd6a3c72-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsec. (a)(1) pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd6a3c73-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/478"},"text":"Pub. L. 95–478","children":[],"tail":" effective at the close of "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/478/s504"},"text":"section 504 of Pub. L. 95–478","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3001"},"text":"section 3001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
