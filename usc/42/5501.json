{"tag":"section","attrib":{"id":"idbd54b89f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501"},"text":null,"children":[{"tag":"num","attrib":{"value":"5501"},"text":"§ 5501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd54b8a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress hereby finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd54b8a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current imbalance between supply and demand for fuels and energy is likely to persist for some time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the early demonstration of the feasibility of using solar energy for the heating and cooling of buildings could help to relieve the demand upon present fuel and energy supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technologies for solar heating are close to the point of commercial application in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technologies for combined solar heating and cooling still require research, development, testing and demonstration, but no insoluble technical problem is now foreseen in achieving commercial use of such technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the early development and export of viable solar heating equipment and combined solar heating and cooling equipment, consistent with the established preeminence of the United States in the field of high technology products, can make a valuable contribution to our balance of trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the widespread use of solar energy in place of conventional methods for the heating and cooling of buildings would have a significantly beneficial effect upon the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mass production and use of solar heating and cooling equipment will help to eliminate the dependence of the United States upon foreign energy sources and promote the national defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the widespread introduction of low-cost solar energy will be beneficial to consumers in a period of rapidly rising fuel cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8a9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovation and creativity in the development of solar heating and combined solar heating and cooling components and systems can be fostered through encouraging direct contact between the manufacturers of such systems and the architects, engineers, developers, contractors, and other persons interested in installing such systems in buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8aa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation of the performance and reliability of solar heating and combined solar heating and cooling technologies can be expedited by testing under carefully controlled conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd54b8ab-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial application of solar heating and combined solar heating and cooling technologies can be expedited by early commercial demonstration under practical conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd54b8ac-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s5501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is therefore declared to be the policy of the United States and the purpose of this subchapter to provide for the demonstration within a three-year period of the practical use of solar heating technology, and to provide for the development and demonstration within a five-year period of the practical use of combined heating and cooling technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd54b8ad-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/409/s2"},"text":"Pub. L. 93–409, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-03"},"text":"Sept. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1069"},"text":"88 Stat. 1069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd54b8ae-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd54b8af-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd54b8b0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/590/s1"},"text":"Pub. L. 95–590, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2513"},"text":"92 Stat. 2513","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/pl/95/590"},"text":"Pub. L. 95–590","children":[],"tail":" (enacting subchapter III of this chapter) could be cited as the “Solar Photovoltaic Energy Research, Development, and Demonstration Act of 1978”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3006/f"},"text":"Pub. L. 116–260, div. Z, title III, § 3006(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2513"},"text":"134 Stat. 2513","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbd54b8b1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/473/s1"},"text":"Pub. L. 93–473, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1431"},"text":"88 Stat. 1431","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/pl/93/473"},"text":"Pub. L. 93–473","children":[],"tail":" (enacting subchapter II of this chapter) could be cited as the “Solar Energy Research, Development, and Demonstration Act of 1974”, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dZ/tIII/s3006/e/1"},"text":"Pub. L. 116–260, div. Z, title III, § 3006(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2513"},"text":"134 Stat. 2513","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/409/s1"},"text":"Pub. L. 93–409, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-03"},"text":"Sept. 3, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1069"},"text":"88 Stat. 1069","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/409/s1"},"text":"“That this Act [enacting this subchapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2473"},"text":"section 2473 of this title","children":[],"tail":"] may be cited as the ‘Solar Heating and Cooling Demonstration Act of 1974’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
