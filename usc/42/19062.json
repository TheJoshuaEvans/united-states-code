{"tag":"section","attrib":{"id":"idc0786657-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19062"},"text":null,"children":[{"tag":"num","attrib":{"value":"19062"},"text":"§ 19062.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accelerating unmanned maritime systems technologies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc0786658-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19062/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to support advances in marine science, maritime domain awareness, and national security the Director, in consultation with the Under Secretary of Commerce for Oceans and Atmosphere and the Commandant of the Coast Guard, shall issue awards, on a competitive basis, to institutions of higher education or nonprofit organizations (or consortia of such institutions or organizations) to support research that will accelerate innovation to advance unmanned maritime systems for the purpose of providing greater maritime domain awareness to the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0786659-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19062/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In implementing this section, the Director shall coordinate with the Coast Guard, the Department of Defense, the National Oceanic and Atmospheric Administration, and other Federal agencies, including those established under the Commercial Engagement Through Ocean Technology Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394"},"text":"Public Law 115–394","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4101"},"text":"33 U.S.C. 4101","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc078665a-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tIII/s10353"},"text":"Pub. L. 117–167, div. B, title III, § 10353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1561"},"text":"136 Stat. 1561","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc078665b-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc078665c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc078665d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commercial Engagement Through Ocean Technology Act of 2018, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/394"},"text":"Pub. L. 115–394","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5281"},"text":"132 Stat. 5281","children":[],"tail":", also known as the CENOTE Act of 2018, which is classified generally to chapter 54 (§ 4101 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Short title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s4101"},"text":"section 4101 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
