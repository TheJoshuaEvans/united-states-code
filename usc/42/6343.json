{"tag":"section","attrib":{"id":"idbd99fe83-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343"},"text":null,"children":[{"tag":"num","attrib":{"value":"6343"},"text":"§ 6343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waste energy recovery incentive grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd99fe84-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish in the Department of Energy a waste energy recovery incentive grant program to provide incentive grants to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe85-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owners and operators of projects that successfully produce electricity or incremental useful thermal energy from waste energy recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe86-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilities purchasing or distributing the electricity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe87-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States that have achieved 80 percent or more of recoverable waste heat recovery opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe88-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to projects and utilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe89-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe8a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the owners or operators of waste energy recovery projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe8b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of excess power purchased or transmitted by a electric utility, to the utility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe8c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants may only be made under this section on receipt of proof of waste energy recovery or excess electricity generation, or both, from the project in a form prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe8d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess electric energy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe8e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of waste energy recovery, a grant under this section shall be made at the rate of $10 per megawatt hour of documented electricity produced from recoverable waste energy (or by prevention of waste energy in the case of a new facility) by the project during the first 3 calendar years of production, beginning on or after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe8f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the project produces net excess power and an electric utility purchases or transmits the excess power, 50 percent of so much of the grant as is attributable to the net excess power shall be paid to the electric utility purchasing or transporting the net excess power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe90-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Useful thermal energy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of waste energy recovery that produces useful thermal energy that is used for a purpose different from that for which the project is principally designed, a grant under this section shall be made to the owner or operator of the waste energy recovery project at the rate of $10 for each 3,412,000 Btus of the excess thermal energy used for the different purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe91-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any State that has achieved 80 percent or more of waste heat recovery opportunities identified by the Secretary under this part, the Administrator shall make a 1-time grant to the State in an amount of not more than $1,000 per megawatt of waste-heat capacity recovered (or a thermal equivalent) to support State-level programs to identify and achieve additional energy efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe92-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe93-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish rules and guidelines to establish eligibility for grants under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe94-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicize the availability of the grant program known to owners or operators of recoverable waste energy sources and sites listed on the Registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe95-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants under the program on the basis of the merits of each project in recovering or preventing waste energy throughout the United States on an impartial, objective, and not unduly discriminatory basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe96-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not award grants to any person for a combined heat and power project or a waste heat recovery project that qualifies for specific Federal tax incentives for combined heat and power or for waste heat recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd99fe97-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd99fe98-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to make grants to projects and utilities under subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd99fe99-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2008 and $200,000,000 for each of fiscal years 2009 through 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd99fe9a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional amounts for fiscal year 2008 and each fiscal year thereafter as may be necessary for administration of the waste energy recovery incentive grant program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd99fe9b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s6343/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants to States under subsection (b), $10,000,000 for each of fiscal years 2008 through 2012, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd99fe9c-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s373"},"text":"Pub. L. 94–163, title III, § 373","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s451/a"},"text":"Pub. L. 110–140, title IV, § 451(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1627"},"text":"121 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd99fe9d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd99fe9e-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd99fe9f-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6343, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/163/tIII/s373"},"text":"Pub. L. 94–163, title III, § 373","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/936"},"text":"89 Stat. 936","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/619/tVI"},"text":"Pub. L. 95–619, title VI","children":[],"tail":", §§ 601(a), 691(b)(2), "},{"tag":"date","attrib":{"date":"1978-11-09"},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3282"},"text":"92 Stat. 3282","children":[],"tail":", 3288, related to identification of major energy-consuming industries and corporations in the United States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIII/s3101/b"},"text":"Pub. L. 99–509, title III, § 3101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1888"},"text":"100 Stat. 1888","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd99fea0-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd99fea1-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
