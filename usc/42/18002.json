{"tag":"section","attrib":{"id":"idc043e86f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002"},"text":null,"children":[{"tag":"num","attrib":{"value":"18002"},"text":"§ 18002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinsurance for early retirees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc043e870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc043e871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-03-23"},"text":"March 23, 2010","children":[],"tail":", the Secretary shall establish a temporary reinsurance program to provide reimbursement to participating employment-based plans for a portion of the cost of providing health insurance coverage to early retirees (and to the eligible spouses, surviving spouses, and dependents of such retirees) during the period beginning on the date on which such program is established and ending on "},{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc043e873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “health benefits” means medical, surgical, hospital, prescription drug, and such other benefits as shall be determined by the Secretary, whether self-funded, or delivered through the purchase of insurance or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment-based plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employment-based plan” means a group benefits plan providing health benefits that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idc043e875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idc043e876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintained by one or more current or former employers (including without limitation any State or local government or political subdivision thereof or any agency or instrumentality of any of the foregoing), employee organization, a voluntary employees’ beneficiary association, or a committee or board of individuals appointed to administer such plan; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idc043e877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multiemployer plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002/37"},"text":"section 1002(37) of title 29","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idc043e878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides health benefits to early retirees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early retirees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “early retirees” means individuals who are age 55 and older but are not eligible for coverage under title XVIII of the Social Security Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1395"},"text":"42 U.S.C. 1395","children":[],"tail":" et seq.], and who are not active employees of an employer maintaining, or currently contributing to, the employment-based plan or of any employer that has made substantial contributions to fund such plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e87a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc043e87b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment-based plan eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participating employment-based plan is an employment-based plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc043e87c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of paragraph (2) with respect to health benefits provided under the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e87d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the Secretary an application for participation in the program, at such time, in such manner, and containing such information as the Secretary shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e87e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment-based health benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employment-based plan meets the requirements of this paragraph if the plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc043e87f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implements programs and procedures to generate cost-savings with respect to participants with chronic and high-cost conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides documentation of the actual cost of medical claims involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e882-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc043e883-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of claims","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc043e884-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating employment-based plan shall submit claims for reimbursement to the Secretary which shall contain documentation of the actual costs of the items and services for which each claim is being submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e885-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for claims","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims submitted under subparagraph (A) shall be based on the actual amount expended by the participating employment-based plan involved within the plan year for the health benefits provided to an early retiree or the spouse, surviving spouse, or dependent of such retiree. In determining the amount of a claim for purposes of this subsection, the participating employment-based plan shall take into account any negotiated price concessions (such as discounts, direct or indirect subsidies, rebates, and direct or indirect remunerations) obtained by such plan with respect to such health benefit. For purposes of determining the amount of any such claim, the costs paid by the early retiree or the retiree’s spouse, surviving spouse, or dependent in the form of deductibles, co-payments, or co-insurance shall be included in the amounts paid by the participating employment-based plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e886-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a participating employment-based plan has submitted a valid claim under paragraph (1), the Secretary shall reimburse such plan for 80 percent of that portion of the costs attributable to such claim that exceed $15,000, subject to the limits contained in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e887-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for reimbursement under the program, a claim submitted by a participating employment-based plan shall not be less than $15,000 nor greater than $90,000. Such amounts shall be adjusted each fiscal year based on the percentage increase in the Medical Care Component of the Consumer Price Index for all urban consumers (rounded to the nearest multiple of $1,000) for the year involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e888-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts paid to a participating employment-based plan under this subsection shall be used to lower costs for the plan. Such payments may be used to reduce premium costs for an entity described in subsection (a)(2)(B)(i) or to reduce premium contributions, co-payments, deductibles, co-insurance, or other out-of-pocket costs for plan participants. Such payments shall not be used as general revenues for an entity described in subsection (a)(2)(B)(i). The Secretary shall develop a mechanism to monitor the appropriate use of such payments by such entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e889-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments not treated as income","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments received under this subsection shall not be included in determining the gross income of an entity described in subsection (a)(2)(B)(i) that is maintaining or currently contributing to a participating employment-based plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc043e88a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc043e88b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appeals process to permit participating employment-based plans to appeal a determination of the Secretary with respect to claims submitted under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc043e88c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to protect against fraud, waste, and abuse under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e88d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct annual audits of claims data submitted by participating employment-based plans under this section to ensure that such plans are in compliance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e88e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is appropriated to the Secretary, out of any moneys in the Treasury not otherwise appropriated, $5,000,000,000 to carry out the program under this section. Such funds shall be available without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc043e88f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s18002/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary has the authority to stop taking applications for participation in the program based on the availability of funding under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc043e890-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI/s1102"},"text":"Pub. L. 111–148, title I, § 1102","children":[],"tail":", title X, § 10102(a), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/143"},"text":"124 Stat. 143","children":[],"tail":", 892.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idc043e891-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idc043e892-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idc043e893-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title XVIII of the Act is classified generally to subchapter XVIII (§ 1395 et seq.) of chapter 7 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idc043e894-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10102/a/1"},"text":"Pub. L. 111–148, § 10102(a)(1)","children":[],"tail":", substituted “group benefits plan providing health benefits” for “group health benefits plan” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10102/a/2"},"text":"Pub. L. 111–148, § 10102(a)(2)","children":[],"tail":", inserted “or any agency or instrumentality of any of the foregoing” after “political subdivision thereof”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
