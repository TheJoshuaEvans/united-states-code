{"tag":"section","attrib":{"id":"idc081dcb7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173"},"text":null,"children":[{"tag":"num","attrib":{"value":"19173"},"text":"§ 19173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunities for online education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc081dcb8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall make competitive awards to institutions of higher education or nonprofit organizations (or a consortium thereof, which may include a private sector partner) to conduct research on online STEM education courses for rural communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dcb9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The research areas eligible for funding under this subsection shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dcba-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the learning and achievement of rural students in prekindergarten through grade 12 in STEM subjects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dcbb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding how computer-based and online professional development courses and mentor experiences can be integrated to meet the needs of educators, principals, and other school leaders of rural students in prekindergarten through grade 12;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dcbc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combining computer-based and online STEM education and training with mentoring and other applied learning arrangements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dcbd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging online programs to supplement STEM studies for rural students that need physical and academic accommodation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dcbe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity the Director determines will accomplish the goals of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dcbf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All proposals for awards under this section shall include an evaluation plan that includes the use of outcome-oriented measures to assess the impact and efficacy of the award. Each recipient of an award under this subsection shall include results from these evaluative activities in annual and final projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dcc0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability and dissemination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc081dcc1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall evaluate the portfolio of awards made under this subsection. Such evaluation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc081dcc2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a common set of benchmarks and tools to assess the results of research conducted under such awards and identify best practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dcc3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, integrate findings from activities carried out pursuant to research conducted under this section, with respect to the pursuit of careers and degrees in STEM, with those activities carried out pursuant to other research on serving rural students and communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc081dcc4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on evaluations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the completion of the evaluation under paragraph (1), the Director shall submit to Congress and make widely available to the public a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc081dcc5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc081dcc6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for administrative and legislative action that could optimize the effectiveness of the awards made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc081dcc7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19173/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Director shall, for purposes of enhancing program effectiveness and avoiding duplication of activities, consult, cooperate, and coordinate with the programs and policies of other relevant Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc081dcc8-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tV/s10513"},"text":"Pub. L. 117–167, div. B, title V, § 10513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1617"},"text":"136 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
