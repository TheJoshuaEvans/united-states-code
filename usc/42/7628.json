{"tag":"section","attrib":{"id":"idbe5d7521-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628"},"text":null,"children":[{"tag":"num","attrib":{"value":"7628"},"text":"§ 7628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration grant program for local governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbe5d7522-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe5d7523-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish a demonstration program under which the Administrator shall provide competitive grants to assist local governments (such as municipalities and counties), with respect to local government buildings—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe5d7524-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deploy cost-effective technologies and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7525-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve operational cost savings, through the application of cost-effective technologies and practices, as verified by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5d7526-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe5d7527-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of an activity carried out using a grant provided under this section shall be 40 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d7528-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may waive up to 100 percent of the local share of the cost of any grant under this section should the Administrator determine that the community is economically distressed, pursuant to objective economic criteria established by the Administrator in published guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5d7529-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant provided under this subsection shall not exceed $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d752a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe5d752b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"December 19, 2007","children":[],"tail":", the Administrator shall issue guidelines to implement the grant program established under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5d752c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines under paragraph (1) shall establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbe5d752d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for monitoring and verification of operational cost savings through the application of cost-effective technologies and practices reported by grantees under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d752e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards for grantees to implement training programs, and to provide technical assistance and education, relating to the retrofit of buildings using cost-effective technologies and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbe5d752f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that each local government that receives a grant under this section shall achieve facility-wide cost savings, through renovation of existing local government buildings using cost-effective technologies and practices, of at least 40 percent as compared to the baseline operational costs of the buildings before the renovation (as calculated assuming a 3-year, weather-normalized average).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7530-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with State and local law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section or any program carried out using a grant provided under this section supersedes or otherwise affects any State or local law, to the extent that the State or local law contains a requirement that is more stringent than the relevant requirement of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7531-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2007 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7532-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbe5d7533-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide annual reports to Congress on cost savings achieved and actions taken and recommendations made under this section, and any recommendations for further action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbe5d7534-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall issue a final report at the conclusion of the program, including findings, a summary of total cost savings achieved, and recommendations for further action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7535-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2012-09-30"},"text":"September 30, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbe5d7536-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s7628/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the terms “cost-effective technologies and practices” and “operating ","children":[{"tag":"ref","attrib":{"idref":"fn003726"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn003726"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “operational”."}],"tail":" cost savings” shall have the meanings defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s17061"},"text":"section 17061 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbe5d7537-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"July 14, 1955, ch. 360","children":[],"tail":", title III, § 329, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tIV/s493"},"text":"Pub. L. 110–140, title IV, § 493","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1652"},"text":"121 Stat. 1652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbe5d7538-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbe5d7539-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbe5d753a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
