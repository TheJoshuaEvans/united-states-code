{"tag":"section","attrib":{"id":"idbf06d4cc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902"},"text":null,"children":[{"tag":"num","attrib":{"value":"9902"},"text":"§ 9902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf06d4cd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity; family literacy services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbf06d4ce-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means an entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbf06d4cf-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is an eligible entity described in paragraph (1) (as in effect on the day before ","children":[{"tag":"date","attrib":{"date":"1998-10-27"},"text":"October 27, 1998","children":[],"tail":") as of the day before "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"October 27, 1998","children":[],"tail":", or is designated by the process described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9909"},"text":"section 9909 of this title","children":[],"tail":" (including an organization serving migrant or seasonal farmworkers that is so described or designated); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbf06d4d0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that has a tripartite board or other mechanism described in subsection (a) or (b), as appropriate, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9910"},"text":"section 9910 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbf06d4d1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family literacy services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “family literacy services” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9832"},"text":"section 9832 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poverty line","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “poverty line” means the official poverty line defined by the Office of Management and Budget based on the most recent data available from the Bureau of the Census. The Secretary shall revise annually (or at any shorter interval the Secretary determines to be feasible and desirable) the poverty line, which shall be used as a criterion of eligibility in the community services block grant program established under this chapter. The required revision shall be accomplished by multiplying the official poverty line by the percentage change in the Consumer Price Index for All Urban Consumers during the annual or other interval immediately preceding the time at which the revision is made. Whenever a State determines that it serves the objectives of the block grant program established under this chapter, the State may revise the poverty line to not to exceed 125 percent of the official poverty line otherwise applicable under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private, nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “private, nonprofit organization” includes a religious organization, to which the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9920"},"text":"section 9920 of this title","children":[],"tail":" shall apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf06d4d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s9902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, the United States Virgin Islands, American Samoa, and the Commonwealth of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf06d4d6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s673"},"text":"Pub. L. 97–35, title VI, § 673","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/285/tII/s201"},"text":"Pub. L. 105–285, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2729"},"text":"112 Stat. 2729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf06d4d7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbf06d4d8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbf06d4d9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9902, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tVI/s673"},"text":"Pub. L. 97–35, title VI, § 673","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/511"},"text":"95 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/115/s17/a/1"},"text":"Pub. L. 97–115, § 17(a)(1)","children"