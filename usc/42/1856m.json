{"tag":"section","attrib":{"id":"idbb817efb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1856m"},"text":"§ 1856m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb817efc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assume any and all liability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “assume any and all liability” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb817efd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the payment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbb817efe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any judgment, settlement, fine, penalty, or cost assessment (including prevailing party legal fees) associated with the applicable litigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbb817eff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cost incurred in handling the applicable litigation (including legal fees); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb817f00-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a Federal firefighter, arranging for, and paying the costs of, representation in the applicable litigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f01-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal firefighter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal firefighter” means an individual furnished by the Secretary of Agriculture or the Secretary of the Interior under an agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856n"},"text":"section 1856n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f02-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign fire organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign fire organization” means any foreign governmental, public, or private entity that has wildfire protection resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f03-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign firefighter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign firefighter” means an individual furnished by a foreign fire organization under an agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856n"},"text":"section 1856n of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f04-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wildfire” means any forest or range fire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb817f05-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1856m/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wildfire protection resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wildfire protection resources” means any personnel, supplies, equipment, or other resources required for wildfire presuppression and suppression activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb817f06-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/428/s2"},"text":"Pub. L. 100–428, § 2","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dE/tIV/s411/2"},"text":"Pub. L. 112–74, div. E, title IV, § 411(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1039"},"text":"125 Stat. 1039","children":[],"tail":".)"}],"ta