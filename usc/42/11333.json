{"tag":"section","attrib":{"id":"idbf4256b4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11333"},"text":null,"children":[{"tag":"num","attrib":{"value":"11333"},"text":"§ 11333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Federal Emergency Management Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbf4256b5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall provide the National Board with administrative support and act as Federal liaison to the National Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbf4256b6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific support activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbf4256b7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the National Board, upon request, the services of the legal counsel and Inspector General of the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256b8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign clerical personnel to the National Board on a temporary basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbf4256b9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s11333/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct audits of the National Board annually and at such other times as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbf4256ba-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/77/tIII/s303"},"text":"Pub. L. 100–77, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-07-22"},"text":"July 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/490"},"text":"101 Stat. 490","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbf4256bb-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbf4256bc-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbf4256bd-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Federal Emergency Management Agency, including the functions of the Under Secretary for Federal Emergency Management relating thereto, to the Federal Emergency Management Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s315/a/1"},"text":"section 315(a)(1) of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Emergency Management Agency, including the functions of the Director of the Federal Emergency Management Agency relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(1) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
