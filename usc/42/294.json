{"tag":"section","attrib":{"id":"idb5dca3f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294"},"text":null,"children":[{"tag":"num","attrib":{"value":"294"},"text":"§ 294.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5dca3f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance under this part, an academic institution shall use such assistance in collaboration with 2 or more disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5dca3f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall use assistance under this part to carry out innovative demonstration projects for strategic workforce supplementation activities as needed to meet national goals for interdisciplinary, community-based linkages. Such assistance may be used consistent with this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5dca3fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and support training programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for faculty development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for model demonstration programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the provision of stipends for fellowship trainees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5dca3ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s294/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for other activities that will produce outcomes consistent with the purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5dca400-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title VII, § 750, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/392/tI/s103"},"text":"Pub. L. 105–392, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","c