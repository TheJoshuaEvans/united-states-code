{"tag":"section","attrib":{"id":"idbbea524e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2132"},"text":null,"children":[{"tag":"num","attrib":{"value":"2132"},"text":"§ 2132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization and production facilities for industrial or commercial purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbbea524f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of licenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (b) and (c), or otherwise specifically authorized by law, any license hereafter issued for a utilization or production facility for industrial or commercial purposes shall be issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2133"},"text":"section 2133 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbea5250-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities constructed or operated under section 2134(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any license hereafter issued for a utilization or production facility for industrial or commercial purposes, the construction or operation of which was licensed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2134/b"},"text":"section 2134(b) of this title","children":[],"tail":" prior to enactment into law of this subsection, shall be issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2134/b"},"text":"section 2134(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbbea5251-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s2132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative Power Reactor Demonstration facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any license for a utilization or production facility for industrial or commercial purposes constructed or operated under an arrangement with the Commission entered into under the Cooperative Power Reactor Demonstration Program shall, except as otherwise specifically required by applicable law, be issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2134/b"},"text":"section 2134(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbbea5252-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"Aug. 1, 1946, ch. 724","children":[],"tail":", title I, § 102, as added "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/936"},"text":"68 Stat. 936","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/91/560/s3"},"text":"Pub. L. 91–560, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1472"},"text":"84 Stat. 1472","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/102/486/tIX/s902/a/8"},"text":"Pub. L. 102–486, title IX, § 902(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2944"},"text":"106 Stat. 2944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbbea5253-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbbea5254-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbbea5255-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/560"},"text":"Pub. L. 91–560","children":[],"tail":" substituted provisions authorizing Commission to issue licenses for a utilization or production facility for industrial or commercial purposes under section 2133, except that license may be issued under section 2134(b), for such utilization or production facility, construction or operation of which was licensed under section 2134(b) before "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"December 19, 1970","children":[],"tail":" or constructed or operated under an arrangement with Commission entered into under Cooperative Power Reactor Demonstration Program, for provisions authorizing Commission to issue licenses pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2133"},"text":"section 2133 of this title","children":[],"tail":" on a determination that such utilization or production facility has been sufficiently developed to be of practical value for industrial or commercial purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
