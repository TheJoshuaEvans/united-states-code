{"tag":"section","attrib":{"id":"idbfa8e21b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a"},"text":null,"children":[{"tag":"num","attrib":{"value":"12898a"},"text":"§ 12898a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise zone homeownership opportunity grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfa8e21c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e21d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage homeownership by families in the United States who are not otherwise able to afford homeownership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e21e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the redevelopment of economically depressed areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e21f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide better housing opportunities in federally approved and equivalent State-approved enterprise zones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e220-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e221-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Home","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “home” means any 1- to 4-family dwelling. Such term includes any dwelling unit in a condominium project or cooperative project consisting of not more than 4 dwelling units, any town house, and any manufactured home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e222-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metropolitan statistical area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “metropolitan statistical area” means a metropolitan statistical area as established by the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e223-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nonprofit organization” means a private nonprofit corporation, or other private nonprofit legal entity, that is approved by the Secretary as to financial responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e224-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e225-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Northern Mariana Islands, the Trust Territory of the Pacific Islands, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e226-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unit of general local government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unit of general local government” means any borough, city, county, parish, town, township, village, or other general purpose political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e227-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to nonprofit organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e228-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide assistance to nonprofit organizations to carry out enterprise zone homeownership opportunity programs to promote homeownership in federally approved and equivalent State-approved enterprise zones in accordance with the provisions of this section. Such assistance shall be made in the form of grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e229-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applications for assistance under this section shall be made in such form, and in accordance with such procedures, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e22a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible uses of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e22b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any nonprofit organization receiving assistance under this section shall use such assistance to provide loans to families purchasing homes constructed or rehabilitated in accordance with an enterprise zone homeownership opportunity program approved under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e22c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each loan made to a family under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e22d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be secured by a second mortgage held by the Secretary on the property involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e22e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in an amount not exceeding $15,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e22f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bear no interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e230-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be repayable to the Secretary upon the sales, lease, or other transfer of such property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e231-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e232-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance provided under this section may be used only in connection with an enterprise zone homeownership opportunity program of construction or rehabilitation of homes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e233-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Family need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each family purchasing a home under this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e234-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a family income on the date of such purchase that is not more than the median income for a family of 4 persons (adjusted for family size) in the metropolitan statistical area in which a federally approved or equivalent State-approved enterprise zone is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e235-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not have owned a home during the 3-year period preceding such purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e236-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Downpayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each family purchasing a home under this section shall make a downpayment of not less than 5 percent of the sale price of such home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e237-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leasing prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No family purchasing a home under this section may lease such home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e238-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions of assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e239-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No proposed enterprise zone homeownership opportunity program may be approved by the Secretary under this section unless the applicant involved demonstrates to the satisfaction of the Secretary that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e23a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it has consulted with and received the support of residents of the neighborhood in which such program is to be located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e23b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it has the approval of each unit of general local government in which such program is to be located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e23c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each applicant for assistance under this section shall submit to the Secretary an estimated schedule for completion of its proposed enterprise zone homeownership opportunity program, which schedule shall have been agreed to by each unit of general local government in which such program is to be located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e23d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All homes constructed or rehabilitated under such program will be located in federally approved or equivalent State-approved enterprise zones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e23e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sales contracts entered into under such program will contain provisions requiring repayment of any loan made under this section upon the sale or other transfer of the home involved, unless the Secretary approves a transfer of such home without repayment (in which case the second mortgage held by the Secretary on such home shall remain in force until such loan is fully repaid).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfa8e23f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program selection criteria","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfa8e240-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting enterprise zone homeownership opportunity programs for assistance under this section from among eligible programs, the Secretary shall make such selection on the basis of the extent to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbfa8e241-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal public or private entities will contribute land necessary to make each program feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e242-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal public and private financial or other contributions (including tax abatements, waivers of fees related to development, waivers of construction, development, or zoning requirements, and direct financial contributions) will reduce the cost of home ","children":[{"tag":"ref","attrib":{"idref":"fn004133"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004133"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “homes”."}],"tail":" constructed or rehabilitated under each program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e243-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each program will produce the greatest number of units for the least amount of assistance provided under this section, taking into consideration the cost differences among different market areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbfa8e244-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each program provides for the involvement of local residents in the planning, and construction or rehabilitation, of homes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfa8e245-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that non-Federal public entities are prohibited by the law of any State from making any form of contribution described in subparagraph (A) or (B) of paragraph (1), the Secretary shall not consider such form of contribution in evaluating such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab5246-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", the Secretary shall issue final regulations to carry out the provisions of this title."},{"tag":"ref","attrib":{"idref":"fn004134"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn004134"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “this section.”"}],"tail":" Any such regulations shall be issued in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", notwithstanding the provisions of subsection (a)(2) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfab5247-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s12898a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $30,000,000 in each of fiscal years 1993 and 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfab5248-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tI/s186"},"text":"Pub. L. 102–550, title I, § 186","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3748"},"text":"106 Stat. 3748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfab5249-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfab524a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbfab524b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Housing and Community Development Act of 1992, and not as part of subtitle C (§§ 441–448) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/625"},"text":"Pub. L. 101–625","children":[],"tail":" which comprises this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbfab524c-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbfab524d-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
