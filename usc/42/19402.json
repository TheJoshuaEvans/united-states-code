{"tag":"section","attrib":{"id":"idc08dea6b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19402"},"text":null,"children":[{"tag":"num","attrib":{"value":"19402"},"text":"§ 19402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc08dea6c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nondisclosure clause” means a provision in a contract or agreement that requires the parties to the contract or agreement not to disclose or discuss conduct, the existence of a settlement involving conduct, or information covered by the terms and conditions of the contract or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea6d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisparagement clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “nondisparagement clause” means a provision in a contract or agreement that requires 1 or more parties to the contract or agreement not to make a negative statement about another party that relates to the contract, agreement, claim, or case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea6e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault dispute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual assault dispute” means a dispute involving a nonconsensual sexual act or sexual contact, as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2246"},"text":"section 2246 of title 18","children":[],"tail":" or similar applicable Tribal or State law, including when the victim lacks capacity to consent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc08dea6f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s19402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual harassment dispute","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual harassment dispute” means a dispute relating to conduct that is alleged to constitute sexual harassment under applicable Federal, Tribal, or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc08dea70-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/224/s3"},"text":"Pub. L. 117–224, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-07"},"text":"Dec. 7, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2290"},"text":"136 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
