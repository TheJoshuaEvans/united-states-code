{"tag":"section","attrib":{"id":"idbaaf8941-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"1397n–10"},"text":"§ 1397n–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Website","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Federal Interagency Council on Social Impact Partnerships shall establish and maintain a public website that shall display the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbaaf8942-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of, or method of accessing, each notice published regarding a social impact partnership project pursuant to this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8943-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of each feasibility study funded under this division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8944-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each State or local government that has entered into an agreement with the Secretary for a social impact partnership project, the website shall contain the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbaaf8945-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The outcome goals of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8946-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of each intervention in the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8947-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The target population that will be served by the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8948-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expected social benefits to participants who receive the intervention and others who may be impacted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf8949-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The detailed roles, responsibilities, and purposes of each Federal, State, or local government entity, intermediary, service provider, independent evaluator, investor, or other stakeholder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf894a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment terms, methodology used to calculate outcome payments, the payment schedule, and performance thresholds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf894b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf894c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project timeline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf894d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project eligibility criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf894e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The evaluation design.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbaaf894f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The metrics used to determine whether the proposed outcomes have been achieved and how these metrics are measured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8950-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the progress reports and the final reports relating to each social impact partnership project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbaaf8951-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1397n–10/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the savings to the Federal, State, and local government, on a program-by-program basis and in the aggregate, resulting from the successful completion of the social impact partnership project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbaaf8952-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XX, § 2061, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dE/tVIII/s50802/2"},"text":"Pub. L. 115–123, div. E, title VIII, § 50802(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/281"},"text":"132 Stat. 281","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
