{"tag":"section","attrib":{"id":"idc019086a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522"},"text":null,"children":[{"tag":"num","attrib":{"value":"16522"},"text":"§ 16522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Low-volume gas reservoir study","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idc019086b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a grant to an organization of oil and gas producing States, specifically those containing significant numbers of marginal oil and natural gas wells, for conducting an annual study of low-volume natural gas reservoirs. Such organization shall work with the State geologist of each State being studied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019086c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The studies under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc019086d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the status and location of marginal wells and gas reservoirs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019086e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gather the production information of these marginal wells and reservoirs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc019086f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimate the remaining producible reserves based on variable pipeline pressures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190870-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" locate low-pressure gathering facilities and pipelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190871-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend incentives which will enable the continued production of these resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190872-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce maps and literature to disseminate to States to promote conservation of natural gas reserves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190873-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the amount of natural gas that is being wasted through the practice of venting or flaring of natural gas produced in association with crude oil well production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190874-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Data development and analysis under this section shall be performed by an institution of higher education with GIS capabilities. If the organization receiving the grant under subsection (a) does not have GIS capabilities, such organization shall contract with one or more entities with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc0190875-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technological capabilities and resources to perform advanced image processing, GIS programming, and data analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190876-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the ability to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idc0190877-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process remotely sensed imagery with high spatial resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190878-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploy global positioning systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc0190879-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process and synthesize existing, variable-format gas well, pipeline, gathering facility, and reservoir data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019087a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create and query GIS databases with infrastructure location and attribute information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019087b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" write computer programs to customize relevant GIS software;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019087c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generate maps, charts, and graphs which summarize findings from data research for presentation to different audiences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idc019087d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deliver data in a variety of formats, including Internet Map Server for query and display, desktop computer display, and access through handheld personal digital assistants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc019087e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary for carrying out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idc019087f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,500,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idc0190880-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $450,000 for each of the fiscal years 2007 through 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idc0190881-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s16522/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “GIS” means geographic information systems technology that facilitates the organization and management of data with a geographic component.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idc0190882-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVIII/s1808"},"text":"Pub. L. 109–58, title XVIII, § 1808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1124"},"text":"119 Stat. 1124","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
