{"tag":"section","attrib":{"id":"idbb922090-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1862p–2"},"text":"§ 1862p–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships for innovation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb922091-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall carry out a program to award merit-reviewed, competitive grants to institutions of higher education to establish and to expand partnerships that promote innovation and increase the impact of research by developing tools and resources to connect new scientific discoveries to practical uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb922092-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb922093-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for funding under this section, an institution of higher education must propose establishment of a partnership that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb922094-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes at least one private sector entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include other institutions of higher education, public sector institutions, private sector entities, and nonprofit organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb922096-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting grant recipients under this section, the Director shall give priority to partnerships that include one or more institutions of higher education and at least one of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb922097-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A minority serving institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922098-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A primarily undergraduate institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb922099-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A 2-year institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb92209a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Proposals funded under this section shall seek—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb92209b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the impact of the most promising research at the institution or institutions of higher education that are members of the partnership through knowledge transfer or commercialization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92209c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the engagement of faculty and students across multiple disciplines and departments, including faculty and students in schools of business and other appropriate non-STEM fields and disciplines in knowledge transfer activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92209d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance education and mentoring of students and faculty in innovation and entrepreneurship through networks, courses, and development of best practices and curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92209e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen the culture of the institution or institutions of higher education to undertake and participate in activities related to innovation and leading to economic or social impact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb92209f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to broaden the participation of all types of institutions of higher education in activities to meet STEM workforce needs and promote innovation and knowledge transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220a0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build lasting partnerships with local and regional businesses, local and State governments, and other relevant entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220a1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting grant recipients under this section, the Director shall also consider the extent to which the applicants are able to demonstrate evidence of institutional support for, and commitment to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb9220a2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieving the goals of the program as described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220a3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expansion to an institution-wide program if the initial proposal is not for an institution-wide program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb9220a4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustaining any new innovation tools and resources generated from funding under this program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb9220a5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1862p–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds provided under this section may be used to construct or renovate a building or structure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb9220a6-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/tV/s508"},"text":"Pub. L. 111–358, title V, § 508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4008"},"text":"124 Stat. 4008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb9220a7-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb9220a8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idbb9220a9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the America COMPETES Reauthorization Act of 2010, also known as the America Creating Opportunities to Meaningfully Promote Excellence in Technology, Education, and Science Reauthorization Act of 2010, and also as part of the National Science Foundation Authorization Act of 2010, and not as part of the National Science Foundation Act of 1950 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb9220aa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbb9220ab-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of terms used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/358/s2"},"text":"section 2 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6621"},"text":"section 6621 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/111/358/s502"},"text":"section 502 of Pub. L. 111–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1862p"},"text":"section 1862p of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
