{"tag":"section","attrib":{"id":"idbfca4bf1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13632"},"text":null,"children":[{"tag":"num","attrib":{"value":"13632"},"text":"§ 13632.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for costs of providing service coordinators in certain federally assisted housing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfca4bf2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13632/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants under this section to owners of federally assisted housing projects described in subparagraphs (B), (C), (D), (E), (F), and (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641/2"},"text":"section 13641(2) of this title","children":[],"tail":". Any grant amounts shall be used for the costs of employing or otherwise retaining the services of one or more service coordinators under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13631"},"text":"section 13631 of this title","children":[],"tail":" to coordinate the provision of any services within the project for residents of the project who are elderly families and disabled families (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641"},"text":"section 13641 of this title","children":[],"tail":"). A service coordinator funded with a grant under this section for a project may provide services to low-income elderly or disabled families living in the vicinity of such project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfca4bf3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13632/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the form and manner of applications for grants under this section and for selection of applicants to receive such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfca4bf4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13632/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible project expense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any federally assisted housing project described in subparagraph (B), (C), (D), (E), (F), or (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641/2"},"text":"section 13641(2) of this title","children":[],"tail":" that does not receive a grant under this section, the cost of employing or otherwise retaining the services of one or more service coordinators under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13631"},"text":"section 13631 of this title","children":[],"tail":" and not more than 15 percent of the cost of providing services to the residents of the project shall be considered an eligible project expense, but only to the extent that amounts are available from project rent and other income for such costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfca4bf5-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550/tVI/s676"},"text":"Pub. L. 102–550, title VI, § 676","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3828"},"text":"106 Stat. 3828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/tVIII/s851/a"},"text":"Pub. L. 106–569, title VIII, § 851(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3023"},"text":"114 Stat. 3023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbfca4bf6-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbfca4bf7-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbfca4bf8-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s851/a/1"},"text":"Pub. L. 106–569, § 851(a)(1)","children":[],"tail":", substituted “certain federally assisted housing” for “multifamily housing assisted under National Housing Act” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s851/a/2"},"text":"Pub. L. 106–569, § 851(a)(2)","children":[],"tail":", substituted “subparagraphs (B), (C), (D), (E), (F), and (G) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641/2"},"text":"section 13641(2) of this title","children":[],"tail":"” for “subparagraphs (E) and (F) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641/2"},"text":"section 13641(2) of this title","children":[],"tail":"”, made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13631"},"text":"section 13631 of this title","children":[],"tail":", and inserted at end “A service coordinator funded with a grant under this section for a project may provide services to low-income elderly or disabled families living in the vicinity of such project.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s851/a/4"},"text":"Pub. L. 106–569, § 851(a)(4)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out heading and text of former subsec. (c). Text read as follows: “There are authorized to be appropriated for fiscal years 1993 and 1994 such sums as may be necessary for grants under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s851/a/4"},"text":"Pub. L. 106–569, § 851(a)(4)","children":[],"tail":", redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569/s851/a/3"},"text":"Pub. L. 106–569, § 851(a)(3)","children":[],"tail":", substituted “subparagraph (B), (C), (D), (E), (F), or (G) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641/2"},"text":"section 13641(2) of this title","children":[],"tail":"” for “subparagraph (E) or (F) of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13641/2"},"text":"section 13641(2) of this title","children":[],"tail":"” and made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s13631"},"text":"section 13631 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbfca4bf9-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbfca4bfa-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/569"},"text":"Pub. L. 106–569","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", unless effectiveness or applicability upon another date certain is specifically provided for, with provisions relating to effect of regulatory authority, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/569/s803"},"text":"section 803 of Pub. L. 106–569","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701q"},"text":"section 1701q of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
