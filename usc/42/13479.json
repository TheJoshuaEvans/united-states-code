{"tag":"section","attrib":{"id":"idbfc3214b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479"},"text":null,"children":[{"tag":"num","attrib":{"value":"13479"},"text":"§ 13479.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spark M. Matsunaga Renewable Energy and Ocean Technology Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbfc3214c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc3214d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the late Spark M. Matsunaga, United States Senator from Hawaii, was a longstanding champion of research and development of renewable energy, particularly wind and ocean energy, photovoltaics, and hydrogen fuels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3214e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it was Senator Matsunaga’s vision that renewable energy could provide a sustained source of non-polluting energy and that such forms of alternative energy might ultimately be employed in the production of liquid hydrogen as a transportation fuel and energy storage medium available as an energy export;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3214f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senator Matsunaga also believed that research on other aspects of renewable energy and ocean resources, such as advanced materials, could be crucial to full development of energy storage and conversion systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32150-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Keahole Point, Hawaii is particularly well-suited as a site to conduct renewable energy and associated marine research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32151-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the purpose of this section to establish the facilities and equipment located at Keahole Point, Hawaii as a cooperative research and development facility, to be known as the Spark M. Matsunaga Renewable Energy and Ocean Technology Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32152-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The facilities and equipment located at Keahole Point, Hawaii are established as the Spark M. Matsunaga Renewable Energy and Ocean Technology Center (in this section referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32153-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32154-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"October 24, 1992","children":[],"tail":", the Secretary may authorize a cooperative agreement with a qualified research institution to administer the Center."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32155-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of paragraph (1), a qualified research institution is a research institution located in the State of Hawaii that has demonstrated competence and will be the lead organization in the State in renewable energy and ocean technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc32156-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center may carry out research, development, educational, and technology transfer activities on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbfc32157-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32158-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy storage, including the production of hydrogen from renewable energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc32159-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials applications related to energy and marine environments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3215a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other environmental and ocean research concepts, including sea ranching and global climate change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbfc3215b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3215c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible for Federal funds under this section, the Center must provide funding in cash or in kind from non-Federal sources for each amount provided by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbfc3215d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s13479/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary for carrying out this section such sums as may be necessary, to be derived from sums authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s13471/c"},"text":"section 13471(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbfc5915e-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/486/tXXI/s2119"},"text":"Pub. L. 102–486, title XXI, § 2119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3080"},"text":"106 Stat. 3080","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
