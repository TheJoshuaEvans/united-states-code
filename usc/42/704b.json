{"tag":"section","attrib":{"id":"idb7edd095-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s704b"},"text":null,"children":[{"tag":"num","attrib":{"value":"704b"},"text":"§ 704b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonavailability of allotments after close of fiscal year","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No allotment for this or any succeeding fiscal year under such title V shall be available after the close of such fiscal year except as may be necessary to liquidate obligations incurred during such year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7edd096-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-05/ch575"},"text":"July 5, 1952, ch. 575","children":[],"tail":", title II, § 201, "},{"tag":"ref","attrib":{"href":"/us/stat/66/368"},"text":"66 Stat. 368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7edd097-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7edd098-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7edd099-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Such title V, referred to in text, means title V of act ","children":[{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", which is classified generally to this subchapter. For complete classification of title V to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7edd09a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1952-07-05"},"text":"July 5, 1952","children":[],"tail":", popularly known as the Federal Security Agency Appropriation Act, 1953, and is not a part of the Social Security Act which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
