{"tag":"section","attrib":{"id":"idb573a8e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s285g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"285g–2"},"text":"§ 285g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on intellectual disabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Institute shall conduct and support research and related activities into the causes, prevention, and treatment of intellectual disabilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb573a8e1-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title IV, § 450, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/158/s2"},"text":"Pub. L. 99–158, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-20"},"text":"Nov. 20, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/856"},"text":"99 Stat. 856","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/256/s2/f/3"},"text":"Pub. L. 111–256, § 2(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-05"},"text":"Oct. 5, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2644"},"text":"124 Stat. 2644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb573a8e2-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb573a8e3-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb573a8e4-3a70-11f1-ae07-e4213316b5fa"},"text":