{"tag":"section","attrib":{"id":"idb84f78e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320b–13"},"text":"§ 1320b–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social security account statements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb84f78ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision upon request","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning not later than ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", the Commissioner of Social Security shall provide upon the request of an eligible individual a social security account statement (hereinafter referred to as the “statement”)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each statement shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of wages paid to and self-employment income derived by the eligible individual as shown by the records of the Commissioner at the date of the request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the aggregate of the employer, employee, and self-employment contributions of the eligible individual for old-age, survivors, and disability insurance as shown by the records of the Commissioner on the date of the request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separate estimate of the aggregate of the employer, employee, and self-employment contributions of the eligible individual for hospital insurance as shown by the records of the Commissioner on the date of the request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the potential monthly retirement, disability, survivor, and auxiliary benefits payable on the eligible individual’s account together with a description of the benefits payable under the medicare program of subchapter XVIII; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an eligible individual described in paragraph (3)(C)(ii), an explanation, in language calculated to be understood by the average eligible individual, of the operation of the provisions under sections 402(k)(5) ","children":[{"tag":"ref","attrib":{"idref":"fn002716"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002716"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 415(a)(7) "},{"tag":"ref","attrib":{"idref":"fn002716"},"text":"1","children":[],"tail":" of this title and an explanation of the maximum potential effects of such provisions on the eligible individual’s monthly retirement, survivor, and auxiliary benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “eligible individual” means an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb84f78f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has a social security account number,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has attained age 25 or over, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb84f78f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb84f78f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has wages or net earnings from self-employment, or (ii) with respect to whom the Commissioner has information that the pattern of wages or self-employment income indicate a likelihood of noncovered employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to eligible individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner shall, to the maximum extent practicable, take such steps as are necessary to assure that eligible individuals are informed of the availability of the statement described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory provision of statements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" By not later than ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":", the Commissioner shall provide a statement to each eligible individual who has attained age 60 by "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"October 1, 1994","children":[],"tail":", and who is not receiving benefits under subchapter II and for whom a current mailing address can be determined through such methods as the Commissioner determines to be appropriate. In fiscal years 1995 through 1999 the Commissioner shall provide a statement to each eligible individual who attains age 60 in such fiscal years and who is not receiving benefits under subchapter II and for whom a current mailing address can be determined through such methods as the Commissioner determines to be appropriate. The Commissioner shall provide with each statement to an eligible individual notice that such statement is updated annually and is available upon request."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Beginning not later than ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", the Commissioner shall provide a statement on an annual basis to each eligible individual who is not receiving benefits under subchapter II and for whom a mailing address can be determined through such methods as the Commissioner determines to be appropriate. With respect to statements provided to eligible individuals who have not attained age 50, such statements need not include estimates of monthly retirement benefits. However, if such statements provided to eligible individuals who have not attained age 50 do not include estimates of retirement benefit amounts, such statements shall include a description of the benefits (including auxiliary benefits) that are available upon retirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb84f78fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure to governmental employees of effect of noncovered employment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb84f78fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any individual commencing employment on or after ","children":[{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":", in any agency or instrumentality of any State (or political subdivision thereof, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s418/b/2"},"text":"section 418(b)(2) of this title","children":[],"tail":") in a position in which service performed by the individual does not constitute “employment” as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s410"},"text":"section 410 of this title","children":[],"tail":", the head of the agency or instrumentality shall ensure that, prior to the date of the commencement of the individual’s employment in the position, the individual is provided a written notice setting forth an explanation, in language calculated to be understood by the average individual, of the maximum effect on computations of primary insurance amounts (under section 415(a)(7) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title) and the effect on benefit amounts (under section 402(k)(5) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title) of monthly periodic payments or benefits payable based on earnings derived in such service. Such notice shall be in a form which shall be prescribed by the Commissioner of Social Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb84f78fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1320b–13/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The written notice provided to an individual pursuant to paragraph (1) shall include a form which, upon completion and signature by the individual, would constitute certification by the individual of receipt of the notice. The agency or instrumentality providing the notice to the individual shall require that the form be completed and signed by the individual and submitted to the agency or instrumentality and to the pension, annuity, retirement, or similar fund or system established by the governmental entity involved responsible for paying the monthly periodic payments or benefits, before commencement of service with the agency or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb84f78fe-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"Aug. 14, 1935, ch. 531","children":[],"tail":", title XI, § 1143, formerly § 1142, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/239/tX/s10308"},"text":"Pub. L. 101–239, title X, § 10308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2485"},"text":"103 Stat. 2485","children":[],"tail":"; renumbered § 1143 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tV/s5111/a"},"text":"Pub. L. 101–508, title V, § 5111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-272"},"text":"104 Stat. 1388–272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/78/tVI/s605"},"text":"Pub. L. 105–78, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-13"},"text":"Nov. 13, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1521"},"text":"111 Stat. 1521","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/203/tIV"},"text":"Pub. L. 108–203, title IV","children":[],"tail":", §§ 419(a)–(c), 421, "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/533-535"},"text":"118 Stat. 533–535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb84f78ff-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb84f7900-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb84f7901-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s402/k"},"text":"section 402(k) of this title","children":[],"tail":", referred to in subsecs. (a)(2)(E) and (d)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/273/s2/a"},"text":"Pub. L. 118–273, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-05"},"text":"Jan. 5, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3232"},"text":"138 Stat. 3232","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s415/a"},"text":"section 415(a) of this title","children":[],"tail":", referred to in subsecs. (a)(2)(E) and (d)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/118/273/s3/a/1"},"text":"Pub. L. 118–273, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-05"},"text":"Jan. 5, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3232"},"text":"138 Stat. 3232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb84f7902-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s421/1"},"text":"Pub. L. 108–203, § 421(1)","children":[],"tail":", substituted “Commissioner of Social Security” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s421/2"},"text":"Pub. L. 108–203, § 421(2)","children":[],"tail":", substituted “Commissioner” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s419/b"},"text":"Pub. L. 108–203, § 419(b)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s419/a/1"},"text":"Pub. L. 108–203, § 419(a)(1)","children":[],"tail":", struck out “who” after “an individual” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s419/a/1"},"text":"Pub. L. 108–203, § 419(a)(1)","children":[],"tail":", inserted “who” before “has”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s419/a/2"},"text":"Pub. L. 108–203, § 419(a)(2)","children":[],"tail":", (3), designated existing provisions as cl. (i), inserted “who” before “has wages”, and inserted “, or” and cl. (ii) before period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s421/2"},"text":"Pub. L. 108–203, § 421(2)","children":[],"tail":", substituted “Commissioner” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/s419/c"},"text":"Pub. L. 108–203, § 419(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/78"},"text":"Pub. L. 105–78","children":[],"tail":" substituted “employer, employee,” for “employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s5111/a/2"},"text":"Pub. L. 101–508, § 5111(a)(2)","children":[],"tail":", substituted “an annual” for “a biennial”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb84f7903-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb84f7904-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/203/tIV/s419/d"},"text":"Pub. L. 108–203, title IV, § 419(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-03-02"},"text":"Mar. 2, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/534"},"text":"118 Stat. 534","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/203/tIV/s419/d"},"text":"“The amendments made by subsections (a) and (b) of this section [amending this section] shall apply with respect to social security account statements issued on or after ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
