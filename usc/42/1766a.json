{"tag":"section","attrib":{"id":"idbb64cf56-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1766a"},"text":"§ 1766a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meal supplements for children in afterschool care","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbb64cf57-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb64cf58-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to assist States through grants-in-aid and other means to provide meal supplements under a program organized primarily to provide care for children in afterschool care in eligible elementary and secondary schools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb64cf59-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible schools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term “eligible elementary and secondary schools” means schools that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb64cf5a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate school lunch programs under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb64cf5b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor afterschool care programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb64cf5c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate afterschool programs with an educational or enrichment purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb64cf5d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reimbursement may be provided under this section only for supplements served to school children who are not more than 18 years of age, except that the age limitation provided by this subsection shall not apply to a child described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1760/d/1/A"},"text":"section 1760(d)(1)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb64cf5e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbb64cf5f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" At-risk school children","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an eligible child who is participating in a program authorized under this section operated at a site located in a geographical area served by a school in which at least 50 percent of the children enrolled are certified as eligible to receive free or reduced price school meals under this chapter or the Child Nutrition Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.), a supplement provided under this section to the child shall be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbb64cf60-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursed at the rate at which free supplements are reimbursed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1766/c/3"},"text":"section 1766(c)(3) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbb64cf61-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served without charge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbb64cf62-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other school children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of an eligible child who is participating in a program authorized under this section at a site that is not described in paragraph (1), for the purposes of this section, the national average payment rate for supplements shall be equal to those established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1766/c/3"},"text":"section 1766(c)(3) of this title","children":[],"tail":" (as adjusted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1759a/a/3"},"text":"section 1759a(a)(3) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbb64cf63-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s1766a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of supplements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements that apply to the content of meal supplements served under child care food programs operated with assistance under this chapter shall apply to the content of meal supplements served under programs operated with assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbb64cf64-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-04/ch281/s17A"},"text":"June 4, 1946, ch. 281, § 17A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/147/tI/s106/a"},"text":"Pub. L. 101–147, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/885"},"text":"103 Stat. 885","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/336/tI/s108"},"text":"Pub. L. 105–336, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-31"},"text":"Oct. 31, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3153"},"text":"112 Stat. 3153","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbb64cf65-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbb64cf66-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbb64cf67-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Child Nutrition Act of 1966, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/642"},"text":"Pub. L. 89–642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-11"},"text":"Oct. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/885"},"text":"80 Stat. 885","children":[],"tail":", which is classified generally to chapter 13A (§ 1771 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"section 1771 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbb64cf68-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s108/a/1"},"text":"Pub. L. 105–336, § 108(a)(1)","children":[],"tail":", substituted “supplements under a program organized primarily to provide care for” for “supplements to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s108/a/2"},"text":"Pub. L. 105–336, § 108(a)(2)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C) which read as follows: “are participating in the child care food program under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1766"},"text":"section 1766 of this title","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1989-05-15"},"text":"May 15, 1989","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s108/b"},"text":"Pub. L. 105–336, § 108(b)","children":[],"tail":", substituted “served to school children who are not more than 18 years of age, except that the age limitation provided by this subsection shall not apply to a child described in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1760/d/1/A"},"text":"section 1760(d)(1)(A) of this title","children":[],"tail":".” for “served to children—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) who are not more than 12 years of age; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) in the case of children of migrant workers or children with handicaps, who are not more than 15 years of age.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336/s108/c"},"text":"Pub. L. 105–336, § 108(c)","children":[],"tail":", added par. (1), designated existing provisions as par. (2), inserted heading, and substituted “In the case of an eligible child who is participating in a program authorized under this section at a site that is not described in paragraph (1), for the purposes” for “For the purposes”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbb64cf69-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbb64cf6a-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/336"},"text":"Pub. L. 105–336","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"Oct. 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/336/s401"},"text":"section 401 of Pub. L. 105–336","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1755"},"text":"section 1755 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbb64cf6b-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/147/tI/s106/b"},"text":"Pub. L. 101–147, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-10"},"text":"Nov. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/886"},"text":"103 Stat. 886","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/147/tI/s106/b"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"1990-07-01"},"text":"July 1, 1990","children":[],"tail":", the Secretary of Agriculture shall issue final regulations to implement section 17A of the [Richard B. Russell] National School Lunch Act [this section] (as added by subsection (a) of this section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
