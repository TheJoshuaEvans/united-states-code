":{},"text":"This subchapter, referred to in text, was in the original “this subtitle”, meaning subtitle D of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3823"},"text":"106 Stat. 3823","children":[],"tail":", which enacted this subchapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1437f"},"text":"section 1437f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
