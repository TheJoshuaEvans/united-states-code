{"tag":"section","attrib":{"id":"idb6ac0216-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9"},"text":null,"children":[{"tag":"num","attrib":{"value":"300gg–9"},"text":"§ 300gg–9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6ac0217-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information by health plan issuers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In connection with the offering of any health insurance coverage to a small employer or an individual, a health insurance issuer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac0218-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make a reasonable disclosure to such employer, or individual, as applicable,,","children":[{"tag":"ref","attrib":{"idref":"fn002454"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002454"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" as part of its solicitation and sales materials, of the availability of information described in subsection (b), and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac0219-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request of such a ","children":[{"tag":"ref","attrib":{"idref":"fn002455"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002455"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “an”."}],"tail":" employer, or individual, as applicable,,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" provide such information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6ac021a-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information described","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6ac021b-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), with respect to a health insurance issuer offering health insurance coverage to a ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" employer, or individual, as applicable,,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" information described in this subsection is information concerning—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6ac021c-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of such coverage concerning issuer’s right to change premium rates and the factors that may affect changes in premium rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6ac021d-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits and premiums available under all health insurance coverage for which the employer, or individual, as applicable, is qualified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac021e-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information under this subsection shall be provided to employers, or individuals, as applicable, in a manner determined to be understandable by the average employer, or individual, as applicable,,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and shall be sufficient to reasonably inform employers, or individuals, as applicable, of their rights and obligations under the health insurance coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6ac021f-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300gg–9/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An issuer is not required under this section to disclose any information that is proprietary and trade secret information under applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6ac0220-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXVII, § 2709, formerly § 2713, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/tI/s102/a"},"text":"Pub. L. 104–191, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-21"},"text":"Aug. 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1966"},"text":"110 Stat. 1966","children":[],"tail":"; renumbered § 2733, renumbered § 2709, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tI"},"text":"Pub. L. 111–148, title I","children":[],"tail":", §§ 1001(3), 1563(c)(10), formerly § 1562(c)(10), title X, § 10107(b)(1), "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/130"},"text":"124 Stat. 130","children":[],"tail":", 268, 911.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb6ac0221-3a70-11f1-ae07-e4213316b5fa"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb6ac0222-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb6ac0223-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–13"},"text":"section 300gg–13 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148"},"text":"Pub. L. 111–148","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 2709 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg–8"},"text":"section 300gg–8 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb6ac0224-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2709 of act ","children":[{"tag":"date","attrib":{"date":"1944-07-01"},"text":"July 1, 1944","children":[],"tail":", was successively renumbered by subsequent acts and transferred, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s238h"},"text":"section 238h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb6ac0225-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/10/A"},"text":"Pub. L. 111–148, § 1563(c)(10)(A)","children":[],"tail":", formerly § 1562(c)(10)(A), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", in introductory provisions substituted “small employer or an individual” for “small employer”, in par. (1) inserted “, or individual, as applicable,” after “employer”, and in par. (2) substituted “employer, or individual, as applicable,” for “small employer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/10/B/i"},"text":"Pub. L. 111–148, § 1563(c)(10)(B)(i)","children":[],"tail":", formerly § 1562(c)(10)(B)(i), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", in introductory provisions substituted “employer, or individual, as applicable,” for “small employer”, in subpar. (A), inserted “and” at end, struck out subpars. (B) and (C) which related to provisions of coverage relating to renewability of coverage and preexisting condition exclusions, respectively, in subpar. (D), inserted “, or individual, as applicable,” after “employer”, and redesignated subpar. (D) as (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/148/s1563/c/10/B/ii"},"text":"Pub. L. 111–148, § 1563(c)(10)(B)(ii)","children":[],"tail":", formerly § 1562(c)(10)(B)(ii), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/s10107/b/1"},"text":"Pub. L. 111–148, § 10107(b)(1)","children":[],"tail":", substituted “employer, or individual, as applicable,” for “small employer” and “employers, or individuals, as applicable,” for “small employers” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb6ac0226-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb6ac0227-3a70-11f1-ae07-e4213316b5fa"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to group health plans, and health insurance coverage offered in connection with group health plans, for plan years beginning after ","children":[{"tag":"date","attrib":{"date":"1997-06-30"},"text":"June 30, 1997","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/191/s102/c"},"text":"section 102(c) of Pub. L. 104–191","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300gg"},"text":"section 300gg of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
