{"tag":"section","attrib":{"id":"idb6d227d2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"300ii–1"},"text":"§ 300ii–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lifespan respite care grants and cooperative agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb6d227d3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d227d4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand and enhance respite care services to family caregivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227d5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the statewide dissemination and coordination of respite care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227d6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, supplement, or improve access and quality of respite care services to family caregivers, thereby reducing family caregiver strain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d227d7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (e), the Secretary is authorized to award grants or cooperative agreements for the purposes described in subsection (a) to eligible State agencies for which an application is submitted pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d227d8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal lifespan approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall work in cooperation with the National Family Caregiver Support Program of the Administration on Aging and other respite care programs within the Department of Health and Human Services to ensure coordination of respite care services for family caregivers of children and adults with special needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d227d9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d227da-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Governor desiring the eligible State agency of his or her State to receive a grant or cooperative agreement under this section shall submit an application on behalf of such agency to the Secretary at such time, in such manner, and containing such information as the Secretary shall require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227db-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under this section shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d227dc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the eligible State agency’s—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d227dd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ability to work with other State and community-based agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227de-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding of respite care and family caregiver issues across all age groups, disabilities, and chronic conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227df-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capacity to ensure meaningful involvement of family members, family caregivers, and care recipients;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227e0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the population of family caregivers to whom respite care information or services will be provided or for whom respite care workers and volunteers will be recruited and trained, a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d227e1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of family caregivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and nature of the respite care needs of that population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing respite care services for that population, including numbers of family caregivers being served and extent of unmet need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing methods or systems to coordinate respite care information and services to the population at the State and local level and extent of unmet need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how respite care information dissemination and coordination, respite care services, respite care worker and volunteer recruitment and training programs, or training programs for family caregivers that assist such family caregivers in making informed decisions about respite care services will be provided using grant or cooperative agreement funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for administration, collaboration, and coordination of the proposed respite care activities with other related services or programs offered by public or private, nonprofit entities, including area agencies on aging;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the population, including family caregivers, care recipients, and relevant public or private agencies, will participate in the planning and implementation of the proposed respite care activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the proposed respite care activities will make use, to the maximum extent feasible, of other Federal, State, and local funds, programs, contributions, other forms of reimbursements, personnel, and facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227e9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respite care services available to family caregivers in the eligible State agency’s State or locality, including unmet needs and how the eligible State agency’s plan for use of funds will improve the coordination and distribution of respite care services for family caregivers of children and adults with special needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227ea-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria used to identify family caregivers eligible for respite care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227eb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the quality and safety of any respite care services provided will be monitored, including methods to ensure that respite care workers and volunteers are appropriately screened and possess the necessary skills to care for the needs of the care recipient in the absence of the family caregiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227ec-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results expected from proposed respite care activities and the procedures to be used for evaluating those results;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227ed-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that, where appropriate, the eligible State agency will have a system for maintaining the confidentiality of care recipient and family caregiver records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227ee-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a memorandum of agreement regarding the joint responsibility for the eligible State agency’s lifespan respite program between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d227ef-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible State agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227f0-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/d/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public or private nonprofit statewide respite coalition or organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d227f1-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority; considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When awarding grants or cooperative agreements under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d227f2-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give priority to eligible State agencies that the Secretary determines show the greatest likelihood of implementing or enhancing lifespan respite care statewide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d227f3-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give consideration to eligible State agencies that are building or enhancing the capacity of their long-term care systems to respond to the comprehensive needs, including respite care needs, of their residents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d227f4-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant or cooperative agreement funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d227f5-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d227f6-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible State agency awarded a grant or cooperative agreement under this section shall use all or part of the funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d227f7-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop or enhance lifespan respite care at the State and local levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227f8-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide respite care services for family caregivers caring for children or adults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227f9-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train and recruit respite care workers and volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227fa-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information to caregivers about available respite and support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227fb-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist caregivers in gaining access to such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d227fc-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each eligible State agency awarded a grant or cooperative agreement under this section may use part of the funds for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb6d227fd-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for family caregivers to assist such family caregivers in making informed decisions about respite care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227fe-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other services essential to the provision of respite care as the Secretary may specify; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb6d227ff-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and education for new caregivers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d22800-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcontracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each eligible State agency awarded a grant or cooperative agreement under this section may carry out the activities described in paragraph (1) directly or by grant to, or contract with, public or private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d22801-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb6d22802-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to the costs of the activities to be carried out under paragraph (1), a condition for the receipt of a grant or cooperative agreement under this section is that the eligible State agency agrees to make available (directly or through donations from public or private entities) non-Federal contributions toward such costs in an amount that is not less than 25 percent of such costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb6d22803-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount contributed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal contributions required by subparagraph (A) may be in cash or in kind, fairly evaluated, including plant, equipment, or services. Amounts provided by the Federal Government, or services assisted or subsidized to any significant extent by the Federal Government, may not be included in determining the amount of such non-Federal contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d22804-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of grants or cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb6d22805-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants or cooperative agreements under this section for terms that do not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb6d22806-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may renew a grant or cooperative agreement under this section at the end of the term of the grant or cooperative agreement determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb6d22807-3a70-11f1-ae07-e4213316b5fa","identifier":"/us/usc/t42/s300ii–1/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall be used to supplement and not supplant other Federal, State, and local funds available for respite care services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb6d22808-3a70-11f1-ae07-e4213316b5fa"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373"},"text":"July 1, 1944, ch. 373","children":[],"tail":", title XXIX, § 2902, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/442/s2"},"text":"Pub. L. 109–442, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3292"},"text":"120 Stat. 3292","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
